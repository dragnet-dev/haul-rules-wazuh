<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3837 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 974ced67-3bd5-5ed6-b221-ab66097e21ac -->
  <rule id="492813" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3837 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>