<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2833 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 5b00326c-aae4-514e-ba40-4ca8b3046c86 -->
  <rule id="200326" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2833 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>