<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2232 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 638093c5-900b-5723-bd2d-d201661e6ff2 -->
  <rule id="409500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2232 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>