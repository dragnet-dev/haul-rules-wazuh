<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3113 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: bcd20049-bd09-5610-beb9-436b77605f43 -->
  <rule id="421200" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3113 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>