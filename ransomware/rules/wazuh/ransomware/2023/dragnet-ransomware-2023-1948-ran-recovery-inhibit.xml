<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1948 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: edbd7fcf-229a-5392-8c30-d2aab6ea10e5 -->
  <rule id="837887" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1948 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>