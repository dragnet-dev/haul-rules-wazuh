<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1989 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 496f91a3-4609-5346-956b-ea0c2d524b32 -->
  <rule id="223066" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1989 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>