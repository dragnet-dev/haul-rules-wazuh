<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2233 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 220605fa-9ba0-5ab2-9014-276114b00eae -->
  <rule id="929695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2233 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>