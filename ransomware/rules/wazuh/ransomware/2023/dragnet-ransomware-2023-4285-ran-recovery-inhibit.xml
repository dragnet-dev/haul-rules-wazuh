<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4285 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: d076c6fa-8fc8-561e-aede-92e2becd6151 -->
  <rule id="392286" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4285 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>