<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2885 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 3fcb776e-4f76-5d48-907b-84e1621396bd -->
  <rule id="833177" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2885 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>