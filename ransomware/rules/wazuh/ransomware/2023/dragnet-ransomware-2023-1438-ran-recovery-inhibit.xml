<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1438 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1b37bd75-0987-543f-84ef-9d324202a4d1 -->
  <rule id="808617" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1438 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>