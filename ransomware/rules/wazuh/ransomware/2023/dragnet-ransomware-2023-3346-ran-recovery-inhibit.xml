<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3346 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: ca0ca19c-88a6-573f-bd81-8729647adc40 -->
  <rule id="773221" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3346 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
