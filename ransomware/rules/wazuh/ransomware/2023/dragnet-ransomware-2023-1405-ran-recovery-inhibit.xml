<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1405 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 4cd70fd4-e109-516e-8815-40215009294f -->
  <rule id="267535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1405 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>