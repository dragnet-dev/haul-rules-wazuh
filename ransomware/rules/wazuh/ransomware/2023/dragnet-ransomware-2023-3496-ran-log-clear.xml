<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3496 — Event Log Clearing (darkrace) | Status: experimental | Sigma ID: 29331a2d-2c25-588f-8752-d93b3561c9e0 -->
  <rule id="293062" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3496 — Event Log Clearing (darkrace)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>