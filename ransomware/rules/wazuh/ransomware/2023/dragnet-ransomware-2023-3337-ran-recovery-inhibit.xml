<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3337 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 4a37c0a5-1a14-5465-8755-513393971eb8 -->
  <rule id="390040" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3337 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>