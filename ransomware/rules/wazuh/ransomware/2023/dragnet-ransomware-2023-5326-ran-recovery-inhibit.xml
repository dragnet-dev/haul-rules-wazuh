<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5326 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f9a2d199-e565-5f3c-8c59-b32c1c931954 -->
  <rule id="586851" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5326 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>