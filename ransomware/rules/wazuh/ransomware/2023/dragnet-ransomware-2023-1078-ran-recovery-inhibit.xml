<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1078 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d1c577ae-3bee-5c16-868c-0c3958fd35d7 -->
  <rule id="408577" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1078 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>