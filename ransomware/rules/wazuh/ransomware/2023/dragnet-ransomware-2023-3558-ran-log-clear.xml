<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3558 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: 6537d4d7-9c55-5b2e-b0dc-78b0a8b4d26b -->
  <rule id="246054" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3558 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>