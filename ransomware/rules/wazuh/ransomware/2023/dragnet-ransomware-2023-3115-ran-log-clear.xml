<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3115 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: f2b64ca6-2f41-5d39-87f3-92e44f8995e1 -->
  <rule id="409836" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3115 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>