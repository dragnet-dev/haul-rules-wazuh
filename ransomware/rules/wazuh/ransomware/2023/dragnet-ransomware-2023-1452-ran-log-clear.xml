<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1452 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 56c2fc3f-f4cb-5daf-9f00-a0dbd5c802bc -->
  <rule id="625244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1452 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>