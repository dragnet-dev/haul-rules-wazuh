<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2570 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a08f413e-9cfe-5abb-89c8-c63b1d1aec70 -->
  <rule id="814341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2570 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>