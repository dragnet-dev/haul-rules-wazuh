<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0629 — Recovery Inhibition (siegedsec) | Status: experimental | Sigma ID: 2fbe2c2a-7c99-5287-af6e-6a5e5639eb4c -->
  <rule id="255564" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0629 — Recovery Inhibition (siegedsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>