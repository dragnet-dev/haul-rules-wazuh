<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3973 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 4772637d-6ae4-553e-a029-b7225cb5dc6a -->
  <rule id="372637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3973 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>