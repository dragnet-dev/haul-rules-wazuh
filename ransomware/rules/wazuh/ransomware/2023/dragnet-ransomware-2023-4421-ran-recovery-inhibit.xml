<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4421 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 06d1d563-5f89-5b75-a9be-7b835fd62a3d -->
  <rule id="946956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4421 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>