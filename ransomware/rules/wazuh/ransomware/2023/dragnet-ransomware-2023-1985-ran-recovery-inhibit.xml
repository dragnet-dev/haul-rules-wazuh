<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1985 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 53193501-7efa-51b0-a99d-a5a23a4361dc -->
  <rule id="919350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1985 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>