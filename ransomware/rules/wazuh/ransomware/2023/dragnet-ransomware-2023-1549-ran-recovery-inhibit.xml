<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1549 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 12bca5d7-ef84-5ee3-a2b8-6e081d3c2087 -->
  <rule id="347293" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1549 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>