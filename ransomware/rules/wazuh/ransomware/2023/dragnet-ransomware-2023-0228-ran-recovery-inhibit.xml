<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0228 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ca8ceb97-1068-583c-bfda-2da8737ff342 -->
  <rule id="309995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0228 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>