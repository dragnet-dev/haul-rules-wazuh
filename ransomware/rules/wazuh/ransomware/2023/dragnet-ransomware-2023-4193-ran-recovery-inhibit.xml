<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4193 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 2e5ba2e1-9795-5caa-82f2-304f076706f1 -->
  <rule id="392262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4193 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>