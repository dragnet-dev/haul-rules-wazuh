<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5108 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8ce7389b-7fcf-5238-9488-2cac67ca272d -->
  <rule id="554738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5108 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>