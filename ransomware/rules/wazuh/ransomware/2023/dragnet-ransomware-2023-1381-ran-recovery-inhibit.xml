<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1381 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 7ae8fb52-af58-5661-99d8-13f261160f47 -->
  <rule id="635259" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1381 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>