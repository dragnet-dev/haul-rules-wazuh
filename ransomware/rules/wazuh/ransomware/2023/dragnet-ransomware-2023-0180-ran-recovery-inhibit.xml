<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0180 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 2dfd917e-9f79-5be6-9ae5-21b003a2ae10 -->
  <rule id="377391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0180 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>