<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4735 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: cf7ca803-a5a3-5358-8c1b-69c9b481c8cd -->
  <rule id="919148" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4735 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>