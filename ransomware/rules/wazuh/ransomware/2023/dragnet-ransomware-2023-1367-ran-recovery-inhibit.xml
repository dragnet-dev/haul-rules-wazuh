<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1367 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: d0bbdb77-08f4-5ad9-ad65-869390e7f6ac -->
  <rule id="567771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1367 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>