<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1456 — Recovery Inhibition (siegedsec) | Status: experimental | Sigma ID: eb8bc16e-e8fd-5f14-853c-ec41391abb7b -->
  <rule id="738361" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1456 — Recovery Inhibition (siegedsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>