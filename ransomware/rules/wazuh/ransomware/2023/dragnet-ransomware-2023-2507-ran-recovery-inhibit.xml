<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2507 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b01201d9-ea9f-570f-a798-710bd4cc0f92 -->
  <rule id="301201" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2507 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>