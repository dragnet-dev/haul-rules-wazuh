<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3613 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 515450d5-bf1b-524d-b01c-4764488a6093 -->
  <rule id="247213" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3613 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>