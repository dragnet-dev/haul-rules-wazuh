<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0425 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2bfc73eb-2b3c-565b-94ff-9308c628ec49 -->
  <rule id="326073" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0425 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>