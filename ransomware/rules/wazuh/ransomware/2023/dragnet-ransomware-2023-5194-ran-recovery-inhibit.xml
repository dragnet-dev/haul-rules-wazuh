<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5194 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 40347273-6f8c-500b-a403-edec08cf3739 -->
  <rule id="534727" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5194 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>