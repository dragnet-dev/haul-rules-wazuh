<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4920 — Event Log Clearing (8base) | Status: experimental | Sigma ID: 40be7a0e-e41c-5d23-8a7c-05ad5d32e7fc -->
  <rule id="868922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4920 — Event Log Clearing (8base)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>