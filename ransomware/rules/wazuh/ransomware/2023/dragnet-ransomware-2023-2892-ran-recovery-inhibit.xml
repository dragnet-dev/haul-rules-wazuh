<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2892 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 50438c4e-61c2-55ae-b5a0-8d63c51306a0 -->
  <rule id="970204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2892 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>