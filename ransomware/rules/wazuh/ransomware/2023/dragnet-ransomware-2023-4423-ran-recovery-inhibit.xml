<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4423 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 7c7ec740-bb76-574a-ad89-227951963b54 -->
  <rule id="594687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4423 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>