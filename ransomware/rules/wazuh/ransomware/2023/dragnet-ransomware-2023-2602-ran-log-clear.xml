<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2602 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 555a6e3d-3d32-5a78-b22e-9e6c08b38c62 -->
  <rule id="622510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2602 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>