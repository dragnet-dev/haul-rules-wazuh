<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2476 — Event Log Clearing (royal) | Status: experimental | Sigma ID: b1d773b5-b4b9-5521-9ba0-bfd88f9f4e7c -->
  <rule id="989773" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2476 — Event Log Clearing (royal)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>