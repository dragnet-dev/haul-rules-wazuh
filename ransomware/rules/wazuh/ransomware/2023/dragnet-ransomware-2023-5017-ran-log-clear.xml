<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5017 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: d78e72fc-9f6f-540a-b3d3-9ea9c9a9acf1 -->
  <rule id="506272" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5017 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>