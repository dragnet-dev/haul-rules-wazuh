<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1337 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b3d592a2-b56f-57d1-a53c-2d7530f1648e -->
  <rule id="121592" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1337 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>