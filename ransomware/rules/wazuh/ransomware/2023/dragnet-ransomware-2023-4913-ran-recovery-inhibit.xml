<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4913 — Recovery Inhibition (medusa) | Status: deprecated | Sigma ID: 745dace5-5183-5c8e-a43b-a09351ed6634 -->
  <rule id="455020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4913 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>