<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3254 — Recovery Inhibition (ransomed) | Status: experimental | Sigma ID: d13e4202-2533-590d-b2fd-8dd26a192f0a -->
  <rule id="402242" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3254 — Recovery Inhibition (ransomed)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>