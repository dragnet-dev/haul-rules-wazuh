<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3420 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 74701f9f-b1be-5766-a175-b190a9ba0aa2 -->
  <rule id="395231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3420 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>