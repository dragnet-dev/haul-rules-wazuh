<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4967 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 2f469c08-249d-5898-926d-b2c62d13286b -->
  <rule id="495160" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4967 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>