<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4954 — Recovery Inhibition (ransomed) | Status: experimental | Sigma ID: fffef789-2ed3-5876-bef2-ef7277fce0bd -->
  <rule id="248559" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4954 — Recovery Inhibition (ransomed)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>