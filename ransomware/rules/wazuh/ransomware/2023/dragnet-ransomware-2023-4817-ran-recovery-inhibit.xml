<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4817 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 8061443c-3f49-5966-8012-53e5d7d3b9bc -->
  <rule id="961443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4817 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>