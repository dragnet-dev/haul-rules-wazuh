<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2540 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: b851561b-ec63-5427-99ea-a1af3dc0de00 -->
  <rule id="385156" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2540 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>