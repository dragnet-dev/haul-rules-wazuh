<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0025 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: c4edb482-972b-50cf-994d-8ace147dfaf1 -->
  <rule id="717074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0025 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>