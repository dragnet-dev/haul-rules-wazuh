<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3798 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: 8946f434-52c8-595e-9ec3-560206e1e907 -->
  <rule id="631514" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3798 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>