<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1645 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b2816b86-e51d-52fe-996d-2adc66611923 -->
  <rule id="105067" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1645 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>