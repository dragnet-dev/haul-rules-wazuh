<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4051 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: fcc0cafc-38cc-5221-80e4-bf1b48444a6f -->
  <rule id="552842" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4051 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>