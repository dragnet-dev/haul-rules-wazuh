<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4612 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c60b70a8-9a27-50aa-82f1-fa8729e7f54c -->
  <rule id="317170" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4612 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>