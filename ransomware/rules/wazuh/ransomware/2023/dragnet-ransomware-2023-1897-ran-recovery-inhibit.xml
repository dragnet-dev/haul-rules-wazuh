<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1897 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 927e679a-1899-5e2c-947d-7fce291fc539 -->
  <rule id="684667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1897 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>