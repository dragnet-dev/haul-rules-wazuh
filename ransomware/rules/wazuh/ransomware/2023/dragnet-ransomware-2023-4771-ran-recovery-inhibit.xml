<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4771 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 55e3b2f0-5c5e-59a3-ab8d-36abba21df95 -->
  <rule id="630992" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4771 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>