<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4820 — Event Log Clearing (arvinclub) | Status: deprecated | Sigma ID: 5f0d2396-44c7-552b-ac51-a328ab2d9861 -->
  <rule id="721323" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4820 — Event Log Clearing (arvinclub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>