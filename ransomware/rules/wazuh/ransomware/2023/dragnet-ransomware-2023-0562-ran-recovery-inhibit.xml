<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0562 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5cfe22fc-c940-5ab7-944c-978e15e9d659 -->
  <rule id="680622" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0562 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>