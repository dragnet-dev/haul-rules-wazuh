<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0449 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7f772eda-56ea-543a-8f58-82e80472f830 -->
  <rule id="344366" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0449 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>