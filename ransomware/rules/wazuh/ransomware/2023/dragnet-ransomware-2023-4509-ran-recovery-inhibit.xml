<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4509 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: be01d204-02a3-5d13-a8e4-84b902ffa798 -->
  <rule id="440292" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4509 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>