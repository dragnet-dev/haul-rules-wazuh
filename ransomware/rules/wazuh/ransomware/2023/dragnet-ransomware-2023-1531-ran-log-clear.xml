<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1531 — Event Log Clearing (ransomhouse) | Status: deprecated | Sigma ID: 16c5ee31-44a3-5d10-a16e-c77c8cd9b781 -->
  <rule id="675983" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1531 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>