<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4503 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 1f7141d4-5fa8-5eaa-b9b2-0c4447d02490 -->
  <rule id="674269" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4503 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>