<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4203 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 0b0c51fa-31fc-55b9-a886-4e70e6d6e391 -->
  <rule id="236031" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4203 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>