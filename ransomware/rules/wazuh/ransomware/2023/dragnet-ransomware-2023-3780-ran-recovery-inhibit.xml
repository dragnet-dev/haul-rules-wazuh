<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3780 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 3f274513-5fb1-57c5-b8ab-38622086ca2c -->
  <rule id="127451" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3780 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>