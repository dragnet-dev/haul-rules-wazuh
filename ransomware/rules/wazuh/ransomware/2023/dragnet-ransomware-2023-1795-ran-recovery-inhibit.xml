<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1795 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 5049aac7-aa99-50c0-ae78-99cfbeaa2293 -->
  <rule id="492714" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1795 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
