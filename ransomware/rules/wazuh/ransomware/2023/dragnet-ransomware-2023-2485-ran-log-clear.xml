<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2485 — Event Log Clearing (ransomed) | Status: experimental | Sigma ID: 87312154-0789-50dd-9fa5-c0980273e8a6 -->
  <rule id="731215" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2485 — Event Log Clearing (ransomed)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>