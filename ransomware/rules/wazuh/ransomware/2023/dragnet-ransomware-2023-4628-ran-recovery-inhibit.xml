<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4628 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6323908e-b532-5a46-902b-d41b04162a82 -->
  <rule id="123908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4628 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>