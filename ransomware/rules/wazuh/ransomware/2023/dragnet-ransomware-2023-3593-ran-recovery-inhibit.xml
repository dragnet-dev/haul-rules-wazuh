<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3593 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 76408ecb-649d-5862-86c3-9564238755b8 -->
  <rule id="422542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3593 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>