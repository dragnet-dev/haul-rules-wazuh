<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2763 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: aa7f121a-676d-50c1-92d2-a8260f46b8d5 -->
  <rule id="132712" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2763 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>