<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1068 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 5ec3d4bf-079f-58e9-a000-363a6cb5a77f -->
  <rule id="726214" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1068 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>