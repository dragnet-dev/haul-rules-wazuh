<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5263 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 7e85c673-00a1-533f-adf7-223c42652793 -->
  <rule id="329726" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5263 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>