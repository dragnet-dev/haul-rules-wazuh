<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3746 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a700c137-8541-5b65-9bd9-1e28564196db -->
  <rule id="912121" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3746 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>