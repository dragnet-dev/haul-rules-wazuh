<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2568 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 06dbe75c-e9b6-5200-8505-ec131b7104e5 -->
  <rule id="209475" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2568 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>