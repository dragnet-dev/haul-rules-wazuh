<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4346 — Recovery Inhibition (cuba) | Status: deprecated | Sigma ID: bb435191-7a79-5dfa-a8b2-02d2201011ea -->
  <rule id="174351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4346 — Recovery Inhibition (cuba)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
