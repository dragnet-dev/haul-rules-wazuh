<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3176 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6555f734-4536-5ddb-8768-e1f815801233 -->
  <rule id="248957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3176 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>