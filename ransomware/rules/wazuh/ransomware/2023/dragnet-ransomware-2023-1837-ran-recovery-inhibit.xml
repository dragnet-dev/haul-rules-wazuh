<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1837 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 5b5a4433-7885-5e91-8320-96bb4fa04b6a -->
  <rule id="665044" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1837 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>