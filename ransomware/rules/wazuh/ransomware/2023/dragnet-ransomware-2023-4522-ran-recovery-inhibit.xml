<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4522 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: c01c1e1a-64cc-5c86-910b-9d436548f716 -->
  <rule id="476510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4522 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>