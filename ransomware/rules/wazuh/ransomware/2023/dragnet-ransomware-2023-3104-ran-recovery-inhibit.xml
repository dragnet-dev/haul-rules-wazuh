<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3104 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: c95e115c-9df4-5dfe-97a7-9b54033305e0 -->
  <rule id="373411" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3104 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>