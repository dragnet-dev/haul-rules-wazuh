<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4942 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 78465b95-cfb0-5558-bda9-5b794c87d805 -->
  <rule id="455451" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4942 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>