<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3197 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c5d6ee06-f795-5651-940a-19d47c9d76c7 -->
  <rule id="755054" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3197 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>