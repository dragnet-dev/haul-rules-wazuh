<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1622 — Recovery Inhibition (thegentlemen) | Status: experimental | Sigma ID: c879019f-8ec5-5dcb-9437-46d86a526aa8 -->
  <rule id="487901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1622 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>