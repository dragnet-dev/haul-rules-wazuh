<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2062 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: 64025760-42d2-5b2f-92a9-c9c74e210e01 -->
  <rule id="202576" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2062 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
