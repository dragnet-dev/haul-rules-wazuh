<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2189 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 0c3b317f-55d9-5a45-b6ac-39aaec7e8c9c -->
  <rule id="279317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2189 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>