<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1072 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: 5b3a533d-82c7-532e-9e97-e45e02c210d9 -->
  <rule id="661853" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1072 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>