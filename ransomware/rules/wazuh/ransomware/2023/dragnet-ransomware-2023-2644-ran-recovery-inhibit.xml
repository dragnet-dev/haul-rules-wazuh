<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2644 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 28ccd82b-3398-52de-843a-1aa43c5e34cc -->
  <rule id="379658" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2644 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>