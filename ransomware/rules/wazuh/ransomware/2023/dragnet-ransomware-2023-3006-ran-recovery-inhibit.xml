<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3006 — Recovery Inhibition (dunghill) | Status: experimental | Sigma ID: e0402814-364a-55af-a73a-22a4f15863d6 -->
  <rule id="604028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3006 — Recovery Inhibition (dunghill)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>