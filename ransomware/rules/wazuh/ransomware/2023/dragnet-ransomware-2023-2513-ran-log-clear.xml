<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2513 — Event Log Clearing (0mega) | Status: deprecated | Sigma ID: 48a3ee2f-380c-5d96-8f23-d05177318cc8 -->
  <rule id="292686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2513 — Event Log Clearing (0mega)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>