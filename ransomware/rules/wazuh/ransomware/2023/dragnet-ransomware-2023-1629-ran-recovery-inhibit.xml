<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1629 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9bb54403-e3fe-5771-b281-de4fa6f273e2 -->
  <rule id="791544" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1629 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>