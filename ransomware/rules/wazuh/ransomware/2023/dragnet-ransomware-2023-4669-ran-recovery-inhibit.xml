<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4669 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3e478c96-da53-56ae-80b4-5eb68c8333c3 -->
  <rule id="196609" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4669 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>