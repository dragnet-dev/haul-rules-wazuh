<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1996 — Recovery Inhibition (karakurt) | Status: experimental | Sigma ID: 934e8f0d-77e8-5dc9-8906-e1e85bb687ab -->
  <rule id="693423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1996 — Recovery Inhibition (karakurt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>