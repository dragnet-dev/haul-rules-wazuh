<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4957 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e482c7b2-5c73-5c38-952c-44bbc2e67e5d -->
  <rule id="617247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4957 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>