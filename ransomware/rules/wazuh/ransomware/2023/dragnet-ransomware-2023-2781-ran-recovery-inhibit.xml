<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2781 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 1933535b-8f7d-59d4-a0b0-1a8937f1946c -->
  <rule id="233535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2781 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>