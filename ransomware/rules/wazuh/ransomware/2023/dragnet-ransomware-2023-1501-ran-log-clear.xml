<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1501 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: 4e2c4fbf-0e79-568f-90eb-93b7499fefd4 -->
  <rule id="303919" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1501 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>