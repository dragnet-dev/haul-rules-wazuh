<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1241 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 4f9cd172-ec4c-512d-b47d-5275c7aa4434 -->
  <rule id="347491" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1241 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
