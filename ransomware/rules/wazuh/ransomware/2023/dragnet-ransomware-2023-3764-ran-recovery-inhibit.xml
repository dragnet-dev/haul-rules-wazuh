<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3764 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c9e1100f-c320-58bd-8002-9aa291576648 -->
  <rule id="378110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3764 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>