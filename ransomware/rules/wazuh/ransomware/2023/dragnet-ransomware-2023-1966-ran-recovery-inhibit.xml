<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1966 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: b2b917b1-6e95-5469-8a53-d4c7b384df8b -->
  <rule id="103917" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1966 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>