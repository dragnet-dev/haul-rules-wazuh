<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2589 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b6b3d762-d96f-5667-928e-f2c4ccb3eb0a -->
  <rule id="387817" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2589 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>