<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1675 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7a77230f-d192-51aa-b63d-f177c2c72e67 -->
  <rule id="427723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1675 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>