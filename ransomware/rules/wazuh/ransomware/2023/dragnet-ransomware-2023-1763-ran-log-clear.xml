<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1763 — Event Log Clearing (darkrace) | Status: experimental | Sigma ID: cff56dec-93f3-5333-b8fa-208f14712cb6 -->
  <rule id="924109" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1763 — Event Log Clearing (darkrace)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>