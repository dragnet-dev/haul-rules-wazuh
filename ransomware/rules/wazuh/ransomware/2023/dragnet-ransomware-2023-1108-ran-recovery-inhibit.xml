<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1108 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3ea5fc35-2306-521f-bd5b-24794280c780 -->
  <rule id="866652" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1108 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>