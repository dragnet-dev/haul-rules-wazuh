<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1290 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 2903d339-0f3b-5918-a348-6e661255a319 -->
  <rule id="246133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1290 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>