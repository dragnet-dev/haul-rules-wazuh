<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4113 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 2a3a3a7f-fda8-5e16-bfae-ec0d2d2b2c53 -->
  <rule id="284538" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4113 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>