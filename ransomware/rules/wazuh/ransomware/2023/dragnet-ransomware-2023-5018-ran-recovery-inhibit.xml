<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5018 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 9b916755-4ecb-59e5-a502-9de295ad2e82 -->
  <rule id="759167" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5018 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>