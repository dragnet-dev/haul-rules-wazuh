<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4842 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9684965b-987b-5335-9009-080764dbc05b -->
  <rule id="784965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4842 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>