<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4012 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 699d9cdb-560a-562a-84b1-44d5b32d222f -->
  <rule id="991676" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4012 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>