<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2469 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 44375bc0-877e-5aff-8244-0b8f24d3b8fa -->
  <rule id="660188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2469 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>