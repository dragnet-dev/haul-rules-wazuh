<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2378 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5e5e3bc6-8e7d-5b64-9968-f1836e31ac99 -->
  <rule id="721499" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2378 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>