<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2386 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: afbea678-a8c6-5424-9ca6-148de26f996f -->
  <rule id="998506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2386 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>