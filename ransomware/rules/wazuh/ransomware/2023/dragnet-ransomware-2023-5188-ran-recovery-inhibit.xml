<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5188 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 99abc593-7364-552e-b46a-36d6b8b813ad -->
  <rule id="582525" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5188 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>