<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0661 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 844929bb-8e12-5275-8ff7-e33cbecc0fd5 -->
  <rule id="118875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0661 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>