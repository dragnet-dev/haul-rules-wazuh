<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1918 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3a15f6e1-2785-5768-81a7-5c8e9a3e9cd3 -->
  <rule id="588910" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1918 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>