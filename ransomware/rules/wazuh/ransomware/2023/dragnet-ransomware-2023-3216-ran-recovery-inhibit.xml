<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3216 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 6b9276d9-35b0-52af-88e7-c3c8897f8757 -->
  <rule id="279276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3216 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>