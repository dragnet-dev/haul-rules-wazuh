<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1193 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: aa9dd7c2-4fa1-5a16-890b-8a1440e5b4d7 -->
  <rule id="877257" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1193 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>