<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1433 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b3b78d3f-eabe-5499-85c3-56cce513f42f -->
  <rule id="311661" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1433 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>