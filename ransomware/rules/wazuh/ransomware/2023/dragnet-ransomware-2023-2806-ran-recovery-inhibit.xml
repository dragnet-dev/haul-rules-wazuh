<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2806 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: f168d9a9-a8f4-50cc-9ad0-b4fd87d792b8 -->
  <rule id="727019" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2806 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>