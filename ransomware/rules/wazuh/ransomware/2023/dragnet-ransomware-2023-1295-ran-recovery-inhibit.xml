<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1295 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7c2d436b-2e34-5c98-8414-07747ce905e3 -->
  <rule id="288543" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1295 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>