<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0804 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: b79328c9-d560-5147-b5e3-efb4a0b6045d -->
  <rule id="379328" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0804 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>