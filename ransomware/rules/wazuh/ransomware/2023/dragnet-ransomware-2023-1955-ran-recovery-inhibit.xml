<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1955 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: a8c7f641-13b6-59cc-9b14-a585537d3227 -->
  <rule id="185276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1955 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>