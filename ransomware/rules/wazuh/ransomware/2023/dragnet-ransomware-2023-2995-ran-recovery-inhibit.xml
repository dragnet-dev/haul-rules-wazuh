<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2995 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d0fb4134-3f62-52a6-9f1b-c74a6a300784 -->
  <rule id="753141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2995 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>