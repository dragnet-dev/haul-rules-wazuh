<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0461 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 6319f467-907b-55f9-9791-88f9ce2f0794 -->
  <rule id="211194" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0461 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>