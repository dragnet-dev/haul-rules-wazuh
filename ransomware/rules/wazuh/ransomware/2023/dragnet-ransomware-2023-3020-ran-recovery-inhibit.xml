<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3020 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f8ff977c-f5ca-5c9f-852d-1821268609c9 -->
  <rule id="570397" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3020 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>