<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3629 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 2002ef3c-6bcd-5b48-804e-61eff957f3e7 -->
  <rule id="727513" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3629 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>