<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4044 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 40956c60-a38c-5e43-9693-5db37e89759b -->
  <rule id="353086" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4044 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>