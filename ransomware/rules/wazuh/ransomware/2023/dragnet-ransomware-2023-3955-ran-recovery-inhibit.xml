<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3955 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 281a37e9-cb0c-502e-ad27-558d1ae1cdba -->
  <rule id="110206" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3955 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>