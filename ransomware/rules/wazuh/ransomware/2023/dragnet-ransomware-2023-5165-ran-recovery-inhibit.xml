<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5165 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: f3743950-ec24-5053-af18-6c018b9efd74 -->
  <rule id="737439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5165 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>