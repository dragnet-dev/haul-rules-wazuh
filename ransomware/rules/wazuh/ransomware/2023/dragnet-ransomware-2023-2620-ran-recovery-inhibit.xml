<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2620 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 562c9116-a8b7-51e7-b2e2-bc442f77dc74 -->
  <rule id="104911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2620 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>