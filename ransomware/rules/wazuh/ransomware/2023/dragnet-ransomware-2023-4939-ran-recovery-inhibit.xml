<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4939 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: b1bf1976-2163-55de-a496-9a34a7b36a85 -->
  <rule id="260719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4939 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>