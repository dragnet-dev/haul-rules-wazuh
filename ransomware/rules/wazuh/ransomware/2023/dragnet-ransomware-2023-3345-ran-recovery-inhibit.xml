<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3345 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b537c227-8380-5aa3-98b3-69bac3f1b31e -->
  <rule id="146042" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3345 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>