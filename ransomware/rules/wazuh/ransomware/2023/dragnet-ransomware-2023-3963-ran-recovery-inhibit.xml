<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3963 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: db384a9b-4737-5267-8d17-dfe30965f3da -->
  <rule id="910154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3963 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>