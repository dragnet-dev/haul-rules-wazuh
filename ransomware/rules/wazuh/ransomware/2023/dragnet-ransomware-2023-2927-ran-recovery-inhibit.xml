<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2927 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 17e77ec8-418a-5b48-be53-1f9b23a06b0c -->
  <rule id="241548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2927 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>