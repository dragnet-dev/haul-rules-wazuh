<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1679 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: 43471a2c-f99d-59b2-8798-f670c07cbe5c -->
  <rule id="755462" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1679 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>