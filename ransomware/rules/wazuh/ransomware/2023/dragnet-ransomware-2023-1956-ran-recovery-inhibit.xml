<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1956 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f6031a33-235d-5775-871a-b035e2e31e51 -->
  <rule id="796506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1956 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>