<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2153 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 366cb847-3a34-5241-8d53-03f78f1ef1f9 -->
  <rule id="489984" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2153 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>