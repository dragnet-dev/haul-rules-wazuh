<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1280 — Event Log Clearing (donutleaks) | Status: experimental | Sigma ID: f40010cc-928b-5fd1-9597-3937c095ffc2 -->
  <rule id="740010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1280 — Event Log Clearing (donutleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>