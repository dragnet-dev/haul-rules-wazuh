<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3123 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: caf296d3-cea9-5d28-9815-49ba9bc1e58b -->
  <rule id="647296" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3123 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>