<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0217 — Event Log Clearing (ElDorado) | Status: deprecated | Sigma ID: ef494877-a64a-5d2d-8c3e-bc1f89d94e0e -->
  <rule id="694948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0217 — Event Log Clearing (ElDorado)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>