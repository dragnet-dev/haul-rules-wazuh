<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0671 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 609afed5-fe4c-5022-bb4b-6a32d2d0784d -->
  <rule id="797278" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0671 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>