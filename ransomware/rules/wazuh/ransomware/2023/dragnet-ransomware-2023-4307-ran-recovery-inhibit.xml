<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4307 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: abf6de72-a4f2-567a-8d8f-143564fc4889 -->
  <rule id="844318" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4307 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>