<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3743 — Recovery Inhibition (siegedsec) | Status: experimental | Sigma ID: 8c4e9a07-e98c-5e80-a91f-216293b7f973 -->
  <rule id="996634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3743 — Recovery Inhibition (siegedsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>