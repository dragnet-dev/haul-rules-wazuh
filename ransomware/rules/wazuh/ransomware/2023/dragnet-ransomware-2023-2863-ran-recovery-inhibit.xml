<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2863 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: d716f7c2-afd4-5a47-a83f-03b679bcb0d0 -->
  <rule id="494717" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2863 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>