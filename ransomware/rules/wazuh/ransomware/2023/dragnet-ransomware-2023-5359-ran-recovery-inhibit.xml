<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5359 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 20795813-591e-517c-8e6f-8d97009464b4 -->
  <rule id="379581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5359 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>