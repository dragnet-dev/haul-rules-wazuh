<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0367 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 587b3f6c-e749-5b9f-8f9c-900401555f97 -->
  <rule id="704543" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0367 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>