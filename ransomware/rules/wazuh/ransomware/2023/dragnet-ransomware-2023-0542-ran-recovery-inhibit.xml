<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0542 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 39a8eb9d-996b-5dd0-aab3-acfccbd832aa -->
  <rule id="825323" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0542 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>