<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4064 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 75acbd31-4845-57bb-bcfd-40630d359afc -->
  <rule id="559421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4064 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>