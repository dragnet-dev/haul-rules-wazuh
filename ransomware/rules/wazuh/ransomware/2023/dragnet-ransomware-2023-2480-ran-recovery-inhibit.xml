<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2480 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 139c4dcb-fdce-5f0e-8513-e31a0ad908f1 -->
  <rule id="425404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2480 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>