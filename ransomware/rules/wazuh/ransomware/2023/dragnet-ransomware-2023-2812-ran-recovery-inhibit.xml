<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2812 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 3bf6fd20-350e-5f94-a63b-a7f2732f25a1 -->
  <rule id="756829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2812 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>