<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2639 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2a7351b3-11b1-5c02-bfb3-92a72f338c1e -->
  <rule id="637627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2639 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>