<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4456 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: f3111d7a-d116-5e79-9eb4-9fe8e87519f0 -->
  <rule id="749789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4456 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>