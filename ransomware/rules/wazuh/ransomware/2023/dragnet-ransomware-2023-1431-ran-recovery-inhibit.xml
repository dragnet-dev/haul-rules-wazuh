<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1431 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: bda84543-d887-54d7-b2d1-60e792f1ff53 -->
  <rule id="434845" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1431 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>