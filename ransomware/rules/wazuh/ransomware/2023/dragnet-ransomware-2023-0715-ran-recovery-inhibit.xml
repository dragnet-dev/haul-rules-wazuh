<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0715 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f75b8cc8-97a3-5312-bea4-415f5ee4d886 -->
  <rule id="533900" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0715 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>