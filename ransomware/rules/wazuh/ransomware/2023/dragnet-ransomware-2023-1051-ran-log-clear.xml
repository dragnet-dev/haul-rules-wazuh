<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1051 — Event Log Clearing (8base) | Status: experimental | Sigma ID: a29b9df8-9c57-57c7-b40d-7c0c5cdcb3c9 -->
  <rule id="936157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1051 — Event Log Clearing (8base)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>