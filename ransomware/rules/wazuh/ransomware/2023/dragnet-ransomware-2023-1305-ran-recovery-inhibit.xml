<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1305 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 4d677919-a6e9-5a3e-a894-c25a15d6300c -->
  <rule id="667791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1305 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>