<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0546 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: c2adac19-ecf8-53f9-82d4-75fa86696dc0 -->
  <rule id="939852" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0546 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>