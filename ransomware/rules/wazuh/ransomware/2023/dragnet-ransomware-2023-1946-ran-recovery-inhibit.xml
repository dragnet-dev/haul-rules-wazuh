<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1946 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 2e7b9371-fc5b-53b1-af74-975e83653223 -->
  <rule id="383937" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1946 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>