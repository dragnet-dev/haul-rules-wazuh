<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2079 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4bf3e606-68fd-5f0e-b382-dea00f8e56d1 -->
  <rule id="244626" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2079 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>