<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5325 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: f7fb0af0-9c09-509d-9cae-9346ef14bfa6 -->
  <rule id="270890" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5325 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>