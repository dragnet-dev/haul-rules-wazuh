<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0371 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: dd8a4963-d73c-5ab6-aacf-05a8bc44530d -->
  <rule id="949849" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0371 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>