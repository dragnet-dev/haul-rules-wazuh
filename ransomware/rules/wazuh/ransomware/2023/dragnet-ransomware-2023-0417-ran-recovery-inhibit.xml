<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0417 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d1e50571-9936-5450-a0b0-755f669e61ae -->
  <rule id="410505" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0417 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>