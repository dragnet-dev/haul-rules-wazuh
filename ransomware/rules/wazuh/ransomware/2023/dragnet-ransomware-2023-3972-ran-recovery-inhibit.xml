<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3972 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: b931ae61-3215-5e45-9069-76981a153bf9 -->
  <rule id="454510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3972 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>