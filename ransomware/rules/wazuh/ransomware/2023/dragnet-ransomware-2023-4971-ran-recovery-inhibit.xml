<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4971 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ae2d02a0-c3fc-5327-bf82-50109bf0d33d -->
  <rule id="188502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4971 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>