<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3588 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 47bb5cc4-c3d5-5b51-bbd6-a45cc649a3da -->
  <rule id="255132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3588 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>