<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1800 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 6da3abc8-2e0c-5033-b8f5-155535045a61 -->
  <rule id="991179" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1800 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>