<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2900 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 93222993-902b-5ee5-a5ab-02c8cdeec460 -->
  <rule id="422299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2900 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>