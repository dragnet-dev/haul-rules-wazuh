  <rule id="923950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4741 — Recovery Inhibition (ciphbit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
