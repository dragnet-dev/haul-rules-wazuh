<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2453 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: c1aed327-3a9d-52c0-a72a-1685065f81a2 -->
  <rule id="584133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2453 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>