<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2044 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 2520e9df-56d6-5efa-8dd8-88d695efbf26 -->
  <rule id="253597" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2044 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>