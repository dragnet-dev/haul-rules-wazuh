<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1592 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3ed4b252-ff79-57f2-9a34-2519e541bd04 -->
  <rule id="808752" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1592 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>