<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3944 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 963e60ef-35aa-54bf-9e28-0573044e41ec -->
  <rule id="742260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3944 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>