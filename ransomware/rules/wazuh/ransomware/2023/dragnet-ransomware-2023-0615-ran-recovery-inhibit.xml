<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0615 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 0cd4f579-0d56-5513-a055-c91a61bf8313 -->
  <rule id="687957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0615 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>