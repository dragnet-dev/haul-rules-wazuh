<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1691 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 19679890-5eac-5d93-ac17-90d20c99aede -->
  <rule id="267989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1691 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>