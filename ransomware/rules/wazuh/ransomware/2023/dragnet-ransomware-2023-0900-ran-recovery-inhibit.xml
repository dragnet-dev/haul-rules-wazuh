<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0900 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 6fe43a30-b48a-53a6-ae15-98052cc442d6 -->
  <rule id="264698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0900 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>