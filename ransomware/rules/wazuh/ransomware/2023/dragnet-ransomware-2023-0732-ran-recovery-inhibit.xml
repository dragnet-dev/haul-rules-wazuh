<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0732 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: dd4977c5-fca4-5a41-bbd8-57e5348ab041 -->
  <rule id="514977" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0732 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>