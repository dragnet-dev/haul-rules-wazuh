<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3305 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: a34af4d1-c6eb-5502-a2f5-dd6edaf903ef -->
  <rule id="948794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3305 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>