<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3523 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7aaf13b3-8969-51c4-b79b-5b29d590cee5 -->
  <rule id="540713" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3523 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>