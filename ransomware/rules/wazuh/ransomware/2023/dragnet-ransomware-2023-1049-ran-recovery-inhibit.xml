<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1049 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 270c8878-b7a0-57c4-9274-78047636c4a1 -->
  <rule id="832887" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1049 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>