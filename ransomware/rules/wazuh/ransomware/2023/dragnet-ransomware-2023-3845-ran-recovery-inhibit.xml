<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3845 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: a6fac5e6-5c47-5448-be4f-a4e23da0988f -->
  <rule id="881885" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3845 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>