<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0385 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: ff5bcf57-00c8-5f34-96ae-3ee17b0ed080 -->
  <rule id="668303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0385 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>