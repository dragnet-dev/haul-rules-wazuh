<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2210 — Event Log Clearing (royal) | Status: deprecated | Sigma ID: 2e8a5ff6-7d2a-5a93-9cca-7927f8bb62ea -->
  <rule id="399775" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2210 — Event Log Clearing (royal)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>