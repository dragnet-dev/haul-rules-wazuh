<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4470 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: d228b352-135a-5449-aa4f-2fbf7fda4875 -->
  <rule id="416593" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4470 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>