<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0256 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 6708849d-1469-5d83-ae37-eaa9508d3abf -->
  <rule id="508849" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0256 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>