<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0103 — Recovery Inhibition (siegedsec) | Status: experimental | Sigma ID: b9e20678-d5b1-5dbe-a02e-964d4937a6ee -->
  <rule id="218206" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0103 — Recovery Inhibition (siegedsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>