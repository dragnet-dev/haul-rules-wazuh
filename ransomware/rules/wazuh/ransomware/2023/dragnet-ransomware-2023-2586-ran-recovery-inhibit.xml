<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2586 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 0b746ce8-efb4-5316-9e92-2d4084be2203 -->
  <rule id="407182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2586 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>