<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4100 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: dfc9894d-7e7d-5b8b-a7b7-567be123e076 -->
  <rule id="980989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4100 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>