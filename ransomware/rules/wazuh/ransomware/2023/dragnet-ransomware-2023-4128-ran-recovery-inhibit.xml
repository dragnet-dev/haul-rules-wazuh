<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4128 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 707c7226-88a2-503b-acc7-be3b1275245e -->
  <rule id="332472" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4128 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>