<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0097 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 5a6cc91c-82ad-5153-9e09-3b40a43dfff8 -->
  <rule id="621409" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0097 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>