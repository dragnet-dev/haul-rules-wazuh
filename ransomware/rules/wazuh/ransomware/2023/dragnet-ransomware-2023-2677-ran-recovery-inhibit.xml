<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2677 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5b2f5bc1-b393-59e5-a564-ea3a478a2267 -->
  <rule id="637211" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2677 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>