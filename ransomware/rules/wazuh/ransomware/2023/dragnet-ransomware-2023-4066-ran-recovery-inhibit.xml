<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4066 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 8baad889-6a3f-5d3f-b059-f21f09134793 -->
  <rule id="420778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4066 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>