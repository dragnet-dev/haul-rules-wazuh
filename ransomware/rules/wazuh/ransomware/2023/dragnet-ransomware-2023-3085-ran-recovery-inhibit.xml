<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3085 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 25bdc422-3033-5829-a791-72aa3333bb5f -->
  <rule id="254364" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3085 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>