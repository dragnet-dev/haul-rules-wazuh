<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3329 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 1420b8b6-9b25-56e3-8708-c761a454d28f -->
  <rule id="137099" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3329 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>