<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3384 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 3ea5164b-3cca-53b9-ad13-be4b9b13f425 -->
  <rule id="202516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3384 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>