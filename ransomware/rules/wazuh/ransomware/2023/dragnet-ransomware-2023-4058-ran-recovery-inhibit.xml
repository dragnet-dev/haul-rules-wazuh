<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4058 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: aafc917f-4c72-5045-a358-4b3696aaad9f -->
  <rule id="877291" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4058 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>