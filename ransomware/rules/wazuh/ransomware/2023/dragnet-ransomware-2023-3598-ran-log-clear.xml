<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3598 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: b8e0b246-fbb6-5940-ab7c-88cd3640e6d4 -->
  <rule id="443312" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3598 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>