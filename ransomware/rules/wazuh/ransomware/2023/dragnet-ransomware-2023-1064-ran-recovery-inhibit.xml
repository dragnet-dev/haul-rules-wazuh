<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1064 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 02a23a9f-a58a-5ecf-a5d1-ca6586b152ed -->
  <rule id="112639" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1064 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>