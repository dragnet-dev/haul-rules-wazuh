<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0601 — Event Log Clearing (knight) | Status: experimental | Sigma ID: dc0bc7ff-2cf2-5dc9-8c88-46524e78ead5 -->
  <rule id="333887" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0601 — Event Log Clearing (knight)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>