<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1783 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a9850bb6-dce7-5a95-acc2-2e870dfe9e06 -->
  <rule id="957611" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1783 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>