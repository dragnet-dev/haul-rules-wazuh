<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0839 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 043bcc67-9f1e-5e8d-be23-78e1e72b1530 -->
  <rule id="991486" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0839 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>