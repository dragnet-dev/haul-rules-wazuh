<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4015 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: fd27538c-7b5b-5d4d-87a3-8eea2c4c5d28 -->
  <rule id="832753" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4015 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>