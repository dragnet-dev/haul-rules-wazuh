<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3171 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 7c4c62a7-d134-5729-ba78-0d13de2083d9 -->
  <rule id="291662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3171 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>