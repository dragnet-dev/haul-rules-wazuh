<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4235 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 3c9374c6-3e86-595c-8f7b-6203b5d1d9cf -->
  <rule id="849996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4235 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>