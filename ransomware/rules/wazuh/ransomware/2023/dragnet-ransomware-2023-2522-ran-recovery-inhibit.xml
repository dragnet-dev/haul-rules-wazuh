<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2522 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c50ec036-49fc-5809-ad1e-67a65b165ac2 -->
  <rule id="602360" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2522 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>