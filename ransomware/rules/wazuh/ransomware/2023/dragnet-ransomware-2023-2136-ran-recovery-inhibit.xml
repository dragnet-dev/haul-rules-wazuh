<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2136 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5fd0855c-4641-53b5-bebe-5a4f60c173fb -->
  <rule id="733085" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2136 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>