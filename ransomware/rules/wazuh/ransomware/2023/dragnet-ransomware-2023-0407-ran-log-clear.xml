<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0407 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 9cc7330e-fea3-5ec6-b176-eec08b9d9c18 -->
  <rule id="808733" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0407 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>