<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5064 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 40247e6c-2502-543c-816b-735905f18a7c -->
  <rule id="239666" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5064 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>