<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1722 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 57a578e0-d0f5-53be-b475-9072d01be273 -->
  <rule id="461262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1722 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>