<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2109 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: cc96c844-0722-5bdc-b467-65219db23102 -->
  <rule id="679488" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2109 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>