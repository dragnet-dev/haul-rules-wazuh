<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1931 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: afd05003-43df-59ae-a0e2-c2069c7914f1 -->
  <rule id="213050" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1931 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>