<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1507 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: bc31fdbc-9d12-599f-8e5b-b21c03c934e0 -->
  <rule id="420989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1507 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>