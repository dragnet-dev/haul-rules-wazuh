<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0310 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 97c32c90-5fcd-53d6-b0c1-1623ce382a39 -->
  <rule id="802924" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0310 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>