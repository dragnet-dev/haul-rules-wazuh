<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0764 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3c0cff81-c394-55f2-9af3-c72448285ed2 -->
  <rule id="760927" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0764 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>