<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2058 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 3dbdff83-487f-5289-97a9-dc2e53e65969 -->
  <rule id="546335" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2058 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>