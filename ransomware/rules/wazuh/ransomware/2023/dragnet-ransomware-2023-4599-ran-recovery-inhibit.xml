<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4599 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7def57ec-3247-5520-86f1-3e16c66267e8 -->
  <rule id="623957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4599 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>