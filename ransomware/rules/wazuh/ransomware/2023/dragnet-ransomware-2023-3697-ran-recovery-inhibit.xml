<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3697 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 520b7c5d-3581-5317-982b-be90a238aa8f -->
  <rule id="533084" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3697 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>