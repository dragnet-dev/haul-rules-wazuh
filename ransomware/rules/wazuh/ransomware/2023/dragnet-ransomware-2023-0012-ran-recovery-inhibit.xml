<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0012 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 6393a5d3-f8f9-52bf-8418-4d577e5db417 -->
  <rule id="222985" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0012 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>