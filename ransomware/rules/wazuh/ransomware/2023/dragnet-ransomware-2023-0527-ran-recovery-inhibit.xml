<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0527 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 98ec1b8c-d690-5428-acc4-4a5be8dc9734 -->
  <rule id="551867" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0527 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>