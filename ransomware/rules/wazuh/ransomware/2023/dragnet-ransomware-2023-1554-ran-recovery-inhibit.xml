<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1554 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: bdfa9b34-1a37-59f9-bd6f-416bf650ff3d -->
  <rule id="681595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1554 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>