<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4659 — Event Log Clearing (vendetta) | Status: deprecated | Sigma ID: f7f7c100-e744-57a1-b49c-75849e763f72 -->
  <rule id="544441" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4659 — Event Log Clearing (vendetta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>