<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4139 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 86678b40-b4d5-5e59-86cc-696f10f9cac4 -->
  <rule id="586859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4139 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>