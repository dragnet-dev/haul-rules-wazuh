<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2257 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: db5bb4a2-9861-5df9-afad-8edfc975d6b5 -->
  <rule id="321074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2257 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>