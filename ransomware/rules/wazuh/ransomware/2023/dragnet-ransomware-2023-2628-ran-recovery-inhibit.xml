<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2628 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 13478333-476c-53da-890f-74adbb88a5fa -->
  <rule id="547833" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2628 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>