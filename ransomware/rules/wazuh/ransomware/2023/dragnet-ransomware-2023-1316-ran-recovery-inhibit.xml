<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1316 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 29b27a12-4716-54e6-8de6-fd669afe9893 -->
  <rule id="504421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1316 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>