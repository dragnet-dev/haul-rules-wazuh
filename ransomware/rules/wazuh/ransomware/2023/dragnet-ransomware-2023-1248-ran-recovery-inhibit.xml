<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1248 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 860500ea-c566-564a-95ad-be222d6e88a0 -->
  <rule id="368014" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1248 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>