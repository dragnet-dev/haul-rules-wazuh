<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2702 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 550ee9ac-8d31-5da3-9fab-6bf708093ca2 -->
  <rule id="610389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2702 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>