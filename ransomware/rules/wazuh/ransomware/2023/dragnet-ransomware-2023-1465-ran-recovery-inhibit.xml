<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1465 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f869f4e2-ab6e-532b-98fc-aad15c6ecbc7 -->
  <rule id="839194" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1465 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>