<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3633 — Event Log Clearing (monti) | Status: experimental | Sigma ID: ee9d6c3b-0641-57a1-a0c7-d1f7a8d4eff8 -->
  <rule id="818028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3633 — Event Log Clearing (monti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>