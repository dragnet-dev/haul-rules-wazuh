<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5369 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 500cfbc2-428d-5429-9fc0-c6bb2e499b4b -->
  <rule id="351323" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5369 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>