<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0039 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 3118ac79-a102-5860-881c-7d98a607b067 -->
  <rule id="883807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0039 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>