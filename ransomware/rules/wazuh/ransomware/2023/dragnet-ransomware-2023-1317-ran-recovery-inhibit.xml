<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1317 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: 9470a734-40ab-5d75-824b-33e6b0075686 -->
  <rule id="715307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1317 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>