<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4010 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2c198207-fdda-504d-935d-15c573ff4d9d -->
  <rule id="919820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4010 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>