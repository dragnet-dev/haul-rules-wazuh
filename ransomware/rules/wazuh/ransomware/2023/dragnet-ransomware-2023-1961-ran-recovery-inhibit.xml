<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1961 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 475d6df7-028d-50ca-9415-ae9f78423974 -->
  <rule id="418189" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1961 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>