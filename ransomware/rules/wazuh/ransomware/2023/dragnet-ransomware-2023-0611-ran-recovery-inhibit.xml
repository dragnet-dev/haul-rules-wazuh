<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0611 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c6c64724-14f2-5b07-94ca-8a65e2bfcef9 -->
  <rule id="328647" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0611 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>