<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0636 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: ebd028ef-5daf-5fd7-afbd-3f0596f21426 -->
  <rule id="273028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0636 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>