<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5240 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 8855f354-dcd7-5d95-acb7-811f3928c3bd -->
  <rule id="616953" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5240 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>