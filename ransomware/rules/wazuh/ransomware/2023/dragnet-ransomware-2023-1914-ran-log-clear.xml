<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1914 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 458dcd1e-00f0-5fe8-9e36-a1fee7ea0ad5 -->
  <rule id="179501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1914 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>