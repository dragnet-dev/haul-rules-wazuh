<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2757 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 3eda83d2-e139-5afb-ac16-9d2a9369e1a8 -->
  <rule id="809083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2757 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>