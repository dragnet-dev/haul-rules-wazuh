<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2789 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 126a2728-419b-5805-ad84-180d584c1811 -->
  <rule id="326272" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2789 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>