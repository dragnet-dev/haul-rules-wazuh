<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4089 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 906d476c-e385-56c1-b953-ffa40295bc64 -->
  <rule id="650947" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4089 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>