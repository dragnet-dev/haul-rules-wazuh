<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1102 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 47fb2d5e-a12c-5bec-85f9-25bb651d5b92 -->
  <rule id="265325" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1102 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>