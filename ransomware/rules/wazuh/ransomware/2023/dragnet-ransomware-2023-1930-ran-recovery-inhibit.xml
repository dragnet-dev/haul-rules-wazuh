<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1930 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: e9112d99-df91-5804-bac0-68b27c6b90e0 -->
  <rule id="685805" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1930 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>