<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4401 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c3349703-a119-5aa2-bd7e-7535d0337a31 -->
  <rule id="433497" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4401 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>