<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2501 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6b480923-279d-5237-b3ba-5d938303f192 -->
  <rule id="274809" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2501 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>