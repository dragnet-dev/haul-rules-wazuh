<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2373 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 61f481d2-28ce-5177-8fff-fda96a2c6c0a -->
  <rule id="663709" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2373 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>