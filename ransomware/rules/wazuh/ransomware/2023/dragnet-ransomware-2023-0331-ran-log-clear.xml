<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0331 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: 6f5eeb8e-9008-5b48-b5fd-dbd3d7722a11 -->
  <rule id="170859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0331 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>