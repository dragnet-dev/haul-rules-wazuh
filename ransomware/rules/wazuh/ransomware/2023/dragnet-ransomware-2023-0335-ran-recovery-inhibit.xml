<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0335 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 650dd73b-c688-55a9-8363-1723f230420c -->
  <rule id="866217" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0335 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>