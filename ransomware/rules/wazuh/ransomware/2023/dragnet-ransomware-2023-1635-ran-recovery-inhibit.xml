<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1635 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: bf57135c-56fe-5421-986b-c2c14604da08 -->
  <rule id="215713" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1635 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>