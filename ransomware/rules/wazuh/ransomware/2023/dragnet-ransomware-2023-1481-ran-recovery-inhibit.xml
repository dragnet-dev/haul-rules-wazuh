<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1481 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: eabfff64-746d-5042-8e79-2cb62c26be16 -->
  <rule id="184575" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1481 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>