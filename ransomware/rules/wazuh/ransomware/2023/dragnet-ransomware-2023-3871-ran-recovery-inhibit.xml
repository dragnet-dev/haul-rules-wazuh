<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3871 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: c20a6378-a29c-59f2-b77b-9d78d45cfb08 -->
  <rule id="253063" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3871 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>