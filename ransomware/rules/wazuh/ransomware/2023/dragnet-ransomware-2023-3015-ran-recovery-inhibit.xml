<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3015 — Recovery Inhibition (mallox) | Status: deprecated | Sigma ID: 59f64e4f-7017-568e-a7bc-419faa8200c7 -->
  <rule id="735438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3015 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>