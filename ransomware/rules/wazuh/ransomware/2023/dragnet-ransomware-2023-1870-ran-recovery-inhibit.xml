<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1870 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: b2b811f0-b881-5937-af84-f35fed27afcb -->
  <rule id="103811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1870 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>