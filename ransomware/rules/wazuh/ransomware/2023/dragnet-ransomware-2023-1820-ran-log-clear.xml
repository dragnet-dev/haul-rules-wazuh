<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1820 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: bf11d9df-0610-5ef0-97a1-4e4b8d9763bc -->
  <rule id="457899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1820 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>