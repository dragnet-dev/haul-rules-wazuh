<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4893 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0f2f789a-5f60-5cfe-a2cc-af556c186c0a -->
  <rule id="747789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4893 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
