<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2932 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: 63d8ebaa-717a-53f7-8f53-6375ec6d5353 -->
  <rule id="916043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2932 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>