<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1832 — Recovery Inhibition (losttrust) | Status: deprecated | Sigma ID: e8eed71d-ad32-57a4-9862-25125bc4d437 -->
  <rule id="800297" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1832 — Recovery Inhibition (losttrust)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>