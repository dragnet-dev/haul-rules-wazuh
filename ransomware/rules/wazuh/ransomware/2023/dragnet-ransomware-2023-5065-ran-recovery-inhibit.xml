<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5065 — Recovery Inhibition (siegedsec) | Status: experimental | Sigma ID: a4e00a1b-5252-5c55-a6d9-9a27fc5bf414 -->
  <rule id="984810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5065 — Recovery Inhibition (siegedsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>