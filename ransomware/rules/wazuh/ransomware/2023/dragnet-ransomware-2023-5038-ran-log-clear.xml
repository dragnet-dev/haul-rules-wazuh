<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5038 — Event Log Clearing (toufan) | Status: deprecated | Sigma ID: 81c48b91-4123-59cd-97e7-c97d05ab6960 -->
  <rule id="393579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5038 — Event Log Clearing (toufan)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>