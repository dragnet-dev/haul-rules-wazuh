<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1669 — Event Log Clearing (8base) | Status: experimental | Sigma ID: fcde5f5c-2e0d-5c10-ba8b-6df4d403ecb8 -->
  <rule id="557535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1669 — Event Log Clearing (8base)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>