<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1981 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 81db76ba-174e-5d97-befd-d53824f99122 -->
  <rule id="395576" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1981 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>