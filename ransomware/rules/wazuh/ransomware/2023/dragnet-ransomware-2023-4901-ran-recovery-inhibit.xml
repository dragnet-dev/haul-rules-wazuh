<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4901 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 38b70e55-5ab0-5671-9570-909440d19e76 -->
  <rule id="115345" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4901 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>