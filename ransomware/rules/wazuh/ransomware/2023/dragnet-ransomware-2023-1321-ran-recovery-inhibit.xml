<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1321 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 7d20aec9-1f90-5aa3-8710-44a293368a56 -->
  <rule id="605294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1321 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>