<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4793 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d76631ba-8806-53c4-aaf8-cc12f4124bbd -->
  <rule id="576631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4793 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>