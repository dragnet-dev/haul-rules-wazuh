<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3698 — Recovery Inhibition (darkrace) | Status: experimental | Sigma ID: a8164936-5005-5d7f-b932-481996e192d4 -->
  <rule id="281649" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3698 — Recovery Inhibition (darkrace)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>