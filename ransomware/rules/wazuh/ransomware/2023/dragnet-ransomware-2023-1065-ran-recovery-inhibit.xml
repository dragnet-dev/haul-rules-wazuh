<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1065 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 982c8515-b11f-5567-9a53-25d89e744d23 -->
  <rule id="772485" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1065 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>