<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2039 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2456ec25-4950-5f42-83a8-c376e9fb8aa4 -->
  <rule id="989722" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2039 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>