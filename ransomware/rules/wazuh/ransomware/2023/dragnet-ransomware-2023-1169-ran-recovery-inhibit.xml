<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1169 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 7f0202d8-7641-5709-8eae-787f64a78b43 -->
  <rule id="470202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1169 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>