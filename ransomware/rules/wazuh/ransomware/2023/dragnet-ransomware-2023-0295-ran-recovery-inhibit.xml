<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0295 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0882e038-0981-5e85-a16b-637c461a2713 -->
  <rule id="612603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0295 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>