<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2060 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e6db49d5-5e34-5c01-ac4b-c3866636fde8 -->
  <rule id="259549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2060 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>