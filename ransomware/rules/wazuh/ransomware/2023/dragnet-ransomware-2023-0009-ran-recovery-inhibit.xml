<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0009 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 833f1bd2-964b-5a63-849e-2e077299f5e0 -->
  <rule id="434907" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0009 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>