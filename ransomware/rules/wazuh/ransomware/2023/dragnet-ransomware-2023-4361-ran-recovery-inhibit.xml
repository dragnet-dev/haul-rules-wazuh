<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4361 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: c0bae5c3-f24b-5dff-a9e2-e649fd4e7a25 -->
  <rule id="545105" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4361 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>