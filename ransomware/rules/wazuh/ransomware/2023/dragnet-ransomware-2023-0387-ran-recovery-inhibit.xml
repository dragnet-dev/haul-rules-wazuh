<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0387 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f6b29a4c-e0ce-5c6f-a53d-2b0a3cce74d1 -->
  <rule id="511674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0387 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>