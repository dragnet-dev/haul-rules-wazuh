<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2505 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 3344b8ae-53ad-5047-8501-a78fcd4d637f -->
  <rule id="562538" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2505 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>