<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1031 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: f37537c1-41a9-52e9-acd3-8c009eaeda36 -->
  <rule id="737537" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1031 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>