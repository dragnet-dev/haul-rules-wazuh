<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1152 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: ba11f7ae-6ffb-59e9-bb03-f0e3676b40db -->
  <rule id="377917" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1152 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>