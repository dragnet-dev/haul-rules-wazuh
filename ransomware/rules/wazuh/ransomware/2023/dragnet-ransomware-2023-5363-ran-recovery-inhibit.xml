<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5363 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 0e498b6f-4bef-5e70-98f8-8bbc2d8e1491 -->
  <rule id="619796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5363 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>