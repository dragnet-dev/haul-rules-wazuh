<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4689 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 3e30bbcf-807d-53b5-b7e0-df22a7b13fe9 -->
  <rule id="795067" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4689 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>