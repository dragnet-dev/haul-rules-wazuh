<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1223 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ee623756-9195-5002-807b-431c72595ce2 -->
  <rule id="686237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1223 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>