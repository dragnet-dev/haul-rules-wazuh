<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0260 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f969b287-022c-50e6-981a-57d075851b30 -->
  <rule id="855152" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0260 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>