<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0985 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4c44303c-79de-5068-88e3-7b849a2e03b1 -->
  <rule id="544303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0985 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>