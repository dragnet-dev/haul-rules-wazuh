<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0743 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 14b5352b-ba6e-5d0b-8a86-ef142366930b -->
  <rule id="655352" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0743 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>