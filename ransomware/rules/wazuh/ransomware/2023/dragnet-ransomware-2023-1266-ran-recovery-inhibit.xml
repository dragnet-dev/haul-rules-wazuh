<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1266 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 22f85b0f-1b1a-587d-965f-a54bf23e5d63 -->
  <rule id="585710" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1266 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>