<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4355 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 06759459-0cba-5955-84db-2494ccc8ef23 -->
  <rule id="559459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4355 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>