<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0216 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 48b512d9-56d7-5515-98f8-6ff6b4afcdfa -->
  <rule id="872205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0216 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>