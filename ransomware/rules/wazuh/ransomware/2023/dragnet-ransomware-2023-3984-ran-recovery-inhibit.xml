<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3984 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 1060bea6-fe6e-5b0a-8546-b24720199cf5 -->
  <rule id="844810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3984 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>