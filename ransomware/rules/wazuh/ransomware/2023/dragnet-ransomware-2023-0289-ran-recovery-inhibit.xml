<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0289 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 7e8fc4af-4a3a-51b2-be26-5d061f50bfbb -->
  <rule id="648604" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0289 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>