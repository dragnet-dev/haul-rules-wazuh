<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3732 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: dae1ac72-c833-5f02-870e-611a187955d9 -->
  <rule id="965548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3732 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>