<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1251 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d95b4cda-d34c-5e5c-aaab-537e21b22168 -->
  <rule id="973036" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1251 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>