<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4569 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: c9f463a3-386d-5a45-a99f-ff2c6c0233d0 -->
  <rule id="379463" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4569 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>