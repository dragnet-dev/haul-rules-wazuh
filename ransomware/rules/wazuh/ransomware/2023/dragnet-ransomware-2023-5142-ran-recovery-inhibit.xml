<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5142 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: a2da14c4-44ff-58b1-904a-c3e2a65f166b -->
  <rule id="933014" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5142 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>