<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0021 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 31aaf088-48f1-5990-bca7-e3cf8fc351f5 -->
  <rule id="497110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0021 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>