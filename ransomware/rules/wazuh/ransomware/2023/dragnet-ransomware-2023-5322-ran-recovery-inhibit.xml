<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5322 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d844b501-79bb-59ab-8881-a4f26b6d2270 -->
  <rule id="515155" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5322 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>