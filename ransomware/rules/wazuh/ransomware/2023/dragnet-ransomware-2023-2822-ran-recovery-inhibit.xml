<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2822 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 4c767797-df83-58f6-a0d5-3dbe6ace0242 -->
  <rule id="576779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2822 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>