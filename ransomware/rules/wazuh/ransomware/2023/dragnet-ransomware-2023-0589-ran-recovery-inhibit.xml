<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0589 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: e5473863-565b-5a7e-acd0-cd563250c88e -->
  <rule id="654738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0589 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>