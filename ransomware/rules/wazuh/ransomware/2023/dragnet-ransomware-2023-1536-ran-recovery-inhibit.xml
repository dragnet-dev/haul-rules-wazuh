<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1536 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 279cde1d-3681-5e81-95ea-fb59083f035f -->
  <rule id="346078" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1536 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>