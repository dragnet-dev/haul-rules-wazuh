<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4348 — Event Log Clearing (metaencryptor) | Status: experimental | Sigma ID: c02ca8ed-6d9a-54c7-aded-ef5bb2856dc1 -->
  <rule id="479148" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4348 — Event Log Clearing (metaencryptor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>