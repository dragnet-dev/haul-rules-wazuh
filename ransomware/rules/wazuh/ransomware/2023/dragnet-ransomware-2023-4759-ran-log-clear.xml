<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4759 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: ed3d0cb3-0999-5840-83ee-d7a8a19bc5a4 -->
  <rule id="776972" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4759 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>