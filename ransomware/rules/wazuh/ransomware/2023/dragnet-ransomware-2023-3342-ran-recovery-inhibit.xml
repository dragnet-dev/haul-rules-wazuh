<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3342 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 4aed6728-6bde-5a73-87d0-a158ee401368 -->
  <rule id="218167" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3342 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>