<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2619 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b18fcaf2-699f-587b-90eb-5a74c4fb69e6 -->
  <rule id="183370" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2619 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>