<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3405 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 370b7dbd-2fe9-5cea-85c2-aa7210473f3d -->
  <rule id="885371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3405 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>