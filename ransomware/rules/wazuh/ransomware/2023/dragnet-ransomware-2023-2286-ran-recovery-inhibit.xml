<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2286 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 7f799fd3-81f7-5f0c-b98d-45aad697ef32 -->
  <rule id="344799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2286 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>