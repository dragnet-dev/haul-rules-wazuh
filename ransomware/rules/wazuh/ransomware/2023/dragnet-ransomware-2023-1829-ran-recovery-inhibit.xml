<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1829 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 851d13e8-f0fd-5415-9c35-7a6f016aa9b8 -->
  <rule id="562913" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1829 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>