<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4809 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 49f9191a-91df-578f-b23a-f6c61aebdb09 -->
  <rule id="899191" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4809 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>