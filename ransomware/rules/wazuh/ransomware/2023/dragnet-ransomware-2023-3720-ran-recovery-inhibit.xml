<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3720 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7d7240d7-0196-50cd-b75f-24a3e79f7d34 -->
  <rule id="457240" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3720 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>