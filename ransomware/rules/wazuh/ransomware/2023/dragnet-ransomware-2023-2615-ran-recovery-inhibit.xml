<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2615 — Recovery Inhibition (cloak) | Status: experimental | Sigma ID: 3502c468-ce82-5f09-9744-6a3f89e326c5 -->
  <rule id="304446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2615 — Recovery Inhibition (cloak)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>