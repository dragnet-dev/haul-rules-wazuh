<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4028 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6b353564-dcbf-52ba-8193-d65fc3c7392e -->
  <rule id="273535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4028 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>