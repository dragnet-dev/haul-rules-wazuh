<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0551 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b4df51a2-3d51-57c9-9508-75a3842adceb -->
  <rule id="340751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0551 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>