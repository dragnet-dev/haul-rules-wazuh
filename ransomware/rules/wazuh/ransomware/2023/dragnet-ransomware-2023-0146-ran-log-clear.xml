<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0146 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 75ea0f16-a6e5-5eb7-877b-e5325b178bbb -->
  <rule id="509455" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0146 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>