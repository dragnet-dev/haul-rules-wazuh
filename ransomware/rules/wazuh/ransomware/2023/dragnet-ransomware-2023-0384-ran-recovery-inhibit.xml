<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0384 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 2ea4740c-3e7a-5ac2-9273-e3b0d12fa15e -->
  <rule id="364740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0384 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>