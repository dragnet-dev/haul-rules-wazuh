<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1694 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 15cb6a58-fdcf-5e53-83c0-3194f8c9cbdf -->
  <rule id="269865" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1694 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>