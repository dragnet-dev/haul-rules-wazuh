<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0817 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 094a6db6-81cf-51cf-93b5-3f924570febd -->
  <rule id="377595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0817 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>