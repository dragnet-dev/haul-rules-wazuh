<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3222 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 04986c5c-fde0-547f-81fe-20523bda8cac -->
  <rule id="266172" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3222 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>