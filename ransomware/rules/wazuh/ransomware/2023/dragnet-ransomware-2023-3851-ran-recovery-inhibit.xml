<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3851 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 419527d2-0543-5390-ad10-279e375f2b05 -->
  <rule id="512445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3851 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>