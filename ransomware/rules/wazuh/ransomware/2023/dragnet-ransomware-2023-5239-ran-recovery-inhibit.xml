<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5239 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: fdc069b4-8d38-50ef-9ab7-ebed3c0dd6bd -->
  <rule id="560069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5239 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>