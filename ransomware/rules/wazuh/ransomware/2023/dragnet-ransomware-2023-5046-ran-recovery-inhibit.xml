<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5046 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3102ca8a-59b8-5e14-b08c-9dc30b7aba6a -->
  <rule id="843148" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5046 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>