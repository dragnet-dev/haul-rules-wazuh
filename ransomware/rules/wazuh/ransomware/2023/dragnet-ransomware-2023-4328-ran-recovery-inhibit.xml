<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4328 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: d084bb5f-aa90-5dcc-888f-3d5be86824ff -->
  <rule id="749691" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4328 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>