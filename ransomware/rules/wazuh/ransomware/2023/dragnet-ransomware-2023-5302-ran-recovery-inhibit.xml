<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5302 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: b3e1d245-5ebd-55db-9ead-e94046fa9386 -->
  <rule id="315492" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5302 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>