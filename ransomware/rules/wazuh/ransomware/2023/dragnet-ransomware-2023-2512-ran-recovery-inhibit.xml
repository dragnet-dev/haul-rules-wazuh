<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2512 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4c6eb957-8afe-5a21-ac44-42c4913c9809 -->
  <rule id="263319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2512 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>