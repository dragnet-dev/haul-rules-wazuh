<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0870 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d2657ba5-8335-5ee5-9aec-3a51c3ee2f82 -->
  <rule id="422523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0870 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>