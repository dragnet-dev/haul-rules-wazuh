<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4402 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 82cad3b5-f749-52a5-a350-9c3a6bb28025 -->
  <rule id="791173" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4402 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>