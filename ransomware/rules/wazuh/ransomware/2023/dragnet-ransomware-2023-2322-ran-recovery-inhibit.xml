<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2322 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9e58f75c-b33c-556f-a992-0ca6ba304c45 -->
  <rule id="837437" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2322 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>