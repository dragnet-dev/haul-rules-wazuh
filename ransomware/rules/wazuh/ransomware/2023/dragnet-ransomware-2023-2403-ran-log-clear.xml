<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2403 — Event Log Clearing (lorenz) | Status: deprecated | Sigma ID: aca52f3b-db5d-52f1-86d9-b5c4c58c9b6b -->
  <rule id="920047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2403 — Event Log Clearing (lorenz)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>