<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2597 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 651a37d8-2827-5ebc-ac45-fd4bbeae6abd -->
  <rule id="242637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2597 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>