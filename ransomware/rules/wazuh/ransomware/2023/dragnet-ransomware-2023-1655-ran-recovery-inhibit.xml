<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1655 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: b158e56a-23cf-54bc-b7be-50570017b205 -->
  <rule id="985425" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1655 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>