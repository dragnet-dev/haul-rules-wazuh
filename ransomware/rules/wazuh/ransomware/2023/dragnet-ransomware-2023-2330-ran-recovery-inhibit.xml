<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2330 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: b8887ceb-fe6c-5f14-9b7d-2af6dcba0e33 -->
  <rule id="202204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2330 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>