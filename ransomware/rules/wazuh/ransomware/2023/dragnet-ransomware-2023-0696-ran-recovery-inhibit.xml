<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0696 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: abd958a3-2d7c-5ebe-bbbc-c9749aef1884 -->
  <rule id="149958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0696 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>