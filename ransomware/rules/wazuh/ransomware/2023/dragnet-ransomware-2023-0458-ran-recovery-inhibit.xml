<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0458 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: e8fa78a6-31d8-5b4f-a48d-fe13c70609d9 -->
  <rule id="313878" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0458 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>