<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0598 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 3c342bc0-5311-503b-93b1-15cc41788aac -->
  <rule id="247740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0598 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>