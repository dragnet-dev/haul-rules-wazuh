<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0211 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 13045a95-8885-5c4e-b335-beef5b795ffb -->
  <rule id="387309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0211 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>