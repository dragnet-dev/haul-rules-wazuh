<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1727 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 3dd1c743-213f-5bf4-88d5-eedd8843a2fa -->
  <rule id="782687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1727 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>