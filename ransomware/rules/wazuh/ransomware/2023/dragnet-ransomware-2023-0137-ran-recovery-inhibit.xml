<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0137 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0c45b7cf-3427-5ab6-a11b-fc038825960c -->
  <rule id="589084" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0137 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>