<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3194 — Recovery Inhibition (losttrust) | Status: deprecated | Sigma ID: 8673b20f-4fe5-540d-a817-85cdc4272e2b -->
  <rule id="587792" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3194 — Recovery Inhibition (losttrust)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>