<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0654 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 9c4c865c-3b7b-5e80-8a3c-e64eb414baee -->
  <rule id="803686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0654 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>