<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1860 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a40e71ab-d292-567d-abb4-badcf5d62674 -->
  <rule id="865471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1860 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>