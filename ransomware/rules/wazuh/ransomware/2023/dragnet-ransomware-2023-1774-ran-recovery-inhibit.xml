<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1774 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: be3eea2b-3a9c-5587-9cdb-8f3143778048 -->
  <rule id="698506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1774 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>