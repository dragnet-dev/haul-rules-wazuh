<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0812 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 15700a85-b049-5d8a-baee-9d5661028968 -->
  <rule id="812108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0812 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>