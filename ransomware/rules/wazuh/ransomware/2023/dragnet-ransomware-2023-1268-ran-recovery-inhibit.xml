<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1268 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8fb3888a-9012-5ccd-b568-22394f818ec8 -->
  <rule id="599388" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1268 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>