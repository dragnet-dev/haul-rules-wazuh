<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0961 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 0814fd37-c691-5f36-8eec-0519935e2fe9 -->
  <rule id="386373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0961 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>