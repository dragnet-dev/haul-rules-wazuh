<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0656 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 09e68860-ad84-5b75-9a34-58fd7937ebcc -->
  <rule id="786886" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0656 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>