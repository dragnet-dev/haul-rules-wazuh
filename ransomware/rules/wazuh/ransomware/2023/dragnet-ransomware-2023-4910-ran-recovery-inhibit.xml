<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4910 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 5c5db39f-4417-52a7-844a-29c40108f503 -->
  <rule id="670193" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4910 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>