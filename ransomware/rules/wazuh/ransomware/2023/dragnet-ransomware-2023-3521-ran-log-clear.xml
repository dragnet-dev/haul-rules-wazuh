<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3521 — Event Log Clearing (nokoyawa) | Status: experimental | Sigma ID: 4c04a9b4-50ad-5dd2-8574-f0dcd1a8cee4 -->
  <rule id="416749" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3521 — Event Log Clearing (nokoyawa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>