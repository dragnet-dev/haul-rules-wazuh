<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2567 — Recovery Inhibition (dunghill) | Status: experimental | Sigma ID: 741ed198-0ed1-55fa-a753-fafe3388b502 -->
  <rule id="199331" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2567 — Recovery Inhibition (dunghill)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>