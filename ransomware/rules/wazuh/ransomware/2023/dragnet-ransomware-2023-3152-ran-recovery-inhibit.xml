<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3152 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: f74b3155-74bb-509e-aec0-303efdcb7a21 -->
  <rule id="819531" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3152 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
