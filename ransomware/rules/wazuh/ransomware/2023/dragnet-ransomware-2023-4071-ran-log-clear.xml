<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4071 — Event Log Clearing (rancoz) | Status: experimental | Sigma ID: 5979eccb-8296-587e-b123-abd2efe6dd07 -->
  <rule id="730860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4071 — Event Log Clearing (rancoz)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>