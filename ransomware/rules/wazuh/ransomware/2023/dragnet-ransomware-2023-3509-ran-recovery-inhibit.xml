<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3509 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0fa91565-908c-5188-9c3e-23b7f6c4e6e3 -->
  <rule id="809156" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3509 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>