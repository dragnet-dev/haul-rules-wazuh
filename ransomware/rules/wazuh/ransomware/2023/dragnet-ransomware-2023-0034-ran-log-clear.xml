<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0034 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 9185c300-7752-5a5c-a73e-05e83b8ba0ca -->
  <rule id="669723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0034 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>