<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1163 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: fb2df4c4-157f-532f-85dc-4ffdec1ab1f2 -->
  <rule id="232954" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1163 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>