<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3064 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: baea7f19-d12e-5852-9b29-96c330e15aff -->
  <rule id="556127" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3064 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>