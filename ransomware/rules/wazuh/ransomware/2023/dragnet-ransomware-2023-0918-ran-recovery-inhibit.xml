<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0918 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1aa076f2-68a9-542e-829f-837c83396578 -->
  <rule id="617231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0918 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>