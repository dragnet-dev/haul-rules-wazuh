<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5106 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8067778a-b96c-53fb-ab3f-94063a1f8a4b -->
  <rule id="967778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5106 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>