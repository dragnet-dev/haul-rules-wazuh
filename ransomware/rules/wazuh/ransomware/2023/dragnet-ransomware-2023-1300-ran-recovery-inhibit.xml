<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1300 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5d761af0-efb3-5545-9a1a-9b77acb584e3 -->
  <rule id="700186" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1300 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>