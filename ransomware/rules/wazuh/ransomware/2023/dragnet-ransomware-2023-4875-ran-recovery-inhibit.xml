<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4875 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f6af2bad-4722-598e-8e77-8b1d09090435 -->
  <rule id="217803" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4875 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>