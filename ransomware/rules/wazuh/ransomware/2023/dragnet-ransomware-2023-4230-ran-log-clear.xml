<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4230 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: dd0147d9-5c97-5a7f-b5eb-2c181300adc1 -->
  <rule id="510147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4230 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>