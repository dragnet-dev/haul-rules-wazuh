<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1644 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 40fa7ea8-c21c-57db-83ea-706225e572f1 -->
  <rule id="878526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1644 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>