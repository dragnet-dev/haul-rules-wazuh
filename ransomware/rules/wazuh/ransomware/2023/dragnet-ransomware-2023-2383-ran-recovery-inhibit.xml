<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2383 — Recovery Inhibition (losttrust) | Status: deprecated | Sigma ID: 7750444a-7682-5104-aaca-3a311cceade3 -->
  <rule id="650444" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2383 — Recovery Inhibition (losttrust)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>