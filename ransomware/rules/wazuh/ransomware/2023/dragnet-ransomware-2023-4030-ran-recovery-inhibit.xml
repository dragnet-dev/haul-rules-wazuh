<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4030 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8ac37066-8f80-5c84-b7ea-5c62c4e9405f -->
  <rule id="520370" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4030 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>