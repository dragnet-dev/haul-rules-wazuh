<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5159 — Recovery Inhibition (losttrust) | Status: deprecated | Sigma ID: 5fdddd29-2ce3-55ee-97d3-88b2d7402207 -->
  <rule id="982717" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5159 — Recovery Inhibition (losttrust)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>