<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0024 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: eb8fe01f-28c7-5539-ac51-ccbb7b7c5692 -->
  <rule id="739020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0024 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>