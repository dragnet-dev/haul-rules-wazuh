<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5287 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 85a0a13e-66ae-50d0-a8b9-979ed5f5aadf -->
  <rule id="492101" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5287 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>