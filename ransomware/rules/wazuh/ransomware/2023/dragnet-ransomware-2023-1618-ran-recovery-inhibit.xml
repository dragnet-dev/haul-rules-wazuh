<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1618 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 9ba6d2f3-41ca-5e10-8cc7-591ea3c1bcb6 -->
  <rule id="485092" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1618 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>