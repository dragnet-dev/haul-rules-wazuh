<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1524 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c3681dfc-18d6-5c9c-8d60-4faaf1eec9d3 -->
  <rule id="278909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1524 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>