<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4605 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 8659a53c-72f6-5334-ad13-99e86d090113 -->
  <rule id="585545" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4605 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>