<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4197 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 4a1cfc2b-8a8d-55b7-9327-37a9e5ff92de -->
  <rule id="438460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4197 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>