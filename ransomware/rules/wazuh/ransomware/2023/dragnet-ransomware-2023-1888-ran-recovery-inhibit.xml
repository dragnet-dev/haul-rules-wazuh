<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1888 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: aaff61c0-cff1-55e6-8409-03887aa7efe2 -->
  <rule id="877561" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1888 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>