<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1745 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 042ee942-1549-51ef-8a1e-929c5ece8fd0 -->
  <rule id="299094" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1745 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>