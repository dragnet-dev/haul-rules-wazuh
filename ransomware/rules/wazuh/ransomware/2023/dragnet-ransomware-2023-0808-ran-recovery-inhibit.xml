<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0808 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: e3e4ee7b-9d54-545d-bc2b-485a5f937c9f -->
  <rule id="594382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0808 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>