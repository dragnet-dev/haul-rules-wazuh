<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2318 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0b2ade35-6a34-563c-86bd-dc33b75bdf18 -->
  <rule id="215343" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2318 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>