<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4705 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 9bf87d90-cdbe-5270-b0a4-66ec92bbb9df -->
  <rule id="493405" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4705 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>