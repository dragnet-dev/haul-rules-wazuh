<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1775 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c2fd78ef-d42d-582d-9e74-706cefee488a -->
  <rule id="548578" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1775 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>