<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3722 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 87dcdd44-22b1-5f47-af1b-b5de62ec2659 -->
  <rule id="458173" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3722 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>