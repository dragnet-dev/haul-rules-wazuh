<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1583 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 7f5d6b4d-84d7-5ee5-9784-f99e9f660fc8 -->
  <rule id="666187" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1583 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>