<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4255 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c5bf79cf-f55f-54b4-9434-416d1cdde0e9 -->
  <rule id="619179" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4255 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>