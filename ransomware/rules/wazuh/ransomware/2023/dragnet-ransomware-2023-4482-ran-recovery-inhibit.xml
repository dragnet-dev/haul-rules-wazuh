<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4482 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: da795312-d68b-5c51-802e-f52f2843a5a1 -->
  <rule id="487953" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4482 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>