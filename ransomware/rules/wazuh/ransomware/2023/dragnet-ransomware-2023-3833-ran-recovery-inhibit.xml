<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3833 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 0fe57dce-e55b-5288-8113-47d3874d3e0a -->
  <rule id="317212" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3833 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>