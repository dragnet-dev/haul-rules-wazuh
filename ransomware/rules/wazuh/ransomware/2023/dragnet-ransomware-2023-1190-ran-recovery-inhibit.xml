<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1190 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 9289badf-291a-507c-91a7-beb700cfa295 -->
  <rule id="678170" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1190 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>