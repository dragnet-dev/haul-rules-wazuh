<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3400 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 45999d5c-9345-50c3-8820-b05e7fc73e02 -->
  <rule id="259975" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3400 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>