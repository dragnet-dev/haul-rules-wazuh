<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4943 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9401aed2-8c66-5fe5-9f55-a7931da72f39 -->
  <rule id="706830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4943 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>