<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4262 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 87a08a13-aade-5568-9dda-2f0dbef8420d -->
  <rule id="543338" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4262 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>