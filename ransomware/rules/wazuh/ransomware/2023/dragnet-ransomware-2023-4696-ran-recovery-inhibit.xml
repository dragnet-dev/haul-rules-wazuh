<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4696 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 89ca6254-936c-5183-9d47-8a23cce57195 -->
  <rule id="598662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4696 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>