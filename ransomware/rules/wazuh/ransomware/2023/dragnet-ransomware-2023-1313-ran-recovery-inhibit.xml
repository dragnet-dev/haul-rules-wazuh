<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1313 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: fea7a53d-c2ae-5362-91b8-215e3acbfa90 -->
  <rule id="319625" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1313 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>