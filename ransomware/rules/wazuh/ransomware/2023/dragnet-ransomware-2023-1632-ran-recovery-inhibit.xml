<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1632 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 211e311a-f554-5b68-a151-53dfb131ac1e -->
  <rule id="790311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1632 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>