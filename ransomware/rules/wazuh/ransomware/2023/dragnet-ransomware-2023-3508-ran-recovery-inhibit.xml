<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3508 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: ae714bda-4bbc-58a6-baca-b5869ce2e08b -->
  <rule id="195435" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3508 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>