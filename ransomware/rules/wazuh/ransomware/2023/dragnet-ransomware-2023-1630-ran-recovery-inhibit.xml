<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1630 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 27fa35fc-c393-571d-83c9-b4414777a4d6 -->
  <rule id="759775" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1630 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>