<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5120 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b1c67da1-0257-551a-a10c-38dc4e363b51 -->
  <rule id="261885" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5120 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>