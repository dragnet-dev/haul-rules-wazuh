<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4460 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: ad21e517-0ca7-5865-a215-7d8f3acc0ac9 -->
  <rule id="171505" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4460 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>