<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3200 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 4b6de1e5-a4e5-5eac-9746-ddbd689f54a7 -->
  <rule id="237581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3200 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>