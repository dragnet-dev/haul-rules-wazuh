<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1735 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: c174bd16-e2bc-5c05-a9e9-6f725e201df5 -->
  <rule id="516733" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1735 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>