<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4389 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: 44e69b91-6276-5b82-b263-df9e0d811264 -->
  <rule id="349915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4389 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>