<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3460 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 05c19799-a0e5-5a03-a405-1b02d8686cfe -->
  <rule id="319799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3460 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>