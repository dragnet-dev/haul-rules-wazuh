<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0309 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 41edf5a1-0862-5f3a-a160-884a10d22b9d -->
  <rule id="917435" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0309 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>