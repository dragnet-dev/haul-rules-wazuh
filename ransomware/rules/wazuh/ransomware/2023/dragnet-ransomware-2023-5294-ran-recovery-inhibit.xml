<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5294 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: f6fcaf0a-bada-5e4a-b548-a18ee3d0f180 -->
  <rule id="488303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5294 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>