  <rule id="695276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4592 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
