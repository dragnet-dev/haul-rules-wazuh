<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0924 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 67abd002-d144-5d97-bfea-28119e29e57f -->
  <rule id="171810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0924 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>