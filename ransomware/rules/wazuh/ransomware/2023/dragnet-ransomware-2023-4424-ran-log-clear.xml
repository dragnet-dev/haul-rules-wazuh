<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4424 — Event Log Clearing (vendetta) | Status: deprecated | Sigma ID: 85304b8f-e894-521e-90af-2597b6a8d9c6 -->
  <rule id="564875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4424 — Event Log Clearing (vendetta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>