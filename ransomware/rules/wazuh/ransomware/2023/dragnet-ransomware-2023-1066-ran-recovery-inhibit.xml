<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1066 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 8d68f14d-e3ff-5130-8649-9b7517f2e458 -->
  <rule id="567031" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1066 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>