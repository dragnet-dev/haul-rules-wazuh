<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0386 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 8b0b52f0-4472-5d2c-8810-775555267f8a -->
  <rule id="525152" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0386 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>