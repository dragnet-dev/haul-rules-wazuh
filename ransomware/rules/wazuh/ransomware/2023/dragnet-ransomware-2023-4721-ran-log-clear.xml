<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4721 — Event Log Clearing (crosslock) | Status: experimental | Sigma ID: 0d3baa3e-d9b7-5d61-916a-472514cc17c4 -->
  <rule id="177543" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4721 — Event Log Clearing (crosslock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>