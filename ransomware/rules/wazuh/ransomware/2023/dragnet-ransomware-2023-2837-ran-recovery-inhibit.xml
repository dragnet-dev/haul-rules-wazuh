<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2837 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: bdb0e438-bf1d-5867-8f28-a34046cefa63 -->
  <rule id="456144" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2837 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>