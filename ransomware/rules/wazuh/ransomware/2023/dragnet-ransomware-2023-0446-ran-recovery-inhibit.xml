<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0446 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 2ea75e03-5e49-52bc-8cf6-c4cbfeb84e59 -->
  <rule id="394814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0446 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>