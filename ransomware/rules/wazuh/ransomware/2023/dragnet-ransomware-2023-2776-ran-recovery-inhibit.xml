<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2776 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: c947d862-2f55-5fe5-b3ce-21f1a6787fe3 -->
  <rule id="371658" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2776 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>