<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2802 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 4118f533-16d2-5c2d-9a76-678bd9b01da5 -->
  <rule id="390353" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2802 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>