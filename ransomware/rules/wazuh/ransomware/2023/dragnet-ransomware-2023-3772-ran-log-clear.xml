<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3772 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 7ac42d4d-ad3b-50f5-a988-cf77aa7e28f8 -->
  <rule id="543085" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3772 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>