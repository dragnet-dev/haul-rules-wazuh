<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0054 — Recovery Inhibition (cryptbb) | Status: experimental | Sigma ID: 708c5cc5-8afa-5663-9583-3c53836ad2da -->
  <rule id="114492" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0054 — Recovery Inhibition (cryptbb)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>