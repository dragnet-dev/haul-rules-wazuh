<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0243 — Recovery Inhibition (mallox) | Status: experimental | Sigma ID: a01cbb11-df6f-5470-844f-05da5c1d8edc -->
  <rule id="603355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0243 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>