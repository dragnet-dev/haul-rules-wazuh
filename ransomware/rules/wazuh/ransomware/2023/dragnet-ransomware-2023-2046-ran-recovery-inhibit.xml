<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2046 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 3745e0dd-0df9-5c7b-8523-c275a8de64ac -->
  <rule id="689453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2046 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>