<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4074 — Event Log Clearing (darkrace) | Status: experimental | Sigma ID: c053d50c-88d4-510e-be8a-3b6fc990559d -->
  <rule id="228615" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4074 — Event Log Clearing (darkrace)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>