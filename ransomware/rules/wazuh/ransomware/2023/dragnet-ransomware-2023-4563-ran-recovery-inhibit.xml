<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4563 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 4b580bda-32a9-5459-b01e-d94765cae554 -->
  <rule id="409291" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4563 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>