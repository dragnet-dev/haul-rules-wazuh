<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0951 — Recovery Inhibition (mallox) | Status: experimental | Sigma ID: 7bc75c37-aaa0-56e4-ba98-80c823931867 -->
  <rule id="569212" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0951 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>