<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4555 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f4869cd7-4351-5cd9-9483-9722114cd99e -->
  <rule id="777916" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4555 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>