<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2839 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 42924e2c-1ac5-5a56-b3b2-33d4d513a895 -->
  <rule id="667982" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2839 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>