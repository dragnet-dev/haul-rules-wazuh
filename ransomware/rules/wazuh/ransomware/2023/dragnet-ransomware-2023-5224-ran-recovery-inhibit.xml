<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5224 — Recovery Inhibition (losttrust) | Status: deprecated | Sigma ID: 8c403c76-3ccc-5ffa-aaae-1e1babfb380b -->
  <rule id="546460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5224 — Recovery Inhibition (losttrust)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>