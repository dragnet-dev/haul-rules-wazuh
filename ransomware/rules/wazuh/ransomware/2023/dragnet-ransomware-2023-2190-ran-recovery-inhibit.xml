<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2190 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f0407d69-f86c-5e64-b937-611f062b19fd -->
  <rule id="706525" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2190 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>