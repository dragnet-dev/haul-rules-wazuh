<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4835 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ae418227-47d3-5360-822a-29bf508eb95c -->
  <rule id="944182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4835 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>