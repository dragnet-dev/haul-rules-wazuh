<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2618 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 68e21150-514e-5e8d-8478-c636372f99e4 -->
  <rule id="302211" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2618 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>