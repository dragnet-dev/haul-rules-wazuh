<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0834 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d82ff8cc-2f20-52a8-bf23-bbd55d48dabd -->
  <rule id="940478" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0834 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>