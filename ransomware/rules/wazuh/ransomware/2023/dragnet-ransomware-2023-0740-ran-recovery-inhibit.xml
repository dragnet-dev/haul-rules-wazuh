<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0740 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8e6bef1c-de34-5197-a094-a4c418c61ba6 -->
  <rule id="543951" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0740 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>