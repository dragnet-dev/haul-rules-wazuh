<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3163 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 2e76225d-749c-55f1-875b-e67d24fd40f3 -->
  <rule id="276225" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3163 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>