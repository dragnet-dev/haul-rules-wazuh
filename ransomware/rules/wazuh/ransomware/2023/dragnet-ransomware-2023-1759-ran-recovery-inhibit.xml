<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1759 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 40dde1c4-a5f5-59bd-8ebe-e858ad4bda98 -->
  <rule id="873901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1759 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>