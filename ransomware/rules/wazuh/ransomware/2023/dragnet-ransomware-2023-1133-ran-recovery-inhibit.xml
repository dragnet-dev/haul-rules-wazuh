<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1133 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: f4dd4ca1-791c-5f55-8600-a331cc0bf738 -->
  <rule id="143276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1133 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>