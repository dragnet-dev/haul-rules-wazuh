<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5244 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e36f3877-2522-5695-8c97-237fb55b418b -->
  <rule id="599138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5244 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>