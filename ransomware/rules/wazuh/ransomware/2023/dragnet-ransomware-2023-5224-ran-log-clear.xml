<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5224 — Event Log Clearing (losttrust) | Status: deprecated | Sigma ID: 0f926b00-ab7c-5bcd-9594-bdb1baf24238 -->
  <rule id="848270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5224 — Event Log Clearing (losttrust)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>