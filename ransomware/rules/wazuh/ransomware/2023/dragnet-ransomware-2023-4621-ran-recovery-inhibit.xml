<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4621 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 4898610c-1dd7-5ba8-849b-9e2c4b7d7a56 -->
  <rule id="498610" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4621 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>