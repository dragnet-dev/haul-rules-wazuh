<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4746 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 2691ef4b-2df8-5493-836f-92c244c05f96 -->
  <rule id="691354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4746 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>