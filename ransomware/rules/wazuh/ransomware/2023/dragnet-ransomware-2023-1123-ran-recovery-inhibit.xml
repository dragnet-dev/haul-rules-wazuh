<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1123 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 0fd50102-840c-5a21-9b95-94b0b3699f51 -->
  <rule id="835010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1123 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>