<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1134 — Event Log Clearing (raznatovic) | Status: experimental | Sigma ID: e14c2ae3-ddd0-55ad-a943-a67c0cc9173f -->
  <rule id="121802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1134 — Event Log Clearing (raznatovic)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>