<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2878 — Event Log Clearing (malas) | Status: experimental | Sigma ID: 34541335-2661-5e90-a68b-26a474fd0788 -->
  <rule id="854133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2878 — Event Log Clearing (malas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>