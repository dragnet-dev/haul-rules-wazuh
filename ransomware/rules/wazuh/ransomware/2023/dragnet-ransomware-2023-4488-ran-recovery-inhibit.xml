<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4488 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ab0a391e-65fb-55ef-a02c-a2c6ff1edb77 -->
  <rule id="137039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4488 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>