<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0139 — Event Log Clearing (abyss) | Status: deprecated | Sigma ID: 4b6e8cfd-7e89-518e-afa9-29fa163bc1c8 -->
  <rule id="237740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0139 — Event Log Clearing (abyss)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>