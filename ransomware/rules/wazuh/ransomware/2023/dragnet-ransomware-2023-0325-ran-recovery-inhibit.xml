<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0325 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 5e42cef2-7606-5dcf-bba1-110c638db617 -->
  <rule id="717358" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0325 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>