<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0675 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: ca04485f-4418-5364-9e8e-aef3bbd72edf -->
  <rule id="320448" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0675 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>