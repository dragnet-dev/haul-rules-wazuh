<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5348 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 7c63852a-8592-5e5b-b51a-d7f41ddb15d2 -->
  <rule id="446385" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5348 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>