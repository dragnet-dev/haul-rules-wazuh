<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4631 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 9581dfec-d4c7-578e-bb7d-8e7ae5e91cec -->
  <rule id="752959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4631 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>