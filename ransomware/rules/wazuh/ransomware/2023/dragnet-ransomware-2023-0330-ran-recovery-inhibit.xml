<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0330 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 07b0c720-87ca-5a3c-a33d-722ebef47aa7 -->
  <rule id="269272" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0330 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>