<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3765 — Event Log Clearing (siegedsec) | Status: deprecated | Sigma ID: 3f050d4a-cb8e-5f51-b9b9-ad7ca67155ec -->
  <rule id="208813" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3765 — Event Log Clearing (siegedsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>