<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2709 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3f6af38e-0a23-599c-8939-886f5c91ec0b -->
  <rule id="829913" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2709 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>