<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1435 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: c9494782-0c6a-5772-a35a-e6bcade4c65c -->
  <rule id="494947" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1435 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>