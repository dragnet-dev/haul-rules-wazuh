<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1045 — Recovery Inhibition (monti) | Status: deprecated | Sigma ID: 43e3b84b-5a7d-5366-b3b5-dd810b20a232 -->
  <rule id="323798" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1045 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>