<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0075 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 53fb9a0f-c81d-5f2c-880b-0aca4e7e7b8a -->
  <rule id="511194" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0075 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>