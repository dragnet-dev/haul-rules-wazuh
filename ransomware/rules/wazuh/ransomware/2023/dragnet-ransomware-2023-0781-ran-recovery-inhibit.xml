<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0781 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 3a765df5-1a61-54e9-9ee2-b5de5f57a60a -->
  <rule id="744063" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0781 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>