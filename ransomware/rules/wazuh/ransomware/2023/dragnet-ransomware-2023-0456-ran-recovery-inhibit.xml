<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0456 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 69c001f8-fe3f-56e2-b8a3-f423c543c721 -->
  <rule id="316001" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0456 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>