<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0312 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 537e16a9-e96f-5246-b59d-32e4bbfbdaf2 -->
  <rule id="369866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0312 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>