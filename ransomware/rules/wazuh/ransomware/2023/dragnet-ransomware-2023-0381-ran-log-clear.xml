<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0381 — Event Log Clearing (losttrust) | Status: deprecated | Sigma ID: f58bf58c-1130-5fc0-99ce-4c42a38b51a5 -->
  <rule id="490395" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0381 — Event Log Clearing (losttrust)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>