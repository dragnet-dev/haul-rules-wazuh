<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3769 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: f1b77e65-0cc8-57fe-8be6-e24bbbdfd288 -->
  <rule id="384446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3769 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>