<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0032 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 66909eec-98ed-56ea-9af2-2c53c78fa714 -->
  <rule id="270558" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0032 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>