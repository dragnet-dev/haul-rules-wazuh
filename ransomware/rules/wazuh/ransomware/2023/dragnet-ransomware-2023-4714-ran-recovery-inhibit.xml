<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4714 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: da7b6e74-cd06-54bc-bc7c-95ba41b1fa5a -->
  <rule id="300590" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4714 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>