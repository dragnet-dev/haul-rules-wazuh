<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0621 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: d4270baf-d18a-56ff-94fd-c2baeb2da7d5 -->
  <rule id="448331" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0621 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>