<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1092 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 1f5286b8-0826-58a8-b11f-0696dd32d093 -->
  <rule id="644587" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1092 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>