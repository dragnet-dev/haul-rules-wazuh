<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1573 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c2ae4df1-0416-5a74-b02f-04d630dade70 -->
  <rule id="625037" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1573 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>