<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4589 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6cc183e4-c2ee-5f08-80fc-2ed5750fc01a -->
  <rule id="940183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4589 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>