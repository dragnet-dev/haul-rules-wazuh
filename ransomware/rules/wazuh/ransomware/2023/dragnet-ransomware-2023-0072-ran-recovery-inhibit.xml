<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0072 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: a7237724-8c0a-5ab2-a68c-243db60eb4da -->
  <rule id="272377" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0072 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>