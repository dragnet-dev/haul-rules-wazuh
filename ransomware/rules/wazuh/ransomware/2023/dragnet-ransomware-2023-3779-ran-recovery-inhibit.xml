<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3779 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 76b4c53d-0ca0-58b6-8e55-58eea321516b -->
  <rule id="263965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3779 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>