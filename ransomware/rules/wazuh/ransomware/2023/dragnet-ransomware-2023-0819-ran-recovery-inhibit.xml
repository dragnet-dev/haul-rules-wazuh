<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0819 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 5d7d4f2f-8caa-5931-a971-ae8faf665cc8 -->
  <rule id="700879" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0819 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>