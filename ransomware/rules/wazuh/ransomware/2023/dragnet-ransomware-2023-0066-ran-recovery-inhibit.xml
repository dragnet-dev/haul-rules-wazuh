<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0066 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 3d8641a4-e73f-5d3d-978f-c665ed3f405f -->
  <rule id="998266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0066 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>