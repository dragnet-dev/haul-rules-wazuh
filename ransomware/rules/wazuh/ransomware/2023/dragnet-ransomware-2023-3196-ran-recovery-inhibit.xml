<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3196 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: dca8b350-0b57-5199-a0f1-377f4d4e4277 -->
  <rule id="349393" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3196 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>