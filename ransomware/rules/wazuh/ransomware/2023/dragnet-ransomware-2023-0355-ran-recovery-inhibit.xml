<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0355 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6124b861-01b7-5163-bb6e-803296d5d5eb -->
  <rule id="899586" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0355 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>