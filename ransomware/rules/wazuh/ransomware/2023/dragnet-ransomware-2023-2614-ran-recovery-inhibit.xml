<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2614 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 88ca2680-14f2-55e2-9f7a-538f9ab8f3d5 -->
  <rule id="573026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2614 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>