<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1379 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: d08edd02-9f2f-565f-9f9c-1573fc7b8b41 -->
  <rule id="961373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1379 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>