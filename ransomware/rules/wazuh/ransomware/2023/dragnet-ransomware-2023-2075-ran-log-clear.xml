<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2075 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 0e22282b-fb8b-5491-9b97-49d1c714efa6 -->
  <rule id="622282" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2075 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>