<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0661 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 3f190f26-476f-5edc-aa6f-5a6c7f0d1ff3 -->
  <rule id="211055" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0661 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>