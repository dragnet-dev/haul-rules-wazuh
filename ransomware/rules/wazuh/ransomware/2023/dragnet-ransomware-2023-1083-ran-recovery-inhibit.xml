<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1083 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: e38d5c74-530f-5c9e-bb48-b429b4e9f897 -->
  <rule id="183452" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1083 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>