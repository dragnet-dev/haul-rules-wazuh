<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0257 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 9c77af1c-5fc4-5021-8280-0d657ac7b9f3 -->
  <rule id="513487" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0257 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>