<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4562 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 6f4ba8ef-4bf4-5c98-99f9-4446cd509972 -->
  <rule id="253708" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4562 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>