<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1038 — Event Log Clearing (qilin) | Status: deprecated | Sigma ID: 41f553d8-6a31-5aa6-82fe-2c12fb9c4690 -->
  <rule id="944861" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1038 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>