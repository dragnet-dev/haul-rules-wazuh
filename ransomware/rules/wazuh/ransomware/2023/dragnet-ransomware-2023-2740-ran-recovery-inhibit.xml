<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2740 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: e31efe44-ea80-5abd-bf72-b8ce7a5bccee -->
  <rule id="565214" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2740 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>