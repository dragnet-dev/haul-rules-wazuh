<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5275 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 726561cf-0ed0-5977-8505-fe5c721c68d6 -->
  <rule id="924988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5275 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>