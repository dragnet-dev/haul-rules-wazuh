<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2482 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 71e06659-f4c1-5409-b6cb-585456175a2d -->
  <rule id="350066" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2482 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>