<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1307 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: acfec670-460b-5f5e-98e5-91cf0f678dea -->
  <rule id="885886" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1307 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>