<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2889 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 1e46c067-ed2b-5102-ab07-c50d6c3a069c -->
  <rule id="474806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2889 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>