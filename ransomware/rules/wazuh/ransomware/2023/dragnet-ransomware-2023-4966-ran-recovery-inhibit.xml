<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4966 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: dcf3975d-dbdc-5256-92f6-8e98fb90ba31 -->
  <rule id="935397" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4966 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>