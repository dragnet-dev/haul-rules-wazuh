<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2332 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 2ef95887-0cf4-5e87-87bc-ce685da79f1b -->
  <rule id="419588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2332 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>