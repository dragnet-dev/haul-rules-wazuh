<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0373 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: ebf4742b-0795-5495-b11d-650d9aca8522 -->
  <rule id="275474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0373 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>