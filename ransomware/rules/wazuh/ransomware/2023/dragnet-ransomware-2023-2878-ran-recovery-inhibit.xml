<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2878 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: e0e0cede-2ba8-5acd-aca4-9b6a33b84d62 -->
  <rule id="470446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2878 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>