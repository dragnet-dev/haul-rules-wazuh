<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1244 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 43b096fd-ae1c-5757-ad70-2db2dcb4541a -->
  <rule id="485551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1244 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>