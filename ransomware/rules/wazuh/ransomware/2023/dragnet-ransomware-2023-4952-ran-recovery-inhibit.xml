<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4952 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 550e2ea8-af3d-586f-b5c4-172c7d458347 -->
  <rule id="610286" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4952 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>