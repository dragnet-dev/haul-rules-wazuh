<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2421 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: f052e20b-c282-5260-9089-16393f71a760 -->
  <rule id="708462" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2421 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>