<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5082 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 303d96ec-fab6-5778-b27d-18ecaad92bcb -->
  <rule id="679150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5082 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>