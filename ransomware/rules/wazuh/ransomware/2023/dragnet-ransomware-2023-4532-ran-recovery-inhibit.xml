<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4532 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 37f3a35c-a2b7-5de4-9453-48ce0235cb26 -->
  <rule id="817835" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4532 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>