<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5027 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 43cd8cff-e983-5618-8115-7ab4fa7d17fd -->
  <rule id="994220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5027 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>