<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0962 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 4d548bb0-d512-5630-984b-25f5f1abd97c -->
  <rule id="440779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0962 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>