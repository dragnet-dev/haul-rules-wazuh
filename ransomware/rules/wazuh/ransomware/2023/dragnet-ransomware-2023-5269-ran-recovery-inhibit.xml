<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5269 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7f7ce61b-c1ba-5893-b3a0-63b6af2c3328 -->
  <rule id="671186" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5269 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>