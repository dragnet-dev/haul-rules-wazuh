<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4321 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 23de6459-4186-5823-9682-ee33e8798a07 -->
  <rule id="810645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4321 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>