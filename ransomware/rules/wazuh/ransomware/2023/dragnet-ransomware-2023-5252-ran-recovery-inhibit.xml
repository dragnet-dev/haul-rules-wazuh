<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5252 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 0ea7fce4-664c-56a9-bbf1-f95fdf0f7007 -->
  <rule id="717358" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5252 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>