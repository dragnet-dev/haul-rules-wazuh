<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4506 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: a6b0868b-228a-5d05-9e9e-cc699cac5eac -->
  <rule id="907086" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4506 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>