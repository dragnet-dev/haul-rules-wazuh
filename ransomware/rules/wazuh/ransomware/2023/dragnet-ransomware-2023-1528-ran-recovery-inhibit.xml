<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1528 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 00621798-16a7-5051-a35d-d7da6088c05d -->
  <rule id="917981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1528 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>