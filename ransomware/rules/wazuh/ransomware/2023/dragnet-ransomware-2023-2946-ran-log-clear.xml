<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2946 — Event Log Clearing (siegedsec) | Status: deprecated | Sigma ID: e24f1f5d-5bda-569d-8e0a-f2f7323bf78b -->
  <rule id="147871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2946 — Event Log Clearing (siegedsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>