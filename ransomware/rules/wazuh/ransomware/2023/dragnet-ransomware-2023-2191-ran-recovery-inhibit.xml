<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2191 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f4f74a1b-17db-51c1-aea7-3547691fa804 -->
  <rule id="467594" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2191 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>