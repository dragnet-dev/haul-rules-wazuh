<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5065 — Event Log Clearing (siegedsec) | Status: experimental | Sigma ID: 7a768428-73b4-5f7a-9f9d-908d5f665b70 -->
  <rule id="427684" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5065 — Event Log Clearing (siegedsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>