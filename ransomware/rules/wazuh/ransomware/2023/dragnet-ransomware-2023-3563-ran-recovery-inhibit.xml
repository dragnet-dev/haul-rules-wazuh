<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3563 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 3a2603ab-6aeb-5891-8f14-6c58610ad660 -->
  <rule id="421658" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3563 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>