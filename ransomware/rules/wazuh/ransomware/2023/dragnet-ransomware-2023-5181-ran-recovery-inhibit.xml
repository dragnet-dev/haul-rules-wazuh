<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5181 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 427943c0-e941-5c42-9f1d-646d33b9047d -->
  <rule id="647100" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5181 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>