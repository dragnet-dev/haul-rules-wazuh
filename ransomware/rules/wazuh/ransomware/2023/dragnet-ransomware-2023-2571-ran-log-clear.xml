<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2571 — Event Log Clearing (toufan) | Status: deprecated | Sigma ID: de542c54-2ff3-5bdd-8b89-71e80ba80d0f -->
  <rule id="960684" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2571 — Event Log Clearing (toufan)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>