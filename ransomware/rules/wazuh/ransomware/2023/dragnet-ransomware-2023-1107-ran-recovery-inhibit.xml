<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1107 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2ea1069e-b299-52c7-adc3-4e8a4137d462 -->
  <rule id="361069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1107 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>