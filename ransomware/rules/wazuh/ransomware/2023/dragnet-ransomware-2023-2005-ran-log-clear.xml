<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2005 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 7934f7a0-4a4c-5348-ab1f-875482e79f47 -->
  <rule id="469597" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2005 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>