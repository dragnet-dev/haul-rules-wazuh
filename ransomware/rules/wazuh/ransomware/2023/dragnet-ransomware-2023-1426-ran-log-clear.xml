<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1426 — Event Log Clearing (ragnarlocker) | Status: experimental | Sigma ID: a3bbd46c-3233-5ffb-a5a5-12b49705de35 -->
  <rule id="748934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1426 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>