<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4383 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e0615561-f795-55e6-89e5-35dfa629a777 -->
  <rule id="606155" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4383 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>