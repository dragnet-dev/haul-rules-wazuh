<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4179 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: 300e1fd5-f82c-59fd-a3d5-31e4e4aeffb0 -->
  <rule id="724349" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4179 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>