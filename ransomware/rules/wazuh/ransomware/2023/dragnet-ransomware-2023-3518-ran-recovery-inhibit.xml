<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3518 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3249776d-1e4f-5b6a-8c46-9401109b4ec9 -->
  <rule id="649776" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3518 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>