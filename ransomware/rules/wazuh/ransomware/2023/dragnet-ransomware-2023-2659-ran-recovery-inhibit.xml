<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2659 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: 055ffd6b-a458-5683-a918-79dd11024366 -->
  <rule id="593736" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2659 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>