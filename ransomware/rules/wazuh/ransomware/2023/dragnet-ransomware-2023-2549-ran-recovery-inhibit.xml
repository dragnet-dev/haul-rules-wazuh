<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2549 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: e0e9d3ec-6ed9-5ffc-beb1-9be756504d2b -->
  <rule id="107973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2549 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>