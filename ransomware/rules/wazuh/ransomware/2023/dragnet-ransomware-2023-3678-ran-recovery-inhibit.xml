<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3678 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 02ed7e9f-e336-5478-bd24-f67ef8ab23f8 -->
  <rule id="399669" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3678 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>