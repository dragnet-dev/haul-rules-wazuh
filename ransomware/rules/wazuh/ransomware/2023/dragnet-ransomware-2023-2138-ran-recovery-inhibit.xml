<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2138 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 4ead46e3-c940-55a7-8eeb-b742df508ab6 -->
  <rule id="314146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2138 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>