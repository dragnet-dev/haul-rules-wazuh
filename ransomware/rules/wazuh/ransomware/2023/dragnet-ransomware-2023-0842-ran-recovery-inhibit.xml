<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0842 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: ec45f137-a3b6-5d94-a0ba-32be24a2333b -->
  <rule id="283351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0842 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>