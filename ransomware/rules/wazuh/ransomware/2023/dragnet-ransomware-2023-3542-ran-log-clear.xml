<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3542 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: e6b1cb7b-fe97-52d5-b159-3fa196bc5f15 -->
  <rule id="708779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3542 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>