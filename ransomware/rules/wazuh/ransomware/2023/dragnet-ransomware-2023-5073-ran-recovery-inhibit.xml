<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5073 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 739e7f8e-4f4a-51b9-ad73-2c0b743ed92b -->
  <rule id="194207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5073 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>