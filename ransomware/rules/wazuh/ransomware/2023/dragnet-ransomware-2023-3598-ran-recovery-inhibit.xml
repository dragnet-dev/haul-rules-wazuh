<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3598 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 47f270bd-6a92-5c0d-b619-9b6137aaf200 -->
  <rule id="676331" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3598 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>