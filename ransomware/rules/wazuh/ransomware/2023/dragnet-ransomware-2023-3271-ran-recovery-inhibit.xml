<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3271 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: faa00cc3-a0ce-51dc-be82-0584edb1234b -->
  <rule id="216012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3271 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>