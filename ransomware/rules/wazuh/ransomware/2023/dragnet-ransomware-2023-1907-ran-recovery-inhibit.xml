<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1907 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: f0810bfe-48d9-5a80-b11a-5eb7461911fc -->
  <rule id="712971" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1907 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>