<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1736 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: b8d19318-47f6-533a-a02b-ccb15eac1fc7 -->
  <rule id="201193" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1736 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>