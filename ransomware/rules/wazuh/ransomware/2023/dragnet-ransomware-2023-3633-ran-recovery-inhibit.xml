<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3633 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 629d0b5a-6b46-5835-b552-253105d61d82 -->
  <rule id="812331" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3633 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>