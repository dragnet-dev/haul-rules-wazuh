<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2998 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e04262de-b4b2-5ccc-928c-a53fe270f18d -->
  <rule id="604262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2998 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>