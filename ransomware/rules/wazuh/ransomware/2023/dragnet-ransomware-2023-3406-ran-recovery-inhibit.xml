<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3406 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ecf739f1-02b2-5a98-8d0d-76cbdab388db -->
  <rule id="291739" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3406 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>