<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2715 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 4431e3b4-2ffb-5364-99ec-038912e722b3 -->
  <rule id="645659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2715 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>