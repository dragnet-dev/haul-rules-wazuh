<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0693 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 117c4433-5007-5b08-ad2d-b6bf8ee071ea -->
  <rule id="184443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0693 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>