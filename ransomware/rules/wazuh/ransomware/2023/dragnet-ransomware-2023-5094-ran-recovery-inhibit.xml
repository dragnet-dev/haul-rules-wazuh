<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5094 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d62f67ff-33e5-5a15-b3a1-78669ffaa2a1 -->
  <rule id="480767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5094 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>