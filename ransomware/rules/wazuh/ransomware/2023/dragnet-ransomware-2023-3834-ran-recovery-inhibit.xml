<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3834 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 2774eca0-1c89-5faf-ac04-4fa63b7adb71 -->
  <rule id="666090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3834 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>