<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4874 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 2be16d27-c661-54c5-8ff9-dd32967fdb2f -->
  <rule id="323469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4874 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>