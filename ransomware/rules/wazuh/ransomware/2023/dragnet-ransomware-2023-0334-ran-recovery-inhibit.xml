<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0334 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 9ec4eb14-708a-5bb1-a4c0-673326b2296c -->
  <rule id="303659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0334 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>