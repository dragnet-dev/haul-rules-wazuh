<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2749 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 1a85743b-8996-5765-9ef9-506ce70b3521 -->
  <rule id="985743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2749 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>