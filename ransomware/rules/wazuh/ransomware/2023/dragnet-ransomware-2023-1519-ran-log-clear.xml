<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1519 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 9f13e8a2-6194-5fda-9d3e-db1c04d196ac -->
  <rule id="846228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1519 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>