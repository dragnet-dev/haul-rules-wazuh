<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3902 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e4bb9a47-2781-5956-8f66-54fe2c4a33ff -->
  <rule id="628314" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3902 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>