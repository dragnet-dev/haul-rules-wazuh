<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1173 — Recovery Inhibition (play) | Status: experimental | Sigma ID: bad6452d-4dd0-50ab-825c-be4343101ad6 -->
  <rule id="389645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1173 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>