<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4535 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 78d9ff44-21bd-5898-929c-593951f02bee -->
  <rule id="630719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4535 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>