<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5201 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 6c222389-60dd-502b-a4f2-11ba51948253 -->
  <rule id="282223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5201 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>