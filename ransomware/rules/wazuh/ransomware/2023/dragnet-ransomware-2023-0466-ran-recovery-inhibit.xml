<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0466 — Recovery Inhibition (royal) | Status: deprecated | Sigma ID: c61a8e3b-ce40-5150-b618-4e8d378759e1 -->
  <rule id="629902" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0466 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>