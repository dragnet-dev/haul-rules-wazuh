<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0229 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: f13e471f-f134-5593-b563-d02e357b2ca9 -->
  <rule id="722247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0229 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>