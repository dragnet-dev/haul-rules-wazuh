<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0150 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 8822aa54-b632-5079-bccc-3e19b05bb539 -->
  <rule id="558602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0150 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>