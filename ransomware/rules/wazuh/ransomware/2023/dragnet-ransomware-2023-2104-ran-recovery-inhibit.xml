<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2104 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 44fd1b1b-ff70-55f2-b777-387c6dbea348 -->
  <rule id="142747" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2104 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>