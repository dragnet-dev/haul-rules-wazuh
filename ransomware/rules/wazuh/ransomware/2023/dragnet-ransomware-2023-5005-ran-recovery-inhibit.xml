<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5005 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: d2a5abb2-92a0-5046-980f-f0989fa2e2f3 -->
  <rule id="133771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5005 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>