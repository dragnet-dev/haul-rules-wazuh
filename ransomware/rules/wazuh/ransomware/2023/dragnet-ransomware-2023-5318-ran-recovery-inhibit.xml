<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5318 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 0ab522fc-f30e-5a5c-993f-df58244d819a -->
  <rule id="144367" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5318 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>