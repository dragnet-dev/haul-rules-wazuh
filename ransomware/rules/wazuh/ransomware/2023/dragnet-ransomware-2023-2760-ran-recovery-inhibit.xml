<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2760 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 3a9f7233-0984-5e67-82c6-94eb44773421 -->
  <rule id="539723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2760 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>