<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1195 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 068e4f81-9058-565e-ad51-6283925edd21 -->
  <rule id="963998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1195 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>