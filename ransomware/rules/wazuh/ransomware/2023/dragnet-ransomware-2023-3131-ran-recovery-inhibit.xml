<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3131 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: a5911d66-0f3b-5234-8d80-c0949b513241 -->
  <rule id="894589" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3131 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>