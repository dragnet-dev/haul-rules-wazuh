<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3240 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 7197f4f8-8c4b-5aab-8d8e-2353dabdfa44 -->
  <rule id="351674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3240 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>