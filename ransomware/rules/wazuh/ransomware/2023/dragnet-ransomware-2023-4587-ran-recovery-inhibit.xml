<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4587 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: bbef7624-8ee4-5295-ac19-cfd6dcd13a0c -->
  <rule id="411176" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4587 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>