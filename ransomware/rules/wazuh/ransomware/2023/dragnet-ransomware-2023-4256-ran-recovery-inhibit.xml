<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4256 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 11565771-d1e2-5b4f-a8db-4e39f235e8b0 -->
  <rule id="356577" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4256 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>