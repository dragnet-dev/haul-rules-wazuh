<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0816 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 980d766b-e245-599d-8f11-efb0a844ded8 -->
  <rule id="769376" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0816 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>