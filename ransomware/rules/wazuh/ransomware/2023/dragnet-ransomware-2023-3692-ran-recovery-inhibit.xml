<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3692 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 857df42f-cbb4-535f-a688-52f4bb2c1c9e -->
  <rule id="496154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3692 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>