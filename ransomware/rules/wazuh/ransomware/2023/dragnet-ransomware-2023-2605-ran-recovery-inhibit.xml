<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2605 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 4d9e0efd-5e85-5c45-8608-8a2e3ade4bf6 -->
  <rule id="296494" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2605 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>