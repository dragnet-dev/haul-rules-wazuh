<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2564 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: b86d0933-8326-5cb8-8be0-5598584775ae -->
  <rule id="198909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2564 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>