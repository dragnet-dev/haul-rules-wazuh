<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0744 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 0715ac39-4b90-5223-9538-1eff9dd4d491 -->
  <rule id="132123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0744 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>