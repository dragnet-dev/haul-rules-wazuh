<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0776 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 5763b673-890f-5704-8753-eccc986ee881 -->
  <rule id="321967" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0776 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>