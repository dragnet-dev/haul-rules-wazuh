<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4217 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 308f27b4-75e4-548e-b03d-0abf78f171b4 -->
  <rule id="809243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4217 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>