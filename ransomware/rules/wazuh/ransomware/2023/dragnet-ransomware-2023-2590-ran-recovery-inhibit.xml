<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2590 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 59024ddb-39da-5fe1-8948-bafeac473e2d -->
  <rule id="810365" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2590 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>