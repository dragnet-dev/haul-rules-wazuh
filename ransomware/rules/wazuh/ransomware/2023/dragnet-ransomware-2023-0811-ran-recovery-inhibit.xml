<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0811 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 7eccea48-4d6d-50be-a849-8713ea753a03 -->
  <rule id="309994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0811 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>