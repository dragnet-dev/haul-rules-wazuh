<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5273 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 79479b53-e4ae-57f1-9fba-2e253be394e3 -->
  <rule id="471675" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5273 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>