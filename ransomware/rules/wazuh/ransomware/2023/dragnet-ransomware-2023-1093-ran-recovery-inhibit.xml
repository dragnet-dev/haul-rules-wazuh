<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1093 — Recovery Inhibition (mallox) | Status: experimental | Sigma ID: 83fea200-4703-5d55-8aeb-b33abd3c63b5 -->
  <rule id="840422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1093 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>