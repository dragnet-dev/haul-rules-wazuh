<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4054 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3c8adde5-b734-5bd0-a2f9-7b34790b10c4 -->
  <rule id="793149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4054 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>