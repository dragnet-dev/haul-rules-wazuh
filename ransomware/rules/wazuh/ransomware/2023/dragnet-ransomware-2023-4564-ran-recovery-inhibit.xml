<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4564 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 68033462-bc93-5eb2-856d-20f14bd0d643 -->
  <rule id="603346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4564 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>