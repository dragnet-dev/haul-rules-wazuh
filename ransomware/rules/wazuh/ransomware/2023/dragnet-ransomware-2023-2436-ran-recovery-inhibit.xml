<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2436 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 36157ae9-1ad1-59ee-b3f7-4b7212e83a1c -->
  <rule id="356366" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2436 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>