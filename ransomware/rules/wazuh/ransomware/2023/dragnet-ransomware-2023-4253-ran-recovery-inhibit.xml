<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4253 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 584136c1-81b8-51e7-b82d-0a804a5a596c -->
  <rule id="446188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4253 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>