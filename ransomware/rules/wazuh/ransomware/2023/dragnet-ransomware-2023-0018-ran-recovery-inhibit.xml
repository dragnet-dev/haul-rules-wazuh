<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0018 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 5bf05bfa-ae9a-5a11-822d-061495bcd9f6 -->
  <rule id="653691" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0018 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>