<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1417 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: a10e1713-032c-56de-afca-030dd5a68a0a -->
  <rule id="817417" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1417 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>