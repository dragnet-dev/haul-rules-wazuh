<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0571 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 949ac794-ecec-5a95-98bd-ee51091c5734 -->
  <rule id="731167" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0571 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>