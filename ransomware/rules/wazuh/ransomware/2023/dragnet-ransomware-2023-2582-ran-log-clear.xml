<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2582 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 4f3a19f0-a5c0-576b-996a-3b72f5db27c5 -->
  <rule id="469819" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2582 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>