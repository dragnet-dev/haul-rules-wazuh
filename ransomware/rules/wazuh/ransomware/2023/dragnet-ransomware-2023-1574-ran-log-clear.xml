<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1574 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: a447cb66-4f3a-5ac0-a5c8-cab8735d2fb0 -->
  <rule id="974635" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1574 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>