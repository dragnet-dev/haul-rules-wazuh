<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3769 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 85830c26-7b42-5315-b5b2-28ca1bc33fb3 -->
  <rule id="573292" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3769 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>