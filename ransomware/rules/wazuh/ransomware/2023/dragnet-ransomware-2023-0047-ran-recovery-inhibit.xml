<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0047 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b6d3cb47-9eed-527e-aff8-96525ac944e4 -->
  <rule id="385611" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0047 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>