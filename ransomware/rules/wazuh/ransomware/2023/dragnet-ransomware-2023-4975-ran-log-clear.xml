<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4975 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 482aa19b-6cb1-55e2-906f-7a56f6b20444 -->
  <rule id="435621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4975 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>