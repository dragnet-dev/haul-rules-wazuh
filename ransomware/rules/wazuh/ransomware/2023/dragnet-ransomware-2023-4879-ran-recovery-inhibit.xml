<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4879 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 14e656d5-38e0-5479-9e7f-dffe405ca4aa -->
  <rule id="318509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4879 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>