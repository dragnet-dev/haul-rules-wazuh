<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1799 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: b85b068b-1dba-5a5d-b84f-804d3513bb12 -->
  <rule id="197106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1799 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>