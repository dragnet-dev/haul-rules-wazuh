<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2954 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 2da60501-19a5-5522-b008-05127e6f78af -->
  <rule id="206050" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2954 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>