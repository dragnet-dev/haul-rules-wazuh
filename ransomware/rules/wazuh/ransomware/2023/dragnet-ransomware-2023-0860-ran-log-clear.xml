<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0860 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 29b82a5b-89e4-5c2f-aac9-30f1e8431ffa -->
  <rule id="513225" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0860 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>