<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4524 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 4902255f-257f-56f7-afc4-601290e07854 -->
  <rule id="502255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4524 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>