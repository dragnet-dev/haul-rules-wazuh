<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3802 — Event Log Clearing (arvinclub) | Status: deprecated | Sigma ID: c6cee1a8-b4c4-5a69-9d34-6279c8d5d543 -->
  <rule id="794061" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3802 — Event Log Clearing (arvinclub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>