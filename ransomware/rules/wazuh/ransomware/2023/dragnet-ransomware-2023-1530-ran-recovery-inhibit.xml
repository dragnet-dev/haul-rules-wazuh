<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1530 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 830858aa-3a11-5f61-b20a-be2cea463f76 -->
  <rule id="793738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1530 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>