<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0520 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: dae2b8af-e61c-5de2-bb96-7d7fa5ec7ede -->
  <rule id="303638" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0520 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>