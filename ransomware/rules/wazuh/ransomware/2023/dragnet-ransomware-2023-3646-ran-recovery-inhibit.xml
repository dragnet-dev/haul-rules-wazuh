<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3646 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 66a7daeb-1f66-51ad-b5a4-b6d20d651c06 -->
  <rule id="130970" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3646 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>