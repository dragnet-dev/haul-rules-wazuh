<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4206 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d0765b6f-e3fb-5e26-bcf0-af2eeebb5534 -->
  <rule id="392251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4206 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>