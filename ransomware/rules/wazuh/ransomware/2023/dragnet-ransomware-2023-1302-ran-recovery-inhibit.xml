<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1302 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 51cd76a5-6494-509a-9b57-df6c459a099a -->
  <rule id="526176" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1302 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>