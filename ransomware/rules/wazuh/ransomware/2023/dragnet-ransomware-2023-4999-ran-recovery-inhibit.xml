<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4999 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: 51192ae3-13f7-5266-a517-ec2f3b21a223 -->
  <rule id="605326" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4999 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
