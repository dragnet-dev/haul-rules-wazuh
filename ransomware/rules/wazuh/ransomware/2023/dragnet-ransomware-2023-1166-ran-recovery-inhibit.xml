<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1166 — Recovery Inhibition (medusa) | Status: deprecated | Sigma ID: 7d8abb00-1a42-55ff-ab82-496d84d9fe87 -->
  <rule id="755515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1166 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
