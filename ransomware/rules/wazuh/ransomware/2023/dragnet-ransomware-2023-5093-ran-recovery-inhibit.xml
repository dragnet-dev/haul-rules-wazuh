<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5093 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 9a572b37-d970-53bd-bcae-026eebaf3ca3 -->
  <rule id="773163" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5093 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>