<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3694 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 92b3c000-b299-56d4-b741-e895bbb87e27 -->
  <rule id="673400" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3694 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>