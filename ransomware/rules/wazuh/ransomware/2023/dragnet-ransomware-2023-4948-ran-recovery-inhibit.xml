<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4948 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 589bcbfc-9f5e-5089-a64d-efe294d680a9 -->
  <rule id="715563" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4948 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>