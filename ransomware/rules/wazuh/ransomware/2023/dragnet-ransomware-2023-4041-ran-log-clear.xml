<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4041 — Event Log Clearing (mallox) | Status: deprecated | Sigma ID: 65d7e29d-3eb6-5308-8840-58b8f7eb6c58 -->
  <rule id="886062" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4041 — Event Log Clearing (mallox)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>