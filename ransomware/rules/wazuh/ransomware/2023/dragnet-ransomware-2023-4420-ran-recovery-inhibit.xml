<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4420 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: dd0ebc7b-b10e-5839-a2fb-218046250530 -->
  <rule id="155932" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4420 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>