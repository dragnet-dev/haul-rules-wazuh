<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1012 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: e553e5bf-06d0-5f11-a6a2-91966160447b -->
  <rule id="628625" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1012 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>