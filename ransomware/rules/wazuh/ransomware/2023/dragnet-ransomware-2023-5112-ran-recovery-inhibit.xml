<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5112 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: c1a3f222-e0f2-5170-a4fb-a4a822993a88 -->
  <rule id="514232" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5112 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>