<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0871 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3c822267-34a4-585d-bb96-a2d3e4d583b7 -->
  <rule id="782226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0871 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>