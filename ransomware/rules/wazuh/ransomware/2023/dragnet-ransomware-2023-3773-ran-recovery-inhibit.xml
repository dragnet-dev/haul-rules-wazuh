<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3773 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 16a80a72-9357-51ed-a796-3b9688ebedd3 -->
  <rule id="768907" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3773 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>