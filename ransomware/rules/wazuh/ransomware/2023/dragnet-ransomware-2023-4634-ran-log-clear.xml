<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4634 — Event Log Clearing (siegedsec) | Status: deprecated | Sigma ID: 6c5eee4e-8ae8-5a04-84ca-5c5ae5f1723f -->
  <rule id="947982" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4634 — Event Log Clearing (siegedsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>