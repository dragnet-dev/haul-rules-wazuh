<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0595 — Event Log Clearing (cactus) | Status: experimental | Sigma ID: fe1e336f-1083-50d3-af30-a9f6e84dcc5e -->
  <rule id="567033" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0595 — Event Log Clearing (cactus)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>