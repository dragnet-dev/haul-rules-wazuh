<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3954 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 1e485f7b-ffcb-5c1f-a805-51251b226f2b -->
  <rule id="477757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3954 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>