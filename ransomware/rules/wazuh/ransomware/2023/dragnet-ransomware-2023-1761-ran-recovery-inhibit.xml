<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1761 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: 48b90b25-a022-59f0-9cfa-f4852dfa523d -->
  <rule id="447851" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1761 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>