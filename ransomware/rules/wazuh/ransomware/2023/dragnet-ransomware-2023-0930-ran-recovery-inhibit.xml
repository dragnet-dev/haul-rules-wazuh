<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0930 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 8fd374fb-c43c-5d2c-a43e-82a6d6c2ced4 -->
  <rule id="601374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0930 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>