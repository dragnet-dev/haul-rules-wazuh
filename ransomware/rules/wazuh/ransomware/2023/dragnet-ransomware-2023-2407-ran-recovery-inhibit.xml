<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2407 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 7944905a-43d6-5978-b4df-bb91dc143b6b -->
  <rule id="844905" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2407 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>