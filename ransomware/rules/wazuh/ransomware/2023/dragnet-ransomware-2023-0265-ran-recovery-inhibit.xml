<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0265 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: fe6f83fd-b446-5e18-ae03-059bb96961f7 -->
  <rule id="575183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0265 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>