<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3061 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: ab187895-9756-5869-bc77-2b6326e17b9b -->
  <rule id="911878" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3061 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>