<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2400 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f0964655-21b4-585e-a768-419a411a1b7b -->
  <rule id="709646" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2400 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>