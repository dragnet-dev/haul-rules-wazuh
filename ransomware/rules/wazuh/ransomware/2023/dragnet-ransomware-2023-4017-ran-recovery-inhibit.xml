<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4017 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: 7eeedf44-9a9d-5027-a630-d54ada5062ac -->
  <rule id="318687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4017 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>