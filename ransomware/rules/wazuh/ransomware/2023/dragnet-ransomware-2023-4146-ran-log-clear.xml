<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4146 — Event Log Clearing (cactus) | Status: deprecated | Sigma ID: 6ff8811d-3eb3-5ea6-bcaf-aff0aaa0b29e -->
  <rule id="991881" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4146 — Event Log Clearing (cactus)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>