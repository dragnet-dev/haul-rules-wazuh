<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0688 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: a53ae63f-0cef-58af-84d1-2da001ef592c -->
  <rule id="997426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0688 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>