<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1361 — Event Log Clearing (play) | Status: deprecated | Sigma ID: d43c2581-e46d-5ce8-853c-cb319d4ff605 -->
  <rule id="450025" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1361 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>