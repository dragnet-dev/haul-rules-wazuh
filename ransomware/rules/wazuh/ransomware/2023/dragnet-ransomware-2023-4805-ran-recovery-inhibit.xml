<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4805 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 503cf493-aafd-54cf-8ba2-a456f15ee615 -->
  <rule id="489754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4805 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>