<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4228 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ec1de71b-c1ff-5936-bdea-959e8b319fbf -->
  <rule id="746387" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4228 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>