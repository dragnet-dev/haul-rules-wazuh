<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3006 — Event Log Clearing (dunghill) | Status: experimental | Sigma ID: 6149c2dc-c3eb-5770-8a90-31f19b7c92fe -->
  <rule id="543405" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3006 — Event Log Clearing (dunghill)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>