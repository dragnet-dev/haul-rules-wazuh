<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3370 — Event Log Clearing (bianlian) | Status: deprecated | Sigma ID: b6c2778a-a5f4-5d9c-95fa-68dbde9fc74e -->
  <rule id="168277" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3370 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>