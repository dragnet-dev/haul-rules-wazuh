<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5254 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: fd08fe77-319c-52f1-9f41-8582ea3e02bd -->
  <rule id="279102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5254 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>