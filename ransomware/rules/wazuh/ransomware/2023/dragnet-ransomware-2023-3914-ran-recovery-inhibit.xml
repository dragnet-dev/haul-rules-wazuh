<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3914 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: a4a09cba-f910-5b87-804a-a78c1fa2129e -->
  <rule id="978556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3914 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>