<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4199 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 5144f3e1-f154-5b62-a020-f6a2ad814f28 -->
  <rule id="671102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4199 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>