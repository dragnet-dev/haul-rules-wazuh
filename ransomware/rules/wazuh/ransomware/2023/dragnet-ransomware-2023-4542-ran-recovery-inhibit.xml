<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4542 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 987b048f-4d4c-51e2-8aff-d24de0b8fa86 -->
  <rule id="780304" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4542 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>