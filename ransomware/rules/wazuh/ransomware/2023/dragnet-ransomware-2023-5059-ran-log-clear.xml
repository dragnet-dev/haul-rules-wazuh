<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5059 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: cd829d3f-ae4e-542e-b2b7-c9b8f5e78492 -->
  <rule id="693277" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5059 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>