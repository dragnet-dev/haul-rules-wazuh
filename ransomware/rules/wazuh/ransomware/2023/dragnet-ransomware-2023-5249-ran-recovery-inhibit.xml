<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5249 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 74090a70-bbf7-5791-9680-8792d0ca385d -->
  <rule id="385450" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5249 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>