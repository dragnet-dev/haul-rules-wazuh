<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0970 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 4a19fc62-ac56-5881-9723-8e3647337eae -->
  <rule id="199516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0970 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>