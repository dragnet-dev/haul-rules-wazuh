<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3376 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 646af4c6-a397-5aeb-a830-adbd90e7c1d6 -->
  <rule id="855514" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3376 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>