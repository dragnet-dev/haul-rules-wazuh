<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4174 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: f31dd213-0b5a-57c8-9534-966760724374 -->
  <rule id="421572" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4174 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>