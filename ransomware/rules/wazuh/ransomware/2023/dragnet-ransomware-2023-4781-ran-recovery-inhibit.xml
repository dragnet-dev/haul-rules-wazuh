<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4781 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 93cd17c7-8edc-5631-82bd-6c9c82967d41 -->
  <rule id="701317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4781 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>