<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1229 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: ba97c2b3-f59c-5aee-ad56-6f99eddd6ca3 -->
  <rule id="391642" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1229 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>