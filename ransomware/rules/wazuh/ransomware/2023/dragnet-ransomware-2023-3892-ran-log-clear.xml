<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3892 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: f2508efe-0af6-5a56-aec0-db6a9f7e0e78 -->
  <rule id="740142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3892 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>