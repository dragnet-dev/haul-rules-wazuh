<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0107 — Recovery Inhibition (ransomed) | Status: experimental | Sigma ID: d4e0dcf9-7744-5bc5-aaad-05ff2522ddf4 -->
  <rule id="224700" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0107 — Recovery Inhibition (ransomed)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>