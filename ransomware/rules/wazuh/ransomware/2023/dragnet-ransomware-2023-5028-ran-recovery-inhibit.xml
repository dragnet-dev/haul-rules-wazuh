<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5028 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 0f9ecc64-c9fb-519c-aa2f-92d40eab0460 -->
  <rule id="350526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5028 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>