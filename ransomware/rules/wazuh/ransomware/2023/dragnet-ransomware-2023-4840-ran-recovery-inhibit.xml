<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4840 — Recovery Inhibition (cryptbb) | Status: experimental | Sigma ID: de2d9559-7cea-53c7-83e2-562f3ed2d328 -->
  <rule id="956595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4840 — Recovery Inhibition (cryptbb)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>