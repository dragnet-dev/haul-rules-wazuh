<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3622 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f5d073ce-27e5-5838-bf4a-6584ef626477 -->
  <rule id="793073" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3622 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>