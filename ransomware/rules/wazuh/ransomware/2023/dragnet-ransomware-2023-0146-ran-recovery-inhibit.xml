<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0146 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 133b8696-d9bb-525b-9d46-17741d8365ef -->
  <rule id="439869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0146 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>