<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3814 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 42ca13b1-bef0-57e1-ac49-75ac233c2391 -->
  <rule id="295413" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3814 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>