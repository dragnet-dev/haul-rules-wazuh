<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3641 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: bd546e99-298d-56da-9d88-4f7957df262b -->
  <rule id="432750" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3641 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>