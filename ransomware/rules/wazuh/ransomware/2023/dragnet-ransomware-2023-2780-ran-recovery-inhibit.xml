<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2780 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 0643e914-5b7c-52a0-b134-81545e0b5bf6 -->
  <rule id="230291" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2780 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>