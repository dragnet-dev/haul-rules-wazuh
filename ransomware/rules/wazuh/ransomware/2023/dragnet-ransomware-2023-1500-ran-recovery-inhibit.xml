<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1500 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 2c593cd2-0359-5917-b201-b2281fbbc44d -->
  <rule id="716013" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1500 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>