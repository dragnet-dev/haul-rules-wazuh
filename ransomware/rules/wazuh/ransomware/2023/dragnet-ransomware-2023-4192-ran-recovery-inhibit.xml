<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4192 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 5709c77a-01a2-5324-94e6-ce662373f053 -->
  <rule id="235677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4192 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>