<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1294 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: b4c2bb4e-9884-5881-85cf-9a9000e21ce7 -->
  <rule id="300859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1294 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>