<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1674 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: dd24243a-28e7-53e8-b6e8-8e06f00724b1 -->
  <rule id="512424" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1674 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>