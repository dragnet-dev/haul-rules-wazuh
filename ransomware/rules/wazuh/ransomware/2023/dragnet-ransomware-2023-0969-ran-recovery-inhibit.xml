<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0969 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: 85fe64fa-63a9-55d4-b13b-977322825861 -->
  <rule id="501464" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0969 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>