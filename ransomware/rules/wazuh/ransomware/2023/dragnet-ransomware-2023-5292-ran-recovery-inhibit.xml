<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5292 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 069cfa6c-9381-559a-97ee-798417f7f504 -->
  <rule id="259466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5292 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>