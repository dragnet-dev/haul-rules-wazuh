<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1177 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 368c6b3e-1766-5a9e-891d-3e15100a30e8 -->
  <rule id="541073" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1177 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>