<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2300 — Recovery Inhibition (darkpower) | Status: experimental | Sigma ID: c4f68c28-609d-5139-9528-5f0f28f41e99 -->
  <rule id="599500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2300 — Recovery Inhibition (darkpower)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>