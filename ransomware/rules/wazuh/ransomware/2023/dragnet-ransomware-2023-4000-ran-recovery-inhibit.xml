<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4000 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1b6f99f6-3a48-5b8f-b8ac-69508257edc3 -->
  <rule id="891199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4000 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>