<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3734 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 01db7d86-d6a1-5d73-be11-076063cc8252 -->
  <rule id="512586" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3734 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>