<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2861 — Event Log Clearing (malas) | Status: experimental | Sigma ID: 3fba1e15-5242-5f7d-a1e9-9da7e49e6f55 -->
  <rule id="910270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2861 — Event Log Clearing (malas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>