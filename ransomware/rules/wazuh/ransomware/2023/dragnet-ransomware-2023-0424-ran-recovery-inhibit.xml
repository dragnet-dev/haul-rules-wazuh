<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0424 — Recovery Inhibition (cuba) | Status: experimental | Sigma ID: 485b2c48-3bb7-5114-9709-502544e1add9 -->
  <rule id="443404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0424 — Recovery Inhibition (cuba)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>