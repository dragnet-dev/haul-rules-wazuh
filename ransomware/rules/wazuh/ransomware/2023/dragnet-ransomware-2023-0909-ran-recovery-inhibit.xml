<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0909 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: a235e651-855d-5b47-83df-175fb34e8cf2 -->
  <rule id="837746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0909 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>