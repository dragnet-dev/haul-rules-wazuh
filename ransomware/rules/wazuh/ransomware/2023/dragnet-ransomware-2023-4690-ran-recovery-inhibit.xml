<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4690 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: c0ec4917-4c98-50ba-87fa-f69a3142bd63 -->
  <rule id="495649" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4690 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>