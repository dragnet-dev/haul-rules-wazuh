<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5375 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 5f608441-ab11-5e57-91e9-9d5642c31f04 -->
  <rule id="660844" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5375 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>