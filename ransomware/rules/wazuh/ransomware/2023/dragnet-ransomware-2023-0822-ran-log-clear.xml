<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0822 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: dba18ae1-fdcf-5290-818d-8b5f5fea3a64 -->
  <rule id="322698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0822 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>