<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2213 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: eb69ddcd-352e-5f97-92ab-d3e1fa10d641 -->
  <rule id="733885" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2213 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>