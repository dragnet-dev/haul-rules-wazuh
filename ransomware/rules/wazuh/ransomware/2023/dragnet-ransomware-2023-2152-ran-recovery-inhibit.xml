<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2152 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 24946569-e9dc-5045-9220-f700c95718f2 -->
  <rule id="794656" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2152 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>