<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3423 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 860aee92-5ddf-5cbc-b6b0-a89e45e72abf -->
  <rule id="925358" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3423 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>