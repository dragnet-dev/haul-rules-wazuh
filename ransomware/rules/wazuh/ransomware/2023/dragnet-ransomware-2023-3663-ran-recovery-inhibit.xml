<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3663 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: d60d6a3d-b0b1-55c8-a816-a6c7f3bc7633 -->
  <rule id="883786" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3663 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>