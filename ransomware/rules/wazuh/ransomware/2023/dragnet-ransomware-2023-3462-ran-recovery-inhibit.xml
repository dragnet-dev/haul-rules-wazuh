<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3462 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 6cf1d62b-7518-525b-812e-6fae6b207dd5 -->
  <rule id="189096" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3462 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>