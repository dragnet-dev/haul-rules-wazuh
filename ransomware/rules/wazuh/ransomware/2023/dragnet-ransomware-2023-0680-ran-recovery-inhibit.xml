<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0680 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: cf7cec30-d917-5745-844b-baed5404ed45 -->
  <rule id="510700" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0680 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>