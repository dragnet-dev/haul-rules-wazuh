<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3383 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 06d9062c-4104-5190-afc9-c4d150c6f037 -->
  <rule id="299062" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3383 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>