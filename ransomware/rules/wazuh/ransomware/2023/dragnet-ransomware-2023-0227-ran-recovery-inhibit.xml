<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0227 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: cbf3e922-3d6a-5fc3-946f-76db8bb062bc -->
  <rule id="821429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0227 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>