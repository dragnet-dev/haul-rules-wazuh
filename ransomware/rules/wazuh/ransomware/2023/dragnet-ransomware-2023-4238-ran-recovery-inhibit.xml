<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4238 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: f1c32fda-2c0c-52c3-864c-93145a7f6eb8 -->
  <rule id="385327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4238 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>