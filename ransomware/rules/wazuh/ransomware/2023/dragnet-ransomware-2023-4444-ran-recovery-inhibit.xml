<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4444 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: d0f3194c-9dde-5712-9b05-ad52e30cc4c0 -->
  <rule id="395319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4444 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>