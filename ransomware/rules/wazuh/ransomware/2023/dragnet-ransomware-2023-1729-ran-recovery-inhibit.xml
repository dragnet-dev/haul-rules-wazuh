<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1729 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 09cdbcec-cc3c-5d3c-abd7-69a1b31dfc08 -->
  <rule id="479886" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1729 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>