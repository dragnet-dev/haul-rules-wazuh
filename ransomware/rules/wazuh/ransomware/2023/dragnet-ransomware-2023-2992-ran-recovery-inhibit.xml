<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2992 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: c0d7ac31-04cf-5f2a-b80e-6a0405e2990d -->
  <rule id="550444" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2992 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>