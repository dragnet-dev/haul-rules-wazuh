<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4263 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 1f518f64-a6a6-535d-861a-9a1bf2c2bad1 -->
  <rule id="643036" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4263 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>