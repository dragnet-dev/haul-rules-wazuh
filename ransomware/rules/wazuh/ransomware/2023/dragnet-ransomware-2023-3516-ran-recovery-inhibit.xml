<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3516 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: acc1fa1d-5061-5088-84cb-7bd9ed233771 -->
  <rule id="876346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3516 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>