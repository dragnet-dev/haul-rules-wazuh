<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4417 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 499970ad-9f14-55f0-a235-7faed1b03a1d -->
  <rule id="899530" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4417 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>