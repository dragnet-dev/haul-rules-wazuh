<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4428 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f65825af-1685-5a71-bcb7-4e89244e7fb9 -->
  <rule id="765825" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4428 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>