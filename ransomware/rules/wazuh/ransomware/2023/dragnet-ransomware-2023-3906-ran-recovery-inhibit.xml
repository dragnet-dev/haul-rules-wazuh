<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3906 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: d7133a27-4aa1-50ca-9d07-38b6918f69dd -->
  <rule id="494138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3906 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>