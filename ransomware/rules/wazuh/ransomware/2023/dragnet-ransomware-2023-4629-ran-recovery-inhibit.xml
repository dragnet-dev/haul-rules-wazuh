<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4629 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: e464a4e2-6b7e-5535-8ecb-07c5d488d346 -->
  <rule id="614344" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4629 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>