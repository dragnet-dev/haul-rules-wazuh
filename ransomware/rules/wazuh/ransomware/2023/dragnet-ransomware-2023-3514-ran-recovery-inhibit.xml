<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3514 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: d0981b8a-4aba-5078-9591-4acc8ebc7bf9 -->
  <rule id="395707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3514 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>