<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5135 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: a02bd565-e82c-57b6-a493-0d70cbb38e08 -->
  <rule id="867015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5135 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>