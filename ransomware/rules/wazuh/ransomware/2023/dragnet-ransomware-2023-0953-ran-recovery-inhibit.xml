<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0953 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: b4cfdf4a-e916-5a45-af17-d6c0c5873e0f -->
  <rule id="424319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0953 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>