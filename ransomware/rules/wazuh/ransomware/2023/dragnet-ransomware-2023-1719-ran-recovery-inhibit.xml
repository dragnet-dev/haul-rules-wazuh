<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1719 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 207fe493-f3c4-5e38-b12a-3b8cc200a25f -->
  <rule id="924649" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1719 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>