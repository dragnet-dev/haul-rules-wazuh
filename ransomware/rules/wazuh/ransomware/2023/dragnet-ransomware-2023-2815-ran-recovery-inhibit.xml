<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2815 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: e81a4ee7-1e07-5531-81c8-7f4145480734 -->
  <rule id="293038" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2815 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>