<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4739 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5ed49937-093a-5313-baf7-ac9734a80169 -->
  <rule id="717499" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4739 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>