<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1087 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 2a5b348b-2d5d-50ce-97ba-151c683c7af1 -->
  <rule id="611348" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1087 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>