<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1426 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 8209aa8e-7ce0-5f46-907d-2b4d313a4d6a -->
  <rule id="401674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1426 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>