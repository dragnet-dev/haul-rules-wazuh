<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0892 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 4b918a5b-3b77-591c-9822-b05fb8921098 -->
  <rule id="414698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0892 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>