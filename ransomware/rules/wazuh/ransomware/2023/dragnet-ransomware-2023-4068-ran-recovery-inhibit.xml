<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4068 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: eb139568-e020-56ec-b124-d3fd8f600a55 -->
  <rule id="651395" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4068 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>