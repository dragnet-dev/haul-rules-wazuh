<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5111 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1d9e9a85-db69-523b-a64f-3d8b3ba042d3 -->
  <rule id="578348" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5111 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>