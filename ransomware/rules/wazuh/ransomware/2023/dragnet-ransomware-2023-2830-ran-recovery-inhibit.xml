<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2830 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 03d7b6eb-0470-52d2-994a-3423aba4ac78 -->
  <rule id="781390" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2830 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>