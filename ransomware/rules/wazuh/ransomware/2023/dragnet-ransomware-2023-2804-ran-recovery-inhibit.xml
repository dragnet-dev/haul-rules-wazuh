<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2804 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 0c8feb57-d295-5c5d-b4d7-5eb6814a4d0b -->
  <rule id="883635" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2804 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>