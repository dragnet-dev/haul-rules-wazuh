<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3901 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 7173fa51-80fb-534b-9e7f-9620bef0a9fd -->
  <rule id="136538" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3901 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>