<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3224 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 5b6c1d20-3c0a-5a3f-8d5e-47203da4d7d6 -->
  <rule id="646909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3224 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>