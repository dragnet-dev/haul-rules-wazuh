<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4108 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8908ddaf-f2b5-512e-90ad-fd9541ff6fb1 -->
  <rule id="580669" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4108 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>