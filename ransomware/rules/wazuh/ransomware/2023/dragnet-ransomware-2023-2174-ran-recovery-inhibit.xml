<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2174 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3e2e01f3-be71-5f8f-a932-71db1eab2c6e -->
  <rule id="745631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2174 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>