<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2439 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f73b7388-c409-59d6-a479-148b8882cab3 -->
  <rule id="817973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2439 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>