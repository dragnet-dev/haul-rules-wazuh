<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2907 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 49055a4f-8cc9-5500-8cee-79ae8e0ede2c -->
  <rule id="748904" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2907 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>