<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1653 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 7c048c67-a805-5dc4-bbd8-6964c659f4bb -->
  <rule id="284780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1653 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>