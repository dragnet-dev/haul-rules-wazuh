<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0944 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 3e0c32f8-6d5e-5a15-82e3-b6174d86193a -->
  <rule id="691727" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0944 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>