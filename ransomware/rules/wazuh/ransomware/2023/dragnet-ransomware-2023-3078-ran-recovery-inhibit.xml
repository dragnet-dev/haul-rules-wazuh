<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3078 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a7b0c298-c932-566c-936a-c67c0680c182 -->
  <rule id="156922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3078 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>