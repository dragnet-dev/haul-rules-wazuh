<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2924 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: f2025c83-d23c-5ff9-8210-0538f4b5112a -->
  <rule id="732412" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2924 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>