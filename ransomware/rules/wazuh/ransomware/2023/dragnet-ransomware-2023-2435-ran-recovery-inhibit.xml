<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2435 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3887502f-bccb-5d39-b4a3-82c9de1a46ad -->
  <rule id="387502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2435 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>