<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2203 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 6fc601f9-3bb7-55ea-ba3c-b27588384053 -->
  <rule id="988601" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2203 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>