<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4824 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 916966a0-c387-57cc-bbca-e843dae5e37d -->
  <rule id="371466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4824 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
