<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2957 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 545307cd-60c8-506d-a958-ab227a1192a0 -->
  <rule id="724924" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2957 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>