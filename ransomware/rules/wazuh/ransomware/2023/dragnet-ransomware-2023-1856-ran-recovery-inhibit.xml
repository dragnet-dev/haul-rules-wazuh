<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1856 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e5e4eba2-92e1-592f-a020-a50d38559834 -->
  <rule id="676299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1856 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>