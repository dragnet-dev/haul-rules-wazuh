<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4204 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: fde515e8-1fae-5066-9793-02a6a72d16e5 -->
  <rule id="562515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4204 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>