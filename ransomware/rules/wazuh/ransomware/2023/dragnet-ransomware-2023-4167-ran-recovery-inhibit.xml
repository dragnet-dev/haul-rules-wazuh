<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4167 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 763b400b-22c2-5237-8621-75453dcf47c1 -->
  <rule id="421940" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4167 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>