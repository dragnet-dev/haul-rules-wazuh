<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4652 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 1a57fbee-055f-53d3-b0eb-8e89928453a5 -->
  <rule id="187102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4652 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>