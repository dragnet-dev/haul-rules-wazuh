<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0379 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: c107d230-0f91-5607-b61d-a7af24e6c374 -->
  <rule id="237252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0379 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>