<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1324 — Event Log Clearing (monti) | Status: experimental | Sigma ID: e6f57d71-6de4-54d3-bc38-aca398f37413 -->
  <rule id="262525" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1324 — Event Log Clearing (monti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>