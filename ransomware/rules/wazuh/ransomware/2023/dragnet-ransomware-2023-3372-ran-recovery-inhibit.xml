<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3372 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: ff1aed48-be9d-5ad2-853a-c7b1204409c6 -->
  <rule id="651693" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3372 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>