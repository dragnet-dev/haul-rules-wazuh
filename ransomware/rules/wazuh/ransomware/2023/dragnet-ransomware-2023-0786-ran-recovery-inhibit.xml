<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0786 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e166c6a9-7533-5700-a184-28b61e78fcb6 -->
  <rule id="566686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0786 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>