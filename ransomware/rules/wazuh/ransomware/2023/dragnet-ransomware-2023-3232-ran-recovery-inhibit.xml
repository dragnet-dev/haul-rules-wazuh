<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3232 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: b88a7df4-0ac8-5642-89ad-e470a48f878c -->
  <rule id="443005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3232 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>