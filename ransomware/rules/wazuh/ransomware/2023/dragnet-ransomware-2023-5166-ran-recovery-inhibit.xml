<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5166 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: bacd3609-6512-5abe-8b21-9b02790ea146 -->
  <rule id="382136" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5166 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>