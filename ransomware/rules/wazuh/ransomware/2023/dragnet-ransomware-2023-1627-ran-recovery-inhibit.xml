<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1627 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 5deba9fd-233c-54b3-a70d-41075879acf5 -->
  <rule id="346989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1627 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>