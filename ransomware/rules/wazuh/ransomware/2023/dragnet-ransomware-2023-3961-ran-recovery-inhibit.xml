<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3961 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: ddc84d4d-063a-5783-b9b5-41ff1a52e1b1 -->
  <rule id="378157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3961 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>