<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2309 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: ae1a30ea-2a93-57b2-8dd3-b28f4ccf2bb5 -->
  <rule id="186630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2309 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>