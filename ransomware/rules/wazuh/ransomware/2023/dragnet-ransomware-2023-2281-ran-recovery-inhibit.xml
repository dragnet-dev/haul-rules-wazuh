<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2281 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 20f17935-f970-5d3e-a1b8-49a77a45f188 -->
  <rule id="751793" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2281 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>