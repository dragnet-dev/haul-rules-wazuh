<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3895 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 5b99a122-b1c5-574a-8a0e-ed3d7d8b91f3 -->
  <rule id="671941" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3895 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
