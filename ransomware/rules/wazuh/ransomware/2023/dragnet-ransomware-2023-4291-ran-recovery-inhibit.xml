<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4291 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 5637f0f4-aaeb-57da-b0a7-dc7b52d2e649 -->
  <rule id="133135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4291 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>