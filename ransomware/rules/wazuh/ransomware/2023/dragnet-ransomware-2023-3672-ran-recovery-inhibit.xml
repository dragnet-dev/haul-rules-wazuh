<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3672 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: a0653d8a-c310-5eae-9058-4adbc03af1a6 -->
  <rule id="810461" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3672 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>