<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4119 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 3a44cf4f-c54b-56d4-b310-735e0c847245 -->
  <rule id="696271" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4119 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>