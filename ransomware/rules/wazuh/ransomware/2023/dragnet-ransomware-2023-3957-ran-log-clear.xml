<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3957 — Event Log Clearing (snatch) | Status: experimental | Sigma ID: 7270ddc4-b6ff-5bf9-8ab0-a6c2aaafea1a -->
  <rule id="161341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3957 — Event Log Clearing (snatch)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>