<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3079 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4b7ca483-e026-5017-a5d8-04fbd81e42c5 -->
  <rule id="239944" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3079 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>