<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4827 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 5f02bc4c-ba7b-5750-9996-255dec5c3013 -->
  <rule id="732700" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4827 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>