<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3619 — Event Log Clearing (donutleaks) | Status: experimental | Sigma ID: 0bf812dd-4e2f-5f97-bf26-a2d32f614b47 -->
  <rule id="469005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3619 — Event Log Clearing (donutleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>