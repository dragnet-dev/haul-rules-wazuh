<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0867 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 47305895-5722-5ddb-964c-4dbea5ad1e09 -->
  <rule id="330589" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0867 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>