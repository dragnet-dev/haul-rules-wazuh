<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2556 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: fe1f9c90-cbeb-55f4-862f-c50dd265b521 -->
  <rule id="307516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2556 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>