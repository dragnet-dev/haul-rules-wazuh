<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3564 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: eea6c54f-7ebf-5850-b1cb-97ee9072b5ac -->
  <rule id="809885" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3564 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>