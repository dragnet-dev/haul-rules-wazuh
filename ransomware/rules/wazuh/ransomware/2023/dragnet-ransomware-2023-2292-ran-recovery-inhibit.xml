<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2292 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e9e4e157-a8da-5e29-9afe-88f869cdd9e7 -->
  <rule id="337581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2292 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>