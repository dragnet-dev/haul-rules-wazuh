<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2342 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: ddaaaf4a-72a5-568c-a68c-597cccf47176 -->
  <rule id="227151" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2342 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>