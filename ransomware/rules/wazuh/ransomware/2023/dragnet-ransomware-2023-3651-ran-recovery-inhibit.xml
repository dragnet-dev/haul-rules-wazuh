<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3651 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 16e56d86-08e7-5b30-b085-3c922c8994a0 -->
  <rule id="829098" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3651 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>