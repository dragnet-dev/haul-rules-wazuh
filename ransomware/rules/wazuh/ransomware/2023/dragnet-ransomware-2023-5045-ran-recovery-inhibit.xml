<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5045 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f5b73b48-2072-5226-a08f-fcae0167be04 -->
  <rule id="486779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5045 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>