<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2446 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 083173b1-45ab-5cff-8425-34096c8f1f4a -->
  <rule id="530779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2446 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>