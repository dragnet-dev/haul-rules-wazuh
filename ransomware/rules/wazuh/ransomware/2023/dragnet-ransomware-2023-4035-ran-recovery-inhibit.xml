<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4035 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: be3c58f5-1228-5e67-812d-d2f246473845 -->
  <rule id="446058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4035 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>