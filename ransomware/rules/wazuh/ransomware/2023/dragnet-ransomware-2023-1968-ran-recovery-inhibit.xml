<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1968 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 60609b6b-ce57-510d-867a-1de52e5fc1ea -->
  <rule id="797556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1968 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>