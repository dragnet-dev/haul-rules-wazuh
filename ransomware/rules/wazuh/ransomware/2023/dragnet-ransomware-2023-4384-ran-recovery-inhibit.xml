<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4384 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 7b33e71c-8d2a-5c69-9521-dc865c2c64d3 -->
  <rule id="273427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4384 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>