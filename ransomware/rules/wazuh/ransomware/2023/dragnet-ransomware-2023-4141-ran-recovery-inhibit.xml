<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4141 — Recovery Inhibition (trigona) | Status: deprecated | Sigma ID: b80daa20-0141-50bb-9eb2-f7606fea3aa7 -->
  <rule id="436778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4141 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
