<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1957 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 93e7855f-3e54-5692-bf01-2031c0f07f4e -->
  <rule id="702785" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1957 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>