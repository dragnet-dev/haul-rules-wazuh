<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2098 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0ebf181e-1bb0-52d5-bab6-70e0c33e776f -->
  <rule id="275181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2098 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>