<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0276 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 3b4ba23c-9f2b-56fb-bf63-2d38638c9929 -->
  <rule id="722502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0276 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>