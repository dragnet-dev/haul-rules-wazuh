<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2736 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 09702af2-3e94-53b6-bcc9-f3fc292c15e7 -->
  <rule id="783887" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2736 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>