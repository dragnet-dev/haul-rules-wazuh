<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2358 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: cc959855-5bb8-5d61-a8ee-f75f697a5f30 -->
  <rule id="349598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2358 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>