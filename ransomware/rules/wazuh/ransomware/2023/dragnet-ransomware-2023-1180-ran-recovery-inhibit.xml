<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1180 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 6bbc6fce-f685-5717-a6cc-6d567b180255 -->
  <rule id="912911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1180 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>