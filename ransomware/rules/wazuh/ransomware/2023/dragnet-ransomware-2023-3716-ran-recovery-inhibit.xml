<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3716 — Recovery Inhibition (play) | Status: experimental | Sigma ID: cec432b0-36bd-56e2-818f-dfcf00769537 -->
  <rule id="708432" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3716 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>