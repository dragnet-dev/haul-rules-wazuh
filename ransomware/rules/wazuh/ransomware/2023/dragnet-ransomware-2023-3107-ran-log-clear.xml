<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3107 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: ecca1bf3-ae8f-5e95-8b6d-6d8d8f34bc78 -->
  <rule id="798907" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3107 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>