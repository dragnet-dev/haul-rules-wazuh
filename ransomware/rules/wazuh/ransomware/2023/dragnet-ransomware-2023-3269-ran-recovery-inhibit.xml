<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3269 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 19d3216d-52a9-51f8-bb26-51f075ca9e2b -->
  <rule id="573216" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3269 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>