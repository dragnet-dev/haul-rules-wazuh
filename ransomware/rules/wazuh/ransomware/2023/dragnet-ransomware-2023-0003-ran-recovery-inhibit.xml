<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0003 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: dfacf3c8-ac76-56c7-8585-163243d34639 -->
  <rule id="261753" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0003 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>