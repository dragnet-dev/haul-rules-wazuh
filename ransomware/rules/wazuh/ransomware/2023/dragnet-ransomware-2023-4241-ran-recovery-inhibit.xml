<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4241 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 1b9f92a7-b9fa-5bbc-8311-8f6f1a59c948 -->
  <rule id="967882" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4241 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>