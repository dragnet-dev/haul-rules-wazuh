<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3562 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 01c9f81a-e039-562d-a724-3553fbe4b1fb -->
  <rule id="323706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3562 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>