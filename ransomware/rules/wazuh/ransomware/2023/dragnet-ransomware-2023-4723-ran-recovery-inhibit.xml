<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4723 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 95367cd1-1a95-5ead-842a-faa885a670ac -->
  <rule id="725884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4723 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>