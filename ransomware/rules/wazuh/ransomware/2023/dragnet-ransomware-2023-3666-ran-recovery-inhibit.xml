<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3666 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: dc9b99ee-21c4-58c5-b260-9ca128dd3072 -->
  <rule id="935599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3666 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>