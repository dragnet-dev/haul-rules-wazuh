<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1512 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8d9fa24a-512c-5b81-b165-f1e268d33c1b -->
  <rule id="135142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1512 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>