<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4751 — Recovery Inhibition (malekteam) | Status: experimental | Sigma ID: dccb174f-1d78-5109-9970-cd7c056a763f -->
  <rule id="352317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4751 — Recovery Inhibition (malekteam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>