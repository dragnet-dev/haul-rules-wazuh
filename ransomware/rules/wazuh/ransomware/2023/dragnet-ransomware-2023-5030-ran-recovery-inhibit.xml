<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5030 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 9bb762f9-00b1-5845-af3c-093e588fc1fb -->
  <rule id="791762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5030 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>