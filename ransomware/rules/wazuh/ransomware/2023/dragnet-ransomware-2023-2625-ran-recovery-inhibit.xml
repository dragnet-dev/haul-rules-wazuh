<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2625 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: b7332b55-cf51-5392-aaef-106e51ce610e -->
  <rule id="177323" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2625 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>