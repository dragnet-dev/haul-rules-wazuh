<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4184 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 928052a5-e32e-5f45-a9ad-2700d2ab02b1 -->
  <rule id="548842" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4184 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>