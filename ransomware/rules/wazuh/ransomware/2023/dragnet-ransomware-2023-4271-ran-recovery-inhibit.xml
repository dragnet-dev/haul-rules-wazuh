<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4271 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: abf1d40a-108c-5482-a5d2-13713266bf18 -->
  <rule id="901894" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4271 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>