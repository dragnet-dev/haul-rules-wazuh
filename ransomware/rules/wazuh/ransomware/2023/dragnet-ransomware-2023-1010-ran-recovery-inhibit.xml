<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1010 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 51d98309-5252-576b-8f87-71882a3eec60 -->
  <rule id="299830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1010 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>