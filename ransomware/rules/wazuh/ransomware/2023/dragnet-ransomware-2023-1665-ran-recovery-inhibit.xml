<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1665 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 7bfd1018-19dc-56c6-bae5-3b6fe1af3330 -->
  <rule id="574110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1665 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>