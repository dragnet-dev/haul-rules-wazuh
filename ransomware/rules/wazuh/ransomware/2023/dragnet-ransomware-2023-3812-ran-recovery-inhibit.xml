<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3812 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: aaa80999-2a56-52ab-9466-04fa4ca8a2b5 -->
  <rule id="130809" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3812 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>