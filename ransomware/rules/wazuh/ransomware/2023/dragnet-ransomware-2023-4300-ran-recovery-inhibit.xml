<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4300 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6163427a-f487-5f52-a1f8-963bdc4ac425 -->
  <rule id="863427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4300 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>