<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0529 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1384056e-22f6-56d9-8b9d-47f78a00e0f0 -->
  <rule id="584056" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0529 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>