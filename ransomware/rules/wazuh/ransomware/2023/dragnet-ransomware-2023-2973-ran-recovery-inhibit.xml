<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2973 — Recovery Inhibition (moneymessage) | Status: experimental | Sigma ID: 1ac36027-b302-53f9-95ae-ee8a2653cbf0 -->
  <rule id="783602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2973 — Recovery Inhibition (moneymessage)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>