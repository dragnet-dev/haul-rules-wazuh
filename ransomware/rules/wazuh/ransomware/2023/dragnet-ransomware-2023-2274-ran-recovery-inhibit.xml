<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2274 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 6e942e1c-023e-5e12-a8a4-ac3a23ca5709 -->
  <rule id="975086" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2274 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>