<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3038 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 95d349a8-3ad2-5ef4-b045-62b93d85ab43 -->
  <rule id="733349" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3038 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>