<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0509 — Recovery Inhibition (cuba) | Status: experimental | Sigma ID: 399c8630-413d-5781-9a59-6d63f406b55d -->
  <rule id="196863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0509 — Recovery Inhibition (cuba)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>