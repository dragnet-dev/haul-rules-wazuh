<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2229 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 22e25f9a-76ab-56e0-89b3-b967054e021b -->
  <rule id="560159" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2229 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>