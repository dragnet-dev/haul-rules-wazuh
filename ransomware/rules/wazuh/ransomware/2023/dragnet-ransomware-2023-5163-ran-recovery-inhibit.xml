<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5163 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: bede3cad-d134-5338-881b-a509b82d41ac -->
  <rule id="717980" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5163 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>