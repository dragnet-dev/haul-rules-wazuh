<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5009 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: dfd30c5d-c17a-5a00-8df2-191eff0dcafb -->
  <rule id="430092" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5009 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>