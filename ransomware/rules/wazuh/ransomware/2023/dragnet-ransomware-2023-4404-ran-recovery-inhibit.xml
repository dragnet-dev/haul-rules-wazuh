<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4404 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e436d431-1e04-5515-8d56-da48b18f7faa -->
  <rule id="609894" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4404 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>