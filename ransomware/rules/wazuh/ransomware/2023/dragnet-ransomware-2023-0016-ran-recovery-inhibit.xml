<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0016 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 67490613-4b45-52ae-827a-22b110594652 -->
  <rule id="549061" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0016 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>