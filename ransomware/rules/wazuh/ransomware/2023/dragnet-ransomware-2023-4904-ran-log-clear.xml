<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4904 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 7006a09e-0daf-53f8-9f80-a0ab3a739403 -->
  <rule id="321060" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4904 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>