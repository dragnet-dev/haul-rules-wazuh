<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0429 — Recovery Inhibition (darkpower) | Status: experimental | Sigma ID: 015afcbc-c9a9-5f99-bb79-f2e6f4fcb22d -->
  <rule id="228043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0429 — Recovery Inhibition (darkpower)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>