<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4164 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: a1a1a84e-b2ec-593c-a441-0f14e3a2004c -->
  <rule id="901868" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4164 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>