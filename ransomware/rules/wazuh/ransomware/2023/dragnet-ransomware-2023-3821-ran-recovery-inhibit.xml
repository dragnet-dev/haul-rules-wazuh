<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3821 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6dbfc7c3-32dc-5a3f-8904-69d0593f612a -->
  <rule id="995327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3821 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>