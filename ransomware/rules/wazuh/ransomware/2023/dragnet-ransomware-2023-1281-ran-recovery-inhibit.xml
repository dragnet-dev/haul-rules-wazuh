<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1281 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 0cfcdc93-47b9-5019-a1f9-e32abb6ff926 -->
  <rule id="511649" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1281 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>