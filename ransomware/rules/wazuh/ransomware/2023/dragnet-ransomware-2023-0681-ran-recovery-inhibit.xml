<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0681 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: c3d02b5b-215c-5b7c-9ff1-b9c4d87f6f3a -->
  <rule id="569643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0681 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>