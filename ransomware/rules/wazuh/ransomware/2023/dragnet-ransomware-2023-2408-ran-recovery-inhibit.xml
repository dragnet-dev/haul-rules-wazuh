<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2408 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 463ba3ee-ae93-5dd6-a0c2-4dce9bb99080 -->
  <rule id="387143" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2408 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>