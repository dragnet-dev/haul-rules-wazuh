<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1338 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ac5e046d-6989-5910-86df-e0606eaecc7e -->
  <rule id="161404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1338 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>