<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5036 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: b98b1c91-98b3-5af0-b9c7-723419848665 -->
  <rule id="468668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5036 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>