<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1639 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: af27c266-ebe7-56c1-8d57-482467e21e8f -->
  <rule id="204442" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1639 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>