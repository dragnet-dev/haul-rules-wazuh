<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3873 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7a8efd52-dc5f-5029-92d9-932a5f9f2e2d -->
  <rule id="633725" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3873 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>