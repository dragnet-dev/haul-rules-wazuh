<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3203 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 069a7838-52c0-5ed0-9b42-9d5efaa58002 -->
  <rule id="314783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3203 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>