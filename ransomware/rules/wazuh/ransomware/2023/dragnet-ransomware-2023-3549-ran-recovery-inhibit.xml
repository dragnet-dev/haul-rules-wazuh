<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3549 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 23bbdb3b-a9a9-56f6-ac3b-f762c58f3fdd -->
  <rule id="755419" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3549 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>