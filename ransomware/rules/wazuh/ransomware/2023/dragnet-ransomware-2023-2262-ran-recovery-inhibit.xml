<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2262 — Recovery Inhibition (siegedsec) | Status: experimental | Sigma ID: 96a5e3c1-cdb2-5c0e-bf8b-567bf130eae7 -->
  <rule id="774543" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2262 — Recovery Inhibition (siegedsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>