<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2518 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: ed2218bb-82d4-5546-80ad-e001c247c21f -->
  <rule id="672218" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2518 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>