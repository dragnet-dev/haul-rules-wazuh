<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2070 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4e4db42c-f4b2-5c32-8789-015ecb1352a3 -->
  <rule id="309234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2070 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>