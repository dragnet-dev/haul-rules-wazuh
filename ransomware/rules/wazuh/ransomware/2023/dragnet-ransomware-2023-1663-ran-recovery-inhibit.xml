<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1663 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a47eadcc-87b4-5e5c-9e48-81f7a7f0781e -->
  <rule id="792269" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1663 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>