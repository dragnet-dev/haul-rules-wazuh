<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2240 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 54a9971a-14a4-53e2-89d8-7d4681fa7b15 -->
  <rule id="749971" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2240 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>