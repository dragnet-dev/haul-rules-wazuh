<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1741 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: ddd3337a-c77f-5353-b87e-1ee27ab380b6 -->
  <rule id="949333" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1741 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>