<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4882 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: c550a1c9-3709-5e49-a7b6-89c0fdd62c98 -->
  <rule id="308101" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4882 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>