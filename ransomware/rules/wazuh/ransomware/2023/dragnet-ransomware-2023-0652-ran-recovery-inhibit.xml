<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0652 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a5e1737b-e30d-563f-a29a-523de2162e30 -->
  <rule id="894173" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0652 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>