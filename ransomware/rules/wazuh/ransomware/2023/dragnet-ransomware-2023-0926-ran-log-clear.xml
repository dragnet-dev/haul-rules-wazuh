<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0926 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: 20cbd03d-2ba4-5d7b-866b-a09be7f6fa13 -->
  <rule id="518103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0926 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>