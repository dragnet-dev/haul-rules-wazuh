<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2395 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 425b5dfa-ad71-5cfa-b81c-e90011b5b8ac -->
  <rule id="289853" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2395 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>