<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0159 — Event Log Clearing (cactus) | Status: deprecated | Sigma ID: d2507607-85a2-50e2-a406-60ad744b6150 -->
  <rule id="525076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0159 — Event Log Clearing (cactus)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>