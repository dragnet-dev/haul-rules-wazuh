<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2981 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 261548df-289b-5027-89a1-160584e7ca47 -->
  <rule id="684781" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2981 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>