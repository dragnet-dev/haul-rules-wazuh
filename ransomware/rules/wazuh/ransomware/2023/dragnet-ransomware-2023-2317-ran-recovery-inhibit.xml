<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2317 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 9e653be0-8902-51d0-b3b1-c8968ddafcd7 -->
  <rule id="838459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2317 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>