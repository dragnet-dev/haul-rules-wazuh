<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2865 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 547b560c-59f2-5819-b718-142eef11dc70 -->
  <rule id="763560" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2865 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>