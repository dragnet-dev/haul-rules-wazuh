<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3586 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: c2b67367-e359-53e2-ab57-8e08403f61a3 -->
  <rule id="263673" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3586 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>