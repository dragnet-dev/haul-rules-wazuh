<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0617 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: eaee37b1-530d-5879-984c-9bf67dc7594b -->
  <rule id="714237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0617 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>