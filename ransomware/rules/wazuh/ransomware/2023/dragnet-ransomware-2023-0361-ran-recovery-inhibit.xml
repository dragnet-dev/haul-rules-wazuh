<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0361 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 2a2605a3-1617-59f6-9c87-5398da82bb94 -->
  <rule id="561690" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0361 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>