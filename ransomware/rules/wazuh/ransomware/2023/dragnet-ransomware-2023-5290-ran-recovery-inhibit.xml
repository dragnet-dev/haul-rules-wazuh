<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5290 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 26ae3ca8-e97f-5315-8d8b-b14f1a4caa0a -->
  <rule id="292860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5290 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>