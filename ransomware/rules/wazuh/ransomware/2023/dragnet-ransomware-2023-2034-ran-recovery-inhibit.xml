<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2034 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 38bd31ad-8162-5b36-aef6-14670c41d79f -->
  <rule id="667706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2034 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>