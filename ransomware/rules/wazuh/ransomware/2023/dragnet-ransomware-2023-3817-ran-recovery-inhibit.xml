<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3817 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c4f5f0e7-f349-572c-bca3-9536278695a5 -->
  <rule id="599350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3817 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>