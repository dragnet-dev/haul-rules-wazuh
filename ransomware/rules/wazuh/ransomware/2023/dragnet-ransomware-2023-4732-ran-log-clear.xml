<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4732 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: be4ee63b-e3ed-5446-94e6-4c2311567ea3 -->
  <rule id="476626" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4732 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>