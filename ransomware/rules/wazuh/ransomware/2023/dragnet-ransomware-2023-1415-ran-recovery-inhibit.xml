<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1415 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 066ef809-b0a0-5cea-81f2-1e277fbb57be -->
  <rule id="913580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1415 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>