<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5220 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 6221c6af-e8ec-5e63-af71-73190847a7de -->
  <rule id="727786" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5220 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>