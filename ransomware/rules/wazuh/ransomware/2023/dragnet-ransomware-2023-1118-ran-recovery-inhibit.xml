<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1118 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 318b3c1a-bbe1-5c69-8869-b28691b6088e -->
  <rule id="159001" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1118 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>