<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1398 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 620695fb-34da-5376-afc6-4a3ecc30223c -->
  <rule id="131135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1398 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>