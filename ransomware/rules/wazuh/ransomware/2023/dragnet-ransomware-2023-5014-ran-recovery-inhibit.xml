<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5014 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 1f61e7e7-aab2-5481-ba99-ff0cfde5bc5d -->
  <rule id="994526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5014 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>