<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4737 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f59d5da1-6235-5fce-957f-073e126bd2ac -->
  <rule id="493213" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4737 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>