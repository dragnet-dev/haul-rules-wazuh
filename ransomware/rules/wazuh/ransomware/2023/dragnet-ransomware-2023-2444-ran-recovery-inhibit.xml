<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2444 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 0e23559c-0a3c-5423-9ec3-b2b7e3391979 -->
  <rule id="623559" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2444 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>