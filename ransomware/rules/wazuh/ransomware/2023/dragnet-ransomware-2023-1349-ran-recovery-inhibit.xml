<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1349 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: bad6796c-2c36-525a-9133-67684ea97ed0 -->
  <rule id="389679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1349 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>