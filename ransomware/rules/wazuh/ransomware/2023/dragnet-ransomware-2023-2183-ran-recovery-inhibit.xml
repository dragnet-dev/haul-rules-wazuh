<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2183 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 6d171f69-edcc-55a5-83c3-59715b43a6f4 -->
  <rule id="946751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2183 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>