<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3247 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 989fe4d2-49f7-57df-ba12-39711d5d7695 -->
  <rule id="834384" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3247 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>