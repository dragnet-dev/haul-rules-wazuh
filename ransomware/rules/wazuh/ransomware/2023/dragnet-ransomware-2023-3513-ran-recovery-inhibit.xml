<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3513 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: f4433572-6aba-5b58-a21b-cb003a852f67 -->
  <rule id="744335" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3513 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>