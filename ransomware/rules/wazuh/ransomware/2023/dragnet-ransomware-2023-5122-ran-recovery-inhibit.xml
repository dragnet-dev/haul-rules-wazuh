<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5122 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 21f16438-1a38-5564-af0b-11ababe026d0 -->
  <rule id="911643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5122 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>