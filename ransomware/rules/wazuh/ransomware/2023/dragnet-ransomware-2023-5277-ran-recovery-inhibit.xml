<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5277 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 15d58fb7-ceac-5b0b-9649-abac12cc9341 -->
  <rule id="291899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5277 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>