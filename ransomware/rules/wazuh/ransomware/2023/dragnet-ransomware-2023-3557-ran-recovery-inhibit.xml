<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3557 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 9cf5b2af-650c-5ddd-8ad7-942e93a401e0 -->
  <rule id="518512" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3557 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>