<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4032 — Recovery Inhibition (play) | Status: experimental | Sigma ID: aaead8ff-c089-51bc-9513-5864d48c73c1 -->
  <rule id="800778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4032 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>