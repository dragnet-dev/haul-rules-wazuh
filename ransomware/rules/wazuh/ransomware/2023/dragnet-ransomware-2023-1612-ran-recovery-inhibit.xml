<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1612 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: f6da4743-7e25-5d87-91f1-e7fc5ce88940 -->
  <rule id="515447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1612 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>