<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2124 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 07f74239-03f4-5e6c-b651-4153791da59b -->
  <rule id="477423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2124 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>