<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0735 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: e468132c-06e1-5644-998d-13308a298a0f -->
  <rule id="646813" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0735 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>