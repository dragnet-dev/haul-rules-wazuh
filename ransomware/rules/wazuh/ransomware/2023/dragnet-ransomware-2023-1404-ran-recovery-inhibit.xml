<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1404 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 35680988-534e-599c-ab2f-ed6315effe09 -->
  <rule id="968098" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1404 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>