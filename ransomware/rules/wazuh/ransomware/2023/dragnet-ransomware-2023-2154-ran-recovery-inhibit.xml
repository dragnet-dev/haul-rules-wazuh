<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2154 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 96e8dc67-5bf4-5350-b5c4-74e66c27f020 -->
  <rule id="470268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2154 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>