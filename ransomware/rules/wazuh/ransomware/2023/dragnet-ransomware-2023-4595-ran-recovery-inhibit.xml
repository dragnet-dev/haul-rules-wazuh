<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4595 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 17cbdcfa-7c58-5bb5-9c29-33024b864173 -->
  <rule id="366300" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4595 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>