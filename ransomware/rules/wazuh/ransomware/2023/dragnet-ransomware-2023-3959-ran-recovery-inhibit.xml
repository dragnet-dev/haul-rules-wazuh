<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3959 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 27dedfdd-57ac-50ac-bf8d-8d06536d7b4d -->
  <rule id="126527" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3959 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>