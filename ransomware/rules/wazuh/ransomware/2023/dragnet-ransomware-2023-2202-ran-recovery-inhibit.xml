<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2202 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 657bcf9d-6f6f-5824-b62a-c660c622b59e -->
  <rule id="994095" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2202 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>