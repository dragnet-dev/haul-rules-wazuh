<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3178 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1156d184-5950-57ed-84a9-08c6dffcd78b -->
  <rule id="150918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3178 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>