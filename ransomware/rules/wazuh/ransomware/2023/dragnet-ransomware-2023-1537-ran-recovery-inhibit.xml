<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1537 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 118d11f4-c738-57b7-8ca8-10d16fdbc764 -->
  <rule id="441791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1537 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>