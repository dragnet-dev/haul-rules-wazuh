<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4083 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 012b4dde-74cd-5955-b23f-17691d5901a9 -->
  <rule id="334814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4083 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>