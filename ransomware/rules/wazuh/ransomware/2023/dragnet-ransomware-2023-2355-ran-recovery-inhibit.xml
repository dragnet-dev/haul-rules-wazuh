<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2355 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 40a5e42a-dd53-5396-858f-46ea313813a0 -->
  <rule id="240944" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2355 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>