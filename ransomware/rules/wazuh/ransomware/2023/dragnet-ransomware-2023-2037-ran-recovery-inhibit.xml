<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2037 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 4b91d41d-d2ba-5125-a118-21c3a8b4fed1 -->
  <rule id="414694" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2037 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>