<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1854 — Event Log Clearing (nokoyawa) | Status: experimental | Sigma ID: 7e707c3c-744f-5ac0-9dfa-c26fb1d0f6f1 -->
  <rule id="327324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1854 — Event Log Clearing (nokoyawa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>