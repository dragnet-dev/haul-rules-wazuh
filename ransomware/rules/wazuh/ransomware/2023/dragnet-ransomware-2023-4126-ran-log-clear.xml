<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4126 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: b3b5a4c3-62c3-5c74-a99f-5b8bb593b590 -->
  <rule id="311304" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4126 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>