<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5347 — Event Log Clearing (meow) | Status: experimental | Sigma ID: 3cd683da-8b26-5c0e-bf59-964325dd8090 -->
  <rule id="378941" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5347 — Event Log Clearing (meow)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>