<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2362 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 2ebb0ae7-d6e9-5157-804b-8db3ad2bc2ac -->
  <rule id="214090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2362 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>