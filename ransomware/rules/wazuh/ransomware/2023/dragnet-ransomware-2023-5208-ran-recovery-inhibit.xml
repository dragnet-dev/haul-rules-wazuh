<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5208 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 147a47b0-5550-5a7f-82d3-3ccad26036cf -->
  <rule id="279963" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5208 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>