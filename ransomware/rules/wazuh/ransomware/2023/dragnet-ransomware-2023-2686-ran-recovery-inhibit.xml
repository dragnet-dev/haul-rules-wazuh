<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2686 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c03281a6-9baf-53ad-acc8-d82126ab8b0a -->
  <rule id="403281" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2686 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>