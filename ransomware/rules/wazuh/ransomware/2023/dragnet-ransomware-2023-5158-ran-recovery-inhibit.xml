<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5158 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: bc4f528b-a2a4-59ca-a1e8-f7d07fd95e75 -->
  <rule id="415952" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5158 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>