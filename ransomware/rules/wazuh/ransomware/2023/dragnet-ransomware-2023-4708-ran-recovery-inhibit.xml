<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4708 — Recovery Inhibition (play) | Status: experimental | Sigma ID: afe8a0bd-977f-57cc-aa6e-f65b6d3dfb9d -->
  <rule id="103780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4708 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>