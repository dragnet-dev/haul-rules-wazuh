<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3756 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 75363a11-d82c-5179-853a-de8c60eae7d4 -->
  <rule id="405818" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3756 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>