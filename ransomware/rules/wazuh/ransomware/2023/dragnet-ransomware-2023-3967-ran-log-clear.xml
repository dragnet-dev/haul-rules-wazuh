<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3967 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 7dd46dbb-c48e-5d09-a8b7-e6dda4789a74 -->
  <rule id="621549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3967 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>