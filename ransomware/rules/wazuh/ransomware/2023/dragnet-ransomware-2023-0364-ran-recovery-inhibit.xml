<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0364 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: e1304cf9-e63e-5179-aa8f-f3bae743e643 -->
  <rule id="560876" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0364 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>