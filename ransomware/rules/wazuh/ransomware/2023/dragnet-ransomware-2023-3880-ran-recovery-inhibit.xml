<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3880 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: e4567730-0384-53d9-8342-1464cee1fd14 -->
  <rule id="645677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3880 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>