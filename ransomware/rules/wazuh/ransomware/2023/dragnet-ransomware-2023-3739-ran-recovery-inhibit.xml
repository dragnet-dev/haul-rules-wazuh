<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3739 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 6248163e-36a4-5781-9e44-73291dc0e5d3 -->
  <rule id="948163" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3739 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>