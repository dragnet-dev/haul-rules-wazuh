<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3696 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: 6e7f0eb2-9669-501b-9a7d-1e0caf1e5c19 -->
  <rule id="236334" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3696 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>