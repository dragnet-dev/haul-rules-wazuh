<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0818 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 3a86f8ab-2c59-5d2b-afdf-2e2b084abeb0 -->
  <rule id="770698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0818 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>