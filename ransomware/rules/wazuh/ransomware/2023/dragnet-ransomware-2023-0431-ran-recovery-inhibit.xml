<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0431 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: a59582e6-8299-5eb4-b80a-bb3e9f6302ab -->
  <rule id="259582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0431 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>