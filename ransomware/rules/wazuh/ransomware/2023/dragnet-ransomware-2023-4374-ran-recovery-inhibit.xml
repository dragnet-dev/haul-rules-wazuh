<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4374 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 42229e51-1c19-5c19-b103-aa0e30fd6378 -->
  <rule id="556785" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4374 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>