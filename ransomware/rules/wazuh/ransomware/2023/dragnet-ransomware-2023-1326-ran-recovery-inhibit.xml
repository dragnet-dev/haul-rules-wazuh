<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1326 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 43b756de-c115-53df-b22d-b0c7b9b573c1 -->
  <rule id="496109" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1326 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>