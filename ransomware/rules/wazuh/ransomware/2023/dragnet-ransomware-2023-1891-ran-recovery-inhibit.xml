<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1891 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 23eb0520-0b85-5b70-baca-991276d17c32 -->
  <rule id="823052" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1891 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>