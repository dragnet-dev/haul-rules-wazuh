<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1593 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8b8b2d4f-9699-5b2c-bdeb-9d7b0902bc02 -->
  <rule id="980685" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1593 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>