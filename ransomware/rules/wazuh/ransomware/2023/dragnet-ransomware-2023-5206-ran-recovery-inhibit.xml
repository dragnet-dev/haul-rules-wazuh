<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5206 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: a44353a1-f641-5daa-8d67-5175bac4c820 -->
  <rule id="244353" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5206 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>