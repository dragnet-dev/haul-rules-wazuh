<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2254 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f3f87f38-e26f-5f59-8161-9d39df3dfbe1 -->
  <rule id="442207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2254 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>