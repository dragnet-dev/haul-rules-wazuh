<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3869 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: df200d63-6641-533a-9800-6fcb471e8631 -->
  <rule id="971213" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3869 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>