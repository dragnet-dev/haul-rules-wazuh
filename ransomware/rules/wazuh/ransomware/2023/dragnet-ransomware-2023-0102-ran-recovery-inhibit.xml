<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0102 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 3d04d7c1-595a-54d0-b249-baf307b30f14 -->
  <rule id="428444" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0102 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>