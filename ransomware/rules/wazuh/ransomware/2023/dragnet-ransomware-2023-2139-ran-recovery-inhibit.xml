<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2139 — Recovery Inhibition (play) | Status: experimental | Sigma ID: cc403649-7f8c-5bcd-b75a-10178b9c8d8f -->
  <rule id="344036" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2139 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>