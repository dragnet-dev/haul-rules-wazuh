<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0576 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: f56931f1-4d00-5266-bdad-a4607a2bc4cc -->
  <rule id="756931" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0576 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>