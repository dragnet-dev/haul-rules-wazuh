<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0709 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: ee91ba3f-5b4f-5483-8a32-41d3a62b767e -->
  <rule id="816282" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0709 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>