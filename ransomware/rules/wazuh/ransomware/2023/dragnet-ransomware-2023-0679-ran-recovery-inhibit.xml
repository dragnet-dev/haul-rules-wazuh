<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0679 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 87e5c8c6-ef95-59cd-b7b9-eb646b3e7f0f -->
  <rule id="550528" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0679 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>