<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5294 — Event Log Clearing (meow) | Status: experimental | Sigma ID: aa841a15-5597-51ca-9f38-57059d725b7b -->
  <rule id="133466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5294 — Event Log Clearing (meow)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>