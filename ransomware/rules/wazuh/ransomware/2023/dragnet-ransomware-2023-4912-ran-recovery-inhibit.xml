<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4912 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 5171244b-aba2-5710-839c-ef8c21b95b6d -->
  <rule id="771244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4912 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>