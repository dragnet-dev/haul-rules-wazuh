<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3057 — Event Log Clearing (play) | Status: experimental | Sigma ID: 4188e6e8-9cf6-5e6d-a80a-b488f4d1e4ab -->
  <rule id="923630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3057 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>