<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0131 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 750d14ad-2e02-5714-bdac-956e5a6ac77e -->
  <rule id="401314" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0131 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>