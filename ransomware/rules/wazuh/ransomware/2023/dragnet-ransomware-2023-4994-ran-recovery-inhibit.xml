<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4994 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b66d3cd5-176a-5237-ab93-670faae35927 -->
  <rule id="387100" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4994 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>