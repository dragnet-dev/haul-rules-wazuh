<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1693 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: b976a450-48fd-5838-a2f0-9b7ce63dd25a -->
  <rule id="216264" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1693 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>