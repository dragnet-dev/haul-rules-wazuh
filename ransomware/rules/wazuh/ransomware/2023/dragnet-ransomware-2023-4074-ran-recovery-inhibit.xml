<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4074 — Recovery Inhibition (darkrace) | Status: experimental | Sigma ID: 1dd82f66-2cfd-5f0a-bf60-0a1a768d7661 -->
  <rule id="545276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4074 — Recovery Inhibition (darkrace)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>