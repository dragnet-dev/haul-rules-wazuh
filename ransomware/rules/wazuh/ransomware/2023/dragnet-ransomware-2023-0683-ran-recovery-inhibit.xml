<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0683 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: ba81dccb-590a-52bc-91bc-b84e6be67637 -->
  <rule id="382556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0683 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>