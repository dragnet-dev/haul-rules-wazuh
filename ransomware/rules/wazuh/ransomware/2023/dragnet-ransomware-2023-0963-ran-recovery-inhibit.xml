<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0963 — Recovery Inhibition (rancoz) | Status: experimental | Sigma ID: e5470642-8f85-56a1-9dc0-53f21388dbed -->
  <rule id="654706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0963 — Recovery Inhibition (rancoz)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>