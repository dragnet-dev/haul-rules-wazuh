<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2841 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 28723d20-1b94-50e3-aef0-025e492a217a -->
  <rule id="195812" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2841 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>