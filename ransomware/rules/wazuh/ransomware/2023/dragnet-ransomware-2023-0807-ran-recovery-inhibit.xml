<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0807 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e66e6f93-4795-5187-9d6f-0873fd4a0b15 -->
  <rule id="255311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0807 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>