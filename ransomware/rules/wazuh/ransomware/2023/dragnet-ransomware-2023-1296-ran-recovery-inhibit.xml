<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1296 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: f5d33726-a215-5be9-a8d6-f3712bc453c7 -->
  <rule id="793337" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1296 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>