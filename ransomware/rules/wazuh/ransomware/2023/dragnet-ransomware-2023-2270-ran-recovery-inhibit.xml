<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2270 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 1d3d23c0-3958-5acb-a3f6-937d56136d4b -->
  <rule id="421980" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2270 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>