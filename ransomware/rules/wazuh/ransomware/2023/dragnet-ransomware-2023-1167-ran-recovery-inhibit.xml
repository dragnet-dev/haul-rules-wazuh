<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1167 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 020b1138-7198-5da2-8fe3-765c2f777ec5 -->
  <rule id="711138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1167 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>