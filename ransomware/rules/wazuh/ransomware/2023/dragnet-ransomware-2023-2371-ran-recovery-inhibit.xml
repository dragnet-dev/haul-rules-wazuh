<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2371 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: b4d08f64-c83a-525b-a6a2-14d19fe4b9b0 -->
  <rule id="339343" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2371 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>