<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3270 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 87ba20d1-a29c-59c2-abf2-c3d1b0e05e1b -->
  <rule id="545820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3270 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>