<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1586 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 615e1760-c25e-5b39-b5aa-9f80d034383f -->
  <rule id="954176" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1586 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>