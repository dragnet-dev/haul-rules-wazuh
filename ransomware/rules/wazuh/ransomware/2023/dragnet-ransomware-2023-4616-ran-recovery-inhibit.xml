<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4616 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1f64e7cf-de78-5e93-b913-752ce2ed0428 -->
  <rule id="102204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4616 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>