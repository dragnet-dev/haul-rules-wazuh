<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1495 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 949d6bb5-e9b1-54b2-af1c-c50d68d136c6 -->
  <rule id="731627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1495 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>