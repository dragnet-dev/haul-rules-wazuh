<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5300 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ac920722-38bc-5a5f-83d4-fcea58283324 -->
  <rule id="929207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5300 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>