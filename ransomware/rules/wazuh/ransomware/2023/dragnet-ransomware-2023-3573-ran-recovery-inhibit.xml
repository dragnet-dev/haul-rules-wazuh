<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3573 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 354f5819-3631-550b-9b49-3c7cfaafbebb -->
  <rule id="379581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3573 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>