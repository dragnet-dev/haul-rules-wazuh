<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1469 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: a9665bbc-cd7a-519d-9c83-977ef0135a8f -->
  <rule id="954651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1469 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
