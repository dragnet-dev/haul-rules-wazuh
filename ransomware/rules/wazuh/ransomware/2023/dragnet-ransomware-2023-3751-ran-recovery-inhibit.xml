<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3751 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 098f08e1-0307-56c5-8a7c-3b3c38faf610 -->
  <rule id="832942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3751 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>