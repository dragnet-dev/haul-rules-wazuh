  <rule id="886557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0565 — Recovery Inhibition (karakurt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
