<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3419 — Event Log Clearing (karakurt) | Status: deprecated | Sigma ID: 8e85d150-e278-5e4c-949c-04f804cb1b01 -->
  <rule id="585731" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3419 — Event Log Clearing (karakurt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>