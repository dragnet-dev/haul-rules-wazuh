<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1358 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 84fcf643-39f0-554c-b1cf-214eb8286e54 -->
  <rule id="881116" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1358 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>