<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2989 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 3ec6b3de-0e97-5d75-a96c-cae17b548f58 -->
  <rule id="807473" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2989 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>