<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5083 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: 9c57a61c-86a9-5a31-a91d-28d3103a9de5 -->
  <rule id="805226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5083 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>