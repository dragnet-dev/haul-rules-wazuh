<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4956 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 2d36d4dd-8f3c-57b2-ac63-9af7cca1139e -->
  <rule id="914317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4956 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>