<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2036 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 3e44ca1e-2ea0-55b9-9997-1a133d6fef04 -->
  <rule id="798666" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2036 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>