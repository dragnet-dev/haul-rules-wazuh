<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1923 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 2f7ccf02-8766-51e6-a04b-f5cc502bf7a6 -->
  <rule id="257071" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1923 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>