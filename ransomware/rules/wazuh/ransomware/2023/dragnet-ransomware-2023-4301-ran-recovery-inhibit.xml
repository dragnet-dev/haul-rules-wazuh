<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4301 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: 4b7fd790-0177-5113-ae5e-3a47f7ca0a1a -->
  <rule id="240457" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4301 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>