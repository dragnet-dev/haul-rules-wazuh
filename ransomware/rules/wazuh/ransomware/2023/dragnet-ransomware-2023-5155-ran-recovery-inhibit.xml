<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5155 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5c4c4167-8c37-57c7-9e4b-1d78fdc6c00c -->
  <rule id="679641" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5155 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>