<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0173 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: ebc88c7b-1413-5290-95b7-bf9d8d932aa4 -->
  <rule id="736620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0173 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>