<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4071 — Recovery Inhibition (rancoz) | Status: experimental | Sigma ID: f2ed22ad-6cec-58ee-a47a-619983c676af -->
  <rule id="414922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4071 — Recovery Inhibition (rancoz)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>