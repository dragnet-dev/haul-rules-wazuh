<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1062 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: fb723c9c-bf3d-522c-9064-3085a2c892d3 -->
  <rule id="527580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1062 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>