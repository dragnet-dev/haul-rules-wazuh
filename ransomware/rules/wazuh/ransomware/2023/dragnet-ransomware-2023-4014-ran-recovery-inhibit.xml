<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4014 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d5a3cd7d-4293-5117-9258-974b37ba5cb7 -->
  <rule id="256173" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4014 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>