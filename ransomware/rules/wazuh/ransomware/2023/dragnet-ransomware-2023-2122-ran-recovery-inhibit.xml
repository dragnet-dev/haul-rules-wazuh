<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2122 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e606fdce-fe86-505b-b3c5-cf68e4414f57 -->
  <rule id="239389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2122 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>