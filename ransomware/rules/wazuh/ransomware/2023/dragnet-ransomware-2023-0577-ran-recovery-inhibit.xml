<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0577 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: d16a803d-d11c-5197-9f8b-1dde1690046d -->
  <rule id="406680" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0577 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>