<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4613 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: e7af8576-200c-5972-a975-6f37c287e5eb -->
  <rule id="280785" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4613 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>