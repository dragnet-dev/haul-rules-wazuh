<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1821 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 0096ac51-016c-594a-8b6a-2feb176e418f -->
  <rule id="774851" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1821 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>