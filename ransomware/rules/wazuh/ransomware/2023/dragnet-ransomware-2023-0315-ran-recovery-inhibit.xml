<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0315 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c09dc017-cfed-5f22-b8fa-b73e2b9c106b -->
  <rule id="497240" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0315 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>