<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3761 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: de40447d-8898-5cdc-a9b5-9783500c3be5 -->
  <rule id="524044" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3761 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>