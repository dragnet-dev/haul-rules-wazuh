<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4322 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 956c481c-0878-5a62-89e3-a3ecf45ae6a8 -->
  <rule id="730848" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4322 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>