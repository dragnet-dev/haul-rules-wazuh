<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2855 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: fac91387-5e3b-504b-9d18-14b1e5101a8a -->
  <rule id="512913" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2855 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>