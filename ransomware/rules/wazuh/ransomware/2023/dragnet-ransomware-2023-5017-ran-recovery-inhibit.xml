<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5017 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 646f99d0-085f-5240-a66e-f7496228b29a -->
  <rule id="235199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5017 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>