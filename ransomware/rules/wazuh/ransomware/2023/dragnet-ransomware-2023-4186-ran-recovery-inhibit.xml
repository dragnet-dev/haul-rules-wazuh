<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4186 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 22fba2ec-b315-5dce-a713-679b2160fe96 -->
  <rule id="762126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4186 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>