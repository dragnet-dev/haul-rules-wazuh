<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2011 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: f0513e28-7cc2-58fd-b042-30c912b7b7bb -->
  <rule id="708222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2011 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>