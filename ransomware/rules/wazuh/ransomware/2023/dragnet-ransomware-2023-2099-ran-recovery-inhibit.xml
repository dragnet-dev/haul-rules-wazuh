<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2099 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 9dd6c5dd-4f56-5457-8a7d-8a1614b43d71 -->
  <rule id="541085" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2099 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>