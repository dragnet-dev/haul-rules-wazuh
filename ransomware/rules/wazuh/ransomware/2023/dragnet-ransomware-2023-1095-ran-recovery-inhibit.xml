<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1095 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 41e39766-1b21-52f7-851f-733425c4978a -->
  <rule id="503976" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1095 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>