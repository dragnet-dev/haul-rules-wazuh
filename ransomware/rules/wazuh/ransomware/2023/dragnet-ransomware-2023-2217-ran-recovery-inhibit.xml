<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2217 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2c1255e3-a1cc-550a-9eed-ff0f96305093 -->
  <rule id="860094" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2217 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>