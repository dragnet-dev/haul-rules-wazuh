<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4110 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 77010fc3-b811-55ac-beaa-9664fa97a48a -->
  <rule id="432175" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4110 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>