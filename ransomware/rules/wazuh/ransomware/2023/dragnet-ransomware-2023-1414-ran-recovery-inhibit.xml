<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1414 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 7d73f2d4-c5f4-5893-bfb0-e1dd7bef3834 -->
  <rule id="311832" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1414 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>