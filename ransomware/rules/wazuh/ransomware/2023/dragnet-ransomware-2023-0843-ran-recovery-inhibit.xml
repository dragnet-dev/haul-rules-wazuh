<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0843 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 36264efe-b11a-55d6-a0b3-d29f228c2162 -->
  <rule id="383823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0843 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>