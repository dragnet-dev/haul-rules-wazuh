<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3279 — Event Log Clearing (knight) | Status: experimental | Sigma ID: 7d08ac5b-98da-542b-b6f1-cbf2b01004d6 -->
  <rule id="602220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3279 — Event Log Clearing (knight)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>