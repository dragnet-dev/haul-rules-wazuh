<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4002 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: f5ac7fd3-b7a1-5eb4-98a5-fe32bb9087b6 -->
  <rule id="176447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4002 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>