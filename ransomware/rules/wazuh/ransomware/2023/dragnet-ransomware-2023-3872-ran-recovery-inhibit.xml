<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3872 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: def25309-9dd3-5258-8492-7be9dc0095b0 -->
  <rule id="967253" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3872 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>