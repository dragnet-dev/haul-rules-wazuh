<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4258 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 71787b67-3ef8-5e31-8e4a-18a5757b42f5 -->
  <rule id="348603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4258 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>