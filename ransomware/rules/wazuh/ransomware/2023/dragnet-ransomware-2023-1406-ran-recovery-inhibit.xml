<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1406 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: b1c46bc5-ee5a-5a56-899a-e6b03e47858d -->
  <rule id="261547" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1406 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>