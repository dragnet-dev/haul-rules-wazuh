<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3985 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: a28eb96c-ce2f-5562-b43d-e3c2c505d1d0 -->
  <rule id="934039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3985 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>