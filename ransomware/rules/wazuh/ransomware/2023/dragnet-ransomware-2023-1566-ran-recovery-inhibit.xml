<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1566 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7e87530d-aae1-52c4-ad82-e4eb7a3853a6 -->
  <rule id="468753" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1566 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>