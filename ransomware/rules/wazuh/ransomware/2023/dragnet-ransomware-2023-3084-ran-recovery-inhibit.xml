<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3084 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: d0305cca-4835-5d19-94cf-364ef953dc9f -->
  <rule id="384892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3084 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>