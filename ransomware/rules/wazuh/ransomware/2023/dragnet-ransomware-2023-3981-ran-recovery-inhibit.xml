<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3981 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7f77e984-14aa-5778-b321-96a758ab54ed -->
  <rule id="344469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3981 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>