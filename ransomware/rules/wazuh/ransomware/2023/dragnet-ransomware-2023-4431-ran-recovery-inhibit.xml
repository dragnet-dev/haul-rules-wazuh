<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4431 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f90b8f59-d32a-5fcc-9e7a-106c64fc00c7 -->
  <rule id="572303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4431 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>