<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0343 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b2c7c2f1-1afb-53c0-8ac2-56919841aa9e -->
  <rule id="287642" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0343 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>