<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0708 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 48ae12e2-e2a6-5214-9b5b-7b57a7793cc1 -->
  <rule id="446212" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0708 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>