<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1939 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 7b18f342-394c-5f2f-af63-041315542aab -->
  <rule id="271033" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1939 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>