<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4227 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: ede58e56-ca0f-5bff-a7a0-13d3adec3269 -->
  <rule id="790542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4227 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>