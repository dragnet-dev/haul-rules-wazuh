<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0278 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: af0f2e59-52f3-5a18-b810-432f4249ed19 -->
  <rule id="982446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0278 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>