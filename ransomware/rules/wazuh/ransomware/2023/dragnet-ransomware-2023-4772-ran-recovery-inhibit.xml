<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4772 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: b81f8c97-0151-57af-aba6-3f8d9eac02b5 -->
  <rule id="425900" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4772 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>