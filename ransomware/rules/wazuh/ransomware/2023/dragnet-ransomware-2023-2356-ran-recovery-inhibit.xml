<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2356 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 6d0d1891-0f84-57a4-bf64-a000368d5011 -->
  <rule id="945318" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2356 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>