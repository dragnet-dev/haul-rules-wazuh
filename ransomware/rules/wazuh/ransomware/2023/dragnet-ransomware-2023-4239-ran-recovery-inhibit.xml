<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4239 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: eb162723-3293-5b4c-b29e-387574dd1a23 -->
  <rule id="651627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4239 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>