<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3312 — Recovery Inhibition (ransomed) | Status: experimental | Sigma ID: 907c0a46-acef-56ab-ab84-afc9e667e8ff -->
  <rule id="623850" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3312 — Recovery Inhibition (ransomed)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>