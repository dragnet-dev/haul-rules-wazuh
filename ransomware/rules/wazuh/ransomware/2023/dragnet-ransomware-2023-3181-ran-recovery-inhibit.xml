<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3181 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 8e4a994d-fb46-534c-b958-509c39afb720 -->
  <rule id="579499" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3181 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
