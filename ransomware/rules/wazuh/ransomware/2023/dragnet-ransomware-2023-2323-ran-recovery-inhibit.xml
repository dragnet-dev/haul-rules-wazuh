<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2323 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 55be8a2c-58f5-5482-8183-a0f5019dba58 -->
  <rule id="583338" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2323 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>