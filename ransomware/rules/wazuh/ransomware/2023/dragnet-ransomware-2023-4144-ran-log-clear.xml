<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4144 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: c350679b-2cb5-5edc-bc1f-29f4f5f525e1 -->
  <rule id="435067" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4144 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>