<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3584 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: bf12c754-b8df-5a31-b3cf-622d713b9fdd -->
  <rule id="458047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3584 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>