<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3126 — Recovery Inhibition (werewolves) | Status: deprecated | Sigma ID: 3b9b13eb-4cf0-5821-82a9-153dc834b7f2 -->
  <rule id="152222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3126 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>