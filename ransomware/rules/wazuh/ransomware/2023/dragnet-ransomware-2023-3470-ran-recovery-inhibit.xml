<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3470 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 76b8453a-6f83-5ca7-a651-af8535392f21 -->
  <rule id="427845" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3470 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>