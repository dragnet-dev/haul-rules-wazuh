<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0982 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 008c067e-fa88-5b1d-b35e-89e6bb90c7c2 -->
  <rule id="541086" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0982 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>