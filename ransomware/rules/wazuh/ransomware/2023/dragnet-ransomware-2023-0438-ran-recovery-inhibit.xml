<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0438 — Recovery Inhibition (cloak) | Status: experimental | Sigma ID: 3ac8d33f-3f14-5db1-8e1e-3e0e054756d4 -->
  <rule id="705413" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0438 — Recovery Inhibition (cloak)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>