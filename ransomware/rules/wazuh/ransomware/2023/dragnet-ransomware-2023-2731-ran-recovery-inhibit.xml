<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2731 — Recovery Inhibition (cyclops) | Status: deprecated | Sigma ID: 241218d2-dd46-55a1-b806-b16df6b5c64b -->
  <rule id="359501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2731 — Recovery Inhibition (cyclops)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>