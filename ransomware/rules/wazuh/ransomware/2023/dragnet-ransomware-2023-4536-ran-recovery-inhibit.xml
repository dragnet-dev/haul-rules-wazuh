<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4536 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 65fe91dd-5f81-5a55-b040-cf5888c2a76f -->
  <rule id="889491" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4536 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>