<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4625 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 81d41faf-381f-5730-99ce-27e623b0b3c1 -->
  <rule id="395071" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4625 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>