<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1259 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: ec01a285-203f-538a-bb32-096b38736f7d -->
  <rule id="276262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1259 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>