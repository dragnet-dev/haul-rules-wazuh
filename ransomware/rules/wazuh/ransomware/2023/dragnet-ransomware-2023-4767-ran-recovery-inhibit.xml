<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4767 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2c75eef9-d491-5947-9996-94bdfd86efba -->
  <rule id="345838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4767 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>