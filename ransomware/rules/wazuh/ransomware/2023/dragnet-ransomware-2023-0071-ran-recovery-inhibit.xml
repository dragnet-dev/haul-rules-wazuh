<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0071 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2941f4f3-4274-5f05-a7bb-312025f8092f -->
  <rule id="431439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0071 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>