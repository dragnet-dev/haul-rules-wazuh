<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4142 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3016fa0d-bd5e-5e01-a858-eb15bfb1c306 -->
  <rule id="623460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4142 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>