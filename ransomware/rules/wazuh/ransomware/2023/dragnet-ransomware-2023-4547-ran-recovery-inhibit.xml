<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4547 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6d40840a-640f-59cc-bee6-494312e5b44a -->
  <rule id="294084" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4547 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>