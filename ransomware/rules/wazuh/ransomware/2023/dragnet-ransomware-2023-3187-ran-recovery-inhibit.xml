<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3187 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: b5c4f06d-43bb-5965-a6c4-09a276394627 -->
  <rule id="363990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3187 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>