<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3957 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: b197c536-db0d-52d5-bebd-aa6fa096224d -->
  <rule id="991645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3957 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>