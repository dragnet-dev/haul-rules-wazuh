<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3282 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2d8fa465-de55-58c2-9f8a-b6ff5d5f7d8e -->
  <rule id="374984" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3282 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>