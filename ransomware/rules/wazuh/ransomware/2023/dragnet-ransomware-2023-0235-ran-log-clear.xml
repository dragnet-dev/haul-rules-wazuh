<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0235 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: cdac06ae-e81d-58a0-84c3-0bcc1f2e7a24 -->
  <rule id="865206" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0235 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>