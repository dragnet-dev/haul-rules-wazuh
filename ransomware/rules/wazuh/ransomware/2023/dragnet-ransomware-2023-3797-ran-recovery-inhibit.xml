<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3797 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 99dd5ab9-762c-50c4-acb1-ac47171782b3 -->
  <rule id="590490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3797 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>