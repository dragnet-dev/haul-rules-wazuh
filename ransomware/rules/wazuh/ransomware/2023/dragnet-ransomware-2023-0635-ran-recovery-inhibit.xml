<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0635 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: 74ad9132-3308-572d-bd50-65f660c68173 -->
  <rule id="211791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0635 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>