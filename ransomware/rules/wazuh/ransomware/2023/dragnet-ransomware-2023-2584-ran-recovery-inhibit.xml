<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2584 — Recovery Inhibition (siegedsec) | Status: experimental | Sigma ID: fe6693f1-f65e-5db6-87cb-5f89fa05c2d2 -->
  <rule id="846693" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2584 — Recovery Inhibition (siegedsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>