<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1170 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: cf0bb028-9bb5-524d-a43e-2693c9704fbe -->
  <rule id="901070" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1170 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>