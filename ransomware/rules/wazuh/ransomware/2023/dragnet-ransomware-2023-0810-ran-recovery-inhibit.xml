<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0810 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: add21aa9-8ef4-543d-ba62-423fe1f8e145 -->
  <rule id="949946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0810 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>