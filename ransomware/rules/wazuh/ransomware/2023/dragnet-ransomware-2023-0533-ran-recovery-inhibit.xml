<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0533 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 100cb8cd-622a-554a-a742-6a5e2da8dce9 -->
  <rule id="628620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0533 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>