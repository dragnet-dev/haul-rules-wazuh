<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1501 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 27d0bdcc-1ac4-57e2-84a3-05d547c4702e -->
  <rule id="339389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1501 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>