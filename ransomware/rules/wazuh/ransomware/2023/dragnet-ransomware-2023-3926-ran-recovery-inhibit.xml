<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3926 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 386a1541-5bda-561d-aa96-53a42948b91a -->
  <rule id="886154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3926 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>