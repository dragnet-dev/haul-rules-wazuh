<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0565 — Event Log Clearing (karakurt) | Status: experimental | Sigma ID: eec70a9c-4ff2-586b-ae3d-44a6e05c2c86 -->
  <rule id="813130" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0565 — Event Log Clearing (karakurt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>