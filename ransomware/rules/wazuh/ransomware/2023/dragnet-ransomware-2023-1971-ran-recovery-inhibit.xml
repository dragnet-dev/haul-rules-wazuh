<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1971 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: b67b12e8-1c54-5a82-93ad-e2a199b280e0 -->
  <rule id="168312" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1971 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>