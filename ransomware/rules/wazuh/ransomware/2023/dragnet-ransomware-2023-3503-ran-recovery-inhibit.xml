<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3503 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: a5825daa-5cdf-5e63-be7f-99dcaceced62 -->
  <rule id="893213" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3503 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>