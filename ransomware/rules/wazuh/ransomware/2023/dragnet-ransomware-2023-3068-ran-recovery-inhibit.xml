<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3068 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 80e49061-fbcf-5726-b23e-7a78e832a543 -->
  <rule id="494490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3068 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>