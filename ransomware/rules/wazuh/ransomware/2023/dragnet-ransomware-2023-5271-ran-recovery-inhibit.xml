<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5271 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 351ef362-f9b3-5755-bb23-c4d3f3765be7 -->
  <rule id="109536" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5271 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>