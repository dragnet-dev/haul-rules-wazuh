<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4928 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 762f2315-a83e-5d2a-b8ff-658eda7bc74d -->
  <rule id="420723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4928 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>