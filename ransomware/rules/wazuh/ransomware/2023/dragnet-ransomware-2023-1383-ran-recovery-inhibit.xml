<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1383 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 1919ff3c-ad5e-595e-a207-d1257bb21f09 -->
  <rule id="515193" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1383 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>