<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3740 — Recovery Inhibition (cryptbb) | Status: experimental | Sigma ID: d662de9e-b8dc-5bbc-96b5-3e09074d8055 -->
  <rule id="897694" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3740 — Recovery Inhibition (cryptbb)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>