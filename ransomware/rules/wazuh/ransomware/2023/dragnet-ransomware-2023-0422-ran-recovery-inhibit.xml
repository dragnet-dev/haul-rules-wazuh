<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0422 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 8a4bd625-e42c-57bc-986a-e5383f342ac8 -->
  <rule id="944936" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0422 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>