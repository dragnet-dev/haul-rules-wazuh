<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2646 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 595e75b2-ee3b-5c6c-a2b4-a383c239a818 -->
  <rule id="955611" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2646 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>