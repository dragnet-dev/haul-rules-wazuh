<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2840 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: cf379379-7551-54b3-9946-db6c1ac366ee -->
  <rule id="373793" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2840 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>