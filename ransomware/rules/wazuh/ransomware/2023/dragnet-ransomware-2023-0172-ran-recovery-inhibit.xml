<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0172 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: d1e3fcef-d838-5007-bd5a-dfb5100850af -->
  <rule id="102620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0172 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>