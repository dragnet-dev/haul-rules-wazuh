<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1513 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: cb9f96cc-190f-555a-ba87-d93db725cfc9 -->
  <rule id="663996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1513 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>