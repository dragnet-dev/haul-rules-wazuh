<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0224 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 113e3d1b-fc5f-5bb2-8f71-ca35279406a4 -->
  <rule id="315811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0224 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>