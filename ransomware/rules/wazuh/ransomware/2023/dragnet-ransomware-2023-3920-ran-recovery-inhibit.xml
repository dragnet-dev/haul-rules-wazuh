<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3920 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 45dc0f3c-cb93-5858-8fdd-4936a7f32751 -->
  <rule id="178415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3920 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>