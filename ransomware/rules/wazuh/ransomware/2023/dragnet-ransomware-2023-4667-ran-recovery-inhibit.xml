<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4667 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 396ae513-f065-5f5c-b3f0-d01a1133253f -->
  <rule id="215505" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4667 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
