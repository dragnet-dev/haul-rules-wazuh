<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4053 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: bf55f6a3-a42e-5e9f-bf17-6a4f0065f488 -->
  <rule id="464956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4053 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>