<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3135 — Recovery Inhibition (cloak) | Status: experimental | Sigma ID: 9cf249b0-5005-5d79-a368-ef12e995ffde -->
  <rule id="811249" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3135 — Recovery Inhibition (cloak)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>