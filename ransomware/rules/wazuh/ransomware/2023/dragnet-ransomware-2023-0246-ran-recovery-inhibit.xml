<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0246 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 20859b48-c7fe-5456-b5cf-19443cc88971 -->
  <rule id="737554" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0246 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>