<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2748 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: f6d80262-80d2-5e32-8c08-72d5b8fdb2be -->
  <rule id="809802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2748 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>