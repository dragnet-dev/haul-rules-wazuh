<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3977 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e8ced413-1855-5af5-842a-a51d32ed0416 -->
  <rule id="795174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3977 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>