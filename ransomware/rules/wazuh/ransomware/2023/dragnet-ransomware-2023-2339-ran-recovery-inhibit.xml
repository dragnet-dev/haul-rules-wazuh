<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2339 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 16b94a25-4bf5-5c31-b75c-e3ef1df8f884 -->
  <rule id="787142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2339 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>