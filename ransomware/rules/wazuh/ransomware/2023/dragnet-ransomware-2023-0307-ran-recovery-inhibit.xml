<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0307 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 62c8ff6f-e712-5f0f-b29d-871d938b53b2 -->
  <rule id="872543" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0307 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>