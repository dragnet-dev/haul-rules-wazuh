<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3316 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ad06178e-a72e-51f5-95d8-9fbf5ff67e65 -->
  <rule id="930617" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3316 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>