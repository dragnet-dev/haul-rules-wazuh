<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0151 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 6c8de783-1ae7-587e-aad6-7d57764227b1 -->
  <rule id="187507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0151 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>