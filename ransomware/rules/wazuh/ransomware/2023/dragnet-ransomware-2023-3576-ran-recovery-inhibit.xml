<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3576 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4e97052b-a45f-5c6a-84ed-f91bfba489d0 -->
  <rule id="797052" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3576 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>