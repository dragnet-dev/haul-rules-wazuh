<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1529 — Recovery Inhibition (ransomed) | Status: experimental | Sigma ID: bfaaa468-e116-5108-9c0d-3ba4e09d77ac -->
  <rule id="750664" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1529 — Recovery Inhibition (ransomed)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>