<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1986 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5df15dc7-d057-5a65-97c3-4eb8cfa1a4d1 -->
  <rule id="705053" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1986 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>