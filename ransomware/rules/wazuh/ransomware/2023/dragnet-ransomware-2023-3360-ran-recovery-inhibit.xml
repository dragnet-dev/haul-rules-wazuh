<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3360 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 93f5e330-5848-5d64-a3f3-ca81f7203f1a -->
  <rule id="705743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3360 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>