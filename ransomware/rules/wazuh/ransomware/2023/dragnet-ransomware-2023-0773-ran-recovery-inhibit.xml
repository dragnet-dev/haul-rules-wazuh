<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0773 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 125d2887-51ca-5540-b3ab-222dc426a33f -->
  <rule id="313288" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0773 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>