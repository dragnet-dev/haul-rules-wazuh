<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3179 — Recovery Inhibition (ransomed) | Status: experimental | Sigma ID: 8e5a8287-4bde-5bb8-9255-d4d631a53bee -->
  <rule id="581082" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3179 — Recovery Inhibition (ransomed)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>