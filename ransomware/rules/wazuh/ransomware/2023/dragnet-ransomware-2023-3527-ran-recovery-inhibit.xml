<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3527 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 39be0b6f-5281-5c41-b476-d296549887de -->
  <rule id="827851" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3527 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>