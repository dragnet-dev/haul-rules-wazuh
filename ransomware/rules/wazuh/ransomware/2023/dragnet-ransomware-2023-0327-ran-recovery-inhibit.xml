<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0327 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 8f5b5768-006c-522a-bd00-54e9d3ebac22 -->
  <rule id="597157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0327 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>