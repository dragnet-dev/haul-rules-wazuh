<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2305 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 9880e258-ad72-544f-9c5a-f5779ec82b33 -->
  <rule id="780942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2305 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>