<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2660 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 791089d7-a6b6-5f0e-b728-02fde4ec38d6 -->
  <rule id="157437" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2660 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>