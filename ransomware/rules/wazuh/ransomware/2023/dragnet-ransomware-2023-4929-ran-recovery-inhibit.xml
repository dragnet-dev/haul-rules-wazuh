<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4929 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: eefcd2a5-1d85-5bfb-872c-6b34907735fd -->
  <rule id="888932" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4929 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>