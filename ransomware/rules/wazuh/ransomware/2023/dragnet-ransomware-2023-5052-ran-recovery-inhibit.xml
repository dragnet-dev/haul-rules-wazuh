<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5052 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: 28c7ade8-5177-52b6-8e06-9a4b1176903e -->
  <rule id="379565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5052 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>