<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2163 — Recovery Inhibition (ElDorado) | Status: experimental | Sigma ID: afc44601-c8ac-59b3-bc11-f6d2fe139585 -->
  <rule id="212446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2163 — Recovery Inhibition (ElDorado)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>