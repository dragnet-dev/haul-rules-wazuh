<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4088 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 13b8e3c1-4ba3-5ea3-90df-dd59d6126c74 -->
  <rule id="329180" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4088 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>