<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3106 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 429412c7-1876-53fa-afc7-ce28277e5278 -->
  <rule id="670604" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3106 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>