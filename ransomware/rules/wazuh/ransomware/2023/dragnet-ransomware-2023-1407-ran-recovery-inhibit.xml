<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1407 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f4f5c379-c705-5bbf-a425-d27ec7798655 -->
  <rule id="467323" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1407 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>