<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3378 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: a7d3ad5b-f6ed-51b0-8dfa-91e70657d40f -->
  <rule id="916941" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3378 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>