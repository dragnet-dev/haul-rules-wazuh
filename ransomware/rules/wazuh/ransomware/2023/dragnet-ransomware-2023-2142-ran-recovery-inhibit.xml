<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2142 — Recovery Inhibition (losttrust) | Status: deprecated | Sigma ID: 7fa3ccc3-e22e-554c-8537-af38ec9643c8 -->
  <rule id="828492" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2142 — Recovery Inhibition (losttrust)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
