<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4707 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: af014a09-12b6-5558-b6f0-364dccb2c18e -->
  <rule id="200234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4707 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>