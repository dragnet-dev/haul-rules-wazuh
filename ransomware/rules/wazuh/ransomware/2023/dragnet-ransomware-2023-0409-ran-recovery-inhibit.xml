<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0409 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: bf950e41-ec53-5163-840c-a6a1a5b356b3 -->
  <rule id="471214" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0409 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>