<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4120 — Event Log Clearing (losttrust) | Status: deprecated | Sigma ID: cbd04dc3-83ec-53c1-85a7-1d68be5f75ba -->
  <rule id="817677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4120 — Event Log Clearing (losttrust)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>