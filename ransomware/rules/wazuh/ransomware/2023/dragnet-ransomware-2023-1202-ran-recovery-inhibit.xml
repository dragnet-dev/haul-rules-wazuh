<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1202 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 61cfb4da-aacc-5932-ab1a-a41f6c2c174a -->
  <rule id="831794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1202 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>