<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0502 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 392ea84f-278c-531d-b116-af015a1ac7e2 -->
  <rule id="205868" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0502 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>