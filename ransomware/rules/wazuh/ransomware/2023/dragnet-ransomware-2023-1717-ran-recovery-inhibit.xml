<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1717 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d6f139fc-2d94-5ac5-804c-75df9b6bc482 -->
  <rule id="491139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1717 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>