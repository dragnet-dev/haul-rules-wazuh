<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4600 — Recovery Inhibition (avoslocker) | Status: deprecated | Sigma ID: 5fd65aff-99fd-5f15-abe4-96e24c8e0636 -->
  <rule id="753850" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4600 — Recovery Inhibition (avoslocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>