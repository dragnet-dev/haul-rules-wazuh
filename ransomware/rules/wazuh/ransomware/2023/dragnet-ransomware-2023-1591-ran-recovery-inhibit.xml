<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1591 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 8bbcf26e-ccbf-5ff7-8b81-165b9b75a01b -->
  <rule id="423672" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1591 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>