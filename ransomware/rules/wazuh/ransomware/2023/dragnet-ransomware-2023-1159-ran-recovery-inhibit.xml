<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1159 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 68a18d89-c76a-5d68-bd8f-7759125ccf3a -->
  <rule id="957101" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1159 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>