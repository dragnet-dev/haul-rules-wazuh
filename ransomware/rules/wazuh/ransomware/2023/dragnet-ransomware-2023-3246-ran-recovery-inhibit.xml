<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3246 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: a6cc7d3b-7266-52bc-94e6-6ad0cdd5cb75 -->
  <rule id="874525" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3246 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>