<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1600 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7d15a337-8487-5274-b6e7-80f7da75831d -->
  <rule id="302503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1600 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>