<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0141 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9ebce454-4b19-5c3d-954e-2c68d495e75a -->
  <rule id="301904" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0141 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>