<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4756 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 11229060-2ece-57fc-b6cf-12b1e0ada45e -->
  <rule id="322906" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4756 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>