<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1521 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 5ad0727b-cd66-5893-ad53-ac1aaa339e51 -->
  <rule id="653072" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1521 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>