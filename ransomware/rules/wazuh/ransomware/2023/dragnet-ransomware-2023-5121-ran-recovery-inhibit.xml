<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5121 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: a8eab7fb-7184-52ee-9011-b32248d175ab -->
  <rule id="961237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5121 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>