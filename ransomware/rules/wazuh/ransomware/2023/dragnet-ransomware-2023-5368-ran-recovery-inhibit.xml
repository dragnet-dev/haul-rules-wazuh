<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5368 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: da43c970-58bc-5fad-b24b-150eb5213794 -->
  <rule id="895009" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5368 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>