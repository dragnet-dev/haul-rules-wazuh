<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2121 — Recovery Inhibition (trigona) | Status: deprecated | Sigma ID: 4757eac3-c229-5a50-8b22-9f6eb8e6ad50 -->
  <rule id="418026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2121 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>