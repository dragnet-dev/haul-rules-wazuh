<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5283 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 752445cd-6686-59c9-851c-5f6ffe0be297 -->
  <rule id="439132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5283 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>