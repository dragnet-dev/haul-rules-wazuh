<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2560 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 96b0cb89-2f2d-5589-a5ca-5ee455398a3d -->
  <rule id="460523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2560 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>