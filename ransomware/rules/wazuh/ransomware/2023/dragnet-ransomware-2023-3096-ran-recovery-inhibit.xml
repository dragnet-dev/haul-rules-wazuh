<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3096 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ae031d00-2977-5cd7-a3f0-6073e6fccefb -->
  <rule id="184509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3096 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>