<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5266 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 375b0edb-d26a-5db6-9bc5-fb773cdf2b7e -->
  <rule id="188397" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5266 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>