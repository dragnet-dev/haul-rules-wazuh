<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4037 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 42b858d5-d8a0-52f2-8a6f-9f1335e7176c -->
  <rule id="241741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4037 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>