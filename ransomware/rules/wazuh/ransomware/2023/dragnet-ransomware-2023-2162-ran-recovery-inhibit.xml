<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2162 — Recovery Inhibition (ElDorado) | Status: experimental | Sigma ID: 4fcba650-d3c7-52ab-9a1e-2c5706d2767c -->
  <rule id="668426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2162 — Recovery Inhibition (ElDorado)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>