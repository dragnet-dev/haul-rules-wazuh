<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3262 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 779f4ab5-74bc-57e3-96f4-4c62df6dc4ae -->
  <rule id="296714" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3262 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>