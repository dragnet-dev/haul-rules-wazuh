<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1596 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 1dd69b9b-3c31-5f5d-b910-071714e365a1 -->
  <rule id="543159" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1596 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>