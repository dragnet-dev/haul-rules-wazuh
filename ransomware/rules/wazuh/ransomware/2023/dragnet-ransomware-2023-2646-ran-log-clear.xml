<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2646 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: ceec8b4e-0c27-5ee4-957a-6fda2ed99924 -->
  <rule id="475659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2646 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>