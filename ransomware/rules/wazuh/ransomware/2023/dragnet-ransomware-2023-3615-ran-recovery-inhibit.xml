<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3615 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 67f8c035-5124-5829-a1a6-a7dde4ea1b36 -->
  <rule id="940600" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3615 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>