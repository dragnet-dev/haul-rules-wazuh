<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2407 — Event Log Clearing (ragnarlocker) | Status: experimental | Sigma ID: cdf4d27d-eddc-529d-8ffa-ee3c82cccdda -->
  <rule id="872772" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2407 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>