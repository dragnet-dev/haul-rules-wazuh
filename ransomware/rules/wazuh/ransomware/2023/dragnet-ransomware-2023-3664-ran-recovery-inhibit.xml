<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3664 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 1cd84330-f8aa-5cff-99c0-32897ecba902 -->
  <rule id="218433" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3664 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>