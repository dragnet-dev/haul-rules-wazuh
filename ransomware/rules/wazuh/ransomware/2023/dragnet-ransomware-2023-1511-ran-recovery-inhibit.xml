<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1511 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 37511e5a-a1d6-55f3-9720-76dbf0c1e45e -->
  <rule id="701905" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1511 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>