<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3681 — Recovery Inhibition (ALP-001) | Status: experimental | Sigma ID: 941d2529-ad21-50ae-8ac3-4b6abaadc4d2 -->
  <rule id="706925" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3681 — Recovery Inhibition (ALP-001)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>