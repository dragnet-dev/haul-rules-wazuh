<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1560 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 18c2a47b-98ff-5666-9762-491e7ab3f3a2 -->
  <rule id="404247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1560 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>