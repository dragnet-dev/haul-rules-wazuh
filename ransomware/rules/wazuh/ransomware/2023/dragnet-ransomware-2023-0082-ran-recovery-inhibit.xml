<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0082 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e90808a4-33ba-5428-9ce1-93e22f8cef40 -->
  <rule id="690808" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0082 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>