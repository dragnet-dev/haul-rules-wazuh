<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4778 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 42133f94-f324-5682-b637-60bfc7f1f09b -->
  <rule id="541439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4778 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
