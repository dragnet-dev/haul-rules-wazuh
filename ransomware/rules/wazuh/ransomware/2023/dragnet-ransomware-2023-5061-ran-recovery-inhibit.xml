<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5061 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 28c22392-bf82-5176-a2ae-f57482929d21 -->
  <rule id="202239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5061 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>