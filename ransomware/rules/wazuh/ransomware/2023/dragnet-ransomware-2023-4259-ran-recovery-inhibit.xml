<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4259 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 152311c5-3d08-555b-9b81-d55d6fbae2e1 -->
  <rule id="736988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4259 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>