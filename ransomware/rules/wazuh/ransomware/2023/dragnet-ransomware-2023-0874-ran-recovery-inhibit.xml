<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0874 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: ddaf76a3-505f-5f27-8498-5e4ae1577de0 -->
  <rule id="375176" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0874 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>