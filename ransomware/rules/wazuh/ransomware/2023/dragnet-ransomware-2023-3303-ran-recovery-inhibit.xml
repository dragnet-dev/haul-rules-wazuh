<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3303 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 6a71b91a-1376-5be0-8444-77409688f603 -->
  <rule id="907479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3303 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>