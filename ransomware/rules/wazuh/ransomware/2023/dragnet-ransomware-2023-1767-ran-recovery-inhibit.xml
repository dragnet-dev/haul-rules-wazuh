<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1767 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 380c766b-eb03-5cac-9499-40bab11e78b5 -->
  <rule id="792766" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1767 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>