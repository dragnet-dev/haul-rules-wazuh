<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2345 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: d9040f26-f898-51b9-ac3c-01603c1c54b4 -->
  <rule id="524655" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2345 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>