<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4982 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 64780722-d5cb-53d3-b821-db9d5af36710 -->
  <rule id="278072" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4982 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>