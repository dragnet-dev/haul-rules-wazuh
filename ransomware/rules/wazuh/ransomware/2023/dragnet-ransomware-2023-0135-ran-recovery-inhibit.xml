<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0135 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 295c356f-bacf-5c53-90b0-64da1298ab4d -->
  <rule id="332356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0135 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>