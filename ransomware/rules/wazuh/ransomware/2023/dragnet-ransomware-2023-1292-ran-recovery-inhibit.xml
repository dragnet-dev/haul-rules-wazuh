<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1292 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: c0b20b16-5490-5542-8cec-cc72fbdb7864 -->
  <rule id="489931" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1292 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>