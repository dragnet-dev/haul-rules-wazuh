<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2563 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7cda275b-77c6-50d2-8f39-126e7e5ff4fa -->
  <rule id="596227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2563 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>