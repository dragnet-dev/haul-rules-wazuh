<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2052 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: fd323cfb-90f6-5c3d-af8b-add1d79a3b7a -->
  <rule id="553180" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2052 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>