<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2860 — Event Log Clearing (malas) | Status: experimental | Sigma ID: c4d4a494-22c4-5ba6-b3ad-85f5a2a86b53 -->
  <rule id="595944" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2860 — Event Log Clearing (malas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>