<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3044 — Event Log Clearing (bianlian) | Status: deprecated | Sigma ID: 36941f96-cdc6-5ebb-8b65-a6eba4e32ed5 -->
  <rule id="610719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3044 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>