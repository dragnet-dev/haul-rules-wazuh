<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2241 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 53ffde55-b875-5090-8edb-dfbde2ec5990 -->
  <rule id="938910" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2241 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>