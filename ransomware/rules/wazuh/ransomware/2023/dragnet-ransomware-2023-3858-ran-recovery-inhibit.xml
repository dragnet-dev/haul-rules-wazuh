<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3858 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: b3b488ff-fed0-5a20-9d05-f8df37712e12 -->
  <rule id="119488" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3858 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>