<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0995 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: c89f408a-0ee4-5425-a413-c213d76a8b88 -->
  <rule id="363940" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0995 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>