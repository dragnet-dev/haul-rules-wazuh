<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0526 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 61b8c590-682b-57a7-813b-3c61a9a2d7b5 -->
  <rule id="780605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0526 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>