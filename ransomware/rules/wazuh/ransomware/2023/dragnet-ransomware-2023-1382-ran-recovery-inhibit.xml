<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1382 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 328fd0f5-f14c-5f4a-97f5-266100b6c5f0 -->
  <rule id="975375" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1382 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>