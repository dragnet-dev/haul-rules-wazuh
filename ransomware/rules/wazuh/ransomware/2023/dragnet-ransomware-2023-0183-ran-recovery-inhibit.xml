<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0183 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: b85712fb-57b8-5831-b6a0-373312d46e67 -->
  <rule id="385712" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0183 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>