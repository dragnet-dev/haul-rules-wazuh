<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3727 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 291dc7cb-ab98-5571-9643-8f487b8e3139 -->
  <rule id="354684" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3727 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>