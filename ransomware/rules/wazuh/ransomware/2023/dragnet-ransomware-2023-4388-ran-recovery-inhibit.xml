<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4388 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 98736c16-7f77-559a-9fbe-32518b4425ec -->
  <rule id="779788" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4388 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>