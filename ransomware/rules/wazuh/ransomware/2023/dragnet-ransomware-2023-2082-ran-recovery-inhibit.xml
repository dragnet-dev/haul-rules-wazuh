<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2082 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: fcff1fb9-6e7e-531b-ac1b-b3498802c784 -->
  <rule id="562751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2082 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>