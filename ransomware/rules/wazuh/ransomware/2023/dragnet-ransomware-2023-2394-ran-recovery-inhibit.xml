<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2394 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 586e2c74-e45a-5c6a-b4b2-b1a190a9b900 -->
  <rule id="702444" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2394 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>