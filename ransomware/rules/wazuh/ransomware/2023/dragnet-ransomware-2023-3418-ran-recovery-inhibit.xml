<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3418 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: fb7e47eb-f525-5656-9ae0-ae24f57c397e -->
  <rule id="528647" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3418 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>