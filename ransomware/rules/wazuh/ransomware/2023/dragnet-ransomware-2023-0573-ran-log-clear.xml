<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0573 — Event Log Clearing (royal) | Status: experimental | Sigma ID: 6c860a1c-b6c7-529c-bb2d-5a4d5d3c0451 -->
  <rule id="941770" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0573 — Event Log Clearing (royal)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>