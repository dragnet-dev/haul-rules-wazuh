<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4774 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: e3e9bbd9-451c-5d4a-a7ef-44a14932d4d3 -->
  <rule id="595611" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4774 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>