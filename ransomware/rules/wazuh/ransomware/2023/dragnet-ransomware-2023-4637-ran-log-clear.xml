<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4637 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: ff46a9ec-0846-58a1-9e7b-9e39e8f9da46 -->
  <rule id="587469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4637 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>