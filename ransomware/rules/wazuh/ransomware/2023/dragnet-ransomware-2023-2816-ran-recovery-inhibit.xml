<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2816 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: a4f926ee-9b2d-5287-b0c9-cc087544c205 -->
  <rule id="879926" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2816 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>