<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4510 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: ebeac3e4-75ee-5c9a-97a3-4aac61d4ba05 -->
  <rule id="763163" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4510 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>