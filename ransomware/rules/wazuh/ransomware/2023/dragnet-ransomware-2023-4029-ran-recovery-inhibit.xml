<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4029 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 03afc3e9-ca8f-52cf-acbc-9f0db1e6fa1f -->
  <rule id="716062" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4029 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>