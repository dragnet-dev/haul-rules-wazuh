<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1344 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 675d5e01-ecec-549b-b3ff-7378216c8280 -->
  <rule id="930174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1344 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>