<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5203 — Recovery Inhibition (ciphbit) | Status: deprecated | Sigma ID: 9b66156e-232b-5579-9636-daf582b20aef -->
  <rule id="756615" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5203 — Recovery Inhibition (ciphbit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
