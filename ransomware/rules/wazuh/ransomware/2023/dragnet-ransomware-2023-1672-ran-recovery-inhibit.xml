<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1672 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 471a11da-ac3e-5792-b57a-26d994a72d29 -->
  <rule id="473789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1672 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>