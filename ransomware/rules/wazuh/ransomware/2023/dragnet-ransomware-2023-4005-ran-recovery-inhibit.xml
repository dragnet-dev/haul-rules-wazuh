<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4005 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 34d41662-0553-52c9-b295-85a31ebbffe6 -->
  <rule id="274166" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4005 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>