<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1562 — Recovery Inhibition (mallox) | Status: experimental | Sigma ID: 977b17f6-a178-5339-9218-06c62f34ab96 -->
  <rule id="764317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1562 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>