<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2997 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1f8100ce-a31c-541e-8a1c-7296caed44d1 -->
  <rule id="689612" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2997 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>