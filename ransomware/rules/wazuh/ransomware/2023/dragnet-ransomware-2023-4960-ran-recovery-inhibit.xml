<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4960 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: be75cb04-689d-5f11-8a77-b42cbdb86499 -->
  <rule id="483403" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4960 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>