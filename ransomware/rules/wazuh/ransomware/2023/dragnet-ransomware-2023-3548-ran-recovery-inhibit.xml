<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3548 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 973ee994-702c-51c9-825c-1e43f53e5a08 -->
  <rule id="793269" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3548 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>