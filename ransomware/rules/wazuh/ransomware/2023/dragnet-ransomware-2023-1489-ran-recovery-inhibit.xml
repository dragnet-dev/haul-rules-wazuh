<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1489 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 313767f8-3431-58f2-9928-4f8ae4c04535 -->
  <rule id="620287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1489 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>