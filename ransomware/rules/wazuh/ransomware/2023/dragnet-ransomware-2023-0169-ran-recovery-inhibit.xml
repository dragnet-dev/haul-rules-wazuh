<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0169 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 93becd56-062b-559d-ba22-4de2503ed298 -->
  <rule id="843693" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0169 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>