<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1390 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: a0161fa0-f08e-5651-8590-9d04733e4a4f -->
  <rule id="802591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1390 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>