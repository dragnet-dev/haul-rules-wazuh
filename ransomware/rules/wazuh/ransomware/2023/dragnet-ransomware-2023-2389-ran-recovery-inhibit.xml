<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2389 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: 7ea5e8ef-dd9e-5063-b7fb-bd28fe7054f0 -->
  <rule id="642548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2389 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>