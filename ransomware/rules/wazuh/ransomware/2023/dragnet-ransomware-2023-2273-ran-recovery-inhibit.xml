<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2273 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: a159b445-f45f-57d5-b2b4-e2a5a24b5172 -->
  <rule id="825554" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2273 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>