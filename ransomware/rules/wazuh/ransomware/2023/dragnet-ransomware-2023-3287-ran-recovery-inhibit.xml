<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3287 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 703fcf94-822b-5c28-9600-a6b22bc6b899 -->
  <rule id="283535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3287 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>