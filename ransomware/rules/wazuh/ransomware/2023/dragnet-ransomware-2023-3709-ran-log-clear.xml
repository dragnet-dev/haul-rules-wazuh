<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3709 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 944a2cc6-ae17-510e-9aab-76e7a1d2c6e1 -->
  <rule id="718284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3709 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>