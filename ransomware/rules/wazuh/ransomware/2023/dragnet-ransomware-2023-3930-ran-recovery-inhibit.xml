<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3930 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 94b2cae6-13bd-508d-bf6e-5ed5cdebafd9 -->
  <rule id="379114" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3930 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>