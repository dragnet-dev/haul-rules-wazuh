<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1227 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 386b182b-a7e9-54fe-a068-d35d18e6f766 -->
  <rule id="887182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1227 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>