<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5226 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 9e103660-968e-593c-903a-1677837ebddb -->
  <rule id="781036" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5226 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>