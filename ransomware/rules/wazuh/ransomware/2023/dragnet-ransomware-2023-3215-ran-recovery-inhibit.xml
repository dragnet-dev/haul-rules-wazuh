<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3215 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: a0e5e6d3-9d2c-5705-bcbd-1b5118325539 -->
  <rule id="883346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3215 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>