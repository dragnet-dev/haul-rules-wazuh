<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4673 — Event Log Clearing (knight) | Status: experimental | Sigma ID: 035540b8-fd8d-5503-9536-fa5b83dbeaf8 -->
  <rule id="386518" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4673 — Event Log Clearing (knight)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>