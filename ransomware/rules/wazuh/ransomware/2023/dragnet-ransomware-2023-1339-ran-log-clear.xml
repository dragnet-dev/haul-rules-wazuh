<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1339 — Event Log Clearing (monti) | Status: experimental | Sigma ID: 92b18d3a-ddf1-5a70-9999-32cc7e26b9c3 -->
  <rule id="673101" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1339 — Event Log Clearing (monti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>