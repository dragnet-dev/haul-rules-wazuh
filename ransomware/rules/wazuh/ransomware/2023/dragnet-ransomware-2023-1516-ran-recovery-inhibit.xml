<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1516 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 9d1b4e35-011d-55b1-8b01-f6a9fe5929c1 -->
  <rule id="523598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1516 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>