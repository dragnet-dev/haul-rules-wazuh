<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2888 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: bb5a1a1a-b77c-5793-90c3-8d6b7682db98 -->
  <rule id="401626" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2888 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>