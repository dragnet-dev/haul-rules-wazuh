<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3315 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: daecaa09-f7ba-5ec7-8d86-53113f6d08eb -->
  <rule id="947434" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3315 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>