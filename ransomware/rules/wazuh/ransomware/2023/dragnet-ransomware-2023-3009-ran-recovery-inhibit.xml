<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3009 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 952d1704-1f75-5e74-90b5-bf8cd77811c9 -->
  <rule id="724517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3009 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>