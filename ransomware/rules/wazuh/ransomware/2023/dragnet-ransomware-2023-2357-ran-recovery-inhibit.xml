<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2357 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 1eae94c6-92a1-5088-9647-72e704659f10 -->
  <rule id="967916" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2357 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>