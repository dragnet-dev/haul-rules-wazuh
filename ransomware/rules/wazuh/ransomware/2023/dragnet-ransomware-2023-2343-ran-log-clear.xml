<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2343 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 3c5e27bd-e8c2-54d2-98f6-505638cf4d9d -->
  <rule id="310843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2343 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>