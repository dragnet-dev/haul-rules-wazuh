<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4941 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c92fe3c6-8eff-5820-9cd2-b8f4218f726b -->
  <rule id="710063" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4941 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>