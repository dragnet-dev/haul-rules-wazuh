<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0287 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: a5d2d793-650e-55c5-9a3e-2ea88dddfd5e -->
  <rule id="109257" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0287 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>