<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5098 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 289aefcf-ad24-5999-afef-ebfb85dee415 -->
  <rule id="386543" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5098 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>