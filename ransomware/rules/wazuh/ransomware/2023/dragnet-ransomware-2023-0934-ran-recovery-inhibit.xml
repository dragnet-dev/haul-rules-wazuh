<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0934 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: db91e51a-9c40-5df2-90d8-1e0e1a794ce8 -->
  <rule id="918705" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0934 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>