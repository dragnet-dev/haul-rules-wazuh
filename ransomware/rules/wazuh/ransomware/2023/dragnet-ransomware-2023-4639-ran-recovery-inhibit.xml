<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4639 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: a7e8740d-0962-56ba-8c8b-ba18214a00da -->
  <rule id="926874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4639 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>