<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4658 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 85c04663-c278-5155-b82e-20df9eac9198 -->
  <rule id="572046" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4658 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>