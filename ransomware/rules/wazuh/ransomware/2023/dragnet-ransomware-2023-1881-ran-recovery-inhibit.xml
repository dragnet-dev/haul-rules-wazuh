<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1881 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: d123eab1-b3e1-5a19-aff7-e3f7bdd62d65 -->
  <rule id="759722" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1881 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>