<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2722 — Event Log Clearing (moneymessage) | Status: experimental | Sigma ID: 8316325a-fb0c-5fca-b18a-ac3ec891eda7 -->
  <rule id="316325" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2722 — Event Log Clearing (moneymessage)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>