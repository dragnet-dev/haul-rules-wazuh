<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2643 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: e8171f90-0638-5b53-be17-8133f56e4a14 -->
  <rule id="670751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2643 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>