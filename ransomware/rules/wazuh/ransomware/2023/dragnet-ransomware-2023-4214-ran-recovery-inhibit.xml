<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4214 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 13334cb5-9fb9-5dbc-a7ca-178096d3fe10 -->
  <rule id="813707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4214 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>