<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2536 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 30f4956e-a31f-524d-b44a-932dad499eeb -->
  <rule id="554956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2536 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>