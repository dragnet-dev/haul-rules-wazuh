<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2467 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 3551304c-e4f8-5f45-b938-a711920615dc -->
  <rule id="951304" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2467 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>