<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3243 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b523536a-694f-508e-9c76-b10d7c9fbd1c -->
  <rule id="352353" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3243 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>