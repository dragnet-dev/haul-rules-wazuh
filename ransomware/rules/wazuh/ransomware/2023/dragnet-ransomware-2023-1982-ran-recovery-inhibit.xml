<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1982 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 9f290b75-f9fc-5a65-a283-3b016acdd754 -->
  <rule id="848651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1982 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>