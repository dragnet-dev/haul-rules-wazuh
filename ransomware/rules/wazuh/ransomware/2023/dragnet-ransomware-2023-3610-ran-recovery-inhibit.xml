<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3610 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 8468e005-04ee-5915-92e4-4892cd5e3b6d -->
  <rule id="555020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3610 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>