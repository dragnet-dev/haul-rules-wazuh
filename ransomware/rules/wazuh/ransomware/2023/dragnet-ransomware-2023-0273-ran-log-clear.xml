<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0273 — Event Log Clearing (mallox) | Status: deprecated | Sigma ID: d8bcb9fb-3bef-5b1f-ae70-e273f2c33190 -->
  <rule id="382679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0273 — Event Log Clearing (mallox)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>