<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2817 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 99f8db1f-a06f-503e-9ea2-f56d7e8daa5f -->
  <rule id="595707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2817 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>