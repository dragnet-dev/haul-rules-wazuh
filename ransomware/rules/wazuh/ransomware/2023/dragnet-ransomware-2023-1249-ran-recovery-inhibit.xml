<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1249 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 9159740a-b853-55d4-921d-f4890005423a -->
  <rule id="259740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1249 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>