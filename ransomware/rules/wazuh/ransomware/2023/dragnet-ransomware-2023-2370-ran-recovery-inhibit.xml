<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2370 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 22028c7b-8e87-5b04-9083-11b7c78e6092 -->
  <rule id="924607" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2370 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>