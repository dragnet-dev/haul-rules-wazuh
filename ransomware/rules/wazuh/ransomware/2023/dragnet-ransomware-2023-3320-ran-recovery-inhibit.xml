<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3320 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e1510cb7-e461-53c4-9d0e-6a576bb9cff2 -->
  <rule id="564172" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3320 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>