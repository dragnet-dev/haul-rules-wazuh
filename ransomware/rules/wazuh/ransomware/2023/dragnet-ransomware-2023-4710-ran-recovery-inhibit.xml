<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4710 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 49ec9abf-c385-5c14-9557-2bfeaf6fe0c8 -->
  <rule id="344954" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4710 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>