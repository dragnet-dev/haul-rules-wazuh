<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3244 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: aa51aa34-c675-5ea7-8666-28d1b4cff7a1 -->
  <rule id="865226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3244 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>