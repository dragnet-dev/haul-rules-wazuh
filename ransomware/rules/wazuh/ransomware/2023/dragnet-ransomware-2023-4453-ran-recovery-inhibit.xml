<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4453 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f8a26788-eeb6-541c-b7e4-85047ea8e4e4 -->
  <rule id="838267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4453 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>