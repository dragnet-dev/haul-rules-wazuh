<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1228 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3d241535-1d4e-572b-9c56-0254d105fd3b -->
  <rule id="824153" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1228 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>