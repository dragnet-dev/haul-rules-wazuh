<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4516 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: f7cffdb9-d9cb-5d7b-835b-a5435c8da125 -->
  <rule id="542397" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4516 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>