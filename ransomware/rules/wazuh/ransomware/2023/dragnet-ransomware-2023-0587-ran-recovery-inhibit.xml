<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0587 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 80e9e655-eec1-5e03-8700-935406fdcda6 -->
  <rule id="371986" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0587 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>