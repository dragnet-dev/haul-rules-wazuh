<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2014 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: dbfedc4f-c693-5310-a91c-b0c4bfb37660 -->
  <rule id="117628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2014 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>