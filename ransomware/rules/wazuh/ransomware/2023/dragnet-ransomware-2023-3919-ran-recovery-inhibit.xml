<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3919 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 65ceeb02-8552-5e55-9a93-695d8ae09b7a -->
  <rule id="812811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3919 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>