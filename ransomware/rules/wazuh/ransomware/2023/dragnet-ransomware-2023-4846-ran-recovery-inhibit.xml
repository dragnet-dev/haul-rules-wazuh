<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4846 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 11df5fb1-812d-5a3b-ba29-ab2deeb0bbf6 -->
  <rule id="681371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4846 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>