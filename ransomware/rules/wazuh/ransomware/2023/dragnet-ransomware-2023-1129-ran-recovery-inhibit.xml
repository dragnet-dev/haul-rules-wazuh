<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1129 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: da018f8d-eeea-5585-bada-65de61650752 -->
  <rule id="888303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1129 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>