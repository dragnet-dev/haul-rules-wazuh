<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2452 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e86a0cc1-7848-57ca-9d38-cc4b04880050 -->
  <rule id="305772" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2452 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>