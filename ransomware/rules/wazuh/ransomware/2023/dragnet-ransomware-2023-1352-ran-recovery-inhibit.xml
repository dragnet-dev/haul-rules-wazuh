<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1352 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 587daac4-38c3-5a43-88d9-ddbf01317a81 -->
  <rule id="707850" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1352 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>