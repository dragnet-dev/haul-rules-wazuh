<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0552 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6236fb7a-1883-591d-81c3-5dc45de3a1c9 -->
  <rule id="796667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0552 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>