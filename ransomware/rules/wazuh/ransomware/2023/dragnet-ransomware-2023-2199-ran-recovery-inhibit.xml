<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2199 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 56a8471a-11d6-5533-9510-4016a0dc737f -->
  <rule id="168471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2199 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
