<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4724 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e588b9bc-a1cb-5679-a55b-c0caa88f786a -->
  <rule id="634199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4724 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>