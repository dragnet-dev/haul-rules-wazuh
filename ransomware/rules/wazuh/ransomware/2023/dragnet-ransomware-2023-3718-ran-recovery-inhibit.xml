<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3718 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 82dec101-b070-5f14-b6e9-95372feb598d -->
  <rule id="794361" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3718 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>