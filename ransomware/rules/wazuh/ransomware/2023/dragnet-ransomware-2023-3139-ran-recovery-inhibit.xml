<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3139 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 501c3a42-f58e-5582-a2e0-d53d0c1753e4 -->
  <rule id="484538" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3139 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>