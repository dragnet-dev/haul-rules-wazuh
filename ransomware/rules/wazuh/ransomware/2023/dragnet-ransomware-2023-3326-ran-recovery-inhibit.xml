<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3326 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 8a7b7052-7f07-5e09-acfc-e07bf9eff4cf -->
  <rule id="520370" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3326 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>