<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3354 — Recovery Inhibition (darkpower) | Status: experimental | Sigma ID: d1ffa92b-8524-5841-b79c-ce9941f40239 -->
  <rule id="106669" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3354 — Recovery Inhibition (darkpower)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>