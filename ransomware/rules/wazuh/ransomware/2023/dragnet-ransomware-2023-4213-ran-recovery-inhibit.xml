<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4213 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 794438eb-2b7e-5d55-852f-130c65ff331d -->
  <rule id="211022" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4213 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>