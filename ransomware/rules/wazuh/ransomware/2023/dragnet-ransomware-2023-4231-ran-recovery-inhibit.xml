<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4231 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ae7c8733-b88b-5e73-bf0f-59ea7e430831 -->
  <rule id="196487" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4231 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>