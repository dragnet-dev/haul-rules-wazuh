<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1911 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 13134ed4-3f53-546b-ac18-40ba681c4333 -->
  <rule id="762541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1911 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>