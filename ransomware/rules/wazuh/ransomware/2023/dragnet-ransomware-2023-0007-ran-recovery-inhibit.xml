<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0007 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 0021c20d-b357-5980-9851-4e7398ee7bd7 -->
  <rule id="914139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0007 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>