<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2848 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: f181e4b9-853b-5f3d-9cd1-f2cce3e607e1 -->
  <rule id="729104" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2848 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>