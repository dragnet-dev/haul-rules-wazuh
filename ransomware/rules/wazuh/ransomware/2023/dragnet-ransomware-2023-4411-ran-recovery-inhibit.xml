<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4411 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: aea51faf-cc54-5b2c-8cf7-bf623d3e980f -->
  <rule id="971231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4411 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>