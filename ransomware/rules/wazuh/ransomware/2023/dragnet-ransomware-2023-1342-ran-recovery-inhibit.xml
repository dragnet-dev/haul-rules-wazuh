<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1342 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 11c0609d-9092-522c-9b58-a21f6ae0f884 -->
  <rule id="180609" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1342 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>