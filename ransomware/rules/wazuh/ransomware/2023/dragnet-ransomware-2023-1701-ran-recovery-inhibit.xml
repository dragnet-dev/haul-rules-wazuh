<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1701 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: d5da285e-73b8-5e75-bcf9-a1d6de5179e8 -->
  <rule id="877828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1701 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>