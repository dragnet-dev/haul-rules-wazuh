<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0019 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: f802dd2d-ae55-58e9-b419-c05f4da9f48a -->
  <rule id="545533" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0019 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
