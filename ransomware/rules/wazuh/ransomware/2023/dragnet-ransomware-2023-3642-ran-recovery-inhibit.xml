<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3642 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 62b50e55-5b57-56fc-954f-bee329db6aef -->
  <rule id="805614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3642 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>