<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3477 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: b42eb811-0867-58e8-b009-ddc488d88477 -->
  <rule id="325878" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3477 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>