<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1756 — Event Log Clearing (ciphbit) | Status: deprecated | Sigma ID: 09d5f5f1-0b0d-5992-b63d-60a0cce744c2 -->
  <rule id="534495" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1756 — Event Log Clearing (ciphbit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>