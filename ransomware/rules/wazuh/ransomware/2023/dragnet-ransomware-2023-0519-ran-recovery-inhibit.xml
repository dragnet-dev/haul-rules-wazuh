<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0519 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ed67dd39-07d1-5ac3-b1ad-aac86c994169 -->
  <rule id="784573" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0519 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>