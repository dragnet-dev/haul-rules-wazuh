<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3609 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: f4614a9d-438a-5aa0-80f7-bfc8af270057 -->
  <rule id="773834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3609 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>