<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0662 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c5bdeaf8-54c2-5af6-b734-93ae8c1f4398 -->
  <rule id="240618" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0662 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>