<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0514 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 0e038046-acb6-5911-b212-1ee2d29d3e14 -->
  <rule id="603804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0514 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>