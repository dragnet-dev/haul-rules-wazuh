<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0452 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: b9eb8864-337c-5226-a89d-899622c2d640 -->
  <rule id="469988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0452 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>