<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2028 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 3cc15d3a-55c6-5025-8f49-13c5a8381c76 -->
  <rule id="755453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2028 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>