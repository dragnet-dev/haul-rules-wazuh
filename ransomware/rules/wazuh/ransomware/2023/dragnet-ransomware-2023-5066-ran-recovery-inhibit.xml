<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5066 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: 71097ca8-eb3c-5c37-97db-74664ff62ee3 -->
  <rule id="337564" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5066 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>