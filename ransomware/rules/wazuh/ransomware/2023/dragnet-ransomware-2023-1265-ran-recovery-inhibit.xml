<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1265 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: bd99575d-6c51-552d-9f03-b630626ba70b -->
  <rule id="199957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1265 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>