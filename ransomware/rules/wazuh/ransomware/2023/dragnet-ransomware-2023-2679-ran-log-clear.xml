<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2679 — Event Log Clearing (trigona) | Status: deprecated | Sigma ID: 693dcc45-0e4f-5b46-a0cc-ae8a112575d6 -->
  <rule id="242060" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2679 — Event Log Clearing (trigona)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>