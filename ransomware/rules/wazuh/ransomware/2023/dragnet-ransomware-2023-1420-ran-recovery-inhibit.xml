<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1420 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: 318e9ea6-5ef3-56ba-ac63-bf29e644eab7 -->
  <rule id="563658" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1420 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>