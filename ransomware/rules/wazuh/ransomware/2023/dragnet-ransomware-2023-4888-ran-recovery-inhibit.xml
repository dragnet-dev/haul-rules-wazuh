<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4888 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: d926cf0e-f956-564b-ab37-103d3ab67ce7 -->
  <rule id="965263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4888 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>