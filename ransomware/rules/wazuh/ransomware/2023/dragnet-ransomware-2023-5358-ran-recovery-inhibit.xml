<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5358 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f0978856-4df1-5c3e-95e8-96d93ed4c432 -->
  <rule id="709788" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5358 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>