<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2862 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 7de1ae2f-0e26-5363-b162-028bdf356e09 -->
  <rule id="756270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2862 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>