<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1309 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 5a4d1f13-bc2a-51bf-9462-4740cb747855 -->
  <rule id="616351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1309 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>