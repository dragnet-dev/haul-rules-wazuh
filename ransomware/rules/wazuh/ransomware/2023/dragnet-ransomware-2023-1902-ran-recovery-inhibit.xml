<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1902 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f3fb5f64-7b7e-5a40-b6cf-77147e143fdd -->
  <rule id="107135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1902 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>