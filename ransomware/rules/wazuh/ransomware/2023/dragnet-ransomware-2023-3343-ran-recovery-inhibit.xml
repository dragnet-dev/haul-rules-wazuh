<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3343 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: b68d054d-ba00-5786-ab64-87d04f0d5996 -->
  <rule id="170105" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3343 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>