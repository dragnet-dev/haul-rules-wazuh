<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4357 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: be93ed00-0963-5670-b461-62528057f816 -->
  <rule id="488045" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4357 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>