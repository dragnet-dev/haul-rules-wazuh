<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3088 — Event Log Clearing (karakurt) | Status: experimental | Sigma ID: 4f9b3745-f6f5-5db4-a3b6-f2c0efd5b886 -->
  <rule id="479537" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3088 — Event Log Clearing (karakurt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>