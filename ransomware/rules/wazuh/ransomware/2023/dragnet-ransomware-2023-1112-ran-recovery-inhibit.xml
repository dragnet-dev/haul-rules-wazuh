<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1112 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: df9e336c-0682-569b-91cd-0a92b195cf5f -->
  <rule id="983833" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1112 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>