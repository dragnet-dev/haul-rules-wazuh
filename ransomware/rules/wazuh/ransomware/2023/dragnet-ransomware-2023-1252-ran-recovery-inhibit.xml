<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1252 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 037e03ab-2ad3-53d5-b9a5-a5432bff4dd4 -->
  <rule id="314539" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1252 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>