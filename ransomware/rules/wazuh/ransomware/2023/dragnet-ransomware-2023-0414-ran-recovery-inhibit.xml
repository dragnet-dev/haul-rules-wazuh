<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0414 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 7963bf63-ee44-575e-9e51-77e0f245c544 -->
  <rule id="338719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0414 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>