<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2166 — Event Log Clearing (losttrust) | Status: deprecated | Sigma ID: 0ef2f25f-743f-5c87-845a-0176cc2f3df8 -->
  <rule id="328725" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2166 — Event Log Clearing (losttrust)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>