<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0893 — Recovery Inhibition (losttrust) | Status: deprecated | Sigma ID: 27eea601-e34d-5916-8ac4-321e79285bdd -->
  <rule id="344106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0893 — Recovery Inhibition (losttrust)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>