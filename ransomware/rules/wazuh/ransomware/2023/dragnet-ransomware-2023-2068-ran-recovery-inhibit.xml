<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2068 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 66b365a8-d80b-547f-b493-4eb16ee06a19 -->
  <rule id="267365" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2068 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>