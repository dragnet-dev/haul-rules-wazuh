<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2652 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: eafaac92-f5f5-55fb-9ed2-a11d9e99f850 -->
  <rule id="199596" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2652 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>