<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0713 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 72d66d79-7041-53ec-b149-4532e6b4e44c -->
  <rule id="165069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0713 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>