<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1845 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: d5e3e8a1-2a88-50d6-89b9-cc52bda03094 -->
  <rule id="879028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1845 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>