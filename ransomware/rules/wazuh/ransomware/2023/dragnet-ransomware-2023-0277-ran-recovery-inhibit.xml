<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0277 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3d334d5a-ea7f-5e5a-b765-50272d3afefd -->
  <rule id="913575" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0277 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>