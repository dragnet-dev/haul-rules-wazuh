<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3511 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 1114dfe4-1bbb-515f-ba7d-90cb22e6a2d6 -->
  <rule id="166526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3511 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>