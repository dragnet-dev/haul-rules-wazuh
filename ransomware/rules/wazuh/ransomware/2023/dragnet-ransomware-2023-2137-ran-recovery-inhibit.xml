<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2137 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 39ce2319-6483-5be6-8e95-0065cc4e7edc -->
  <rule id="219023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2137 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>