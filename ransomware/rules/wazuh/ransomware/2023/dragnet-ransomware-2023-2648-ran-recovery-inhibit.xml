<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2648 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 33fdb6a9-5b3b-55dd-9c20-fe241a277c19 -->
  <rule id="592276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2648 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>