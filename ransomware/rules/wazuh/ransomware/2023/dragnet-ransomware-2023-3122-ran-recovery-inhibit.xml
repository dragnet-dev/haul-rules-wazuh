<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3122 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: d65af58e-9297-53ed-b1f6-0fbeb4c6372d -->
  <rule id="896155" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3122 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>