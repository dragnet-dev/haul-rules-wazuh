<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2750 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: d0709d8b-c549-5ce9-b230-0248cb20a883 -->
  <rule id="391357" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2750 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>