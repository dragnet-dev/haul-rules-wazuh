<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4104 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d8ac2029-699c-55fb-8c60-74693a18a87c -->
  <rule id="950020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4104 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>