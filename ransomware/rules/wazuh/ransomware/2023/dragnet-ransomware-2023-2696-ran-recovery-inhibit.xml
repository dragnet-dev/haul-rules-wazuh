<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2696 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 15158c61-1c00-55da-93c7-36b5d81ca9aa -->
  <rule id="725406" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2696 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
