<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4133 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9bd2ab5b-155d-5a69-9efa-1f65a01d1def -->
  <rule id="182763" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4133 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>