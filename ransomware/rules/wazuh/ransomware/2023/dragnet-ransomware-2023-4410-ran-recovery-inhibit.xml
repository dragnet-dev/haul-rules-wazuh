<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4410 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 048a4eec-51a2-5174-b7d4-f28930005f46 -->
  <rule id="292942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4410 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>