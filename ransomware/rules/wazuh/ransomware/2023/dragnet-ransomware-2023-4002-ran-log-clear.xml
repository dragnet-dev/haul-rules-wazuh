<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4002 — Event Log Clearing (underground) | Status: experimental | Sigma ID: 1fd9b2fd-6a13-5e00-9b4d-b733566be0c5 -->
  <rule id="555247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4002 — Event Log Clearing (underground)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>