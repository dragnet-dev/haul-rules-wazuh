<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4445 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 5ef916dc-019c-5021-b7e8-d50e81eae147 -->
  <rule id="719916" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4445 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>