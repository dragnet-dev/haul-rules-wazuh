<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2787 — Event Log Clearing (malas) | Status: experimental | Sigma ID: b3f54a98-aa62-5086-a217-b0cf021d0f6a -->
  <rule id="317674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2787 — Event Log Clearing (malas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>