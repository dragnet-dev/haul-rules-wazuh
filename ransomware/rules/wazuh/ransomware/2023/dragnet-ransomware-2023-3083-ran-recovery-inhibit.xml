<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3083 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 2db2ca17-8ea8-5a19-b876-c221968df3b0 -->
  <rule id="172074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3083 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>