<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0841 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: cbfae312-21c1-5442-b5f1-1c05a0afc7c0 -->
  <rule id="355023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0841 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>