<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3733 — Recovery Inhibition (play) | Status: experimental | Sigma ID: df41aa49-c36f-5e38-b170-97aa48906f29 -->
  <rule id="419466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3733 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>