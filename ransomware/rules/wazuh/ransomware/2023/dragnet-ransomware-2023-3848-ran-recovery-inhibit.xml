<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3848 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: a978b1cb-c0b8-515e-8f7b-6f845675cd01 -->
  <rule id="956591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3848 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>