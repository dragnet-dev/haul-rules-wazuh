<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3983 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ac0ba40c-06c7-57c9-9103-b849f4958687 -->
  <rule id="905064" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3983 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>