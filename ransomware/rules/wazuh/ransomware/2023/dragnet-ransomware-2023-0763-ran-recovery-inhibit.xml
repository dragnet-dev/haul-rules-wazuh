<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0763 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2dec8089-362d-5242-9872-aa9f427237e9 -->
  <rule id="375680" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0763 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>