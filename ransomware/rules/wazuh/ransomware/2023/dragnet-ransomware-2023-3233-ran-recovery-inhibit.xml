<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3233 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 9678ea89-4e07-5ecd-9909-faa8ebfa05f9 -->
  <rule id="777802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3233 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>