<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3988 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 20c5c5d8-e035-5896-bbf9-851354e509ee -->
  <rule id="514013" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3988 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>