<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2824 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 19e74d6d-e91e-5618-8cb6-10e1a0f2a720 -->
  <rule id="699976" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2824 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>