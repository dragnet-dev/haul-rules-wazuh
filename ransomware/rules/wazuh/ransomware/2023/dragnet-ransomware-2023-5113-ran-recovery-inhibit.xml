<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5113 — Recovery Inhibition (dunghill) | Status: experimental | Sigma ID: 72f9455d-594d-5a2b-bdb7-de79c0f8005c -->
  <rule id="367945" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5113 — Recovery Inhibition (dunghill)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>