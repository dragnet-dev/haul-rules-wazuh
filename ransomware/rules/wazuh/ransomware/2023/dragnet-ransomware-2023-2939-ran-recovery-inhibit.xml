<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2939 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: bb657118-5e38-56dc-a8f2-856091a81825 -->
  <rule id="176571" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2939 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>