<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2987 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e853664e-1c35-5f27-a3e7-c02c513b8d81 -->
  <rule id="685366" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2987 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>