<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3632 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 799c780a-777f-5a87-a026-897d30d447e1 -->
  <rule id="479678" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3632 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>