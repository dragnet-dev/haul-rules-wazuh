<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0010 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 981ff5a5-47b6-50ab-8974-fe20585a0e3e -->
  <rule id="813915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0010 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>