<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0300 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: a89d04fc-9cd7-56fa-b1c5-23d21dca5936 -->
  <rule id="943704" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0300 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>