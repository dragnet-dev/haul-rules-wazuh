<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2849 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: d0a056d5-8bf0-54db-bd93-f986d7174b97 -->
  <rule id="390056" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2849 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>