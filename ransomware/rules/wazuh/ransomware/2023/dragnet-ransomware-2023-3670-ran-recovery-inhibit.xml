<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3670 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 954a3d60-6712-51ef-aca7-24f1f8dd0b22 -->
  <rule id="743901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3670 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>