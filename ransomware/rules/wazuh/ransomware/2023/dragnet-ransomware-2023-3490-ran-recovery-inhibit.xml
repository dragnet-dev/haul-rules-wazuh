<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3490 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5934407c-e49c-518d-8725-f7b9dbcd58cf -->
  <rule id="634407" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3490 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>