<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0798 — Event Log Clearing (medusalocker) | Status: experimental | Sigma ID: 7bbbad4a-3d0e-5a48-805b-b1f256f1f136 -->
  <rule id="108973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0798 — Event Log Clearing (medusalocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>