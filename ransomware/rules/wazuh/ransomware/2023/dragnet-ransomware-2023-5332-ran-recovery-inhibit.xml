<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5332 — Recovery Inhibition (dunghill) | Status: experimental | Sigma ID: 4f4fb2e4-207b-52ac-9e3b-769b6c1c29a7 -->
  <rule id="335152" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5332 — Recovery Inhibition (dunghill)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>