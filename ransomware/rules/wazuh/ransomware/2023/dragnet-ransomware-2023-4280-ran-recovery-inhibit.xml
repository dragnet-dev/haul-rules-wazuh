<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4280 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d4e516f3-a684-5acc-aa29-3378d6c1ba40 -->
  <rule id="458516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4280 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>