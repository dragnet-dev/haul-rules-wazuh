<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2593 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7b286b39-0351-5be4-958c-bb2b73adb96d -->
  <rule id="272587" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2593 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>