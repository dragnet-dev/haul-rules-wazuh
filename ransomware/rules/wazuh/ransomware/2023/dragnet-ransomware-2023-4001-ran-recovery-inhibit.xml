<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4001 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: d69f19a7-0fa9-5316-ab86-64f30acd9de5 -->
  <rule id="491919" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4001 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>