<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5075 — Recovery Inhibition (rancoz) | Status: experimental | Sigma ID: e5ff7f14-6d82-5ddf-bf7d-cbfdbfb75bc6 -->
  <rule id="680127" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5075 — Recovery Inhibition (rancoz)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>