<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2346 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 5a05b206-8ad4-5027-ac2a-5226bf20ec5f -->
  <rule id="640912" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2346 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>