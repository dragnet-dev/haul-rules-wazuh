<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1621 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: defe898d-4d44-55f8-abf1-6772d0153757 -->
  <rule id="408689" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1621 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>