<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2202 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 4ca8a964-7e7d-5691-b382-7b16b3ac12f3 -->
  <rule id="262989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2202 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>