<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4153 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 513f3ff0-8e28-551f-94b6-eac7a9ab35df -->
  <rule id="515743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4153 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>