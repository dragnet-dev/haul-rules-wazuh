<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1790 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 9ad608f9-e776-5ad8-81ac-ad9f750bdab9 -->
  <rule id="777608" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1790 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>