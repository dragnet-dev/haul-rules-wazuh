<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2988 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: f8259743-0693-5330-9cc3-ddbe85ca480a -->
  <rule id="782597" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2988 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>