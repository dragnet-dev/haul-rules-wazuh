<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0603 — Recovery Inhibition (dunghill) | Status: experimental | Sigma ID: f12cb636-2617-5d18-bd56-7b8d7397d2fa -->
  <rule id="372756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0603 — Recovery Inhibition (dunghill)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>