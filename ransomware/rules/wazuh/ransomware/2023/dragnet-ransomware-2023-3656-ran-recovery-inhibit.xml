<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3656 — Recovery Inhibition (moneymessage) | Status: experimental | Sigma ID: 1bd99292-0c97-5450-8160-e3fe673bd9ed -->
  <rule id="959929" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3656 — Recovery Inhibition (moneymessage)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>