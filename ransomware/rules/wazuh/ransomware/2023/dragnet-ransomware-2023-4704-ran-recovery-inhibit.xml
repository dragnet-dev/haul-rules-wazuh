<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4704 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 2e5419c9-aaf4-5701-b2c9-5377f68509dc -->
  <rule id="346716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4704 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>