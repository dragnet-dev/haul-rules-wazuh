<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0737 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 495c8d60-a246-5dcb-841b-5e8217521e1f -->
  <rule id="469261" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0737 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>