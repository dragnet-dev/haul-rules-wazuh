<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3776 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ee6d0ca7-e010-5ff9-b197-dcdcad9778e2 -->
  <rule id="810252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3776 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>