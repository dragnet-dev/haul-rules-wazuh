<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2320 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 30383db1-9d13-5854-8e0b-2138309b7b5f -->
  <rule id="678267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2320 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>