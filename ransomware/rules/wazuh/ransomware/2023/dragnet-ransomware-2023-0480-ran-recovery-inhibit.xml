<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0480 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 68428066-cf18-56dd-a268-90cd65417546 -->
  <rule id="642806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0480 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>