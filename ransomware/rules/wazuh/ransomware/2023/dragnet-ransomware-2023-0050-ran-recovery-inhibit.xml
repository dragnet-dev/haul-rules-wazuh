<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0050 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: fe8d4060-6690-5b92-b1f2-731e1ddb6e82 -->
  <rule id="578140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0050 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>