<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1037 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 810b291c-52a2-537b-9b0f-abe97dbb7a4d -->
  <rule id="497129" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1037 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>