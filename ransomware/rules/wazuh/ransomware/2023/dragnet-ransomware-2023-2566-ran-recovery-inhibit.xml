<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2566 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: e8f19d56-59d3-517a-b860-876e464ee42a -->
  <rule id="313117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2566 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>