<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2616 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: acdcd0ea-f780-5112-b7d1-b36958cb38bb -->
  <rule id="880450" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2616 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>