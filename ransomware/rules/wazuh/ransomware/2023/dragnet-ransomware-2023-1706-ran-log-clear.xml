<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1706 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 475f8628-dc18-5ed8-bc3c-5ccbb9c90940 -->
  <rule id="515862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1706 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>