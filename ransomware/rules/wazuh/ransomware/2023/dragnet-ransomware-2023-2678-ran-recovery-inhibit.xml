<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2678 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 73c3446d-e437-5766-bfad-84196109e4d1 -->
  <rule id="380344" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2678 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>