<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1933 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: ef81106a-5d4d-5c11-a23e-549654736a5a -->
  <rule id="698110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1933 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>