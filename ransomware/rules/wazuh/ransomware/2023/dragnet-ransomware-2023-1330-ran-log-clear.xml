<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1330 — Event Log Clearing (arvinclub) | Status: deprecated | Sigma ID: 112cbff4-73ac-5703-b748-d3e6b3753836 -->
  <rule id="292255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1330 — Event Log Clearing (arvinclub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>