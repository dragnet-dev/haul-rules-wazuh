<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1493 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 823ce2fd-1190-5201-9813-8e74440075ca -->
  <rule id="408942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1493 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>