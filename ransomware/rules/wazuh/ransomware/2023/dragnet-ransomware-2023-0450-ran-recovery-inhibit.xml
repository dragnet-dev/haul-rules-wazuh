<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0450 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: 841e0f30-36cd-502e-96c7-d4f25a01906c -->
  <rule id="455215" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0450 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>