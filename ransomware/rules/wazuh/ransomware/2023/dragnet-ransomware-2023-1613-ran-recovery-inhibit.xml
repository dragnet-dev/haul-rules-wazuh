<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1613 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: b270151f-9828-5bbd-b92c-4f4e314918cc -->
  <rule id="327015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1613 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>