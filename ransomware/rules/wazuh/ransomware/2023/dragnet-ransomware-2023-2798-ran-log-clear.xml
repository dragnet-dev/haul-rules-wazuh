<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2798 — Event Log Clearing (malas) | Status: experimental | Sigma ID: 4c7c89eb-83a3-5dd2-95b1-6e61d1fdbcfa -->
  <rule id="428489" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2798 — Event Log Clearing (malas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>