<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0049 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: f87e5168-eb0b-5b49-ac88-746f44453cd3 -->
  <rule id="840651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0049 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>