<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3058 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7d69e699-c91c-5d8a-a916-c2066a6c2907 -->
  <rule id="311186" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3058 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>