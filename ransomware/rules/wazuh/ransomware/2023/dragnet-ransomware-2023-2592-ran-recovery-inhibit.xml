<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2592 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: b1e73e65-9645-5aa2-8c74-d1563775ccf1 -->
  <rule id="265182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2592 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>