<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3735 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 5285a1df-faa3-5cc0-8be3-da75c3f643ee -->
  <rule id="131229" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3735 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>