<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0803 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: fa74b070-68ce-5cb9-ae55-c0a6ca21821d -->
  <rule id="511950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0803 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>