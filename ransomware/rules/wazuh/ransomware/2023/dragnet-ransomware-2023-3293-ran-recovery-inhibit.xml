<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3293 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: be943549-64fe-5636-9e34-628b6b644fe9 -->
  <rule id="209435" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3293 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>