<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3335 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 435ee02f-66b1-56e3-bae1-eff25a3519dd -->
  <rule id="315980" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3335 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>