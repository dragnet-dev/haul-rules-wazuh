<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0225 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: facef82a-0d0b-561e-8c63-efd9da24b0e3 -->
  <rule id="227311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0225 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>