<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2978 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 016164ea-9c98-5190-a9e9-970e28d08275 -->
  <rule id="638218" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2978 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>