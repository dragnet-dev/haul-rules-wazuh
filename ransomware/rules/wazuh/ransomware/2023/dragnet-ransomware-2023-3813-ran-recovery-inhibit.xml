<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3813 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 0188927a-199a-54eb-8adc-a7557bc851b7 -->
  <rule id="422842" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3813 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>