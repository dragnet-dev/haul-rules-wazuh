<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4966 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: 71b8c06d-c99f-52c1-a6dc-9e39cfdfde41 -->
  <rule id="136600" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4966 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>