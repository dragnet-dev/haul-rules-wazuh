<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0142 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 12276464-dee7-5594-af99-c0adf2bc99c5 -->
  <rule id="427646" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0142 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>