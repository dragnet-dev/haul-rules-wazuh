<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5136 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: d249ddf1-9378-5d07-8799-5133747a255d -->
  <rule id="791965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5136 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>