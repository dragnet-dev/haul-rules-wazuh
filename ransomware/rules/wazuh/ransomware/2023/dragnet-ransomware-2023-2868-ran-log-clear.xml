<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2868 — Event Log Clearing (malas) | Status: experimental | Sigma ID: c4bbae71-f632-59cf-ba9d-ea2e487bf0c2 -->
  <rule id="174510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2868 — Event Log Clearing (malas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>