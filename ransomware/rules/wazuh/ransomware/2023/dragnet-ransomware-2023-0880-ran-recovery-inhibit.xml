<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0880 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ba294a28-2191-58e4-8118-792d677a1a83 -->
  <rule id="380714" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0880 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>