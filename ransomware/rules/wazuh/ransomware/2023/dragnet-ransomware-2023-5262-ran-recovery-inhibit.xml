<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5262 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f32e9cd6-c5dc-5d01-b331-5dccd59a0802 -->
  <rule id="424316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5262 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>