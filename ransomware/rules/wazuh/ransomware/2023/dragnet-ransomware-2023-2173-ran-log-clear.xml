<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2173 — Event Log Clearing (stormous) | Status: experimental | Sigma ID: 6db9eeea-363f-5ba6-99d6-bfed0dfb1be0 -->
  <rule id="995342" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2173 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>