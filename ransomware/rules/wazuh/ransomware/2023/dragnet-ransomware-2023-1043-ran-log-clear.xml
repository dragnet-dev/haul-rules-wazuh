<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1043 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: af0bbfc8-ad52-57b2-8399-9f14a70d11c3 -->
  <rule id="971007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1043 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>