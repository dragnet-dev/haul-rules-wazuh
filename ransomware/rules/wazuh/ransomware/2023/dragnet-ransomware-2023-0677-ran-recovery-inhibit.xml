<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0677 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 179c4fe3-aa53-5f9c-9513-458df07a9255 -->
  <rule id="263838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0677 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>