<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1960 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: d7711884-7999-5fcc-bb26-ed1e3ac7a9c4 -->
  <rule id="577118" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1960 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>