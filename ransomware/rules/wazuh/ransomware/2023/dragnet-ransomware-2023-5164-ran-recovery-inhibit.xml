<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5164 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 4455e191-2060-57f4-9caf-e49513d36712 -->
  <rule id="929419" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5164 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>