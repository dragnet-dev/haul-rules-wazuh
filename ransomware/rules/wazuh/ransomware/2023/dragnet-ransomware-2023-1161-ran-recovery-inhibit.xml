<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1161 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e515fea3-ac64-53b4-af86-e7ffa34cefcc -->
  <rule id="216094" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1161 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>