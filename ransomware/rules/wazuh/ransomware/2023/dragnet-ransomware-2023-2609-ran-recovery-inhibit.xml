<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2609 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 48ee9358-c2cb-5b5b-a46c-b7f21acd91cd -->
  <rule id="452693" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2609 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>