<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0200 — Event Log Clearing (stormous) | Status: deprecated | Sigma ID: 7e4744ac-f1cc-5233-a2eb-c6bf73922c08 -->
  <rule id="464744" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0200 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>