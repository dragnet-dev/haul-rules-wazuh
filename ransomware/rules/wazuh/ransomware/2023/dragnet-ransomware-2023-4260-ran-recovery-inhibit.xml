<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4260 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f5b946fc-1493-5c93-a52c-144f043f71a0 -->
  <rule id="791946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4260 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>