<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5097 — Recovery Inhibition (mallox) | Status: experimental | Sigma ID: 93889842-f118-5f22-af42-265f8103f218 -->
  <rule id="488984" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5097 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>