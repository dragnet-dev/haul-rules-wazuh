<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3167 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 73af1efe-bd45-54cf-8cc2-672c61d49e69 -->
  <rule id="418110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3167 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>