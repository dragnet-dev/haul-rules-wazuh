<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5057 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: bf426e3f-c626-53ee-be78-36566c776c09 -->
  <rule id="462830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5057 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>