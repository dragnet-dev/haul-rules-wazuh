<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1602 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: d7ecb605-a7b1-59e3-ace9-a0c69a117170 -->
  <rule id="349396" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1602 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>