<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1256 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 977b5dd1-91dd-5a7c-9a68-edda72728c8e -->
  <rule id="802973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1256 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>