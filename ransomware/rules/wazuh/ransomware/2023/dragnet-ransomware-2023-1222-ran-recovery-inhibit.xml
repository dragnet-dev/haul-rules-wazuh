<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1222 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 82e64d6e-ebc5-5808-8e88-eeef1c395cf3 -->
  <rule id="422637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1222 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>