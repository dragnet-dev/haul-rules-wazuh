<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3705 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: c4452c72-4439-56b0-a067-335a5fdb2744 -->
  <rule id="291244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3705 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>