<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0510 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: efc285cb-37e9-5241-90a9-ecdfa4097716 -->
  <rule id="336285" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0510 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>