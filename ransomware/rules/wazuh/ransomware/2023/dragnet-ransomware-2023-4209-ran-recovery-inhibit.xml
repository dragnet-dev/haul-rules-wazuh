<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4209 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 4d6d8a9f-1235-5bcd-a661-a14b80111683 -->
  <rule id="288778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4209 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>