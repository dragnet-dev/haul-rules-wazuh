<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2048 — Event Log Clearing (medusalocker) | Status: experimental | Sigma ID: cadc638e-d3a8-5cc8-84ab-ec250513cc68 -->
  <rule id="793263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2048 — Event Log Clearing (medusalocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>