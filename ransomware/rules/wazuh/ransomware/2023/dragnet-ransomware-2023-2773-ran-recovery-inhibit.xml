<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2773 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 30d54366-433b-5098-89a2-b2fff51cc640 -->
  <rule id="535436" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2773 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>