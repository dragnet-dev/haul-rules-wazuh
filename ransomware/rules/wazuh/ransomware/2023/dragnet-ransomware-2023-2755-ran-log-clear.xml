<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2755 — Event Log Clearing (malas) | Status: experimental | Sigma ID: 762c4c2f-513a-5d1c-8777-08fcc32861e3 -->
  <rule id="252716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2755 — Event Log Clearing (malas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>