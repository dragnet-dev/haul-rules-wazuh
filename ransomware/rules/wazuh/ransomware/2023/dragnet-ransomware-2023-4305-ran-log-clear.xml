<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4305 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: a94af5fd-e5c5-562a-9296-968a30c072b3 -->
  <rule id="202395" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4305 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>