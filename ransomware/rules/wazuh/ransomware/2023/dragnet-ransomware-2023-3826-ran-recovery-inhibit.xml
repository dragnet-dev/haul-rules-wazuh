<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3826 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: f012abcb-b7a6-56d3-bd2f-ef12846010a0 -->
  <rule id="343243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3826 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
