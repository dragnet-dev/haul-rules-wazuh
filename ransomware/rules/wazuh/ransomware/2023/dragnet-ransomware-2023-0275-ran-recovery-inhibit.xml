<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0275 — Recovery Inhibition (toufan) | Status: deprecated | Sigma ID: f5d54dc4-6a94-5e30-b328-62048cca7bc8 -->
  <rule id="489677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0275 — Recovery Inhibition (toufan)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
