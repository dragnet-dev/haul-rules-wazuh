<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3363 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 4a3c7ecd-32dd-579d-8675-466ce2d7d46b -->
  <rule id="204126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3363 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>