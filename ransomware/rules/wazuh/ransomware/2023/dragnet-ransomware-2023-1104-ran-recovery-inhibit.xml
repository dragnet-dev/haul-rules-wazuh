<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1104 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 38973406-ed4e-5b5f-b084-7313f76a63bd -->
  <rule id="397340" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1104 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>