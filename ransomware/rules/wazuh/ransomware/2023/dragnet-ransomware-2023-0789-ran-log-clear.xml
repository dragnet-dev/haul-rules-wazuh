<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0789 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 81a4bdc2-7cfd-5d4f-af05-61f3fbea514c -->
  <rule id="744573" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0789 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>