<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3408 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: c3f91afe-b210-54a0-a27e-452f67bee2da -->
  <rule id="574266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3408 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>