<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2598 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 71ce4623-991c-51fe-a5dc-9d7dd21a9368 -->
  <rule id="138246" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2598 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>