<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0648 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 32de6291-7035-5cd2-9d2a-8e3998b5d924 -->
  <rule id="414629" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0648 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>