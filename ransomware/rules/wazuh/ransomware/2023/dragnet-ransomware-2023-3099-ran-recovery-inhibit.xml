<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3099 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8dc0f222-bcec-5162-8a46-5baead7a9264 -->
  <rule id="128952" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3099 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>