<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4923 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 406e3f98-52b2-5ddb-a3ac-4ec952e293f0 -->
  <rule id="241663" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4923 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>