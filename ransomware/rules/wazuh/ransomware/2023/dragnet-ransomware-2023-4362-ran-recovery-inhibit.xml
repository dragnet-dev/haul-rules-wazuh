<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4362 — Recovery Inhibition (darkpower) | Status: experimental | Sigma ID: 46ff5306-727e-509a-9850-5defb4f2c35b -->
  <rule id="403153" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4362 — Recovery Inhibition (darkpower)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>