<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4725 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: de3b4e63-6802-58bb-a7c2-85001d1e55fa -->
  <rule id="392718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4725 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>