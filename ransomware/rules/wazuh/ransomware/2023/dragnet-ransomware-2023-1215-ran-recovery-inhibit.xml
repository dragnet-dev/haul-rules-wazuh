<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1215 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 0091496c-5671-5055-9219-5018742755ad -->
  <rule id="663948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1215 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>