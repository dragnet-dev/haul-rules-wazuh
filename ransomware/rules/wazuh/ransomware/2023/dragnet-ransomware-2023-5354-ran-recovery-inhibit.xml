<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5354 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 39066f39-9b99-5cd2-8c92-b39e5334b877 -->
  <rule id="950713" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5354 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>