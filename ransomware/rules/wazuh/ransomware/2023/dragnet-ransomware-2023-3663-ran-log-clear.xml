<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3663 — Event Log Clearing (werewolves) | Status: experimental | Sigma ID: 5f97f3a4-8283-5eb2-8513-afa193e4191c -->
  <rule id="735673" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3663 — Event Log Clearing (werewolves)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>