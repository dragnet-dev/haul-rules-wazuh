<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3947 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 185c19d8-0fc6-51f0-994b-cd2d78d16593 -->
  <rule id="355517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3947 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>