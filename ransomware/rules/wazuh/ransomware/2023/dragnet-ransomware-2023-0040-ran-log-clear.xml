<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0040 — Event Log Clearing (toufan) | Status: deprecated | Sigma ID: a5e8c8e3-9dc0-50f9-9a6e-2abf5ac23f28 -->
  <rule id="111808" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0040 — Event Log Clearing (toufan)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>