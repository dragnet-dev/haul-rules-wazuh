<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0255 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4141474e-d351-5795-8d3f-568feaa279c3 -->
  <rule id="641474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0255 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>