<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4534 — Recovery Inhibition (play) | Status: experimental | Sigma ID: be726379-b05c-5dbc-aeb8-1cdc87ade84a -->
  <rule id="207263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4534 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>