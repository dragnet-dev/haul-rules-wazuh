<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1017 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: b6f2f704-5543-57cb-9100-b2b94f07668e -->
  <rule id="394077" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1017 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>