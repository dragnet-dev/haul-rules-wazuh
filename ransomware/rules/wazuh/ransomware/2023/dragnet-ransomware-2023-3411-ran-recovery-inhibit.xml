<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3411 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 12b3e5cc-4c63-5880-89d4-f2dc62ffc496 -->
  <rule id="806812" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3411 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>