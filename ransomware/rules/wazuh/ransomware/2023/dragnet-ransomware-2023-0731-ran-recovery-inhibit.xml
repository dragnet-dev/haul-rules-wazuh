<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0731 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 4b91a4e6-49da-5783-8965-2fe3bef85cc7 -->
  <rule id="414664" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0731 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>