<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4925 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: e1a5d335-9d18-5913-bc28-f7358a75b90d -->
  <rule id="126533" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4925 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>