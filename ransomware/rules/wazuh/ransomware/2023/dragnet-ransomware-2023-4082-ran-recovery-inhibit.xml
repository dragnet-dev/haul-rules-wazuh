<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4082 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2d819e72-b529-5614-b5f6-91b605b401ef -->
  <rule id="231187" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4082 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>