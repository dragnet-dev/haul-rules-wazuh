<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2165 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 495be64a-7186-5415-ad90-8a56bb78199d -->
  <rule id="469106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2165 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>