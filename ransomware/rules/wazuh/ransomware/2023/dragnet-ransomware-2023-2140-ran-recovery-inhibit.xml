<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2140 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f5bda034-a0ff-50ea-8c51-cb9248cf0ae3 -->
  <rule id="179140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2140 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>