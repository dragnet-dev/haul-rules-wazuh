<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1237 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f99efc72-7fcf-5f73-8686-5c277bce79b4 -->
  <rule id="353340" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1237 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>