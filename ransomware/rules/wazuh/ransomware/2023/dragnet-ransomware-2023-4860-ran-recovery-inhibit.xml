<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4860 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 53eaf9af-e319-5d28-8ef2-8b8224ce3908 -->
  <rule id="508479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4860 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>