<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3275 — Recovery Inhibition (toufan) | Status: deprecated | Sigma ID: 27724d3a-75ee-58a4-a147-5cc21b27d427 -->
  <rule id="935973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3275 — Recovery Inhibition (toufan)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>