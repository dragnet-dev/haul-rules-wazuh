<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0278 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: a26921e6-41d9-5f3d-bb6c-8e4bc7e019ee -->
  <rule id="226921" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0278 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>