<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2380 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 7f5450fa-bdb9-5545-8956-9dd91ecc738e -->
  <rule id="475450" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2380 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>