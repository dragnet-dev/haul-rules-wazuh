<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4851 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: c9fbfcd0-cb1c-5a32-b6b3-7ba6e814f0e1 -->
  <rule id="518652" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4851 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>