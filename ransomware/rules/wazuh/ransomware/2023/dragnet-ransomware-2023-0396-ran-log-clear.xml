<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0396 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 629fb23b-db9e-57f2-bed9-4e3e5adce9b7 -->
  <rule id="812752" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0396 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>