<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4850 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: d1dc98b5-b297-5a4c-8338-91cf22ddc82e -->
  <rule id="775698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4850 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>