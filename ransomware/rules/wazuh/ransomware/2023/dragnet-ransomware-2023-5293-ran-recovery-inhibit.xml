<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5293 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3819a2aa-7732-58b8-bfb9-0719bb067a3d -->
  <rule id="878282" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5293 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>