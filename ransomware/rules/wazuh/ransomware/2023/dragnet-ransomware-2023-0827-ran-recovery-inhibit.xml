<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0827 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a337a644-b88d-53ca-a06d-9703e4857d98 -->
  <rule id="854026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0827 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>