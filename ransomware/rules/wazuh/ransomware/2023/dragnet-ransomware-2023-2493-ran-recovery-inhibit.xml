<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2493 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7cd268d0-5eee-5b8d-ae60-79e8af3e7eb8 -->
  <rule id="297268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2493 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>