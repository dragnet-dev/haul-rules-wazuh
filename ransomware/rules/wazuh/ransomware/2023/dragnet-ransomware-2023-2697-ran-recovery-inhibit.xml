<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2697 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 52000b3c-ea10-5bb3-8ffc-0950aff068d3 -->
  <rule id="320113" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2697 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>