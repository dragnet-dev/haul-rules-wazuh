<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1040 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e92b749a-11af-5b34-97dd-bcefa0d40931 -->
  <rule id="688374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1040 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>