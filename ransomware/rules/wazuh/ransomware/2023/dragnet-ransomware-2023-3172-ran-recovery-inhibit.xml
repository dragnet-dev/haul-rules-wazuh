<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3172 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 15bb3e75-d944-5407-a4b7-1729e4380968 -->
  <rule id="243827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3172 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>