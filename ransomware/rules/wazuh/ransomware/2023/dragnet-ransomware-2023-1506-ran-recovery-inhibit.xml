<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1506 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e4988fad-6f8f-5abf-b75d-5448f709e7ec -->
  <rule id="619823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1506 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>