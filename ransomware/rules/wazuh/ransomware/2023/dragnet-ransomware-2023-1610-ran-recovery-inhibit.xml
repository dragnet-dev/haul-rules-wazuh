<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1610 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 65816b5d-294b-597b-9a93-d3451169d72c -->
  <rule id="253067" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1610 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>