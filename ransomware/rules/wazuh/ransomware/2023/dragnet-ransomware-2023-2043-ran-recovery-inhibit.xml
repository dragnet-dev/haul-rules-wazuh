<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2043 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 1b27b4d3-7e9a-54f8-9668-c7d2df5a99d4 -->
  <rule id="782957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2043 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
