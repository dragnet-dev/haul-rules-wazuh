<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2834 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: d5065325-ad42-5925-a509-cb87b8466136 -->
  <rule id="550653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2834 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>