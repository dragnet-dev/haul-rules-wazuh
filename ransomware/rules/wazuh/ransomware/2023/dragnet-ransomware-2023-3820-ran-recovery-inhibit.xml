<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3820 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 0d7284ca-269b-52b5-a0f9-a1f397bb6081 -->
  <rule id="496556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3820 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>