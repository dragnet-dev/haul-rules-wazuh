<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2873 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 53c47879-83b8-5110-9b38-2f388192279b -->
  <rule id="604787" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2873 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>