<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2012 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: fef8f8fb-06cb-5c70-9ff9-6013ae05516c -->
  <rule id="327838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2012 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>