<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4567 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: cc910c90-6de2-570c-8ddd-ad550aad82b5 -->
  <rule id="678572" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4567 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>