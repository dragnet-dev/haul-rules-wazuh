<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3558 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 002df38b-ad08-516e-a2f3-5b19182a8015 -->
  <rule id="376619" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3558 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>