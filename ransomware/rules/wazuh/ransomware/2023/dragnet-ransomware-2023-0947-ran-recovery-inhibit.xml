<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0947 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 5886cc82-1c92-5f71-83a7-5c0b735dfc73 -->
  <rule id="707020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0947 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>