<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2001 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 2242e252-9956-5fb1-89b6-5a586bd125de -->
  <rule id="988625" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2001 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>