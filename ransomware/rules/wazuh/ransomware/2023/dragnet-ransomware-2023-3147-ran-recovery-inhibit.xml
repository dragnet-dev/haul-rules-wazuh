<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3147 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: fd17f1f7-8a41-5723-ab2d-7ca04bc74117 -->
  <rule id="550871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3147 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>