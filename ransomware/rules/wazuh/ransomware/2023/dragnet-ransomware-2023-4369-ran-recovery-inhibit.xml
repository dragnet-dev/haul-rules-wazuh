<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4369 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: d54a8520-18b9-51ec-a461-0269f6644170 -->
  <rule id="467485" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4369 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>