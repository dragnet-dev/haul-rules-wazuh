<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1877 — Event Log Clearing (donutleaks) | Status: experimental | Sigma ID: b0bcaec2-4c43-595a-a01c-f42a335d5ce5 -->
  <rule id="157262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1877 — Event Log Clearing (donutleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>