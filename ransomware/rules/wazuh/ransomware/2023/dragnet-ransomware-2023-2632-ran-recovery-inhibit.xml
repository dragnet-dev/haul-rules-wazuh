<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2632 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: bc4ea4f8-1d88-569c-928c-78ce303ef14d -->
  <rule id="425384" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2632 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>