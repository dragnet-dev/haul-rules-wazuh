<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2215 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: 2d0b23bc-d334-5590-8784-3d94697bdccd -->
  <rule id="837979" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2215 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>