<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1151 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 74fba8c4-8b78-5c78-8fa7-7f042afbc700 -->
  <rule id="471308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1151 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>