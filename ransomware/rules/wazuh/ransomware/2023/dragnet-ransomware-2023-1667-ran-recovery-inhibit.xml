<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1667 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: ee3a8716-e838-50b2-843f-8ef8ce355fe2 -->
  <rule id="313887" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1667 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>