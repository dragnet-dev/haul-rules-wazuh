<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1997 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: 2c785df1-1362-54d5-9556-a2667e94be38 -->
  <rule id="765183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1997 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>