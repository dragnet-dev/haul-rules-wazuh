<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0628 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 5c19a468-cb54-5579-88a0-0c976c969f4f -->
  <rule id="675144" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0628 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>