<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0904 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 8d0fc460-0a1c-5868-a205-a1abc1d1d2f5 -->
  <rule id="112124" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0904 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>