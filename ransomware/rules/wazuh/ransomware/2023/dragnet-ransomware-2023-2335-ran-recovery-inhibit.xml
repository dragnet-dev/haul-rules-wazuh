<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2335 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: fc57e799-b8fc-50ee-84f3-59a59f266e41 -->
  <rule id="541267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2335 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>