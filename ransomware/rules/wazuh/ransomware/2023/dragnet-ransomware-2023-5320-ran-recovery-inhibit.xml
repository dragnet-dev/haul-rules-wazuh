<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5320 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 998dac7a-e6a3-5a82-a89f-f395c0484287 -->
  <rule id="591308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5320 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>