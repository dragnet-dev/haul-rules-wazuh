<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1634 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: af7c0674-95c4-53db-a676-a71a26b414d8 -->
  <rule id="212406" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1634 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>