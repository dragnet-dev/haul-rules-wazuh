<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3307 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 38c2aafd-b15a-571a-8e07-59b401070c04 -->
  <rule id="787882" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3307 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>