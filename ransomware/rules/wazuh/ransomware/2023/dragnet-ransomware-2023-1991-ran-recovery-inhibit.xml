<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1991 — Recovery Inhibition (siegedsec) | Status: experimental | Sigma ID: ce8dc714-db94-5a1f-92c5-10d6653c1af9 -->
  <rule id="896287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1991 — Recovery Inhibition (siegedsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>