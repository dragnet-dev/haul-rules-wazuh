<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0153 — Recovery Inhibition (noname) | Status: experimental | Sigma ID: 4497a6f1-6ceb-5090-a6bc-3318399244f0 -->
  <rule id="814031" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0153 — Recovery Inhibition (noname)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>