<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2847 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 87d451cf-6611-57bf-ae16-8b2b02772bc6 -->
  <rule id="605451" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2847 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>