<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5312 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: df052a43-58de-5f65-855a-ce92823a59e4 -->
  <rule id="968842" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5312 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>