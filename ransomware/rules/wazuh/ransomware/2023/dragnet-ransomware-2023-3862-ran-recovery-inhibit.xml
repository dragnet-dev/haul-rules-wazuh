<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3862 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: 49f264c0-ffe2-5771-94c9-c05c75b50731 -->
  <rule id="288236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3862 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>