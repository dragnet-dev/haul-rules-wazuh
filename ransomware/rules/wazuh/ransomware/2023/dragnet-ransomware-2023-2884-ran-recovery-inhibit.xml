<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2884 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: a00ca8dd-512c-5560-9e66-e390489d8d7c -->
  <rule id="862028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2884 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>