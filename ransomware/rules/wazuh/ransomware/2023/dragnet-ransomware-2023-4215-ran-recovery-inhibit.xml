<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4215 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: d7bfe3da-7904-58d0-808b-b5068bca2cae -->
  <rule id="342223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4215 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>