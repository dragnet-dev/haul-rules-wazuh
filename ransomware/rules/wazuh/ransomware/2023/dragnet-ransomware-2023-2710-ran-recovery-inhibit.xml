<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2710 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: c19aedd9-3c93-5fd4-b85b-db500335f19e -->
  <rule id="595821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2710 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>