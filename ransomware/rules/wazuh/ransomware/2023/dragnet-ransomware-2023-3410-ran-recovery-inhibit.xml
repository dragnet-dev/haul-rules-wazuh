<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3410 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 2fd50b85-2c32-5ac3-a873-e84d5c30d01f -->
  <rule id="424811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3410 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>