<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0503 — Event Log Clearing (rhysida) | Status: experimental | Sigma ID: f830064b-1b0d-5a6e-9ecd-d83abb4c0c2e -->
  <rule id="783006" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0503 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>