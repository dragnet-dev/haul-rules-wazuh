<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3245 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: da195bb6-eb1b-5ac3-a774-1383948eaa11 -->
  <rule id="891131" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3245 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>