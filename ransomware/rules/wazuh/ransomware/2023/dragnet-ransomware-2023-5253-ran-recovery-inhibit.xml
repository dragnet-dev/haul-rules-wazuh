<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5253 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e2760a74-8e8b-5d57-ae73-3343e2950724 -->
  <rule id="584170" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5253 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>