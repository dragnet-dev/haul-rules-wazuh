<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3194 — Event Log Clearing (losttrust) | Status: deprecated | Sigma ID: 3074eca2-6d81-5f0d-9160-0d0bdc6e818f -->
  <rule id="994890" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3194 — Event Log Clearing (losttrust)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>