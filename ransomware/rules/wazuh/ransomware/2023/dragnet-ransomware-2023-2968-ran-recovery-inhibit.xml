<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2968 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 4dadcb42-5560-5a06-a1f5-9f68612faea3 -->
  <rule id="690763" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2968 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>