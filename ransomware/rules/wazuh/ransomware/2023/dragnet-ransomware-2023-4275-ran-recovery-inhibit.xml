<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4275 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0158c4b6-0823-5c09-912d-21fce44a7553 -->
  <rule id="564756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4275 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>