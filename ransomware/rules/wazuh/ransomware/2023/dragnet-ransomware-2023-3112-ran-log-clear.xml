<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3112 — Event Log Clearing (moneymessage) | Status: deprecated | Sigma ID: d6e2df8b-b132-5422-b8be-6ed1cf4a1609 -->
  <rule id="307135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3112 — Event Log Clearing (moneymessage)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>