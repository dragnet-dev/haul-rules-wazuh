<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3824 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: aebae295-1813-5e8c-9826-966714053999 -->
  <rule id="956942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3824 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>