<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3711 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 69ca98f9-2e76-5a9d-8067-3b63a34f1eae -->
  <rule id="986698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3711 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>