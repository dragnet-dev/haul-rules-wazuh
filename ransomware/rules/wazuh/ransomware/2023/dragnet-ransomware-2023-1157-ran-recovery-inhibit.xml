<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1157 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ffade420-49d0-5856-add7-07d594e6be14 -->
  <rule id="247262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1157 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>