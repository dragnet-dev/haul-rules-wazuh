<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0435 — Event Log Clearing (ransomhouse) | Status: deprecated | Sigma ID: 6afa49c1-1ab3-5bc8-83a8-d0160b654adf -->
  <rule id="138649" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0435 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>