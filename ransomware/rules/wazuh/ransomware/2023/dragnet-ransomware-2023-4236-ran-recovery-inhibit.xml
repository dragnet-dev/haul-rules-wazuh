<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4236 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 28e7245a-50d4-5f25-8c9c-95a120268ab6 -->
  <rule id="227245" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4236 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>