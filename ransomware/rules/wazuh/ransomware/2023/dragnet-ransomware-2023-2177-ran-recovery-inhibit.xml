<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2177 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 6996eb9d-e0fd-509d-a0c6-7ea277c8a3eb -->
  <rule id="991211" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2177 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>