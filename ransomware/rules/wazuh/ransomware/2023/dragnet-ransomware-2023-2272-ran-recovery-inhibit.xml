<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2272 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 00d6e23a-c562-5d43-82a2-d0a0b8033a2d -->
  <rule id="904378" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2272 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
