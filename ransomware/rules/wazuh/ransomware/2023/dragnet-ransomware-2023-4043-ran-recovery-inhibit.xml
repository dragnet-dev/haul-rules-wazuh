<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4043 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 791cd2a6-4286-5bd5-ac97-825b89da6d95 -->
  <rule id="327012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4043 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>