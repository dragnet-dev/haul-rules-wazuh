<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1447 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6649b346-e050-5a8d-a8f9-38e5861a15ee -->
  <rule id="263953" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1447 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>