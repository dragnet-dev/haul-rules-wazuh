<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1397 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ee7ded95-a04d-5d39-8ea9-6f2e822d5f72 -->
  <rule id="880717" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1397 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>