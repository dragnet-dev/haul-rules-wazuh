<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3707 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 1ca03014-d891-5d6e-b006-aec2ea17ee5c -->
  <rule id="180301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3707 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>