<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2791 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 503420d5-ca6a-5563-b75f-a25702cf9ed2 -->
  <rule id="954733" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2791 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>