<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1301 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 3ef9248b-70f4-52c1-a083-a1b793715d47 -->
  <rule id="207924" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1301 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>