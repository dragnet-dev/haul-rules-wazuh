<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0739 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 22505a02-d33c-50c4-845d-f1ee039d5302 -->
  <rule id="100900" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0739 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>