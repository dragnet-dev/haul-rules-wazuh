<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4086 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 0b22f9c7-8131-5783-accf-7fedba426498 -->
  <rule id="274876" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4086 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>