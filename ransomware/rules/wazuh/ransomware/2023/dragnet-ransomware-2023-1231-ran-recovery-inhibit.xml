<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1231 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 6be3a776-ee3f-539b-8b27-544b7c07b3ef -->
  <rule id="162187" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1231 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>