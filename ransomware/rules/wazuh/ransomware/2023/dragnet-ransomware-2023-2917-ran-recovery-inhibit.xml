<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2917 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: cbc483eb-159b-5ca5-afad-a51ae242acc3 -->
  <rule id="660483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2917 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>