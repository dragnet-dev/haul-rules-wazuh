<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2509 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 33bba6ad-b5a2-505b-a03a-86f343389c9a -->
  <rule id="581706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2509 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>