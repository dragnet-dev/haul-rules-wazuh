<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3816 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 5f520b4b-1ce4-571c-ab53-0d17ed4248ca -->
  <rule id="728331" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3816 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>