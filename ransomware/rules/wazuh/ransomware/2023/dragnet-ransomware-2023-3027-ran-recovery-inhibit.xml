<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3027 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9eb6ce92-1500-5ded-b7af-dee6d4006b3f -->
  <rule id="301582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3027 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>