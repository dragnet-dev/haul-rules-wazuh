<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0946 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: d4311f96-4d83-5807-acc1-371a018699f6 -->
  <rule id="448991" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0946 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>