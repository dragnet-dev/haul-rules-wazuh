<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0864 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 4c3e3548-c5f3-57bd-87ea-6fffad4f3f07 -->
  <rule id="422235" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0864 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>