<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0877 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 2218fc8f-4c7d-55e7-a004-a7d5f3536d8a -->
  <rule id="380608" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0877 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>