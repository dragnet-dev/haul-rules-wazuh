<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2398 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ad5f42ed-015e-51ac-b466-6e1ce425e18f -->
  <rule id="177542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2398 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>