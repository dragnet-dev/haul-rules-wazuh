<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2352 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f171d3c5-bae2-521c-a8ed-a31ac2bc9e5a -->
  <rule id="727493" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2352 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>