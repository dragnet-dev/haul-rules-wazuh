<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4414 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 6a021e62-3e4e-5b20-a2c2-ea9c6cccf41a -->
  <rule id="896350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4414 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>