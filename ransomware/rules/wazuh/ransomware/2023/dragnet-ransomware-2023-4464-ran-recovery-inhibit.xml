<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4464 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 0911fe15-5a5a-5845-8486-6b27ee13e74f -->
  <rule id="634701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4464 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>