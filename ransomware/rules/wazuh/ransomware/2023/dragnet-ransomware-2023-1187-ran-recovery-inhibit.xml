<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1187 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3dd38e99-5cbc-515d-9704-d015cd682c1c -->
  <rule id="783022" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1187 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>