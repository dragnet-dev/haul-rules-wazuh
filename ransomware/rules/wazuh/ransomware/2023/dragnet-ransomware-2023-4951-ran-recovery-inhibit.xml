<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4951 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9fc16f3f-5093-5819-af10-a127f58ff5cf -->
  <rule id="589871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4951 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>