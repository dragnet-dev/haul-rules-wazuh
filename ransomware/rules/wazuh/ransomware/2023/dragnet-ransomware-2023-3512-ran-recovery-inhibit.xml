<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3512 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 0618a76b-803d-51f9-8783-fcefc336ff38 -->
  <rule id="638027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3512 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>