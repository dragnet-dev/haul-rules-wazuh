<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3946 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: c0fc3663-005f-59da-814b-b1571dd90fda -->
  <rule id="497236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3946 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
