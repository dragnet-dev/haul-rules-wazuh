<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1878 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: 9e73a10b-f319-5032-bec0-ad0f25d28e86 -->
  <rule id="839781" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1878 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>