<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3441 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: b47c0951-73d9-5c17-9aa8-82fc697a2d9f -->
  <rule id="136409" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3441 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>