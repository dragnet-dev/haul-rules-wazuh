<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0979 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 61e20ecd-526a-5978-8b0b-334f2353363b -->
  <rule id="784334" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0979 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>