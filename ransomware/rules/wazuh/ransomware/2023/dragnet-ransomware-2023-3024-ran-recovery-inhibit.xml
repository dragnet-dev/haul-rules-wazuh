<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3024 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: aa18ba7c-9ea0-5838-80a6-e775b494df7a -->
  <rule id="856794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3024 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>