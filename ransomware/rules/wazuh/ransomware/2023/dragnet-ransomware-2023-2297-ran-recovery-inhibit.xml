<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2297 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: aba83022-ff35-53d8-900e-9b75571ab140 -->
  <rule id="146830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2297 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>