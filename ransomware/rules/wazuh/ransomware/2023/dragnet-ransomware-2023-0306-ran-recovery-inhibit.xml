<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0306 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: ec310dff-4851-54c4-9aa9-76da9f7db948 -->
  <rule id="280973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0306 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>