<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3102 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ae0dac73-710c-5559-ba3c-64ad09ecb45c -->
  <rule id="930540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3102 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>