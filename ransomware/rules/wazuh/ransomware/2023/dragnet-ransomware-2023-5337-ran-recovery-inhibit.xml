<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5337 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 1e0c100c-e304-527f-ab42-a5fd361d4c3d -->
  <rule id="412100" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5337 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>