<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3480 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ab1f2668-55ff-58fc-b895-b779ddc7838e -->
  <rule id="139126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3480 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>