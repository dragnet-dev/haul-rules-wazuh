<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4833 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 7f63513f-0395-53d6-abfd-792c08d812f8 -->
  <rule id="476351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4833 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>