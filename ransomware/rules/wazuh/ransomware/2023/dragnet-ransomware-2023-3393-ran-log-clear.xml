<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3393 — Event Log Clearing (royal) | Status: deprecated | Sigma ID: a88fbe6b-7447-5a66-ad21-cf3e7325e6a6 -->
  <rule id="960478" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3393 — Event Log Clearing (royal)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>