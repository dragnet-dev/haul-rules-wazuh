<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4500 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: bd72a17b-8588-58ad-b7d7-5cf3f845263c -->
  <rule id="435621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4500 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>