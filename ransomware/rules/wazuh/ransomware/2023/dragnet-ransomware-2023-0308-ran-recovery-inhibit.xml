<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0308 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3134ff8c-5f54-5c81-a002-f2bf3dc40c31 -->
  <rule id="925598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0308 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>