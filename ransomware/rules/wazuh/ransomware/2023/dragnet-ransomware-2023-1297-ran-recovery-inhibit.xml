<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1297 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 198b36ed-d8af-5f6c-bd9b-d5fc47462e75 -->
  <rule id="686990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1297 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>