<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2688 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ad65de17-a57f-5cca-88af-3284e6267935 -->
  <rule id="945662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2688 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>