<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0253 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: bd8a78a1-2c9f-5027-9bcc-694fe2b3ac17 -->
  <rule id="437878" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0253 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>