<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1035 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c7d41ec6-9695-5544-8d35-8e7ee46c04bd -->
  <rule id="672670" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1035 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>