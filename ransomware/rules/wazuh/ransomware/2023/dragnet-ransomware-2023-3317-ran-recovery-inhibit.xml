<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3317 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 860b32c7-b230-5585-923b-640fa5902f4d -->
  <rule id="577132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3317 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>