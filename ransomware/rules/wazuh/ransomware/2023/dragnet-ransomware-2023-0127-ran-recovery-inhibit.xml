<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0127 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 672fe293-3ec1-5b6c-8123-11e8c033f371 -->
  <rule id="922862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0127 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>