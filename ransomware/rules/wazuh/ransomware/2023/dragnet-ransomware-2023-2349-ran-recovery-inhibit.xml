<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2349 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: ad185844-7d74-5e2e-9c34-adf92bba3a9a -->
  <rule id="931858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2349 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>