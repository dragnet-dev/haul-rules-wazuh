<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2645 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: ec115cc0-905b-5395-a582-4144afda121d -->
  <rule id="277852" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2645 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>