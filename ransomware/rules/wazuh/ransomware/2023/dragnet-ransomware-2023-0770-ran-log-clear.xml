<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0770 — Event Log Clearing (royal) | Status: experimental | Sigma ID: 591b26e4-a0a9-5cb4-a0c8-068ade4b0ebf -->
  <rule id="847630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0770 — Event Log Clearing (royal)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>