<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5031 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 83821e9d-054c-5591-9bdb-0bbef6478f39 -->
  <rule id="541150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5031 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>