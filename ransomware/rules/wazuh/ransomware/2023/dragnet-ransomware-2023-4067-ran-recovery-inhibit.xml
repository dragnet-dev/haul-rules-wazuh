<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4067 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 179b67d8-7f59-5565-afb4-757825553511 -->
  <rule id="201085" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4067 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>