<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1943 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: feaac9c6-9309-519e-98a6-38fe8ea9f6ef -->
  <rule id="243116" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1943 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>