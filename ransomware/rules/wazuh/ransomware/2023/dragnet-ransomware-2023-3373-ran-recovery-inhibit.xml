<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3373 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: c9e2628c-b4b3-55d1-b19b-256da5be1165 -->
  <rule id="378262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3373 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>