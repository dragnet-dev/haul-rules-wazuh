<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3717 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: dec24521-f794-5762-85b8-7ed31077d00a -->
  <rule id="964245" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3717 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>