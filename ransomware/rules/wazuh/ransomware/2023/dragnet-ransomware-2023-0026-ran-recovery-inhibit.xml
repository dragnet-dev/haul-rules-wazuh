<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0026 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: b353c3a7-5e8f-5f58-bb03-96feffe42e20 -->
  <rule id="116603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0026 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>