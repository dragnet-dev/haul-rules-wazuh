<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4451 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: bb8fb810-b439-5c1f-ad55-a43808c4a1e4 -->
  <rule id="410198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4451 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>