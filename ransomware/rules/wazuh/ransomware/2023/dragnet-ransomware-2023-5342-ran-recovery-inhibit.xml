<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5342 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: a7aa0b3b-50b1-5b3a-9c74-afadeaab5c1a -->
  <rule id="909931" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5342 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>