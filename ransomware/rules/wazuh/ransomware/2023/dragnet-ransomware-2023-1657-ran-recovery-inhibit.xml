<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1657 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 4b076807-7376-5350-a7bf-91fb3cdafcae -->
  <rule id="407680" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1657 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>