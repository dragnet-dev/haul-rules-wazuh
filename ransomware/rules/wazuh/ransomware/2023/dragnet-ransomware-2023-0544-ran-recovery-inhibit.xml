<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0544 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ea5a3157-01e2-5379-8163-078207dbb6d7 -->
  <rule id="253031" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0544 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>