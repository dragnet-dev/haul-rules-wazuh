<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5151 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 5be67c56-2b81-54e6-9c34-14effdb314f5 -->
  <rule id="653084" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5151 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>