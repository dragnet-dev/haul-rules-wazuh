<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2197 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: e4e7c72d-0272-5f49-8ef8-f3958beb17d7 -->
  <rule id="210047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2197 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>