<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2868 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 7c64ae33-b0b0-5521-b9c2-cc4afc01b989 -->
  <rule id="590958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2868 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>