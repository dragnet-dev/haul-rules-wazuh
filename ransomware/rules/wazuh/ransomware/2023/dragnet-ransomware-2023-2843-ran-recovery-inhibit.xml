<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2843 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 2739a040-bc7b-5d59-b2ea-35879593548a -->
  <rule id="883404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2843 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>