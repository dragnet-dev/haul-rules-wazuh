<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3786 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: d6baca01-2272-569b-8165-f93a7dc5e5b2 -->
  <rule id="960714" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3786 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>