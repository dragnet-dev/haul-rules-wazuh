<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5373 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: d23db8ad-c8b7-5a0d-a05a-f6b84136b5c8 -->
  <rule id="789078" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5373 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>