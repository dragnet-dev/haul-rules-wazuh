<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3941 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: fd8bd194-1f69-5f5f-8036-26400154439e -->
  <rule id="299171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3941 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>