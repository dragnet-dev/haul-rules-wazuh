<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4986 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7666ff44-5f01-5da4-9042-db90776bd6c5 -->
  <rule id="262751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4986 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>