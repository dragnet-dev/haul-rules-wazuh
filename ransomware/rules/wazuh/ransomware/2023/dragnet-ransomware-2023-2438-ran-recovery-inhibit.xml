<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2438 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5a28e878-fb6b-51cd-bb59-50c3d6bdd431 -->
  <rule id="644628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2438 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>