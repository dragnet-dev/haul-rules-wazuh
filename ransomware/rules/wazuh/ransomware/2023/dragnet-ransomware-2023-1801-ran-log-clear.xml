<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1801 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 636f1f0f-2ced-5d59-9cd0-0fff7d30af2e -->
  <rule id="830591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1801 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>