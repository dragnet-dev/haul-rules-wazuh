<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1245 — Recovery Inhibition (toufan) | Status: deprecated | Sigma ID: 35515657-3cb8-5ede-918c-7a461d4232f2 -->
  <rule id="951565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1245 — Recovery Inhibition (toufan)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>