<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5337 — Event Log Clearing (stormous) | Status: experimental | Sigma ID: 4b4c1b9e-3ca0-5ef5-9966-f5cfb99c8320 -->
  <rule id="232187" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5337 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>