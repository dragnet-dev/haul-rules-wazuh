<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5370 — Recovery Inhibition (cryptbb) | Status: experimental | Sigma ID: e55417ee-8e35-552b-a024-c4266355dca6 -->
  <rule id="655417" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5370 — Recovery Inhibition (cryptbb)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>