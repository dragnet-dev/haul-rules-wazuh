<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0165 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: edd7ee18-6409-5a83-ae15-eda8642933f0 -->
  <rule id="842830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0165 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>