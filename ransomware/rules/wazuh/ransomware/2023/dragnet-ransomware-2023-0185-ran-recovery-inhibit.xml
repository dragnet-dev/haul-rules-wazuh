<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0185 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: f15dde57-6e42-5ed8-9c97-8b8692cc199a -->
  <rule id="908990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0185 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>