<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0029 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 61f17d68-e35e-5668-a53b-33a66c0e14d9 -->
  <rule id="785885" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0029 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>