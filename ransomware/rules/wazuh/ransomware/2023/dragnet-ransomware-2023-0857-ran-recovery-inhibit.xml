<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0857 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 30c7dd4e-9bb6-5a74-b03f-df4402c7beda -->
  <rule id="461533" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0857 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>