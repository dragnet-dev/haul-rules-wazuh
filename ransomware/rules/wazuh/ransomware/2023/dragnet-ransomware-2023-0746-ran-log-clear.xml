<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0746 — Event Log Clearing (royal) | Status: experimental | Sigma ID: 9bf2a9e1-4cca-5d8d-b42c-85b32a0ac1f6 -->
  <rule id="492429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0746 — Event Log Clearing (royal)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>