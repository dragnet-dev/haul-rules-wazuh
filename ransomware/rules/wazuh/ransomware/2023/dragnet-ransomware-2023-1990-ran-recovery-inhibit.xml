<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1990 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b54c15bb-228f-5b8e-a5c9-7599f5b71129 -->
  <rule id="147615" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1990 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>