<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1175 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 02e279ad-b0b5-59fa-80e4-421b3753ba72 -->
  <rule id="247597" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1175 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>