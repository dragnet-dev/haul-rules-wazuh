<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4998 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c185cc72-9c89-5b25-a81e-49fdfa7bfe4b -->
  <rule id="519564" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4998 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>