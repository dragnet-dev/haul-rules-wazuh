<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1208 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d44daf60-26ef-5e65-ba52-1ad9f0a65ec6 -->
  <rule id="208527" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1208 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>