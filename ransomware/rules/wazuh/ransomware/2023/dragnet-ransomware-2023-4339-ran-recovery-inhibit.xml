<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4339 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: d9c9eae9-ab9e-5bc5-a05c-ba41256262d5 -->
  <rule id="426698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4339 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>