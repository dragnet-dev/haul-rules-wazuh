<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3459 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0add66af-cbed-5216-a436-de7d9141cb59 -->
  <rule id="950666" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3459 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>