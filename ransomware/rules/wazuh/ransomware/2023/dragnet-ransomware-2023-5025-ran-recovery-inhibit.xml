<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5025 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 85c50ddf-3a8d-55ba-bc28-267106b876f1 -->
  <rule id="496013" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5025 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>