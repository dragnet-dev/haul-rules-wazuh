<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5225 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: a985bc76-7338-5b9c-a936-9ca6ceff13c8 -->
  <rule id="212348" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5225 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>