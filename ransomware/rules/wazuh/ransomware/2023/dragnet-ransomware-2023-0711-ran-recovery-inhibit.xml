<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0711 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 05ea7230-b6a0-5df9-b98f-79e3be6a6d6d -->
  <rule id="714723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0711 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>