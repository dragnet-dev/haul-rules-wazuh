<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4996 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 9111a22f-f45c-53a6-966f-787962ff1330 -->
  <rule id="657862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4996 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>