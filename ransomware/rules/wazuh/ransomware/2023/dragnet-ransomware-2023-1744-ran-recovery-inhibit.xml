<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1744 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: ada531b9-6bc9-54ec-8026-aecaef37451a -->
  <rule id="178531" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1744 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>