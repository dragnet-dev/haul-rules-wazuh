<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4979 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: e408a25c-4544-53de-a764-48d5f8a0cc63 -->
  <rule id="605382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4979 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>