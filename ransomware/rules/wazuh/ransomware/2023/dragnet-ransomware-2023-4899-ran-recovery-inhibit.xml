<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4899 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 14f1bb81-f633-5230-a738-0590b0d7fbb7 -->
  <rule id="822838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4899 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>