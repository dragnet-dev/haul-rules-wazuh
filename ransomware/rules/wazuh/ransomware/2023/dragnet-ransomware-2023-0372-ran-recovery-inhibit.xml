<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0372 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 14e8e1fa-866d-5c66-ac69-c6113de08520 -->
  <rule id="815551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0372 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>