<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4254 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 9f6bbf7e-5505-5b99-a56b-22b6d3dcab5a -->
  <rule id="340223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4254 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>