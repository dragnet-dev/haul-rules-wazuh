<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0919 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: b9996ca2-ea10-548c-8bcb-c82cc5043d6b -->
  <rule id="219948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0919 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>