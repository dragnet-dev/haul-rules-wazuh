<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1840 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 80e8552e-0b7c-5abf-9f0e-0482d1f8581b -->
  <rule id="494855" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1840 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>