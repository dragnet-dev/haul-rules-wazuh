<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3495 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 575268d6-ad04-5878-9bfe-9fdc618da2fa -->
  <rule id="304301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3495 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>