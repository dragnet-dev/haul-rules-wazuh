<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3034 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 068018a7-c168-5463-b8df-0064ab712a7a -->
  <rule id="288298" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3034 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>