<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5184 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 1cb60219-29cd-57d8-8482-dfa23848ba0a -->
  <rule id="196021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5184 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>