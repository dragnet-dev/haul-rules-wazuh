<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4818 — Recovery Inhibition (ransomed) | Status: experimental | Sigma ID: 485c565f-f1b9-5eb3-9842-5353f5cf29eb -->
  <rule id="672565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4818 — Recovery Inhibition (ransomed)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>