<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5037 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: b9f17433-4d40-5288-8ca4-7be55dea4790 -->
  <rule id="219174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5037 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>