<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3728 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: b12b8d12-4bbe-5946-82f5-c1e9116259cc -->
  <rule id="248621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3728 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>