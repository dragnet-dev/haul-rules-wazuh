<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2172 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 22665756-208f-59dc-9f41-4dfb5fec422b -->
  <rule id="566575" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2172 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>