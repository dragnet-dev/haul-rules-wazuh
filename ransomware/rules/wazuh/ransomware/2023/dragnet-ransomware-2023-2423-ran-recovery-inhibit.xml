<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2423 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: adcfb778-89fe-5bfc-a4c3-77e547b180e9 -->
  <rule id="919317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2423 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>