<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0189 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 0f4b697d-d873-5188-953b-ecc2aa7c6374 -->
  <rule id="775697" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0189 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>