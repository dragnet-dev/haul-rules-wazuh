<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3682 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 082e6d7c-df6c-5a18-8281-4d5b2c479769 -->
  <rule id="422697" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3682 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>