<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0269 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 1459b83d-a07a-5a4e-b56e-21f15c0b4e75 -->
  <rule id="635583" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0269 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>