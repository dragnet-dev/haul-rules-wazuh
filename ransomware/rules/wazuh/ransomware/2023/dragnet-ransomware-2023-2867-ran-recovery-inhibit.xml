<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2867 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 1730507e-7697-561b-825d-6fbc8040f5ee -->
  <rule id="930507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2867 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>