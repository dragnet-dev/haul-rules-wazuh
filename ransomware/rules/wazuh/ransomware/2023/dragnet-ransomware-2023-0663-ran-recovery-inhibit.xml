<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0663 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 79084d3d-9046-5183-8132-4c280fa307f6 -->
  <rule id="465357" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0663 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>