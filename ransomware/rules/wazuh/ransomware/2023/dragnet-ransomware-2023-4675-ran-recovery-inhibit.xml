<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4675 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3e32b95e-4ad0-51e5-aa83-ebe84de3d12f -->
  <rule id="172395" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4675 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>