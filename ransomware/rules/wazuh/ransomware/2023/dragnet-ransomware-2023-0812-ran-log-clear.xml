<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0812 — Event Log Clearing (raworld) | Status: experimental | Sigma ID: 0bd6c86e-fe6a-581c-bdc2-b17c73df98ad -->
  <rule id="434886" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0812 — Event Log Clearing (raworld)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>