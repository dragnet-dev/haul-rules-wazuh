<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2055 — Event Log Clearing (play) | Status: experimental | Sigma ID: 0ec74b49-3c4a-5b14-a2af-b7ff6e54bb40 -->
  <rule id="287954" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2055 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>