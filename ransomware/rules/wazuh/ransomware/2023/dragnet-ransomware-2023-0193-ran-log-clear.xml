<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0193 — Event Log Clearing (darkpower) | Status: experimental | Sigma ID: d32a3b13-4d24-5cfb-ac36-f8c7c64b0e0a -->
  <rule id="811579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0193 — Event Log Clearing (darkpower)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>