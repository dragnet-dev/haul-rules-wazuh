<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3166 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 1893df73-c3de-58b5-8088-9f6618dd4988 -->
  <rule id="448317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3166 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>