<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4699 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: c446d054-6de1-54b4-84bc-154bb2fea72c -->
  <rule id="291490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4699 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>