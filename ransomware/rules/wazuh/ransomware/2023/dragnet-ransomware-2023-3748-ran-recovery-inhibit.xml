<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3748 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 4d7fb238-c5b1-5e27-81dc-73fc9de33af6 -->
  <rule id="291632" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3748 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>