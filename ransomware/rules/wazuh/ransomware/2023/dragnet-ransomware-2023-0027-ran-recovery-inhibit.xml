<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0027 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c07d5ce2-13ea-5059-a3da-a5dd8e13a9f1 -->
  <rule id="492092" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0027 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>