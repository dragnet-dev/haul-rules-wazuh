<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3498 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3f26df0c-2373-5691-92dc-755ca4e54fa8 -->
  <rule id="819679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3498 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>