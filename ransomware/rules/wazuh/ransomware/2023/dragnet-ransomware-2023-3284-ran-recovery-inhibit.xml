<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3284 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 474b1074-11ff-5323-9559-96cb8d59d0eb -->
  <rule id="495107" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3284 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>