<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1260 — Event Log Clearing (trigona) | Status: experimental | Sigma ID: 050dd5dd-2ba5-5933-ba2a-b9ee3f8b35c6 -->
  <rule id="383453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1260 — Event Log Clearing (trigona)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>