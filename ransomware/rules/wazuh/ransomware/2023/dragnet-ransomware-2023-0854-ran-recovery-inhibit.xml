<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0854 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 7cbf5cba-ed2f-53f1-894d-839ef0b9163c -->
  <rule id="709692" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0854 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>