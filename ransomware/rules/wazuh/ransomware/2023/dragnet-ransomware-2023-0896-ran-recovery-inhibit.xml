<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0896 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 97c83a53-62b2-581f-9487-cf13e8815343 -->
  <rule id="803738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0896 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>