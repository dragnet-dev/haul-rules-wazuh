<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3053 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 70dbf2f8-e360-5011-aa76-e8d0e471e208 -->
  <rule id="302392" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3053 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>