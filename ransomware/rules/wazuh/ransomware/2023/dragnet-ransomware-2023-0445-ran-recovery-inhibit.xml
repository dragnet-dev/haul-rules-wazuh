<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0445 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 56f49338-e6b6-5399-a1a0-d5451c360b34 -->
  <rule id="214933" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0445 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>