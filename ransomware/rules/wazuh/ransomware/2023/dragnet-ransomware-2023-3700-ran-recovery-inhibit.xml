<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3700 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 7dcaa48e-18df-51f0-b557-12d7959e76db -->
  <rule id="752424" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3700 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>