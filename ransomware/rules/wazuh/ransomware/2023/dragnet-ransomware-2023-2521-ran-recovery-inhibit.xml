<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2521 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7c3c8d57-3e30-535d-a093-697245e12d2e -->
  <rule id="584141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2521 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>