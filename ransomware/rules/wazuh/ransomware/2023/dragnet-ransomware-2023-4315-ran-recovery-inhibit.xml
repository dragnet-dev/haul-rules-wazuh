<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4315 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c1e882f4-0e4b-5b53-a04d-12b4ef821e69 -->
  <rule id="250882" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4315 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>