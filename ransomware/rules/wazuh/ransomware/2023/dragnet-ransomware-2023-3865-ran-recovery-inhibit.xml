<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3865 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1c69b9a4-5bb7-529e-9875-a3709f78106f -->
  <rule id="246554" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3865 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>