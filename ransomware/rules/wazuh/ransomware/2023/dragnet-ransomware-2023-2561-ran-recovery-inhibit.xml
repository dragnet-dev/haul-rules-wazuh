<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2561 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 0873fa69-602a-58b0-b413-f1d8dd6b9c69 -->
  <rule id="537386" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2561 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>