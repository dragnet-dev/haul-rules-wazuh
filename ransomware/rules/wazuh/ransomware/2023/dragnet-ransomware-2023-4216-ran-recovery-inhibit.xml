<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4216 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 73f9f8d6-f39c-5bf7-9560-a0a4fb038561 -->
  <rule id="194398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4216 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>