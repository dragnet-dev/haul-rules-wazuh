<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2186 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 09c7b185-cdce-5a2d-9f79-960075ebb10b -->
  <rule id="808318" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2186 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>