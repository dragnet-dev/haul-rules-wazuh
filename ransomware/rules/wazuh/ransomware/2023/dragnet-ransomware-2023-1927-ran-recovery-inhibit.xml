<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1927 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4995ff38-6833-5705-b5f2-9c2474a0ef6e -->
  <rule id="478975" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1927 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>