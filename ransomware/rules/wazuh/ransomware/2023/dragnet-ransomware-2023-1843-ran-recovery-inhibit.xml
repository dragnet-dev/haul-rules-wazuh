<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1843 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 0acf4d16-0cfc-543d-9515-1571cdbc716d -->
  <rule id="927971" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1843 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>