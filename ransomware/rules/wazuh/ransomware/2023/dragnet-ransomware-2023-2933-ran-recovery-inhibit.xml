<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2933 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3ea89864-5c05-5bd9-aa34-7d05fd4f7be1 -->
  <rule id="202898" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2933 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>