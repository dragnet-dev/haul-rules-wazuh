<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5237 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: eaa2a005-ac4f-53c7-8c90-a92e2e6814f5 -->
  <rule id="706820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5237 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>