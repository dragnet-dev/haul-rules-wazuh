<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1688 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 236e98cb-9fa7-5eeb-9330-3b4713f662ed -->
  <rule id="765580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1688 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>