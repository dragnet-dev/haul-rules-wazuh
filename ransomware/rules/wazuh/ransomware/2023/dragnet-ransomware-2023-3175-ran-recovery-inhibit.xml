<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3175 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 5d9fa29e-4578-589d-9cfe-328d285eac15 -->
  <rule id="706342" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3175 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>