<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2164 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: bd129811-1314-550c-b862-86c1c18a7d25 -->
  <rule id="191298" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2164 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>