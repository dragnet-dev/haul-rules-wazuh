<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3380 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: cd764736-bf8e-5c0b-9252-2c43ce378b67 -->
  <rule id="357647" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3380 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>