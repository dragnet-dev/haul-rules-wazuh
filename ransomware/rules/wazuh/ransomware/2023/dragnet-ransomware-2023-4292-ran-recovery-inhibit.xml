<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4292 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: f507e74e-c518-5879-90df-f8e0c9651180 -->
  <rule id="781267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4292 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>