<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0583 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 3542049b-cd8a-5c4f-8f11-57d9d3d67c7c -->
  <rule id="942049" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0583 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>