<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2963 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 83f19228-ffc6-5577-8810-66fd4011285b -->
  <rule id="543192" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2963 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>