<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2825 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 213e279f-e1bc-54e3-b3cf-a55ab6aa44fe -->
  <rule id="822279" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2825 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>