<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1144 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f6c38447-ccb6-5d8d-890a-8a611907fe80 -->
  <rule id="808384" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1144 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>