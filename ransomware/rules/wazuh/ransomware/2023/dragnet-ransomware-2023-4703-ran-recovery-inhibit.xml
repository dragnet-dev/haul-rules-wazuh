<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4703 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 59466159-531d-55db-87a1-6ebf52d29fc3 -->
  <rule id="646615" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4703 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>