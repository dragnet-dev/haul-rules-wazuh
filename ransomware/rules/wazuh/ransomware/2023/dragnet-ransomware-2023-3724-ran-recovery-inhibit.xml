<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3724 — Recovery Inhibition (cryptbb) | Status: experimental | Sigma ID: 067bd4fd-280e-5b78-81fc-cd9400e42c77 -->
  <rule id="174639" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3724 — Recovery Inhibition (cryptbb)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>