<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3856 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 1557bf51-a550-5158-bd33-b5d49dc27b6f -->
  <rule id="487835" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3856 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
