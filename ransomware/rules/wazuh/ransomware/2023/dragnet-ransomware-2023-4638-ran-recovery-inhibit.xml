<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4638 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 1faaa533-1119-53c8-af3b-acc08141e8ee -->
  <rule id="497065" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4638 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>