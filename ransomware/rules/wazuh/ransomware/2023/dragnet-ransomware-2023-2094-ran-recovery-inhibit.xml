<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2094 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: ed18d72e-e6e3-59fe-b2a7-16267ca7f63e -->
  <rule id="295017" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2094 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>