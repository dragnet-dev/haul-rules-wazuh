<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3140 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: f32bdead-dc08-5045-9766-3d5cbd2ec87b -->
  <rule id="978110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3140 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>