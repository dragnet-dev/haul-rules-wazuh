<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0222 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 66595b19-d4fe-5028-9171-355bd8dd4128 -->
  <rule id="265531" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0222 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>