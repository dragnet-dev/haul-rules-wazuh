<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3604 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: fee96b26-9e72-55ce-826d-9f149d9b245f -->
  <rule id="326347" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3604 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>