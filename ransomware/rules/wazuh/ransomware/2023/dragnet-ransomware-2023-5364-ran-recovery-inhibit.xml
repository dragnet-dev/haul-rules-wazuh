<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5364 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: e63850a7-8a71-50b6-b26d-fef912d29e80 -->
  <rule id="663850" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5364 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>