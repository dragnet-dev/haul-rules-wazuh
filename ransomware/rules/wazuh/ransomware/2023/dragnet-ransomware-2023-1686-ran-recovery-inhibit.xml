<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1686 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: adb3579d-0a34-56c6-b245-159f6447472c -->
  <rule id="179357" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1686 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>