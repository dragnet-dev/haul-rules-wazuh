<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4137 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 45dbe67f-fb4c-5fd2-bde7-7275203766cc -->
  <rule id="178386" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4137 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>