<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4760 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7ea2e588-679f-56e5-acab-0180956a4d34 -->
  <rule id="642065" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4760 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>