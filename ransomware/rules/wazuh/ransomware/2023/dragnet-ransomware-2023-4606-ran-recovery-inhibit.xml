<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4606 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 87d9636d-c392-5ce7-8f10-6ce457cf3226 -->
  <rule id="605963" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4606 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>