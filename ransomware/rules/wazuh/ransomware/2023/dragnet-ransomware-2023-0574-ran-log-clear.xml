<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0574 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 875a5683-8f77-5bf1-acdd-3c9a4324ecb6 -->
  <rule id="601056" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0574 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>