<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5150 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: b8a5b8c6-1b3d-5667-874b-6994e81242e8 -->
  <rule id="437718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5150 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>