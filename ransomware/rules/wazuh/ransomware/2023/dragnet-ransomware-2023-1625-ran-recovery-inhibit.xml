<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1625 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f467583d-a44e-5849-ac4c-a891264e1a3b -->
  <rule id="746758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1625 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>