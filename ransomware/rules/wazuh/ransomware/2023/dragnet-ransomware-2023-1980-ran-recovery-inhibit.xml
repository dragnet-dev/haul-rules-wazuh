<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1980 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 780b203c-dc7b-5eac-9637-53b44ea568d6 -->
  <rule id="449120" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1980 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>