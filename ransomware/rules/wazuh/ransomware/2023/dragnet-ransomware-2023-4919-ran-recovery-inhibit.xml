<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4919 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: e53d8d53-af50-5fcf-b900-8051d735a1dc -->
  <rule id="221901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4919 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>