<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5116 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e25853ce-65c5-5747-a1a0-592206f77d1e -->
  <rule id="625853" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5116 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>