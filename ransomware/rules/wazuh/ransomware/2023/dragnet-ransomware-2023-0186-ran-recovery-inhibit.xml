<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0186 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: 2bf842d7-1531-5f02-825c-2e59e8727ea4 -->
  <rule id="561485" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0186 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>