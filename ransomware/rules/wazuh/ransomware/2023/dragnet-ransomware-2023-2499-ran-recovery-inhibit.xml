<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2499 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 14922712-2a25-538e-8e21-0c44bb963b6c -->
  <rule id="692271" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2499 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>