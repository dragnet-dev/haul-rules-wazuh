<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5068 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 9c585084-62f5-5f62-a7b6-8539b87be885 -->
  <rule id="765850" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5068 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>