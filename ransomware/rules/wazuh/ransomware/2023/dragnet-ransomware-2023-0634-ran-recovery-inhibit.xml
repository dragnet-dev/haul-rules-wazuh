<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0634 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0d968094-23e3-54a2-a9f0-78fe82d4a831 -->
  <rule id="596809" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0634 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>