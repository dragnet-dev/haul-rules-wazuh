<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1721 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: f3f2ef77-4642-5239-b232-dfea17a6c12d -->
  <rule id="106031" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1721 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>