<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4078 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d4ba8776-375c-5781-afd5-7b3bfd52c8a7 -->
  <rule id="849087" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4078 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>