<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5301 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 61db0359-ed25-5825-8be4-272839fbf4c2 -->
  <rule id="783503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5301 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>