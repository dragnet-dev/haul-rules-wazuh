<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2454 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a616e442-f68d-5d99-b942-c9474f4c8d8b -->
  <rule id="898704" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2454 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>