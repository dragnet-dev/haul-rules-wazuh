<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2461 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: d76cca63-53fd-52dc-9b02-60a0da91c7d7 -->
  <rule id="339370" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2461 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>