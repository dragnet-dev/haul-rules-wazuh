<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3874 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 0b9745f8-3d04-576d-9eb7-1cc6f17f2051 -->
  <rule id="215935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3874 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>