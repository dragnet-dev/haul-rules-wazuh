<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0445 — Event Log Clearing (monti) | Status: experimental | Sigma ID: 6591f9c1-bc7e-53cf-b58f-b83320c1e9d7 -->
  <rule id="254719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0445 — Event Log Clearing (monti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>