<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2092 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 67164ab2-b975-52f1-8e98-11edcc3d41bf -->
  <rule id="274634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2092 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>