<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0296 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e848f983-f32c-59f2-8b65-7ffad39026ae -->
  <rule id="675839" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0296 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>