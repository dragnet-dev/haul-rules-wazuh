<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3844 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 191bad8f-a251-54e3-865f-e13b3028ba1c -->
  <rule id="753258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3844 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>