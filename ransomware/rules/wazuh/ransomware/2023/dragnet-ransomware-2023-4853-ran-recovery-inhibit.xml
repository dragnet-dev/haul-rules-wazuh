<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4853 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 5fda5cc8-2953-5ab5-bbdb-52266607cfd9 -->
  <rule id="426172" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4853 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>