<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3473 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: efe26efe-7d9a-55d2-a7a2-d7145d6c0c07 -->
  <rule id="841230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3473 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>