<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1419 — Event Log Clearing (karakurt) | Status: deprecated | Sigma ID: b8cef68f-ec1d-5456-8a79-c2adbc5182e9 -->
  <rule id="466396" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1419 — Event Log Clearing (karakurt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>