<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2664 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3f52bce7-f389-5d95-bb52-f04f11d09f67 -->
  <rule id="826300" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2664 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>