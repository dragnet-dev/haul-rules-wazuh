<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4653 — Event Log Clearing (snatch) | Status: experimental | Sigma ID: 5c1d7d76-5a6f-5ad7-82ff-1eb1709162b4 -->
  <rule id="659965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4653 — Event Log Clearing (snatch)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>