<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3992 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 66f14ce2-b208-550c-86e2-ca3e37a3107a -->
  <rule id="913836" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3992 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>