<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2859 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 17c86190-d2bb-5d5c-ba86-8336d3db4ae2 -->
  <rule id="248619" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2859 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>