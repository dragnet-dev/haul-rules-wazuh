<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2569 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 446b78c2-f04c-5d24-8548-b3fdf08abb40 -->
  <rule id="736460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2569 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>