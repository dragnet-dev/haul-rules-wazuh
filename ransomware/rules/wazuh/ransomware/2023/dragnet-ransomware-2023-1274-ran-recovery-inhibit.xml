<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1274 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0c2b7ea8-cde4-5923-b806-d43bcf72a4c2 -->
  <rule id="627306" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1274 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>