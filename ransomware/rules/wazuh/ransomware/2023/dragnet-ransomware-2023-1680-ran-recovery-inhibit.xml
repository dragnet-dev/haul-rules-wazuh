<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1680 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 48fd231c-be54-52ff-92da-ab99d7fc5195 -->
  <rule id="454123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1680 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>