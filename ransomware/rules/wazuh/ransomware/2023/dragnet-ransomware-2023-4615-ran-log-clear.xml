<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4615 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 787736b8-c6e3-531a-8a23-568133ca9c4c -->
  <rule id="103787" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4615 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>