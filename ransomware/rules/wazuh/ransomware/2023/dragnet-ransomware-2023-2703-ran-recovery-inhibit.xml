<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2703 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: a12b34db-035d-53fa-9ef2-bd6dbaec9d39 -->
  <rule id="820334" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2703 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>