<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0655 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 6f94739f-de4b-542c-aec0-f561f720fd6e -->
  <rule id="319473" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0655 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>