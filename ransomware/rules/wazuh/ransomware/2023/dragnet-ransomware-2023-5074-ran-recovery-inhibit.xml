<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5074 — Recovery Inhibition (rancoz) | Status: experimental | Sigma ID: 34baa494-4296-5bff-885f-6a1b27f32aab -->
  <rule id="622504" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5074 — Recovery Inhibition (rancoz)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>