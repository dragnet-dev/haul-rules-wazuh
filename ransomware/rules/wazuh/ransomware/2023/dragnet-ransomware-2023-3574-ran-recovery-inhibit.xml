<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3574 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6f7db173-f80e-57e1-9df3-d9f987f7c8e0 -->
  <rule id="261711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3574 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>