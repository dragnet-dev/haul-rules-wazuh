<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0540 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d6cbe2ee-3bd0-5893-acf6-bd752c19a4d0 -->
  <rule id="303182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0540 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>