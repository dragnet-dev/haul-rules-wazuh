<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1967 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2cfaf7d7-fe64-5d25-ae25-4515d28796d4 -->
  <rule id="142397" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1967 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>