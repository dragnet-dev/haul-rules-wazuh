<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2064 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b4a6e7cf-ac2a-5a81-b9dc-a8555726a045 -->
  <rule id="335507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2064 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>