<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0874 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 02f6d61a-e7f2-5ab0-9956-41ef0a220d4d -->
  <rule id="607386" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0874 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>