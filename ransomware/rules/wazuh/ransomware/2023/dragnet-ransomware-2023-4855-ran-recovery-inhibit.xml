<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4855 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1e8aea5b-ce8e-5c49-81e4-9297563de482 -->
  <rule id="464362" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4855 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>