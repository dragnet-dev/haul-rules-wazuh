<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4873 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 76ea0ba5-c9e0-51c0-a28c-f881b5472a96 -->
  <rule id="550411" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4873 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>