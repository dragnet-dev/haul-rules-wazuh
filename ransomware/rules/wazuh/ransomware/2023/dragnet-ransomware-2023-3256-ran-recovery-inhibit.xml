<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3256 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: d605edcf-d3e6-5f92-b375-7d114971ed76 -->
  <rule id="883117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3256 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>