<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3582 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: fd944ee6-e219-520c-af9a-8e7830c365c5 -->
  <rule id="563118" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3582 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>