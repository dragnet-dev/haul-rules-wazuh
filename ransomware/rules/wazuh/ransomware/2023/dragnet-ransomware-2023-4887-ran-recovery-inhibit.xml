<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4887 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9baf81f3-ab1f-51fc-8631-d27ee7817e14 -->
  <rule id="485581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4887 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>