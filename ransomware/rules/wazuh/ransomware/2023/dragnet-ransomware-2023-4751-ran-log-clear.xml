<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4751 — Event Log Clearing (malekteam) | Status: experimental | Sigma ID: 9b5c6008-4b5c-53cc-980e-ab43df7c06c0 -->
  <rule id="789260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4751 — Event Log Clearing (malekteam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>