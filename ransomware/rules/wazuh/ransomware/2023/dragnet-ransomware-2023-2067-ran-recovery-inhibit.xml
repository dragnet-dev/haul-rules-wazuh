<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2067 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: d4f02c72-f20e-5da3-af21-1f6b5b784333 -->
  <rule id="854444" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2067 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>