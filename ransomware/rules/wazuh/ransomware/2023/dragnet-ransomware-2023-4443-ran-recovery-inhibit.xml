<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4443 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 73876eb4-59af-5154-90f7-b97698c704a9 -->
  <rule id="382030" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4443 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>