<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4626 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: af619f5b-910f-584d-8553-82fef30b4f3a -->
  <rule id="209919" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4626 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>