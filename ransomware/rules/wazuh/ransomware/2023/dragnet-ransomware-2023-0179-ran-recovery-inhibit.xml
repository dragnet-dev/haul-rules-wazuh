<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0179 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 01f8971c-f82e-5faf-b555-e1668e578640 -->
  <rule id="703548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0179 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>