<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2986 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 90b9f33a-13d8-5920-b01c-9526cb35a120 -->
  <rule id="623193" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2986 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>