<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2182 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: dab466eb-ab6c-5b19-a514-330ac7bcbd87 -->
  <rule id="899466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2182 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>