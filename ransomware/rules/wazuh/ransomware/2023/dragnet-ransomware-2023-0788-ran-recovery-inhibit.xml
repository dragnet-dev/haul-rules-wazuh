<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0788 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 47ae67fb-0ebe-52fd-b1af-342fa060a432 -->
  <rule id="420667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0788 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>