<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3438 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a8864b27-7d66-5de0-91c0-d27214e53bf9 -->
  <rule id="941835" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3438 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>