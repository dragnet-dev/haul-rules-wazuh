<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4363 — Recovery Inhibition (toufan) | Status: deprecated | Sigma ID: 50e4f369-b6ed-535e-873b-f56f3a17fc9b -->
  <rule id="503193" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4363 — Recovery Inhibition (toufan)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>