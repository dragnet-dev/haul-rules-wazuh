<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1648 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 949f22fa-9843-521c-b70e-cfbfbab792b7 -->
  <rule id="719922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1648 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>