<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3261 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 6e6fc1dc-b66f-5f2b-80d2-08a91d7f0f85 -->
  <rule id="233881" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3261 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>