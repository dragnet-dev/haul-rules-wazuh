<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3996 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f87ab6b0-c830-5b57-83fd-1954d4599db4 -->
  <rule id="564436" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3996 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>