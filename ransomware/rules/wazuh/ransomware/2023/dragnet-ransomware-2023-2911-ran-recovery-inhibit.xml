<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2911 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 939e4c2b-bf39-5650-b1c0-3e24c07c0df3 -->
  <rule id="706156" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2911 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>