<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4788 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 0b3d7d13-1582-5f9d-b5b6-3fc26ea01030 -->
  <rule id="314851" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4788 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>