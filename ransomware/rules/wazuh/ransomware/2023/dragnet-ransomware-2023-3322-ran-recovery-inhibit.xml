<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3322 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 741b041f-2db6-53c0-b820-c28115dff475 -->
  <rule id="386704" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3322 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>