<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0610 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 852801ae-8aad-5645-80ed-16d0e2fa955f -->
  <rule id="244826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0610 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>