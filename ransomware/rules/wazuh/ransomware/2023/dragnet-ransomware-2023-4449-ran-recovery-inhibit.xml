<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4449 — Recovery Inhibition (darkrace) | Status: experimental | Sigma ID: 73a5b255-8cca-573b-89da-1169ca9e8d0a -->
  <rule id="185712" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4449 — Recovery Inhibition (darkrace)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>