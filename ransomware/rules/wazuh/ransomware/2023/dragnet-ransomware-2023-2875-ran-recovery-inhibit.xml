<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2875 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: d072fe0b-4d2f-5d7a-afa1-5111f2801111 -->
  <rule id="746686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2875 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>