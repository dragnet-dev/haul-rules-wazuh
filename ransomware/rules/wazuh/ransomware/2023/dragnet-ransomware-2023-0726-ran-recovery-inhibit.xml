<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0726 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: a9bd9dd3-fdef-5ea9-8cde-2bcb2da5e926 -->
  <rule id="995037" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0726 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>