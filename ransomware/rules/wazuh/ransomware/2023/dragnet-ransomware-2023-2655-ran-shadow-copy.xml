<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2655 — Shadow Copy Deletion (snatch) | Status: experimental | Sigma ID: 29159e76-9b88-5243-8390-9751b285544e -->
  <rule id="265587" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2655 — Shadow Copy Deletion (snatch)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>