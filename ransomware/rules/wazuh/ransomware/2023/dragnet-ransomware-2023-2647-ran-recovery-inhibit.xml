<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2647 — Recovery Inhibition (darkpower) | Status: experimental | Sigma ID: 16c42a7e-f9a5-575a-851e-9fd049c86578 -->
  <rule id="794827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2647 — Recovery Inhibition (darkpower)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>