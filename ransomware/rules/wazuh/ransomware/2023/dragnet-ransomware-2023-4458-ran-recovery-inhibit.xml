<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4458 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e6ea4f22-1a8d-5f04-ab62-3314b74b268c -->
  <rule id="717679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4458 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>