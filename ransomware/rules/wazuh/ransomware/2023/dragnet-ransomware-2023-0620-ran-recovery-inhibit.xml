<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0620 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 98efc9ba-7819-58a5-9487-69ddf2002588 -->
  <rule id="552449" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0620 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>