<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3618 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 6a470d22-a0ec-565c-9758-a41a27db29c9 -->
  <rule id="903533" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3618 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
