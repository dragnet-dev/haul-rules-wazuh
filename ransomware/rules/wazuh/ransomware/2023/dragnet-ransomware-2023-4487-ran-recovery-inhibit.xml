<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4487 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7ba3d3eb-95d6-5198-b163-a512977874fd -->
  <rule id="565413" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4487 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>