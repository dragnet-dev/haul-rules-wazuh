<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0772 — Event Log Clearing (meow) | Status: experimental | Sigma ID: 06abf4b9-835c-5dd3-a797-4cdeb4f058b6 -->
  <rule id="872395" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0772 — Event Log Clearing (meow)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>