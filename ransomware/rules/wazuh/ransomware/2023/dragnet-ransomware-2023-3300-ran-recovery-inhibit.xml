<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3300 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: bd1a0d1f-d8d5-5076-a1d7-ebf60501e8f3 -->
  <rule id="442573" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3300 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>