<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1742 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 75ee5a62-7c44-59ff-9e50-c44d6c6c2474 -->
  <rule id="510170" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1742 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>