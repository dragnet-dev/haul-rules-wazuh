<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2237 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 172199c8-71e2-50b6-ae45-44080d403dd6 -->
  <rule id="155196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2237 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>