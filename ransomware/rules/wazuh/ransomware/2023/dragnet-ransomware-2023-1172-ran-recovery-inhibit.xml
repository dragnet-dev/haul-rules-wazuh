<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1172 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 6e127e0c-ea1b-58de-965b-ed572b0e6078 -->
  <rule id="962046" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1172 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>