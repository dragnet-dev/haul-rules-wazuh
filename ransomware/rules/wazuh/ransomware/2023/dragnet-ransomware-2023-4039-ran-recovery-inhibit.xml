<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4039 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2cc2065d-e5a4-5e56-ac09-2ced0b8a10ff -->
  <rule id="962065" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4039 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>