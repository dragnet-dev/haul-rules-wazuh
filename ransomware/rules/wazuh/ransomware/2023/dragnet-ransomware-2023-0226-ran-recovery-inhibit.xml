<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0226 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 4255512e-c479-5d15-9a1b-abad20949001 -->
  <rule id="755512" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0226 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>