<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0832 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2553aa07-da60-5d1e-8c5f-e4dd1e2c7ba0 -->
  <rule id="337380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0832 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>