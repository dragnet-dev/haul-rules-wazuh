<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1128 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 25e691cc-42ee-5d10-8545-1b85cbbc3a9a -->
  <rule id="435068" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1128 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>