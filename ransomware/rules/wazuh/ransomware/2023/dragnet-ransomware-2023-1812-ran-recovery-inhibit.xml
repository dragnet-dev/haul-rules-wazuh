<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1812 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 5b25cd38-2c7a-5f19-abf7-47c6faa06a12 -->
  <rule id="636205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1812 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>