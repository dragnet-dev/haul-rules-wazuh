<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4390 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: b4396c58-1ecd-522f-8bee-068b30db0121 -->
  <rule id="130348" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4390 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>