<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1563 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 6a4f51a6-8372-5eec-a5d5-9088e477ab28 -->
  <rule id="903951" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1563 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>