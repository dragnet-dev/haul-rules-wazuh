<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1767 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 82d2bdc5-4a85-54bc-83db-d73388cb6f05 -->
  <rule id="792701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1767 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>