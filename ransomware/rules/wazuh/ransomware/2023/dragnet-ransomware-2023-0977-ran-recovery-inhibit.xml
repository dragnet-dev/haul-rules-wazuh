<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0977 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: ce49b7a2-9ea5-57ec-904a-2a828e23bb38 -->
  <rule id="703957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0977 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>