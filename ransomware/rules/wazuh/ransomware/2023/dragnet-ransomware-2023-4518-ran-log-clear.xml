<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4518 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: c4eab0df-1ae4-5562-ab0c-6f16203dfd61 -->
  <rule id="716590" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4518 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>