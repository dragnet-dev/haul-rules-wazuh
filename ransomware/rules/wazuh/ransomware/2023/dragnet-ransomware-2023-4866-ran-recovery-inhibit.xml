<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4866 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 6bf76b61-7b7a-5fbf-9c80-338408d713e7 -->
  <rule id="164427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4866 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>