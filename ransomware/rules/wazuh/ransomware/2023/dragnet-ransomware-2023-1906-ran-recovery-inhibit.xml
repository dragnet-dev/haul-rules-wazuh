<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1906 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: f4219082-ed4c-5f4e-a8c7-db0a79f91b4a -->
  <rule id="742190" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1906 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>