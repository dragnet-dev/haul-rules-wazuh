<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0653 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 01871644-f0f1-5ace-8553-6f0788266c1d -->
  <rule id="171644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0653 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>