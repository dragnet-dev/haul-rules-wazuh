<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1394 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 93f73099-2228-5437-98b5-a503dbd9296b -->
  <rule id="703730" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1394 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>