<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0052 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3c73f794-8412-5e40-9682-5f62db8eba72 -->
  <rule id="818379" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0052 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>