<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0508 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: ddc871ef-385a-5406-9075-07ce6cb98213 -->
  <rule id="948871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0508 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>