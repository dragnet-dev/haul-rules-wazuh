<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4594 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: d7f7e60e-01f4-5fab-9c73-c95a7a1e95ab -->
  <rule id="932466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4594 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>