<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0105 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 339db465-5ed6-52ae-8497-87a7610c9aa6 -->
  <rule id="700346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0105 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>