<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1924 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 4dabaced-dfbf-5cd3-8fac-e2db20d66ee7 -->
  <rule id="690220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1924 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
