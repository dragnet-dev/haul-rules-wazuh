<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3092 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 4a324327-7bce-5741-89a4-4c291bf8760b -->
  <rule id="332432" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3092 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>