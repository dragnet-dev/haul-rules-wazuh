<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4662 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: cedc8a33-c0de-5896-a622-5650b9992907 -->
  <rule id="473098" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4662 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>