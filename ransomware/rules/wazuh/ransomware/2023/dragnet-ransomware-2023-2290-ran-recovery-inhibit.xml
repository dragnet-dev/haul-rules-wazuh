<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2290 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: f4c8abab-c4a7-5b10-a965-b62dd0951a3a -->
  <rule id="140779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2290 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>