<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3000 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2aacdf09-c42a-5d32-8428-d2061cf2c2fd -->
  <rule id="196767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3000 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>