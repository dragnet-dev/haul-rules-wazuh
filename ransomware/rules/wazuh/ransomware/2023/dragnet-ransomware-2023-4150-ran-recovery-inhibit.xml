<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4150 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: c065f363-830d-5c9f-bd58-efefb554f5d0 -->
  <rule id="230553" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4150 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>