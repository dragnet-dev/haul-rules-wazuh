<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0797 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 839060d2-068a-520a-919a-749a873dd1aa -->
  <rule id="924973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0797 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>