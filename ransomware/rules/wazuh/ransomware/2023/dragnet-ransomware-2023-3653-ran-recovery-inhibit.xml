<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3653 — Recovery Inhibition (moneymessage) | Status: experimental | Sigma ID: 1b29965d-cb3d-5cb9-bd74-373adf220622 -->
  <rule id="129965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3653 — Recovery Inhibition (moneymessage)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>