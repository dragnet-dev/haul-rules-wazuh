<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3259 — Event Log Clearing (monti) | Status: experimental | Sigma ID: 928a5fea-524f-5baf-bc37-c6d2169714fb -->
  <rule id="677375" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3259 — Event Log Clearing (monti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>