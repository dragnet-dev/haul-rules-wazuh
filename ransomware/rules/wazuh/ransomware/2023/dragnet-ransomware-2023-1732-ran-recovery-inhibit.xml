<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1732 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: 33295823-00c9-5f8e-a9a2-486704a7e6ea -->
  <rule id="729582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1732 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
