<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4964 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b483983f-65e2-5122-be18-f3f99cba2233 -->
  <rule id="348398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4964 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
