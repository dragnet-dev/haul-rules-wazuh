<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2948 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 8d341154-c750-5a6d-a1ee-459a3981f4b5 -->
  <rule id="613411" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2948 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>