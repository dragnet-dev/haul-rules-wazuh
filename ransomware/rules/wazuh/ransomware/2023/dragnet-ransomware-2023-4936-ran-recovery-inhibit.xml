<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4936 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 9d48ffc5-8844-5ecc-ba8d-bd8e9073d340 -->
  <rule id="531743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4936 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>