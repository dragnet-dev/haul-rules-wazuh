<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0478 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5c53fe40-2ae3-5171-9914-75e504ce20a0 -->
  <rule id="669022" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0478 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>