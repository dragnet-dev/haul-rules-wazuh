<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0158 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 9706dc68-7a6a-5992-912e-5c9ceabeb70a -->
  <rule id="784956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0158 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>