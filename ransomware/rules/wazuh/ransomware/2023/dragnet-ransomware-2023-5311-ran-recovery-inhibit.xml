<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5311 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: d484a8ef-e36f-5b44-b99f-815eb462e525 -->
  <rule id="457548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5311 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
