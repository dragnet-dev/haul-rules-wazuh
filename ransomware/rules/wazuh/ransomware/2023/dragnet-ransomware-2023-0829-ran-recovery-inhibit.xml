<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0829 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 5fd9f92a-2d39-5e5d-86bb-b413b22fe1b0 -->
  <rule id="754399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0829 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>