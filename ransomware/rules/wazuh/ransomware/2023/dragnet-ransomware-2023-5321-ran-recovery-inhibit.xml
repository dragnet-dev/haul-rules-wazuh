<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5321 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: c8ddfb20-57ac-5333-b759-3e03c2fb2c4c -->
  <rule id="445435" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5321 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>