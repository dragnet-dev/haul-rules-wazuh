<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3328 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: bdd56c05-edb0-5806-aa1f-15c1c94d7e16 -->
  <rule id="460108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3328 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>