<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5305 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: b10c3ff1-dac2-5ae0-9067-0d23ee24bfd8 -->
  <rule id="243583" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5305 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>