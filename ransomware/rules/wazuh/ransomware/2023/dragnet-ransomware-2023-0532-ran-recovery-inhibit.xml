<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0532 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: e1ae10f7-c719-530b-b297-cca3c4be88b5 -->
  <rule id="127010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0532 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>