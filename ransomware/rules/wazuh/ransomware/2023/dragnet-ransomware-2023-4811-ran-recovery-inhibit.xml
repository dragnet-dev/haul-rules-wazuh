<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4811 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0c039298-6158-53cb-a633-acbfc3ac3d40 -->
  <rule id="403929" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4811 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>