<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1527 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: 5b54dd11-4bdf-5c7a-b9d5-8f480e04b0ab -->
  <rule id="643645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1527 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>