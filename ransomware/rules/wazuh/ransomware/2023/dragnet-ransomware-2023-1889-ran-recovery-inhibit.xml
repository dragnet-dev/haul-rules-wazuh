<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1889 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 493200f9-5381-50e1-9d8f-26c80a14405e -->
  <rule id="791215" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1889 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>