<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0721 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9d3b5f99-41fd-5c74-850f-81597aa2be4c -->
  <rule id="528735" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0721 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>