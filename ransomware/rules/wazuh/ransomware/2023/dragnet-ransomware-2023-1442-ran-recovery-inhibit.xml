<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1442 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7c4bc170-8f14-51e2-a42f-6cb71a59a2f9 -->
  <rule id="586521" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1442 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>