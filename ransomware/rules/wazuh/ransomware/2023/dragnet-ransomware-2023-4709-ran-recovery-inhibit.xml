<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4709 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9161c844-8648-5280-bcd5-9e309f32441c -->
  <rule id="665888" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4709 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>