<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3294 — Event Log Clearing (hunters) | Status: experimental | Sigma ID: c9330e91-815c-5266-8dd9-a70b6c47a64e -->
  <rule id="369294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3294 — Event Log Clearing (hunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>