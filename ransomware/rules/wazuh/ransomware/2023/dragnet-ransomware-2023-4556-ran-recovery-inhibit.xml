<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4556 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: d72c9863-cb72-5cf7-a9aa-d25c917494c1 -->
  <rule id="496498" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4556 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>