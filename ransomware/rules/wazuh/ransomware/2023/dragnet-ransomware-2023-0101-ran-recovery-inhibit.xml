<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0101 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: d2d8a077-93f6-5f7f-aa62-0b6011707f53 -->
  <rule id="801380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0101 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>