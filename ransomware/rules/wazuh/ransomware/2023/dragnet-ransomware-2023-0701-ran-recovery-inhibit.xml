<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0701 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8a5ebb33-8096-5f58-963f-ebd8f9c013ba -->
  <rule id="376731" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0701 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>