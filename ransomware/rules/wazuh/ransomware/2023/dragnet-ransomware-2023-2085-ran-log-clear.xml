<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2085 — Event Log Clearing (ciphbit) | Status: deprecated | Sigma ID: 217e4e3f-cc56-5fe4-b5c7-da064bb70697 -->
  <rule id="278383" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2085 — Event Log Clearing (ciphbit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>