<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2765 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 9dc099ca-d97c-5141-9ecf-a935ac3bd30e -->
  <rule id="824099" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2765 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>