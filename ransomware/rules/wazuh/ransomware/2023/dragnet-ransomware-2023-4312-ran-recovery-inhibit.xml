<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4312 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: cd14666e-ad1b-5591-8313-ffad70ed8855 -->
  <rule id="351466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4312 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>