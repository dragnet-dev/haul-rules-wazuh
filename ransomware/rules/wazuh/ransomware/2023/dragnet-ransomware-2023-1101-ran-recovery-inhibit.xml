<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1101 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 0e005ed1-47c2-56cb-9afb-f02322ffc0fc -->
  <rule id="985517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1101 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>