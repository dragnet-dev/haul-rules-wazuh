<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3827 — Event Log Clearing (siegedsec) | Status: experimental | Sigma ID: 0a445943-fd19-55d2-a598-d4f702a6ed42 -->
  <rule id="244594" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3827 — Event Log Clearing (siegedsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>