<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3910 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: facbce0b-c490-5615-94c0-feef514d2039 -->
  <rule id="227260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3910 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>