<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0381 — Recovery Inhibition (losttrust) | Status: deprecated | Sigma ID: 64171e41-81c1-5035-a81f-d995de083b58 -->
  <rule id="226750" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0381 — Recovery Inhibition (losttrust)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>