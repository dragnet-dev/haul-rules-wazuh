<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4985 — Event Log Clearing (raznatovic) | Status: experimental | Sigma ID: 9f709cd7-d6e7-59e2-a2df-d13c37bd96f6 -->
  <rule id="855356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4985 — Event Log Clearing (raznatovic)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>