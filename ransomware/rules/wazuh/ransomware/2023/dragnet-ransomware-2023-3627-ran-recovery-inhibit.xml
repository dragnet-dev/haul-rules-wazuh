<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3627 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 8fa7d1a9-1747-5207-b41e-f64ff35a57ff -->
  <rule id="178051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3627 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>