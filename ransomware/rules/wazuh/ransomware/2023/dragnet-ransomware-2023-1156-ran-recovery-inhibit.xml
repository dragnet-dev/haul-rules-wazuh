<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1156 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 11ea82cf-2713-5458-96cf-6e51d9d4d01a -->
  <rule id="481324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1156 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>