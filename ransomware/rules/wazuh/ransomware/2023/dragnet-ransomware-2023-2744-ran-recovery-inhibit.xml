<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2744 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 170f06a8-9acc-58d0-8e3a-952d264952d5 -->
  <rule id="876106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2744 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>