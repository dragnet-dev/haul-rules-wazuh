<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2635 — Recovery Inhibition (cuba) | Status: experimental | Sigma ID: c2f3bc7a-69bd-5d82-a0b3-2e5904135200 -->
  <rule id="636476" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2635 — Recovery Inhibition (cuba)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>