<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4766 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a7105bf6-9359-51b7-880d-b9dd8c810b57 -->
  <rule id="913691" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4766 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>