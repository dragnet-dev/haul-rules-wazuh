<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3367 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: cab3781f-f853-5361-8aeb-cfb1e6fa805f -->
  <rule id="643378" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3367 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>