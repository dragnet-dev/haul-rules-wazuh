<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5070 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 013609be-8898-5217-ab58-08c9063d57f3 -->
  <rule id="884094" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5070 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>