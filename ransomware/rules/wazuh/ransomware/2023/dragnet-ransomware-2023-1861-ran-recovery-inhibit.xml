<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1861 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ddf22b01-73c1-5146-af16-5509b4e35656 -->
  <rule id="381963" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1861 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>