<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3637 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7fb1cea5-a80b-5636-a43e-f14bf7b2a934 -->
  <rule id="830542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3637 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>