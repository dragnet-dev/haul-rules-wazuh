<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0705 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: be19bd20-0a30-5922-80fb-75d40b887b31 -->
  <rule id="469053" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0705 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>