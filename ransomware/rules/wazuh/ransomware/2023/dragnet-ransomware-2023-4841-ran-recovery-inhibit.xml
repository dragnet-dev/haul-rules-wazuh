<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4841 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3bc37846-3472-532d-9e26-4c7f2c0bd16a -->
  <rule id="663784" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4841 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>