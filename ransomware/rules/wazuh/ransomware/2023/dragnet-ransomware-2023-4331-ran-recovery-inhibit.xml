<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4331 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: ab37f9f5-e706-5711-aa33-e9a997b436b2 -->
  <rule id="142079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4331 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>