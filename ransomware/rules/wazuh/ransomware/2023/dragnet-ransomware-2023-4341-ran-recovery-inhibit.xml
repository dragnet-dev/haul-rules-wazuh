<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4341 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f3ccaa8c-ab17-5eb8-ae97-4c6ea96939c1 -->
  <rule id="279402" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4341 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>