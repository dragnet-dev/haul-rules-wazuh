<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0755 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 42bec784-79ea-592a-986d-c710b9135504 -->
  <rule id="950847" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0755 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>