<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3565 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 0c24b532-f1db-5bc0-8e39-c1c3975aa26d -->
  <rule id="259553" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3565 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>