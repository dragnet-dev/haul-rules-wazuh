<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4573 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: f7d200a3-7ddd-5b8c-b018-36b41e53db53 -->
  <rule id="825200" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4573 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>