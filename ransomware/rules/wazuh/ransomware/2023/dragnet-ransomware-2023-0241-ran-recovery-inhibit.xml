<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0241 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 938d6993-7e2e-5943-96b5-bfeb4aff08f4 -->
  <rule id="702169" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0241 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>