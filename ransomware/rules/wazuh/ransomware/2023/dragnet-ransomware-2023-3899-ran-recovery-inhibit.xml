<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3899 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 038882aa-78de-5823-bf39-9705490c3567 -->
  <rule id="153962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3899 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>