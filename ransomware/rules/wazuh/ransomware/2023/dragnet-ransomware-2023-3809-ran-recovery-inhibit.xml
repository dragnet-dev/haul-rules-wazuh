<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3809 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 4a491b60-e898-5893-a297-8ca1d56e65fe -->
  <rule id="391867" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3809 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>