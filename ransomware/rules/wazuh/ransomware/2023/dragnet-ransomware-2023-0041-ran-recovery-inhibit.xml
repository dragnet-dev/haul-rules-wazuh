<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0041 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: fac89615-521f-5a24-9d2d-b9719ecc56e8 -->
  <rule id="512896" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0041 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>