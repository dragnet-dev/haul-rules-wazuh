<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0716 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 68e2e235-c5ee-5a19-a19a-de75f13b000c -->
  <rule id="963662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0716 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>