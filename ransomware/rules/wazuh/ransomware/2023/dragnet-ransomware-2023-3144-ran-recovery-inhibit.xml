<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3144 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 03e37057-1ec6-5c4f-b71d-4124934281f7 -->
  <rule id="937057" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3144 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>