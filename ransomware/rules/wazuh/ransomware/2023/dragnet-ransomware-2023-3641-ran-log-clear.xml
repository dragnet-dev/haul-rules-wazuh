<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3641 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: 283f71c6-3d9d-57f8-8720-b0a588fed1d1 -->
  <rule id="169948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3641 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>