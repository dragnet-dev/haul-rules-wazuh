<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2077 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: a765ad85-6ebb-5079-9a6f-626486ae6aad -->
  <rule id="156013" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2077 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>