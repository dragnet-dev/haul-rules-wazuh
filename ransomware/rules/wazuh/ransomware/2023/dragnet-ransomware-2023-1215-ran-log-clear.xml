<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1215 — Event Log Clearing (8base) | Status: experimental | Sigma ID: 22faa0a8-96b8-55b3-b94c-a4b61c2d1d39 -->
  <rule id="759530" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1215 — Event Log Clearing (8base)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>