<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3231 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 4d425369-1bd0-5cb5-8df5-fbb160d43c51 -->
  <rule id="642536" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3231 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>