<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1992 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7637cfb3-b33e-5c86-962e-b07c90bede57 -->
  <rule id="255279" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1992 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>