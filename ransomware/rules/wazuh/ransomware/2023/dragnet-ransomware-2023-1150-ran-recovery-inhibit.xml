<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1150 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 59f2d15a-3416-5bbe-b798-cc7f56e3ac25 -->
  <rule id="734851" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1150 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>