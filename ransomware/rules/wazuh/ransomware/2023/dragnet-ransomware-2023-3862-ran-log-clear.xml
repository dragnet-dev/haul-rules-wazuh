<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3862 — Event Log Clearing (donutleaks) | Status: experimental | Sigma ID: 5089c54f-1870-5b06-a6e1-b28ba9f2d60d -->
  <rule id="143654" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3862 — Event Log Clearing (donutleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>