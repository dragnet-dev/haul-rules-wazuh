<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3772 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 63f59981-0802-56d8-b998-1dd147ff13c6 -->
  <rule id="223599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3772 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>