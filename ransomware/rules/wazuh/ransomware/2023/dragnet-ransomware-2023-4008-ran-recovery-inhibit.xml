<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4008 — Recovery Inhibition (toufan) | Status: deprecated | Sigma ID: 44641919-28b1-54d8-98a1-2b340f347806 -->
  <rule id="964191" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4008 — Recovery Inhibition (toufan)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>