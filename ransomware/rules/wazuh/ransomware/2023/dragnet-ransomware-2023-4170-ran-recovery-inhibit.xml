<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4170 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: d43ebbb2-6760-5b0b-953c-b2c98c3a3aa2 -->
  <rule id="204699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4170 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>