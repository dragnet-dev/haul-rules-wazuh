<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3030 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: aaa8ae4a-32e5-5251-ae7f-ac0dcb34940b -->
  <rule id="791022" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3030 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>