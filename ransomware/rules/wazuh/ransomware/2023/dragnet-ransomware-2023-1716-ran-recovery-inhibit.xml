<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1716 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 4dc0c995-28e2-5449-9949-6d5433fc4588 -->
  <rule id="290529" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1716 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>