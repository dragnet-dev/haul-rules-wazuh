<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3446 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: de8c9091-815a-5a6a-99f4-212451b092bd -->
  <rule id="966090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3446 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>