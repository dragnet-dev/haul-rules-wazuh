<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2835 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 905d080f-0bb0-5c13-ad7e-3457e063dc81 -->
  <rule id="649308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2835 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>