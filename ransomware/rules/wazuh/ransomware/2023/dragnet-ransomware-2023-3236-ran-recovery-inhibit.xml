<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3236 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 3d5f99df-b48c-5d60-8880-c755eb3fee6e -->
  <rule id="569597" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3236 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>