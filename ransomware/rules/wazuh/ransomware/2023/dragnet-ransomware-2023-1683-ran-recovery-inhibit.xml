<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1683 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5b684f72-ab77-55a1-9764-19a6dae9b327 -->
  <rule id="666959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1683 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>