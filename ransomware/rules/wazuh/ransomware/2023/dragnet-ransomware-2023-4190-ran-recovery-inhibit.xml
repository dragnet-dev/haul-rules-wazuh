<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4190 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 15bfda09-8679-5974-9d19-5a587a167eea -->
  <rule id="232154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4190 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>