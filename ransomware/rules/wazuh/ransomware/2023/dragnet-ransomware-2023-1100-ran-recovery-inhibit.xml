<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1100 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4b03b7cb-c937-50c7-8650-86a8f065c3cf -->
  <rule id="400597" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1100 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>