<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0338 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1f19afed-b207-50f3-9964-a5332b3e10a2 -->
  <rule id="278238" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0338 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>