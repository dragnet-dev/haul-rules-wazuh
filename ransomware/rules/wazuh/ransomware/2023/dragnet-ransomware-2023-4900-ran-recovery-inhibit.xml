<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4900 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 25ef1041-950f-5e7d-a240-538d98436fb0 -->
  <rule id="439104" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4900 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>