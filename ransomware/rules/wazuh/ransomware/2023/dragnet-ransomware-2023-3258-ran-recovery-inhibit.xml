<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3258 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 72694c57-bec3-5db9-b857-6119d39be395 -->
  <rule id="363116" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3258 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>