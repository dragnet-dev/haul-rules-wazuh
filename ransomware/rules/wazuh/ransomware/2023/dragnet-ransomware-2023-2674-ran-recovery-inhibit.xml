<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2674 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ee63cd65-7727-5477-bf6d-1a5e782471e5 -->
  <rule id="809133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2674 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>