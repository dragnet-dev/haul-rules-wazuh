<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4700 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 988d4846-b0dd-5aac-a3e2-9339c485259f -->
  <rule id="782148" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4700 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
