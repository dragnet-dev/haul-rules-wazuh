<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0802 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: c1fee13b-f0f1-5f2d-9478-e33560727014 -->
  <rule id="596941" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0802 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>