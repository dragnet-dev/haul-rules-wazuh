<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5242 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 5154732e-76fa-5bd5-aeb7-c4b115e1627f -->
  <rule id="754732" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5242 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>