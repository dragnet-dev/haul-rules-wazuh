<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3081 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 646594f4-a3e7-581e-8797-22ee17abd38a -->
  <rule id="545519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3081 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>