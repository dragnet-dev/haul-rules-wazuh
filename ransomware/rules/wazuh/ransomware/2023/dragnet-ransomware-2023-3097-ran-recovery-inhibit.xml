<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3097 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 300371b2-4ac9-53ee-bf43-18c536654986 -->
  <rule id="405947" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3097 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>