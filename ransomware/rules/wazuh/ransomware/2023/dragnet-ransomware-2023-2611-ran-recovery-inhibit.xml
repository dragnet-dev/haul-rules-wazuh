<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2611 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 6232a3c5-5a02-5a23-8109-ede3a15b390f -->
  <rule id="755580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2611 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>