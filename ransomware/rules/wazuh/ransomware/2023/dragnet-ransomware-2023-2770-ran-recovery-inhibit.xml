<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2770 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 98faabfe-358e-5626-923c-ca179ea8a1d1 -->
  <rule id="286699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2770 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>