<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3454 — Recovery Inhibition (cuba) | Status: experimental | Sigma ID: e262def1-06cd-5023-a2ef-aebb49faaac0 -->
  <rule id="151294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3454 — Recovery Inhibition (cuba)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>