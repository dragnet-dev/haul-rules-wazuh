<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4722 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 45de8917-7c91-5b51-a06a-7605dbd3e3c6 -->
  <rule id="374289" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4722 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>