<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1503 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 0c5be97e-bb94-59c8-9b33-54398a24d429 -->
  <rule id="619097" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1503 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>