<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3995 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: be0531b3-4e8f-54fa-8407-8d1b3f957cc5 -->
  <rule id="200531" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3995 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>