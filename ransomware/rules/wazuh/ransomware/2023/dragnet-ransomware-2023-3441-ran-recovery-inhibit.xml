<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3441 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 6a133fad-077e-5fbb-9b92-90c5c0751916 -->
  <rule id="898143" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3441 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
