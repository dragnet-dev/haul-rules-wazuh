<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0815 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 0f749c44-22c4-5b69-b952-30e3b98f549d -->
  <rule id="819964" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0815 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>