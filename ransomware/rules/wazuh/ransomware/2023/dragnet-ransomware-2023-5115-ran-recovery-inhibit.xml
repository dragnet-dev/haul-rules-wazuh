<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5115 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ce323df6-f074-50ce-95e8-e2b94ef33005 -->
  <rule id="701181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5115 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>