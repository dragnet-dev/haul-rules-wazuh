<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0362 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 3071715c-2ae1-5e8c-8636-93edaee2a79f -->
  <rule id="471715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0362 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>