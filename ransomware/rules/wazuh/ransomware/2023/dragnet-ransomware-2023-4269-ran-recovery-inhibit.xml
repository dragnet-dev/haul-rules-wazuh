<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4269 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 8fc793a3-6de9-5174-8855-325e104a9273 -->
  <rule id="600793" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4269 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>