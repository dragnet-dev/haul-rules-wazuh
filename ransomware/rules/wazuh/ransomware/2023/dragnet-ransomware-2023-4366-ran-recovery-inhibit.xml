<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4366 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: e41597cc-bd41-534e-85a2-a96a3228f103 -->
  <rule id="641597" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4366 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>