<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0618 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 005a2d41-056f-54a0-872f-a14a1daa6633 -->
  <rule id="644541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0618 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>