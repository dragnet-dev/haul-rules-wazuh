<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4701 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 941297b1-bcf2-5705-8870-b3f2e60a5fad -->
  <rule id="760763" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4701 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>