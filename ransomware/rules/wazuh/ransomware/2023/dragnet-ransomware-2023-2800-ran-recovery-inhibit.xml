<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2800 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: c8e3d9c1-307f-5d95-bdc4-607fef069163 -->
  <rule id="699819" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2800 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>