<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0002 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0e727cac-a34a-501a-943d-5a6760316854 -->
  <rule id="270314" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0002 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>