<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0199 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: dbdf590a-1622-5723-b288-967fb4452502 -->
  <rule id="328759" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0199 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>