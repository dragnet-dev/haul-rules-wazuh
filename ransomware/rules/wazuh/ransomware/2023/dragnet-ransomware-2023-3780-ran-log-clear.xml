<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3780 — Event Log Clearing (monti) | Status: experimental | Sigma ID: 344e6f7c-1b2c-59d3-aa63-e0f1acf2e57f -->
  <rule id="829917" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3780 — Event Log Clearing (monti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>