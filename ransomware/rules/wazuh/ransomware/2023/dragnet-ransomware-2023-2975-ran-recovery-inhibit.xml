<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2975 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7cfbb4ae-8859-507b-b04a-09ab0015ddff -->
  <rule id="719314" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2975 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>