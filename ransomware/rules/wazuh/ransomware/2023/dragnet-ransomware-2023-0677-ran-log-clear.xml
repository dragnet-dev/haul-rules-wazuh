<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0677 — Event Log Clearing (8base) | Status: experimental | Sigma ID: 8f6eaacb-ed6e-5ea7-acf8-b0983c0af773 -->
  <rule id="585610" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0677 — Event Log Clearing (8base)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>