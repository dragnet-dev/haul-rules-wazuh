<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3348 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 16d87798-2a07-5ffc-8d49-7e2851d8acb8 -->
  <rule id="998779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3348 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>