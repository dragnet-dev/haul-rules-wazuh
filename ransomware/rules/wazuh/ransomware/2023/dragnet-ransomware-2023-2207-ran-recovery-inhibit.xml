<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2207 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d2e9fa6e-58e8-562a-a34d-4605b2b8fcf7 -->
  <rule id="145114" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2207 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>