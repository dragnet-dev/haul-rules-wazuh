<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2554 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 87a4aeb0-26df-5cbd-8b5a-1ef25ef2d040 -->
  <rule id="990318" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2554 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>