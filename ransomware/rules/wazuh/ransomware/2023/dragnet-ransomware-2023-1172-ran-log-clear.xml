<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1172 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: 2d1b96bd-9ca4-5bd5-aecb-8d52af1a012d -->
  <rule id="864747" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1172 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>