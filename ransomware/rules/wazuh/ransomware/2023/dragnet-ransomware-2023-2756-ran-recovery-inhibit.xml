<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2756 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 5c69bda6-23c6-5e27-a305-bb960780ad93 -->
  <rule id="673053" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2756 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>