<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0801 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 156a4377-3d8b-5d92-b428-307240f62851 -->
  <rule id="806437" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0801 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>