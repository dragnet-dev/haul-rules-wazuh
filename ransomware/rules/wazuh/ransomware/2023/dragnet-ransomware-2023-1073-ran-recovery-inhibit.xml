<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1073 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: d9a929e6-838c-598f-8dbe-4cad78e58b66 -->
  <rule id="534929" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1073 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>