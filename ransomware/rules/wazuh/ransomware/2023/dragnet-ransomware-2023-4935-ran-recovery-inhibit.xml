<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4935 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3a75022a-6312-5e18-a1c9-02854ff4eb1a -->
  <rule id="575022" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4935 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>