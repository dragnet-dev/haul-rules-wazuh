<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2585 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: c0b19311-2bcc-5b4c-8056-a9d1d75d525e -->
  <rule id="231193" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2585 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>