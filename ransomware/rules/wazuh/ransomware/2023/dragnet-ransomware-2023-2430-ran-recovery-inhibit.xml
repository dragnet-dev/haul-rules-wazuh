<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2430 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 550ede48-17c8-5b02-a0a7-04bbba6f22c8 -->
  <rule id="556606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2430 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>