<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0757 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 58ffd364-cd94-59e9-8bd3-54e0cbd21c05 -->
  <rule id="716613" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0757 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>