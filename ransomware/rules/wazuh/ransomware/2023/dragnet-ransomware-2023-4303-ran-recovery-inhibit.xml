<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4303 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 96409894-b840-5160-8229-70200395b89c -->
  <rule id="740989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4303 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>