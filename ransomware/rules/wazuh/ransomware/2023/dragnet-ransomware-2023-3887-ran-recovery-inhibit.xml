<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3887 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d05efe3d-1a09-5dd2-a020-38b9102f3ca2 -->
  <rule id="949118" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3887 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>