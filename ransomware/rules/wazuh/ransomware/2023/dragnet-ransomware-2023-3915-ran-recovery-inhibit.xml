<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3915 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 9fe4bb6c-3128-5d9c-83ef-f45c8dd1fda8 -->
  <rule id="349691" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3915 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>