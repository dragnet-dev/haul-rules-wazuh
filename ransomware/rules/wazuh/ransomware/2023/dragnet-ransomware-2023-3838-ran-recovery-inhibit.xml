<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3838 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 915c6fb1-a770-5ae7-8757-ad2a3cbd95a3 -->
  <rule id="644431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3838 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>