<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3805 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: e543afa1-b4ec-50f8-8bd6-c971a073c214 -->
  <rule id="223183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3805 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>