<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3386 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 8ef0f782-38bf-55fd-b2e1-c2ac19e5f2a7 -->
  <rule id="159357" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3386 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>