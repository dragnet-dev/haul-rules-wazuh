<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4664 — Event Log Clearing (donutleaks) | Status: experimental | Sigma ID: 2186cb94-99d5-5b82-84ba-c94f4ffdad8f -->
  <rule id="298199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4664 — Event Log Clearing (donutleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>