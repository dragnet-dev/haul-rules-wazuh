<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4382 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 7efdccd4-c1aa-5126-a3c0-763c91813a93 -->
  <rule id="322508" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4382 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>