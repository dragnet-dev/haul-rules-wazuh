<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4828 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: fb646209-96ed-5b23-a89a-87775a4bf822 -->
  <rule id="816462" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4828 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>