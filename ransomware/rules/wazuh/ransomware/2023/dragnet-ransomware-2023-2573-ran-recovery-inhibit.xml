<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2573 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 9b4c5b97-c92d-58da-8c4e-b3b6c6fb4078 -->
  <rule id="480251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2573 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>