<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2832 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: abee4aff-1534-5710-a445-a762d72c77e6 -->
  <rule id="842314" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2832 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>