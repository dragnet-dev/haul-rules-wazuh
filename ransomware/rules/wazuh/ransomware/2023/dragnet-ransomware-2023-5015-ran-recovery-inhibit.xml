<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5015 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 2c2437da-f59a-53d6-b7fe-cdfb4d11e813 -->
  <rule id="879005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5015 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>