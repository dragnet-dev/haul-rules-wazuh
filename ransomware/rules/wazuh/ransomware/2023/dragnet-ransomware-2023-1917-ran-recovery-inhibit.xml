<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1917 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: 3813c0ec-c728-58f8-b2f4-7ea86c938595 -->
  <rule id="863214" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1917 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>