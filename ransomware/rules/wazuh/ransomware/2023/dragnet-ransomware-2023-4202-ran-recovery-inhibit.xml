<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4202 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: d0e5bca6-ba98-5ece-b53d-6427d9ea64c6 -->
  <rule id="962108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4202 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>