<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1695 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 8f01f9a7-f7b5-5963-838c-e11dd00cfc92 -->
  <rule id="588319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1695 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>