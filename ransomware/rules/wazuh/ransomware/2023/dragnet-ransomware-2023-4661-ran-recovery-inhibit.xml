<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4661 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 52ea258d-bdd1-5277-af29-481618847656 -->
  <rule id="554625" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4661 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>