<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2256 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2b2f8af0-e79f-5a13-8e33-bc9dd310e981 -->
  <rule id="308458" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2256 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>