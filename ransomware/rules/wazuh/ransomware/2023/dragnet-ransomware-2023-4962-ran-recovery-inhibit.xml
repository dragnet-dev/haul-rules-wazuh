<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4962 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 406a3e05-7dba-5e67-9c62-3b234d22ca26 -->
  <rule id="241022" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4962 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>