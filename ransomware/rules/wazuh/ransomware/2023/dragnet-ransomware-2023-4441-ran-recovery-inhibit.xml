<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4441 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0a8d1ae7-e619-5bed-b282-d88a23ca6d6a -->
  <rule id="957390" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4441 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>