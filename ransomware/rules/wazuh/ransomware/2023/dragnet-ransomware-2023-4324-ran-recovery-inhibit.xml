<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4324 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 841954fb-fead-52ca-99c5-59c95cb00e12 -->
  <rule id="971279" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4324 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>