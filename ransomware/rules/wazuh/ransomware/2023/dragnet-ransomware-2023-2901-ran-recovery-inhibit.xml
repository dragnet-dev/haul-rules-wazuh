<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2901 — Recovery Inhibition (akira) | Status: experimental | Sigma ID: 590292c5-6aac-5253-9c33-ffbfb9963309 -->
  <rule id="544684" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2901 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>