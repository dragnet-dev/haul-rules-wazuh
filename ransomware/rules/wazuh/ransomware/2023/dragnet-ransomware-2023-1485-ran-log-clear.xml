<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1485 — Event Log Clearing (darkpower) | Status: experimental | Sigma ID: 916275c5-67ab-5f70-801c-c02fb54eca27 -->
  <rule id="360412" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1485 — Event Log Clearing (darkpower)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>