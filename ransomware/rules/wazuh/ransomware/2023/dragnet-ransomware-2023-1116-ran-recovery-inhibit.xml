<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1116 — Recovery Inhibition (arvinclub) | Status: experimental | Sigma ID: 4aba4a89-b8ce-5924-b791-95f4d8d43a48 -->
  <rule id="460874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1116 — Recovery Inhibition (arvinclub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>