<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2739 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: fb2d4991-4b1b-5807-943c-2ff3d5d25490 -->
  <rule id="520549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2739 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>