<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4802 — Recovery Inhibition (play) | Status: experimental | Sigma ID: bb10a1de-36be-568a-a533-97d56d68ebf2 -->
  <rule id="393701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4802 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>