<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2204 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: b005dc31-b853-5119-8b96-e02920d1eba8 -->
  <rule id="217500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2204 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>