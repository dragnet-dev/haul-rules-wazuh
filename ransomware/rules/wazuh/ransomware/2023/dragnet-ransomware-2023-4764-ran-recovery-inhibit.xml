<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4764 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 603dd6d7-110a-5379-92d2-c5b54f5dcd30 -->
  <rule id="745896" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4764 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>