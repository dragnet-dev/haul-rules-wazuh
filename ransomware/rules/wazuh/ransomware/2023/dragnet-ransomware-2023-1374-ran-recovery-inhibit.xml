<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1374 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 2506af03-4d1d-548d-ad02-d5b62ff0089b -->
  <rule id="217110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1374 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>