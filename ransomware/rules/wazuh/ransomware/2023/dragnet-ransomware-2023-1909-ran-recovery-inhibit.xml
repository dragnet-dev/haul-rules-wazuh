<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1909 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: b12e5657-1ba9-5352-89a1-97eb8d773333 -->
  <rule id="980656" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1909 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>