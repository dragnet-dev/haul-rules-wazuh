<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1919 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: ce12b4ef-7d70-50f8-994a-e3c95588feb9 -->
  <rule id="698034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1919 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>