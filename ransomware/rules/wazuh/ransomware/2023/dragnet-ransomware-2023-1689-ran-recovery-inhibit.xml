<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1689 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 1fd88c0f-ca63-5d72-a6d1-0fb4d4d7a699 -->
  <rule id="158200" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1689 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>