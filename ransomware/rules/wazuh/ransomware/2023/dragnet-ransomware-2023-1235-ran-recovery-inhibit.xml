<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1235 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 8da10a96-cdee-55cb-bddc-85f9a1232fe6 -->
  <rule id="125770" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1235 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>