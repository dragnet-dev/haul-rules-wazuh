<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1522 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 9fb03d3a-7fc0-5f92-be36-79e0dc2d75d7 -->
  <rule id="588061" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1522 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>