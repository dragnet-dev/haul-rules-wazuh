<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3841 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 25d6c161-eb0c-5a64-9bbb-c4575a62271c -->
  <rule id="418816" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3841 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>