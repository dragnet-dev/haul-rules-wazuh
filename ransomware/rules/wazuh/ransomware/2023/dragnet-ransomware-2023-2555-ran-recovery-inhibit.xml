<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2555 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 6bc861eb-58d4-53f9-ac8d-d25cc14efce6 -->
  <rule id="924861" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2555 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>