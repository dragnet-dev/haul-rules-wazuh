<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0813 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: 127bd4bc-d8de-5321-a954-8fd591bdacf8 -->
  <rule id="832235" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0813 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
