<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3052 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 5d16fabe-6d54-5729-9704-1563030b88a8 -->
  <rule id="685146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3052 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>