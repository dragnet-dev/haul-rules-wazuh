<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0055 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 87e08d58-9df5-51a6-b204-7e68f7e06a5f -->
  <rule id="549741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0055 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>