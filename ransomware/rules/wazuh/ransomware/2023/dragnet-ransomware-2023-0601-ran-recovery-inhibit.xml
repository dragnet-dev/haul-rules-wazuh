<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0601 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: a3fc3ecb-3e53-5e18-882b-341005568470 -->
  <rule id="759262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0601 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>