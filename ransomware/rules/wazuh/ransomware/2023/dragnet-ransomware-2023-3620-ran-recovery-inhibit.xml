<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3620 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: f82f72e6-057d-5700-a43c-d8d4b0ce6bcd -->
  <rule id="832772" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3620 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>