<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0486 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: ed857617-a7a3-5713-a3d1-75c0fd636d5f -->
  <rule id="678576" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0486 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>