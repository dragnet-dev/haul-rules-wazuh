<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5336 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: ce98a20b-3aae-5741-8b55-57da8e75ab70 -->
  <rule id="711782" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5336 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>