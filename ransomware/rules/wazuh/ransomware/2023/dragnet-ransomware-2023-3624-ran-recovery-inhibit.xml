<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3624 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f14a97f9-f8b2-5c30-b51e-4eb0688c50de -->
  <rule id="723497" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3624 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>