<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4343 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: e30e0b1a-23ec-5f2e-9e55-f2aee63dbdd7 -->
  <rule id="163051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4343 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>