<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4097 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 2476fd88-6b17-5ba2-bb67-f454d536ebc6 -->
  <rule id="141098" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4097 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>