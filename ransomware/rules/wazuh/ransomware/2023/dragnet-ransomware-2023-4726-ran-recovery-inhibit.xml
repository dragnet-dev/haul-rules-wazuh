<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4726 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 1a8bd601-ca86-59cb-b4d6-7a489ffe5076 -->
  <rule id="679760" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4726 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>