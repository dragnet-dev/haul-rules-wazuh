<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3762 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 1ea234e7-5de6-5dda-a8c0-861e318633c8 -->
  <rule id="743758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3762 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>