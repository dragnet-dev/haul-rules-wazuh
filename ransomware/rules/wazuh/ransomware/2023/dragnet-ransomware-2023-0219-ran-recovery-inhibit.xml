<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0219 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 8bf54795-4bca-5930-afc7-d01134cb3f26 -->
  <rule id="539547" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0219 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>