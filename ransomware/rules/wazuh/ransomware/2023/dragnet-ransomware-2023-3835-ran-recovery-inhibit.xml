<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3835 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: e5f13852-1189-5a48-a9c5-e9b87b49c419 -->
  <rule id="635138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3835 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>