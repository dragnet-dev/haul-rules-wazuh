<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3679 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 660b6542-9102-56ad-a1c3-fbf52c49aec7 -->
  <rule id="257165" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3679 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>