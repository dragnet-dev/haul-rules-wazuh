<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1210 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5bfa87f3-790e-5cf3-889b-7e01736c1fd6 -->
  <rule id="654687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1210 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>