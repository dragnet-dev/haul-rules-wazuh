<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3427 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 8ed69ac9-d1d9-5cd9-8d44-a431e983d084 -->
  <rule id="157114" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3427 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>