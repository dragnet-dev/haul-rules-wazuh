<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4471 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: af641d58-e4c8-5196-b105-84fa218fdf8a -->
  <rule id="210269" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4471 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>