<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1725 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 9c128557-0d2a-55da-ae29-0dda7b52b497 -->
  <rule id="761285" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1725 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>