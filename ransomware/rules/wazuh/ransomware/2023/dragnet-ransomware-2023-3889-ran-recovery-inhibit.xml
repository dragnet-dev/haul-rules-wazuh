<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3889 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 470e805c-ca51-5f11-a4a4-4e9bab75e208 -->
  <rule id="434805" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3889 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>