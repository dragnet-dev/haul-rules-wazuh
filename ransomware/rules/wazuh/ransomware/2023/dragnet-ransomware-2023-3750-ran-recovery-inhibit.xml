<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3750 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: a08c0244-b26e-5d58-b56a-bc3221cab313 -->
  <rule id="814002" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3750 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>