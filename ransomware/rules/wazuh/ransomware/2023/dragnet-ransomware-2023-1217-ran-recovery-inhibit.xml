<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1217 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 4ccb6586-14a3-54a1-bf19-93d0d35621d1 -->
  <rule id="265965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1217 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>