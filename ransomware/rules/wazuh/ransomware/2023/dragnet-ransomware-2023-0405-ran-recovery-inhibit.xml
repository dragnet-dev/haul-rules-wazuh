<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0405 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: bb59958d-a5a9-59dc-a639-0eb96efca960 -->
  <rule id="175995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0405 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>