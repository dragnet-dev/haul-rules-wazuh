<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4070 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 18d14725-7361-5199-98f2-4f3f3e1347ca -->
  <rule id="411472" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4070 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>