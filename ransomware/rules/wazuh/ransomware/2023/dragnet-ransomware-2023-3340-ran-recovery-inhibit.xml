<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3340 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: b6ce5db1-0d22-5522-b9c5-c188bf50b69f -->
  <rule id="384413" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3340 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>