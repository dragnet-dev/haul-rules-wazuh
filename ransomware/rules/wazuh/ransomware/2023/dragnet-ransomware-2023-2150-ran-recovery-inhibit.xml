<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2150 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: b76f83b8-0c8f-5256-bd15-e0ffd739b21b -->
  <rule id="183183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2150 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>