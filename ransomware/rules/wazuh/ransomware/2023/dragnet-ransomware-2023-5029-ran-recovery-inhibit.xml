<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5029 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 9db8e392-ce4e-5138-9cfc-679bd7c5b874 -->
  <rule id="538223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5029 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>