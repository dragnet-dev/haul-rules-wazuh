<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1624 — Recovery Inhibition (karakurt) | Status: experimental | Sigma ID: 2bef2b56-e141-554d-acab-f8b68b030a1b -->
  <rule id="999563" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1624 — Recovery Inhibition (karakurt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>