<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2265 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 908a7d3a-337d-511c-8ed7-dabaa2ef8715 -->
  <rule id="626205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2265 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>