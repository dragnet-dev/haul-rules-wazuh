<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0464 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f26a02ef-374d-5571-9df1-3afdb61ee377 -->
  <rule id="742602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0464 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>