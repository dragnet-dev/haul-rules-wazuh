<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1464 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: a59071b0-ac1b-592f-b077-7ff5bf1c4cca -->
  <rule id="259071" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1464 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>