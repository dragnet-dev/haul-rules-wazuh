<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1964 — Recovery Inhibition (royal) | Status: experimental | Sigma ID: e085928e-e1db-5d1e-ae30-7e0274ed30b1 -->
  <rule id="608592" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1964 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>