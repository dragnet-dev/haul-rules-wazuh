<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4282 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: fbd97cff-4e8b-5652-82a8-074b0b707dec -->
  <rule id="247964" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4282 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>