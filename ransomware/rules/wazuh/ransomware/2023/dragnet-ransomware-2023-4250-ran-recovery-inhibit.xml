<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4250 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 45a6525e-490d-5167-8097-02a817e1c64a -->
  <rule id="206525" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4250 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>