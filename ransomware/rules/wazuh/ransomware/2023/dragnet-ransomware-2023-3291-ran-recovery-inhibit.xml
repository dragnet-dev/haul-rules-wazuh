<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3291 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 918f79a7-f3aa-5466-82f6-d534d0911563 -->
  <rule id="670379" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3291 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>