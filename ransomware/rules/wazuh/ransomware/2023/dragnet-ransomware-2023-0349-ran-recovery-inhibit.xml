<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0349 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 58d86b4e-7a98-5805-aa35-227538195e25 -->
  <rule id="706987" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0349 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>