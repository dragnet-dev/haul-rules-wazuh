<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4319 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3b65a5ee-147e-5784-aca0-e83baef9135d -->
  <rule id="972094" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4319 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>