<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2280 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: aee27dc8-390e-5bc1-9df7-b7331ab012c8 -->
  <rule id="977245" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2280 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>