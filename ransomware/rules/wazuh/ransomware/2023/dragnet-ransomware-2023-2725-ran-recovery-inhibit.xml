<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2725 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: 719d3efe-b7be-54a5-8fa5-01c1719dbaf5 -->
  <rule id="142782" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2725 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>