<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2431 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 785b8d39-69c9-53d7-98b6-52212a2933e2 -->
  <rule id="311501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2431 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>