<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3207 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f0eb7c4a-df48-5788-b069-7a06b71630f4 -->
  <rule id="881724" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3207 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>