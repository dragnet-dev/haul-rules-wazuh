<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3100 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 44ecbf77-72a1-5671-9e5b-1c95f0ff2ba1 -->
  <rule id="344191" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3100 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>