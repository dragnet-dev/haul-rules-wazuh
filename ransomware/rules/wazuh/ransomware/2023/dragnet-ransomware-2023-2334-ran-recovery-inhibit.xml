<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2334 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 33149049-02e1-5284-9a6b-47d38bc8b9c3 -->
  <rule id="714904" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2334 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>