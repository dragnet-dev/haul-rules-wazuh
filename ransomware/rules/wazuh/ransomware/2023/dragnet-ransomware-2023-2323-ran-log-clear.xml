<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2323 — Event Log Clearing (royal) | Status: experimental | Sigma ID: 088a60dd-7aa1-5fd0-9a92-08f6b1bd57c3 -->
  <rule id="569773" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2323 — Event Log Clearing (royal)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>