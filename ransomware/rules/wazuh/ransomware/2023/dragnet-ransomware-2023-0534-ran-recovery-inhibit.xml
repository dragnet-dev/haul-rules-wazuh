<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0534 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3337b461-697c-5371-bdd7-cab5f67bf9e9 -->
  <rule id="940346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0534 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>