<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2953 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 9fa069ef-5bc9-5521-9793-d6e55e55f3b0 -->
  <rule id="854069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2953 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>