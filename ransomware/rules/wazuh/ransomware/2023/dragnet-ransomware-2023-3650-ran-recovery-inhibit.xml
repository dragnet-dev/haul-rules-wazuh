<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3650 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3cf58ea6-df2a-58fb-b3b9-aeae4ec56199 -->
  <rule id="760942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3650 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>