<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4109 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 97f25816-dbf6-5310-8e60-5282ae204d8c -->
  <rule id="767258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4109 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>