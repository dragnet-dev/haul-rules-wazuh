<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2361 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 8ca012be-bbee-59e3-a261-a7e8f79a331f -->
  <rule id="550012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2361 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>