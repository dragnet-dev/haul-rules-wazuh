<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4591 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 479af836-7055-5a44-91fb-5d048dd8dd66 -->
  <rule id="427998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4591 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>