<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3277 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 761327bf-6821-5558-a2b4-3789f4738c1e -->
  <rule id="581243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3277 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>