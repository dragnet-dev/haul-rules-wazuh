<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0314 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 75022282-758f-5042-86d4-a6700c77ebe4 -->
  <rule id="402228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0314 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>