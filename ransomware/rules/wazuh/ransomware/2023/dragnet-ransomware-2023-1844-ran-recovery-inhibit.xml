<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1844 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 723f456e-2c50-56e6-9f2b-77838e051f6f -->
  <rule id="358345" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1844 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>