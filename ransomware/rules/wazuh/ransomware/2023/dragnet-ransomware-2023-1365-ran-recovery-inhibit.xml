<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1365 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 672193f0-68c8-5f91-b57e-fd04657ac683 -->
  <rule id="955103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1365 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>