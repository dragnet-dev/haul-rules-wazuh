<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3292 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 81afe2eb-1be9-5ddf-8a60-eab0e1f7cf46 -->
  <rule id="745902" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3292 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>