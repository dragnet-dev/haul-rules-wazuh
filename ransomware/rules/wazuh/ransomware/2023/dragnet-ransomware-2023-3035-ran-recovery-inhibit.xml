<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3035 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: a1798b12-b027-5430-af0e-badac67f78f9 -->
  <rule id="828779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3035 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>