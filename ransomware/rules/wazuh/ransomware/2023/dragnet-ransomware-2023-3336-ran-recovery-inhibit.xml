<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3336 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 8ed476f9-82b2-5a78-9001-40457d56d047 -->
  <rule id="585476" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3336 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>