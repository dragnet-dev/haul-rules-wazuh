<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1250 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d9bb070d-f217-58d2-9a90-d78f5a49a887 -->
  <rule id="977107" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1250 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>