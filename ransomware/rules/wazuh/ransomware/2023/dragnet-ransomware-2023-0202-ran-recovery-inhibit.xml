<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0202 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 00fc4a2a-47b3-59db-9e43-11a1eadb4018 -->
  <rule id="263082" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0202 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>