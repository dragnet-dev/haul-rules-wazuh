<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2416 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: f463e652-8cb3-53cd-a902-23676a6c704a -->
  <rule id="774226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2416 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>