<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1044 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 8aaeb7f6-45d2-5a34-873d-5592b1af36cd -->
  <rule id="380437" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1044 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>