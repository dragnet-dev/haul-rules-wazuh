<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2424 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: b378c9d1-60c2-5f6a-ade2-05b573cff1db -->
  <rule id="120609" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2424 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>