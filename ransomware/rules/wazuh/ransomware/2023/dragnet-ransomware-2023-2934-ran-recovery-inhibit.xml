<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2934 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ca038bb8-67e1-5d19-98b5-852bb41b0f18 -->
  <rule id="632619" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2934 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>