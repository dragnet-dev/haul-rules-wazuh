<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3069 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 2250c40f-c6c8-546e-b854-849336307b8a -->
  <rule id="101240" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3069 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>