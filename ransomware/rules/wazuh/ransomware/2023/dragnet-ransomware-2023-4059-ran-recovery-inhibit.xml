<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4059 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 2acdf5b6-8f51-506c-9e54-9e611162764b -->
  <rule id="953275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4059 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>