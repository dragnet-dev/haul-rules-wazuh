<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5067 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: f233169e-6a1d-51f5-b23b-e0e7fbd4477e -->
  <rule id="723316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5067 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
