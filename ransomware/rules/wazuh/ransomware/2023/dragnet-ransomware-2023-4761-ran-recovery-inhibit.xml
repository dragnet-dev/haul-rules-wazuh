<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4761 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 860ea74e-6467-5a63-807f-ba3d15ed4aca -->
  <rule id="503947" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4761 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>