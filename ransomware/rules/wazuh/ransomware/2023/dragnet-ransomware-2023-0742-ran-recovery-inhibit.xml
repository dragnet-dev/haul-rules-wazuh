<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0742 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 6cb024ce-5676-500a-b7f5-5142a8b472ee -->
  <rule id="939024" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0742 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>