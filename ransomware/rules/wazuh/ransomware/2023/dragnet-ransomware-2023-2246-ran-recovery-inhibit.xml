<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2246 — Recovery Inhibition (bianlian) | Status: deprecated | Sigma ID: 863742ba-efe6-590f-9888-4809543e4bae -->
  <rule id="419883" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2246 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
