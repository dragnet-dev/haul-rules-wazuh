<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3499 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 77526779-7cf6-5dad-9440-290c2172298e -->
  <rule id="652677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3499 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>