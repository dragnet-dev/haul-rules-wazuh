<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0176 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 5ffe2943-27e8-5296-a914-9d6edfc108c7 -->
  <rule id="757429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0176 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>