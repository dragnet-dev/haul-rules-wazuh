<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0051 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 65add1b9-aaa2-5ad5-9d24-6686addcf419 -->
  <rule id="990211" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0051 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>