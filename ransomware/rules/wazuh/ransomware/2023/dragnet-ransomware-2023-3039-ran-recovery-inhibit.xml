<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3039 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: a5db88a3-f29c-5174-afea-36ab26b073af -->
  <rule id="109988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3039 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>