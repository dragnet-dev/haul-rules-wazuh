<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5280 — Recovery Inhibition (losttrust) | Status: deprecated | Sigma ID: cd2650f6-73f9-57ca-a462-c73e10187baf -->
  <rule id="352650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5280 — Recovery Inhibition (losttrust)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
