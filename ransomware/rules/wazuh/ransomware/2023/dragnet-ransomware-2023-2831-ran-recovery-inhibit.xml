<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2831 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 51bbd930-6340-5fec-bb8d-4f32f55b5ca7 -->
  <rule id="419019" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2831 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>