<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4557 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: faa83402-199e-5e1d-9f7c-f41b4bcbcd11 -->
  <rule id="510834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4557 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>