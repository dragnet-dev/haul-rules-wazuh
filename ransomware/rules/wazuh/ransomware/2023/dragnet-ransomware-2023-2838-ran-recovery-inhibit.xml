<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2838 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: e7055f22-a9c1-5b85-a349-2435f803a7ae -->
  <rule id="652895" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2838 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>