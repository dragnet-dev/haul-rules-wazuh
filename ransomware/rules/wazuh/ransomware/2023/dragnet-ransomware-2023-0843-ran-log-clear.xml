<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0843 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: f93be894-3c0f-5f3d-8eb1-9a14ceccbf81 -->
  <rule id="579988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0843 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>