<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1702 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3f8d4ff9-e6d0-52d3-8629-486a0a121be0 -->
  <rule id="835439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1702 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>