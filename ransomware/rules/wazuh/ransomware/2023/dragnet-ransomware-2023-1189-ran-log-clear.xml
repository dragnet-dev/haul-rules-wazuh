<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1189 — Event Log Clearing (noescape) | Status: experimental | Sigma ID: b7b8128f-dc62-5f1e-8bd1-b92ed32e9d6d -->
  <rule id="183812" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1189 — Event Log Clearing (noescape)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>