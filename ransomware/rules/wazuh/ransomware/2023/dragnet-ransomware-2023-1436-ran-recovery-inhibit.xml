<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1436 — Recovery Inhibition (karakurt) | Status: experimental | Sigma ID: e878df9d-0e11-5486-b917-2dfffeedfcfd -->
  <rule id="308991" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1436 — Recovery Inhibition (karakurt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>