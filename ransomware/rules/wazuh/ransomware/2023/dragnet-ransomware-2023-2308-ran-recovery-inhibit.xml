<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2308 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c39e045d-4843-5dbb-b6b4-32e4956678bc -->
  <rule id="283804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2308 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>