<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1857 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: cd455574-7881-5aba-ae7f-5236438f23b9 -->
  <rule id="354555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1857 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>