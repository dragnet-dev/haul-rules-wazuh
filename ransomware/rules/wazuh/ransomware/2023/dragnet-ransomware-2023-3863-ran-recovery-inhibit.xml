<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3863 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: c1395ab2-37b3-519c-ace7-adb728914997 -->
  <rule id="242330" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3863 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>