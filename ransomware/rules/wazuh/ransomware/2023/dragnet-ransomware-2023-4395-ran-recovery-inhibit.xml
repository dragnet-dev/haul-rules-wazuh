<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4395 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 1179b3ca-327c-5db9-9c33-2da69973ab71 -->
  <rule id="420060" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4395 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>