<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0525 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 820277d7-2778-50ae-97b3-3cf18dc82a10 -->
  <rule id="624445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0525 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>