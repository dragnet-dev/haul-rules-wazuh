<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4863 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ec9bb745-e0fd-5785-a436-6046efc0887b -->
  <rule id="766517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4863 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>