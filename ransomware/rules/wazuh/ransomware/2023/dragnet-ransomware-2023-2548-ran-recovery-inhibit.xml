<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2548 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: bc5a7d46-8554-5a2a-9958-e8b2e46fe155 -->
  <rule id="427325" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2548 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>