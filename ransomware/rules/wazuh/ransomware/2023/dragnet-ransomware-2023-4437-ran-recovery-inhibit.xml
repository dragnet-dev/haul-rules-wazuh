<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4437 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 35e0cdd3-d03b-5bea-8ca4-f07e5f703116 -->
  <rule id="669645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4437 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>