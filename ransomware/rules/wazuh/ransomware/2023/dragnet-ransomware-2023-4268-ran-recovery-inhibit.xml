<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4268 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: d4d6d6c0-ec8f-503d-92a8-e3ded4f7f3b7 -->
  <rule id="852296" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4268 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>