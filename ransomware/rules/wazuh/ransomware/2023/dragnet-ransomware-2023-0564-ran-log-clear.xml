<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0564 — Event Log Clearing (arvinclub) | Status: deprecated | Sigma ID: 5bbf9130-f6ec-537e-9e3c-d4ddeae35547 -->
  <rule id="648791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0564 — Event Log Clearing (arvinclub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>