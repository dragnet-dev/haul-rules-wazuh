<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4834 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b12e8618-922b-57f5-a3e3-aa12ec963f2a -->
  <rule id="980686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4834 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>