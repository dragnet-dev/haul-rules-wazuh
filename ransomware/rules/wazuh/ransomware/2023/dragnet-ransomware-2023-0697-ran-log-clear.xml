<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0697 — Event Log Clearing (losttrust) | Status: deprecated | Sigma ID: 76b2c9b5-a34f-522f-ba60-a913e4dbb205 -->
  <rule id="263649" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0697 — Event Log Clearing (losttrust)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>