<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0579 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2ee7bbbf-adc5-5c48-82af-dc713f5108cd -->
  <rule id="221979" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0579 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>