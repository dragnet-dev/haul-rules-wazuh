<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4583 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 43b53722-0104-5cd7-be5f-333de14bc015 -->
  <rule id="795372" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4583 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>