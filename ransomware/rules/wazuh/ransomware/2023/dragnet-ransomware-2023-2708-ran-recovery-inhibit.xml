<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2708 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 569f838c-f7e2-542f-b3e2-3ef772cb078c -->
  <rule id="219838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2708 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>