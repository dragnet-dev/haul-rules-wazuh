<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1976 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 3d00b623-c255-5c2d-b962-e44819d1b942 -->
  <rule id="861162" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1976 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>