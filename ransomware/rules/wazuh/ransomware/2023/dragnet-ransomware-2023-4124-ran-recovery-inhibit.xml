<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4124 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: c016662f-1190-52d1-a736-9c9705974eb4 -->
  <rule id="401666" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4124 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>