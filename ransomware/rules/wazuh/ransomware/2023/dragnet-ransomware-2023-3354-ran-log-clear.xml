<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3354 — Event Log Clearing (darkpower) | Status: experimental | Sigma ID: d55174f7-f5ce-55bf-a728-0b8b448fcfc5 -->
  <rule id="555174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3354 — Event Log Clearing (darkpower)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>