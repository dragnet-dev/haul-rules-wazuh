<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1015 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 49410e5c-7cde-5709-b4a4-280aac7cf732 -->
  <rule id="805745" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1015 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>