<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0530 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5dfd8313-a0f8-5309-817a-a87e06b54061 -->
  <rule id="706183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0530 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>