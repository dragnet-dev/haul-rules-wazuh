<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5044 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: a96a1901-f949-565f-933e-cb103f957030 -->
  <rule id="954619" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5044 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>