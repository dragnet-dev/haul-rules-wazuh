<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0975 — Event Log Clearing (threeam) | Status: experimental | Sigma ID: 2b1c3bf9-b0de-50fd-96ee-9eccb6a49499 -->
  <rule id="305339" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0975 — Event Log Clearing (threeam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>