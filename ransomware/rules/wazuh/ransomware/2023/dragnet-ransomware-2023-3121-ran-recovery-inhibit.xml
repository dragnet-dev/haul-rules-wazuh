<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3121 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: ce5c1e1d-41c3-5d67-b2eb-019567d82c92 -->
  <rule id="888350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3121 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>