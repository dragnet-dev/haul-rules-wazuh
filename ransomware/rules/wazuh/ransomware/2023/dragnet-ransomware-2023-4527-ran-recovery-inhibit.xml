<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4527 — Recovery Inhibition (ransomed) | Status: experimental | Sigma ID: 7707d979-f219-5d78-87c6-865ab3e1825a -->
  <rule id="433259" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4527 — Recovery Inhibition (ransomed)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>