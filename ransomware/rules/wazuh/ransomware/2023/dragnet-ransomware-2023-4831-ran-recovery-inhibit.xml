<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4831 — Recovery Inhibition (play) | Status: experimental | Sigma ID: bafafee4-7d68-5578-bcde-2797e4930b57 -->
  <rule id="653950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4831 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>