<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2021 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 14614104-a5b1-54df-a1ab-ee64977f7e7d -->
  <rule id="661410" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2021 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>