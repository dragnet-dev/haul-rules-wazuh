<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4933 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: d0eb7b47-e679-55a1-bc56-39a7aa082121 -->
  <rule id="962523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4933 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>