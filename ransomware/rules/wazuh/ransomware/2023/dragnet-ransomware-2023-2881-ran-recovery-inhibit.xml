<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2881 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 299bd398-dc5f-5dc8-8d2f-7ea5fa45963b -->
  <rule id="573339" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2881 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>