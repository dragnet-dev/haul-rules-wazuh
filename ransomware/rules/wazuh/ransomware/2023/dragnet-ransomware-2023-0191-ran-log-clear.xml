<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0191 — Event Log Clearing (ciphbit) | Status: deprecated | Sigma ID: f515109c-cb48-5e17-b7bb-8eee99df2352 -->
  <rule id="751510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0191 — Event Log Clearing (ciphbit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>