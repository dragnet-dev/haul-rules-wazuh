<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1401 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 6c4e3ae1-20da-528a-b5b7-397a3a39d8cc -->
  <rule id="177338" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1401 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>