<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3299 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: fb450fcb-af2b-5570-bb62-4a97c14739f4 -->
  <rule id="523215" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3299 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>