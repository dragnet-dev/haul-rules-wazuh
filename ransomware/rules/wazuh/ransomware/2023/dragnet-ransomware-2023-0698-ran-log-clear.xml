<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0698 — Event Log Clearing (daixin) | Status: deprecated | Sigma ID: af0f3bfa-b188-5cac-89b9-14f5aa4fb0e0 -->
  <rule id="982459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0698 — Event Log Clearing (daixin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>