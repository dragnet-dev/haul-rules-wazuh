<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3328 — Event Log Clearing (8base) | Status: experimental | Sigma ID: 1bab35a3-8b70-5caa-8aa8-0c8ee42f7566 -->
  <rule id="633370" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3328 — Event Log Clearing (8base)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>