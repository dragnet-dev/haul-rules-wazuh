<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1685 — Recovery Inhibition (darkpower) | Status: experimental | Sigma ID: b4a85b3b-16c1-59b7-bca1-38d377f3f984 -->
  <rule id="335771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1685 — Recovery Inhibition (darkpower)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>