<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1034 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 76023fce-4e63-553b-a5a3-b7f4699e421b -->
  <rule id="416383" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1034 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>