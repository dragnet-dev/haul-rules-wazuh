<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2316 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: 7fce9242-8b6f-5fc8-ae9b-7ea372a4ee96 -->
  <rule id="671892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2316 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>