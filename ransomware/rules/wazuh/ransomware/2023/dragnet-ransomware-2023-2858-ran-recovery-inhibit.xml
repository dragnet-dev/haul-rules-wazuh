<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2858 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 4e0bf533-0920-5aff-83c4-fb97798baf4d -->
  <rule id="298715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2858 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>