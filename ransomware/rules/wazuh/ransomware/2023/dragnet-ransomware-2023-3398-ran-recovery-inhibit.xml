<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3398 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: abaee705-e9d6-58e8-b4fa-263856ab1c9e -->
  <rule id="832147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3398 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>