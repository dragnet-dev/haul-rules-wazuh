<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1887 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1457c539-b606-5561-b242-e2dd385264df -->
  <rule id="632453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1887 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>