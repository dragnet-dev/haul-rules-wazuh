<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4650 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 8885fc0c-948f-547d-9edf-553dbb40d3d2 -->
  <rule id="574812" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4650 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>