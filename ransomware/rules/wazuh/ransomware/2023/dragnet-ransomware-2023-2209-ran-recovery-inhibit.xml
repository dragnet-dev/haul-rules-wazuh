<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2209 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e32425b6-ab54-5c35-9eec-3170dfab5cbf -->
  <rule id="632425" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2209 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>