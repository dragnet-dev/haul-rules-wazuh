<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2994 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: be78c95f-bb17-50ca-a522-d1c7e7b0e398 -->
  <rule id="452609" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2994 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>