<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0200 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 27535ad2-f200-5db1-8151-92bf31c57b93 -->
  <rule id="849133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0200 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>