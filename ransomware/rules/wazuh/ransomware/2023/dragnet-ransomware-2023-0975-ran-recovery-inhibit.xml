<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0975 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: ee188921-317f-5523-9a4d-7722a03347f7 -->
  <rule id="681889" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0975 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>