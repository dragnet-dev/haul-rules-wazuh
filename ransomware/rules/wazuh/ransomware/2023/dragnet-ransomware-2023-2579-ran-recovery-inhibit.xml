<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2579 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a8345907-d45e-5056-b16c-0482534a96d3 -->
  <rule id="283459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2579 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>