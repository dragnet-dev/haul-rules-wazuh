<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2506 — Recovery Inhibition (losttrust) | Status: deprecated | Sigma ID: 0523f119-a22e-5e74-9022-2aa637bb37df -->
  <rule id="383119" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2506 — Recovery Inhibition (losttrust)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>