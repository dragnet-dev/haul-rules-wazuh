<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4484 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 6e7fa978-aedd-5c60-94b9-913b497a30f1 -->
  <rule id="236429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4484 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>