<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5062 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: dcecf547-2fe7-5e32-b740-d80a1f85c5df -->
  <rule id="149115" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5062 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>