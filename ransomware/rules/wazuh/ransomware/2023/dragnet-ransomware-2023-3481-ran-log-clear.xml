<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3481 — Event Log Clearing (beast) | Status: experimental | Sigma ID: 1abce396-9b19-5201-adc7-3888a0df134f -->
  <rule id="295183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3481 — Event Log Clearing (beast)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>