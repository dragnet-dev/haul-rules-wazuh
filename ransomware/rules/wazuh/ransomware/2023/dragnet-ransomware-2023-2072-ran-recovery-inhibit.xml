<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2072 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 559995c6-0bf8-56e9-b588-b24aed04a712 -->
  <rule id="959932" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2072 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>