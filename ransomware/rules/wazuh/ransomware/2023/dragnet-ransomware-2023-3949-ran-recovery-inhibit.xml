<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3949 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 37da9112-a397-5f06-bac7-3259207c4246 -->
  <rule id="790911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3949 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>