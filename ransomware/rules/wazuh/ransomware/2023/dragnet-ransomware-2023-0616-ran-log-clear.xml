<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0616 — Event Log Clearing (raznatovic) | Status: deprecated | Sigma ID: 54067b1d-9230-5ae3-85a4-758ab783d733 -->
  <rule id="650831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0616 — Event Log Clearing (raznatovic)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>