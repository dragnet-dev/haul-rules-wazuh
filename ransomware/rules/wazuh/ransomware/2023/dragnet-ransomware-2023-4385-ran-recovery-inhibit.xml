<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4385 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: 0824f659-831c-5adf-bf39-f18d8720b6d1 -->
  <rule id="519965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4385 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>