<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1337 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: c770cfea-2176-56d6-8f0f-f1a3b27a01f5 -->
  <rule id="669327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1337 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>