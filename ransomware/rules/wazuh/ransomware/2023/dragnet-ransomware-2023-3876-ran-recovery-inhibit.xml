<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3876 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: dcd4bf31-7b50-5038-b40d-8e2dc71a3f5b -->
  <rule id="145695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3876 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>