<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4330 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 1d7db02f-9d91-5109-bb36-c9b587f2d437 -->
  <rule id="525102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4330 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>