<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4038 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7a2c2275-4e2a-58de-9fec-6af3341d7c38 -->
  <rule id="256422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4038 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>