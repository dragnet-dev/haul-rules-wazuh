<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0863 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2e082e75-8e89-5529-8f6f-b5d4b0da4715 -->
  <rule id="273267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0863 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>