<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2895 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: de5f2d14-ff64-53a7-bdb8-122cddce7688 -->
  <rule id="398445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2895 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>