<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3407 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6a2570be-5c2e-5158-80fa-88086fb14407 -->
  <rule id="262570" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3407 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>