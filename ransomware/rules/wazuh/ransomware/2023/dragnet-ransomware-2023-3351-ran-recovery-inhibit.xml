<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3351 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 8bc55df7-107c-5421-8190-e17e340dc963 -->
  <rule id="978493" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3351 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>