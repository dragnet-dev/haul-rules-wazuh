<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1467 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: fd6f607b-8d87-59b4-b556-7c53bd0f9fe0 -->
  <rule id="559160" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1467 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>