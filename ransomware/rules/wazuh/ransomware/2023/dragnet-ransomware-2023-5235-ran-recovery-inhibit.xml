<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5235 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: c3080dbc-bb01-5803-a463-b0911c5ebd6b -->
  <rule id="269293" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5235 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>