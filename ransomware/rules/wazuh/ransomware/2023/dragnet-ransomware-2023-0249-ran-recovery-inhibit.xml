<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0249 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: ff057193-7f3e-55a5-b1c7-1909d2b6acb3 -->
  <rule id="850571" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0249 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>