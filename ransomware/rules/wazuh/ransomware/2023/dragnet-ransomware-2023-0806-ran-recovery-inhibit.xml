<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0806 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d9e68a2e-6ca7-5536-88e6-e94e5f44739a -->
  <rule id="981898" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0806 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>