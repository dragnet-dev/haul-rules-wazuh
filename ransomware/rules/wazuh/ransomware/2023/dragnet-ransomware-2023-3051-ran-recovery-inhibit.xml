<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3051 — Recovery Inhibition (noescape) | Status: experimental | Sigma ID: d4375749-647c-592a-8b0b-777ca3db0d83 -->
  <rule id="543757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3051 — Recovery Inhibition (noescape)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>