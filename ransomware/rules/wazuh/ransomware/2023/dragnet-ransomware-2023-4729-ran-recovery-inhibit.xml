<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4729 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 54eef22f-fbf5-5a7b-916b-2b85bea9aa6a -->
  <rule id="550072" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4729 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>