<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1271 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d0f0f7bc-1f84-5b38-8510-138c60152a7f -->
  <rule id="752157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1271 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>