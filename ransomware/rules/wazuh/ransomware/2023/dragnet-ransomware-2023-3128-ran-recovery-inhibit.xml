<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3128 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 35911884-ba8d-5a4a-9012-cf2fe4350d41 -->
  <rule id="991188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3128 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>