<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3975 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 89e65947-2066-5d66-aaf7-bb7c0feb9a10 -->
  <rule id="638659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3975 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>