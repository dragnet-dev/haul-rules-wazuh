<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4981 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: 7f480f7c-fd1d-5e2a-8966-f2914aa49807 -->
  <rule id="339695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4981 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>