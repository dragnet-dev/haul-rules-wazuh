<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1669 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f1765737-af78-5fe0-84b4-99c46c53e90e -->
  <rule id="717657" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1669 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>