<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5245 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: e2888cc9-3627-5d32-ada5-2783322dd012 -->
  <rule id="586220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5245 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>