<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3534 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c5086d2b-ba23-55f0-9fe1-8cc360f236a8 -->
  <rule id="301389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3534 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>