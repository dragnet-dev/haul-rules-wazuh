<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0523 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: cf004e33-339d-503e-bdb8-ff769d63fbba -->
  <rule id="712078" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0523 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>