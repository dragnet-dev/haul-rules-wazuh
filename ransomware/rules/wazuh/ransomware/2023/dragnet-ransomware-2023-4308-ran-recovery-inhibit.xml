<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4308 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ba2de9b8-3993-51ab-a336-178408418210 -->
  <rule id="368949" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4308 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>