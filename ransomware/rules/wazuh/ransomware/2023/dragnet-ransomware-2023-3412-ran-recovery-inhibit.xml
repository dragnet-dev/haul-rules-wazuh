<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3412 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 7c272212-6e89-51ed-82d7-45bb7d07d550 -->
  <rule id="442722" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3412 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>