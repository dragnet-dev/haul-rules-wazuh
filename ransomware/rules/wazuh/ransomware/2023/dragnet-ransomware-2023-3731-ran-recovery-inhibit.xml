<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3731 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 51b0955c-06b4-5dfe-af97-7361f29e8c88 -->
  <rule id="270955" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3731 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>