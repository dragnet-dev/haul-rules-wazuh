<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1327 — Event Log Clearing (toufan) | Status: deprecated | Sigma ID: 3ded0b2a-cf57-5a4d-9b5f-0f95a94a9fee -->
  <rule id="836491" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1327 — Event Log Clearing (toufan)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>