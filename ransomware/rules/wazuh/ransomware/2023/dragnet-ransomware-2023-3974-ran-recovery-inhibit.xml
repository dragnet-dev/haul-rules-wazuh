<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3974 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: e893d848-2e66-544f-b6eb-cc5ad7f557d1 -->
  <rule id="683018" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3974 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>