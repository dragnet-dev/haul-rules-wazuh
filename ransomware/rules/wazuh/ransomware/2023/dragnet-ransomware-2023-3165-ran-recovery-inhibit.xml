<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3165 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a8e57433-7e8d-5d85-b6f8-2fb5ce0f852c -->
  <rule id="942574" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3165 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>