<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1372 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 05ad7b41-ede4-51b6-9fe9-c13819cc60b2 -->
  <rule id="626034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1372 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>