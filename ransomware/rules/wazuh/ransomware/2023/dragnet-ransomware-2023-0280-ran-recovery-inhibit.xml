<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0280 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: ee004b0e-8f5e-51c3-8cc0-7ebfcaf43708 -->
  <rule id="308075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0280 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>