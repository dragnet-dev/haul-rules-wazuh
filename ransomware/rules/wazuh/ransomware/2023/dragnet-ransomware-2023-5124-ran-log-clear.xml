<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5124 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 4a703ac1-6e35-5db7-8cfa-d0196cfe43b8 -->
  <rule id="395258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5124 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>