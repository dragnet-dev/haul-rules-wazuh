<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2015 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 6e01ccf5-fc2a-5875-839a-e0e3ab43ddff -->
  <rule id="216460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2015 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>