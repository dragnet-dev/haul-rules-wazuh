<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2076 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 61b3181d-ba6d-5518-95cc-5992fb9c2c6d -->
  <rule id="973181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2076 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>