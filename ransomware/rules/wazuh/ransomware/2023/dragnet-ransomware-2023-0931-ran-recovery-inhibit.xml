<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0931 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 51b38ec8-296c-513f-90ff-9585b43dd51c -->
  <rule id="523822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0931 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>