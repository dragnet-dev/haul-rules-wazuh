<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0858 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 63e6cf81-b5b9-55e9-bba4-7e77f6ec0c76 -->
  <rule id="918063" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0858 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>