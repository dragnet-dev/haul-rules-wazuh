<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0767 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: fc82d19d-3c35-551f-bc92-920569623c95 -->
  <rule id="545251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0767 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>