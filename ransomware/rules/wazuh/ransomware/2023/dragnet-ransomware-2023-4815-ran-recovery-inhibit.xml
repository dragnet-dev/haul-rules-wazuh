<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4815 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 4f1c9d17-81ec-59b6-9e77-693cef3ee213 -->
  <rule id="327037" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4815 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>