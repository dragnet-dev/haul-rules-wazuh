<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1788 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: 2c90ef75-7ce9-569a-b7cc-1373fc628218 -->
  <rule id="349679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1788 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>