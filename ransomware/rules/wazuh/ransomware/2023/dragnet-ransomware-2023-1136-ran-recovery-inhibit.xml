<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1136 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 00a7f5d0-d3cf-516a-83a4-93fc77a928a0 -->
  <rule id="164130" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1136 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>