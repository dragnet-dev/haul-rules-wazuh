<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4639 — Event Log Clearing (snatch) | Status: experimental | Sigma ID: 3d69fb6d-bbbb-549b-9c72-16ecd53cbad8 -->
  <rule id="779515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4639 — Event Log Clearing (snatch)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>