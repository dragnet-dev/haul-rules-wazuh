<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3105 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 618d9d66-a81a-5035-99d2-72e0d7330981 -->
  <rule id="784317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3105 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>