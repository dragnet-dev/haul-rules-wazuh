<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3979 — Recovery Inhibition (nokoyawa) | Status: experimental | Sigma ID: ffe608d4-afff-5e84-a8ee-e88d90d03dce -->
  <rule id="594608" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3979 — Recovery Inhibition (nokoyawa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>