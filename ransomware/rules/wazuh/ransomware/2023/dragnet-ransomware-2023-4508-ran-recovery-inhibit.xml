<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4508 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: a73060b2-52ca-5638-b411-502fa7a8fcec -->
  <rule id="273060" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4508 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>