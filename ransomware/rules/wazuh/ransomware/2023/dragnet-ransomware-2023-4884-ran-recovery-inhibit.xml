<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4884 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b8dbaf05-5a2a-5e5a-87b6-09101696d542 -->
  <rule id="689487" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4884 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>