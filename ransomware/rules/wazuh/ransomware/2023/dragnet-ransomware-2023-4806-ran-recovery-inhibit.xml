<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4806 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6f3b13af-c863-5ded-b4ad-3f0725980a07 -->
  <rule id="981913" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4806 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>