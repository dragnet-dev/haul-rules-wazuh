<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0727 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 36274e10-f8a2-5a89-b985-acb2efad1e46 -->
  <rule id="503981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0727 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>