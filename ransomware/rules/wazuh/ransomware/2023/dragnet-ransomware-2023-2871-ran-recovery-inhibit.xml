<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2871 — Recovery Inhibition (malas) | Status: experimental | Sigma ID: 31b2685c-3987-55f5-abc7-138a1a98dfbf -->
  <rule id="672685" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2871 — Recovery Inhibition (malas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>