<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4464 — Event Log Clearing (snatch) | Status: experimental | Sigma ID: 4fe8c3d4-fe5d-5778-8c5c-cdb8dd66a9bf -->
  <rule id="346203" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4464 — Event Log Clearing (snatch)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>