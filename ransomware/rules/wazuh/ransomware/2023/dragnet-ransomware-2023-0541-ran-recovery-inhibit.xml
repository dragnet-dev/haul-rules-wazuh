<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-0541 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 15ae3bb4-3c76-5a40-95de-2aa1fa286cb4 -->
  <rule id="476795" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-0541 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>