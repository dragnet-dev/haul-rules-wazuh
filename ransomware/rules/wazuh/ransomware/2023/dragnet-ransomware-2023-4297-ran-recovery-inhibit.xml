<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4297 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 41dc2862-37c8-5b1c-b7c6-65b282a55353 -->
  <rule id="271628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4297 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>