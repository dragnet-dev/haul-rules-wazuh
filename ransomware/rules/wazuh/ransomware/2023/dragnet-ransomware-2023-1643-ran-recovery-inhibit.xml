<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1643 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: fa14fe32-1d17-5e49-b022-4c6d72cb0d6d -->
  <rule id="203838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1643 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>