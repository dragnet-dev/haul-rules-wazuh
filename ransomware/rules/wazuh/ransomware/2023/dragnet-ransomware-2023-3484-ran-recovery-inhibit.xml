<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3484 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: d7cf6272-210a-59fd-b9f3-761faff0a7aa -->
  <rule id="927962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3484 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>