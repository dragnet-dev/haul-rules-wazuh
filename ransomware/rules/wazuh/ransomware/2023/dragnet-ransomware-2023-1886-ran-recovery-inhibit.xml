<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1886 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 60ecaea4-4918-5e84-8711-16d7f0e98157 -->
  <rule id="492750" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1886 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>