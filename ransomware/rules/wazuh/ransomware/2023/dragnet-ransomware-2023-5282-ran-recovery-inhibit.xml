<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-5282 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 68c182e0-4eb6-541f-9c46-85f963800176 -->
  <rule id="300182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-5282 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>