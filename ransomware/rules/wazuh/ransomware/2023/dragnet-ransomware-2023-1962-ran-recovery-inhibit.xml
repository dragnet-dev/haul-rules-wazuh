<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-1962 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e0b4729f-f102-51a9-9af1-4f73e3c8b6df -->
  <rule id="551472" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-1962 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>