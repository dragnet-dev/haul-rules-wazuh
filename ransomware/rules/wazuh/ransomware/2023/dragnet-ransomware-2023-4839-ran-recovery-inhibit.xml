<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-4839 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: e6e11923-ba1d-5f4e-af71-7f3767ad78c0 -->
  <rule id="650119" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-4839 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>