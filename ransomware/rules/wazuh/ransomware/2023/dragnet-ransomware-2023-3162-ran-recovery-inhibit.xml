<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-3162 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 529ee350-6c87-5ed2-b2ed-2c4d18b1afe0 -->
  <rule id="556623" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-3162 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>