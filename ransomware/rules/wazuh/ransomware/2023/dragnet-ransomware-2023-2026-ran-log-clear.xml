<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2023-2026 — Event Log Clearing (abyss) | Status: deprecated | Sigma ID: 596f7d86-e7d7-5af5-beb7-3faeb9fc9063 -->
  <rule id="728285" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2023-2026 — Event Log Clearing (abyss)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>