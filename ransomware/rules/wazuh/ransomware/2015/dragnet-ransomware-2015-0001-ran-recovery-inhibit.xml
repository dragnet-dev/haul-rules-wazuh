<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2015-0001 — Recovery Inhibition (AiLock) | Status: deprecated | Sigma ID: 716654fb-ba5e-51ab-b496-f1b4a549adac -->
  <rule id="766479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2015-0001 — Recovery Inhibition (AiLock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>