<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1179 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 60b53756-509e-5580-9920-e8cf094278f5 -->
  <rule id="815375" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1179 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>