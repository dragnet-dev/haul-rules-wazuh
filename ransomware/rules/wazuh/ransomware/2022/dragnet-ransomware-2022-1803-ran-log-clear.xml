<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1803 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: 828451e6-443c-5ec4-899f-6a67f8f1dee4 -->
  <rule id="755230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1803 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>