  <rule id="370943" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1120 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
