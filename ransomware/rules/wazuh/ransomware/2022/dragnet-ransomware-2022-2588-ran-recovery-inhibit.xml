<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2588 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 0bcc754a-28b9-5f46-98e0-46f2ce581848 -->
  <rule id="420754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2588 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>