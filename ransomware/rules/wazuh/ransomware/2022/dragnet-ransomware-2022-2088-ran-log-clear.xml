<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2088 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: c5ad1850-b1f0-5d6b-ba4e-f7f710098cd2 -->
  <rule id="617318" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2088 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>