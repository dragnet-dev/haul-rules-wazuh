<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2641 — Event Log Clearing (hive) | Status: deprecated | Sigma ID: c1f8c854-3ff7-5fcb-ba99-8a8df5ecbe80 -->
  <rule id="523008" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2641 — Event Log Clearing (hive)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>