<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1195 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: a667cb98-c198-5f7d-8707-79674e25635d -->
  <rule id="130955" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1195 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
