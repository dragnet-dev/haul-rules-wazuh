<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0065 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7bc9583c-263e-5126-82cb-8db40417c75a -->
  <rule id="280958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0065 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>