<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0005 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: a80ad044-8a6e-59d4-a6b1-2f9883f61d21 -->
  <rule id="166530" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0005 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>