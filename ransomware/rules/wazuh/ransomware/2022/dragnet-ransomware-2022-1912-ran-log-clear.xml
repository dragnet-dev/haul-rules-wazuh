<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1912 — Event Log Clearing (kelvinsecurity) | Status: deprecated | Sigma ID: 0de25507-9f79-5a57-818c-6411fc4ae2d7 -->
  <rule id="522550" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1912 — Event Log Clearing (kelvinsecurity)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>