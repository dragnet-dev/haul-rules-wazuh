<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2192 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 8f4b2e7b-054d-5754-be37-dfa302bdbfae -->
  <rule id="172846" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2192 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>