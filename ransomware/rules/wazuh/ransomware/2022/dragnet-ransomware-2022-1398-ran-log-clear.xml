<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1398 — Event Log Clearing (karakurt) | Status: deprecated | Sigma ID: ad5a1a2e-bc8a-5fa4-93b0-e7be660befc2 -->
  <rule id="943226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1398 — Event Log Clearing (karakurt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>