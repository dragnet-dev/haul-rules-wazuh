<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1172 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 39b724c1-8849-577c-a087-215e1cc67792 -->
  <rule id="371596" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1172 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>