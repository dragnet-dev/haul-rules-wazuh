<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0381 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 60b41284-5669-5788-b969-44c319f76314 -->
  <rule id="814128" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0381 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>