<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3155 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 24235fa1-f5bf-5273-8056-7d071e16f5d2 -->
  <rule id="904410" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3155 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>