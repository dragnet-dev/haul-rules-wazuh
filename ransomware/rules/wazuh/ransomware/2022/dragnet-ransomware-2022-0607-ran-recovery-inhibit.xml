<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0607 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 6445e68e-9882-57f2-ba21-57fd1bbd2004 -->
  <rule id="231346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0607 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
