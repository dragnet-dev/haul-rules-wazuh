<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0583 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ec8b622c-07f5-52e6-b0da-6f213a76058c -->
  <rule id="289962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0583 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>