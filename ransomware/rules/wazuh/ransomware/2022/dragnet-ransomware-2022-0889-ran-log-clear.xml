<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0889 — Event Log Clearing (everest) | Status: deprecated | Sigma ID: 6af3ffe8-7cec-50b4-92c0-ad7fe6c35ce3 -->
  <rule id="881183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0889 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>