<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1007 — Event Log Clearing (lv) | Status: deprecated | Sigma ID: 116810a2-a3fa-5af5-b5f4-b8a430689b5b -->
  <rule id="168970" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1007 — Event Log Clearing (lv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>