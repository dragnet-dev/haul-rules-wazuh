<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2586 — Recovery Inhibition (onyx) | Status: deprecated | Sigma ID: befcdcf6-cbac-57f0-ba22-5dea6dba4074 -->
  <rule id="916572" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2586 — Recovery Inhibition (onyx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>