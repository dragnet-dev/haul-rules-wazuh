<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1065 — Event Log Clearing (avoslocker) | Status: deprecated | Sigma ID: 4b6dfe7c-9a86-5449-a88c-6e8529727679 -->
  <rule id="500158" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1065 — Event Log Clearing (avoslocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>