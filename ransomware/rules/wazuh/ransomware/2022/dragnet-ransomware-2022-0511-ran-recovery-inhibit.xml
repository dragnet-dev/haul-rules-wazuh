<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0511 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 97f6e3fa-7ef2-5894-b669-9dcfe77c7872 -->
  <rule id="808303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0511 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>