<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0086 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 05408dbe-6645-537c-acdd-320efbc09062 -->
  <rule id="584667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0086 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>