<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2084 — Event Log Clearing (medusalocker) | Status: deprecated | Sigma ID: ace5f6c6-e87a-53f4-8f8c-045c8a38bdde -->
  <rule id="926556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2084 — Event Log Clearing (medusalocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>