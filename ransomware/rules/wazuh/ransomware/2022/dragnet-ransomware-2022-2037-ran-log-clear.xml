<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2037 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: b32cadfd-a9c7-5509-8d62-4f7a8880a090 -->
  <rule id="239917" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2037 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>