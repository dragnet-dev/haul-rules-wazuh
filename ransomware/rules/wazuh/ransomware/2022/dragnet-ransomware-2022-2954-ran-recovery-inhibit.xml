<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2954 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: d45b7610-7cc4-5ee5-996c-93a911871243 -->
  <rule id="453176" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2954 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
