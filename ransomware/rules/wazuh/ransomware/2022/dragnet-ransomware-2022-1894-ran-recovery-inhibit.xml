<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1894 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 5654ea5a-5cd1-519b-8f13-c8a98207efb6 -->
  <rule id="647658" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1894 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>