<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1675 — Recovery Inhibition (snatch) | Status: deprecated | Sigma ID: 256da3e6-da30-519d-85ee-506d0f9b1f40 -->
  <rule id="720702" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1675 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>