<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2201 — Recovery Inhibition (karakurt) | Status: experimental | Sigma ID: 3efc2cd8-100f-5bbb-92ac-3bee6bf62308 -->
  <rule id="879884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2201 — Recovery Inhibition (karakurt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>