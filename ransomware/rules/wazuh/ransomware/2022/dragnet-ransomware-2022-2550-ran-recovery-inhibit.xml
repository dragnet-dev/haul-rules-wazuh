<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2550 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: afd1cb0c-9fe2-55a9-8056-babf914b6873 -->
  <rule id="101739" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2550 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>