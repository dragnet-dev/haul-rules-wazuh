<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0551 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 91c11654-c17a-5724-9c53-ef7caa17c039 -->
  <rule id="668116" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0551 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
