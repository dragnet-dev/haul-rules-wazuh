<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3015 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: da4a77ae-5893-56b1-9636-cdbf659a27c2 -->
  <rule id="895477" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3015 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>