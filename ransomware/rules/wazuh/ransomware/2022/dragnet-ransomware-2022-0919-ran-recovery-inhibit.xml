<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0919 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 818c0da0-87ad-55b2-90f1-e68bdd3b8844 -->
  <rule id="396013" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0919 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>