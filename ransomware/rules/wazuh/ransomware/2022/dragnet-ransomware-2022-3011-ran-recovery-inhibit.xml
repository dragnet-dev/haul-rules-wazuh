<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3011 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 97708e4d-4bae-5868-b34a-80543510ed94 -->
  <rule id="763342" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3011 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>