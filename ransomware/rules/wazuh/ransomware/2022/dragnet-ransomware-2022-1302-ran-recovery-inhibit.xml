<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1302 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 59722c99-873b-5fe1-96c2-f981b618487e -->
  <rule id="655649" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1302 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>