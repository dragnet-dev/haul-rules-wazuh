<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2369 — Event Log Clearing (memedusalockerdusa) | Status: deprecated | Sigma ID: 176efaf5-238a-5e02-90f4-f531d9ddccc2 -->
  <rule id="895695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2369 — Event Log Clearing (memedusalockerdusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>