<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2884 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 76278182-e7af-5e07-bc75-fb7c21d3accb -->
  <rule id="527818" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2884 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>