<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2796 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: ed9b7057-d41f-50e6-87d4-c40680858ed0 -->
  <rule id="307570" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2796 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
