<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0318 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: f5ab7cbb-1201-57e4-908c-81788b9ad99f -->
  <rule id="176284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0318 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>