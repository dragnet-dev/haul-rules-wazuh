<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0550 — Event Log Clearing (projectrelic) | Status: deprecated | Sigma ID: 341d6889-6585-5852-96e5-83e692c430cc -->
  <rule id="169688" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0550 — Event Log Clearing (projectrelic)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>