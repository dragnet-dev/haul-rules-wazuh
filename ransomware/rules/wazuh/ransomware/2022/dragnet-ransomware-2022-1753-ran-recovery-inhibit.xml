<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1753 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 90de1a25-7565-5508-b8de-e829b378a80d -->
  <rule id="221946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1753 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>