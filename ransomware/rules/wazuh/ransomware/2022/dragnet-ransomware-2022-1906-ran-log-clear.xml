<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1906 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 8af498d2-70ef-55d0-b9a5-edd4cc63c264 -->
  <rule id="523498" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1906 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>