<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2418 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 3392bef2-25f0-59ff-98b2-8223e04aea52 -->
  <rule id="496687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2418 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
