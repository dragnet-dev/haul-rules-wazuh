<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0118 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: a278f568-fcb4-5394-b324-80c8579a21aa -->
  <rule id="844635" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0118 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>