<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2222 — Event Log Clearing (sparta) | Status: deprecated | Sigma ID: c19df4be-8cda-5720-bc76-146985ca37bd -->
  <rule id="522874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2222 — Event Log Clearing (sparta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>