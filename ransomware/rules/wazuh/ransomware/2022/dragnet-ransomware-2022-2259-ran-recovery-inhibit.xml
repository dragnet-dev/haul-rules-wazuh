<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2259 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 824f6a7f-e5eb-5166-85be-e6a44c3674cf -->
  <rule id="411946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2259 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>