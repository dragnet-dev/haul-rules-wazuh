<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0810 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 2f8819f1-a217-5548-85fb-d081a48ba481 -->
  <rule id="561119" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0810 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>