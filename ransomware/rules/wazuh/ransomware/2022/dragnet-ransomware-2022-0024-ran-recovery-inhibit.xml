<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0024 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: b352eedf-236d-5698-856b-9f17700612cb -->
  <rule id="306350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0024 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>