<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0978 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 717d8223-07d6-5f2c-96c5-24352ae96f89 -->
  <rule id="348582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0978 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>