<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2225 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: 3613cbb7-e99c-595e-8ed7-bb637bd29585 -->
  <rule id="502107" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2225 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>