<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0513 — Recovery Inhibition (cheers) | Status: deprecated | Sigma ID: d26923f8-eaa7-5840-9e1d-c89bc5afac8a -->
  <rule id="526923" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0513 — Recovery Inhibition (cheers)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>