<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1372 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: c2191d11-30be-5c26-bcb6-6c6b2e95f2dc -->
  <rule id="255069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1372 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>