<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2165 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: f74ffde1-446f-5c0b-817b-5595ad38866e -->
  <rule id="251197" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2165 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>