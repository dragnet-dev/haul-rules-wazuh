<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0264 — Event Log Clearing (suncrypt) | Status: deprecated | Sigma ID: 22b68a79-2f82-5d63-b0f8-44babaf48694 -->
  <rule id="518987" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0264 — Event Log Clearing (suncrypt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>