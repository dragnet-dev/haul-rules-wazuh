<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2637 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 71701b88-64c5-5c8e-9d6f-b34df8e5b1c8 -->
  <rule id="347227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2637 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>