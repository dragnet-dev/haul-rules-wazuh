<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1805 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: cf759559-6ec2-5a07-b4c7-add40034f98e -->
  <rule id="377595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1805 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>