<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0875 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 99462516-de88-564d-bd63-6b6a9fd5aaca -->
  <rule id="146251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0875 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>