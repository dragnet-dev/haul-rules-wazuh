<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2280 — Recovery Inhibition (cuba) | Status: deprecated | Sigma ID: 06359e53-e3c0-56e6-844b-a029f8168282 -->
  <rule id="217585" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2280 — Recovery Inhibition (cuba)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>