<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1766 — Event Log Clearing (freecivilian) | Status: deprecated | Sigma ID: 6ca5e660-c06a-5885-adb2-d7b57e01039e -->
  <rule id="181746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1766 — Event Log Clearing (freecivilian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>