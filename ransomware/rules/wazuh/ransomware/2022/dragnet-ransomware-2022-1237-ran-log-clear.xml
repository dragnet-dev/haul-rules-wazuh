<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1237 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 3f35ad39-084a-564b-a59b-6e1efcfdc56f -->
  <rule id="821933" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1237 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>