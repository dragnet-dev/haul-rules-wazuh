<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2757 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: fdc862cb-3040-5951-9e81-45399fb86dc5 -->
  <rule id="560862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2757 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>