<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2646 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 678eebf6-ebb2-5a50-b110-57cea24872a4 -->
  <rule id="180907" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2646 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>