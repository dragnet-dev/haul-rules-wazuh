<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2532 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 50a848d2-871a-54bd-9ed2-41a524c021a0 -->
  <rule id="473581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2532 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>