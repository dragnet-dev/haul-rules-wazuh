<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0957 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: aea171ff-d086-5bf6-8f5b-b46fa31a543a -->
  <rule id="194171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0957 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>