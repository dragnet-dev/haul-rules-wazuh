<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2293 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 4228ebff-b217-51ba-a1e5-d869a9d5474c -->
  <rule id="282603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2293 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>