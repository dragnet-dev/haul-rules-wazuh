<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2750 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: da30128a-6e6d-5e50-8eee-5785f0dd851a -->
  <rule id="483012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2750 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>