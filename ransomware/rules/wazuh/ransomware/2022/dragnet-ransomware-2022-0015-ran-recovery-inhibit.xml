<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0015 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 8c051ccf-f5e4-5036-b910-cd2235d53e6a -->
  <rule id="540828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0015 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>