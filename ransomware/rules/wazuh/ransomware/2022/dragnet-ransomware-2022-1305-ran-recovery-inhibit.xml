<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1305 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 3fd2e4a9-d655-53b0-bd44-697b32694606 -->
  <rule id="834064" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1305 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>