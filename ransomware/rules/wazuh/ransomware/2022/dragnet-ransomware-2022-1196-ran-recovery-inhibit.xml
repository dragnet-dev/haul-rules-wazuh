<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1196 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 29ac3380-4341-59d2-a575-182aa1bc4134 -->
  <rule id="496338" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1196 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
