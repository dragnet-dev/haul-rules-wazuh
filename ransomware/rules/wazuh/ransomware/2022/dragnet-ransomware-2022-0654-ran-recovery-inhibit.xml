<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0654 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ff18127e-2ef8-5ec3-89f5-914b3b6f51de -->
  <rule id="851812" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0654 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>