<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1886 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 39086561-1091-536c-86f4-689cd5a47e8b -->
  <rule id="408656" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1886 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>