<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2445 — Recovery Inhibition (royal) | Status: deprecated | Sigma ID: de62e329-675f-5a01-bbc9-08ff64a9718d -->
  <rule id="962063" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2445 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
