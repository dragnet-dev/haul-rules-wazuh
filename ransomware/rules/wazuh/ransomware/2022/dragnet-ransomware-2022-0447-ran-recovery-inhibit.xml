<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0447 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 360f695c-4a3a-51e9-9074-007e9fea18f5 -->
  <rule id="475695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0447 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>