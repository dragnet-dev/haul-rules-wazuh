<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1570 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: bc6f692f-181f-547b-8704-1eedd292f730 -->
  <rule id="419169" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1570 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>