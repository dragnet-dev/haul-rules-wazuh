<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2753 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: e09ca500-2ddb-5977-8516-2ed18eac5b34 -->
  <rule id="109065" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2753 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>