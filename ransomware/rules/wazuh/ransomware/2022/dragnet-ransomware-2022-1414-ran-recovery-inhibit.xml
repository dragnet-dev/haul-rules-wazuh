<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1414 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 98e6d103-3722-581b-b90f-703cfba920d3 -->
  <rule id="832291" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1414 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>