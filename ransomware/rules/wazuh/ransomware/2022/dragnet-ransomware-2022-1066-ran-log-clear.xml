<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1066 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: e23125f0-a615-5f7d-a412-a9f6717e6c60 -->
  <rule id="623125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1066 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>