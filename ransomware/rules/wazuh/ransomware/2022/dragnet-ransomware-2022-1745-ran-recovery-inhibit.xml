<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1745 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: ae523c49-10e3-560a-93d0-477af98741d4 -->
  <rule id="192380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1745 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>