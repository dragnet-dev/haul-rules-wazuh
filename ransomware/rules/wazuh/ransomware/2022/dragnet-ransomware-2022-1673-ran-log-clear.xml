<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1673 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 7f5053ab-931a-53a7-8b5a-efee0f90ec44 -->
  <rule id="475053" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1673 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>