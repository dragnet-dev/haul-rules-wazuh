<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1568 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 9926a393-be75-55f8-90b1-4f27a85ae86a -->
  <rule id="788263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1568 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>