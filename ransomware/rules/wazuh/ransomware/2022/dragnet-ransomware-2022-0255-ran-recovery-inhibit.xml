<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0255 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 9fee2482-cc1b-5182-806f-5b2c3efea7bb -->
  <rule id="594224" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0255 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>