<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2000 — Event Log Clearing (lv) | Status: deprecated | Sigma ID: 98d73ce6-f323-5b42-b0ba-1123f33c4ce8 -->
  <rule id="830780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2000 — Event Log Clearing (lv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>