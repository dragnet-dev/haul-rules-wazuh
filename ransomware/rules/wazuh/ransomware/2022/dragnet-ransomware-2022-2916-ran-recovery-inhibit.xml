<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2916 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3a5deb1a-4f55-5395-a4db-1d5005559a06 -->
  <rule id="699723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2916 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>