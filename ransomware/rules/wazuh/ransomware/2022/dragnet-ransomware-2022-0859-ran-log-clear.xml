<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0859 — Event Log Clearing (snatch) | Status: experimental | Sigma ID: 6fea00fb-6ab8-5348-9ddd-2303df3ce0e0 -->
  <rule id="265000" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0859 — Event Log Clearing (snatch)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>