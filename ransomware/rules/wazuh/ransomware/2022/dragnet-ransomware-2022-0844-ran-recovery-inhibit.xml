<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0844 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: eacd2ea9-d541-528f-bc75-c709351cc52e -->
  <rule id="717486" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0844 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>