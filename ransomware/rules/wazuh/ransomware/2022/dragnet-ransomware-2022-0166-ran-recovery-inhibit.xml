<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0166 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: fa896f92-d311-537b-99de-d651346ec20b -->
  <rule id="514351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0166 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>