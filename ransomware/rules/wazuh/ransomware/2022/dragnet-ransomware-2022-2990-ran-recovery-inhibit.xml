<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2990 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 10157bef-15e1-56f8-b989-df15791c3a4d -->
  <rule id="900382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2990 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>