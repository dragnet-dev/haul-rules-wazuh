<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2490 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d364c32a-e78e-532a-a614-75860fd828da -->
  <rule id="438363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2490 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>