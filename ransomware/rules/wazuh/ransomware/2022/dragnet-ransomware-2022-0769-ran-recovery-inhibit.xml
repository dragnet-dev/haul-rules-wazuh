<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0769 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 5232155b-df2c-556e-a0ad-df3a78e1effa -->
  <rule id="832155" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0769 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>