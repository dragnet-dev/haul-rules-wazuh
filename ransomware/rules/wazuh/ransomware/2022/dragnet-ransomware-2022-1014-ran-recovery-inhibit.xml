<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1014 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: bc589a0c-7e6e-57f9-b896-882b110adecc -->
  <rule id="417434" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1014 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>