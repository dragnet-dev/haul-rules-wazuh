<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1553 — Event Log Clearing (medusalocker) | Status: deprecated | Sigma ID: 4cec7eb2-e800-507e-824e-aff3414eb5e0 -->
  <rule id="550846" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1553 — Event Log Clearing (medusalocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>