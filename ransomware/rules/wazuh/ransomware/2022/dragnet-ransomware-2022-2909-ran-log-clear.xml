<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2909 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: c3f6da76-dfe1-59f8-b57e-bcf0b10118d8 -->
  <rule id="678234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2909 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>