<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1377 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ded94d14-d29b-580a-b384-f919f27a73a0 -->
  <rule id="405517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1377 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>