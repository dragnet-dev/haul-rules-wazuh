<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2771 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: e64e50cf-77d7-5890-afe5-e3f266a35af0 -->
  <rule id="643850" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2771 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>