<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2704 — Recovery Inhibition (bitlocker) | Status: deprecated | Sigma ID: 5b47f382-153d-5aae-bc85-01664d1a7e0b -->
  <rule id="663673" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2704 — Recovery Inhibition (bitlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>