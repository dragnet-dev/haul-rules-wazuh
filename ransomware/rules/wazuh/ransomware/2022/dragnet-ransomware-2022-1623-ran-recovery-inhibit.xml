<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1623 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 03a3058e-f382-54de-afa7-1e158957cb43 -->
  <rule id="428942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1623 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>