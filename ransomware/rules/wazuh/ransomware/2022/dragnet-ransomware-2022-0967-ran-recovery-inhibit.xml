<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0967 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 50074eae-441b-5006-9a9c-32e6bfc2c92c -->
  <rule id="319178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0967 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>