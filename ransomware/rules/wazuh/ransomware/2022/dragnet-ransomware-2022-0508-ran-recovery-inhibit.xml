<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0508 — Recovery Inhibition (cuba) | Status: deprecated | Sigma ID: 460576e8-fc07-5aeb-9e52-21a52af88aac -->
  <rule id="269230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0508 — Recovery Inhibition (cuba)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
