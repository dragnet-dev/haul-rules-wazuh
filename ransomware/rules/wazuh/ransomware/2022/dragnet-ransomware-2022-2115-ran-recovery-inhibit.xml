<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2115 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 20408663-23f9-55d9-a48c-1f4a08dffec3 -->
  <rule id="340866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2115 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>