<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2076 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: c4978ea6-e54d-5685-bd92-e43ebc2787b1 -->
  <rule id="299662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2076 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>