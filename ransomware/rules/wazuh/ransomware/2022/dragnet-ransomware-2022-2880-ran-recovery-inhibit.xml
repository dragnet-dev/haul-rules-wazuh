<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2880 — Recovery Inhibition (icefire) | Status: deprecated | Sigma ID: 87853f3d-f911-5d59-81ab-492f348184d8 -->
  <rule id="605663" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2880 — Recovery Inhibition (icefire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>