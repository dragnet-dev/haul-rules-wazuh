<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2444 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 6d6e8e4b-2421-5b60-8f7f-ffb2069d4e17 -->
  <rule id="208142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2444 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>