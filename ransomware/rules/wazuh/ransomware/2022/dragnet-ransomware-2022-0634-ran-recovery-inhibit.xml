<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0634 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: f1941d26-9aa0-5c26-aedb-565a3f334a81 -->
  <rule id="731069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0634 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>