<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0409 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: fc072068-14f5-5d7f-80e2-8c5cee95e914 -->
  <rule id="820720" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0409 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>