<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2270 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: fa36d74b-1952-513a-95c9-efaec4ab9e3b -->
  <rule id="505897" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2270 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>