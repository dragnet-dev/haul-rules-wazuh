<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0942 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 2ebff2d6-b76a-55a9-b3b0-873e28e1f37a -->
  <rule id="214872" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0942 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>