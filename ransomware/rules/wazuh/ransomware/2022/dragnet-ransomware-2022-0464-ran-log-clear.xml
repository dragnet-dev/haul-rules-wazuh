<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0464 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: 2a93e9e3-ee74-5ed8-9c6a-9caf9e141cea -->
  <rule id="292478" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0464 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>