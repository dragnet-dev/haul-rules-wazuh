<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3161 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: 0fd83c8c-39c1-54c3-a017-629eb7fb81a1 -->
  <rule id="561408" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3161 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>