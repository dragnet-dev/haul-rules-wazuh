<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1641 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: fe7b107e-3936-5e00-989c-7feb09cd5e26 -->
  <rule id="576310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1641 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>