<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1836 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 84b9e449-83d1-598c-ade6-44978e4739ac -->
  <rule id="469584" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1836 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>