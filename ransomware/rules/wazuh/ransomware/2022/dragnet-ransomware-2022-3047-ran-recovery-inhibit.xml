<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3047 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 82bbe6be-9621-591e-ac9d-1a7c56585f67 -->
  <rule id="788786" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3047 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>