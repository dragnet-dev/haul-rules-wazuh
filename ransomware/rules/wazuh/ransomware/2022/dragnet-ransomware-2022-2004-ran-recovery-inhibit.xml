<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2004 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: da4690e9-2d16-5dc9-b823-765424f92ec7 -->
  <rule id="484690" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2004 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>