<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0056 — Recovery Inhibition (mindware) | Status: deprecated | Sigma ID: 4e9623f6-195a-5f6a-bd09-2066eba134a7 -->
  <rule id="133983" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0056 — Recovery Inhibition (mindware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>