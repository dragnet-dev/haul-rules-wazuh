<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2783 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: db02599f-7977-5a7e-8485-65d762b7e7f4 -->
  <rule id="490259" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2783 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>