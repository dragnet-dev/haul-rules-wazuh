<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2639 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 08bc0ec3-736d-5fac-a40e-5bb07c56459e -->
  <rule id="424396" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2639 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>