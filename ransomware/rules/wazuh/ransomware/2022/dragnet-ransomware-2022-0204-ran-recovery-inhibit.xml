<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0204 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: ad279970-057e-54df-a297-d30ce8d7ebeb -->
  <rule id="932799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0204 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>