<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1554 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 5104c4fd-2ebd-519e-a118-86406b6cc2f5 -->
  <rule id="568239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1554 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>