<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1209 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 1f76bfd0-b60e-5c48-9b6b-af0b7230202e -->
  <rule id="511965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1209 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>