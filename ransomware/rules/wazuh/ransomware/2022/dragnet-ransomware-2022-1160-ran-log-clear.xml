<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1160 — Event Log Clearing (suncrypt) | Status: deprecated | Sigma ID: 22e9b2f9-d1f1-5153-b46f-136639c74fc1 -->
  <rule id="494447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1160 — Event Log Clearing (suncrypt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>