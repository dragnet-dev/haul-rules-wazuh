<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1017 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: aad8f71b-e8bb-57da-a321-91c5bd87aa35 -->
  <rule id="874237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1017 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
