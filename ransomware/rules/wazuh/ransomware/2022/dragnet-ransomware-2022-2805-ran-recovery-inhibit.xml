<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2805 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: fbc6589a-7408-560e-ba9b-81d9f464ed39 -->
  <rule id="528658" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2805 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>