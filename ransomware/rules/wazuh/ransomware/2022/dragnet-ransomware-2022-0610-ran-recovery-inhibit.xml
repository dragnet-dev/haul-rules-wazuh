<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0610 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: e1ee7b93-7354-55f4-8a2b-c150fe889bc3 -->
  <rule id="513563" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0610 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>