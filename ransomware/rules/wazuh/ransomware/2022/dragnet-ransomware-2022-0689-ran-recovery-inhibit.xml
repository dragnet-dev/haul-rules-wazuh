<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0689 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: db5f2f79-310a-5f1a-b080-43ceb69b04dd -->
  <rule id="321647" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0689 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>