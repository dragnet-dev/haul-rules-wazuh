<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2802 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: 8aee5a4f-5971-5602-80e7-3b945bfa2652 -->
  <rule id="390650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2802 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>