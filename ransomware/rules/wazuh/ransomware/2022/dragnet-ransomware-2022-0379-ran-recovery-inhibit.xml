<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0379 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: ca9d9edf-8a79-5136-8737-ead9490c52ab -->
  <rule id="796478" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0379 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>