<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1862 — Recovery Inhibition (onyx) | Status: deprecated | Sigma ID: fde88172-8182-5e70-822a-c8613cbed4c5 -->
  <rule id="562881" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1862 — Recovery Inhibition (onyx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>