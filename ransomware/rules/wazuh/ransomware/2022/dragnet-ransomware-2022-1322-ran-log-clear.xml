<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1322 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: a56ff59d-4dcc-5c9d-a243-f8c5da0be959 -->
  <rule id="105915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1322 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>