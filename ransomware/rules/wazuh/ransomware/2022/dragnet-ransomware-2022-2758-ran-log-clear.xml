<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2758 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 1e37d7f1-a2ac-5fac-9f64-ab8147f42849 -->
  <rule id="676927" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2758 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>