<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1291 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 6dece95f-3c83-56dd-81d7-bf95d1c7125f -->
  <rule id="102549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1291 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>