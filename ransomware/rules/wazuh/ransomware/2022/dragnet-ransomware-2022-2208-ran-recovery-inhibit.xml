<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2208 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 6eeb16b7-be8e-5601-8cbe-490bd1a06e03 -->
  <rule id="239516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2208 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>