<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1508 — Recovery Inhibition (medusalocker) | Status: deprecated | Sigma ID: 27522035-658a-5560-8dec-c05a3fbd1c24 -->
  <rule id="152203" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1508 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>