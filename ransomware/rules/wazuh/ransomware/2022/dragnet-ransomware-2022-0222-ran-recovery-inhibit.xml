<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0222 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 91157b83-470d-5a09-b323-2cc9b947d084 -->
  <rule id="658523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0222 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>