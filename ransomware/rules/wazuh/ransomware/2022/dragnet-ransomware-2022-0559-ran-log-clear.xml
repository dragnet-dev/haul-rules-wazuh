<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0559 — Event Log Clearing (kelvinsecurity) | Status: deprecated | Sigma ID: a84dc594-70e3-5396-9226-e7c302dbb7a6 -->
  <rule id="177245" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0559 — Event Log Clearing (kelvinsecurity)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>