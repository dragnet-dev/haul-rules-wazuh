<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2437 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: df804db6-acf2-5fe0-ae33-68c20f20ff63 -->
  <rule id="980877" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2437 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>