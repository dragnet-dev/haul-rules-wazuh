<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1889 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: b1990fa2-c900-5156-9f4c-4bb6ec2ed29d -->
  <rule id="991855" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1889 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>