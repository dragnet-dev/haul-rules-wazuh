<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0956 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c94fd72e-dea8-5117-b51a-582e82dea2df -->
  <rule id="715177" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0956 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>