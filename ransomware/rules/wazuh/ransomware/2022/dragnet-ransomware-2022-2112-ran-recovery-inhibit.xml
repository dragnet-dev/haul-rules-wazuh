<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2112 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 176ae807-544d-5a13-af50-241b6374881f -->
  <rule id="123080" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2112 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>