<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1910 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: c1a39a6a-e8ad-5bd4-ae51-5c108814c391 -->
  <rule id="514234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1910 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>