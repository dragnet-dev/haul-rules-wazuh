<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0832 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 1521e436-9ef0-5dbe-a1f4-cc70e1df1359 -->
  <rule id="735043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0832 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>