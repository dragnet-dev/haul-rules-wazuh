<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1759 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: c88fa686-c418-5b72-a3c5-edc8c9b180f3 -->
  <rule id="699786" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1759 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>