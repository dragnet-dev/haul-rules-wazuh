<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3054 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 42fd3c0a-a466-51e0-abfa-d1bc9dc84038 -->
  <rule id="960860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3054 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
