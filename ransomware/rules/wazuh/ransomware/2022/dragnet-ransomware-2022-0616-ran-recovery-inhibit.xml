<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0616 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 8f22363a-e8b6-5607-a27d-7090f30d6d4f -->
  <rule id="632236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0616 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>