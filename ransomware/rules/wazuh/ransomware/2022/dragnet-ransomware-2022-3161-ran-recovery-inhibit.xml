<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3161 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 99ed24c2-0479-5e47-9853-40e7e2081229 -->
  <rule id="858124" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3161 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>