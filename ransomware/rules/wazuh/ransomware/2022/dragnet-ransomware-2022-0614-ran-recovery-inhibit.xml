<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0614 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: ff75fa97-091c-5f57-82e1-7371bcf36b5e -->
  <rule id="347450" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0614 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>