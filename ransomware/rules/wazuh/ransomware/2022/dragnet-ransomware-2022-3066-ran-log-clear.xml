<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3066 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 7cb3c67c-2538-502a-ac2f-906e38a3e6f3 -->
  <rule id="592606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3066 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>