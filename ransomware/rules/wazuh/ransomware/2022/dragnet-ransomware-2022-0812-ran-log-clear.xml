<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0812 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: d3c850d6-eec6-563e-b4b2-c1c1ea7b382c -->
  <rule id="440850" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0812 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>