<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0542 — Recovery Inhibition (monti) | Status: deprecated | Sigma ID: b60821e6-3183-5d39-847c-995e719b6971 -->
  <rule id="360821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0542 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>