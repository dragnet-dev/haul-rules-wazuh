<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1347 — Event Log Clearing (pandora) | Status: deprecated | Sigma ID: 448fb6a8-dede-5ea7-9631-1fa095d56d11 -->
  <rule id="349396" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1347 — Event Log Clearing (pandora)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>