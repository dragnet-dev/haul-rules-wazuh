<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3005 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 441264e4-75e2-5077-846a-0bc826560ad1 -->
  <rule id="860238" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3005 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>