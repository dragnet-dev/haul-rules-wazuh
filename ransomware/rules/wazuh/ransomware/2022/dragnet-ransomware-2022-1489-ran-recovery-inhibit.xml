<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1489 — Recovery Inhibition (midas) | Status: deprecated | Sigma ID: 2626ba3a-8eb2-5ec0-b51f-43f841de4001 -->
  <rule id="524423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1489 — Recovery Inhibition (midas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
