<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0653 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 637d237b-5dff-5f7d-9fec-b392301167d3 -->
  <rule id="220523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0653 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>