<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0554 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 61d0fd25-4ee7-5d68-94a1-96e1cbed4676 -->
  <rule id="832093" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0554 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>