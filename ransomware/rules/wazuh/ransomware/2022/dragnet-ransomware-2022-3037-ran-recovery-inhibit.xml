<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3037 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: d578cb64-3eaf-5559-8813-e11ea383352a -->
  <rule id="876171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3037 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>