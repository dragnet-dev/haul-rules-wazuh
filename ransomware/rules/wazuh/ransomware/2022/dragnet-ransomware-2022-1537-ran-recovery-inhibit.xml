<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1537 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 9cfd018f-698e-57ea-9e57-081bff2380d1 -->
  <rule id="518901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1537 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>