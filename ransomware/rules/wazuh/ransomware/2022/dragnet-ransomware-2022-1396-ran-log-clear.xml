<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1396 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 2ebd00dd-43e8-5b1f-afa0-e6fb3a5fb7ac -->
  <rule id="396500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1396 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>