<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0554 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 64653b75-42c5-528c-8fb6-f51b1b08b391 -->
  <rule id="234459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0554 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>