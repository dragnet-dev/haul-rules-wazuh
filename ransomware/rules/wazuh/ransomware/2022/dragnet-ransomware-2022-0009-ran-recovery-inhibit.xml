<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0009 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 0f9142df-be6f-5615-9e7c-5730f73295cd -->
  <rule id="846285" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0009 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>