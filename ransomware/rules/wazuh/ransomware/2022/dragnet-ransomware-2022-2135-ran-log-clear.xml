<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2135 — Event Log Clearing (lorenz) | Status: deprecated | Sigma ID: 10548cb8-cd24-5385-8e7e-9b3bb5239517 -->
  <rule id="100491" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2135 — Event Log Clearing (lorenz)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>