<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1212 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 22c25b35-156f-5ce3-bb9a-c3e604d736de -->
  <rule id="528113" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1212 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>