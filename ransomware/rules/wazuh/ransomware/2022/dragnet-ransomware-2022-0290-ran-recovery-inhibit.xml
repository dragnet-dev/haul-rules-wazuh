<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0290 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: c9d6508a-451d-57d0-88a5-10127b2b04c3 -->
  <rule id="377650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0290 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>