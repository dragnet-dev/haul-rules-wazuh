<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3007 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: 6e9035f3-3b74-5463-9d36-c1bf284a60a9 -->
  <rule id="309035" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3007 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>