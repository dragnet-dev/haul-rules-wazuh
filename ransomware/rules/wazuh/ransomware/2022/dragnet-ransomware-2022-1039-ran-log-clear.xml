<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1039 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 2e804dd1-f3d1-55fd-af71-f2d5d8c4e731 -->
  <rule id="382045" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1039 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>