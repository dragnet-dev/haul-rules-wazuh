<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0934 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: ad29256a-a218-55a0-9a2f-a904b2b25cd8 -->
  <rule id="932925" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0934 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>