<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2608 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: da483d4e-e524-5592-a948-a98d34dfbacf -->
  <rule id="895741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2608 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>