<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1515 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: 9b174b7a-4b7d-5e19-87fd-eeaa64781f06 -->
  <rule id="782795" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1515 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>