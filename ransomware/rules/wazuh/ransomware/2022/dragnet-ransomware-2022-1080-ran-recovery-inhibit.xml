<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1080 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 86cd540d-7a7d-5563-a154-e9d555fcdd3a -->
  <rule id="522154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1080 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>