<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1078 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: d83c64fd-acff-563f-9a02-175d8c5b665e -->
  <rule id="514064" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1078 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>