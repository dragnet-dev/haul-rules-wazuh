<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1765 — Event Log Clearing (mallox) | Status: deprecated | Sigma ID: 45f1a60b-76bb-5a99-bd9c-f731b0f3bd59 -->
  <rule id="376266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1765 — Event Log Clearing (mallox)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>