<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0415 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: cad6ca67-146a-5277-8f9f-678f34d8ad9e -->
  <rule id="308938" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0415 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>