<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2706 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 8bfcab2e-3c66-550f-bb5a-ca891f8d6ec4 -->
  <rule id="274187" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2706 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>