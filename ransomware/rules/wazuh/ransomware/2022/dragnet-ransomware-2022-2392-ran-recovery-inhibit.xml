<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2392 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: e0ad159b-bcaa-596d-adfa-89f4bd280650 -->
  <rule id="101315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2392 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>