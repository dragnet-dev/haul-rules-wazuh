<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3041 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: e2f8e3f9-ed25-50bf-97a8-1a4cfcb336e0 -->
  <rule id="160623" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3041 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>