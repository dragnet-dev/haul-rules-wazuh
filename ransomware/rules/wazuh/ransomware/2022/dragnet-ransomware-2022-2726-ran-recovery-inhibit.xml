<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2726 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: deb54f6e-5d3d-52ab-917e-abe62809adb0 -->
  <rule id="401679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2726 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
