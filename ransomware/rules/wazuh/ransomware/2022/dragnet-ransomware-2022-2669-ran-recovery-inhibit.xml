<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2669 — Recovery Inhibition (karakurt) | Status: experimental | Sigma ID: 692df846-4377-5a77-8849-e37063618c41 -->
  <rule id="973758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2669 — Recovery Inhibition (karakurt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
