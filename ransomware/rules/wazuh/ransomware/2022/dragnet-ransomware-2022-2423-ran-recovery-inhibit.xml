<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2423 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 8a43f466-5f56-5449-8516-970e99caa138 -->
  <rule id="515034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2423 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>