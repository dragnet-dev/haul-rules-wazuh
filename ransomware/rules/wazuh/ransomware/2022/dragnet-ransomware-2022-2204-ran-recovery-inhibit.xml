<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2204 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7ecc773a-7ca8-559e-9e20-d0f86c452185 -->
  <rule id="646077" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2204 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>