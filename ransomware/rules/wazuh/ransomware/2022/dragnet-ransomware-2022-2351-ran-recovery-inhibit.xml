<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2351 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 45019181-4ab6-58f7-b918-7fade96cb7d0 -->
  <rule id="101918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2351 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>