  <rule id="688159" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0807 — Recovery Inhibition (kelvinsecurity)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
