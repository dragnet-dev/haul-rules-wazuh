<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2138 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: ecec7724-559e-50a2-bdaa-d64bdc4aba11 -->
  <rule id="765277" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2138 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>