<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2078 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 10f47bc9-c4bd-58be-a257-36daf89e5b02 -->
  <rule id="992220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2078 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>