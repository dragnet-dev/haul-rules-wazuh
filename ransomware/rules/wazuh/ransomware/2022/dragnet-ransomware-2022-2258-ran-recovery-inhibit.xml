<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2258 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f58ce0d3-fa25-5874-b016-2ba1c6f350f1 -->
  <rule id="490540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2258 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>