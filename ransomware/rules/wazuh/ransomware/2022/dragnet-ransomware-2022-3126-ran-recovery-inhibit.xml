<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3126 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7b8a155b-b866-5ec0-8f87-4cc0f9104839 -->
  <rule id="281815" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3126 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>