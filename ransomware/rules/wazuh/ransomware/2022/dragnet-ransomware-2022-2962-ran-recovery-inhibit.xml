<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2962 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 5fdc5713-a854-5011-961d-d7c80ade2406 -->
  <rule id="754057" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2962 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>