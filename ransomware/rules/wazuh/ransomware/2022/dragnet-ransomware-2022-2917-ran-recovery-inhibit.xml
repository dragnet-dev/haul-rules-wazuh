<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2917 — Recovery Inhibition (bitlocker) | Status: deprecated | Sigma ID: f7d9cd46-6ed0-5cc3-ae6a-f39e14859d7f -->
  <rule id="266509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2917 — Recovery Inhibition (bitlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>