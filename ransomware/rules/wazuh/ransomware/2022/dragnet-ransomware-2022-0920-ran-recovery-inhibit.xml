<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0920 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 35bb8902-9f0d-5066-997d-cb494a65a330 -->
  <rule id="247890" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0920 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>