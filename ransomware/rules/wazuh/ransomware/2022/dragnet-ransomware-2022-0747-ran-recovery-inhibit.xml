<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0747 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 659a09b0-de20-5a58-ad5d-4202d6e5aec9 -->
  <rule id="255409" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0747 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>