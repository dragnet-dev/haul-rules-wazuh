<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0727 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 1337c91d-2ad3-598d-bb36-da74df97fc3f -->
  <rule id="440491" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0727 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
