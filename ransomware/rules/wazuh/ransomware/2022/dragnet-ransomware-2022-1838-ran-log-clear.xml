<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1838 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: a00a0b1f-6c95-5bf4-992f-814a6c9ad150 -->
  <rule id="861611" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1838 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>