<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1015 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 432a03a4-3109-526a-be4c-8c30cb3b936c -->
  <rule id="375258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1015 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>