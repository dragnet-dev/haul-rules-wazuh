<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2458 — Event Log Clearing (bianlian) | Status: deprecated | Sigma ID: 0fa667e9-d31d-58d5-bbf7-e3ffd91a884a -->
  <rule id="510686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2458 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>