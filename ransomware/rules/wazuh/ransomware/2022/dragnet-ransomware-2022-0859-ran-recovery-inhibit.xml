<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0859 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: befc000f-d0bb-590e-9d6d-9e5fa7f68760 -->
  <rule id="489200" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0859 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>