<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3166 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: 4efba1a5-4c45-5c1f-a23e-ab0bf44fa719 -->
  <rule id="635141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3166 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>