<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1380 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 1870eca3-7bf1-55fa-8712-66055d54bffa -->
  <rule id="563306" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1380 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>