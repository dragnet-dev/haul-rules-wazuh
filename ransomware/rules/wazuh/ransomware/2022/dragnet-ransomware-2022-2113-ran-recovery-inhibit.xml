<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2113 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 8cd38311-a589-5df1-8f53-da7c98321e65 -->
  <rule id="553383" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2113 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>