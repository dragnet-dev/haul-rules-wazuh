<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2541 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 3982ac54-ce83-53a5-aaf1-adee8fc16709 -->
  <rule id="219564" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2541 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>