<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1290 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 47029e27-2dca-5ec0-beea-528c7c0c8254 -->
  <rule id="424782" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1290 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>