<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1326 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: e66c7129-4554-5c5d-aae3-351257b96ee5 -->
  <rule id="646871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1326 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>