<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0953 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 464a059b-ffd9-5e4f-b127-5c560c100bc9 -->
  <rule id="334059" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0953 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
