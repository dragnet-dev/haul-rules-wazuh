<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0618 — Event Log Clearing (darkleakmarket) | Status: deprecated | Sigma ID: 89c44e96-a0f4-5084-9763-6b3f13a71425 -->
  <rule id="598318" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0618 — Event Log Clearing (darkleakmarket)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>