<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2831 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 23ad8ea0-6b33-505e-ad23-fad9817578da -->
  <rule id="318442" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2831 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>