<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2680 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: d9412ec5-bedb-5642-8682-98b8117bfae5 -->
  <rule id="530606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2680 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>