<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0454 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: a1b16de1-2243-5493-a8b1-e8072369cadc -->
  <rule id="903469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0454 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>