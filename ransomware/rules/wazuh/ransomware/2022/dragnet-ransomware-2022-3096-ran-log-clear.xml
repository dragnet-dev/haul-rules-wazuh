<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3096 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 10ffc9e6-ebb0-5545-876d-2f6c4dd702d9 -->
  <rule id="108478" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3096 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>