<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3142 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c22cf94c-027e-5123-a1f2-29a47f30db91 -->
  <rule id="530399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3142 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>