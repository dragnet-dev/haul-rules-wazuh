<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1202 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 9c041630-7fdb-5eb7-958d-eb78a66775ee -->
  <rule id="760416" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1202 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>