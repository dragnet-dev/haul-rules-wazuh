<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0803 — Recovery Inhibition (medusalocker) | Status: deprecated | Sigma ID: ad8a6e51-962b-5fae-bd9b-b634dc492500 -->
  <rule id="950990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0803 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>