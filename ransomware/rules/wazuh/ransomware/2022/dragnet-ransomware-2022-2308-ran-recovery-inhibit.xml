<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2308 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 07a757b1-feb6-5312-aaed-65263339a47a -->
  <rule id="264123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2308 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>