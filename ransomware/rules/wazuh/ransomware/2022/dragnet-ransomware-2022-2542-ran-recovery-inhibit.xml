<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2542 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 46719a09-b1c5-5fac-85af-7cbf7eb4a25e -->
  <rule id="375140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2542 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>