<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1120 — Event Log Clearing (royal) | Status: deprecated | Sigma ID: e4834ca0-76a7-5417-a456-d1688915ce23 -->
  <rule id="617356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1120 — Event Log Clearing (royal)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>