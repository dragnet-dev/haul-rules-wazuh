<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2061 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 85e1954e-beff-5f8f-97a6-afa009b32581 -->
  <rule id="574195" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2061 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>