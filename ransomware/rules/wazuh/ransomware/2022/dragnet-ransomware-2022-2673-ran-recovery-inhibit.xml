<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2673 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d68c890e-ce41-5ec5-a50a-1b257147124a -->
  <rule id="490089" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2673 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>