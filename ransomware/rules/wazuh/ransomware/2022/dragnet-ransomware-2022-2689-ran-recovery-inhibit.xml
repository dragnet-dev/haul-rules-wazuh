<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2689 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 5574491f-61f4-5d97-8966-a30964755a15 -->
  <rule id="274491" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2689 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>