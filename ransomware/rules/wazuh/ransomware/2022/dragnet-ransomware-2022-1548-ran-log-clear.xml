<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1548 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: e8bff941-3ba6-5a1c-9927-4bbf9f6188a0 -->
  <rule id="792799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1548 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>