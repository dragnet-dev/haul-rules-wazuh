<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0681 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 01ab1b3a-95ad-5312-9334-31fc36c013f0 -->
  <rule id="235578" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0681 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
