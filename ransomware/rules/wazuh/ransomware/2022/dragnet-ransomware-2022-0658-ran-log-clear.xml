<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0658 — Event Log Clearing (yanluowang) | Status: deprecated | Sigma ID: fe049892-e39c-5e0e-97a1-e13c2103ee61 -->
  <rule id="840498" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0658 — Event Log Clearing (yanluowang)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>