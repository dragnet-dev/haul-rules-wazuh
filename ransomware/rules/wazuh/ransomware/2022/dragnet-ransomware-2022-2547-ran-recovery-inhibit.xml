<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2547 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 8160abc3-c902-5653-9e6d-a0893f2ce855 -->
  <rule id="389131" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2547 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>