<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0577 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: c2225067-9093-5322-8400-9577d8971db7 -->
  <rule id="422250" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0577 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>