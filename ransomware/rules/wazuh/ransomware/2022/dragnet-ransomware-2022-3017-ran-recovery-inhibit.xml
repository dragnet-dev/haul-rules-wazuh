<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3017 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 6a8e1583-c08f-5032-8988-9257120de223 -->
  <rule id="910215" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3017 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>