<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1288 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: afcb30ca-4551-571f-837e-dd0301ff53e2 -->
  <rule id="100330" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1288 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>