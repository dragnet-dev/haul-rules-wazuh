<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0652 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 3fe79beb-e3f2-57aa-8249-ce10a29e5050 -->
  <rule id="836475" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0652 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>