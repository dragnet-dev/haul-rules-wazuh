<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0742 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: d59496da-cfae-5ff1-82a2-469c697af45e -->
  <rule id="559496" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0742 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>