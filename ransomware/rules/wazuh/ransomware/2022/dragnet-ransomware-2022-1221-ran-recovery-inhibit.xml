<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1221 — Recovery Inhibition (karakurt) | Status: experimental | Sigma ID: ed9f3bcf-33f5-5b4c-a400-04bff3c6e52f -->
  <rule id="792699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1221 — Recovery Inhibition (karakurt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>