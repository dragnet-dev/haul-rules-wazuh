  <rule id="468207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0247 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
