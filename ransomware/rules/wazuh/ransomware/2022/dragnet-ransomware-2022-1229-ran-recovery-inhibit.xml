<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1229 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 026cda1f-61e1-5142-8336-d5d53e9888c0 -->
  <rule id="297861" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1229 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>