<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0351 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 22966809-339c-550e-b38d-d2011e8ccad2 -->
  <rule id="596680" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0351 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>