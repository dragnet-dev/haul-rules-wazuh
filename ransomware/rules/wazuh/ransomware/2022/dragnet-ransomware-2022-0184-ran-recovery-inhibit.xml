<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0184 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 5950ec6e-1b01-57ce-b32c-03fa322eb01c -->
  <rule id="723436" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0184 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>