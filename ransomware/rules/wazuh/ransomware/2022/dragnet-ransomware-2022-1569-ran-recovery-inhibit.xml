<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1569 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: e1cbb7c4-04e7-512e-8321-a1f2199d4508 -->
  <rule id="507957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1569 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>