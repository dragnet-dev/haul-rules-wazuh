<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2807 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: e8a643ba-91cd-5eee-8d9e-858128f41961 -->
  <rule id="678643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2807 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>