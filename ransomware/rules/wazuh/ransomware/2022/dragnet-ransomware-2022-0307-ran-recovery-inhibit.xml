<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0307 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: e127da03-451f-577b-9303-e31b2d584fc5 -->
  <rule id="116730" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0307 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>