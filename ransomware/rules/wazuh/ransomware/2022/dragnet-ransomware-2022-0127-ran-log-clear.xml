<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0127 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 0cb2d79c-ad80-5b09-b6f3-41ea9e26bb4b -->
  <rule id="652579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0127 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>