<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0739 — Event Log Clearing (ragnarlocker) | Status: deprecated | Sigma ID: ad592fe9-9263-5db0-b3e1-120be57efcf5 -->
  <rule id="177487" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0739 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>