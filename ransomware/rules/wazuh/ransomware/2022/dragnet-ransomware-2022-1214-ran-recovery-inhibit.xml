<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1214 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7f04416c-a7f8-5837-8e78-0cbdf3335a52 -->
  <rule id="470441" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1214 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>