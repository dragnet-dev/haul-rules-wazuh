<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1711 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 56f889f7-822f-55e5-833c-6e044b2548b1 -->
  <rule id="290239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1711 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>