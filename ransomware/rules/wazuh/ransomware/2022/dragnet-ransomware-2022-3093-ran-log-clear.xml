<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3093 — Event Log Clearing (ragnarlocker) | Status: deprecated | Sigma ID: fd36b6d9-30c3-59c6-aa9b-11ff11a55180 -->
  <rule id="553876" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3093 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>