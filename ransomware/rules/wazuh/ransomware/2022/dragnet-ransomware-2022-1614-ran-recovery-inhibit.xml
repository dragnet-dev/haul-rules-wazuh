<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1614 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 1c074ed6-a502-5edf-87af-d8744cd86240 -->
  <rule id="987181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1614 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>