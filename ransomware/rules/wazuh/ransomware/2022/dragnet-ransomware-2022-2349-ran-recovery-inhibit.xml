<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2349 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: a7e2004b-55d3-570f-8d40-ef30097b7e15 -->
  <rule id="926200" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2349 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>