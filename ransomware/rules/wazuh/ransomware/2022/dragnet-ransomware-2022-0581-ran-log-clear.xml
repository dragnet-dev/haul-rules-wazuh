<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0581 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 308b336f-4a5c-54b3-bf95-fab5b6eb19c0 -->
  <rule id="539336" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0581 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>