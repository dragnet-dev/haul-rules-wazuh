<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2303 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: a7623933-9407-5bf9-accb-bed25a912375 -->
  <rule id="276239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2303 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>