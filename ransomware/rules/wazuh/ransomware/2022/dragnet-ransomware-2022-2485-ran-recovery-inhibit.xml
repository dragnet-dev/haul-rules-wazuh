<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2485 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 4df82c33-17d8-5865-8caa-73e9d46562d2 -->
  <rule id="296524" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2485 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>