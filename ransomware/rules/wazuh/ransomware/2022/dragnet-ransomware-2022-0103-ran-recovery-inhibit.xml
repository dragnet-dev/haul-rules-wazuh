<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0103 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: befb8151-8623-5de8-b6b1-95b8c2926814 -->
  <rule id="489181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0103 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>