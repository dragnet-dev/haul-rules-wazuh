<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0220 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 52fe79c7-572b-54ce-a88b-3607cb7113c9 -->
  <rule id="556679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0220 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>