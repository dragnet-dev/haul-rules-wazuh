<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2841 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: d600f25d-2c77-5d10-b7cd-3bbcd2cf66df -->
  <rule id="476152" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2841 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>