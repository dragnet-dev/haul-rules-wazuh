<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1725 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: aae2341f-aa5a-5972-9d1b-dc9c31fef850 -->
  <rule id="134234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1725 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>