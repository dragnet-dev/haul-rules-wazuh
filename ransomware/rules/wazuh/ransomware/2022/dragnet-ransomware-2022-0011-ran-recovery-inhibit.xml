<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0011 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 0a69e23e-3e88-5447-8b07-fb1448a1370a -->
  <rule id="911823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0011 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>