<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0562 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 97f1936f-4146-5a27-8901-6ae6f8906ec5 -->
  <rule id="767193" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0562 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>