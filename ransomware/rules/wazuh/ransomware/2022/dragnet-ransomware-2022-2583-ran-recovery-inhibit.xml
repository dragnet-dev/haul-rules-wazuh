<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2583 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: d8af2fc4-6dd5-5909-9e76-9705791f9b9f -->
  <rule id="380527" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2583 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>