<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2540 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8bc25f73-7c37-51b0-9789-22d3f6b21521 -->
  <rule id="978015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2540 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>