<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0107 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 4cee8ece-0c62-58b9-8bd5-055d41ab90f3 -->
  <rule id="551182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0107 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>