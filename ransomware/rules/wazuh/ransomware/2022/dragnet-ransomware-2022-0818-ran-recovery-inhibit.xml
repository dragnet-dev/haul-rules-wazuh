<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0818 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: ababd3f1-7f56-57b9-9486-66529abf36ec -->
  <rule id="831653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0818 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>