<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2549 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 4b899030-5b46-599f-8c89-8bec296762f5 -->
  <rule id="489903" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2549 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>