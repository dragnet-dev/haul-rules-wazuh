<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0574 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 93d8c833-6fc1-5829-b37a-a7220e87b527 -->
  <rule id="703008" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0574 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>