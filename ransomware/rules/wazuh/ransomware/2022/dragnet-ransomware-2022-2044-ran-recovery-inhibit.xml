<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2044 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7c66b01d-243d-5668-bf45-0c05c8abc89b -->
  <rule id="294670" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2044 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>