<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1928 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 3596589e-661f-50d2-b35e-cd155f770371 -->
  <rule id="996589" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1928 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>