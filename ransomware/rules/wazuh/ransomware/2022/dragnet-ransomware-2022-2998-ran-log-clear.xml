<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2998 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: c154a90a-9fa5-5a30-a053-5968070f0231 -->
  <rule id="244749" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2998 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>