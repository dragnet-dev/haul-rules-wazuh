<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3159 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 70111277-e75e-5c81-960f-c63a92275861 -->
  <rule id="811127" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3159 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>