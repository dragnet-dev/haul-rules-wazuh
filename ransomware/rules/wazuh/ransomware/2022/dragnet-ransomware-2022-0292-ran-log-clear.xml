<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0292 — Event Log Clearing (bianlian) | Status: deprecated | Sigma ID: 978a0ea0-eef6-5de0-9b1f-8621483e66b2 -->
  <rule id="805294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0292 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>