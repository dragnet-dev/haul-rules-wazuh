<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1984 — Event Log Clearing (lorenz) | Status: deprecated | Sigma ID: e1695065-a7d9-5fc0-b8c3-51c7a7fe9124 -->
  <rule id="616950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1984 — Event Log Clearing (lorenz)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>