<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0615 — Event Log Clearing (ransomexx) | Status: deprecated | Sigma ID: 62477464-d3b6-5929-b0d3-0bf1fa6c384d -->
  <rule id="947746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0615 — Event Log Clearing (ransomexx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>