<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0346 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 8a0a2753-3bfd-5ea8-bc96-87b00505f626 -->
  <rule id="509027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0346 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
