<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0061 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 674dc646-84cc-5d1d-8291-9c736dbd8d86 -->
  <rule id="927646" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0061 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>