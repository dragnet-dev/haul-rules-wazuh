<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1648 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 53bb874c-b995-58de-82a1-b8b5079010c5 -->
  <rule id="575587" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1648 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>