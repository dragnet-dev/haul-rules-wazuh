<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0680 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 2552d62f-9510-53ec-99c8-fb3a774c1034 -->
  <rule id="584562" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0680 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>