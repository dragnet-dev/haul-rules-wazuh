<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1459 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: 147bfde7-03e1-5592-88d7-2073a63a38fb -->
  <rule id="782910" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1459 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
