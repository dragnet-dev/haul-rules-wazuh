<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2130 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 5a78d5c9-7c02-5443-a6a1-4088694ffe56 -->
  <rule id="652615" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2130 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>