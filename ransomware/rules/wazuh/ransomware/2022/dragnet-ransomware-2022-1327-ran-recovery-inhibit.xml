<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1327 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 8accfd68-bc83-5851-97c5-cc4dc55d40cf -->
  <rule id="196445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1327 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>