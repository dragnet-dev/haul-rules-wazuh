<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2800 — Event Log Clearing (lorenz) | Status: deprecated | Sigma ID: 861d6fd0-f3c3-5772-a2bc-e31de51ebc73 -->
  <rule id="506351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2800 — Event Log Clearing (lorenz)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>