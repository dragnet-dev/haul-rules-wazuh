<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2789 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: d5504afd-2864-5110-95dc-5f8f21653065 -->
  <rule id="468074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2789 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>