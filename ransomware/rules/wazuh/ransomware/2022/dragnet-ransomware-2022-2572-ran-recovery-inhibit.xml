<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2572 — Recovery Inhibition (onyx) | Status: deprecated | Sigma ID: e1fdec62-0137-505e-bd2a-69a623735d37 -->
  <rule id="405580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2572 — Recovery Inhibition (onyx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>