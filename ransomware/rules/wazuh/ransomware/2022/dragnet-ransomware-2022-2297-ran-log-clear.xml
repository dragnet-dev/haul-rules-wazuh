<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2297 — Event Log Clearing (icefire) | Status: deprecated | Sigma ID: ff1eda29-a359-57ca-90cc-ec6b6bb57157 -->
  <rule id="652698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2297 — Event Log Clearing (icefire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>