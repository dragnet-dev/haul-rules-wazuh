<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1029 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: ca73138c-2a8e-5e9a-8242-b7523e58abb5 -->
  <rule id="327313" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1029 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>