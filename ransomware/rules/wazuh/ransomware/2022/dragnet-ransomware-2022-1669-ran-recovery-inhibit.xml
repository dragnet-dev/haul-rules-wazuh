<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1669 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 5dde4a0e-c958-5572-b410-7c3b04e52448 -->
  <rule id="344874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1669 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>