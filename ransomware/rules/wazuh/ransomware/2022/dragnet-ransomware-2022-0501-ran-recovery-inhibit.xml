<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0501 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 6ff16af3-169b-5add-aa5b-bb3aa7328ece -->
  <rule id="265866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0501 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>