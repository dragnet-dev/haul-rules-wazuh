<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0137 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: d95b94f8-b5c7-5600-a3a6-2a11d07a0523 -->
  <rule id="533194" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0137 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>