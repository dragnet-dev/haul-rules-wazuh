<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1304 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: 18afa5c8-b6a6-5b2a-a334-8fc2edaf3417 -->
  <rule id="646172" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1304 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>