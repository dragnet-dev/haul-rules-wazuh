<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0481 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: c41ca140-54c2-5f46-99d0-6567285db3bd -->
  <rule id="578981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0481 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
