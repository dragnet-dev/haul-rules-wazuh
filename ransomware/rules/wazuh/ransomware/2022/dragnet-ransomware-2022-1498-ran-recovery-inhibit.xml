<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1498 — Recovery Inhibition (royal) | Status: deprecated | Sigma ID: 5e0e69ff-de4c-568f-bbe2-92ea106a85e2 -->
  <rule id="705469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1498 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
