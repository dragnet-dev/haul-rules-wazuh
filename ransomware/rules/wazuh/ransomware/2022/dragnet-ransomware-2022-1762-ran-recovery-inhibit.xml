<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1762 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: aa3b1575-1785-5155-b117-806e6066c48a -->
  <rule id="125915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1762 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>