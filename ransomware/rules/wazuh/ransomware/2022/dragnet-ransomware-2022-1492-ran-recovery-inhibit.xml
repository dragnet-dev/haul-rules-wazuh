<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1492 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 737caae6-199e-5527-aeba-5a3b38b9ea09 -->
  <rule id="421994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1492 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>