<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0728 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 1988f3f3-4c4b-530f-9ad2-322c8a50a978 -->
  <rule id="691743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0728 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>