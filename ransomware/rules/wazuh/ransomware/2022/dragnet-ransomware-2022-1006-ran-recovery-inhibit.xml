<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1006 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: df915138-f251-5316-a40a-ea1652257a3d -->
  <rule id="539151" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1006 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>