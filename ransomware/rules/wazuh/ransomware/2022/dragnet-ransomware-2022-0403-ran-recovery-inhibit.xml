<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0403 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 4f8b764b-83cc-5be9-89e7-5277d124ce9e -->
  <rule id="477976" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0403 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>