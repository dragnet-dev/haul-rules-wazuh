<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0987 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: aa85f497-4e13-5f68-a585-eca1bc2c9a1d -->
  <rule id="133754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0987 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>