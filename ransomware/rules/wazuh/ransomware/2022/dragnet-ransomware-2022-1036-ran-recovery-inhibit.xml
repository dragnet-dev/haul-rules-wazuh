<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1036 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: b420f323-16ba-5385-99d6-55d083a79c7b -->
  <rule id="127353" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1036 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>