<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0411 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: c91cc475-4063-5dc2-8f75-8e45a7bb30a5 -->
  <rule id="707004" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0411 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>