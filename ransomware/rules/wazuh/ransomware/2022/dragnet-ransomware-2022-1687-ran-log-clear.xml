<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1687 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 0d4bc9cc-59f7-5d96-b4ce-8d62a8c2bc5e -->
  <rule id="218876" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1687 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>