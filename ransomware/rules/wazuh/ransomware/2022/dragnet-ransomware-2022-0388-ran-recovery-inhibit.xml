<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0388 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 6d45851e-1535-5d09-8595-5fed95cdd328 -->
  <rule id="294585" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0388 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>