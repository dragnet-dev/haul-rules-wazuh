<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2953 — Recovery Inhibition (suncrypt) | Status: deprecated | Sigma ID: 32739412-544d-5970-ae89-3a9e1424e1fb -->
  <rule id="673941" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2953 — Recovery Inhibition (suncrypt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>