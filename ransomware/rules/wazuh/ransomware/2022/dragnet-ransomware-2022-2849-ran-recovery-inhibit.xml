<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2849 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 51e4bdde-695e-50be-a781-337823eee88a -->
  <rule id="426013" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2849 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>