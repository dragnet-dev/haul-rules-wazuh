<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2459 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 29b0ac65-d638-5279-ae3b-6fa6c3804234 -->
  <rule id="416172" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2459 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>