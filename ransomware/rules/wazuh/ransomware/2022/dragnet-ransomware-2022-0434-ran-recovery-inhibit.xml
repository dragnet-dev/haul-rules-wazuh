<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0434 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 71bdd54a-3588-5ace-97ef-90b8b74509ea -->
  <rule id="338535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0434 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>