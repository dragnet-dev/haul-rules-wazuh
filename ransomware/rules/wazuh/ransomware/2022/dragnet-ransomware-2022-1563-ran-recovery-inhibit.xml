<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1563 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 630b1f1e-5a35-5d9b-afa9-76f52efc0fd0 -->
  <rule id="814591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1563 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>