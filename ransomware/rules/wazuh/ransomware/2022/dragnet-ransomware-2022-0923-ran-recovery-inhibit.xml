<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0923 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 4435f0aa-ad90-500a-944d-5d77c099002d -->
  <rule id="656010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0923 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>