<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2325 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 8c350787-7c6c-59d8-8359-0259ec7182fa -->
  <rule id="603507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2325 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>