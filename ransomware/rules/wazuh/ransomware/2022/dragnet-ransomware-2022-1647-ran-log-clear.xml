<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1647 — Event Log Clearing (ransomexx) | Status: experimental | Sigma ID: 66bf1d1f-4e09-51fa-8b4f-efa163c9c107 -->
  <rule id="133949" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1647 — Event Log Clearing (ransomexx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>