<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2081 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: b66d1969-9908-5f03-8ac1-111af548d6e8 -->
  <rule id="166919" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2081 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>