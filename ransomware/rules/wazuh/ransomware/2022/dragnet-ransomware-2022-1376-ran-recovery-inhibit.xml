<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1376 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 12a4d7dd-5b94-58ac-a49d-42a28e487b01 -->
  <rule id="783645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1376 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>