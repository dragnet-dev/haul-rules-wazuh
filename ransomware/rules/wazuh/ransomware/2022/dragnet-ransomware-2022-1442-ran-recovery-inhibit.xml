<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1442 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 939322c8-b73f-5071-b536-973ebe81ac2c -->
  <rule id="729164" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1442 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>