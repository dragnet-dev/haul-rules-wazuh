<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1875 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: ce124332-956a-510d-91ad-b2b2a465f003 -->
  <rule id="361243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1875 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>