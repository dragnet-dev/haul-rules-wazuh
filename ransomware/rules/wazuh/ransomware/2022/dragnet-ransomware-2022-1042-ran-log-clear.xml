<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1042 — Event Log Clearing (ransomexx) | Status: experimental | Sigma ID: d00cc7d6-3f9f-53ff-9649-cf6c41f13722 -->
  <rule id="730047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1042 — Event Log Clearing (ransomexx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>