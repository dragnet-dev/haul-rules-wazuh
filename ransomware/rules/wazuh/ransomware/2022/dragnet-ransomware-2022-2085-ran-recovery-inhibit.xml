<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2085 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: caf52176-29e9-5b42-a462-412352e3e75f -->
  <rule id="647521" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2085 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>