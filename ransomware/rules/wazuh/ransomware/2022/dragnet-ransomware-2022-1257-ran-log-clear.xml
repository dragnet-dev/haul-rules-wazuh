<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1257 — Event Log Clearing (karakurt) | Status: deprecated | Sigma ID: 8f3d45d1-30a6-5d8e-83ef-9fbbe79bd77a -->
  <rule id="594145" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1257 — Event Log Clearing (karakurt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>