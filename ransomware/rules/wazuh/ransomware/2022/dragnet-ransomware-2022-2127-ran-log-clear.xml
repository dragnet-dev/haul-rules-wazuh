<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2127 — Event Log Clearing (quantum) | Status: deprecated | Sigma ID: fa2602fd-5177-5937-ae87-ca63a59065c1 -->
  <rule id="802602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2127 — Event Log Clearing (quantum)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>