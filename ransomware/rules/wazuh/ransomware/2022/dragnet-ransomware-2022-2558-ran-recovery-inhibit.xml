<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2558 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 72259522-310f-5f3b-a1ed-156197ed79ec -->
  <rule id="125952" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2558 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
