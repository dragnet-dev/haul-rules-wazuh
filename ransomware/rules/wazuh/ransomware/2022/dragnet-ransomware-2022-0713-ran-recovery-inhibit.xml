<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0713 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 12335c43-6c19-568b-bc25-1915e2ec5d95 -->
  <rule id="273724" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0713 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>