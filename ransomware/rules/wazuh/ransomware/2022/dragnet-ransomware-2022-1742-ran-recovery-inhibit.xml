<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1742 — Recovery Inhibition (royal) | Status: deprecated | Sigma ID: e4d13f90-56b3-5bab-ab01-d8647bd358e4 -->
  <rule id="207423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1742 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>