<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1999 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: eb5741ef-3c8c-58c6-bd6a-635ece75f2ce -->
  <rule id="655741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1999 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>