  <rule id="432051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0556 — Recovery Inhibition (cheers)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>