<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2931 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 8c7ac893-38d1-562c-866f-334b5309a485 -->
  <rule id="103648" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2931 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>