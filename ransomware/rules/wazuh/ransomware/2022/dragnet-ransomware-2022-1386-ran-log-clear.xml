<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1386 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: fedfa5e7-7b52-59e3-84af-894a81f0b3fa -->
  <rule id="243962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1386 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>