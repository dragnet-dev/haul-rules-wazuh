<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0051 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 49b20e27-9bf4-59fe-b279-b9042f02480f -->
  <rule id="472334" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0051 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>