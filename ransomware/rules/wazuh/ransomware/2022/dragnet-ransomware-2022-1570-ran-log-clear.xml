<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1570 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: 4c1bcd77-0672-5a07-8fe0-d11e9e7a01d2 -->
  <rule id="520077" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1570 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>