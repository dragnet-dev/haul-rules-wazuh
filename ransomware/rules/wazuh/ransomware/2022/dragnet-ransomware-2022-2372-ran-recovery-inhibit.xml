<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2372 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 67147fc5-e57a-5b8c-be05-5b58bb472a49 -->
  <rule id="274367" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2372 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
