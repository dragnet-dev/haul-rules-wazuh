<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1448 — Event Log Clearing (play) | Status: deprecated | Sigma ID: 2afa8ea1-18ae-5ef0-b2e0-61ed5d6cf22a -->
  <rule id="960462" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1448 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>