<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2901 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 1a65485f-0d02-5e0d-b9be-bc51e6de96c5 -->
  <rule id="965485" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2901 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>