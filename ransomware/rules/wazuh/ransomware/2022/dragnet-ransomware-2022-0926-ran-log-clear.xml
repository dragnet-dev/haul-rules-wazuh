<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0926 — Event Log Clearing (cheers) | Status: deprecated | Sigma ID: fa74126f-f0a8-51ef-8559-c7e97f6fb39c -->
  <rule id="807412" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0926 — Event Log Clearing (cheers)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>