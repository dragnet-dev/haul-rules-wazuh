<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1098 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: cdb3a8bc-a1d9-5118-8614-c3d977c2286c -->
  <rule id="866188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1098 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>