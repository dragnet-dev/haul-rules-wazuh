<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0721 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 77cd8f07-7e42-5006-8642-13f47696a4ab -->
  <rule id="586863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0721 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>