<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1025 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 8cb1493e-51d6-5460-97d0-8e51148b6ace -->
  <rule id="551149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1025 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>