<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2545 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 31604dfa-3a76-5b0d-a831-cccc3a5521da -->
  <rule id="990847" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2545 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>