<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1686 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 4d376b3b-2a82-5095-a17e-3284d6de6b87 -->
  <rule id="438027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1686 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>