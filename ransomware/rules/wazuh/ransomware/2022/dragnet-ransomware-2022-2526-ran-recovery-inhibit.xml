<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2526 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: b36679bf-7963-58e3-ada6-4ce8732d41eb -->
  <rule id="336679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2526 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
