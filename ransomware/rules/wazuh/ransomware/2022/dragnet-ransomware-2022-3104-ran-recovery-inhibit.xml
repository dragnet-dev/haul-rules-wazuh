<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3104 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 16c0b856-220c-568d-af22-ffba8391c83c -->
  <rule id="789185" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3104 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
