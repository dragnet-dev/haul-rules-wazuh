<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2993 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: c575ebd2-787a-5e61-948b-7fd24d55a751 -->
  <rule id="619435" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2993 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>