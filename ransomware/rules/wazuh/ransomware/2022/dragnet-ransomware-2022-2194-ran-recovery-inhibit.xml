<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2194 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: a6a3e307-5250-58d0-b210-8d66a7dc2244 -->
  <rule id="130223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2194 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>