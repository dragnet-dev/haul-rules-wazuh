<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2665 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 57f98442-17ae-5d3f-a391-b5130d2d9895 -->
  <rule id="379844" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2665 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>