<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1859 — Event Log Clearing (royal) | Status: deprecated | Sigma ID: dd22bf0e-91d4-5b60-8ed8-0214ebd9ef66 -->
  <rule id="363423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1859 — Event Log Clearing (royal)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>