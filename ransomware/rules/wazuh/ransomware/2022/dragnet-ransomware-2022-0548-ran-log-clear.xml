<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0548 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: 0455e6eb-9711-5448-85a0-c9ebcd8f3fdc -->
  <rule id="367150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0548 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>