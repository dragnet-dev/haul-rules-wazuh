<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0176 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: 1d141a78-6495-5c1a-80c5-d0976a2c7fea -->
  <rule id="262667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0176 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>