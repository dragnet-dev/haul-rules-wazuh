<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0695 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 2a892fac-75a6-5f46-b40d-471e4f5fe58f -->
  <rule id="280602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0695 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>