<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2637 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 9f172995-cb62-5a34-9f4d-77137ffbb2fe -->
  <rule id="791729" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2637 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
