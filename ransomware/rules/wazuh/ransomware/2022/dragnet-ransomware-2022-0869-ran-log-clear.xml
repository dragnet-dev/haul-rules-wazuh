<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0869 — Event Log Clearing (roadsweep) | Status: deprecated | Sigma ID: 165968b5-54f3-5382-8089-d57d6f5aa982 -->
  <rule id="955499" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0869 — Event Log Clearing (roadsweep)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>