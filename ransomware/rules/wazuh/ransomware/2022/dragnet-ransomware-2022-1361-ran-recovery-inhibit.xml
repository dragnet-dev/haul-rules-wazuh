<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1361 — Recovery Inhibition (alphv) | Status: deprecated | Sigma ID: af6e7d39-061c-58f1-901e-ad8e598b720d -->
  <rule id="997725" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1361 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>