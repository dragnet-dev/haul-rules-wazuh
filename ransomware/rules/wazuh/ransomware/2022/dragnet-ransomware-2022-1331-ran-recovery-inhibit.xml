<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1331 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: df09faf2-935b-5a1f-ae6f-74b310927821 -->
  <rule id="411354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1331 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>