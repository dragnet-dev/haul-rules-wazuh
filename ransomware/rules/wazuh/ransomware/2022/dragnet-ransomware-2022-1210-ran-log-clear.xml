<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1210 — Event Log Clearing (yanluowang) | Status: deprecated | Sigma ID: f3ec3b9b-8277-5ee8-a381-906d2746fb64 -->
  <rule id="104699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1210 — Event Log Clearing (yanluowang)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>