<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1383 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 5e56e630-9ee6-51b4-90bc-87d8385445c2 -->
  <rule id="713106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1383 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>