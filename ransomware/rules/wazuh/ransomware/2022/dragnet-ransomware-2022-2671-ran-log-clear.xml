<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2671 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: 816b15cd-9fa8-571a-9cc9-b1e19f80a396 -->
  <rule id="506715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2671 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>