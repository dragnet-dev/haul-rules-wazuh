<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1406 — Event Log Clearing (leaktheanalyst) | Status: deprecated | Sigma ID: f7cdbf46-6de0-5004-b45b-e8a9e889ed8b -->
  <rule id="541823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1406 — Event Log Clearing (leaktheanalyst)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>