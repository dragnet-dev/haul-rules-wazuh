<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1671 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: f11e3d65-9527-5741-8876-0aa4f12a7ba7 -->
  <rule id="370461" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1671 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>