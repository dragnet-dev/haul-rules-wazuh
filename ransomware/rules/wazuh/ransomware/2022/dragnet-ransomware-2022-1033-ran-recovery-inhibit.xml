<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1033 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c8eea658-657d-5ee1-b733-35ba52a9f305 -->
  <rule id="881066" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1033 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>