  <rule id="261165" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1340 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
