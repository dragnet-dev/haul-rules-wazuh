<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3008 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: a634ce30-c65b-52ec-b6eb-a27478abb910 -->
  <rule id="122510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3008 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>