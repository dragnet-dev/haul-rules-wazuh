<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0046 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: 8c09c0b0-fd48-5bbc-9bf7-4d1910cb3a9e -->
  <rule id="541560" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0046 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>