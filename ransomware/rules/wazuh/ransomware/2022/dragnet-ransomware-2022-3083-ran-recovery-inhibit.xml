<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3083 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 45724afa-b3ce-5531-aa6c-bf4309c71323 -->
  <rule id="105519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3083 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>