<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1208 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: f455bb16-cb70-5c57-a9cc-9d0962e19187 -->
  <rule id="456667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1208 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
