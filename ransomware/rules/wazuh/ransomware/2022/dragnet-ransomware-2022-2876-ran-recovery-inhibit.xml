<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2876 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 92465a58-ce8f-51cf-bf05-bfc0c1c514d8 -->
  <rule id="679450" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2876 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>