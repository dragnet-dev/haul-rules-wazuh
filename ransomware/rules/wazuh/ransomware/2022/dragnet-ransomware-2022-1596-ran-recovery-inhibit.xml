<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1596 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 75bd4cf4-a865-5c8d-bb11-604bf9271f82 -->
  <rule id="502316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1596 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>