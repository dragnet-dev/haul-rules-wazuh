<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2695 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3857a508-fc94-580b-9fa5-47e462c8362d -->
  <rule id="872250" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2695 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
