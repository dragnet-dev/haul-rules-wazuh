<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0762 — Recovery Inhibition (royal) | Status: deprecated | Sigma ID: 32491de0-9af1-5230-a5b1-52491962a19e -->
  <rule id="317918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0762 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
