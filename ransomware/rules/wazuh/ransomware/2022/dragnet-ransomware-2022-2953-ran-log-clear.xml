<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2953 — Event Log Clearing (suncrypt) | Status: deprecated | Sigma ID: 716f45e0-4a27-5664-9c0c-6d4cc8110e67 -->
  <rule id="347145" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2953 — Event Log Clearing (suncrypt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>