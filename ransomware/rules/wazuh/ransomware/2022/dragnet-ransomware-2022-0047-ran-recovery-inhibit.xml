<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0047 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 1b538b5d-f4a8-5552-8ac4-46e45695b305 -->
  <rule id="906195" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0047 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>