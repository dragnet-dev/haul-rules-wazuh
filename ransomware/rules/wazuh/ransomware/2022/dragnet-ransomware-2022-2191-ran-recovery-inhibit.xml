<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2191 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 29dc646c-be81-56b9-bc7c-c1abe8b4a4e0 -->
  <rule id="544646" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2191 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>