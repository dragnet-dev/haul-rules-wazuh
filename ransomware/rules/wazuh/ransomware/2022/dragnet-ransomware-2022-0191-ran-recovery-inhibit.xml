<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0191 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: e6369bc3-9857-5c80-9f27-7132b0e02e02 -->
  <rule id="641915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0191 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
