<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1169 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: bf39f81f-df23-5654-a9f1-37c03537afa9 -->
  <rule id="462398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1169 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>