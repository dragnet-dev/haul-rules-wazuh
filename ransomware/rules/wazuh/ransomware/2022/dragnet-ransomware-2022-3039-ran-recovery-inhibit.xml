<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3039 — Recovery Inhibition (icefire) | Status: deprecated | Sigma ID: edca645d-241d-5c19-9b07-dde95296a3bf -->
  <rule id="787464" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3039 — Recovery Inhibition (icefire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>