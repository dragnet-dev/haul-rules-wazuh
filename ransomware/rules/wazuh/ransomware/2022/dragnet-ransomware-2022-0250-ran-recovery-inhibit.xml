<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0250 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6bb6f5dc-7dd3-5c98-b974-49e85cbe305b -->
  <rule id="157915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0250 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>