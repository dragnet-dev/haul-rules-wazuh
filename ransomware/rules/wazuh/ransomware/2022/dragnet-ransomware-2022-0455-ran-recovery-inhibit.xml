<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0455 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 188c9354-242d-52b4-ba59-0b8f028d841f -->
  <rule id="420935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0455 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>