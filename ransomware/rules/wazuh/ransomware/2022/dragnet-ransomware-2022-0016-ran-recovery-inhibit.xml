<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0016 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 74192a9c-658a-5f0b-8581-d1719e0f1e18 -->
  <rule id="387082" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0016 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>