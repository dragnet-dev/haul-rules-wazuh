<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0355 — Recovery Inhibition (suncrypt) | Status: deprecated | Sigma ID: d5fd7a17-2454-5bbd-9463-efd890c950a6 -->
  <rule id="270202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0355 — Recovery Inhibition (suncrypt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>