<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2950 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 93c86dff-51db-58f3-8f36-89fedd545ba6 -->
  <rule id="701389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2950 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
