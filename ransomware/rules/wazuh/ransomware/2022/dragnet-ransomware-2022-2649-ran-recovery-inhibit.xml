<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2649 — Recovery Inhibition (royal) | Status: deprecated | Sigma ID: f0373f56-172e-5322-b274-bdb862b1b829 -->
  <rule id="705983" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2649 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>