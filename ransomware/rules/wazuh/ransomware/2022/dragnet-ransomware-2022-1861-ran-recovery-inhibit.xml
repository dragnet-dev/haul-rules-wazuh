<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1861 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 746de095-efce-5142-a95c-82f00db88325 -->
  <rule id="211980" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1861 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>