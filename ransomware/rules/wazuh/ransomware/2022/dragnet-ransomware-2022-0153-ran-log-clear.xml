<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0153 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 4de80d6a-037c-55a6-bfc4-5c7b769bb2fb -->
  <rule id="294893" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0153 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>