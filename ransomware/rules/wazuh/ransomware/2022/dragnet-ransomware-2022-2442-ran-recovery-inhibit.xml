<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2442 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 96543595-140c-577c-a1a5-5aa0565a85fa -->
  <rule id="754359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2442 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>