<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2943 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 8213db6e-aa6d-527a-bfbf-9d63e5110a09 -->
  <rule id="402747" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2943 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>