<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1006 — Event Log Clearing (8base) | Status: experimental | Sigma ID: c695ac3c-44b6-5ee3-a21b-eee093b8ebe9 -->
  <rule id="650092" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1006 — Event Log Clearing (8base)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>