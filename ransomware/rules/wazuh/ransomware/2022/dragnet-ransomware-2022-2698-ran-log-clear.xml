<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2698 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: 00016808-6da2-5a8d-8092-77e7bc01b8a1 -->
  <rule id="989389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2698 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>