<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0006 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: c436b710-8af4-5524-afdb-cc38c1b1322c -->
  <rule id="289877" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0006 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>