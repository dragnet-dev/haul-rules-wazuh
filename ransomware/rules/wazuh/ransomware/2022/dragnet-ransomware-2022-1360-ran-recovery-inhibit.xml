<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1360 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: ab279ac2-a016-5a89-9089-3e1eca256ec1 -->
  <rule id="140474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1360 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>