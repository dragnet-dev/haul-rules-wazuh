<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0474 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: f429eca9-5320-5305-937c-a288c273fec4 -->
  <rule id="450060" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0474 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>