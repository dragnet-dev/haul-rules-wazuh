<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1688 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 5d7d82f3-9098-544d-b961-c95651a9d05a -->
  <rule id="700582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1688 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>