<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2539 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: c75659b3-5852-5ae5-a1c5-705231adb3b7 -->
  <rule id="475659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2539 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>