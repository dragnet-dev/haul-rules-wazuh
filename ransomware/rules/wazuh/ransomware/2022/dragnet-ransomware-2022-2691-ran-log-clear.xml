<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2691 — Event Log Clearing (kelvinsecurity) | Status: deprecated | Sigma ID: dc4a5f05-60be-524d-b9a5-5b0b160ccbe2 -->
  <rule id="343935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2691 — Event Log Clearing (kelvinsecurity)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>