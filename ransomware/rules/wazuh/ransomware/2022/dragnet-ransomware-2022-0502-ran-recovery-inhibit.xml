<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0502 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: dfe5b9e0-fa7b-59bf-9af6-150ba046fd39 -->
  <rule id="432119" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0502 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>