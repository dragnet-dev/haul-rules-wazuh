<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2065 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 304f159e-690f-5499-88f3-18abc7b0b72c -->
  <rule id="479159" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2065 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
