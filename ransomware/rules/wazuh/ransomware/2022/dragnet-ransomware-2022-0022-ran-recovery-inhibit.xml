<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0022 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 3a6ff96f-aa4f-5910-8e9c-7fa755e1c829 -->
  <rule id="702719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0022 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>