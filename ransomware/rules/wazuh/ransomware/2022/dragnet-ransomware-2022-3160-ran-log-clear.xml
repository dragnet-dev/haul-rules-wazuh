<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3160 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: 52abcc77-5fe2-5f3c-85f4-43e91ac5d0fc -->
  <rule id="851852" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3160 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>