<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2917 — Event Log Clearing (bitlocker) | Status: deprecated | Sigma ID: 682be5ae-077f-50dd-999f-428d794f58a0 -->
  <rule id="947825" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2917 — Event Log Clearing (bitlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>