<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1042 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 01c0d0e7-4292-5a88-b3b5-639d8c8ebe0d -->
  <rule id="988947" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1042 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>