<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0484 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 0ead5059-321a-52e8-a6fc-93753c68e063 -->
  <rule id="257505" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0484 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>