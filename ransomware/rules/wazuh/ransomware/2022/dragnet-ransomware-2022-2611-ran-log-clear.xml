<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2611 — Event Log Clearing (kelvinsecurity) | Status: deprecated | Sigma ID: 4202634a-b869-507c-afcd-1b2dcdd14717 -->
  <rule id="702634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2611 — Event Log Clearing (kelvinsecurity)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>