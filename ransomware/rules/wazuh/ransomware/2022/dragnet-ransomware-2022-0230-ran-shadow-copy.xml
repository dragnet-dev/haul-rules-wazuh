<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0230 — Shadow Copy Deletion (leaktheanalyst) | Status: deprecated | Sigma ID: 8de9e384-af39-59a4-bb37-4df74e654e77 -->
  <rule id="133583" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0230 — Shadow Copy Deletion (leaktheanalyst)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>