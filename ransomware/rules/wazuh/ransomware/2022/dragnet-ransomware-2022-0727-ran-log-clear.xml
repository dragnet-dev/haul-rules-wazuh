<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0727 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 73cd7380-d2f5-5567-84a4-074c8dcb64c3 -->
  <rule id="189373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0727 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>