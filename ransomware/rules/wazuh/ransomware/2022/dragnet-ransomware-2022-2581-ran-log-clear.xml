<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2581 — Event Log Clearing (ransomexx) | Status: experimental | Sigma ID: 99c5ccd1-3053-54d7-a935-34cf7369f1b0 -->
  <rule id="587244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2581 — Event Log Clearing (ransomexx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>