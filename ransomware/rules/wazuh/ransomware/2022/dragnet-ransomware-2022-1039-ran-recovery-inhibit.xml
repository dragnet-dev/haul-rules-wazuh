<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1039 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4917a8fb-c705-5375-9d1c-89ee5764945d -->
  <rule id="989263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1039 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>