<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0675 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 8bdccb85-68a6-5fd7-a70a-1a2c16c62a9c -->
  <rule id="266027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0675 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>