<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3113 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: cabb7e88-1834-5db3-94da-8fbb55769eed -->
  <rule id="303966" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3113 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
