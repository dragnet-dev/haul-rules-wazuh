<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0305 — Recovery Inhibition (play) | Status: deprecated | Sigma ID: 7a9c3e95-2a19-589d-a732-6f2abac028a7 -->
  <rule id="548222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0305 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>