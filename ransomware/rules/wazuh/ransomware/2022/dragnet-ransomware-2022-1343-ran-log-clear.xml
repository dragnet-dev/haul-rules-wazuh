<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1343 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 302e3d0a-2e0e-5c75-9aa5-1e11572b8bb1 -->
  <rule id="654210" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1343 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>