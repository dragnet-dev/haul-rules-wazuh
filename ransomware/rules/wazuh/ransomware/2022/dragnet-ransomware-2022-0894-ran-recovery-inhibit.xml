<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0894 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: d7da65c4-33a2-599f-8834-32e52ca11e5b -->
  <rule id="929065" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0894 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
