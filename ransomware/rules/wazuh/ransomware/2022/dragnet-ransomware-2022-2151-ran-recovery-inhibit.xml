<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2151 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 45ea454a-54e8-5cab-a7a1-c7c555568470 -->
  <rule id="375445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2151 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>