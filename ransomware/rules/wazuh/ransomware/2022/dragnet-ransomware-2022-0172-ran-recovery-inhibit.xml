<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0172 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: ab3d66a9-0a3a-5f11-9932-f5bf3ab56f18 -->
  <rule id="142166" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0172 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>