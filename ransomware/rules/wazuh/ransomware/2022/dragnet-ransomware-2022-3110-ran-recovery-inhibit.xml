<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3110 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 15fba162-cdce-5fa1-b963-fa5d25bb880a -->
  <rule id="346616" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3110 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>