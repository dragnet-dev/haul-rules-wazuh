<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2921 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: 85eda1ae-04bf-5bc9-9d6c-e74c14ba5894 -->
  <rule id="919621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2921 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>