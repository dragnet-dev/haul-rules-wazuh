<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1609 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 1f35e3dd-f95d-5a08-9594-d7779e19ab88 -->
  <rule id="927901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1609 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>