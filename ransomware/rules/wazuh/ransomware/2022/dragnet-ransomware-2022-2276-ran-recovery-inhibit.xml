<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2276 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: d23deefa-2b3d-5fdb-bfd4-a97a68261738 -->
  <rule id="122574" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2276 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>