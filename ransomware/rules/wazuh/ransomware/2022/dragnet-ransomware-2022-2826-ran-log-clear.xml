<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2826 — Event Log Clearing (mindware) | Status: deprecated | Sigma ID: 8be2aa89-780f-5b10-87ab-41fad79b701f -->
  <rule id="429962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2826 — Event Log Clearing (mindware)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>