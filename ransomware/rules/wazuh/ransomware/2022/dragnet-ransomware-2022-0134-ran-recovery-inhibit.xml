<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0134 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 1e1bac42-3680-562a-acc5-c5a700ebc3fa -->
  <rule id="435884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0134 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>