<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0106 — Event Log Clearing (everest) | Status: deprecated | Sigma ID: 6970eefc-7dd4-5c6f-8478-e03f7cd29d25 -->
  <rule id="984558" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0106 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>