<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1338 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 17940e58-4a5f-58fa-842c-50c6b2bf17a2 -->
  <rule id="270545" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1338 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>