<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2347 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0f3625fb-1cf8-592e-aa80-c6b9ec22e3da -->
  <rule id="758015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2347 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>