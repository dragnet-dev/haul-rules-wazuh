<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1253 — Event Log Clearing (darkleakmarket) | Status: deprecated | Sigma ID: d0eb7bbd-8609-5bbb-87ea-5fa2e32136f2 -->
  <rule id="962523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1253 — Event Log Clearing (darkleakmarket)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>