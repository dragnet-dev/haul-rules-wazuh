<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0110 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: dbbf5979-c28c-5f7d-a17f-ce7a9d6db16b -->
  <rule id="325559" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0110 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>