<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2754 — Event Log Clearing (karakurt) | Status: experimental | Sigma ID: 2720e9a9-f79a-59d6-8b51-b9fcbc23dab2 -->
  <rule id="765594" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2754 — Event Log Clearing (karakurt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>