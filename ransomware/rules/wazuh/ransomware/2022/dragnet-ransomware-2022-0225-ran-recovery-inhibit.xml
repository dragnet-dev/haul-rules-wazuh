<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0225 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 3a01814b-27dc-5135-8eff-e9dc328c420d -->
  <rule id="501814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0225 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
