<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0349 — Event Log Clearing (freecivilian) | Status: deprecated | Sigma ID: 2ecd4c64-bf6c-57c8-b5b5-18f6c5bc5bf6 -->
  <rule id="217036" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0349 — Event Log Clearing (freecivilian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>