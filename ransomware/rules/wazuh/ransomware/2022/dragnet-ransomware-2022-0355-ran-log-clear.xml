<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0355 — Event Log Clearing (suncrypt) | Status: deprecated | Sigma ID: ecd5669d-4190-5f93-8f64-4a2b305b86a6 -->
  <rule id="289566" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0355 — Event Log Clearing (suncrypt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>