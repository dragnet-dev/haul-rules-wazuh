<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1586 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 8eab3c20-b3a7-52a5-81ee-9b58a7594002 -->
  <rule id="543740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1586 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>