<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1114 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: 61c2fdfe-acdc-532e-b814-f3d712cbda56 -->
  <rule id="830045" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1114 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>