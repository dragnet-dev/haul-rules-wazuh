<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2713 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: 3dfbaad3-d673-5277-ac36-94d5c268cd6e -->
  <rule id="562122" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2713 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>