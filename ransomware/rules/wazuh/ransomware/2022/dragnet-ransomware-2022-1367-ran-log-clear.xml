<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1367 — Event Log Clearing (pandora) | Status: deprecated | Sigma ID: 561ace0b-44e6-58c3-a922-795225edae50 -->
  <rule id="600622" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1367 — Event Log Clearing (pandora)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>