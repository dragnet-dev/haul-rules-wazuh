<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2631 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: 66f9d01c-91d9-55cc-9d0c-0112b143a7bf -->
  <rule id="915170" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2631 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>