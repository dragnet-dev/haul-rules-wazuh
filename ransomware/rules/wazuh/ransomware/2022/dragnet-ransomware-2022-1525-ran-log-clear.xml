<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1525 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: c1a07984-fe3b-5c2b-9f29-e06aba92fe0d -->
  <rule id="246079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1525 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>