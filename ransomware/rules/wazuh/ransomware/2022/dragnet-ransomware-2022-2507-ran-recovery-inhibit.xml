<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2507 — Recovery Inhibition (icefire) | Status: deprecated | Sigma ID: 1efed6df-70da-58be-92f1-2aea2e834171 -->
  <rule id="469576" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2507 — Recovery Inhibition (icefire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>