<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2817 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: f1b95ab7-4856-5a54-b2ad-c10313818446 -->
  <rule id="384730" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2817 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>