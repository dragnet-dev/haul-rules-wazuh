<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1670 — Recovery Inhibition (icefire) | Status: deprecated | Sigma ID: 833e8c63-8546-5a7e-b3ff-a083b0cf4505 -->
  <rule id="434860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1670 — Recovery Inhibition (icefire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>