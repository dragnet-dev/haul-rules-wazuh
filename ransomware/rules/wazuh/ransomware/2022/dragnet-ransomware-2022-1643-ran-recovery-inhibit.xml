<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1643 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: dd1beb6d-423e-51e5-bf2e-76d0f8559454 -->
  <rule id="159307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1643 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>