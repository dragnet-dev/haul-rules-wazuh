<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3057 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: d71166cb-5986-5557-8d30-c34a7fbf17d5 -->
  <rule id="571166" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3057 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>