<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0185 — Event Log Clearing (royal) | Status: deprecated | Sigma ID: 6ea1d99a-f0fe-596f-a69a-36f95388b9e3 -->
  <rule id="232299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0185 — Event Log Clearing (royal)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>