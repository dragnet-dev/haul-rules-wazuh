<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0650 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 09d33d66-5a3d-57f8-9f3c-beccccfec755 -->
  <rule id="817416" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0650 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>