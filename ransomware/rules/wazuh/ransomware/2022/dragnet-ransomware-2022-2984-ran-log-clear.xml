<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2984 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: bb5127b2-9ec2-54a4-84d1-d53a1bf45c32 -->
  <rule id="175127" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2984 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>