<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1658 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 09a22526-50f7-5221-a4c3-56572e2be713 -->
  <rule id="742252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1658 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>