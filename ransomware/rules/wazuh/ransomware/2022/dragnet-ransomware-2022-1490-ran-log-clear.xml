<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1490 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 163f2695-b3ee-5d6c-85aa-6941c4ae6dfa -->
  <rule id="923269" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1490 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>