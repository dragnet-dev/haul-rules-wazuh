<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2785 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 5b79d302-c28d-5b65-9ddd-f9f9655c6c96 -->
  <rule id="668773" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2785 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>