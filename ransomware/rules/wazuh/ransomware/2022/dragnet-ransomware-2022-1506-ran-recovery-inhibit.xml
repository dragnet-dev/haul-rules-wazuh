<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1506 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: fa823669-abd0-57ee-bab4-ff3e5b21fbf4 -->
  <rule id="808236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1506 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>