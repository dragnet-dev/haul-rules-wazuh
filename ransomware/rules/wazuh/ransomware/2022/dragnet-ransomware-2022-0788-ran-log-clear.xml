<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0788 — Event Log Clearing (donutleaks) | Status: deprecated | Sigma ID: 4af29a1e-a42d-55ed-ab37-f14b8c1fa911 -->
  <rule id="218874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0788 — Event Log Clearing (donutleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>