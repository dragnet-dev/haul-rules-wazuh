<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1798 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: ca01adbb-6ba5-51f6-adcd-4f89ef98106a -->
  <rule id="771629" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1798 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>