<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1440 — Event Log Clearing (bianlian) | Status: deprecated | Sigma ID: b0ec67bf-98b5-5b93-913d-6b18cb5d3086 -->
  <rule id="239667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1440 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>