<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0265 — Recovery Inhibition (onyx) | Status: deprecated | Sigma ID: de5b9298-d858-5266-b82e-dba54060ba38 -->
  <rule id="961192" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0265 — Recovery Inhibition (onyx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>