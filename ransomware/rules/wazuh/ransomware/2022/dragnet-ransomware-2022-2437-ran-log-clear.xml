<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2437 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 4feb8e7b-4c08-58d8-9b73-0d891bae4fda -->
  <rule id="673582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2437 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>