<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1575 — Event Log Clearing (quantum) | Status: deprecated | Sigma ID: 237d246a-79e7-51ea-8aa5-a4364d384f91 -->
  <rule id="305246" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1575 — Event Log Clearing (quantum)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>