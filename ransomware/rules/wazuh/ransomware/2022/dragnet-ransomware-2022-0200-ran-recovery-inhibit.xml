<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0200 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 4137cebe-9113-5bc1-9c38-60cbd3b3e765 -->
  <rule id="259278" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0200 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>