<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2330 — Event Log Clearing (kelvinsecurity) | Status: deprecated | Sigma ID: bfaf9bef-f659-5971-a96d-9e5036b4a7a2 -->
  <rule id="751515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2330 — Event Log Clearing (kelvinsecurity)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>