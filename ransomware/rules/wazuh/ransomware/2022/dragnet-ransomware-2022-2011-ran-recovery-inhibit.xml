<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2011 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: abc3027c-4b0e-52ff-9159-4b1f8654299b -->
  <rule id="148302" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2011 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>