<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1882 — Event Log Clearing (hive) | Status: deprecated | Sigma ID: de4b1c86-2f3b-5e4c-a6eb-3571e63bbe3a -->
  <rule id="395228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1882 — Event Log Clearing (hive)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>