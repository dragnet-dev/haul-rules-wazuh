<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0529 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 85c5e74f-8b94-5e6b-a5fe-4d26daa48a01 -->
  <rule id="496147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0529 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>