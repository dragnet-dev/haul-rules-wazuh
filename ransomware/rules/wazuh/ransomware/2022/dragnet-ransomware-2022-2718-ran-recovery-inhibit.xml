<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2718 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 173e0199-c634-511b-8ed2-51709a4aec44 -->
  <rule id="182019" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2718 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>