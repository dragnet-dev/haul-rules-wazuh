<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0774 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: ff9fecb5-f2a7-542c-af45-8b230012005a -->
  <rule id="685740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0774 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
