<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0246 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: cd7d05de-8d29-57bd-8218-5431df3e33f7 -->
  <rule id="692505" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0246 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>