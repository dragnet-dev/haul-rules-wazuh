  <rule id="627631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0203 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
