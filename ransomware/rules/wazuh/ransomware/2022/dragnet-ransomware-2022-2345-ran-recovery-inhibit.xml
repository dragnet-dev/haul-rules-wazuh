<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2345 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 825ac2f3-dd80-5cff-bc78-d1f18bea3848 -->
  <rule id="413722" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2345 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>