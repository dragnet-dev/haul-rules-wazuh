<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1458 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: c1dc7395-0f8c-5685-8c19-1bed9a54b750 -->
  <rule id="519673" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1458 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>