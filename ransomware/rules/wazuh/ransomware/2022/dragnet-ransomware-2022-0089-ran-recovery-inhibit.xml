<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0089 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 0d821242-d656-5888-bc2a-5e7aaec4b8e3 -->
  <rule id="582124" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0089 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>