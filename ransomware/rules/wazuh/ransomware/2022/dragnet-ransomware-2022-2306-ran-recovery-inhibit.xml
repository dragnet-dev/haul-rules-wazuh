<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2306 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 294f4839-ea45-59ff-9b24-5307b33628e3 -->
  <rule id="319483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2306 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>