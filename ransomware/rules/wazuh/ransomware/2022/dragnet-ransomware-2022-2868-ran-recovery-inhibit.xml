<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2868 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6d75c6fa-d872-5ab1-b0db-750258642bb4 -->
  <rule id="956126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2868 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>