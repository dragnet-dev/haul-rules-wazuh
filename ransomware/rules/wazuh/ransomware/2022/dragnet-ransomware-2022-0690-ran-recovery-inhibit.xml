<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0690 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: ff698cac-3cdd-50fa-a309-3f79cfd53d84 -->
  <rule id="591180" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0690 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>