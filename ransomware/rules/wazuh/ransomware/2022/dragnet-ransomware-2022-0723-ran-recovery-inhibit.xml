<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0723 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: a74f506a-60a3-5384-b9e4-f729cc313236 -->
  <rule id="919950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0723 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>