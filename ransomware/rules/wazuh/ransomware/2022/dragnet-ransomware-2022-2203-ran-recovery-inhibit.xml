<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2203 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 3d00500e-5466-5306-91a0-22ecf40a9b1a -->
  <rule id="800500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2203 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>