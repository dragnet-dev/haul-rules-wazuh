<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0021 — Recovery Inhibition (cheers) | Status: deprecated | Sigma ID: 8cbce722-1233-5d99-94de-fdee9caa8a50 -->
  <rule id="464627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0021 — Recovery Inhibition (cheers)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>