<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2096 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: e3fae23b-3a2e-53f6-8a7e-95bfa0a524ce -->
  <rule id="597422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2096 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>