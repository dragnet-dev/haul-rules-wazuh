<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1460 — Shadow Copy Deletion (kelvinsecurity) | Status: deprecated | Sigma ID: d1f28f31-8c8f-5de6-8972-91e3b7f13c32 -->
  <rule id="778063" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1460 — Shadow Copy Deletion (kelvinsecurity)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>