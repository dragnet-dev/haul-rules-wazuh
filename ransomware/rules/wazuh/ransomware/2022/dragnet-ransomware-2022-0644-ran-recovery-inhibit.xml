<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0644 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 53d82e24-1867-518d-9021-5d15f33d6b5c -->
  <rule id="578926" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0644 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>