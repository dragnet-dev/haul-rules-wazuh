<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3017 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: 5c0be053-f07d-5b9d-a38a-b8ee9f0c3af5 -->
  <rule id="657100" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3017 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>