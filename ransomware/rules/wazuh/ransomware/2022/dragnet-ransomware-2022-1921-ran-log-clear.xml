<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1921 — Event Log Clearing (sabbath) | Status: deprecated | Sigma ID: c1f4ee4e-f521-5918-ab9e-a3c920195801 -->
  <rule id="595822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1921 — Event Log Clearing (sabbath)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>