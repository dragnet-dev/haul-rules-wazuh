<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2036 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 93ae1aaa-4109-5a58-913e-ea9f0bdaef98 -->
  <rule id="337146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2036 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>