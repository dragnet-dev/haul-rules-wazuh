<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1994 — Event Log Clearing (lorenz) | Status: deprecated | Sigma ID: 855a66d7-1fa0-59b4-8da9-274f0a0c56a4 -->
  <rule id="569066" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1994 — Event Log Clearing (lorenz)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>