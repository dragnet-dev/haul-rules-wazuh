<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0860 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 0f2280e7-c557-5fd4-a1d4-d8d68e7e5aaf -->
  <rule id="736494" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0860 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>