<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1023 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: a8a8f92a-8e0e-5ad6-bc7e-9ff45788c060 -->
  <rule id="182239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1023 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>