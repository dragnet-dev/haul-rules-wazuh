<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0269 — Event Log Clearing (cryptbb) | Status: experimental | Sigma ID: 52b24323-d542-52ea-a894-a25497c58e1c -->
  <rule id="432432" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0269 — Event Log Clearing (cryptbb)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>