<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2850 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 1aeca8c3-6b62-507a-b6cb-a2bd25900445 -->
  <rule id="302828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2850 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>