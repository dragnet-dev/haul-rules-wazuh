<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3040 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: cdc9492a-dae5-5e90-8cf4-6b8c04d7e81a -->
  <rule id="692949" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3040 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>