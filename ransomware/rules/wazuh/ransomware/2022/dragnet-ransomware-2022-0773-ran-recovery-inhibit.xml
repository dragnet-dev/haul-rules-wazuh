<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0773 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 79bf09d2-f15c-5bd4-a369-f60ea32a0919 -->
  <rule id="341509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0773 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>