<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1609 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: ae65ca88-a498-5f6c-8765-73aedcfd27b8 -->
  <rule id="971242" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1609 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>