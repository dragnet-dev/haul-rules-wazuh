<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0136 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 72e4bd27-88c1-5178-8354-dc2e99431527 -->
  <rule id="386173" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0136 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>