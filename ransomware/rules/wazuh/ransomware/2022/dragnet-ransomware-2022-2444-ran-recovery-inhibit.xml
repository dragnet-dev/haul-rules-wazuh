<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2444 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 2786617d-efe8-53db-baf3-34e17347a10d -->
  <rule id="186617" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2444 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>