<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2829 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: b717feb4-256e-538d-bbed-e3f5fc5282f1 -->
  <rule id="399806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2829 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>