<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0224 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: 6d766aad-5126-5266-90e8-dafac581fdf5 -->
  <rule id="956266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0224 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>