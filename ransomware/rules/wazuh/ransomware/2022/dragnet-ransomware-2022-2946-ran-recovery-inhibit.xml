<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2946 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 04bc1a60-2326-5846-b265-8af3bdf474c5 -->
  <rule id="239466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2946 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>