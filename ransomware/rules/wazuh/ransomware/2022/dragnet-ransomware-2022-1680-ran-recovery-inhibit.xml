<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1680 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 1bbb31fc-8e94-559e-9753-9b3abb2562c7 -->
  <rule id="658911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1680 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>