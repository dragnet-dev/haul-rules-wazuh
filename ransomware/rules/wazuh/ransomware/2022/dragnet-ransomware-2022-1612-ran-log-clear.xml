<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1612 — Event Log Clearing (icefire) | Status: deprecated | Sigma ID: fa6ad011-fcd0-5ef0-b2aa-16c39717f0d6 -->
  <rule id="217090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1612 — Event Log Clearing (icefire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>