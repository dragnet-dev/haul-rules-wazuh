<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0829 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: 6dfa6206-5595-5666-a0dc-b478e96cb6a0 -->
  <rule id="215462" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0829 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>