<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2577 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: a0cd72c8-3e46-5f99-a1c4-0cd79607c283 -->
  <rule id="880572" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2577 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>