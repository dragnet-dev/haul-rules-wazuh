<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1814 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: ea337b84-58fd-5c02-9910-a459ded34f16 -->
  <rule id="249403" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1814 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>