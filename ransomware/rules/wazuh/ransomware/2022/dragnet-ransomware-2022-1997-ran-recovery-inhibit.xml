<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1997 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: b09ab53f-b05e-50c9-9328-3b672f903e18 -->
  <rule id="240755" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1997 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>