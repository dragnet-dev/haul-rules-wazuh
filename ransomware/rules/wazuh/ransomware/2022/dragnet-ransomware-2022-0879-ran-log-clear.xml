<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0879 — Event Log Clearing (hive) | Status: deprecated | Sigma ID: 5c63eb05-e281-5bf5-8fa8-2ff9ae3f488d -->
  <rule id="671563" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0879 — Event Log Clearing (hive)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>