<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1329 — Recovery Inhibition (sparta) | Status: deprecated | Sigma ID: 2bffdf37-c847-5015-82ed-665bcf1e7eb4 -->
  <rule id="283551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1329 — Recovery Inhibition (sparta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>