<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2670 — Event Log Clearing (stormous) | Status: deprecated | Sigma ID: 3b67b916-5c0a-5cd2-aa40-76ffc26efd84 -->
  <rule id="648391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2670 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>