<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1249 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: dc969083-8f1e-50a6-a681-94ff420a6060 -->
  <rule id="509690" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1249 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>