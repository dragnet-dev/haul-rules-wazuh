<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2343 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 82550602-fc02-503a-9c46-1810fb8e4e26 -->
  <rule id="255060" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2343 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>