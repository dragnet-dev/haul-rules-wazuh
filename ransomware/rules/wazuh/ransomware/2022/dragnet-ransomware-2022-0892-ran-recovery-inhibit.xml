<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0892 — Recovery Inhibition (royal) | Status: deprecated | Sigma ID: 03b51025-56fb-5482-892f-be2ba3337f46 -->
  <rule id="651025" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0892 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
