<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1990 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: f5c21f6c-f074-5d9c-8205-c4f7711a6b62 -->
  <rule id="487551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1990 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>