<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3012 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 235ecd7e-793e-552f-bd90-0bcc929287fe -->
  <rule id="763497" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3012 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
