<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0995 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 26e2a507-fad8-58b3-83c7-dca61f2f4c7a -->
  <rule id="684250" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0995 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>