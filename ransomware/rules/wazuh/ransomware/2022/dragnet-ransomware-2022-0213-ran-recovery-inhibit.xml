<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0213 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: da182262-54f5-520c-b3d8-1717b99c17d2 -->
  <rule id="481822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0213 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>