<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2645 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 7418db9a-3cab-5728-854f-343882e874ae -->
  <rule id="199227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2645 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>