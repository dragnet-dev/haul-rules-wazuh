<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1237 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 6cedfb01-d15c-5765-9ee4-bfc85d4187a8 -->
  <rule id="938811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1237 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>