<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2966 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: f7859cc3-d762-5083-b8e2-ed0b6eeb4fdb -->
  <rule id="825756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2966 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>