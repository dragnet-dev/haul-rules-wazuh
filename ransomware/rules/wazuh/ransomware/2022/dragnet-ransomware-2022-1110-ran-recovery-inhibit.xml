<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1110 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: b8529864-09fb-574a-9c70-b3eec047a00e -->
  <rule id="385298" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1110 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>