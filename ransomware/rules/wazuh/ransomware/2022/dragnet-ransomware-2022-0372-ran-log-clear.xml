<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0372 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 818d6fce-c9ca-5144-8c29-ee64b5613a6b -->
  <rule id="396271" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0372 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>