<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1700 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 5b984260-b9c1-5adb-81dd-875963bd2820 -->
  <rule id="298426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1700 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>