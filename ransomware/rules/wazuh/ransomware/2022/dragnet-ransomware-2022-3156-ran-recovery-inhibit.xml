<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3156 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 78a9e646-0e8e-54dc-b9bf-eb77c334e52e -->
  <rule id="314386" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3156 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>