<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0004 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: f060fa89-34ea-5340-90f1-6861d7da35f8 -->
  <rule id="355610" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0004 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>