<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0064 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: fefcc7e3-a94f-58ac-a76e-54788ecbcbc5 -->
  <rule id="244428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0064 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>