<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0036 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: bb08e5a1-e019-579a-8f84-1efe0f3da1eb -->
  <rule id="393425" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0036 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>