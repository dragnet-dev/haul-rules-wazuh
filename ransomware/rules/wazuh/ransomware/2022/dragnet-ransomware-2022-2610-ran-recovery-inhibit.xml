<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2610 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: a28ef061-78eb-56bf-b67a-d1c69c87f445 -->
  <rule id="934070" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2610 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>