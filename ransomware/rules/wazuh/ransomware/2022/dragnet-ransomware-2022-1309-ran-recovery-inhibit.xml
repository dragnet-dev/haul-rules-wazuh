<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1309 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 8dab017b-400e-5755-ba65-3f7bebe13730 -->
  <rule id="126701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1309 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>