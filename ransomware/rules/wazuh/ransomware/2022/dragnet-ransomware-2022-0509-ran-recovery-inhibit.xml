<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0509 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 00e294d4-772c-55d8-8de5-c9cf540fa12a -->
  <rule id="587174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0509 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
