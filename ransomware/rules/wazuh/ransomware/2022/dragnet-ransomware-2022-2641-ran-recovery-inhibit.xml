<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2641 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 485fa36e-5b89-5057-be93-fa670cb06461 -->
  <rule id="444103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2641 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>