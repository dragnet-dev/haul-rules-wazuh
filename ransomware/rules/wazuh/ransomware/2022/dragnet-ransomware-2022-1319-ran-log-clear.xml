<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1319 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 1955848c-0f4f-5ab3-aa55-e90c12147d65 -->
  <rule id="255848" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1319 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>