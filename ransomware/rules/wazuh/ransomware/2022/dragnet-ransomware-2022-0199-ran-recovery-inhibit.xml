<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0199 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: d474941d-58c6-5851-8dd3-e84cb3a32230 -->
  <rule id="547494" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0199 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>