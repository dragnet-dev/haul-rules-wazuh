<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2013 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3e396646-5d33-5d27-b601-0ec456a3d290 -->
  <rule id="939664" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2013 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>