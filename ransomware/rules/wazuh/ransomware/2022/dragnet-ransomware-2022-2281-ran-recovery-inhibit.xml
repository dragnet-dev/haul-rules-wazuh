<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2281 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 896f43d1-e335-537a-bc09-a3e4d3e06cf7 -->
  <rule id="635143" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2281 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>