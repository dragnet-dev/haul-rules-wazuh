<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1721 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 3b04dad4-3bc1-58f1-b020-fefadfe18d09 -->
  <rule id="711642" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1721 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>