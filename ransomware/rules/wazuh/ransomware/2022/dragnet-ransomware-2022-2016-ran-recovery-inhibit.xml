<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2016 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 8e4a1981-e6ce-53c0-9732-046992973ed4 -->
  <rule id="579419" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2016 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>