<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0757 — Event Log Clearing (projectrelic) | Status: deprecated | Sigma ID: 636138f4-e97f-5450-a092-a25ee103da57 -->
  <rule id="378223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0757 — Event Log Clearing (projectrelic)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>