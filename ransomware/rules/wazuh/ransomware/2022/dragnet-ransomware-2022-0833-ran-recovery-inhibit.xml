<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0833 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: e3f682cd-af83-54ed-b7f6-fa686b45284f -->
  <rule id="603682" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0833 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>