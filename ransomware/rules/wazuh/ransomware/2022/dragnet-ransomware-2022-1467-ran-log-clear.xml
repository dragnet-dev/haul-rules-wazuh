<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1467 — Event Log Clearing (suncrypt) | Status: deprecated | Sigma ID: 38876ee8-19de-5f8e-af92-16a10ae190c0 -->
  <rule id="152494" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1467 — Event Log Clearing (suncrypt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>