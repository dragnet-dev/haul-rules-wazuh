<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0360 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 1959a2ee-f01f-5da3-8705-adaac2dc942b -->
  <rule id="616686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0360 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>