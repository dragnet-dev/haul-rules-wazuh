<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0890 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: f21ee34b-8652-50dc-a949-fd5d974759c7 -->
  <rule id="396143" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0890 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>