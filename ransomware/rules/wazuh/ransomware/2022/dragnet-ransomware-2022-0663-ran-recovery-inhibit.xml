<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0663 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: fd8b9dc3-eb28-513e-8ca9-26630da6c7be -->
  <rule id="299197" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0663 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>