<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1447 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7da3220b-c134-56b6-b575-480a425ba592 -->
  <rule id="310322" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1447 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>