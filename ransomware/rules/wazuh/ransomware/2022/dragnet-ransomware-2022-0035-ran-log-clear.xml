<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0035 — Event Log Clearing (lv) | Status: deprecated | Sigma ID: cb7298a1-ef0c-5172-9a84-e879e1e6a5b9 -->
  <rule id="337298" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0035 — Event Log Clearing (lv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>