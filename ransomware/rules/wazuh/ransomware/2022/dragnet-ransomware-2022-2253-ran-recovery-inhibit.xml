<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2253 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: bfc86342-c91e-5195-b1d0-d41476b15954 -->
  <rule id="468863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2253 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>