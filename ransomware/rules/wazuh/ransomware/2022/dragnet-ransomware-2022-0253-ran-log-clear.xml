<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0253 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: 6a2a5ea3-20ae-53b8-adf7-67e06eb33fa2 -->
  <rule id="120414" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0253 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>