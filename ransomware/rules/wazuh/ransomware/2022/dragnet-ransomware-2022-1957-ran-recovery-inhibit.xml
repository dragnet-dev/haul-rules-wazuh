<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1957 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 98c8adc8-c65b-5b8b-aa82-b6b47efbba88 -->
  <rule id="547021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1957 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>