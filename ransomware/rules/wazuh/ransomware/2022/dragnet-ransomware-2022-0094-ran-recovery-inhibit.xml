<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0094 — Recovery Inhibition (ragnarlocker) | Status: experimental | Sigma ID: 156a508f-1bba-598a-b378-6726c09e6c4e -->
  <rule id="806508" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0094 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>