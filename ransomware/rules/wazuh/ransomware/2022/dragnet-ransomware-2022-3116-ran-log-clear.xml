<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3116 — Event Log Clearing (avoslocker) | Status: deprecated | Sigma ID: 85e56e12-ba5f-5919-a0f2-55dc2dcfa083 -->
  <rule id="499310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3116 — Event Log Clearing (avoslocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>