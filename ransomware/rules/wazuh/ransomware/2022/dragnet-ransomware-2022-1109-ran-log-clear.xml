<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1109 — Event Log Clearing (stormous) | Status: deprecated | Sigma ID: 4f93d57c-741a-55ff-8fb6-3d5c5ffc6451 -->
  <rule id="479015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1109 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>