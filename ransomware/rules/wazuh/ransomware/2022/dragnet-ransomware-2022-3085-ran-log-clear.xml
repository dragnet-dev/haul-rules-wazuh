<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3085 — Event Log Clearing (mindware) | Status: deprecated | Sigma ID: 8a4a81c9-0013-56dd-a3c6-e9d2eaf5d4cc -->
  <rule id="515481" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3085 — Event Log Clearing (mindware)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>