<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2496 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: fd5459cc-938c-57fd-85bd-88423b4d00b1 -->
  <rule id="835459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2496 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>