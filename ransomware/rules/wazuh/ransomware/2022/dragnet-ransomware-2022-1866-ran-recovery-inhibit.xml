<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1866 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: 296f633b-b718-5d2b-bb89-e9ad42aa1b29 -->
  <rule id="351633" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1866 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>