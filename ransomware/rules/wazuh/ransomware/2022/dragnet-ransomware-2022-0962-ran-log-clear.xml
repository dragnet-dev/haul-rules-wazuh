<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0962 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: b31ec77d-e3c5-5a3e-96ba-82bcb8f0483a -->
  <rule id="297727" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0962 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>