<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0465 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 11bb2a10-9352-5487-a082-f59fa3d03140 -->
  <rule id="405221" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0465 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>