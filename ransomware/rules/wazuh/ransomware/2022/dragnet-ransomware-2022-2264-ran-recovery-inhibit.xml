<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2264 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 2293adac-8250-5389-83b5-edbabde1044c -->
  <rule id="494906" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2264 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>