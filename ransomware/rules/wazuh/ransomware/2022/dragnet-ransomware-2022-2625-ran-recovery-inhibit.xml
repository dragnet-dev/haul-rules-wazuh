<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2625 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 2f552c98-ddda-59e5-8bc9-4c73eb04c9fe -->
  <rule id="508449" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2625 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>