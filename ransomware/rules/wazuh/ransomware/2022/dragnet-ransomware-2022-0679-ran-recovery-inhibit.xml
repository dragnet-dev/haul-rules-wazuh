<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0679 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 7632d91f-0624-5301-93ae-20a89a42d4a5 -->
  <rule id="421259" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0679 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>