<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2883 — Event Log Clearing (leaktheanalyst) | Status: deprecated | Sigma ID: 8c7f6b0e-ad29-52cf-870d-eac6863a3c71 -->
  <rule id="104427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2883 — Event Log Clearing (leaktheanalyst)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>