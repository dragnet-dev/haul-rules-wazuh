<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1791 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: f906ef01-d443-5939-a9ee-0ac490b61327 -->
  <rule id="572175" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1791 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>