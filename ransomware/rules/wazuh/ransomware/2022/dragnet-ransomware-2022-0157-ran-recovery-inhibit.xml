<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0157 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: ff4375be-5a17-5ac4-8406-36f1f6dc5fdd -->
  <rule id="854375" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0157 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>