<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0257 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: edfdc42f-dc3f-5443-952f-24d4e07689d3 -->
  <rule id="848124" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0257 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>