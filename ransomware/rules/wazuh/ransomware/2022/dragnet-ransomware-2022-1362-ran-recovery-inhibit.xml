<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1362 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: a4ed7686-aeb0-54a1-92bb-889eff86c3bc -->
  <rule id="986176" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1362 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>