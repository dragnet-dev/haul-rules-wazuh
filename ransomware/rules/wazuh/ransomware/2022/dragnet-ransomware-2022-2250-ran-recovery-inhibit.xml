<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2250 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: b8e0b57e-c207-5966-95e0-ddce088590bf -->
  <rule id="443315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2250 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
