<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0014 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: f925cb80-1958-51c4-a92f-3a1f64a7db65 -->
  <rule id="577003" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0014 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>