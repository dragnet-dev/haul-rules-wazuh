<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0524 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: ac01c844-55ea-54b7-88e3-67620e1dd6f5 -->
  <rule id="152288" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0524 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>