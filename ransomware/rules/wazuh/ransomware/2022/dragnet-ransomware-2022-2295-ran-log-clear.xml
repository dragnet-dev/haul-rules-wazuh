<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2295 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 5b8b48e2-50b9-5abe-9123-11f5b0253a9e -->
  <rule id="669948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2295 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>