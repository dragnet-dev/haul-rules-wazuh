<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2242 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 3e252f18-4f72-5513-a2c3-ace6712aee97 -->
  <rule id="160471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2242 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>