<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0479 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 2da51300-26d5-5e38-b8d7-400663cd0987 -->
  <rule id="205130" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0479 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>