<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1373 — Event Log Clearing (suncrypt) | Status: deprecated | Sigma ID: fd4e9e7b-4c3e-573a-aecd-91b466833e8c -->
  <rule id="289438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1373 — Event Log Clearing (suncrypt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>