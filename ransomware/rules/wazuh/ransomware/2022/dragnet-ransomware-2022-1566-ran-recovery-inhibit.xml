<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1566 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: b175b6b1-8e4a-5166-a1e0-234075ec544d -->
  <rule id="988116" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1566 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>