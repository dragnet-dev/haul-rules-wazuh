<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0353 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: e343188d-115e-5828-ad79-e7f71f9e9b85 -->
  <rule id="634318" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0353 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>