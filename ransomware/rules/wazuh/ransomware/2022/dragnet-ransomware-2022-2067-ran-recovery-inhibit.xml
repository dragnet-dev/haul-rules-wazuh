<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2067 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: d40744c0-132e-5ceb-ae80-f88413aabe4e -->
  <rule id="540744" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2067 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>