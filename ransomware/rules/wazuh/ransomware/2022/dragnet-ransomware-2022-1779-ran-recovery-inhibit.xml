<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1779 — Recovery Inhibition (suncrypt) | Status: deprecated | Sigma ID: 2219826f-9985-5e7d-aa7f-808f123c5ed4 -->
  <rule id="519826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1779 — Recovery Inhibition (suncrypt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>