<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1840 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 79ff0d20-c70b-5482-8e21-95d30d7fd0d6 -->
  <rule id="676653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1840 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>