<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1215 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: 30c88a10-6776-5a82-a345-01a379b450d5 -->
  <rule id="786181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1215 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
