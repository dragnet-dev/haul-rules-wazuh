<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1430 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8e588f6a-ed79-540a-adc6-9f3ecf56ef30 -->
  <rule id="581423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1430 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>