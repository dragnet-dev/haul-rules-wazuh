<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3030 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: e9b32fa8-ec9d-5207-b226-e9250226926f -->
  <rule id="332527" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3030 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>