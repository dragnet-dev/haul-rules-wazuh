<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1130 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: 55d7240c-a600-5888-80ed-c6107e4d4f3f -->
  <rule id="937240" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1130 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>