<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3073 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: f695c61f-a72e-5249-a506-633e23396a08 -->
  <rule id="811326" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3073 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>