<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1341 — Recovery Inhibition (onyx) | Status: deprecated | Sigma ID: 12a82088-c8b2-5001-9689-13ad7037342e -->
  <rule id="328208" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1341 — Recovery Inhibition (onyx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>