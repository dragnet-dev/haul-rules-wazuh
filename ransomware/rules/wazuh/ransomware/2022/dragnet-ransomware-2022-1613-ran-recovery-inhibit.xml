<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1613 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: f70f34ff-d316-563e-bbe0-8d17d0e8fe56 -->
  <rule id="813534" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1613 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>