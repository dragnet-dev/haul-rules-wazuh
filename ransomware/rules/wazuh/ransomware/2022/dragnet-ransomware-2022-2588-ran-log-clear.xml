<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2588 — Event Log Clearing (ragnarlocker) | Status: experimental | Sigma ID: 8d2dc0bf-ba8a-5d87-b4a2-55bcce00a358 -->
  <rule id="116920" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2588 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>