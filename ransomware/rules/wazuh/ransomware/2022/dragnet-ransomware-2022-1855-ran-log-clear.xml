<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1855 — Event Log Clearing (bianlian) | Status: deprecated | Sigma ID: 61c5cc4a-2f0c-5c00-b4d4-cf3852a6de47 -->
  <rule id="830764" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1855 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>