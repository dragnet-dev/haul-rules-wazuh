<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1106 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 06bc1cbb-b594-5d4f-aa6d-73be16139d47 -->
  <rule id="913899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1106 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>