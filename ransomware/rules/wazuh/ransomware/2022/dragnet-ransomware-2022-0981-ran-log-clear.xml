<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0981 — Event Log Clearing (leaktheanalyst) | Status: deprecated | Sigma ID: 2d0bda3f-6e59-5901-818f-620900dfaa59 -->
  <rule id="146234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0981 — Event Log Clearing (leaktheanalyst)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>