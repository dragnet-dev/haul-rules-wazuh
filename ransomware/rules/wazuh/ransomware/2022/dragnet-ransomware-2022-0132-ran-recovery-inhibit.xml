<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0132 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7eea08f5-3a68-55a7-93bd-fc89163835d5 -->
  <rule id="649008" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0132 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>