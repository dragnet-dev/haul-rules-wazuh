<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1071 — Recovery Inhibition (sabbath) | Status: deprecated | Sigma ID: c452547e-bea1-5cce-bff1-9bd94170f2fa -->
  <rule id="445254" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1071 — Recovery Inhibition (sabbath)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>