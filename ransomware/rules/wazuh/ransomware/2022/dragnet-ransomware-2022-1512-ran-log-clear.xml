<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1512 — Event Log Clearing (leaktheanalyst) | Status: deprecated | Sigma ID: 9d3121e5-a96f-57ac-aeb5-f3c8edd7cbaf -->
  <rule id="773121" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1512 — Event Log Clearing (leaktheanalyst)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>