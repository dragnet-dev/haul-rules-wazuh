<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2608 — Event Log Clearing (everest) | Status: deprecated | Sigma ID: 012aedb6-9df6-58fc-a47c-30e0a4b95f71 -->
  <rule id="311956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2608 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>