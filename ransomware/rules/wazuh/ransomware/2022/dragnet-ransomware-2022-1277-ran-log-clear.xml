<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1277 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 6530a1d4-d2fb-56ba-b1cd-c41b92fb0864 -->
  <rule id="244901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1277 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>