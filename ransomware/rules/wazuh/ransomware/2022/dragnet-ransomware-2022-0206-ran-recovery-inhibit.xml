<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0206 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 702b6db7-bf82-5931-8bf6-90198dcc8830 -->
  <rule id="998989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0206 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
