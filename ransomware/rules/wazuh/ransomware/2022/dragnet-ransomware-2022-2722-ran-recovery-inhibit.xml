<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2722 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: c6481080-4c7b-5dd8-9a34-c9d8e817893d -->
  <rule id="464810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2722 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>