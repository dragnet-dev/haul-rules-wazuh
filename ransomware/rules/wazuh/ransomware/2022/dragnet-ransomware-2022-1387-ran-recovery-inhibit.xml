<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1387 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: d239b636-e52e-5dd5-a5d9-10a2096581eb -->
  <rule id="418356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1387 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>