<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0544 — Event Log Clearing (bianlian) | Status: deprecated | Sigma ID: 714b03e6-e9fc-5a2e-b9c7-798e2f44babd -->
  <rule id="343503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0544 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>