<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0332 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: bf4f4985-9fd4-56bb-ace5-e76eecb21171 -->
  <rule id="463949" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0332 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>