<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0373 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 51fbcf40-68f1-54e8-8863-4bd5a3d41f97 -->
  <rule id="806799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0373 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>