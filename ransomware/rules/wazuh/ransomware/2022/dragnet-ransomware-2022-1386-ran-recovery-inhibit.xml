<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1386 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 69fb8648-1147-562a-8269-7d9998795754 -->
  <rule id="991586" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1386 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>