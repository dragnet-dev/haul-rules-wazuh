<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1898 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 32f65b2b-8020-5250-bd72-4018f8f011c6 -->
  <rule id="442512" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1898 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>