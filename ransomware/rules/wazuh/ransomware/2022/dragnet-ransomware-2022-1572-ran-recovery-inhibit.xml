<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1572 — Recovery Inhibition (lv) | Status: deprecated | Sigma ID: 230637eb-e8d3-5839-ba02-bf21e4a818b4 -->
  <rule id="190206" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1572 — Recovery Inhibition (lv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
