<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2548 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: 3ced3abd-2e68-5fe1-b716-28ea3d761362 -->
  <rule id="795578" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2548 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>