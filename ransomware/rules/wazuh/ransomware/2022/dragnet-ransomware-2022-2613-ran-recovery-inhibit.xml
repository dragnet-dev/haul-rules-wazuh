<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2613 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e9a461de-329b-5d5e-af83-0aaea1a6092b -->
  <rule id="694461" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2613 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>