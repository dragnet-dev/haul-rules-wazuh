<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1356 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 3e4638bb-8956-5ce1-bd91-4063aef5ec57 -->
  <rule id="194219" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1356 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>