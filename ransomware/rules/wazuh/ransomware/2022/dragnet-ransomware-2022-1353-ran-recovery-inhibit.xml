<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1353 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8b957ad5-67f9-5cdb-ba33-4edc0cc374be -->
  <rule id="539322" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1353 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>