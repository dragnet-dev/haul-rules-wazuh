<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0608 — Recovery Inhibition (royal) | Status: deprecated | Sigma ID: 45cddec4-cd18-5dd2-ab12-7fd5cca51aa2 -->
  <rule id="401822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0608 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>