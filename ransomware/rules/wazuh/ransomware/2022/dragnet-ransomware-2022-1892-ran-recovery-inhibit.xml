<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1892 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: afd4d5c9-076a-5726-9189-97fb8c22e3f0 -->
  <rule id="101575" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1892 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>