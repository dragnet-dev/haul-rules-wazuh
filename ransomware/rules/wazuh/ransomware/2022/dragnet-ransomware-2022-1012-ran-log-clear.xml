<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1012 — Event Log Clearing (hive) | Status: deprecated | Sigma ID: 7dd2e4f6-55f1-524c-8ab5-a4ef17a0caed -->
  <rule id="621264" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1012 — Event Log Clearing (hive)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>