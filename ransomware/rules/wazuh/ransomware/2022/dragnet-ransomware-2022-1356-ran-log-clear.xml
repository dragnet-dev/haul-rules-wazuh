<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1356 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 49299ec0-f809-5e1a-a80c-61b1d49a15e9 -->
  <rule id="120780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1356 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>