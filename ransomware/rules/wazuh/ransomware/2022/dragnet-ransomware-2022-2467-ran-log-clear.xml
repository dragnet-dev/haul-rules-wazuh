<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2467 — Event Log Clearing (bianlian) | Status: deprecated | Sigma ID: 498e8922-62bb-5d29-a7e0-5f5ddb4f02a4 -->
  <rule id="882892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2467 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>