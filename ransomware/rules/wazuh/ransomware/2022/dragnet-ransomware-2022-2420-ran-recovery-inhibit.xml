<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2420 — Recovery Inhibition (avoslocker) | Status: deprecated | Sigma ID: 1192e124-9043-52b8-be3d-d8623c75a583 -->
  <rule id="208612" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2420 — Recovery Inhibition (avoslocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>