<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1379 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 8d98676a-b280-56f7-a1a2-331fc5d7e663 -->
  <rule id="619867" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1379 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>