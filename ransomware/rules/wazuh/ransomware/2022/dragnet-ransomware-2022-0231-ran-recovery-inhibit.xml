<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0231 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 40eeee25-5ab7-52e2-8073-093b5df80600 -->
  <rule id="982606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0231 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>