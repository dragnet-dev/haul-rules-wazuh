<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0337 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 7b82341d-3d4e-5e70-9066-0d6b5c47aaa9 -->
  <rule id="438234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0337 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>