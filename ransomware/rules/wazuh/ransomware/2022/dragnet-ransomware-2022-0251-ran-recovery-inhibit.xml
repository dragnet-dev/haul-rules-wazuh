<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0251 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: 221b2bb8-85d3-548b-af37-4428f9e17eaa -->
  <rule id="181019" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0251 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>