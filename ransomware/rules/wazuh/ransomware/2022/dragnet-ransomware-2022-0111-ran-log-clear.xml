<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0111 — Event Log Clearing (karakurt) | Status: deprecated | Sigma ID: d760fd2c-81bf-5cac-8c58-0b0cdf1762d2 -->
  <rule id="922813" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0111 — Event Log Clearing (karakurt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>