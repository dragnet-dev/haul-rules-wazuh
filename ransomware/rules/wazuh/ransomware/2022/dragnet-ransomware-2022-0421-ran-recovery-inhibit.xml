<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0421 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 2eafc996-5e3d-5dbd-a100-b83fc59dc232 -->
  <rule id="212289" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0421 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>