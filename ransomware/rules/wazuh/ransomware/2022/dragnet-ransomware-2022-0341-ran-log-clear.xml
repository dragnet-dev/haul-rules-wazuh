<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0341 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 700d16cd-d7b7-5cfa-98f1-d2fc383994b6 -->
  <rule id="321316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0341 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>