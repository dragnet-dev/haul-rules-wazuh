<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0693 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 39890cab-c1fd-549a-9564-2a5e45e2bb1a -->
  <rule id="412042" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0693 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>