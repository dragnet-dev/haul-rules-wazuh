<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2206 — Event Log Clearing (midas) | Status: deprecated | Sigma ID: 2335a58c-d2bb-56bb-85af-6f0b1c86059d -->
  <rule id="237058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2206 — Event Log Clearing (midas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>