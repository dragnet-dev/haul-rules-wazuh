<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0426 — Event Log Clearing (ragnarlocker) | Status: deprecated | Sigma ID: 9d2a2fbd-2674-5d65-81c1-d747c7f1651e -->
  <rule id="525967" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0426 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>