<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2179 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ca80bc2f-c310-58cd-bb61-c14da545ac36 -->
  <rule id="791868" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2179 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>