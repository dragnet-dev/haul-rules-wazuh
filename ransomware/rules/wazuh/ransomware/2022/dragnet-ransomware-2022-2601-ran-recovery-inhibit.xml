<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2601 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: d588e046-cffb-58f6-8c82-61eacd73d355 -->
  <rule id="474220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2601 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
