<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1301 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: cce50711-6eee-5e7a-85f7-083f105b2df2 -->
  <rule id="678507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1301 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>