<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1781 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 1b121a34-31b8-5444-bb05-d1384e31e7de -->
  <rule id="839463" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1781 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>