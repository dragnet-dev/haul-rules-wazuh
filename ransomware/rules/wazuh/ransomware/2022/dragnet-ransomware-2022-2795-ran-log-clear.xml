<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2795 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: c5726efc-74d1-5a9f-85b3-cf71ecb18052 -->
  <rule id="311630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2795 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>