<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2354 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 567bab3e-7afe-5b65-aa72-20657fc5892e -->
  <rule id="625419" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2354 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>