<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0199 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 6de0b1b2-d7d6-53fa-868d-4bdd82ae47c1 -->
  <rule id="212911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0199 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>