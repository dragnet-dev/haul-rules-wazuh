<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2429 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: edfef5ac-dc71-573c-b736-9e420ce543c8 -->
  <rule id="848315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2429 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>