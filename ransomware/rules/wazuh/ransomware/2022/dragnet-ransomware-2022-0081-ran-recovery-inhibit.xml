<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0081 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 11484b60-aded-582a-bdb7-68adcb9e581a -->
  <rule id="137556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0081 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>