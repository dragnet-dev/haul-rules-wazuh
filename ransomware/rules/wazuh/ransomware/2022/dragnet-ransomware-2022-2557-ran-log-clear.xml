<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2557 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: a9ec142c-0e3c-5cdd-8c88-31c10f3c6330 -->
  <rule id="214014" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2557 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>