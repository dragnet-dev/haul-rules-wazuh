<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1532 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 96085d48-8019-5169-b44c-4eb6b9c6d0c4 -->
  <rule id="737373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1532 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>