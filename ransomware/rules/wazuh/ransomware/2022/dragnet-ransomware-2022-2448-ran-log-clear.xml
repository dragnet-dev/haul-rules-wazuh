<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2448 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 581334cb-1c66-5a1f-afad-c6fbcd43e9f7 -->
  <rule id="401356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2448 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>