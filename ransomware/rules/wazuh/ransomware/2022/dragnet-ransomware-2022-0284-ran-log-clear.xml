<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0284 — Event Log Clearing (ransomhouse) | Status: deprecated | Sigma ID: 3162ecf9-b176-5abe-a807-fe8c4ba41775 -->
  <rule id="455343" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0284 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>