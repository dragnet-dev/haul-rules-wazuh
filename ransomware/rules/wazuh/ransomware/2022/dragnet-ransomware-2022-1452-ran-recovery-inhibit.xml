<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1452 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: aabe6921-bad3-5b2f-94ed-7f9972555350 -->
  <rule id="871069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1452 — Recovery Inhibition (lockbit3)</description>
