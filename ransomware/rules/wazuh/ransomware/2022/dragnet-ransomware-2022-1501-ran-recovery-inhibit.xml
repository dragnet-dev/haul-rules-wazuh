<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1501 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: c7f5f4c7-6a09-598e-bd80-9bf5a7dd956d -->
  <rule id="676154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1501 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>