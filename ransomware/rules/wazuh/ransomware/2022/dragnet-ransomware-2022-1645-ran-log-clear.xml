<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1645 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: 9f2991e2-1ebc-5042-8531-37b733b1a0c7 -->
  <rule id="792991" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1645 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>