<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1968 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 14a0e6f5-e671-52aa-95ab-414b2ec12c09 -->
  <rule id="692751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1968 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>