<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2131 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 5f81422a-72cd-528c-b2f3-66fd77b24941 -->
  <rule id="681422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2131 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>