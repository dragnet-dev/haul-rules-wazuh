  <rule id="322157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1944 — Recovery Inhibition (icefire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
