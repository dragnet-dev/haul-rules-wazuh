<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2298 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: c0b5ab5a-21e4-5e20-802c-27dcd44c0957 -->
  <rule id="544811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2298 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>