<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1715 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 06144a4f-68f5-5a56-937d-171649434396 -->
  <rule id="530319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1715 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>