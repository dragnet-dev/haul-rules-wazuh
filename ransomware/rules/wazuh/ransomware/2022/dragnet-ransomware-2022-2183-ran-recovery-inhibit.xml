<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2183 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 66253f55-994b-53c8-8278-2925c8964f50 -->
  <rule id="260063" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2183 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>