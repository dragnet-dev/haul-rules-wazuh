<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0549 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 6b22b2c2-01d5-5c67-ae51-abebe187e013 -->
  <rule id="915632" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0549 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>