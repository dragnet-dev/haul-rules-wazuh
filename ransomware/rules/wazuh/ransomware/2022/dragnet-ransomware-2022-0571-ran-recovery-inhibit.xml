<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0571 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 549bb1bf-60bc-5a8d-a957-3126de955c65 -->
  <rule id="607311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0571 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>