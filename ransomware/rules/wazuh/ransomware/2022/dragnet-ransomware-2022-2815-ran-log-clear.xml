<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2815 — Event Log Clearing (royal) | Status: deprecated | Sigma ID: 0d2ac46a-ae4a-5592-bd89-89d15c9ae6fc -->
  <rule id="796446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2815 — Event Log Clearing (royal)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>