<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0946 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: ccddfaa9-a347-510e-9cb2-d51cf71337e4 -->
  <rule id="926170" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0946 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>