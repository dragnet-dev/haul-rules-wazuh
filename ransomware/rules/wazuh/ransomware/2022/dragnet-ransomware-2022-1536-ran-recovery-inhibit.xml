<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1536 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 79cadfea-ae7b-5bd2-afe7-949231106992 -->
  <rule id="829279" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1536 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
