<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1181 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: a37e54e6-ed9d-5283-b339-9c2c50ed7b81 -->
  <rule id="860654" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1181 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>