<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2889 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 1c89f8f3-3aef-541e-94a3-1cde9eea64de -->
  <rule id="298383" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2889 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>