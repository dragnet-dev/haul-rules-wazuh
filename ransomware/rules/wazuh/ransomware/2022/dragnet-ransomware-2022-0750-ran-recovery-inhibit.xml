<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0750 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 166c9b9d-aa87-5651-a166-a5fa1de2e026 -->
  <rule id="770359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0750 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>