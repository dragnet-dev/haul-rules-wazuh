<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0698 — Recovery Inhibition (avoslocker) | Status: deprecated | Sigma ID: 07d538ee-8f1f-5334-abbd-ddf35ca69919 -->
  <rule id="308622" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0698 — Recovery Inhibition (avoslocker)</description>
