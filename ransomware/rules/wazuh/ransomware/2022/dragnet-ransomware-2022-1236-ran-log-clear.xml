<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1236 — Event Log Clearing (midas) | Status: deprecated | Sigma ID: 4ce2a7b8-6568-5f2c-a0d9-fad77737c6fb -->
  <rule id="268427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1236 — Event Log Clearing (midas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>