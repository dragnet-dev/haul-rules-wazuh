<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1991 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 741053b7-ebe4-5068-8b81-1a1e15b694b9 -->
  <rule id="256859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1991 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>