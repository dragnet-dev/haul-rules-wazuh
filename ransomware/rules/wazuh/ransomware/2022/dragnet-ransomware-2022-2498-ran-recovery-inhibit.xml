<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2498 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 893abaad-b4bf-5d89-8390-7bd6b2c7e09c -->
  <rule id="160474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2498 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>