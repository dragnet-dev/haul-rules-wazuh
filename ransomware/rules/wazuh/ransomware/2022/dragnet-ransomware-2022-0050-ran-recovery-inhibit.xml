<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0050 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 2ee71f13-96c2-58a7-a4ea-c62ca2d6c2db -->
  <rule id="401151" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0050 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>