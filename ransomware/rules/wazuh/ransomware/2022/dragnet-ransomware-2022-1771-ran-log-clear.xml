<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1771 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 2ef6f8a4-fbc0-5b1d-a4dc-142b5746ba5d -->
  <rule id="402718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1771 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>