<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1222 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: e2526a9d-173c-5cef-84cf-9fdd5891ab66 -->
  <rule id="580426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1222 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>