<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2620 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: ed59323b-9708-5fe4-8ba2-f5ae43044309 -->
  <rule id="675932" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2620 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>