<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2466 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: 9561cbc8-4469-553b-976e-93c2d25f5662 -->
  <rule id="747819" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2466 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
