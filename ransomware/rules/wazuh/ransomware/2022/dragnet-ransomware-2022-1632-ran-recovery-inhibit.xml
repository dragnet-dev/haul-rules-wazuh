<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1632 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b405afd1-5abf-52e9-85df-3f1ce4d64a25 -->
  <rule id="319855" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1632 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>