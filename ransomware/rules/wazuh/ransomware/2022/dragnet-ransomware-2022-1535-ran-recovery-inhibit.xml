<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1535 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 6555be49-ee8a-5f7f-bf79-b364f6991460 -->
  <rule id="878270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1535 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>