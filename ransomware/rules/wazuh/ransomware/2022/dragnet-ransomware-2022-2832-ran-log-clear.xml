<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2832 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: 181dd5e7-9c15-5777-a3fc-b5b6b5286e77 -->
  <rule id="349214" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2832 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>