<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2781 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 2d2216f4-c1a3-5e98-add0-fb2a27ff9e1a -->
  <rule id="135471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2781 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>