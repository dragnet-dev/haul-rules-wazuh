<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1799 — Event Log Clearing (ransomhouse) | Status: deprecated | Sigma ID: 6bdae4a6-bfc5-559c-b491-3756fad3d7e5 -->
  <rule id="917744" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1799 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>