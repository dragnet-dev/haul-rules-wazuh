<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2433 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 5ebeabb2-ddf9-5cf0-a7da-988c9baaeb74 -->
  <rule id="909195" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2433 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>