<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0488 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 3f49285f-3abd-5e33-b636-7b43c8beaf92 -->
  <rule id="149285" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0488 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>