<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0194 — Event Log Clearing (leaktheanalyst) | Status: deprecated | Sigma ID: 3dfc76a7-62ea-50eb-82e8-e0c601ec43dd -->
  <rule id="786876" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0194 — Event Log Clearing (leaktheanalyst)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>