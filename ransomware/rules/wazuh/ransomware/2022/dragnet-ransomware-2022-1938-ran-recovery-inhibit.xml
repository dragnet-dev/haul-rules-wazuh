<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1938 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: f73be5da-da01-5c56-902b-aae663593d1b -->
  <rule id="528785" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1938 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
