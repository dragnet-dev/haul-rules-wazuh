<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1800 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 76cc40b1-b367-5aba-9117-ef6b99bfae5e -->
  <rule id="266040" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1800 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>