<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2132 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 62e1c98f-10d1-5b49-97ef-6e3cb5db6746 -->
  <rule id="809889" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2132 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>