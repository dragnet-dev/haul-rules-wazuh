<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0656 — Event Log Clearing (sabbath) | Status: deprecated | Sigma ID: 6b5f3fa7-45f4-5db9-bfba-dc8501530971 -->
  <rule id="154463" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0656 — Event Log Clearing (sabbath)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>