<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2688 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 3d39b6ca-a126-5a13-b6b9-dc74a290b0b5 -->
  <rule id="517708" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2688 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>