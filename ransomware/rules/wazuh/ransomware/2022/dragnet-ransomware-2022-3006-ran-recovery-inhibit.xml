<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3006 — Recovery Inhibition (suncrypt) | Status: deprecated | Sigma ID: 76cb8e0b-a41f-5c47-acce-ad1e8b02ef58 -->
  <rule id="545582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3006 — Recovery Inhibition (suncrypt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>