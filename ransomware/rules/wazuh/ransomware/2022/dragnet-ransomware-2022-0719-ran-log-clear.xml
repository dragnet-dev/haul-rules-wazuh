<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0719 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: da4d34eb-3d6a-5c25-84ac-e8c8d04462b9 -->
  <rule id="895734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0719 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>