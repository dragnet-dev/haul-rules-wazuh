<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2379 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 518786d4-e3ec-502b-a5e7-70d9d1e72ae7 -->
  <rule id="300589" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2379 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>