<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0018 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: 1b98008c-f9ed-5378-8b2f-8b9ce084c1a2 -->
  <rule id="198008" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0018 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>