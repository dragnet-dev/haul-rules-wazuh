<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1433 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 7ba08c45-67cb-5b82-a7d4-74c5bad56a84 -->
  <rule id="564940" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1433 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>