<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0282 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: b8ccc781-64a8-5ec1-87ae-8a80ec95fcf1 -->
  <rule id="466047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0282 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>