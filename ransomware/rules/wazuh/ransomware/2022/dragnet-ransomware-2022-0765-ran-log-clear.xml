<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0765 — Event Log Clearing (hive) | Status: deprecated | Sigma ID: 9f5c6006-bd76-562e-ac47-b548b683ddaf -->
  <rule id="853260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0765 — Event Log Clearing (hive)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>