<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2818 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: dbbf9bbd-1642-5a6e-8c07-ae0d90380369 -->
  <rule id="100955" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2818 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>