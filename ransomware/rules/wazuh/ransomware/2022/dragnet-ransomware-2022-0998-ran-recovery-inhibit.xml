<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0998 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 68d727ad-b03b-55cc-a180-a11a96fd700e -->
  <rule id="301727" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0998 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>