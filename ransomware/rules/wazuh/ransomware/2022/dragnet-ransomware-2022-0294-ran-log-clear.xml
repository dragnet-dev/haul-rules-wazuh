<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0294 — Event Log Clearing (cuba) | Status: deprecated | Sigma ID: 48ae2e21-fdf8-517a-bcfa-ef1e1174b0d7 -->
  <rule id="293966" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0294 — Event Log Clearing (cuba)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>