<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2368 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: c3ab18be-e5d5-5a84-b367-74baf3432b4c -->
  <rule id="565918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2368 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>