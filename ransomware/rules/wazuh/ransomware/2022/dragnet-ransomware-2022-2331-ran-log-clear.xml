<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2331 — Event Log Clearing (avoslocker) | Status: deprecated | Sigma ID: 75e4746a-f6b8-55fe-8443-0dc50bcae11f -->
  <rule id="414474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2331 — Event Log Clearing (avoslocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>