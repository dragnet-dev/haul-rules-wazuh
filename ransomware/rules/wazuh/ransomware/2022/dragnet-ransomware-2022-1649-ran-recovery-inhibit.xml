<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1649 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 102ca0b5-95e5-5310-99d6-d2cc177a1843 -->
  <rule id="710251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1649 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>