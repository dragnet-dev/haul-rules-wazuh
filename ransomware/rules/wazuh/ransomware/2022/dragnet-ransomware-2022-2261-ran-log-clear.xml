<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2261 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 139c1d1f-101f-56ba-9e98-0153f3206bf7 -->
  <rule id="977891" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2261 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>