<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1267 — Event Log Clearing (clop) | Status: experimental | Sigma ID: d7de27e1-c1a5-59cc-a906-0db42147d26b -->
  <rule id="929427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1267 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>