<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1733 — Event Log Clearing (unsafe) | Status: deprecated | Sigma ID: 0287b1f7-14ca-5148-9a18-a9c1083ef1e3 -->
  <rule id="265117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1733 — Event Log Clearing (unsafe)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>