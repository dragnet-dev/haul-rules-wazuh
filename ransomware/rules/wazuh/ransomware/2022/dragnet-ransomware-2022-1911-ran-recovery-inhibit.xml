<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1911 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 7e5feff0-5d5f-5bc1-b3ab-4215a0e23cef -->
  <rule id="785519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1911 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>