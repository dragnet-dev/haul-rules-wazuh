<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1620 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0a7d8fe9-3acc-5d3a-a230-da229edf4850 -->
  <rule id="918302" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1620 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>