<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1213 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 4729723c-4777-591c-9ea5-50e31fd24ff4 -->
  <rule id="329723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1213 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>