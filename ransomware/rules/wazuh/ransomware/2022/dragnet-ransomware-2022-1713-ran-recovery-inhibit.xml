<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1713 — Recovery Inhibition (suncrypt) | Status: deprecated | Sigma ID: 39730ecc-4af5-59cd-bdae-e547fd5910be -->
  <rule id="371116" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1713 — Recovery Inhibition (suncrypt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>