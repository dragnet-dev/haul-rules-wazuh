<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2341 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: c0c6b0a2-82f6-5db9-861f-346ae0cb5862 -->
  <rule id="492270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2341 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>