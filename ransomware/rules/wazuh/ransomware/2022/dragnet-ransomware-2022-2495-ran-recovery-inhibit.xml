<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2495 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 53e7d0df-5ac4-5198-9325-9716f6121172 -->
  <rule id="580450" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2495 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
