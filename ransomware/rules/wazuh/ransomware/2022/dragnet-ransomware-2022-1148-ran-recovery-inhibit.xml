<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1148 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: de4560ec-173f-52ac-9224-881ad57e84f8 -->
  <rule id="524560" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1148 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>