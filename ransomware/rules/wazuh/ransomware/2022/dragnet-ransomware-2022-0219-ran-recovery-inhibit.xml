<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0219 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 8fcf1e87-07ef-5357-9ca8-d3b030509e49 -->
  <rule id="590430" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0219 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>