<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0619 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: 5f6b4698-78d2-5ecc-acc2-76e13ae1dfcb -->
  <rule id="730746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0619 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>