<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0236 — Event Log Clearing (shaoleaks) | Status: deprecated | Sigma ID: 076c078d-4927-5333-8562-634310033b90 -->
  <rule id="428078" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0236 — Event Log Clearing (shaoleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>