<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1444 — Event Log Clearing (cuba) | Status: deprecated | Sigma ID: d74ef9b6-e36c-5e8b-b78e-16c4fc9b24de -->
  <rule id="919839" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1444 — Event Log Clearing (cuba)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>