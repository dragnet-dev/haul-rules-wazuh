<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3001 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: f90f070d-8bf5-5077-8be8-63513f784f86 -->
  <rule id="845507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3001 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>