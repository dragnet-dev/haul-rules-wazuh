<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0855 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 9480e607-b45c-5cf6-a19d-707baf59057f -->
  <rule id="716946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0855 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>