<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1371 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 4760cf72-9e4f-5043-bcb8-6d6310969c72 -->
  <rule id="418767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1371 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
