<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2607 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: 69fc133d-03c0-5669-b6d7-5d8b3dcfb9c0 -->
  <rule id="991613" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2607 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>