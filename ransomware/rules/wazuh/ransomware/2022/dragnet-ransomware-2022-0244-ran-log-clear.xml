<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0244 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: f69d9a9a-4cdf-5e52-9f2a-0a17c1dde54e -->
  <rule id="518874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0244 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>