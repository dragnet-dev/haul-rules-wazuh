<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1622 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 5beb6b5d-7fea-5df7-93ad-3a35b3b9c30c -->
  <rule id="265067" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1622 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>