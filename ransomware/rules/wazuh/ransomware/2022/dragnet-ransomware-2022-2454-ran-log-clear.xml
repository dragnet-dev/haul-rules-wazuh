<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2454 — Event Log Clearing (shaoleaks) | Status: deprecated | Sigma ID: e05e9001-24b5-58bc-92de-cd7fedcbc07d -->
  <rule id="549490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2454 — Event Log Clearing (shaoleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>