<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1996 — Recovery Inhibition (royal) | Status: deprecated | Sigma ID: 200730ad-a2c2-5bda-a54f-8cab0338d12b -->
  <rule id="611690" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1996 — Recovery Inhibition (royal)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>