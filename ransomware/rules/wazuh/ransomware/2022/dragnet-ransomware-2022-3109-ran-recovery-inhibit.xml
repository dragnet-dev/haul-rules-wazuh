<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3109 — Recovery Inhibition (onyx) | Status: deprecated | Sigma ID: d0860326-419f-5dbc-9025-77bf95ebbd8f -->
  <rule id="508603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3109 — Recovery Inhibition (onyx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>