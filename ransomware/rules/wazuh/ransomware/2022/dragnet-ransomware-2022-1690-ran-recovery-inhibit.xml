<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1690 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e5a26f57-231f-5cf1-9019-593574ca6034 -->
  <rule id="228431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1690 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
