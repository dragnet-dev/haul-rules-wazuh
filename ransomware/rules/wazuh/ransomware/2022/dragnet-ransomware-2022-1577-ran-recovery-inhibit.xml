<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1577 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: a8585efd-842a-578e-828c-2f271c4f76cb -->
  <rule id="937374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1577 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>