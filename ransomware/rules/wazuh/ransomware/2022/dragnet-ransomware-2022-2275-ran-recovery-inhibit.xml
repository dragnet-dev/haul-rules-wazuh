<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2275 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: b0fc2120-76fb-56c3-83d7-88069a5deb58 -->
  <rule id="241221" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2275 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>