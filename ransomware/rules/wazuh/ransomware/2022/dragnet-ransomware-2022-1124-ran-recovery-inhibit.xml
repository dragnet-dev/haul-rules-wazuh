<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1124 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 02450734-f855-5d79-9955-d0d62a52d5fb -->
  <rule id="750734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1124 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>