<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2780 — Event Log Clearing (yanluowang) | Status: deprecated | Sigma ID: 605c13c0-c8b0-5c47-8ba1-6c86f287c79b -->
  <rule id="307420" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2780 — Event Log Clearing (yanluowang)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>