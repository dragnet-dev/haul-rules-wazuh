<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1058 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 11e93a86-5fea-5126-867b-f393a9b04b62 -->
  <rule id="454988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1058 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>