<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1041 — Event Log Clearing (alphv) | Status: deprecated | Sigma ID: 0ee960c5-7d21-525c-b6a8-04c51c6f22f8 -->
  <rule id="323372" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1041 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>