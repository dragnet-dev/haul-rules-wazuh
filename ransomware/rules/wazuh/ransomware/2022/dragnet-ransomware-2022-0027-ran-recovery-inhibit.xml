<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0027 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 340e571d-4ca6-5d7f-a010-d3ffe02871f2 -->
  <rule id="154571" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0027 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>