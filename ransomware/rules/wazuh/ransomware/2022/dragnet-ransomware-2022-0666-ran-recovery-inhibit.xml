<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0666 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 2f21df87-50c4-51bd-8f27-ca13530c4c50 -->
  <rule id="408799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0666 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>