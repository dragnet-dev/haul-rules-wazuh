<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3547 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: cb593a06-3bd6-5fb6-ac8f-28d2675005b0 -->
  <rule id="657498" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3547 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>