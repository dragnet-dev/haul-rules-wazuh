<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2164 — Recovery Inhibition (play) | Status: stable | Sigma ID: 9981ab19-7d3d-510e-af45-fed5b5ed6d31 -->
  <rule id="855307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2164 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>