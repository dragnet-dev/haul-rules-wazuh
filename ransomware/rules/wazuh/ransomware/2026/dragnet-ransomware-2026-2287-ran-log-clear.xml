<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2287 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: b03c3efb-c8b5-50c8-84a6-baeec7f9ae8b -->
  <rule id="225662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2287 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>