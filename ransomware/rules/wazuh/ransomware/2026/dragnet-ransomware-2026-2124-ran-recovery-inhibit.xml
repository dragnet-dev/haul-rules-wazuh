<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2124 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 7d6653dd-a23a-5871-9bd2-205896c0c15d -->
  <rule id="456653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2124 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>