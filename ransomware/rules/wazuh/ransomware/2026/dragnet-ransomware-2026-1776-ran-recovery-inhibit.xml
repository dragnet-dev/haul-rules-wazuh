<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1776 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: 2fc2b4ac-492b-5834-9936-19735c4a942d -->
  <rule id="422834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1776 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>