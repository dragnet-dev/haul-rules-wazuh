<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3199 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: 7618c3a0-8efa-5853-ac4f-4ae512c7c7b4 -->
  <rule id="419003" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3199 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>