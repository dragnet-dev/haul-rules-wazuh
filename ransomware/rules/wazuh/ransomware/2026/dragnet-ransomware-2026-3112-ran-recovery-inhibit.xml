<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3112 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 4131741b-c085-567b-aa4c-298cd2bb81f9 -->
  <rule id="631741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3112 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>