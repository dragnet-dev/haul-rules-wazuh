<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3512 — Event Log Clearing (PrinzEugen) | Status: stable | Sigma ID: a6136941-f200-55e6-a4c2-de89a9b843ff -->
  <rule id="261369" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3512 — Event Log Clearing (PrinzEugen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>