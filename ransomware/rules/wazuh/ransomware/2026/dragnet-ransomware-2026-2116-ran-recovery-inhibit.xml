<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2116 — Recovery Inhibition (termite) | Status: test | Sigma ID: 1a12ed81-4ec8-5828-b196-743332839f4f -->
  <rule id="489098" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2116 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
