<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1761 — Event Log Clearing (genesis) | Status: test | Sigma ID: d948af07-3c42-5a31-a3ee-4cd658fedf55 -->
  <rule id="970863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1761 — Event Log Clearing (genesis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>