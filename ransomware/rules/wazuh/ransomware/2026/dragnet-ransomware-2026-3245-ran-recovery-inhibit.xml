<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3245 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: a9359860-a964-5054-81fb-7581c9a1321f -->
  <rule id="293598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3245 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>