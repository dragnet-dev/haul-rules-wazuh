<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0126 — Event Log Clearing (cipherforce) | Status: stable | Sigma ID: 5f9e3783-7cf0-5c2d-95e2-d179055145a5 -->
  <rule id="735837" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0126 — Event Log Clearing (cipherforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>