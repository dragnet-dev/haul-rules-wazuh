<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0793 — Event Log Clearing (ms13089) | Status: stable | Sigma ID: 50b41fc5-cf36-5c98-ac6a-3a260428044d -->
  <rule id="498271" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0793 — Event Log Clearing (ms13089)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>