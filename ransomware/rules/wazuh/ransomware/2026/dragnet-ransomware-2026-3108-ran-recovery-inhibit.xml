<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3108 — Recovery Inhibition (tridentlocker) | Status: test | Sigma ID: 1a78cf82-f992-5265-b5db-41f3d6177613 -->
  <rule id="657758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3108 — Recovery Inhibition (tridentlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>