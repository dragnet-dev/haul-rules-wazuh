<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2114 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 6f483c47-42b4-5fcf-ae79-e3e481db81ea -->
  <rule id="983740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2114 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>