<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1981 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: aeef355d-22ce-551d-9efb-7d3192cb1ff0 -->
  <rule id="978335" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1981 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>