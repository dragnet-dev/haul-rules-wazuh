<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1198 — Recovery Inhibition (play) | Status: stable | Sigma ID: 6d9b9c16-7cbf-5518-80b6-3fd01870f34a -->
  <rule id="215356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1198 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
