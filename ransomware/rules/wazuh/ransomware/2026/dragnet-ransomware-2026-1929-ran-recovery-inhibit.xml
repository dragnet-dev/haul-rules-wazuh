<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1929 — Recovery Inhibition (anubis) | Status: stable | Sigma ID: 4d15b9ea-ff13-5af7-b43a-ddfc4aea58fd -->
  <rule id="434519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1929 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>