<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2596 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 27d52059-daa4-5f3d-a532-a26b38d2e0a9 -->
  <rule id="955205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2596 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>