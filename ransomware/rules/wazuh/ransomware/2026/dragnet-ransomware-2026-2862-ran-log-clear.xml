<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2862 — Event Log Clearing (krybit) | Status: stable | Sigma ID: c0b5c831-a058-5c01-ad31-e447e7e0ce66 -->
  <rule id="490528" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2862 — Event Log Clearing (krybit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>