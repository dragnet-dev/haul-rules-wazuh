<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0030 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 4ac1fc3d-4625-5cab-85c7-92fe09b1fac4 -->
  <rule id="462268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0030 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>