<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3155 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 1e6ff925-55ff-5892-9e8b-9192b0d5d465 -->
  <rule id="759192" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3155 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>