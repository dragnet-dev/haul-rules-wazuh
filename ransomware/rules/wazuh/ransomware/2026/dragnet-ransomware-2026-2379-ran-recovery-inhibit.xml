<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2379 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 0f6abefa-ef05-55f6-965d-94c6a7119eaa -->
  <rule id="467631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2379 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>