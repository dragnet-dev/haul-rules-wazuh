<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0786 — Recovery Inhibition (titan) | Status: stable | Sigma ID: 3724aeca-a87c-582d-a407-b3a1537b4372 -->
  <rule id="956300" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0786 — Recovery Inhibition (titan)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>