<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2337 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: e44d7e0e-7be1-59b5-aa5d-6d55af1fe2e7 -->
  <rule id="198846" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2337 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>