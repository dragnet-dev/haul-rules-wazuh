<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3188 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: f28f8ed3-972e-58a2-9b16-0788aa5dce2d -->
  <rule id="414222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3188 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>