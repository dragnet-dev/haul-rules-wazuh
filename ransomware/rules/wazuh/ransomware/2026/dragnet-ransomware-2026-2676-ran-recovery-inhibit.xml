<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2676 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 24d9231f-24de-544b-a5d2-22d23bcf167a -->
  <rule id="479231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2676 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>