<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2161 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: c908a216-bd33-5e3a-82ed-f7fbe350cf19 -->
  <rule id="365382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2161 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>