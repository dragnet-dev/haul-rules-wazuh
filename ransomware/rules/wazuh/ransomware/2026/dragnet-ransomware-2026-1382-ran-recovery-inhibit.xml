<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1382 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: dd6ad4ff-7bf0-57d1-baf9-50bda3c58f6e -->
  <rule id="374694" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1382 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>