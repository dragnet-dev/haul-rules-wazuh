<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3488 — Recovery Inhibition (fulcrumsec) | Status: stable | Sigma ID: 2db8f840-c4dd-59f3-bc23-eaaa822e1652 -->
  <rule id="371038" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3488 — Recovery Inhibition (fulcrumsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>