<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0440 — Event Log Clearing (sinobi) | Status: test | Sigma ID: e9e3ecd0-6692-50de-9555-bc9da21c1853 -->
  <rule id="839884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0440 — Event Log Clearing (sinobi)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>