<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1688 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: d9683ae5-a55e-5041-8c9e-e3681eff6cd8 -->
  <rule id="534938" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1688 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>