<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3191 — Event Log Clearing (osiris) | Status: deprecated | Sigma ID: b38a2efe-f419-5931-b495-723fc70e6147 -->
  <rule id="314926" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3191 — Event Log Clearing (osiris)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>