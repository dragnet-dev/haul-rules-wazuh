<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1362 — Event Log Clearing (aurora) | Status: stable | Sigma ID: 7110d259-253e-5ca4-92f7-e685a5527ad3 -->
  <rule id="337732" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1362 — Event Log Clearing (aurora)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>