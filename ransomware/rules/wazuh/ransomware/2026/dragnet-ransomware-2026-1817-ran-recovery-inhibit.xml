<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1817 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: b3710235-a718-5083-a5b3-f553c87a2488 -->
  <rule id="337102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1817 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>