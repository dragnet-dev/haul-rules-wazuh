<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2931 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: bb215592-ff1c-5db9-a22c-03d06476f656 -->
  <rule id="172155" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2931 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>