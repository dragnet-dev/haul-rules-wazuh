<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0720 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 68b6be61-6836-5888-96af-8d8499e2fe18 -->
  <rule id="215166" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0720 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>