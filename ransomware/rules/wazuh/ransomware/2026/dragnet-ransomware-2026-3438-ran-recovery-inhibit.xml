<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3438 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: cfee0096-59e9-5201-9083-667968ae05df -->
  <rule id="923000" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3438 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>