<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1353 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: f50c6acd-0b67-576d-892a-e6a7ebb1c82b -->
  <rule id="470026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1353 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>