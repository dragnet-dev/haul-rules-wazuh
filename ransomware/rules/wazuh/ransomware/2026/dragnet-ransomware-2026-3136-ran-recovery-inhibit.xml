<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3136 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 94642926-de84-5577-a04c-a66c408125f9 -->
  <rule id="564292" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3136 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>