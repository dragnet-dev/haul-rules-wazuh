<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2976 — Recovery Inhibition (lynx) | Status: stable | Sigma ID: cb0088ae-11c6-594a-8afc-69f992a9fda8 -->
  <rule id="330088" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2976 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>