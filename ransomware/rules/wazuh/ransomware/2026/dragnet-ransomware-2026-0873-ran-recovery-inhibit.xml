<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0873 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 2c31f4b6-73b8-56db-bccb-bc212a27362a -->
  <rule id="645835" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0873 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>