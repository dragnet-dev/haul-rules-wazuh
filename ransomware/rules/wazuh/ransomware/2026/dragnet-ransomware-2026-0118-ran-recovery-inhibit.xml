<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0118 — Recovery Inhibition (termite) | Status: stable | Sigma ID: c64c1893-e000-5be8-8334-b2851af842d1 -->
  <rule id="323618" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0118 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>