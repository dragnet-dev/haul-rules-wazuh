<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3386 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 6412f2f6-2773-5feb-b5f9-e40004fe6247 -->
  <rule id="226072" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3386 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>