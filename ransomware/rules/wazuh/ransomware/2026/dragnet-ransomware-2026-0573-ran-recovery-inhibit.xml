<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0573 — Recovery Inhibition (pear) | Status: stable | Sigma ID: 180cd1e3-597a-59e1-84ef-d78069ee324d -->
  <rule id="305630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0573 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>