<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0015 — Recovery Inhibition (clop) | Status: test | Sigma ID: c5286065-ebfc-5e96-bb0d-1fa2b5b1d202 -->
  <rule id="452860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0015 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
