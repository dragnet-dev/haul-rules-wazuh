<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2722 — Recovery Inhibition (pear) | Status: stable | Sigma ID: 3bb676ab-2d30-5f1e-bd69-9028d39759bb -->
  <rule id="990826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2722 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>