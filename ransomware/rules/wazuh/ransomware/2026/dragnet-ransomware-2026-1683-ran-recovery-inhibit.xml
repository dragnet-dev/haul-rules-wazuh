<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1683 — Recovery Inhibition (pear) | Status: stable | Sigma ID: 5e8ecfec-362f-53eb-ae1a-df24417c8cb5 -->
  <rule id="386799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1683 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>