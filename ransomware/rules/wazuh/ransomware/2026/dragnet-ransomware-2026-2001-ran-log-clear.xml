<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2001 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 36c9eec0-ca0e-5a1c-8aa3-59d2d8144547 -->
  <rule id="707822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2001 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>