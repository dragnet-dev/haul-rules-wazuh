<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2289 — Recovery Inhibition (netrunner) | Status: stable | Sigma ID: f628032d-6e43-5c32-8a3f-15118a1f1ca3 -->
  <rule id="762803" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2289 — Recovery Inhibition (netrunner)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>