<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0382 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 2fb0dc7a-b208-5d8e-9d96-d35e3b9ea396 -->
  <rule id="253500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0382 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>