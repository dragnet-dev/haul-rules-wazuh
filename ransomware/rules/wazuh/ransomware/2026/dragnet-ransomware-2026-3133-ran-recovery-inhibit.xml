<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3133 — Recovery Inhibition (AiLock) | Status: deprecated | Sigma ID: c14c445a-5371-5450-a3a9-9e8616e10908 -->
  <rule id="243644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3133 — Recovery Inhibition (AiLock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>