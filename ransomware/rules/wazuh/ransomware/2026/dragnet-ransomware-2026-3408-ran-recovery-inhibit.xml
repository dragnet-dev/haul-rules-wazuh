<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3408 — Recovery Inhibition (threeam) | Status: stable | Sigma ID: 7cae0187-6bc4-5f39-82db-fcf12b0078b0 -->
  <rule id="591801" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3408 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>