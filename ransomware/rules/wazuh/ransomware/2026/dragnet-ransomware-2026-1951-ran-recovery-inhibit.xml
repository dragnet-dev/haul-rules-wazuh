<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1951 — Recovery Inhibition (insomnia) | Status: stable | Sigma ID: 3d35231c-19ff-5bf4-a699-72e18671d233 -->
  <rule id="835231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1951 — Recovery Inhibition (insomnia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>