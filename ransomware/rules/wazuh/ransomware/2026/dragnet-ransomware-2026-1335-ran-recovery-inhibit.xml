<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1335 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: d6fb3154-cce3-5961-bef2-75e8822dd283 -->
  <rule id="906731" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1335 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>