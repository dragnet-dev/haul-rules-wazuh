<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0655 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 10d3f15b-90f2-55c4-883f-e17c1e624404 -->
  <rule id="174315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0655 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>