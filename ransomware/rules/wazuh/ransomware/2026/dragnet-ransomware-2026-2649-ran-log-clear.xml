<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2649 — Event Log Clearing (m3rx) | Status: stable | Sigma ID: 4fd3e0c6-5e47-5bfe-b348-f711ad976550 -->
  <rule id="343820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2649 — Event Log Clearing (m3rx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>