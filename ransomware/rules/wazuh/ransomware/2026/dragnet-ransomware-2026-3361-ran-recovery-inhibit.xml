<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3361 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 8cb600a6-1d01-5e36-9d44-afa7285f7429 -->
  <rule id="551600" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3361 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>