<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2212 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: da945c52-520b-5f4d-b67f-8c79c5393850 -->
  <rule id="903132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2212 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>