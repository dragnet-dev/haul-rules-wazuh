<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2376 — Shadow Copy Deletion (SilentRansomGroup) | Status: deprecated | Sigma ID: 6375ac2b-6d10-5425-8d2b-51e25f6f4f23 -->
  <rule id="832172" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2376 — Shadow Copy Deletion (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>