<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2595 — Recovery Inhibition (threeam) | Status: stable | Sigma ID: 0801bc83-1d1c-59c4-b8fb-148aba08497f -->
  <rule id="352448" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2595 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>