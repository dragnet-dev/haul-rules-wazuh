<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3496 — Recovery Inhibition (everest) | Status: stable | Sigma ID: f39c5134-35e1-5c5e-85b7-1ed084dce3d4 -->
  <rule id="763651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3496 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>