<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2038 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 67757498-5ce8-5a11-80e7-6223af8b91ef -->
  <rule id="575749" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2038 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>