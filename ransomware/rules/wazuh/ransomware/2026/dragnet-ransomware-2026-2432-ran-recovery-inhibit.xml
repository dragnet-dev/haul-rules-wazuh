<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2432 — Recovery Inhibition (devman) | Status: test | Sigma ID: a7deaaa2-5bf9-545a-bee3-34762032b5c5 -->
  <rule id="869354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2432 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>