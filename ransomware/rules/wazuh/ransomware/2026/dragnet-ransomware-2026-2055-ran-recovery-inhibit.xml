<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2055 — Recovery Inhibition (aurora) | Status: stable | Sigma ID: acd7e8f6-6975-57b7-9d92-80e04c3c245a -->
  <rule id="925268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2055 — Recovery Inhibition (aurora)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>