<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1682 — Recovery Inhibition (AuditTeam) | Status: stable | Sigma ID: f620c875-3d65-5a86-90eb-b97105726868 -->
  <rule id="799328" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1682 — Recovery Inhibition (AuditTeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
