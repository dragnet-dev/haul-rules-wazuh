<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0744 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: dded2164-e119-52ff-a368-236e43b145ba -->
  <rule id="381321" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0744 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>