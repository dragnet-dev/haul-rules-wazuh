<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1302 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: cf0beabd-21f6-54aa-a4fe-f328edd98789 -->
  <rule id="481770" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1302 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>