<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2723 — Recovery Inhibition (pear) | Status: stable | Sigma ID: 1fbd6956-19fe-5564-9008-77150af4626c -->
  <rule id="125695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2723 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>