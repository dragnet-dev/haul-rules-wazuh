<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2705 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: b9467df8-c12c-5b81-af74-20ae1a4723ed -->
  <rule id="211485" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2705 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>