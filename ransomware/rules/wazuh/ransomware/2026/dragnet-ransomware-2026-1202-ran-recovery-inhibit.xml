<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1202 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: c85df91f-24a6-507b-ae3a-8d9c94e9f204 -->
  <rule id="691839" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1202 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>