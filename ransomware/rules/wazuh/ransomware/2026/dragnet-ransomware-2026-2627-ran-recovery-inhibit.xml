<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2627 — Recovery Inhibition (interlock) | Status: stable | Sigma ID: beb8b731-2f2b-591a-85c1-6dab3cfea3ba -->
  <rule id="482997" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2627 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>