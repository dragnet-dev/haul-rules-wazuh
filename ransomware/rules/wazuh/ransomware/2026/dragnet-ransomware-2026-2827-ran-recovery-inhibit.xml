<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2827 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: ba242b32-995d-558d-ae73-fb894d8cdbaf -->
  <rule id="379883" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2827 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>