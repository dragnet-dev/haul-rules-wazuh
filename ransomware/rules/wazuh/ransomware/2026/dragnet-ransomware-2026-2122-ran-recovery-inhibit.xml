<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2122 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 7f58e512-3bab-5c1a-aa4c-c33d187a55b5 -->
  <rule id="341425" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2122 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>