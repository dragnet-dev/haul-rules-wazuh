<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2554 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: e4cf24ed-7dd0-5539-94a1-d6956c4b6b83 -->
  <rule id="207124" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2554 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>