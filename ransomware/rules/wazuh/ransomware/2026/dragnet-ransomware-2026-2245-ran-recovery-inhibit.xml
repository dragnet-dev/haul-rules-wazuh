<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2245 — Recovery Inhibition (qilin) | Status: test | Sigma ID: d4488374-afda-5be5-be87-2b4668a6e885 -->
  <rule id="544883" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2245 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
