<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1843 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 942f9ea4-4335-53a1-95ae-424b34be66ae -->
  <rule id="714078" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1843 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>