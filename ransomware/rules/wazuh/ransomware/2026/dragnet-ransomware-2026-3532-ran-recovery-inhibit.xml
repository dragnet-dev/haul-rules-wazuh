<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3532 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 09ad9951-3a11-5849-9d16-1b62ca1e27ea -->
  <rule id="777995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3532 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>