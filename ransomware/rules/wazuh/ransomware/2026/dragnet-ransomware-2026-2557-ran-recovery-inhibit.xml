<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2557 — Recovery Inhibition (everest) | Status: stable | Sigma ID: b9c4b0be-c42f-5d87-843e-487b70c1dfe9 -->
  <rule id="466350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2557 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>