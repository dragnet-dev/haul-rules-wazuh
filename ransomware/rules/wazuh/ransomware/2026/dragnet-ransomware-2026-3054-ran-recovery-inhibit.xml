<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3054 — Recovery Inhibition (incransom) | Status: test | Sigma ID: 27feb705-c7f1-582e-9bf5-52bf4183224e -->
  <rule id="346677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3054 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
