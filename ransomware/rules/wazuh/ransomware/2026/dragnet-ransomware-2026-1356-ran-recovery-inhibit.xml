<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1356 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: df91778b-2ee0-5b89-8f68-c4e569f68012 -->
  <rule id="539177" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1356 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>