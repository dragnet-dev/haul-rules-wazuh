<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2657 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: bd6e6c96-ea6b-5751-816d-8dd29d1c7f9e -->
  <rule id="456108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2657 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
