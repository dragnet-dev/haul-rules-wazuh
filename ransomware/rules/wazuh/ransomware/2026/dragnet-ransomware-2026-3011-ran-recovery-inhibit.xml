<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3011 — Recovery Inhibition (spacebears) | Status: stable | Sigma ID: f3532a52-311c-5ae9-9647-4261389b0cd6 -->
  <rule id="756522" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3011 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>