<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3190 — Recovery Inhibition (beast) | Status: stable | Sigma ID: ef62010a-5bfe-5406-9f9b-aed7de7fd013 -->
  <rule id="696201" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3190 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>