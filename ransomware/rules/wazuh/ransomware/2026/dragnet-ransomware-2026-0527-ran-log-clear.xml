<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0527 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 129b0ee8-744f-569c-9b9e-5ffe76ad5f0a -->
  <rule id="912238" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0527 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>