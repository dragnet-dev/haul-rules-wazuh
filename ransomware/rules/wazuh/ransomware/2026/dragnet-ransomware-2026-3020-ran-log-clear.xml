<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3020 — Event Log Clearing (TiMc) | Status: deprecated | Sigma ID: 27af5e82-2642-5206-b4ee-8c8db47ac98f -->
  <rule id="334014" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3020 — Event Log Clearing (TiMc)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>