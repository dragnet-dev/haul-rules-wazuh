<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2681 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 4a7664d5-8990-5ec8-a7c9-930a3778367f -->
  <rule id="362637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2681 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>