<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0765 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 64be19db-3a1b-56e2-9a8c-9ecc44b61bdd -->
  <rule id="857419" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0765 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>