<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2564 — Recovery Inhibition (fulcrumsec) | Status: stable | Sigma ID: 056b3363-dabc-5379-aead-209fa8518f56 -->
  <rule id="173363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2564 — Recovery Inhibition (fulcrumsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>