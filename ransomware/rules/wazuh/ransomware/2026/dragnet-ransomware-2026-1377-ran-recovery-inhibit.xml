<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1377 — Recovery Inhibition (chaos) | Status: stable | Sigma ID: fefb611b-0205-5abd-8653-e38f72246182 -->
  <rule id="327561" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1377 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>