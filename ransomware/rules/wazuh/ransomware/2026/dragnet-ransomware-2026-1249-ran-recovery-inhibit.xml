<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1249 — Recovery Inhibition (handala) | Status: stable | Sigma ID: e706aa4c-0413-5d2b-9912-c1c3d8310dd4 -->
  <rule id="264906" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1249 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>