<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2919 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 45204ed6-64ad-52cf-9e41-4842fea488c4 -->
  <rule id="872461" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2919 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>