<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1821 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 37905558-7a7b-5491-a4ce-31c3f53423f1 -->
  <rule id="290555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1821 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>