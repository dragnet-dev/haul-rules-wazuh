<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2805 — Event Log Clearing (coinbasecartel) | Status: stable | Sigma ID: 23f91553-8417-57e2-b4b6-8cba8ba7c4e4 -->
  <rule id="339155" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2805 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>