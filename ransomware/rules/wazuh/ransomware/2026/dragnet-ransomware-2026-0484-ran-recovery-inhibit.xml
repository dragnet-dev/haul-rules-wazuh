<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0484 — Recovery Inhibition (payload) | Status: stable | Sigma ID: abe977da-7608-5c2f-a5e2-e03f3363776f -->
  <rule id="150977" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0484 — Recovery Inhibition (payload)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>