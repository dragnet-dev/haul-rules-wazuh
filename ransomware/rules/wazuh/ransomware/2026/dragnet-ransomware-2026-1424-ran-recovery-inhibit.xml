<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1424 — Recovery Inhibition (embargo) | Status: stable | Sigma ID: b2557502-f202-544d-9524-f7a525092071 -->
  <rule id="325575" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1424 — Recovery Inhibition (embargo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>