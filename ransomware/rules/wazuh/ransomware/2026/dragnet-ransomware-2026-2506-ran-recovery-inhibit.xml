<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2506 — Recovery Inhibition (everest) | Status: test | Sigma ID: 222b7bad-59b5-5d07-a7c5-0bb25e91c833 -->
  <rule id="223258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2506 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>