<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1777 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: e1cf86e3-6d3f-587f-b2c6-38e124634ede -->
  <rule id="130386" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1777 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>