<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3044 — Recovery Inhibition (mnt6) | Status: stable | Sigma ID: ab085cad-60af-5f7a-9abb-68def659fbbc -->
  <rule id="137372" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3044 — Recovery Inhibition (mnt6)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>