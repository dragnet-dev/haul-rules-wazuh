<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0294 — Recovery Inhibition (mnt6) | Status: stable | Sigma ID: 8ca57af9-84e3-50e5-9d38-c43d780052ad -->
  <rule id="100922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0294 — Recovery Inhibition (mnt6)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>