<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1855 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 4d7a585b-2b03-5f8c-a033-c4370e7cf5e4 -->
  <rule id="444258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1855 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>