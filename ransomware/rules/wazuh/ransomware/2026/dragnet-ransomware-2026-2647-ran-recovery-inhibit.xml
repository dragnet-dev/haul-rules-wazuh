<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2647 — Recovery Inhibition (m3rx) | Status: stable | Sigma ID: f7aeeaae-cfa1-56e0-a6d7-07559e273549 -->
  <rule id="533930" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2647 — Recovery Inhibition (m3rx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>