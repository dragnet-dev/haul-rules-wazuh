<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3227 — Event Log Clearing (vect) | Status: deprecated | Sigma ID: 94113c07-a947-5b3b-9b1c-cf3f477c5f06 -->
  <rule id="705820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3227 — Event Log Clearing (vect)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>