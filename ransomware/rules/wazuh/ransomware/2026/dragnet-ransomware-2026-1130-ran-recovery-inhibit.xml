<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1130 — Recovery Inhibition (thegentlemen) | Status: stable | Sigma ID: 95278036-317b-53fc-a91b-ed1f5340833a -->
  <rule id="627803" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1130 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
