<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2013 — Recovery Inhibition (play) | Status: stable | Sigma ID: 51817f4b-e729-5ea8-a1ee-f8e54138f234 -->
  <rule id="290874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2013 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>