<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2649 — Recovery Inhibition (m3rx) | Status: stable | Sigma ID: 8ee6aca5-c308-5435-9639-db57c0b95024 -->
  <rule id="553868" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2649 — Recovery Inhibition (m3rx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>