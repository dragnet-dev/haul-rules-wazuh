<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1487 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 2e9f1a30-c9a8-5e0b-b005-f505dd29cac3 -->
  <rule id="403066" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1487 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>