<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0124 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 1f0f1ff4-fe7b-56bc-aaf1-f47d1d5c1886 -->
  <rule id="236511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0124 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>