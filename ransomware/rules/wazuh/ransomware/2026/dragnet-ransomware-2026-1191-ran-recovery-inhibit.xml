<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1191 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: c216b610-7897-5e2a-a259-631ded78a63c -->
  <rule id="254676" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1191 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>