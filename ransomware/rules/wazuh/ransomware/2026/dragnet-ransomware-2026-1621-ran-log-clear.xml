<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1621 — Event Log Clearing (embargo) | Status: stable | Sigma ID: 4f88e128-6a21-55bc-a7ae-87985e25d76c -->
  <rule id="478221" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1621 — Event Log Clearing (embargo)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>