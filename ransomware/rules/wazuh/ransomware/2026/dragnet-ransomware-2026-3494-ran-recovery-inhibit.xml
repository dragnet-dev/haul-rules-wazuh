<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3494 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: a783adb5-3a94-53b6-b43c-2580ea084d6d -->
  <rule id="160621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3494 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>