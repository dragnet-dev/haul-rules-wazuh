<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2169 — Recovery Inhibition (safepay) | Status: stable | Sigma ID: 20178072-45ac-57a1-8217-2bca4047992a -->
  <rule id="317807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2169 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>