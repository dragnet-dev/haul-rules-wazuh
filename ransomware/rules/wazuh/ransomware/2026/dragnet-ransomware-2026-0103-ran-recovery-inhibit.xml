<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0103 — Recovery Inhibition (qilin) | Status: test | Sigma ID: c7854841-bb9a-57e2-a38b-ca4595a75a43 -->
  <rule id="478548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0103 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>