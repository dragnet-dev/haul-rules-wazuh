<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1397 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 80044a5c-3f03-59ca-ae89-cc76c02a1901 -->
  <rule id="480714" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1397 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>