<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1264 — Recovery Inhibition (nova) | Status: stable | Sigma ID: 193d4e57-95c2-5781-9090-990436691163 -->
  <rule id="562385" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1264 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>