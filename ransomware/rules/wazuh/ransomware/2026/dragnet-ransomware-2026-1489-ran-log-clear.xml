<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1489 — Event Log Clearing (apt73) | Status: stable | Sigma ID: 12e36ee4-3324-5eaa-8f7d-ba7d75e7a8cf -->
  <rule id="883054" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1489 — Event Log Clearing (apt73)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>