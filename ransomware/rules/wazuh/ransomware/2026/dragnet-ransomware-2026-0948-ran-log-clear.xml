<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0948 — Event Log Clearing (ALP-001) | Status: stable | Sigma ID: d19aec7f-ad81-55b5-8191-2cebd0bb1fa0 -->
  <rule id="105420" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0948 — Event Log Clearing (ALP-001)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>