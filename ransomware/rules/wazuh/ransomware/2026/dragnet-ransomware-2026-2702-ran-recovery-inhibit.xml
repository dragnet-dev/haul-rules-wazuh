<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2702 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: e62b6360-d54a-560b-a0da-99efc9d06e15 -->
  <rule id="640363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2702 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>