<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2118 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 508377b8-6a3a-5466-8daf-30ae0902ad26 -->
  <rule id="134043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2118 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>