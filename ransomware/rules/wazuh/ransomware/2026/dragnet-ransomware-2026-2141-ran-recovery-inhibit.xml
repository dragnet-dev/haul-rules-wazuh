<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2141 — Recovery Inhibition (everest) | Status: stable | Sigma ID: 61552305-aca5-53d0-bd84-a74d62f1c48c -->
  <rule id="855230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2141 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>