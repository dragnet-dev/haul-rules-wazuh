<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0799 — Event Log Clearing (genesis) | Status: test | Sigma ID: 499875e8-d9d6-5380-9086-3577da05ffda -->
  <rule id="898014" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0799 — Event Log Clearing (genesis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>