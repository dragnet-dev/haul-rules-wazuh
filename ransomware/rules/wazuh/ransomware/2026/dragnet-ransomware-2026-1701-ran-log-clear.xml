<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1701 — Event Log Clearing (orca) | Status: stable | Sigma ID: 47e22b69-3671-536d-b941-7f68b490c187 -->
  <rule id="425963" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1701 — Event Log Clearing (orca)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>