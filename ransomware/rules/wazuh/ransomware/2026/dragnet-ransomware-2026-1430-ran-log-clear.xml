<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1430 — Event Log Clearing (cmdorganization) | Status: deprecated | Sigma ID: c5333e90-4238-501e-97c9-66ac23924046 -->
  <rule id="305342" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1430 — Event Log Clearing (cmdorganization)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>