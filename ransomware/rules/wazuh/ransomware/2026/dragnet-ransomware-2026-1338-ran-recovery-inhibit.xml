<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1338 — Recovery Inhibition (lynx) | Status: stable | Sigma ID: 026ea34b-0ea5-5fe9-b231-a7f002456770 -->
  <rule id="324555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1338 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
