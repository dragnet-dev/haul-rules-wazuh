<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2770 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: 4daea9ed-94bd-5783-a082-3d9fb28d5970 -->
  <rule id="581869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2770 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>