<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2006 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 84aed429-9c74-5a99-bc97-17df09816fe6 -->
  <rule id="868614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2006 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>