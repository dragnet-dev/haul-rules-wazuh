<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2930 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: d126137b-4fbe-52e1-a6e4-72e19ab52e89 -->
  <rule id="512613" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2930 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>