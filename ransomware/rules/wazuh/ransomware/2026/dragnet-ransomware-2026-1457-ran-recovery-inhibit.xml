<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1457 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 994fa3ba-feb0-5875-8f1a-1611db716a30 -->
  <rule id="847143" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1457 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>