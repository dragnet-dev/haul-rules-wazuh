<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1762 — Recovery Inhibition (play) | Status: stable | Sigma ID: eca9ed3d-60f2-5d03-8331-680c04414697 -->
  <rule id="794701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1762 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>