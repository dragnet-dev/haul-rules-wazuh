<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2215 — Event Log Clearing (blackwater) | Status: stable | Sigma ID: 07f381c7-e706-585e-afef-5f8793f46b86 -->
  <rule id="338108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2215 — Event Log Clearing (blackwater)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>