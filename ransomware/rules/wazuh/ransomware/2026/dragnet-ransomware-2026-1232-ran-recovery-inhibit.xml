<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1232 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 03b83dd9-21f0-50b4-8f81-ddb664bd6845 -->
  <rule id="731869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1232 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>