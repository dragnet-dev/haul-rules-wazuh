<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0010 — Recovery Inhibition (blacknevas) | Status: stable | Sigma ID: 1bfa2b6a-78e2-5a1f-aa14-0d321a6446b3 -->
  <rule id="345963" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0010 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>