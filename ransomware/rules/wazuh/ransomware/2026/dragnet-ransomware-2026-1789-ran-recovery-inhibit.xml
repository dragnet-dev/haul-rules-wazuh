<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1789 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 4622e01c-443e-5ad4-bc92-276ba7013f8e -->
  <rule id="296601" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1789 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>