<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2617 — Recovery Inhibition (everest) | Status: stable | Sigma ID: 3a6ba19e-fca1-5a0a-8ec5-38ecbe7a3de7 -->
  <rule id="702021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2617 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>