<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0698 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 8642e8d9-5b4b-5862-9a26-1e2baebdfd6d -->
  <rule id="582868" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0698 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>