<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2196 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 4089f0be-33d1-553d-8eb9-452fea49f8ae -->
  <rule id="670251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2196 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>