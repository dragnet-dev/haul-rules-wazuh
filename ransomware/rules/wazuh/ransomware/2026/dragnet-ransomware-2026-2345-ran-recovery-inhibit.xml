<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2345 — Recovery Inhibition (pear) | Status: stable | Sigma ID: 7431f07e-bbca-508b-bf12-8827ca174c03 -->
  <rule id="389110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2345 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>