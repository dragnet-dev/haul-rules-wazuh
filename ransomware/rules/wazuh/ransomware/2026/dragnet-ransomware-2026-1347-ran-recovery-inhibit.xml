<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1347 — Recovery Inhibition (direwolf) | Status: test | Sigma ID: 732ddeee-92fe-5358-9d9a-b5c9218dd356 -->
  <rule id="401822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1347 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
