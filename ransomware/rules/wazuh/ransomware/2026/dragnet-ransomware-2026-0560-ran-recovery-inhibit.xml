<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0560 — Recovery Inhibition (fulcrumsec) | Status: stable | Sigma ID: 58a30839-9d35-5f38-8171-c43113a2167b -->
  <rule id="483083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0560 — Recovery Inhibition (fulcrumsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>