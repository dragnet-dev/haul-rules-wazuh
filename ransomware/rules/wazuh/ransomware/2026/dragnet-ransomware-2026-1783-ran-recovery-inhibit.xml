<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1783 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: b0702c7b-bf4c-5e5c-a89d-e02c65633081 -->
  <rule id="971244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1783 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>