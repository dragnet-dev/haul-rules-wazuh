<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3126 — Recovery Inhibition (incransom) | Status: test | Sigma ID: 74686c16-5d80-5b0d-b70d-cad4b4226bec -->
  <rule id="394988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3126 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>