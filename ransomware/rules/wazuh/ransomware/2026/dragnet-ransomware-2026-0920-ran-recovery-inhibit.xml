<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0920 — Recovery Inhibition (fulcrumsec) | Status: stable | Sigma ID: fb0b8ef2-f04b-56e2-a1f4-2a451033ec53 -->
  <rule id="227502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0920 — Recovery Inhibition (fulcrumsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>