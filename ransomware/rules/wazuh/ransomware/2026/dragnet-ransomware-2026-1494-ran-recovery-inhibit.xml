<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1494 — Recovery Inhibition (anubis) | Status: stable | Sigma ID: f2392cd5-5d4a-59a8-8896-75c633baed38 -->
  <rule id="738284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1494 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>