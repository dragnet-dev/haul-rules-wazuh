<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0577 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: d50051fe-679a-5728-b1a7-9045c2fc4a9d -->
  <rule id="550051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0577 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>