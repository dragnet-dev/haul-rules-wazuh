<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2003 — Recovery Inhibition (lynx) | Status: stable | Sigma ID: 22aec960-0c18-5963-8ed6-25d79221105a -->
  <rule id="390896" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2003 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>