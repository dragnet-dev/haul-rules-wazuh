<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1318 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 8bd84852-e465-52f0-a4c1-0df10c24b7cf -->
  <rule id="537848" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1318 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>