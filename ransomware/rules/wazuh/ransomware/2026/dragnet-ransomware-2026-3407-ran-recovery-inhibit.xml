<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3407 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 1dd73c5a-810f-5e61-b737-793c596810f0 -->
  <rule id="543805" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3407 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>