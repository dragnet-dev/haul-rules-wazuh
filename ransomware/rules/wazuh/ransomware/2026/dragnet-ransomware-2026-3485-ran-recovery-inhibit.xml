<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3485 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 4faf2656-87a2-5022-b2a8-1281449d3abe -->
  <rule id="339926" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3485 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>