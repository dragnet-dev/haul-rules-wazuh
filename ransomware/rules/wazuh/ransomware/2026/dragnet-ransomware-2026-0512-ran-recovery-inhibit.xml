<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0512 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 40e81a16-2511-57a0-b426-5872cea7c82c -->
  <rule id="247706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0512 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>