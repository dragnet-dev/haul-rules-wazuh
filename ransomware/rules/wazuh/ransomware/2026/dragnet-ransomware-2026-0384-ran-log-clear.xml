<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0384 — Event Log Clearing (bravox) | Status: test | Sigma ID: 0f0730d2-a065-5c9a-af00-2fb75758e287 -->
  <rule id="711693" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0384 — Event Log Clearing (bravox)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>