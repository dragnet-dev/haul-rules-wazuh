<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0924 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: e75e0d96-3166-5907-ac52-75df519c662a -->
  <rule id="278253" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0924 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>