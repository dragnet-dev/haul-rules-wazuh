<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2329 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: 2e555ada-9997-59f7-9c07-197c792d04b0 -->
  <rule id="318253" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2329 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>