<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0204 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 8e900298-c476-5081-bfd4-09265506bdbb -->
  <rule id="629002" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0204 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>