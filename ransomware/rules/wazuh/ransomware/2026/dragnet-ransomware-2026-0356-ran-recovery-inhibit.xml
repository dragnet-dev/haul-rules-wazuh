<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0356 — Recovery Inhibition (beast) | Status: stable | Sigma ID: a16fa418-60b8-5955-930a-753d22c852cb -->
  <rule id="903464" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0356 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>