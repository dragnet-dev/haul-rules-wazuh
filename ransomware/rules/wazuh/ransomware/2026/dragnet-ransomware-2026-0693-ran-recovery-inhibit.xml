<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0693 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: c3f4f06c-978d-5ec1-84b3-94354fa744d8 -->
  <rule id="573590" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0693 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>