<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0166 — Recovery Inhibition (pear) | Status: stable | Sigma ID: b11441a8-4aaf-584a-9577-9e77e0408e31 -->
  <rule id="311441" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0166 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>