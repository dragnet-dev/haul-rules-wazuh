<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3331 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 714dd1bb-ee42-574c-8182-21359d2ad188 -->
  <rule id="130051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3331 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>