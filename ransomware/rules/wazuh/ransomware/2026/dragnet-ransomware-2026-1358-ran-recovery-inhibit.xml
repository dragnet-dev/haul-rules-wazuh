<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1358 — Recovery Inhibition (handala) | Status: stable | Sigma ID: b2fd278e-b3b4-5699-a33c-14fa55b31be3 -->
  <rule id="292527" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1358 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>