<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1224 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: f8471b97-88ba-59b8-a2b7-ce7c1bbaaf6e -->
  <rule id="835547" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1224 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>