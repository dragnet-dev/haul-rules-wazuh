<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0040 — Event Log Clearing (aurora) | Status: stable | Sigma ID: 27eaf060-2488-5789-bfe8-2b41f302db48 -->
  <rule id="343510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0040 — Event Log Clearing (aurora)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>