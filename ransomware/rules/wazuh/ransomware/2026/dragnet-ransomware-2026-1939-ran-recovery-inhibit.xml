<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1939 — Recovery Inhibition (sinobi) | Status: stable | Sigma ID: cf94fb50-d661-5c6a-854a-84e712f9a3d4 -->
  <rule id="923515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1939 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>