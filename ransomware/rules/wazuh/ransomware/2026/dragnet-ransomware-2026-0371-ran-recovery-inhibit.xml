<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0371 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: d487a128-0d38-5f38-98a0-c635cadbb820 -->
  <rule id="458021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0371 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>