<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0005 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 3fd9dfa4-5197-517a-bfc8-8c578176cba0 -->
  <rule id="916287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0005 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>