<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1234 — Event Log Clearing (sinobi) | Status: test | Sigma ID: f7ae7b25-1beb-5400-a3f4-b9ae59611bc9 -->
  <rule id="258683" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1234 — Event Log Clearing (sinobi)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>