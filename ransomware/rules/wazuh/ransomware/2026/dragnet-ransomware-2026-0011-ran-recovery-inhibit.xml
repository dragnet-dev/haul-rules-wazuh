<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0011 — Recovery Inhibition (clop) | Status: test | Sigma ID: 4ac06670-8ef1-5640-8ef3-65507fbfe57d -->
  <rule id="396066" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0011 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>