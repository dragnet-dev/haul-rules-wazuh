<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3315 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 7f2eb8ba-1120-58dd-b033-6e11c27866cb -->
  <rule id="658678" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3315 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>