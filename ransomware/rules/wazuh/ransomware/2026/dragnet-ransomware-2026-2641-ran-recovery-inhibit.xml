<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2641 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: ccb252d9-135a-5936-b53d-04dc11557e02 -->
  <rule id="675252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2641 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>