<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2996 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 1314f9d4-f9e0-5c3b-89f3-79cf4001d8a4 -->
  <rule id="766397" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2996 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>