<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2916 — Event Log Clearing (qilin) | Status: test | Sigma ID: 8c1a9384-e79f-55d1-a1cd-2aa6bb0f7b6f -->
  <rule id="542693" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2916 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>