<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0989 — Recovery Inhibition (m3rx) | Status: stable | Sigma ID: 737829e8-a0fc-56ee-a4c1-a1c55e7e9e5a -->
  <rule id="205278" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0989 — Recovery Inhibition (m3rx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>