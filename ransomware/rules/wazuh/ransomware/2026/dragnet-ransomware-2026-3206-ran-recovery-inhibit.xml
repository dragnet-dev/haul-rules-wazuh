<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3206 — Recovery Inhibition (lynx) | Status: test | Sigma ID: 13bea49e-37f7-5289-85ed-2317933555d3 -->
  <rule id="329849" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3206 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>