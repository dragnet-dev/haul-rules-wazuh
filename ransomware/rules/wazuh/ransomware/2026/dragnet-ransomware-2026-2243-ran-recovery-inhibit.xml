<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2243 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 9f3e8c8c-b12f-55d6-9976-95992d109353 -->
  <rule id="580460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2243 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>