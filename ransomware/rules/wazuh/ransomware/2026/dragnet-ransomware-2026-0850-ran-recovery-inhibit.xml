<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0850 — Recovery Inhibition (LeakBazaar) | Status: stable | Sigma ID: 2f5781e4-571e-55dc-9276-361d6541063c -->
  <rule id="512510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0850 — Recovery Inhibition (LeakBazaar)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>