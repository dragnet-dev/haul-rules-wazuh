<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2773 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: f5c7c20a-8c40-5551-a9ad-7305004b5e8a -->
  <rule id="488442" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2773 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>