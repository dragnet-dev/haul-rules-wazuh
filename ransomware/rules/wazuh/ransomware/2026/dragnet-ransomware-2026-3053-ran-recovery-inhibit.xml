<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3053 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: f8d36f8c-dffe-5235-b37c-62fd6af4b902 -->
  <rule id="566191" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3053 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>