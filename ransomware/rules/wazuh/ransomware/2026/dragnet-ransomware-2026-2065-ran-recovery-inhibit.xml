<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2065 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 08131222-7e53-5dd1-a1f5-66b826153f92 -->
  <rule id="131222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2065 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>