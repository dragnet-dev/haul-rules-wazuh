<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0462 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: bb28acc9-693c-5e3e-b24a-2b006e2dd7d8 -->
  <rule id="394540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0462 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>