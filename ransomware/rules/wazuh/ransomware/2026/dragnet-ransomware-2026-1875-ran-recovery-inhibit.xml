<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1875 — Recovery Inhibition (bravox) | Status: stable | Sigma ID: bf9d129f-4d32-5fa2-8f80-5e4be74cb6f5 -->
  <rule id="471712" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1875 — Recovery Inhibition (bravox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>