<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0439 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: fcb485d2-a2e4-5834-9704-4e624c3f54a3 -->
  <rule id="543485" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0439 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>