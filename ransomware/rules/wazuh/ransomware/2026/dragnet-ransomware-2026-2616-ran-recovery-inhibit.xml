<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2616 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: f0129354-ba6d-5417-9e06-cb4ad5c3acbb -->
  <rule id="701293" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2616 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>