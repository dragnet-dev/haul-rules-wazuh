<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2231 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 91c0496e-87a8-5707-a203-a1a4eadc28d8 -->
  <rule id="668049" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2231 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>