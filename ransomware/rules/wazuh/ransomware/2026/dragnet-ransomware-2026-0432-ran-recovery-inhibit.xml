<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0432 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: c632ac35-0d81-54d1-b91c-32ff44589346 -->
  <rule id="633964" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0432 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>