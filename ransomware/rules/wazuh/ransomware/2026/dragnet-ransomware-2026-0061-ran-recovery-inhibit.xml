<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0061 — Recovery Inhibition (blackwater) | Status: stable | Sigma ID: 6025d6f7-e2eb-535f-9cbc-253a972bfc79 -->
  <rule id="226191" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0061 — Recovery Inhibition (blackwater)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
