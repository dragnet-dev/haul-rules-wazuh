<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0514 — Recovery Inhibition (handala) | Status: test | Sigma ID: 330e7221-7fa6-52d1-b35e-37cb5e661794 -->
  <rule id="894722" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0514 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>