<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0581 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 21be3451-d45a-5349-81fc-fa673075e737 -->
  <rule id="266345" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0581 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>