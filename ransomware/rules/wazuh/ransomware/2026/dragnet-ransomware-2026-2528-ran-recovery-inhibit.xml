<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2528 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: ef04e89e-5c26-51e6-a181-789492709b34 -->
  <rule id="324788" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2528 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>