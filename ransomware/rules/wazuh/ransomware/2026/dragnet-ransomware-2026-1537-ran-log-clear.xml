  <rule id="855517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1537 — Event Log Clearing (genesis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
