<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0074 — Event Log Clearing (cipherforce) | Status: stable | Sigma ID: d24e71de-5209-5882-9ddd-1eefbd7c49aa -->
  <rule id="419871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0074 — Event Log Clearing (cipherforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>