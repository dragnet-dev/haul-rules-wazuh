<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2585 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 0a1acf41-5bf2-561b-b1b4-9d25943d6069 -->
  <rule id="664634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2585 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>