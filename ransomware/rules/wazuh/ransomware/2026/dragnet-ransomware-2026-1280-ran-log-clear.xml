<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1280 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 5c13a8a7-c48d-52d5-b6ec-630d0f0fa9cf -->
  <rule id="674188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1280 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>