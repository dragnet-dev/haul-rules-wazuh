<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0533 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 8f887d72-bc7b-5f84-b3cf-4bcb2366a795 -->
  <rule id="602205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0533 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>