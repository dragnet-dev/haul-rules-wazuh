<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1741 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 30fa2dfb-5c12-542a-885e-4323608a80a4 -->
  <rule id="468845" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1741 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>