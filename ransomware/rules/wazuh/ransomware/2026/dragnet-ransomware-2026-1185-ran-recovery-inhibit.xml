<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1185 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: cf2ede06-c169-51b0-833f-7b1fd7f6e678 -->
  <rule id="490718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1185 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>