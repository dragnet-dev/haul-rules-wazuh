<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1506 — Recovery Inhibition (interlock) | Status: stable | Sigma ID: 9dae32e1-bb5d-558b-ac3f-6af94ed1aa9b -->
  <rule id="536632" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1506 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>