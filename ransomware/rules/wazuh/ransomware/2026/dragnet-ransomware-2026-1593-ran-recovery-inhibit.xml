<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1593 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 5e2dce6e-b7ec-5dbf-ac81-8863f98ac231 -->
  <rule id="361966" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1593 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
