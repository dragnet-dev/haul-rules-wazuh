<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1222 — Recovery Inhibition (handala) | Status: stable | Sigma ID: ed97a1c1-5823-5899-b35f-57437c8dd16c -->
  <rule id="307621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1222 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>