<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3362 — Event Log Clearing (lockbit5) | Status: stable | Sigma ID: 6f7f9f0c-b3f3-5e1b-8bbc-ad879a3c1a3b -->
  <rule id="262079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3362 — Event Log Clearing (lockbit5)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>