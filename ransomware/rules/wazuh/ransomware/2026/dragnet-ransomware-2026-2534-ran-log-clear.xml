<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2534 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 1f0f8ae4-1a6c-5e7e-b82e-c1dc80d59c88 -->
  <rule id="238222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2534 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>