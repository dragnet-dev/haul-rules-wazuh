<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3153 — Recovery Inhibition (pear) | Status: stable | Sigma ID: 6639306e-16e1-59e2-a331-9b135d0e70d8 -->
  <rule id="439306" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3153 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>