<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1233 — Event Log Clearing (m3rx) | Status: stable | Sigma ID: 4d1e6f6c-0a41-5c0a-81ce-31a0bd39d26d -->
  <rule id="276111" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1233 — Event Log Clearing (m3rx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>