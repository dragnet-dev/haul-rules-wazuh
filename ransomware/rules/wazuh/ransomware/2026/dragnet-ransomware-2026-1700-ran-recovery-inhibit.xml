<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1700 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 81ea90ab-668b-5dd1-b278-7a0448864781 -->
  <rule id="397090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1700 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>