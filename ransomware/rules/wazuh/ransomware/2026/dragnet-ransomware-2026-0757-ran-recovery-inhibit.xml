<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0757 — Recovery Inhibition (lynx) | Status: test | Sigma ID: 70476c5b-c1f2-55e5-8afb-4ac8fd96cbcf -->
  <rule id="327628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0757 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>