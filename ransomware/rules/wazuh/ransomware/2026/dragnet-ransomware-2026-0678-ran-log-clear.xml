<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0678 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: 38c34e83-e7a6-5f33-a1dd-429d9cd24d5c -->
  <rule id="125588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0678 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>