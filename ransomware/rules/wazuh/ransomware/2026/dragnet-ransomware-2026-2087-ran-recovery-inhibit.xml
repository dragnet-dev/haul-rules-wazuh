<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2087 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: d4efbca8-dbb6-5121-8ea6-8531b79356b6 -->
  <rule id="843196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2087 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>