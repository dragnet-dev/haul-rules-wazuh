<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2553 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 507be498-fde2-5834-b941-59233df8936e -->
  <rule id="499824" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2553 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>