<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3448 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: e4b92cb5-cea3-5600-8628-7cf3ca8aaa3d -->
  <rule id="205484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3448 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>