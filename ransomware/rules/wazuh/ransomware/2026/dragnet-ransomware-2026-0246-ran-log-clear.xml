<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0246 — Event Log Clearing (chaos) | Status: stable | Sigma ID: e324932b-fd58-5dac-88e2-26d2909f7eb2 -->
  <rule id="632493" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0246 — Event Log Clearing (chaos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>