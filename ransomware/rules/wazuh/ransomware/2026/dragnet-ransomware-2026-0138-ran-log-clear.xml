<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0138 — Event Log Clearing (lockbit5) | Status: stable | Sigma ID: fb1bb720-53dc-5548-8c6e-ef4f2f5e2ded -->
  <rule id="230037" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0138 — Event Log Clearing (lockbit5)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>