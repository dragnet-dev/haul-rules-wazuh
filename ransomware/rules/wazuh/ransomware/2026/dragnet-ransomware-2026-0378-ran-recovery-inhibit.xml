<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0378 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: 189066d4-83bf-50d5-b9f1-d829f9d7de47 -->
  <rule id="425069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0378 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>