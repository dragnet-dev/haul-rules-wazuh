<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0280 — Recovery Inhibition (lynx) | Status: test | Sigma ID: ae86b330-da2a-512e-b2f9-48f94a023f9e -->
  <rule id="197873" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0280 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>