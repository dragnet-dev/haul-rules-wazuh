<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0016 — Event Log Clearing (coinbasecartel) | Status: stable | Sigma ID: 3c0e102e-87d4-5c08-9ce3-141f3c29ba19 -->
  <rule id="714102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0016 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>