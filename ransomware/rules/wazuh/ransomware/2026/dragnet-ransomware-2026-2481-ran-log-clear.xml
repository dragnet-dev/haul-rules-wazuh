<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2481 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: 7f88d94b-752a-5483-b17a-34ef55f70c8c -->
  <rule id="346219" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2481 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>