<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0150 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: f1acf407-f884-56ee-8816-1be93c6ea041 -->
  <rule id="912634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0150 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>