<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2282 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: a920b1b6-b3b1-50c4-91e4-57f72d9b0312 -->
  <rule id="947311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2282 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>