<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3016 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 67e7d314-9945-58ad-ac5b-664b72818f9d -->
  <rule id="938853" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3016 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>