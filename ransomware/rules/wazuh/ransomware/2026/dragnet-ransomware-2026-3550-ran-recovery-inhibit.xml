<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3550 — Recovery Inhibition (nova) | Status: stable | Sigma ID: cbc8fae9-3b38-51e9-9c1c-ad7a25a2ad7c -->
  <rule id="347898" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3550 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>