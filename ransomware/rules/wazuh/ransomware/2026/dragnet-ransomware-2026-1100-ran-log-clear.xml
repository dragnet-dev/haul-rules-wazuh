<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1100 — Event Log Clearing (thegentlemen) | Status: test | Sigma ID: 09a35a7f-6ad2-5522-a5d9-5b3e6f7368e6 -->
  <rule id="769707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1100 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>