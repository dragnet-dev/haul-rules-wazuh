<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0265 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 60073940-91a6-51cb-ac77-ef4dc5d9eadb -->
  <rule id="707394" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0265 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>