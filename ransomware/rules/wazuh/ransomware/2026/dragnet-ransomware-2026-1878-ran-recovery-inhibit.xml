<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1878 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 636576fe-23ae-587f-ae95-7a08e1eee8a8 -->
  <rule id="385231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1878 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>