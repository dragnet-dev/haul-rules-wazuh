<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0335 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 9e61222c-2f99-5ed4-b309-ad270d215b54 -->
  <rule id="786122" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0335 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>