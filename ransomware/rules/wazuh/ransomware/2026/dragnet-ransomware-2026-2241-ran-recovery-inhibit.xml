<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2241 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 1e62400d-0b21-5758-ae5f-b97307a5d248 -->
  <rule id="462400" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2241 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>