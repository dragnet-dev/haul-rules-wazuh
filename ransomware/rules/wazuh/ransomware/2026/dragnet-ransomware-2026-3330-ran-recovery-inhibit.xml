<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3330 — Recovery Inhibition (interlock) | Status: test | Sigma ID: 287fbc88-859b-5858-b08f-a33cc02f95d6 -->
  <rule id="379580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3330 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
