<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0008 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 35bf722e-4222-5f5d-9f1e-1fab9300dd9b -->
  <rule id="251722" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0008 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>