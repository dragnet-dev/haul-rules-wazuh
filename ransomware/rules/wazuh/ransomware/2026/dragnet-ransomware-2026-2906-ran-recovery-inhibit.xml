<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2906 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: cd88daf6-d0ec-58ea-aea0-0cc5b471a54f -->
  <rule id="870746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2906 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>