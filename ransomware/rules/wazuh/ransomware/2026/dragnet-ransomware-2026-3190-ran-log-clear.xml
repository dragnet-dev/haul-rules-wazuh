<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3190 — Event Log Clearing (beast) | Status: stable | Sigma ID: 61c7a67b-9c2c-5291-84d8-6f2daa5ca0b5 -->
  <rule id="782026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3190 — Event Log Clearing (beast)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>