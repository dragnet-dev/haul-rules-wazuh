<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0324 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 16dbb72d-a3c6-58bb-a70f-6d7f58e82a2e -->
  <rule id="705172" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0324 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>