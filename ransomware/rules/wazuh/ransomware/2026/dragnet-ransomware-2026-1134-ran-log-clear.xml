<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1134 — Event Log Clearing (thegentlemen) | Status: stable | Sigma ID: 0dffc5a5-0faa-5fd7-9b9e-b0932857d18d -->
  <rule id="274490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1134 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>