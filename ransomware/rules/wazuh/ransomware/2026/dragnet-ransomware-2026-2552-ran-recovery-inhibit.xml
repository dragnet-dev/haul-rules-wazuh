<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2552 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: a593bd58-dda7-53c5-b0cb-2c4d255e8b4f -->
  <rule id="111997" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2552 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>