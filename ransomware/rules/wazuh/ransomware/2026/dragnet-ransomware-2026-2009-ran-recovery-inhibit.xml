<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2009 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: a160dabb-f674-55a3-ab7b-e6b1aa91a9b3 -->
  <rule id="901178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2009 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>