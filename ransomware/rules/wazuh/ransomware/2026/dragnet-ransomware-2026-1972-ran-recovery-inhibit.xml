<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1972 — Recovery Inhibition (BrainCipher) | Status: stable | Sigma ID: 039dfae4-0144-5bbc-905c-351e195f076f -->
  <rule id="913166" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1972 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
