<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0968 — Recovery Inhibition (nova) | Status: stable | Sigma ID: 55f6c496-211a-5752-a19c-28ec15956195 -->
  <rule id="633084" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0968 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
