<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0823 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 89fbaf8a-4a71-5915-bf40-e1fa1d66e221 -->
  <rule id="597135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0823 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>