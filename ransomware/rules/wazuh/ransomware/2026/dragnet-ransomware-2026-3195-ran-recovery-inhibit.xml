<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3195 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 68ff95af-eea4-5a24-acdd-6c49798a9f62 -->
  <rule id="966395" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3195 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>