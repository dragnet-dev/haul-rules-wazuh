<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1722 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: 66a32c3c-bd32-5601-a2ea-2188ccd9488e -->
  <rule id="906124" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1722 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>