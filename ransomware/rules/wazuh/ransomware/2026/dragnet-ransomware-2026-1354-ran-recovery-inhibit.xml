<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1354 — Recovery Inhibition (fulcrumsec) | Status: stable | Sigma ID: 1ccf46cf-516c-5d6b-a2c8-16656f0ad49a -->
  <rule id="200748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1354 — Recovery Inhibition (fulcrumsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>