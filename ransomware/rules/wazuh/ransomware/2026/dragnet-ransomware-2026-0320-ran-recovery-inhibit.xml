<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0320 — Recovery Inhibition (m3rx) | Status: stable | Sigma ID: b8881f37-0c26-5d21-8554-fc45f84ee66f -->
  <rule id="202111" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0320 — Recovery Inhibition (m3rx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>