<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0819 — Recovery Inhibition (pear) | Status: stable | Sigma ID: 36a8252c-40de-56a8-bab3-2c03a102b095 -->
  <rule id="568252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0819 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>