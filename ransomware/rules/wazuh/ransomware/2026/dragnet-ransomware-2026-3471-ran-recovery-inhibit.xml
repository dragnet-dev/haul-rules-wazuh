<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3471 — Recovery Inhibition (play) | Status: stable | Sigma ID: f5c6aeb6-09ce-50cf-9322-e16cf92af060 -->
  <rule id="181230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3471 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>