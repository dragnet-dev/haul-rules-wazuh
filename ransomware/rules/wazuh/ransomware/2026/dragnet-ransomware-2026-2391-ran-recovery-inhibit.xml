<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2391 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 974ea091-29ae-5f3e-98ef-8319afdbe5bc -->
  <rule id="795780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2391 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>