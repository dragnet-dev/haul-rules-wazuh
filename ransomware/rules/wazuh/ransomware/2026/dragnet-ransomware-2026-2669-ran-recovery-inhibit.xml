<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2669 — Recovery Inhibition (payload) | Status: stable | Sigma ID: 1d753bee-7d12-5bed-8da6-ae40dd185d82 -->
  <rule id="516958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2669 — Recovery Inhibition (payload)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>