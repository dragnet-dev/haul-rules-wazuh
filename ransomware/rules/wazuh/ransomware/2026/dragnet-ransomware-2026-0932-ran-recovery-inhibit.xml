<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0932 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 371b6647-d65c-5882-9e59-f5c1bc05dbc1 -->
  <rule id="647664" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0932 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>