<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1591 — Recovery Inhibition (incransom) | Status: test | Sigma ID: 53062324-f1d2-51a9-aa00-b651a2696705 -->
  <rule id="906232" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1591 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>