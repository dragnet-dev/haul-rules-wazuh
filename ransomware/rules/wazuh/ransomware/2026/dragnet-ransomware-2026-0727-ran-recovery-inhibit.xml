<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0727 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 383dff83-c8f7-5ec4-87df-2d7eb86204cc -->
  <rule id="772351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0727 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>