<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2748 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: afa6adbc-b8ea-5808-9f6b-8a26bda416cf -->
  <rule id="995309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2748 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>