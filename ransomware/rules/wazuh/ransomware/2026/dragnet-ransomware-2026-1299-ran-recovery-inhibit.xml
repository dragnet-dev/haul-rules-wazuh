<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1299 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 87a85f24-cc0f-54ab-9aa2-9dc3d190424a -->
  <rule id="544575" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1299 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>