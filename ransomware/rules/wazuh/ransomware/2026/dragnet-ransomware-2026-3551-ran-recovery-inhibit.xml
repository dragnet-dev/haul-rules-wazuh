<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3551 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: c4733543-3f8b-5af4-8d91-7965c828eb53 -->
  <rule id="447335" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3551 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>