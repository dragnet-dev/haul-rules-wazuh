<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3100 — Event Log Clearing (shadowbyt3$) | Status: deprecated | Sigma ID: be523511-5e3e-5edc-a8ea-e704ca9c08c7 -->
  <rule id="205235" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3100 — Event Log Clearing (shadowbyt3$)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>