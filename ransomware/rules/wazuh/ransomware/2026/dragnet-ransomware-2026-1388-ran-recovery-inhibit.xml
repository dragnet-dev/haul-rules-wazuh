<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1388 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 29897333-f561-50a0-a5cd-83feacc081b9 -->
  <rule id="389733" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1388 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>