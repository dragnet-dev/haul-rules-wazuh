<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0986 — Recovery Inhibition (lynx) | Status: stable | Sigma ID: bd86197d-9013-5580-9b80-b4dcf572267f -->
  <rule id="198619" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0986 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>