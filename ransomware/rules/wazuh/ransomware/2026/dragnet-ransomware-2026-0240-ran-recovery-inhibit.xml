<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0240 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 3f1e041d-bfef-5df8-9855-f9ae3b53a950 -->
  <rule id="211004" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0240 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>