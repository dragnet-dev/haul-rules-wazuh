<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2543 — Event Log Clearing (payoutsking) | Status: deprecated | Sigma ID: 1cc03d0e-f5a7-58cd-a62f-4c7da9f79876 -->
  <rule id="260610" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2543 — Event Log Clearing (payoutsking)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>