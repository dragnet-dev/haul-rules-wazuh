<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1291 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 69b8b98a-4858-5a08-86f4-4ff8b780260f -->
  <rule id="985399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1291 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>