<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0456 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 8ad553d7-99f2-5dd9-89e0-bd5fc1029f02 -->
  <rule id="521553" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0456 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>