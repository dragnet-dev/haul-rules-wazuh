<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2217 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 1c70b3b5-42e4-5a68-b52a-040f11515bee -->
  <rule id="249019" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2217 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>