<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2139 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: c57947c4-ee00-5946-a7d6-16a372fdf6db -->
  <rule id="457947" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2139 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>