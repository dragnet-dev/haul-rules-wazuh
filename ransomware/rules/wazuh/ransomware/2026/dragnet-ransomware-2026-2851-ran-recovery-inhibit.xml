<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2851 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: e60e6ee9-a81f-587c-9ca2-611a726d9471 -->
  <rule id="239950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2851 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>