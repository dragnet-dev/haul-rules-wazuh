<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3369 — Recovery Inhibition (aurora) | Status: stable | Sigma ID: 0af63774-eccd-5d68-a4d1-1ef76e440d83 -->
  <rule id="956377" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3369 — Recovery Inhibition (aurora)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>