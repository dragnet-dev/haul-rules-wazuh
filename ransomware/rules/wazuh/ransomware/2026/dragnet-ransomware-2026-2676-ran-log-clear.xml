<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2676 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: e65d1102-5a8d-5ced-999d-d0e2c9c7fb46 -->
  <rule id="645311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2676 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>