<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3216 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 14cd1d7d-762b-5db4-a1b5-6448de417f91 -->
  <rule id="762697" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3216 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>