<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2562 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 93161afa-c0c3-5ae7-895a-e507654cf47e -->
  <rule id="690586" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2562 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>