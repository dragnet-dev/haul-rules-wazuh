<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0953 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 32eb9d8f-a0ac-58ab-8d62-665f3c0000d4 -->
  <rule id="548477" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0953 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>