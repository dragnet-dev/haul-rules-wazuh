<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1701 — Recovery Inhibition (orca) | Status: stable | Sigma ID: d39c6f3f-616f-5d49-bcf6-354d6d4cd8c2 -->
  <rule id="829871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1701 — Recovery Inhibition (orca)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>