<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1669 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 5bcce057-2ab6-595f-9a6a-603af5d9c7ed -->
  <rule id="260140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1669 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>