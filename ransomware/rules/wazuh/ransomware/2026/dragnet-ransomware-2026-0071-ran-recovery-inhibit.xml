<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0071 — Recovery Inhibition (titan) | Status: stable | Sigma ID: 5ca8b0d2-b841-57f4-8dc1-ce2197907caf -->
  <rule id="672590" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0071 — Recovery Inhibition (titan)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
