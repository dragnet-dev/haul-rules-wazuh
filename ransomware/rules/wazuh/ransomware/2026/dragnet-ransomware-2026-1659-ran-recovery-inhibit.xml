<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1659 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 2f641f98-a1eb-52f8-984f-259affc3a1cb -->
  <rule id="522719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1659 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>