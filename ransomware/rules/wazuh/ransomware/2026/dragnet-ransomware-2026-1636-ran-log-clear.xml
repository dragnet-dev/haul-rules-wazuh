<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1636 — Event Log Clearing (titan) | Status: stable | Sigma ID: da554b72-f13f-5997-af5e-17e3814b7084 -->
  <rule id="896875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1636 — Event Log Clearing (titan)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>