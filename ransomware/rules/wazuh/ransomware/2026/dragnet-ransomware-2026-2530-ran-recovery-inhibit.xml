<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2530 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 88bd703d-1394-5cc4-9674-30f07816fc30 -->
  <rule id="571770" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2530 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>