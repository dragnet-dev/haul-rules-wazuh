<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2465 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: e8f50eef-0329-5e8e-a38c-1e812493dabf -->
  <rule id="313614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2465 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>