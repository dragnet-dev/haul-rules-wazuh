<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1534 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 298ab9cb-4b80-5195-8807-24fb5cbc99e7 -->
  <rule id="633596" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1534 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>