<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0311 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 0984fe8b-b4f6-52f0-86b7-d6f177e7b70f -->
  <rule id="821588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0311 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>