<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1508 — Recovery Inhibition (titan) | Status: stable | Sigma ID: da7f337d-9676-5794-98e3-d2f65199a119 -->
  <rule id="900733" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1508 — Recovery Inhibition (titan)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>