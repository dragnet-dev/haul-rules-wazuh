<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2331 — Event Log Clearing (shadowbyt3$) | Status: deprecated | Sigma ID: b10ef805-9df7-5970-9632-546d225f5608 -->
  <rule id="243998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2331 — Event Log Clearing (shadowbyt3$)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>