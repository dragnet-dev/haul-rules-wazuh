<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0937 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 06ec8ed8-a28b-5dd8-ac83-87dbbbd23ea4 -->
  <rule id="138605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0937 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>