<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2166 — Recovery Inhibition (exitium) | Status: stable | Sigma ID: 325c5dba-3b2f-52e0-9593-6e81189ef4d1 -->
  <rule id="844219" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2166 — Recovery Inhibition (exitium)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>