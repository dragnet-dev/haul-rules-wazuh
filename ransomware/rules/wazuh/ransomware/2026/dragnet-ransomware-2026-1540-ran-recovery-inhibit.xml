<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1540 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 1f35a83e-9212-5232-a819-6afcb9faf902 -->
  <rule id="617083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1540 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>