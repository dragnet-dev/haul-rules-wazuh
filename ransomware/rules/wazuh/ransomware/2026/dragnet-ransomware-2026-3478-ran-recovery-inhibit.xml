<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3478 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 5092d6a3-1ca2-5202-8350-97755941a7b7 -->
  <rule id="537706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3478 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>