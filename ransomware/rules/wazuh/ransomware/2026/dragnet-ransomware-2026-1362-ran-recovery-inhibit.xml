<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1362 — Recovery Inhibition (aurora) | Status: stable | Sigma ID: 15475742-3c19-5b75-ab79-44b3b017e633 -->
  <rule id="747574" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1362 — Recovery Inhibition (aurora)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>