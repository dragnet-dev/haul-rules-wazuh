<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3308 — Recovery Inhibition (anubis) | Status: stable | Sigma ID: 415afbda-7bb0-5b91-b8a9-8054c1939cdf -->
  <rule id="902651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3308 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>