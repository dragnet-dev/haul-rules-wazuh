<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2725 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: eff9de0c-20b6-5628-9d6c-76278412ef95 -->
  <rule id="930366" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2725 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>