<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1645 — Event Log Clearing (tridentlocker) | Status: stable | Sigma ID: 87c9e12c-d2cb-5bd4-ba03-be3c3ef4cd6f -->
  <rule id="547981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1645 — Event Log Clearing (tridentlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>