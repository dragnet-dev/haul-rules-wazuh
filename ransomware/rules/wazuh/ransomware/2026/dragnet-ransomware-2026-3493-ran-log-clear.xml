<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3493 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: 691e1072-50e5-5594-8b16-e938281b6b9f -->
  <rule id="307010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3493 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>