<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2286 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 2c903ec2-9cb7-5b44-ab7d-49930657c940 -->
  <rule id="795404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2286 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>