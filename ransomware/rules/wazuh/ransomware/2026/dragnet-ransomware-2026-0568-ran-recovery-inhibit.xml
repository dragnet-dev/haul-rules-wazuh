<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0568 — Recovery Inhibition (AiLock) | Status: deprecated | Sigma ID: 7dfc77e3-8bcb-5c25-be56-3a0966987723 -->
  <rule id="625277" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0568 — Recovery Inhibition (AiLock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
