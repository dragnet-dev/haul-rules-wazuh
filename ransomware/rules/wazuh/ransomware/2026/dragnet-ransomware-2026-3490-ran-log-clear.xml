<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3490 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: fe2e87dd-8cb6-5e17-a1d9-bcae256a67fd -->
  <rule id="568687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3490 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>