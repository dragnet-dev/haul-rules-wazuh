<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2561 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 913679bd-b1a4-5c27-8d36-b9fd4f69352a -->
  <rule id="318875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2561 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>