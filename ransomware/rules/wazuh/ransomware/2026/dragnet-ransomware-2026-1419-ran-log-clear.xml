<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1419 — Event Log Clearing (LeakBazaar) | Status: stable | Sigma ID: 09070581-7283-537b-9e63-b18cd7db174d -->
  <rule id="170581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1419 — Event Log Clearing (LeakBazaar)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>