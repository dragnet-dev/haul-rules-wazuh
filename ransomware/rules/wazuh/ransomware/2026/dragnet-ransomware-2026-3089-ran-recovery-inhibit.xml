<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3089 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 209254dd-ea7b-5ccd-b043-3dafe9e2de63 -->
  <rule id="748077" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3089 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>