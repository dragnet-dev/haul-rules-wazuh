<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3237 — Recovery Inhibition (pear) | Status: stable | Sigma ID: 9d46c20a-e016-5a60-9189-4e306b64eff4 -->
  <rule id="819482" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3237 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>