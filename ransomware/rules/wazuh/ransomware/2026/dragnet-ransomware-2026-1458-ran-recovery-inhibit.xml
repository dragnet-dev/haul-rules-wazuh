<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1458 — Recovery Inhibition (kairos) | Status: deprecated | Sigma ID: 1973802d-bfaf-57ab-81d2-b8b12d8a8436 -->
  <rule id="273802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1458 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
