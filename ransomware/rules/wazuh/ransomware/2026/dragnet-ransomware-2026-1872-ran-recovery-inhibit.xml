<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1872 — Recovery Inhibition (ransomhouse) | Status: stable | Sigma ID: 146f1532-54d9-55ff-8123-3c5859d16efb -->
  <rule id="651153" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1872 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>