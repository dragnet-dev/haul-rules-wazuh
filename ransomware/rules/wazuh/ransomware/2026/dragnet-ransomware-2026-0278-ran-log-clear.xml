<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0278 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 2b3cae4d-5233-560c-9123-eb7d1d58b0f7 -->
  <rule id="976814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0278 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>