<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2210 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 36b209ae-33c8-5ed4-811a-02c9404029f6 -->
  <rule id="495354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2210 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
