<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2512 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: be9a0160-5a23-56fc-966e-409039a33933 -->
  <rule id="455401" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2512 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>