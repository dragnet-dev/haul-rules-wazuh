<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2160 — Recovery Inhibition (lynx) | Status: test | Sigma ID: a92cc4aa-b27c-5df1-a0bd-18d1129044c2 -->
  <rule id="197564" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2160 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>