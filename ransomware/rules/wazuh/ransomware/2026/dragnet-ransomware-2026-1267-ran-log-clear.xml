<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1267 — Event Log Clearing (netrunner) | Status: stable | Sigma ID: 0f7e6b83-8169-5832-8f62-f66de23a5669 -->
  <rule id="542678" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1267 — Event Log Clearing (netrunner)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>