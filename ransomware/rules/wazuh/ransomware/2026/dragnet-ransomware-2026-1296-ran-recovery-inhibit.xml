<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1296 — Recovery Inhibition (anubis) | Status: stable | Sigma ID: 399ac663-cacc-5e4b-9950-a05bd53f43e6 -->
  <rule id="223166" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1296 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>