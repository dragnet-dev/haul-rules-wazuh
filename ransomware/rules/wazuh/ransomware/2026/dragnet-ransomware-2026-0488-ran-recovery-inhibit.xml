<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0488 — Recovery Inhibition (fulcrumsec) | Status: stable | Sigma ID: f617cb36-9ad3-5f64-8b46-9459d46f9315 -->
  <rule id="498155" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0488 — Recovery Inhibition (fulcrumsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>