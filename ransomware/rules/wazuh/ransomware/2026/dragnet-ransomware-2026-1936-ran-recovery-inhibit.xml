<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1936 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: bee2d72e-ac66-5d10-b08d-bd5e7872cf33 -->
  <rule id="486857" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1936 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>