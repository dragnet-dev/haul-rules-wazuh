<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1130 — Event Log Clearing (thegentlemen) | Status: stable | Sigma ID: b85fb2fa-c047-59c3-bbd4-9dbc6ddedc9e -->
  <rule id="436112" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1130 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>