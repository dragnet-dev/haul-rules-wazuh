<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3289 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: ad91e7d6-7e33-536f-97e6-6219348e465b -->
  <rule id="182707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3289 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>