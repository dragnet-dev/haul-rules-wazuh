<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2897 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 6b4bc437-fa51-5045-a7c8-a500063ecada -->
  <rule id="151324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2897 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>