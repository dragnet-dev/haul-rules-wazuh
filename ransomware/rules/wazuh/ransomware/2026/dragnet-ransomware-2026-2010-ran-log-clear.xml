<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2010 — Event Log Clearing (vect) | Status: deprecated | Sigma ID: 2bda8ee0-dbcc-53c4-95e2-830d5ac3d980 -->
  <rule id="996302" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2010 — Event Log Clearing (vect)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>