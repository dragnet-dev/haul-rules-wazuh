<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0075 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 0b0b1f12-c805-5696-91b1-b3b4dca1fc44 -->
  <rule id="233911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0075 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>