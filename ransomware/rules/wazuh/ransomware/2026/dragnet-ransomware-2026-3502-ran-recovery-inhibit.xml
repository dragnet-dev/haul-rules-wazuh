<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3502 — Recovery Inhibition (interlock) | Status: stable | Sigma ID: ab071935-de1d-58c6-9de2-863ed59d7d22 -->
  <rule id="910719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3502 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>