<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2392 — Recovery Inhibition (payload) | Status: stable | Sigma ID: 499c6ece-3042-570a-8dc5-49460ae699c4 -->
  <rule id="479470" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2392 — Recovery Inhibition (payload)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>