<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3065 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 236fcb98-df00-5eba-8f6d-88dd1fd2ec10 -->
  <rule id="806999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3065 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>