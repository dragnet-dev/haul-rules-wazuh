<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0175 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 2fffd0f4-8805-5bdc-ae99-ab38fa9a5b6a -->
  <rule id="266050" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0175 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>