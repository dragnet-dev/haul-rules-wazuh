<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1489 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 59fb096b-3bb1-5df1-94bc-0cbd45a8078d -->
  <rule id="735509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1489 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>