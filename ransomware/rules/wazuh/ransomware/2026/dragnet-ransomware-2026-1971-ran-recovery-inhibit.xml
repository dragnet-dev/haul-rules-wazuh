<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1971 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: c494e428-6da2-5017-9d58-e349b82f3335 -->
  <rule id="299184" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1971 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>