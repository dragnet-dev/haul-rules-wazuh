<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0369 — Recovery Inhibition (play) | Status: stable | Sigma ID: 6e76cbaf-3594-57b9-8ab9-8bae8db57e1c -->
  <rule id="235659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0369 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>