<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2607 — Recovery Inhibition (play) | Status: stable | Sigma ID: 2c11380f-4aef-57c8-8097-e95845ed3d62 -->
  <rule id="911380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2607 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>