<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3489 — Recovery Inhibition (play) | Status: stable | Sigma ID: a2f75b75-9abc-5464-99fb-577e1df4f232 -->
  <rule id="936411" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3489 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
