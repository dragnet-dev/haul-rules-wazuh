<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0773 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 4f4b8159-5fc6-5721-a283-e993807478f6 -->
  <rule id="471581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0773 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>