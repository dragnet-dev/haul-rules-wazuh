<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0600 — Event Log Clearing (dragonforce) | Status: stable | Sigma ID: 5bf4b5f4-9ae4-58ae-9b15-942584fb1349 -->
  <rule id="654355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0600 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>