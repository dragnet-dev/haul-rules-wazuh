<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3252 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 90807dd6-2cea-553c-a80f-2b3041d08333 -->
  <rule id="652925" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3252 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>