<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1200 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: d7b197a3-3d40-5ccc-8e59-ba03a7b5ce83 -->
  <rule id="503197" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1200 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>