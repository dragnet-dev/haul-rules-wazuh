<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2886 — Recovery Inhibition (anubis) | Status: stable | Sigma ID: 70f60466-d769-573d-a529-28ca54907bf3 -->
  <rule id="335604" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2886 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>