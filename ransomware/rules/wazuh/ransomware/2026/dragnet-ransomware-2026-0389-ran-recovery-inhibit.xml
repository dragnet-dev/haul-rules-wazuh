<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0389 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: cd6ec99a-b8e6-5465-a45f-c743ffe5b1e9 -->
  <rule id="865729" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0389 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>