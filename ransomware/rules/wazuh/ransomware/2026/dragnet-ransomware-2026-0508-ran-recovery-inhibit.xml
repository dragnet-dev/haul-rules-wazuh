<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0508 — Recovery Inhibition (everest) | Status: stable | Sigma ID: bf9ef4a6-a9fe-5849-8beb-b1773bebe3b1 -->
  <rule id="515034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0508 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>