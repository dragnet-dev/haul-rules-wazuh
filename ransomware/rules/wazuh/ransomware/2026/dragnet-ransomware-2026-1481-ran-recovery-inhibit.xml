<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1481 — Recovery Inhibition (play) | Status: stable | Sigma ID: 1c521d77-372a-52ea-8e10-a30f3f75051c -->
  <rule id="163497" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1481 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>