<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2920 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 12e4bf1a-4578-54d1-94b1-6e5be4314bf4 -->
  <rule id="885751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2920 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>