<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0913 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: 8552d51e-e398-5104-aafd-51849b2e475b -->
  <rule id="568455" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0913 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>