<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1562 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 1f80d50e-571c-5197-938e-b018a7a3d4ff -->
  <rule id="689350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1562 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>