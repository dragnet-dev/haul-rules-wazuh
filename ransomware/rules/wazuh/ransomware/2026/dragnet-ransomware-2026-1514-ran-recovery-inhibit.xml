<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1514 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: a752ba49-a8b9-5b65-97aa-6247e0f36d8f -->
  <rule id="152698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1514 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>