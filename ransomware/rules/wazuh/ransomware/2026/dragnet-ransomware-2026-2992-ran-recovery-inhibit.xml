<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2992 — Recovery Inhibition (qilin) | Status: test | Sigma ID: d8d6362a-f922-57bc-bd65-d86144bcf068 -->
  <rule id="521636" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2992 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>