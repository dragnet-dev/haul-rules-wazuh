<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2953 — Event Log Clearing (vect) | Status: deprecated | Sigma ID: 52433329-7925-58b7-b7ec-92801ab74c64 -->
  <rule id="843332" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2953 — Event Log Clearing (vect)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>