<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1671 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 7401e324-b67f-50a2-ba8d-bf369c5b1fbf -->
  <rule id="384303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1671 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>