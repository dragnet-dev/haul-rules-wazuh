<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2785 — Recovery Inhibition (everest) | Status: stable | Sigma ID: e6aaa10f-7548-5951-88fa-189b0ef064d2 -->
  <rule id="707461" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2785 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>