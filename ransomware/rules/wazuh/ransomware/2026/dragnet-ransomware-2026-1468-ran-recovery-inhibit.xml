<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1468 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 4c3bdcba-12a6-54e7-8bf4-e0e8ca685aac -->
  <rule id="528284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1468 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>