<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2475 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 00f7ec74-649d-59e1-89e7-604feaa67a29 -->
  <rule id="542874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2475 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>