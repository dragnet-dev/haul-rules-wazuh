<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3096 — Recovery Inhibition (securotrop) | Status: stable | Sigma ID: 3f4d0323-55f8-5c5b-a040-e0251b7da177 -->
  <rule id="215703" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3096 — Recovery Inhibition (securotrop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>