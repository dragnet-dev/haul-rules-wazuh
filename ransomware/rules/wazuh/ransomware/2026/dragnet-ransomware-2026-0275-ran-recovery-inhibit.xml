<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0275 — Recovery Inhibition (gunra) | Status: stable | Sigma ID: 8646b354-089a-5e33-b1aa-296540f9304b -->
  <rule id="583473" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0275 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>