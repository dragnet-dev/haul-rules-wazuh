<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0089 — Event Log Clearing (coinbasecartel) | Status: stable | Sigma ID: 464a4cb7-5d91-5aeb-acdc-11181ecb8e9f -->
  <rule id="389516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0089 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>