<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1810 — Event Log Clearing (play) | Status: test | Sigma ID: 452c8e61-a85d-5776-be61-168935a3bd59 -->
  <rule id="359182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1810 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>