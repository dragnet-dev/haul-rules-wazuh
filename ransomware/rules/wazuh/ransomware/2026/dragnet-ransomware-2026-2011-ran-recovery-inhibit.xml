<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2011 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: cacb7ea7-3e94-56d2-a191-e690a03ae2a3 -->
  <rule id="306526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2011 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>