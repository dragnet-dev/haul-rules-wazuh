<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0771 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 03b50c34-27d3-59bb-89b7-a24096674058 -->
  <rule id="621234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0771 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>