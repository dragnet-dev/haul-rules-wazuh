<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3158 — Recovery Inhibition (sinobi) | Status: stable | Sigma ID: 524207fc-6ae2-54a5-8fa2-343a3bee8ac3 -->
  <rule id="387327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3158 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>