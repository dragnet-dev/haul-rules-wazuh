<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2172 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 355ed200-b7b6-5e9b-8339-1fddd3a7f43c -->
  <rule id="211720" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2172 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>