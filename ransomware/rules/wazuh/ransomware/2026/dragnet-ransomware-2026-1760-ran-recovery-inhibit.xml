<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1760 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: c01c1a64-5550-570d-968d-56102466ea34 -->
  <rule id="476506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1760 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
