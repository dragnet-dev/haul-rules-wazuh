<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2339 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 38b80fe0-18da-5de3-8c69-68355e046a01 -->
  <rule id="667134" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2339 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>