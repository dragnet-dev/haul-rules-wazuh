<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2559 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 4d72eac8-277f-575d-b70f-4c6c0d61a39a -->
  <rule id="289866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2559 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>