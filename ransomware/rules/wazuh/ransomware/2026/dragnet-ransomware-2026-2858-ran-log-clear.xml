<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2858 — Event Log Clearing (dragonforce) | Status: stable | Sigma ID: 91a3be8c-d4c5-50d0-96fc-5635b7004ab7 -->
  <rule id="253918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2858 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>