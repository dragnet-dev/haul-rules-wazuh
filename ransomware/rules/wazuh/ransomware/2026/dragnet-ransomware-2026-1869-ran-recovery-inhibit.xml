<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1869 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: a7ca662c-b718-5098-a710-d4368d4a7565 -->
  <rule id="159466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1869 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
