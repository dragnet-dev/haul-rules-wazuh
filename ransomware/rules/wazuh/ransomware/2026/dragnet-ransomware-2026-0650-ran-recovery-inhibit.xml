<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0650 — Recovery Inhibition (anubis) | Status: stable | Sigma ID: 0d881f3e-fec4-52fd-89d2-18d9faf78954 -->
  <rule id="521113" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0650 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>