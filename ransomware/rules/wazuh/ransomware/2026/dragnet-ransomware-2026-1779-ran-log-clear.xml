<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1779 — Event Log Clearing (coinbasecartel) | Status: stable | Sigma ID: 6b5c60f6-a43e-54f9-b936-09d83e4077d4 -->
  <rule id="921260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1779 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>