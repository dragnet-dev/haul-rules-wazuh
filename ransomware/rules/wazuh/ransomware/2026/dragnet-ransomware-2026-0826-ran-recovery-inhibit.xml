<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0826 — Recovery Inhibition (termite) | Status: stable | Sigma ID: 48757e8c-04d3-5663-b879-2d407a99e588 -->
  <rule id="701268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0826 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>