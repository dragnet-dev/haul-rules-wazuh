<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3544 — Recovery Inhibition (nova) | Status: stable | Sigma ID: fd7fd6d8-9977-5e86-98db-07d97e2dd879 -->
  <rule id="297256" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3544 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>