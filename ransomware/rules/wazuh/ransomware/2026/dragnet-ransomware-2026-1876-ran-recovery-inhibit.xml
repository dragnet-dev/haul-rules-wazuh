<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1876 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 16dfc346-69eb-5eed-af5f-8773a86f8de4 -->
  <rule id="711634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1876 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>