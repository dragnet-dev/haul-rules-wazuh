<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3529 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: 46542c44-4ddd-5148-8bf7-02e1c176b22e -->
  <rule id="346844" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3529 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>