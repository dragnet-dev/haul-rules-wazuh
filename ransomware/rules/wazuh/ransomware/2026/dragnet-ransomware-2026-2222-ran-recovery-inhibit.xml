<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2222 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 5ea06b92-afea-52ac-a52d-bd1cb412e855 -->
  <rule id="722507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2222 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>