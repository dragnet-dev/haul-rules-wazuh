<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1502 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: f8195246-71c2-5fff-8807-d75ad69fbd55 -->
  <rule id="781952" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1502 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>