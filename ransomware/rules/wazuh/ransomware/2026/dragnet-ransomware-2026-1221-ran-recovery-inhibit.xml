<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1221 — Recovery Inhibition (interlock) | Status: stable | Sigma ID: 7a7a82eb-0225-5f18-a408-0bd3ee9f8c03 -->
  <rule id="264282" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1221 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>