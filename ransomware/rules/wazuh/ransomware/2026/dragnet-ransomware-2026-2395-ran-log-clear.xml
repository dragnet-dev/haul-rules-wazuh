<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2395 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: 35f97af2-cb79-57d7-a1ad-51af25eea6fd -->
  <rule id="445007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2395 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>