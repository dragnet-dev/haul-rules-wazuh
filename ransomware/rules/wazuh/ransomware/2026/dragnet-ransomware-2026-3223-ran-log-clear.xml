<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3223 — Event Log Clearing (dragonforce) | Status: stable | Sigma ID: 1b55ada5-24c8-56e2-aeea-6f08b66f6a22 -->
  <rule id="587258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3223 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>