<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1043 — Event Log Clearing (thegentlemen) | Status: test | Sigma ID: 60cb9e1f-9dd4-5e75-bb34-7e8e21bfee10 -->
  <rule id="790238" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1043 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>