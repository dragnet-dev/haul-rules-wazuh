<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3318 — Event Log Clearing (payload) | Status: stable | Sigma ID: 6a79f2fd-6bb9-590c-8af4-a8ec0323f8a1 -->
  <rule id="908792" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3318 — Event Log Clearing (payload)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>