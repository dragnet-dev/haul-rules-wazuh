<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1686 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: e0456469-f099-5378-afc8-91483e842f82 -->
  <rule id="604564" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1686 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>