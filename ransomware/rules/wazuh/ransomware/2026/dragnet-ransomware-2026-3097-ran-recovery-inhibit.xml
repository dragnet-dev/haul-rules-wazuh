<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3097 — Recovery Inhibition (securotrop) | Status: stable | Sigma ID: c7273d9b-28d1-54fd-91be-ec2dcfcaa288 -->
  <rule id="336381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3097 — Recovery Inhibition (securotrop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>