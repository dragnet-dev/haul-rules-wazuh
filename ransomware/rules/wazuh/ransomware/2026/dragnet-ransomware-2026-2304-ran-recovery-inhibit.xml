<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2304 — Recovery Inhibition (spacebears) | Status: stable | Sigma ID: 21313641-3b9c-54d6-b126-d2a2cc2b00ba -->
  <rule id="431364" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2304 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>