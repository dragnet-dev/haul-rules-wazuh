<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1533 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: b9388709-a68a-5b79-ac79-c859208a9c6b -->
  <rule id="393887" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1533 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>