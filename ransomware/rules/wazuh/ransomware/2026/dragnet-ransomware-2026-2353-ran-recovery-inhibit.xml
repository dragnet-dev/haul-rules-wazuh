<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2353 — Recovery Inhibition (ransomexx) | Status: stable | Sigma ID: 8ff1504f-d32a-5f56-9b4d-6ef61dd8dc68 -->
  <rule id="603150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2353 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>