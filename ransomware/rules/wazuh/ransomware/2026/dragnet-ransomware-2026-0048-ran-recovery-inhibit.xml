<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0048 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 4e7f4e93-ce35-56f5-a2be-470e42d56a6d -->
  <rule id="317198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0048 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>