<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2517 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 8097cfb8-aaf4-5f81-90d5-8f6ce63b89c5 -->
  <rule id="373039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2517 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>