<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3377 — Event Log Clearing (ransomhouse) | Status: test | Sigma ID: 1bdc20a4-b38b-5a56-a8c1-576b85fb78b4 -->
  <rule id="711530" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3377 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>