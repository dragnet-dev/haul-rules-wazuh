<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1896 — Recovery Inhibition (m3rx) | Status: stable | Sigma ID: 8209facb-3d7a-50c7-a8b2-e53c27d712d5 -->
  <rule id="401754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1896 — Recovery Inhibition (m3rx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>