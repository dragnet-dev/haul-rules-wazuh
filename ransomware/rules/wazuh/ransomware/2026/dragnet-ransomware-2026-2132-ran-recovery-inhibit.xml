<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2132 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 631124b3-d617-5c60-987f-95c747f1f2a0 -->
  <rule id="297995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2132 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>