<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2466 — Recovery Inhibition (BrainCipher) | Status: stable | Sigma ID: e22307b1-5807-5017-a5e5-4b99499f6645 -->
  <rule id="622307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2466 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>