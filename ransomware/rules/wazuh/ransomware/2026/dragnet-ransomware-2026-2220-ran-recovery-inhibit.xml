<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2220 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 80ee17bc-5148-53bb-8125-4d4fd683a724 -->
  <rule id="371817" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2220 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>