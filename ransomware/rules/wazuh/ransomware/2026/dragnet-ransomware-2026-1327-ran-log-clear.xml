<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1327 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: ea16a824-0b9f-5647-a093-e730d83590d2 -->
  <rule id="246668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1327 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>