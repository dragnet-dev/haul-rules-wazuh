<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2711 — Event Log Clearing (safepay) | Status: test | Sigma ID: bdf2dedd-3ba4-5754-ab1e-e8ffafa4b1c9 -->
  <rule id="680574" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2711 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>