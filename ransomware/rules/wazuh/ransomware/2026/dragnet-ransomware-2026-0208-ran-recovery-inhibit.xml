<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0208 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 246c9183-5576-59a3-8d09-dbf8a866e406 -->
  <rule id="448918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0208 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>