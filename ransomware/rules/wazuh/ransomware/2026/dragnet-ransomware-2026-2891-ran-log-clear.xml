<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2891 — Event Log Clearing (dragonforce) | Status: stable | Sigma ID: e0b3db24-28d3-5502-b8e0-1d053e1f2fc9 -->
  <rule id="463547" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2891 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>