<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0574 — Recovery Inhibition (BrainCipher) | Status: stable | Sigma ID: 5747e732-e180-5325-a599-ea586e70ac4e -->
  <rule id="296673" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0574 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>