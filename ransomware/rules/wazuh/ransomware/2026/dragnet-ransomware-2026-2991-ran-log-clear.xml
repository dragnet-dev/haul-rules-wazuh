<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2991 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: 6e1794a2-54c7-5ba1-b2c9-8c223e1e1ea0 -->
  <rule id="301794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2991 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>