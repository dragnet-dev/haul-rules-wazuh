<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1314 — Recovery Inhibition (worldleaks) | Status: stable | Sigma ID: d468da63-8f79-5cee-bb22-5952c735e864 -->
  <rule id="848026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1314 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>