<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2645 — Recovery Inhibition (m3rx) | Status: stable | Sigma ID: 82fa297c-f830-52ec-af82-49aeb6a2b0f5 -->
  <rule id="424229" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2645 — Recovery Inhibition (m3rx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>