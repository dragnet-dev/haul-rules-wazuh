<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2073 — Recovery Inhibition (payload) | Status: stable | Sigma ID: 293a817e-5c6f-564f-acd8-60b819b2ad5b -->
  <rule id="298817" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2073 — Recovery Inhibition (payload)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>