<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0094 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 32cf4647-2e1a-51c6-8d68-fea6643750e3 -->
  <rule id="399464" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0094 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>