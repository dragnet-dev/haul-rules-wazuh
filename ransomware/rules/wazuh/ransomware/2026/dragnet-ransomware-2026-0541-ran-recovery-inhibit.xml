<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0541 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 678fecee-1937-5894-b9a1-24810c205171 -->
  <rule id="181164" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0541 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>