<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0372 — Recovery Inhibition (kittykatkrew) | Status: stable | Sigma ID: 4ecddb81-9f04-55f8-aa29-cd10fbf62968 -->
  <rule id="764507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0372 — Recovery Inhibition (kittykatkrew)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>