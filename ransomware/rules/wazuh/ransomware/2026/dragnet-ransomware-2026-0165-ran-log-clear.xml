<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0165 — Event Log Clearing (chaos) | Status: test | Sigma ID: 635dbd1e-f6f4-522d-9f1b-9415c8216c9a -->
  <rule id="904477" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0165 — Event Log Clearing (chaos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>