<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3149 — Recovery Inhibition (lynx) | Status: test | Sigma ID: 44a5507a-4d6f-5b03-8b9b-f87aa3edba02 -->
  <rule id="945507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3149 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>