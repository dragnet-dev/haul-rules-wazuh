<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3029 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: 4596c7f9-7cb1-5d1c-8757-9dee76236a47 -->
  <rule id="167807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3029 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>