<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0810 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: c07295cc-593b-5cfa-b385-06111c92bffc -->
  <rule id="407295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0810 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>