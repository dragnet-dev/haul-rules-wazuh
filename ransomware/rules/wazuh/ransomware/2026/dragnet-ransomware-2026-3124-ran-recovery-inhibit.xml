<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3124 — Recovery Inhibition (handala) | Status: stable | Sigma ID: e35b28ce-2b85-591a-b6f7-0bbfac0cd400 -->
  <rule id="597128" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3124 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>