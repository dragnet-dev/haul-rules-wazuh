<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0028 — Recovery Inhibition (BrainCipher) | Status: stable | Sigma ID: 0e3fe74a-e905-5283-877d-1e331948caaa -->
  <rule id="186274" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0028 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>