<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2358 — Event Log Clearing (osiris) | Status: deprecated | Sigma ID: 31d4d7a3-0271-55f2-88b7-2cd18fd1826c -->
  <rule id="542842" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2358 — Event Log Clearing (osiris)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>