<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0753 — Event Log Clearing (insomnia) | Status: stable | Sigma ID: ca1fc077-3d22-51f6-bd88-f6a26fd709e4 -->
  <rule id="776280" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0753 — Event Log Clearing (insomnia)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>