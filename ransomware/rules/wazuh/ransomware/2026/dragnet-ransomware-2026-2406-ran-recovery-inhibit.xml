<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2406 — Recovery Inhibition (clop) | Status: stable | Sigma ID: 8d685e0b-3b22-5bd5-a598-400e413990f0 -->
  <rule id="566974" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2406 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
