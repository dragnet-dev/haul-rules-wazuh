<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3484 — Event Log Clearing (blackwater) | Status: stable | Sigma ID: 0448db02-3269-5eb7-b889-e7a55dad9348 -->
  <rule id="349070" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3484 — Event Log Clearing (blackwater)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>