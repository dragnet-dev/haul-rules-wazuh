<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0346 — Event Log Clearing (dragonforce) | Status: stable | Sigma ID: 602ef9b5-cea1-5f3a-bb76-0cf72eb041c6 -->
  <rule id="743519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0346 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>