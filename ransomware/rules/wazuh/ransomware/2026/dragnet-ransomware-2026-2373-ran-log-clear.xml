<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2373 — Event Log Clearing (kairos) | Status: deprecated | Sigma ID: 2c80c4fd-3d59-5ef4-ba21-1c9cb2cb6ad0 -->
  <rule id="770799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2373 — Event Log Clearing (kairos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>