<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0264 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 51055d64-2cb8-5cdf-b071-a610f73ce1f4 -->
  <rule id="168936" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0264 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>