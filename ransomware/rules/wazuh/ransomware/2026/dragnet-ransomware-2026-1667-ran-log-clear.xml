<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1667 — Event Log Clearing (gunra) | Status: stable | Sigma ID: 3628cf08-ef81-5aba-9840-9c39ce3e1890 -->
  <rule id="389750" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1667 — Event Log Clearing (gunra)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>