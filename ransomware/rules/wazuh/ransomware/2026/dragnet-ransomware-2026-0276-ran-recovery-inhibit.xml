<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0276 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 46cc6c0f-8109-5914-b495-d92d16e07402 -->
  <rule id="216908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0276 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>