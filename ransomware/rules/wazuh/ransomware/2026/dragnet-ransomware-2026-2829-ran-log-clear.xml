<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2829 — Event Log Clearing (genesis) | Status: stable | Sigma ID: 5d4d1cc5-8376-5ddc-9dff-ff709d290134 -->
  <rule id="693148" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2829 — Event Log Clearing (genesis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>