<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0246 — Recovery Inhibition (chaos) | Status: stable | Sigma ID: 292c4f9f-2496-510e-99b2-701761463457 -->
  <rule id="395199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0246 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
