<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0182 — Recovery Inhibition (everest) | Status: stable | Sigma ID: ba9e46ef-6d43-5adf-b627-a4a9237edb03 -->
  <rule id="391846" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0182 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>