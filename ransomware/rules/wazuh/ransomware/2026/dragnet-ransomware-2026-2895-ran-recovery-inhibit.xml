<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2895 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 5416c59b-46fe-580d-92f2-c28b66985718 -->
  <rule id="666859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2895 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
