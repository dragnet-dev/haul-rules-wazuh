<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2235 — Recovery Inhibition (play) | Status: stable | Sigma ID: ee84171e-6956-544c-9965-4d70e254c523 -->
  <rule id="688417" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2235 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>