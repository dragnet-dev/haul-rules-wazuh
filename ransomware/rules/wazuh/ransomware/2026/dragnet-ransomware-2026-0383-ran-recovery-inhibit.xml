<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0383 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 53fcfc38-3b56-50a2-9840-5d33e59e7d65 -->
  <rule id="938172" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0383 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>