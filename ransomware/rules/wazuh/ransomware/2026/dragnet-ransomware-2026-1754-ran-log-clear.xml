<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1754 — Event Log Clearing (AuditTeam) | Status: stable | Sigma ID: d7bd763b-12f9-5de1-b2e7-8f2fe47f87b3 -->
  <rule id="926176" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1754 — Event Log Clearing (AuditTeam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>