<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0891 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 58cea530-a7cb-5e79-b22f-81f1a3db32bc -->
  <rule id="708745" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0891 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>