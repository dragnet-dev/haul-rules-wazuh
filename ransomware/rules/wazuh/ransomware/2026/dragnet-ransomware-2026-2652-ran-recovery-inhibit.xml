<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2652 — Recovery Inhibition (m3rx) | Status: stable | Sigma ID: 8a6238f0-d821-52c2-80a5-6bcc1bc5c1e9 -->
  <rule id="586238" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2652 — Recovery Inhibition (m3rx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>