<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1369 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 8e643d62-b756-5228-8db5-606fbd616208 -->
  <rule id="582301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1369 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>