<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0838 — Recovery Inhibition (everest) | Status: test | Sigma ID: 2f063609-b64e-5f24-a44d-99d66633ae6a -->
  <rule id="306360" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0838 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>