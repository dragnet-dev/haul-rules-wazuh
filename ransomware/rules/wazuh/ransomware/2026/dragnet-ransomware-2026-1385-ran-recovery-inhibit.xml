<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1385 — Recovery Inhibition (beast) | Status: stable | Sigma ID: 5e99d3e1-41d4-5b45-a8e2-ded660b054b5 -->
  <rule id="719973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1385 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>