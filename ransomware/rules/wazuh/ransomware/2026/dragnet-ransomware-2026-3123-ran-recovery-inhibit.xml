<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3123 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: cf851e9f-c755-5239-9464-33d855032fe5 -->
  <rule id="725630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3123 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>