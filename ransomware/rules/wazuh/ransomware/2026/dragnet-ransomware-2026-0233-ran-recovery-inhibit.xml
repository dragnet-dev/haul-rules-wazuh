<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0233 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 22e8fb4f-7b43-5398-8e19-bfc0301e64bb -->
  <rule id="492594" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0233 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>