<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2026 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 73ec84e9-a3df-56cb-8084-3d023929fca4 -->
  <rule id="192484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2026 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>