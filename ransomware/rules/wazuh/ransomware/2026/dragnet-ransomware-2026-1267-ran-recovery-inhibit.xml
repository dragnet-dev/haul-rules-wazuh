<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1267 — Recovery Inhibition (netrunner) | Status: stable | Sigma ID: dad1ae08-d362-5052-a41a-297cfe522ce7 -->
  <rule id="962990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1267 — Recovery Inhibition (netrunner)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>