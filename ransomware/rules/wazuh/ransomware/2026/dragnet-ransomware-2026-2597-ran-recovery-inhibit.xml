<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2597 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 67886d90-dc2b-5539-95a8-ce3f061acc63 -->
  <rule id="286189" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2597 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>