<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3512 — Recovery Inhibition (PrinzEugen) | Status: stable | Sigma ID: 805c9681-6fde-5783-9a6c-470d52495ded -->
  <rule id="489296" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3512 — Recovery Inhibition (PrinzEugen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>