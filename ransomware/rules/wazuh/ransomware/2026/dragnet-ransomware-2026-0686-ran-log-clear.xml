<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0686 — Event Log Clearing (mnt6) | Status: stable | Sigma ID: 8319317c-f23c-509a-ad16-214dbca703bf -->
  <rule id="319317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0686 — Event Log Clearing (mnt6)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>