<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3351 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: e36ffed5-43a4-5bd6-bd47-e635dd1c0dba -->
  <rule id="585950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3351 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>