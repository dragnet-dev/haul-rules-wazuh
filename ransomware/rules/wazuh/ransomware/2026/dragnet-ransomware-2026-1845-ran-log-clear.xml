<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1845 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: 9f78ebab-3c6d-51f0-84a0-31a7ec680c6e -->
  <rule id="590603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1845 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>