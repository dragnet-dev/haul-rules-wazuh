<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1297 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 706f1199-dee5-56be-bd7d-afa0e33fe0ea -->
  <rule id="331111" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1297 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>