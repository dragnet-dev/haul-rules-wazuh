<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1601 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 45c5486c-f327-5f24-9813-b52cb813fd80 -->
  <rule id="225486" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1601 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>