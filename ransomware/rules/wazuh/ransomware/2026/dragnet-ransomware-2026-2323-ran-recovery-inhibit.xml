<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2323 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 4b2fb548-0219-51ad-bbec-2f4a4a904f1c -->
  <rule id="227635" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2323 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>