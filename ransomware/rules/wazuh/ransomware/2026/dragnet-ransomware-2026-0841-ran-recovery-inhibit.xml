<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0841 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 1e96ec60-8c52-5a22-a153-9a754e6fcc65 -->
  <rule id="828126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0841 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>