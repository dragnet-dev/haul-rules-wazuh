<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2780 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 47aa141f-c6ac-5f1b-ae22-1c0f10740efb -->
  <rule id="420214" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2780 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>