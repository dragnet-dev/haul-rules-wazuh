<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1786 — Shadow Copy Deletion (BrainCipher) | Status: stable | Sigma ID: 4b9a3bbe-e31e-5e9e-8d57-4396155cd7ef -->
  <rule id="244699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1786 — Shadow Copy Deletion (BrainCipher)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>