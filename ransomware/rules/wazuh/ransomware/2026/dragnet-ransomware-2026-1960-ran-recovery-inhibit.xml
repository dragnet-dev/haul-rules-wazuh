<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1960 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: e1e0fb50-e050-5dd9-aa70-78c52469d920 -->
  <rule id="511451" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1960 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
