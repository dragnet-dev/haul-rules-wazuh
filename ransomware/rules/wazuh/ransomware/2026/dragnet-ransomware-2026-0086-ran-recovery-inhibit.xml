<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0086 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 8a792066-6638-5794-9da4-71fb62e63210 -->
  <rule id="587920" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0086 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>