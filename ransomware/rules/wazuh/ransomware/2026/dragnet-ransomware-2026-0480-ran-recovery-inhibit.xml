<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0480 — Recovery Inhibition (pear) | Status: stable | Sigma ID: d6d1c694-f75d-51c6-98f8-3cd029e49975 -->
  <rule id="902686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0480 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>