<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3400 — Event Log Clearing (qilin) | Status: test | Sigma ID: 2dcc4287-9a91-55ea-ad0f-a1a5f3bb4dc9 -->
  <rule id="372442" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3400 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>