<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0050 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: aee265b2-a7f3-582f-98c1-a928517697e7 -->
  <rule id="198265" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0050 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
