<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0019 — Recovery Inhibition (lynx) | Status: stable | Sigma ID: 76c50c1c-379d-574a-ab80-74f7db20cd64 -->
  <rule id="265612" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0019 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>