<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0538 — Recovery Inhibition (everest) | Status: stable | Sigma ID: 4730c6e5-d7cd-5aa7-8e3b-2a565607951a -->
  <rule id="510830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0538 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>