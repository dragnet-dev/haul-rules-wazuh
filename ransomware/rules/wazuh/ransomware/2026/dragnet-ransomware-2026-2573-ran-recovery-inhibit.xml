<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2573 — Recovery Inhibition (medusalocker) | Status: stable | Sigma ID: c40177f9-ec12-516b-a9fc-3fa66c2eb453 -->
  <rule id="440177" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2573 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>