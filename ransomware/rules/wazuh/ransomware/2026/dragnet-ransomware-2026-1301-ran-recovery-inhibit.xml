<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1301 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 85991e29-e7ce-5609-a725-ef16682c52c6 -->
  <rule id="575870" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1301 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>