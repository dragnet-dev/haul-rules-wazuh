<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2807 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: abff4f60-f20d-50fe-bc0f-499fc560d3f6 -->
  <rule id="845039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2807 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>