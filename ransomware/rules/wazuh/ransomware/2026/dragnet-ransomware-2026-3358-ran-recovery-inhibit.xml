<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3358 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 83c34e62-ab15-5ef9-8b6e-113526bf52e6 -->
  <rule id="444558" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3358 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>