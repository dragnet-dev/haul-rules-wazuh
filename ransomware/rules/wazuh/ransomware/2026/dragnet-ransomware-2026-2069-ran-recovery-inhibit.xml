<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2069 — Recovery Inhibition (lynx) | Status: stable | Sigma ID: c1f5d166-8dfc-56b8-8d01-f81164fcc137 -->
  <rule id="522531" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2069 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>