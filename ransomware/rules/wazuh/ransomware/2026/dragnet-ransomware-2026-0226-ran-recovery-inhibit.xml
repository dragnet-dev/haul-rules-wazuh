<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0226 — Recovery Inhibition (play) | Status: stable | Sigma ID: 78ebd808-e9b4-52c0-a85f-6c26ea0cd004 -->
  <rule id="632618" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0226 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>