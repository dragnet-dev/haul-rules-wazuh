<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0507 — Recovery Inhibition (payload) | Status: stable | Sigma ID: e8ad985c-dc14-5d6c-a5f2-d1695ee88f0d -->
  <rule id="306198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0507 — Recovery Inhibition (payload)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>