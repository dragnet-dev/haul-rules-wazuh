<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3187 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 65d5afae-1d5c-50d1-8bbc-acc208ab8fa8 -->
  <rule id="997135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3187 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>