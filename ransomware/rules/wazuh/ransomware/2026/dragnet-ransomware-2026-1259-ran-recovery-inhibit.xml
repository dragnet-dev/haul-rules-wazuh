<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1259 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 6da77d06-9286-5e1d-8485-bee14b66aeda -->
  <rule id="207645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1259 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>