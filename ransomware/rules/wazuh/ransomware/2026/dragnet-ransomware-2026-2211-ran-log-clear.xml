  <rule id="327148" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2211 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
