<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0036 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 7a5b6692-03b4-5f53-bcb5-7180e717a85f -->
  <rule id="261166" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0036 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>