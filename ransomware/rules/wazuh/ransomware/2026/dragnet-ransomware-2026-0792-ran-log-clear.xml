<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0792 — Event Log Clearing (gunra) | Status: stable | Sigma ID: 1a5f8e88-f714-53fb-9870-f8bef82bed4f -->
  <rule id="609428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0792 — Event Log Clearing (gunra)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>