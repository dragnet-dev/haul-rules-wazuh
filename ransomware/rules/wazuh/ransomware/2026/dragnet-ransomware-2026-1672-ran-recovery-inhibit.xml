<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1672 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: b0ffd074-2349-5700-a8dd-4b30608e0660 -->
  <rule id="146530" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1672 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>