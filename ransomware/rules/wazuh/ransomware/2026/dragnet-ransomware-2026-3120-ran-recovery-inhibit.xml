<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3120 — Recovery Inhibition (everest) | Status: test | Sigma ID: 2d7a884c-9c9b-50b6-8758-e9aedce506c6 -->
  <rule id="222884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3120 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>