<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2520 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 9b757224-4e53-5c6b-82c9-27fb4755a85b -->
  <rule id="757572" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2520 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>