<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3372 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: d4e82832-fc57-585c-827e-2e1821c60e80 -->
  <rule id="458828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3372 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>