<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0835 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 75c4e49a-01df-538a-8add-87bb04066efe -->
  <rule id="239984" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0835 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>