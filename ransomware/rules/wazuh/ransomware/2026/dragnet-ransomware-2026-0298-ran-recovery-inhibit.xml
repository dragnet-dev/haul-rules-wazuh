<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0298 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: d4d4f9fa-9321-557b-98d6-26a8fe9cd5db -->
  <rule id="851999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0298 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>