<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0649 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: b87f5fe5-f8bb-5a23-81d2-d5c863b5f104 -->
  <rule id="441215" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0649 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>