<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0205 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 101095ba-3534-560d-84a0-c0a12264acb4 -->
  <rule id="817531" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0205 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>