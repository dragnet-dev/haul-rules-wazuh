<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3480 — Event Log Clearing (qilin) | Status: stable | Sigma ID: bf45b958-9d93-5b4a-b3d3-f8ac52f4e1b0 -->
  <rule id="463319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3480 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>