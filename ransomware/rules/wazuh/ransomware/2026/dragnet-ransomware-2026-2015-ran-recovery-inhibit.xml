<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2015 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: d33ee1aa-7a5a-5043-b346-35688100a761 -->
  <rule id="814861" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2015 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>