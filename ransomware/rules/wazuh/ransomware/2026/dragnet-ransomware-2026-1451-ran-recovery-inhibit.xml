<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1451 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 2d5b4f31-0aab-5031-95d8-c683c79ec44b -->
  <rule id="366639" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1451 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>