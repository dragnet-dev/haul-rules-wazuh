<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2367 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 33c55586-3729-5ab2-bda1-1e348dab144c -->
  <rule id="105558" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2367 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>