<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2847 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 1a8e6f54-4378-5edb-887c-5a51495101c7 -->
  <rule id="684315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2847 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>