<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0808 — Event Log Clearing (nova) | Status: stable | Sigma ID: 1bc5aa8f-bc29-5a4a-b9e1-d580aa6321ad -->
  <rule id="338090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0808 — Event Log Clearing (nova)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>