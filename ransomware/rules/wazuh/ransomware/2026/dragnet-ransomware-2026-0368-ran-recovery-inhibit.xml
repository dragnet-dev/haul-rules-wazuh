<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0368 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: c86145c3-3f7e-5d9e-8a3b-7b16bc299e63 -->
  <rule id="486145" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0368 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>