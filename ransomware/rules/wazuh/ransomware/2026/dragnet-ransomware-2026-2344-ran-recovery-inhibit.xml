<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2344 — Recovery Inhibition (interlock) | Status: stable | Sigma ID: f3787d8e-56d6-5d5f-a4ae-958a0278aa73 -->
  <rule id="760605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2344 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>