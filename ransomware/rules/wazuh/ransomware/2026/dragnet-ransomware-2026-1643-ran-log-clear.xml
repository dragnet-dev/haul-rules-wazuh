<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1643 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: 3fe33131-dc74-5f59-8bac-bad3b282fc2f -->
  <rule id="222331" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1643 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>