<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1157 — Event Log Clearing (thegentlemen) | Status: stable | Sigma ID: 8876f9a9-3f9c-5010-b4eb-ea7057d28d12 -->
  <rule id="620319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1157 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>