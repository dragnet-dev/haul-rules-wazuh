<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3421 — Recovery Inhibition (lynx) | Status: test | Sigma ID: dc04f810-232e-5919-90f0-f8d550a11c01 -->
  <rule id="920798" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3421 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
