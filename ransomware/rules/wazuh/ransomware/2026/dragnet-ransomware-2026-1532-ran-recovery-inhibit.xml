<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1532 — Recovery Inhibition (play) | Status: stable | Sigma ID: 5709f4df-fea8-5077-9110-7317feb7d702 -->
  <rule id="317517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1532 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>