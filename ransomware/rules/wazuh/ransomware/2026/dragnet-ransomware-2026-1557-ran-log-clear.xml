<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1557 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 1c9594ca-9873-5c7c-8ed8-b7e4f1e89f1a -->
  <rule id="233516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1557 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>