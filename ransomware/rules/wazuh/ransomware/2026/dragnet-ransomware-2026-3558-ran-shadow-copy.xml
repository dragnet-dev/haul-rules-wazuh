<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3558 — Shadow Copy Deletion (shadowbyt3$) | Status: deprecated | Sigma ID: 9b36aad1-2a19-5ee4-850c-434590e78cd0 -->
  <rule id="477386" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3558 — Shadow Copy Deletion (shadowbyt3$)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>