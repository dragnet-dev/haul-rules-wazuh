<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0778 — Recovery Inhibition (play) | Status: stable | Sigma ID: da128517-62b3-5847-9adc-8ea8e3dcb9bd -->
  <rule id="481285" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0778 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>