<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2264 — Event Log Clearing (gunra) | Status: stable | Sigma ID: ad812f6c-579e-56d8-9d46-0a6a0d8c5324 -->
  <rule id="181007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2264 — Event Log Clearing (gunra)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>