<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0040 — Recovery Inhibition (aurora) | Status: stable | Sigma ID: 2d1a0692-d58b-5235-a028-05bd52fa9429 -->
  <rule id="126069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0040 — Recovery Inhibition (aurora)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>