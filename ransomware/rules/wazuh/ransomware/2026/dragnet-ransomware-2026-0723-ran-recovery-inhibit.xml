<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0723 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 4ca720a8-d399-5cc1-9141-626c1b03c18a -->
  <rule id="426720" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0723 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>