<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2311 — Recovery Inhibition (m3rx) | Status: stable | Sigma ID: 905650ca-3c2f-5f60-95e1-0d121b4f9c96 -->
  <rule id="190412" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2311 — Recovery Inhibition (m3rx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>