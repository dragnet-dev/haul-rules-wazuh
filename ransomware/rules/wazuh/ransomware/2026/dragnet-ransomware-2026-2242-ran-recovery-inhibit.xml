<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2242 — Recovery Inhibition (BrainCipher) | Status: stable | Sigma ID: ad2202eb-b08b-550b-afc6-162144c5f218 -->
  <rule id="932202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2242 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>