<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2624 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: 2a60cffe-e088-5694-ac5a-2da2d5bb7d8e -->
  <rule id="290767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2624 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>