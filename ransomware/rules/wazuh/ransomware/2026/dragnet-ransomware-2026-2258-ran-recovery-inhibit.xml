<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2258 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 567acc46-d47e-5ff4-9b36-c030b72004db -->
  <rule id="625196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2258 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>