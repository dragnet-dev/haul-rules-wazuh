<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1324 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 49e22db1-71c9-530f-b1b1-5c415db23e7d -->
  <rule id="477165" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1324 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>