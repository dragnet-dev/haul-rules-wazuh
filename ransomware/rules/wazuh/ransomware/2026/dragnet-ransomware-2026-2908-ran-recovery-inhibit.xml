<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2908 — Recovery Inhibition (insomnia) | Status: stable | Sigma ID: d364fa40-9739-5059-b13e-c65ae0817e5d -->
  <rule id="821434" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2908 — Recovery Inhibition (insomnia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>