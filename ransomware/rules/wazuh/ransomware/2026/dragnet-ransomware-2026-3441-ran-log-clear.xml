<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3441 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 7b5de94c-9ba8-517d-befe-df9bb7cb6c75 -->
  <rule id="563829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3441 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>