<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1321 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 072ca956-5914-5732-9397-8c1f17634d64 -->
  <rule id="163495" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1321 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>