<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2479 — Event Log Clearing (fulcrumsec) | Status: stable | Sigma ID: 67f723f6-8db2-5a56-9b41-fb17cfc12674 -->
  <rule id="287723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2479 — Event Log Clearing (fulcrumsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>