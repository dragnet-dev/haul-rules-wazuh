<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2892 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 0c602b72-6fde-5da3-98c8-14d08c976029 -->
  <rule id="316437" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2892 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>