<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2004 — Recovery Inhibition (spacebears) | Status: stable | Sigma ID: b0cfab1d-b134-590e-9152-4e2ad11fbf44 -->
  <rule id="162123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2004 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>