<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1750 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: fb929127-1803-5131-b7ef-20b96632f6ea -->
  <rule id="819291" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1750 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>