<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2826 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 29085961-c050-53c4-ae21-a8eba263c58a -->
  <rule id="308596" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2826 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>