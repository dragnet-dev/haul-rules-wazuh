<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1712 — Event Log Clearing (dragonforce) | Status: stable | Sigma ID: 5275af6d-ea3b-5bdf-90e2-d9c7f5639d1f -->
  <rule id="550575" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1712 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>