<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3434 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 7e7eadcc-3d93-500d-9ada-5487bbe2aae9 -->
  <rule id="793389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3434 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>