<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3381 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 23d1e1f5-d31d-59be-ada4-9457ea265cbe -->
  <rule id="858431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3381 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
