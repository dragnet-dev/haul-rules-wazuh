<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2599 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: a747ed52-2d34-53a7-a7c1-fc6b889158da -->
  <rule id="151469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2599 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>