<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1717 — Recovery Inhibition (gunra) | Status: stable | Sigma ID: 06d47ee4-61eb-589c-a086-00f35c026030 -->
  <rule id="202670" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1717 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>