<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1801 — Recovery Inhibition (medusalocker) | Status: stable | Sigma ID: 7a7f0402-dd30-5cf5-99f9-89f150bd2ef6 -->
  <rule id="264704" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1801 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>