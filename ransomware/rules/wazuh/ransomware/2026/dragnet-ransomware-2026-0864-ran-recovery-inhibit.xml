<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0864 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 3bf08929-43e2-5a27-ac37-9a209c44a15f -->
  <rule id="690892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0864 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>