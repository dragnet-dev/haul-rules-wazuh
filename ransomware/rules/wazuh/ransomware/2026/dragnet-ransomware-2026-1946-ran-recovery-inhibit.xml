<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1946 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: d4873672-7c6a-57a1-aad2-5ccabe156236 -->
  <rule id="548736" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1946 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>