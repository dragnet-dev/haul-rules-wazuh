<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2842 — Event Log Clearing (worldleaks) | Status: stable | Sigma ID: 32d43b76-bc81-5f1f-ad49-bd6f3cf49afb -->
  <rule id="406997" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2842 — Event Log Clearing (worldleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>