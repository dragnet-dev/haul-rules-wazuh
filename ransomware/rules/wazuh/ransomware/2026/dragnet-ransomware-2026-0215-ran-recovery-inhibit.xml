<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0215 — Recovery Inhibition (ransomhouse) | Status: stable | Sigma ID: c5367982-3dfa-527e-bcf0-2ae81f430ac7 -->
  <rule id="453679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0215 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>