<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0312 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: e904d68b-9c08-5583-b1b6-ba377ad22ba5 -->
  <rule id="684776" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0312 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>