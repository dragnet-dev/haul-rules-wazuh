<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3042 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 82002311-ec3b-53ba-abf9-a90a535daeb7 -->
  <rule id="200231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3042 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>