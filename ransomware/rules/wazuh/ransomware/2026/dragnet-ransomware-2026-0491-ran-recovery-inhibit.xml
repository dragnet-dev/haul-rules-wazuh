<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0491 — Recovery Inhibition (spacebears) | Status: stable | Sigma ID: cb7f3e52-4350-5f1e-a237-0e5627b3d414 -->
  <rule id="817182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0491 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>