<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2568 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: b05befd3-00e3-5ca0-97fe-017f10b84129 -->
  <rule id="129135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2568 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>