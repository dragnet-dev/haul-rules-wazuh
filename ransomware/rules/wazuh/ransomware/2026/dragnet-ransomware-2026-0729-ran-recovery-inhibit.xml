<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0729 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: b331172f-2ac4-5017-9680-4a5ae536750c -->
  <rule id="333117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0729 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>