<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0710 — Recovery Inhibition (payoutsking) | Status: stable | Sigma ID: 3bd35fd6-7016-511c-ace9-418b13be0dde -->
  <rule id="731775" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0710 — Recovery Inhibition (payoutsking)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>