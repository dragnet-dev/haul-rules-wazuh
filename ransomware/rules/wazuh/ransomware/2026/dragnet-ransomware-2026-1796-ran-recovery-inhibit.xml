<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1796 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: e684cf70-1304-513e-ba61-b02425588dc4 -->
  <rule id="259311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1796 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>