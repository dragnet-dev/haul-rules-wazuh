<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0018 — Recovery Inhibition (lynx) | Status: stable | Sigma ID: ff6009f9-af23-5faf-8bda-b9cb2b0c24f6 -->
  <rule id="856009" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0018 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>