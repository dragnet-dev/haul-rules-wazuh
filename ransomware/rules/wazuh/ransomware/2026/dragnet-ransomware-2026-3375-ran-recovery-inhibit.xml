<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3375 — Recovery Inhibition (handala) | Status: stable | Sigma ID: de22843d-ce85-5041-9a86-47641cf64771 -->
  <rule id="522284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3375 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>