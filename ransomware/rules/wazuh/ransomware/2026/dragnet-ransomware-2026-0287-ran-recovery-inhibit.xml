<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0287 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 03c248f0-fdf5-57b6-ac9c-ca3f5ac9315b -->
  <rule id="739830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0287 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>