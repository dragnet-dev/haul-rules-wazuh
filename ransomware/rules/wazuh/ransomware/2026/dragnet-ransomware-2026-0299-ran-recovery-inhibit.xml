<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0299 — Recovery Inhibition (everest) | Status: stable | Sigma ID: e448d138-9b39-5a72-9b90-7dfc79a43566 -->
  <rule id="611811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0299 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>