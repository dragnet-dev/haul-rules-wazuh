<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0203 — Recovery Inhibition (play) | Status: test | Sigma ID: fd04514d-f72d-5463-a51c-c12be4e5a24a -->
  <rule id="830451" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0203 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>