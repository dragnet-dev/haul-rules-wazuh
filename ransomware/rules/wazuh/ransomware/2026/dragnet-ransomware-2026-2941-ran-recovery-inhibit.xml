<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2941 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 4e302b93-f786-5830-91a0-ab028eb47665 -->
  <rule id="452843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2941 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>