<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0310 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: e31815d8-b53a-50c3-af64-46ea93bbca15 -->
  <rule id="631815" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0310 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>