<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0412 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: ff305d16-d742-52d3-9589-f5a285097769 -->
  <rule id="584893" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0412 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>