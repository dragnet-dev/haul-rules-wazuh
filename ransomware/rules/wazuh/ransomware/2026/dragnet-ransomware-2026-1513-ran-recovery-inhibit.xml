<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1513 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 1023b613-7f74-5eec-996b-0263fc327719 -->
  <rule id="837961" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1513 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>