<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3302 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 5aa85700-a555-5942-99d7-8744499e1516 -->
  <rule id="650857" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3302 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>