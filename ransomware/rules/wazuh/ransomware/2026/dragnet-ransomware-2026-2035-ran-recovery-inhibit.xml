<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2035 — Recovery Inhibition (handala) | Status: stable | Sigma ID: e66cd29b-b0f6-542a-b32d-54e5c4c9f8aa -->
  <rule id="255012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2035 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>