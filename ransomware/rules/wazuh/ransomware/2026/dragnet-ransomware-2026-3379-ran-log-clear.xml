<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3379 — Event Log Clearing (tengu) | Status: test | Sigma ID: 52042793-ae1e-5c4c-b4d9-d49903251ada -->
  <rule id="804279" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3379 — Event Log Clearing (tengu)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>