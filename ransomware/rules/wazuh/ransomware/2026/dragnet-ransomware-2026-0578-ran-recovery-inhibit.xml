<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0578 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 83a5bd72-b492-5614-aaaf-7604294b3579 -->
  <rule id="826749" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0578 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>