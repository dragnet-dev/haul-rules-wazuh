<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2719 — Event Log Clearing (chaos) | Status: stable | Sigma ID: 30b17f72-d15d-529f-8f70-8a846b19fea2 -->
  <rule id="758877" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2719 — Event Log Clearing (chaos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>