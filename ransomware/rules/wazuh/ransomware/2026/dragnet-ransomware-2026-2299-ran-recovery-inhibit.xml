<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2299 — Recovery Inhibition (play) | Status: stable | Sigma ID: 0184adb3-f8b0-5d6c-9215-5e5506895729 -->
  <rule id="464433" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2299 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>