<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0594 — Event Log Clearing (brotherhood) | Status: deprecated | Sigma ID: a1920b3e-3261-56d0-93d2-5970b64c049d -->
  <rule id="830731" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0594 — Event Log Clearing (brotherhood)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>