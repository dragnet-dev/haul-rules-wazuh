<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0279 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: d3340043-6183-5f23-ae8e-dc64f3da7df6 -->
  <rule id="533400" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0279 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>