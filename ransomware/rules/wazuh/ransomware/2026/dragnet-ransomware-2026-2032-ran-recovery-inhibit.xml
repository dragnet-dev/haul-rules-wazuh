<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2032 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 9bf74580-2ce4-5b73-a75b-23f2f8288cd1 -->
  <rule id="795745" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2032 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>