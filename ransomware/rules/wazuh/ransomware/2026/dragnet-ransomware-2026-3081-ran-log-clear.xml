<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3081 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: b711847e-b974-5c0a-8787-2b9038deaaf4 -->
  <rule id="371184" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3081 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>