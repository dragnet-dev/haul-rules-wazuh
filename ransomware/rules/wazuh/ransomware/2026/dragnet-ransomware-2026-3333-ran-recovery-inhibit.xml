<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3333 — Recovery Inhibition (lynx) | Status: test | Sigma ID: 1f83f691-1df4-59ee-bab8-0168fb46c4ee -->
  <rule id="694369" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3333 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
