<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1916 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 2abe1e74-35e9-5adc-8ceb-6370707db195 -->
  <rule id="950750" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1916 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>