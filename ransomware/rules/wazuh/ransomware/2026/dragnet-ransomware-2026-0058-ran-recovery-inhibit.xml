<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0058 — Recovery Inhibition (play) | Status: stable | Sigma ID: 862fbfef-28c4-58f8-bab8-785589eedca1 -->
  <rule id="934783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0058 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
