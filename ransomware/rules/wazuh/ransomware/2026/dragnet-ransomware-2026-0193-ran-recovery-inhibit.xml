<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0193 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 2fe5c8cf-60d7-5900-b577-893706b7fd29 -->
  <rule id="426528" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0193 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>