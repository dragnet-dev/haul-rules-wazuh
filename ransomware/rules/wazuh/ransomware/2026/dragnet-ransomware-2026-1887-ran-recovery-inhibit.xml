<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1887 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: ea23c4ef-bdc4-59ca-a3f4-ee48fd220517 -->
  <rule id="247804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1887 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>