<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2590 — Event Log Clearing (AuditTeam) | Status: test | Sigma ID: 3891f6cd-ac62-558f-a2d6-68ce7de4cf61 -->
  <rule id="163468" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2590 — Event Log Clearing (AuditTeam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>