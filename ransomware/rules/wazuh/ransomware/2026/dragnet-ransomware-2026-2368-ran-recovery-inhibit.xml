<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2368 — Recovery Inhibition (sinobi) | Status: stable | Sigma ID: 7e6175e5-846f-520a-bfe9-f7af06493b15 -->
  <rule id="466175" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2368 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>