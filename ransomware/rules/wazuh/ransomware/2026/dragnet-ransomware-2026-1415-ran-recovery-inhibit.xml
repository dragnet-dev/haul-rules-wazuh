<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1415 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: da5b83c9-bd56-5aa7-b3e0-c4db6b253c1e -->
  <rule id="897183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1415 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>