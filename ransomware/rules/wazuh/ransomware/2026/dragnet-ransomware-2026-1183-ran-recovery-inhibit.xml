<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1183 — Recovery Inhibition (anubis) | Status: stable | Sigma ID: f70ca11d-f284-51d0-8fcf-a5863e4d1713 -->
  <rule id="521221" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1183 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>