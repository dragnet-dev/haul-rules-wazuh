<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2307 — Recovery Inhibition (ALP-001) | Status: stable | Sigma ID: f54f75e8-c416-524e-9cd1-4709bcb47f81 -->
  <rule id="787975" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2307 — Recovery Inhibition (ALP-001)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>