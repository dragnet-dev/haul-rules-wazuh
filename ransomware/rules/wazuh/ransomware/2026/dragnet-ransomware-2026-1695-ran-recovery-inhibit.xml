<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1695 — Recovery Inhibition (everest) | Status: stable | Sigma ID: 737651bc-78c2-56e7-b770-0f93b0ed1627 -->
  <rule id="202427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1695 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>