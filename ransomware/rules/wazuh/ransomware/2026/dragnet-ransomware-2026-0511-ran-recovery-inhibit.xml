<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0511 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 7211f420-5406-5e54-99fc-e89c242acf81 -->
  <rule id="353914" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0511 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
