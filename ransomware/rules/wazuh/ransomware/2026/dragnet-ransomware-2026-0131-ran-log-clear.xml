<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0131 — Event Log Clearing (shinyhunters) | Status: deprecated | Sigma ID: d7d95314-a72f-5584-9e0f-9210b1fcbe13 -->
  <rule id="505953" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0131 — Event Log Clearing (shinyhunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>