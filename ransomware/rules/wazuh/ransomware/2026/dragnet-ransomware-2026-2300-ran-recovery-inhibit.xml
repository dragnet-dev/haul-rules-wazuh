<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2300 — Recovery Inhibition (netrunner) | Status: stable | Sigma ID: f408225d-6ec4-5bd2-a808-7161ff93bc5d -->
  <rule id="740822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2300 — Recovery Inhibition (netrunner)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>