<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2464 — Event Log Clearing (kazu) | Status: deprecated | Sigma ID: 552afa44-e43b-53cd-86af-957a4ba52185 -->
  <rule id="563802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2464 — Event Log Clearing (kazu)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>