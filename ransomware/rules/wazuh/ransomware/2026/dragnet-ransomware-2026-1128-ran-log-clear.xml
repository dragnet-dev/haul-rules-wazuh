<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1128 — Event Log Clearing (thegentlemen) | Status: stable | Sigma ID: 7d7aba35-a9cd-5a16-beeb-f9de565a4bb7 -->
  <rule id="751418" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1128 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>