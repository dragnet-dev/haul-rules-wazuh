<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2422 — Recovery Inhibition (threeam) | Status: stable | Sigma ID: 74d0f9c3-39c5-540d-8cb4-ce171ad042f6 -->
  <rule id="215359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2422 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>