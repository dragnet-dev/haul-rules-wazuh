<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0973 — Recovery Inhibition (qilin) | Status: test | Sigma ID: f983e358-7735-5f84-92d8-5d540a5db900 -->
  <rule id="857423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0973 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
