<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1300 — Event Log Clearing (AiLock) | Status: deprecated | Sigma ID: fe620e1a-29f3-567f-9de4-5b59f3eda1c7 -->
  <rule id="573934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1300 — Event Log Clearing (AiLock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>