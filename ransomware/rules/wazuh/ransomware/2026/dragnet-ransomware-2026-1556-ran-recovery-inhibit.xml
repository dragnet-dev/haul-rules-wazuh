<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1556 — Recovery Inhibition (insomnia) | Status: stable | Sigma ID: 66b60e7a-4fb9-5d98-82cd-8988b7a16918 -->
  <rule id="908174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1556 — Recovery Inhibition (insomnia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>