<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2954 — Recovery Inhibition (sinobi) | Status: stable | Sigma ID: bac0f017-1f4d-560c-bc9c-de9891a1618d -->
  <rule id="380950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2954 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
