<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2225 — Event Log Clearing (payload) | Status: test | Sigma ID: 844562d4-4c44-5393-b871-ba4c79e589d0 -->
  <rule id="113005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2225 — Event Log Clearing (payload)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>