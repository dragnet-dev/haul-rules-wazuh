<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1423 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: fa34505a-b66b-556a-9821-4d3fd4a41ee5 -->
  <rule id="803450" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1423 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>