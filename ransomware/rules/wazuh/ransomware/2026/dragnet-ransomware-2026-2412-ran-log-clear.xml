<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2412 — Event Log Clearing (qilin) | Status: stable | Sigma ID: 24db05e5-ce12-5dc7-aa1b-ca7f18ed5bf0 -->
  <rule id="380894" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2412 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>