<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0384 — Recovery Inhibition (bravox) | Status: test | Sigma ID: a2c7adbd-c6bc-560b-b082-ce6e52c7cfc8 -->
  <rule id="710605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0384 — Recovery Inhibition (bravox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>