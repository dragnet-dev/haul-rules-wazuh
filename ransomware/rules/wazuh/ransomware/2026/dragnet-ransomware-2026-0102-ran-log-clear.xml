<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0102 — Event Log Clearing (morpheus) | Status: deprecated | Sigma ID: c57f6c2c-8f77-563f-9757-87d060220c25 -->
  <rule id="620428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0102 — Event Log Clearing (morpheus)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>