<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2252 — Recovery Inhibition (bravox) | Status: stable | Sigma ID: 2de51a4b-dbdb-5d2d-b3cd-995a2d802767 -->
  <rule id="375226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2252 — Recovery Inhibition (bravox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>