<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2070 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 6198b9da-bd95-5c2f-a67c-aa90c3599a29 -->
  <rule id="668797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2070 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>