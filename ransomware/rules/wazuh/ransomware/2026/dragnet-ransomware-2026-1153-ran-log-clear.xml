<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1153 — Event Log Clearing (thegentlemen) | Status: stable | Sigma ID: a89d6575-71a8-5be6-9dfb-a79ca58dbaa3 -->
  <rule id="943765" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1153 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>