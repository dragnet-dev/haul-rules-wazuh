<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2693 — Recovery Inhibition (fulcrumsec) | Status: stable | Sigma ID: c464c78b-8778-5ab5-9186-b599708afcbb -->
  <rule id="294367" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2693 — Recovery Inhibition (fulcrumsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>