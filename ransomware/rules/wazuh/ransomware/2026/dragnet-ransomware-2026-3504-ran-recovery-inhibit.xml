<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3504 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: f70b2aa4-81e2-5ef2-98e6-54dddd2dc380 -->
  <rule id="521002" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3504 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>