<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0343 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 17f941c8-a5c1-54e5-800a-f68ddf8b166b -->
  <rule id="207068" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0343 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>