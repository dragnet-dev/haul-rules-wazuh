<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3178 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 37465af1-6418-5f74-81f3-570cb65ec917 -->
  <rule id="691215" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3178 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>