<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3309 — Event Log Clearing (lynx) | Status: stable | Sigma ID: 1a37ee8e-8b7b-5823-9d72-d6a07a4e9ff4 -->
  <rule id="553108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3309 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>