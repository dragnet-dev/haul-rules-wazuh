<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3362 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 7afcb5bd-46d3-5e10-aeca-a8f9393ba47f -->
  <rule id="637555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3362 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>