<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2136 — Event Log Clearing (worldleaks) | Status: test | Sigma ID: 6f1eb2b5-1f63-5e89-8a0e-4327a0cc4e82 -->
  <rule id="246512" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2136 — Event Log Clearing (worldleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>