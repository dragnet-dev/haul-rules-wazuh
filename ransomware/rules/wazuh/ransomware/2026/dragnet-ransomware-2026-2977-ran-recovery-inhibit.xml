<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2977 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 64c01c90-8ed4-53b6-893a-86ab8b2bf5ef -->
  <rule id="857628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2977 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>