<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3552 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: cbc858b4-6f66-5460-a28b-c24dec99349d -->
  <rule id="660858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3552 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>