<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0227 — Event Log Clearing (aurora) | Status: stable | Sigma ID: 75691303-38e7-57c7-aa79-ac6a01dc4bfc -->
  <rule id="469130" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0227 — Event Log Clearing (aurora)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>