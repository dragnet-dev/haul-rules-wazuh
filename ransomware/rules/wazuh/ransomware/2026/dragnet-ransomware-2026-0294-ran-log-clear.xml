<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0294 — Event Log Clearing (mnt6) | Status: stable | Sigma ID: 6beb4351-2eba-5ede-baa1-d72ba22b20c0 -->
  <rule id="162743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0294 — Event Log Clearing (mnt6)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>