<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1967 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 46b0b26a-1381-51b6-bba0-21906653d9af -->
  <rule id="395312" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1967 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
