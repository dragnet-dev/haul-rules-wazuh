<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1376 — Recovery Inhibition (AiLock) | Status: deprecated | Sigma ID: 2b209ecf-23ee-59e1-896f-b018ff910029 -->
  <rule id="361740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1376 — Recovery Inhibition (AiLock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
