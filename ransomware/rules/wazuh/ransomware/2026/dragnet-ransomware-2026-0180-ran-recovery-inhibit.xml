<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0180 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 06d43200-9672-5ffa-b9ec-01cac9f42dd2 -->
  <rule id="294320" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0180 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>