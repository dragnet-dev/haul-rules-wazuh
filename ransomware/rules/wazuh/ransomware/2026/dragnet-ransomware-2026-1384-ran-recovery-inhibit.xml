<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1384 — Recovery Inhibition (everest) | Status: test | Sigma ID: 4d5ef463-00f5-537c-9fdb-a815a6641f74 -->
  <rule id="286394" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1384 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>