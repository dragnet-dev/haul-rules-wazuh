<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2219 — Recovery Inhibition (lynx) | Status: stable | Sigma ID: 4dc1a329-9c9f-5b92-823c-24ea212953e5 -->
  <rule id="290663" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2219 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>