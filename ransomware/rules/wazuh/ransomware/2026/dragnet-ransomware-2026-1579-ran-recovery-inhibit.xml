<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1579 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: c8f0b4ce-4f2c-53fe-9940-b281e417ded7 -->
  <rule id="700914" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1579 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>