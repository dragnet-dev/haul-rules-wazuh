<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3262 — Event Log Clearing (anubis) | Status: stable | Sigma ID: 02c51547-0d61-547d-9c5f-3a7bd590e5f2 -->
  <rule id="951547" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3262 — Event Log Clearing (anubis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>