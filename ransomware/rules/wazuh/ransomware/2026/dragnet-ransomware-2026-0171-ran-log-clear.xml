<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0171 — Event Log Clearing (incransom) | Status: test | Sigma ID: 6ace9068-0bf3-590f-a7ca-e3cf8bfdd7d9 -->
  <rule id="134290" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0171 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>