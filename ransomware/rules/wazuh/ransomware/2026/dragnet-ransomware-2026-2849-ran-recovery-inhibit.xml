<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2849 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: af9c1668-59b7-5579-b035-8349aff4bd5e -->
  <rule id="215616" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2849 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>