<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0713 — Recovery Inhibition (pear) | Status: stable | Sigma ID: 4d7a02e5-f8ad-5267-af9e-8333aec6536f -->
  <rule id="444202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0713 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>