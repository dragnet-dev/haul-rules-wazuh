<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0977 — Recovery Inhibition (gunra) | Status: stable | Sigma ID: 0a41680b-a0a3-586a-84b9-4b6cd26a3ac9 -->
  <rule id="241680" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0977 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>