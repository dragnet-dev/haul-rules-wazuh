<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2995 — Recovery Inhibition (clop) | Status: test | Sigma ID: 0acee125-8e0a-5f8e-af04-c57fa02f34ad -->
  <rule id="927012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2995 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
