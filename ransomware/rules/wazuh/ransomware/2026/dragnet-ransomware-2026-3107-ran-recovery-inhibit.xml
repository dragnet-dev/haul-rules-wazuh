<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3107 — Recovery Inhibition (payload) | Status: stable | Sigma ID: 61861c39-3852-5513-9a32-d50847275bb7 -->
  <rule id="997883" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3107 — Recovery Inhibition (payload)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>