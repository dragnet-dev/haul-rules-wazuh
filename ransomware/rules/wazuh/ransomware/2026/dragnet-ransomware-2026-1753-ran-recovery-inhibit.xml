<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1753 — Recovery Inhibition (AiLock) | Status: deprecated | Sigma ID: addd32fb-5b36-5c01-b766-6a7706f404ce -->
  <rule id="950932" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1753 — Recovery Inhibition (AiLock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
