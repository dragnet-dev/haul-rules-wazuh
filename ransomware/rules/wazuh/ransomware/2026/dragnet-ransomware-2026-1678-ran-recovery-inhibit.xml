<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1678 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 76ac9d83-a581-595d-9a73-d4fc8b33ea07 -->
  <rule id="540637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1678 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>