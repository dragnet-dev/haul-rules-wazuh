<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3449 — Recovery Inhibition (payload) | Status: stable | Sigma ID: 461397ce-c4d8-5c98-b26f-872e0ba2b331 -->
  <rule id="282364" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3449 — Recovery Inhibition (payload)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>