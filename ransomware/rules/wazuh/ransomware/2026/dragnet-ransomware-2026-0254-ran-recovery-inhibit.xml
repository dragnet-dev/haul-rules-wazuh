<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0254 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: b2e20d6b-58d1-5171-beff-dfd2d983a70b -->
  <rule id="289933" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0254 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>