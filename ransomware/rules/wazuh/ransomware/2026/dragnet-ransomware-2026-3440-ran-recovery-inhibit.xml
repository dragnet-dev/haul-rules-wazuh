<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3440 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: e7fdadb4-5225-5b86-bd3e-05457f2a8ee5 -->
  <rule id="798733" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3440 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>