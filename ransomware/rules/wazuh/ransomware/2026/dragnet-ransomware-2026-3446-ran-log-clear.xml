<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3446 — Event Log Clearing (coinbasecartel) | Status: stable | Sigma ID: e555497c-4eb8-5b9d-b3d4-ecd6f22e8e02 -->
  <rule id="655549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3446 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>