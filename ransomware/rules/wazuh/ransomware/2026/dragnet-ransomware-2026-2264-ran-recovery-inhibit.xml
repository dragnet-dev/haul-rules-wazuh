<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2264 — Recovery Inhibition (gunra) | Status: stable | Sigma ID: ab85ea1d-ecff-51da-96bd-b1be08fe315e -->
  <rule id="899594" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2264 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>