<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0681 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: f5fcc24e-ba94-5d62-b37e-775e663e1138 -->
  <rule id="189242" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0681 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>