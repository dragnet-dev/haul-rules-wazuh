<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2306 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: 2cf0611f-6bad-5653-87a2-3d1adba979f1 -->
  <rule id="990611" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2306 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>