<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1667 — Recovery Inhibition (gunra) | Status: stable | Sigma ID: a326f80f-cdef-5ffe-93e8-a2d689d480bb -->
  <rule id="852318" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1667 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>