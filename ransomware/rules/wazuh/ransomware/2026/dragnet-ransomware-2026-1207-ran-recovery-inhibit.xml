<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1207 — Recovery Inhibition (nova) | Status: stable | Sigma ID: c344d018-593a-5d49-8711-5dc16f559df4 -->
  <rule id="275170" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1207 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>