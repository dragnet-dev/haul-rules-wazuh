<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0408 — Recovery Inhibition (play) | Status: stable | Sigma ID: 34f4ed2e-ab3c-5fd5-9446-fd064de74edf -->
  <rule id="632301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0408 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>