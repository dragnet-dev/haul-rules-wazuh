<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2868 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: b2f36312-6c5b-58f8-a1a4-ae602fb4102e -->
  <rule id="107363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2868 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>