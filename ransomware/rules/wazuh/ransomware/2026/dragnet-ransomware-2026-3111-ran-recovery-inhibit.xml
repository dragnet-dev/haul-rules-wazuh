<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3111 — Recovery Inhibition (killsec) | Status: deprecated | Sigma ID: 918527ef-4d11-5f06-bbd2-f7874d97e825 -->
  <rule id="396446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3111 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>