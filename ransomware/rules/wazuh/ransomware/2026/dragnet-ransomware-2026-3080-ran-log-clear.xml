<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3080 — Event Log Clearing (crypto24) | Status: deprecated | Sigma ID: 5f8580d2-4ac8-5050-9919-c96046f46d55 -->
  <rule id="137293" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3080 — Event Log Clearing (crypto24)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>