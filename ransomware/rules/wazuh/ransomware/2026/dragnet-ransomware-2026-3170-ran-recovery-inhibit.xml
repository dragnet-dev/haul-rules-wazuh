<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3170 — Recovery Inhibition (interlock) | Status: stable | Sigma ID: 4fa78a2e-861b-5ace-ac66-02ca4ad1ec67 -->
  <rule id="339658" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3170 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>