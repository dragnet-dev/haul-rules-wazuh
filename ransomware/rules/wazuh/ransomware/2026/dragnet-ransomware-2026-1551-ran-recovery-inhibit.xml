<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1551 — Recovery Inhibition (safepay) | Status: stable | Sigma ID: f647f3e4-0c12-59dd-ad08-2446fa058f80 -->
  <rule id="803673" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1551 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>