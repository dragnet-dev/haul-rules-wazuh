<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3343 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 24808770-f349-5a3c-a845-cb404455a4a3 -->
  <rule id="780877" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3343 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
