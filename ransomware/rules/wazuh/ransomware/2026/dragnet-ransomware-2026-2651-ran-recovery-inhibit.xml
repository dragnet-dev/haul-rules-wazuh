<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2651 — Recovery Inhibition (m3rx) | Status: stable | Sigma ID: 02716009-2ad3-5569-b535-894915475ca0 -->
  <rule id="116009" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2651 — Recovery Inhibition (m3rx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>