<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1935 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 0d07482a-20f0-5264-b466-8bebdbcbfe06 -->
  <rule id="507482" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1935 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
