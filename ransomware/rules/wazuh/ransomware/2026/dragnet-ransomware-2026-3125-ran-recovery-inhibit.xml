<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3125 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: bf7df137-9afc-5c8c-b0ec-c6f1da1f71b2 -->
  <rule id="509751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3125 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>