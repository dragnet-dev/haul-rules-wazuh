<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1625 — Recovery Inhibition (everest) | Status: stable | Sigma ID: 5cc9ecb6-5dfc-5a4e-b9e0-401a12ac00c7 -->
  <rule id="301580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1625 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>