<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0457 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 4bfeff2b-ebbf-58cb-bc83-3c72e9b458b7 -->
  <rule id="580479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0457 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>