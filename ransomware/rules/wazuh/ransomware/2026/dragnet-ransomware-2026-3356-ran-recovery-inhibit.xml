<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3356 — Recovery Inhibition (fulcrumsec) | Status: stable | Sigma ID: c07ec434-15e0-5e6f-a20d-8ea47938331f -->
  <rule id="492284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3356 — Recovery Inhibition (fulcrumsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>