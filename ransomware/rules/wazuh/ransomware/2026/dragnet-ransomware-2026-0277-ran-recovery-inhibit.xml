<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0277 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: d4c435c0-cb84-5ad3-a437-829d4ff25dc7 -->
  <rule id="456435" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0277 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>