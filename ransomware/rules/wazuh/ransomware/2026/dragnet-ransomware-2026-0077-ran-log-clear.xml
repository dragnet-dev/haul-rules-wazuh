<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0077 — Event Log Clearing (genesis) | Status: test | Sigma ID: 3be22e9d-b918-5190-81e5-bebeebfa2831 -->
  <rule id="733166" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0077 — Event Log Clearing (genesis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>