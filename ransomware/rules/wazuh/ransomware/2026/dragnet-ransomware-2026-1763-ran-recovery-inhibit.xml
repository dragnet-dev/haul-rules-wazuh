<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1763 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: c0edd415-b06a-56c5-9699-7ad88950c18a -->
  <rule id="553254" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1763 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>