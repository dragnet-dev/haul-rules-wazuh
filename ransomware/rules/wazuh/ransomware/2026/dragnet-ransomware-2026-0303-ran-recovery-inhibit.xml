<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0303 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 02b6c3cc-77dd-50b6-b8f9-76c6d32ac5a3 -->
  <rule id="318140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0303 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>