<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2874 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 07c511a2-f965-546f-ab16-c65bc96f8c88 -->
  <rule id="292186" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2874 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>