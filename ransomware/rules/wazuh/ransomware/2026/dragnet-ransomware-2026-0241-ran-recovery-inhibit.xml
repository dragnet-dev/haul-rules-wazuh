<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0241 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 98a41f87-101b-5e02-89ee-9284ceefcd5d -->
  <rule id="825471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0241 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>