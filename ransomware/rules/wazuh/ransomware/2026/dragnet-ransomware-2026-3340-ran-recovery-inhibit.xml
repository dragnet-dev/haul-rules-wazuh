<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3340 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: ff0e5d3d-5b47-580a-a4c7-78cfa162149a -->
  <rule id="330333" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3340 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>