<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2828 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 695f4980-2901-593a-80d7-340114211a5c -->
  <rule id="313549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2828 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>