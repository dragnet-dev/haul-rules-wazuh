<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2800 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: dd90c0f1-c722-5e31-b544-aa08ae6ac98f -->
  <rule id="950520" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2800 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>