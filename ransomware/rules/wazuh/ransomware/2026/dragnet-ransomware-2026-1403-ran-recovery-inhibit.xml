<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1403 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 681f9c83-9c7f-5436-8c2a-c07b76225912 -->
  <rule id="945916" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1403 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>