<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3548 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: cc9eb5a6-4535-5be4-a8ee-f6b1a542a0f1 -->
  <rule id="847795" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3548 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>