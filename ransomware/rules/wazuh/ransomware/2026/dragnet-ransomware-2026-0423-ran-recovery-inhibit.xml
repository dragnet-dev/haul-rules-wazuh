<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0423 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: e2f84ac7-42a2-5634-850d-7a9cdc0a6536 -->
  <rule id="160554" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0423 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>