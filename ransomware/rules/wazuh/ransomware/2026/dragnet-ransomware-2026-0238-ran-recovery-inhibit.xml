<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0238 — Recovery Inhibition (insomnia) | Status: stable | Sigma ID: 96430597-8935-5a10-aaa5-f600c1835420 -->
  <rule id="743059" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0238 — Recovery Inhibition (insomnia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>