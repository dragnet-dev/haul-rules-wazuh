<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1163 — Recovery Inhibition (thegentlemen) | Status: stable | Sigma ID: 8a442e5a-647e-5545-bdcc-c73285212a25 -->
  <rule id="515086" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1163 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>