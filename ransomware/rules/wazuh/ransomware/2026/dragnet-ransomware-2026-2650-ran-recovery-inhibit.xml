<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2650 — Recovery Inhibition (m3rx) | Status: stable | Sigma ID: 65cd4f32-0a1a-5411-8ec7-634483f480fd -->
  <rule id="995279" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2650 — Recovery Inhibition (m3rx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>