<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2168 — Recovery Inhibition (play) | Status: stable | Sigma ID: b84faf12-21c5-5994-a73c-3be89c23939d -->
  <rule id="453679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2168 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>