<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2864 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: f8ad7caa-3996-56f1-a006-304944b87f3f -->
  <rule id="299484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2864 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>