<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2831 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: 1263ee64-a616-54b3-9e5d-80cf2a7dc773 -->
  <rule id="635666" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2831 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>