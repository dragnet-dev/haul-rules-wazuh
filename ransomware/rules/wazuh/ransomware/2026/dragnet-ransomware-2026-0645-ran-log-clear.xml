<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0645 — Event Log Clearing (dragonforce) | Status: test | Sigma ID: 27285152-587d-5bed-b160-449a864f112c -->
  <rule id="128515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0645 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>