<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2296 — Recovery Inhibition (medusalocker) | Status: stable | Sigma ID: 456552a4-abf5-5c35-b1ff-27dbaef05aa1 -->
  <rule id="204842" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2296 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>