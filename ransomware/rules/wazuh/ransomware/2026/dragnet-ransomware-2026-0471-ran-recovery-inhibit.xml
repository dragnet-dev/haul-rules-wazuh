<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0471 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 6b3f395b-3add-5d32-8eb3-f372bf533cbc -->
  <rule id="918339" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0471 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>