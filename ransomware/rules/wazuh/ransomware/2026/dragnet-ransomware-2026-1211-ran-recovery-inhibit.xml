<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1211 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 7cda1ee5-7a40-5218-9029-b1dc7ca5fc34 -->
  <rule id="713950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1211 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>