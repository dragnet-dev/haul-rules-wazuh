<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1168 — Recovery Inhibition (thegentlemen) | Status: stable | Sigma ID: ebe404d3-b003-5b64-9826-e53e7c50f884 -->
  <rule id="274404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1168 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>