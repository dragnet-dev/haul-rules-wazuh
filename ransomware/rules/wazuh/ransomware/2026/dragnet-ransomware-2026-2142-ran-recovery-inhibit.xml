<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2142 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 099b7f2c-19a8-5a38-917d-d07d3328c9fc -->
  <rule id="853272" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2142 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>