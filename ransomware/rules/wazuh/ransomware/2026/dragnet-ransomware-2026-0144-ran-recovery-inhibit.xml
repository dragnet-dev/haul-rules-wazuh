<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0144 — Recovery Inhibition (incransom) | Status: test | Sigma ID: 7857054d-21f3-56e8-84f3-36a724a43978 -->
  <rule id="757054" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0144 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>