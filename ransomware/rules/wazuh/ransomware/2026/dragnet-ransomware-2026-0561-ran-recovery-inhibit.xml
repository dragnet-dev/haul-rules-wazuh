<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0561 — Recovery Inhibition (pear) | Status: stable | Sigma ID: c6d72b98-d6e7-581a-a501-eb341bdd36d7 -->
  <rule id="647563" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0561 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>