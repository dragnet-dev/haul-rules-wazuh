<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0565 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: db3137e6-d6c5-59f8-b144-3cf41c07d4ce -->
  <rule id="493137" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0565 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>