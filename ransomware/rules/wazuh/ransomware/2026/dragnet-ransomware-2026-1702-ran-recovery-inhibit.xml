<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1702 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 958ad91e-04b3-5f91-b5df-9a41fa49b25b -->
  <rule id="754219" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1702 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>