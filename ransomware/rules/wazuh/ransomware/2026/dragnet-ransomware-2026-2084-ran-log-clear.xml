<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2084 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 4f9e11ab-6003-5f46-9c93-1ef92a14af33 -->
  <rule id="479811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2084 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>