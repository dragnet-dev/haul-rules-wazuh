<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3076 — Event Log Clearing (lapsus$) | Status: deprecated | Sigma ID: 59ef282d-2b4f-5071-9fdc-7b37693f6a00 -->
  <rule id="734328" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3076 — Event Log Clearing (lapsus$)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>