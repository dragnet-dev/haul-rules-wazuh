<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3163 — Event Log Clearing (vect) | Status: deprecated | Sigma ID: 068a0fa8-a404-5de4-82b6-32d367c1a76b -->
  <rule id="211130" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3163 — Event Log Clearing (vect)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>