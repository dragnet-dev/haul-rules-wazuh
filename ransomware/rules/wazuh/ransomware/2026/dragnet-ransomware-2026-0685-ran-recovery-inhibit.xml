<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0685 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: e5c11f91-31be-5eb3-9019-93fb699b3898 -->
  <rule id="231391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0685 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>