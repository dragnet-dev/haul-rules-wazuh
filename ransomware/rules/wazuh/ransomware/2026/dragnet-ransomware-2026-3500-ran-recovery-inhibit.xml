<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3500 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 4999242d-4a96-5ba4-bdd2-4b463ec0167d -->
  <rule id="599242" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3500 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>