<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0016 — Recovery Inhibition (coinbasecartel) | Status: stable | Sigma ID: df88679d-8dd7-5ce3-862b-2acdd113b3f8 -->
  <rule id="538867" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0016 — Recovery Inhibition (coinbasecartel)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>