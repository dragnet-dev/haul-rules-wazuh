<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0829 — Recovery Inhibition (interlock) | Status: test | Sigma ID: 1e967cab-3671-5dda-847a-0493b7ca61e8 -->
  <rule id="827754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0829 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>