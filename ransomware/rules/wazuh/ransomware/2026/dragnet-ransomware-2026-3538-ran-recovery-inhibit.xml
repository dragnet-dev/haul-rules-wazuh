<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3538 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: b54f0d24-bfeb-5220-8e32-4fa99683ebba -->
  <rule id="356653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3538 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>