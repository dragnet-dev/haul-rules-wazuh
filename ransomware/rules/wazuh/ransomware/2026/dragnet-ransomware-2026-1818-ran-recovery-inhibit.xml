<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1818 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 79f44a3b-3fd5-55dc-b951-9025160d8658 -->
  <rule id="347114" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1818 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>