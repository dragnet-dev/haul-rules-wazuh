<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2587 — Recovery Inhibition (interlock) | Status: stable | Sigma ID: 9b228914-dd53-59b3-b41f-20322e8aeff9 -->
  <rule id="752289" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2587 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>