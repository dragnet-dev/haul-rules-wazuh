<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2675 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 1dae733e-91ef-51b2-b769-ffa794dbb771 -->
  <rule id="498733" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2675 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>