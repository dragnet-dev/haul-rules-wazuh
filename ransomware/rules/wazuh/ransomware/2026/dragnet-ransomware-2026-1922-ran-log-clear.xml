<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1922 — Event Log Clearing (cipherforce) | Status: stable | Sigma ID: 1cf04bf5-94b6-5bb6-a3ff-2eef02b1b15f -->
  <rule id="254015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1922 — Event Log Clearing (cipherforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>