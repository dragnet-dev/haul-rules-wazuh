<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2503 — Event Log Clearing (secpo) | Status: stable | Sigma ID: 859ab2f5-c8e7-51a2-bc0b-9f260b57555d -->
  <rule id="500752" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2503 — Event Log Clearing (secpo)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>