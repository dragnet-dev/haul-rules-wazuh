<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2393 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 4f4b410f-527d-5bbc-bb4a-62e72d9d58da -->
  <rule id="471541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2393 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>