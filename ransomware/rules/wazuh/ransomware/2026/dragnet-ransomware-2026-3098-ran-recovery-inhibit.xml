<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3098 — Recovery Inhibition (securotrop) | Status: stable | Sigma ID: 55eaea49-7e66-5f28-a57c-9517949bdeab -->
  <rule id="164618" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3098 — Recovery Inhibition (securotrop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>