<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1621 — Recovery Inhibition (embargo) | Status: stable | Sigma ID: 662b2581-e2fd-5ad1-a99d-1b63ce3cd410 -->
  <rule id="260325" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1621 — Recovery Inhibition (embargo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
