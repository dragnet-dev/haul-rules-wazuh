<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0575 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: 01ad3306-f1d7-5b61-b83b-32203a139ee2 -->
  <rule id="793306" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0575 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>