<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2362 — Recovery Inhibition (lynx) | Status: test | Sigma ID: ae30e5bf-b764-5842-86c9-c794207b072b -->
  <rule id="188945" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2362 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>