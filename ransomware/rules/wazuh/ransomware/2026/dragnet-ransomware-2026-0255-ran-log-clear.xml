<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0255 — Event Log Clearing (crypto24) | Status: deprecated | Sigma ID: 38fd2f02-2688-5116-b52e-b8f4d6e65a0f -->
  <rule id="797007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0255 — Event Log Clearing (crypto24)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>