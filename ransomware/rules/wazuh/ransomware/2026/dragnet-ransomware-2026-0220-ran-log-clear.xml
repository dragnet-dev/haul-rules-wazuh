<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0220 — Event Log Clearing (dragonforce) | Status: stable | Sigma ID: cfe1863b-a528-56cb-8ba6-0010bcc0a9d7 -->
  <rule id="726186" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0220 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>