<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3282 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: 765711da-66b8-521e-8dc8-799212a22646 -->
  <rule id="651389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3282 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>