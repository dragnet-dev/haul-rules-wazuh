<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0961 — Event Log Clearing (bravox) | Status: stable | Sigma ID: b935d8f7-f87d-5341-8e99-5e48a4fef779 -->
  <rule id="209738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0961 — Event Log Clearing (bravox)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>