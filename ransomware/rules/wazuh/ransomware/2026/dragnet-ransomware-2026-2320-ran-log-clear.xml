<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2320 — Event Log Clearing (m3rx) | Status: stable | Sigma ID: e728ae09-5a70-5f2a-a7fa-46af6917cdfc -->
  <rule id="270542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2320 — Event Log Clearing (m3rx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>