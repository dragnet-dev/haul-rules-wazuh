<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1474 — Recovery Inhibition (payload) | Status: stable | Sigma ID: ebad91f4-9ac5-5fa9-9a4d-fe7dc68b6b11 -->
  <rule id="733391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1474 — Recovery Inhibition (payload)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>