<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1715 — Event Log Clearing (qilin) | Status: test | Sigma ID: db700d72-45cb-5af9-a0a4-31f8429a30d0 -->
  <rule id="915213" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1715 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>