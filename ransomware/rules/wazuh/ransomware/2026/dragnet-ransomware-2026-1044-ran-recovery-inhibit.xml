<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1044 — Recovery Inhibition (thegentlemen) | Status: stable | Sigma ID: b6e23687-af7d-569e-a274-fb78459dd088 -->
  <rule id="170236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1044 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>