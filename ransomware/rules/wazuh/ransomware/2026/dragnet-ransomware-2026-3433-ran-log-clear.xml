<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3433 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: a837ea6e-ed45-5a00-a2af-5744d58c674b -->
  <rule id="174506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3433 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>