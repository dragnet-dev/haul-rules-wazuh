<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0940 — Recovery Inhibition (play) | Status: stable | Sigma ID: e53b59fb-3447-5818-ae2b-e330b35c093a -->
  <rule id="625959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0940 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>