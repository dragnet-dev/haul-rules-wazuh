<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2734 — Recovery Inhibition (lynx) | Status: stable | Sigma ID: 8947550b-b178-56c0-a5ed-a92d67ff1185 -->
  <rule id="947550" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2734 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>