<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0105 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 37ccd276-2cdb-50b5-a637-2c05a8cee78f -->
  <rule id="748292" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0105 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>