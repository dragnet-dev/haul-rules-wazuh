<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0459 — Recovery Inhibition (titan) | Status: stable | Sigma ID: 8450ccc3-bef8-5ce6-a7db-4a9e8a415f5b -->
  <rule id="463404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0459 — Recovery Inhibition (titan)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>