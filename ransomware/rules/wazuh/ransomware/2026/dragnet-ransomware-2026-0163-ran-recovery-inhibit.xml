<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0163 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: c3737f54-92d4-5112-9d8b-5b7d49065652 -->
  <rule id="279807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0163 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>