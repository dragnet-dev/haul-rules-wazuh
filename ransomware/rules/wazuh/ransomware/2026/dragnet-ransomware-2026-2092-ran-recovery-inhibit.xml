<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2092 — Recovery Inhibition (everest) | Status: stable | Sigma ID: 968d2c6c-89ce-5385-bc3c-2e6ec899c2dc -->
  <rule id="780204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2092 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>