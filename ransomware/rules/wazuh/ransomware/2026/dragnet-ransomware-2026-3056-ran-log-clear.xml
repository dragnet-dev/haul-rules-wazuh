<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3056 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: 39beabc9-26c1-505a-8fd5-bca4e67ecf05 -->
  <rule id="904715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3056 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>