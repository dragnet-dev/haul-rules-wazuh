<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2712 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: b13aa479-58aa-5646-b6b5-172a9a70f422 -->
  <rule id="250984" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2712 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>