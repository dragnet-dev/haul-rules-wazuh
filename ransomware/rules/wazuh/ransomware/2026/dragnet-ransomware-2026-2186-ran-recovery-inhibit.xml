<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2186 — Recovery Inhibition (pear) | Status: stable | Sigma ID: b21f1f1b-4a23-5eda-b2f3-c72296a0927c -->
  <rule id="272191" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2186 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>