<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1560 — Recovery Inhibition (nova) | Status: stable | Sigma ID: 84098ee2-63c5-510d-b71b-d18946456031 -->
  <rule id="545582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1560 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>