<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3455 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 547e2e2e-6d72-5e0f-bdae-396e47456c41 -->
  <rule id="602606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3455 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>