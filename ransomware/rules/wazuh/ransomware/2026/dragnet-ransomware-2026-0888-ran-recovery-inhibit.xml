<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0888 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 9f4b6eec-348d-5c02-9056-4b4398dd5c1a -->
  <rule id="582510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0888 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>