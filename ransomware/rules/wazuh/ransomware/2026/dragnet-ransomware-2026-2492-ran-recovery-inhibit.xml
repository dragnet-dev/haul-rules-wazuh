<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2492 — Recovery Inhibition (everest) | Status: stable | Sigma ID: e86ea66e-0b81-5de9-8a1d-96b350077693 -->
  <rule id="306506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2492 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>