<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0404 — Event Log Clearing (blackshrantac) | Status: test | Sigma ID: 05b03130-f919-50a3-9b70-96e1d5bcde1e -->
  <rule id="203130" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0404 — Event Log Clearing (blackshrantac)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>