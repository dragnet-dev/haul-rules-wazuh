<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3184 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 82c1cde1-92c4-5e43-ab16-d5c7d6fd3a69 -->
  <rule id="789901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3184 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>