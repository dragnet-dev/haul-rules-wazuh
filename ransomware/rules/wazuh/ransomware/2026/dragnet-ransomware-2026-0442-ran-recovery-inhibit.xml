<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0442 — Recovery Inhibition (payload) | Status: stable | Sigma ID: e87004be-8080-5c94-8cfe-f3b0981ba54a -->
  <rule id="687004" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0442 — Recovery Inhibition (payload)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>