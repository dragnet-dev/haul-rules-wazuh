<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2848 — Event Log Clearing (genesis) | Status: stable | Sigma ID: aa4e2e97-8a1f-5c7f-9dc0-cae6f49a9054 -->
  <rule id="864526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2848 — Event Log Clearing (genesis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>