<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1932 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: 37bde3f6-7804-5328-8135-3e332fa7ccf9 -->
  <rule id="745903" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1932 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>