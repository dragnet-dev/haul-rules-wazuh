<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1363 — Recovery Inhibition (anubis) | Status: stable | Sigma ID: 1ebbe1ff-e971-583e-b5f8-17e4d242988e -->
  <rule id="458861" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1363 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>