<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3255 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 2c654893-94cf-5e0b-92c8-8ccda2a348a6 -->
  <rule id="965489" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3255 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>