<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2717 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: c5631651-4238-5673-a26a-e0d823d2edbc -->
  <rule id="456316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2717 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>