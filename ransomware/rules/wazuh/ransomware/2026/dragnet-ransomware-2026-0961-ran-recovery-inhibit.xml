<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0961 — Recovery Inhibition (bravox) | Status: stable | Sigma ID: d6a0abf4-95a2-56d6-984b-411bd0f1ec55 -->
  <rule id="296331" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0961 — Recovery Inhibition (bravox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>