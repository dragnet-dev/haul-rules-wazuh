<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2107 — Recovery Inhibition (interlock) | Status: test | Sigma ID: de4a2e7d-e9cf-5471-8833-877ac85c8ae4 -->
  <rule id="395086" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2107 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>