<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0676 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 92645e36-dcec-5df9-b728-60503daf7e0e -->
  <rule id="682334" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0676 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>