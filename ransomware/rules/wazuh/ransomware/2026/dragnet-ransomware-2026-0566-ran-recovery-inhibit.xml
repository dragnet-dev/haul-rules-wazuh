<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0566 — Recovery Inhibition (fulcrumsec) | Status: stable | Sigma ID: 6ec79c62-dedb-5cec-9a35-aa367b30f113 -->
  <rule id="236476" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0566 — Recovery Inhibition (fulcrumsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>