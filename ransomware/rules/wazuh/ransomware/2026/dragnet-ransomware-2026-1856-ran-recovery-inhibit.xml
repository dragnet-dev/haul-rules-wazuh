<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1856 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: d2f7132c-8221-5523-80e7-1a33f35f756e -->
  <rule id="427713" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1856 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>