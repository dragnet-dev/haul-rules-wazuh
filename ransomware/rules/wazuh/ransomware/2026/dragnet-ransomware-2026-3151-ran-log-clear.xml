<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3151 — Event Log Clearing (genesis) | Status: test | Sigma ID: 7e658a50-cc5b-5f08-9ef5-51766853c575 -->
  <rule id="326538" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3151 — Event Log Clearing (genesis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>