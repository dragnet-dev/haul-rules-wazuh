<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0473 — Recovery Inhibition (clop) | Status: test | Sigma ID: 61027d10-4020-5801-904e-2298b4e4e04a -->
  <rule id="864451" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0473 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>