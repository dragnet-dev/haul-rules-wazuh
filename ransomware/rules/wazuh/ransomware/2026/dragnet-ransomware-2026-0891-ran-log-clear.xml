<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0891 — Event Log Clearing (incransom) | Status: stable | Sigma ID: 7d1a2373-9b03-5ad6-8f2f-e8f0ff80da6d -->
  <rule id="302623" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0891 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>