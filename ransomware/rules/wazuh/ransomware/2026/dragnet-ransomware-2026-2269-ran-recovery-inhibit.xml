<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2269 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 3571d93a-352d-5996-b9b9-c354eca87152 -->
  <rule id="414993" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2269 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>