<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1082 — Event Log Clearing (thegentlemen) | Status: test | Sigma ID: ab0cdfd4-72c1-5f93-892f-ff1bf3a7c953 -->
  <rule id="807455" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1082 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>