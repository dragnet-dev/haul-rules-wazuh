<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1204 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 1ed9819d-1dfd-51e6-900c-4fac60f8b153 -->
  <rule id="539819" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1204 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>