<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1462 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 2b7d2908-2e41-5d35-b3d5-c1548dcf1c6d -->
  <rule id="805290" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1462 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>