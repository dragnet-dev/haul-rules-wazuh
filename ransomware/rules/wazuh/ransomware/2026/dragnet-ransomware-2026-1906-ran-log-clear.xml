<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1906 — Event Log Clearing (AuditTeam) | Status: stable | Sigma ID: 075a7c4e-47ae-5a6b-99f2-df43cfd8ef4c -->
  <rule id="237244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1906 — Event Log Clearing (AuditTeam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>