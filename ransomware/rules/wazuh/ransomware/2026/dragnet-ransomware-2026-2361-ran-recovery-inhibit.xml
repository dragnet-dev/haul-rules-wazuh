<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2361 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: be3fd687-1411-5bdd-a255-335a08fdfa27 -->
  <rule id="474216" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2361 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>