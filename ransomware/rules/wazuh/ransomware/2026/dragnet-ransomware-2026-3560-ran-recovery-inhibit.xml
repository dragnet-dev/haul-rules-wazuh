<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3560 — Recovery Inhibition (BrainCipher) | Status: stable | Sigma ID: a06ec407-6594-5128-9c33-88e1553cf387 -->
  <rule id="877724" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3560 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>