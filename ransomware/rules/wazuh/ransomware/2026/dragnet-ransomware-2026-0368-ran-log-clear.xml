<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0368 — Event Log Clearing (apt73) | Status: stable | Sigma ID: 481b77d7-fcc7-5ef2-ab4c-8af37d576b00 -->
  <rule id="732445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0368 — Event Log Clearing (apt73)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>