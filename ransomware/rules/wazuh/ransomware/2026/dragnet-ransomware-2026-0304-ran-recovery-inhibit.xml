<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0304 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 64bc3e21-7b18-53c3-90d6-50177ef58162 -->
  <rule id="951582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0304 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>