<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1187 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 88051785-f391-5b92-9df4-8dffa7ff2ad3 -->
  <rule id="805178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1187 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>