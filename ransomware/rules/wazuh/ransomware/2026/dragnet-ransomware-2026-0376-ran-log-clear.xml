<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0376 — Event Log Clearing (lamashtu) | Status: stable | Sigma ID: 1f9fffd8-300e-5af5-ad74-1b0918698dde -->
  <rule id="510719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0376 — Event Log Clearing (lamashtu)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>