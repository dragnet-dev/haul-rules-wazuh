<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2666 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 2b8f0cce-e3c0-5ca5-8f8f-8189bf852ec1 -->
  <rule id="323692" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2666 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>