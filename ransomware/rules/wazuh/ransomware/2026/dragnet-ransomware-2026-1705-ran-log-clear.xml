<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1705 — Event Log Clearing (lockbit5) | Status: stable | Sigma ID: cdf8f2d6-e1b5-5712-8b09-186e9dfc3340 -->
  <rule id="873432" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1705 — Event Log Clearing (lockbit5)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>