<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2653 — Recovery Inhibition (m3rx) | Status: stable | Sigma ID: 485fb717-59a9-5235-8481-c6f941f4fc0b -->
  <rule id="444117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2653 — Recovery Inhibition (m3rx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>