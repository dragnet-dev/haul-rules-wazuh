<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2663 — Event Log Clearing (payoutsking) | Status: deprecated | Sigma ID: 3c174bb9-fb89-5905-ba89-4d4f37788ae3 -->
  <rule id="204731" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2663 — Event Log Clearing (payoutsking)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>