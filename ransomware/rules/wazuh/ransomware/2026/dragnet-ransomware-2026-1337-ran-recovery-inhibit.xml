<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1337 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 6a616e61-75b3-5a17-a510-68d3ca56e6ba -->
  <rule id="905870" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1337 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>