<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1343 — Event Log Clearing (incransom) | Status: test | Sigma ID: 58f68ade-e5a4-5b54-9b22-83deb063465e -->
  <rule id="709898" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1343 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>