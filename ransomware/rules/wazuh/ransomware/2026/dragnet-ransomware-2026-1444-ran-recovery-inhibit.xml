<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1444 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 04722f08-aa12-511d-921a-f4f97580296a -->
  <rule id="456708" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1444 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>