<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3473 — Event Log Clearing (qilin) | Status: test | Sigma ID: b4ade3d2-c025-5693-8407-8fd17be332de -->
  <rule id="297263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3473 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>