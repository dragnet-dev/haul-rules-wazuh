<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0187 — Recovery Inhibition (play) | Status: stable | Sigma ID: 075e8ed4-7afc-5772-b8dd-22e4e27942f7 -->
  <rule id="510125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0187 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>