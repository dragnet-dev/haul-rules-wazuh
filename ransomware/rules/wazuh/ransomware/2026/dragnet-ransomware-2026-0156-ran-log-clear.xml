<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0156 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: 2aa14208-3c4f-508d-ac8d-7fd904d470b0 -->
  <rule id="621420" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0156 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>