<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3402 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 793cf1f6-edfc-5f62-a297-7be7fcb6c7e2 -->
  <rule id="332151" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3402 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>