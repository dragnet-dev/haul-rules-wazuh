<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2679 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 5651a46e-993f-5422-833a-b06d41e6f919 -->
  <rule id="142646" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2679 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>