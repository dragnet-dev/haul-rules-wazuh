<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3091 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: dfc7a96d-1d7e-5e8b-a3db-0eaffd991451 -->
  <rule id="429229" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3091 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>