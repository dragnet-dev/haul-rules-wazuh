<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0982 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 43576fce-a525-5b79-a891-8a70735df39c -->
  <rule id="455708" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0982 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>