<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2461 — Recovery Inhibition (devman) | Status: test | Sigma ID: 180ce7e3-ef7b-56aa-aec2-a9947bc84fe8 -->
  <rule id="305886" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2461 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>