<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2683 — Event Log Clearing (genesis) | Status: stable | Sigma ID: a0c0018f-5c8d-5fe9-af5a-1635e0c97f58 -->
  <rule id="812001" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2683 — Event Log Clearing (genesis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>