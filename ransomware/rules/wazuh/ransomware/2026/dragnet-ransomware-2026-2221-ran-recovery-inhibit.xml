<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2221 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 373ff81b-2509-51e1-919f-06bcc4e09c54 -->
  <rule id="674381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2221 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>