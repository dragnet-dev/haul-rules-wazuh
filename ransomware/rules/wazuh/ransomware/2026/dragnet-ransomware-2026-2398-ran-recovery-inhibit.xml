<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2398 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 67e3fbfe-6204-54fd-a3af-2726c7139bc2 -->
  <rule id="181179" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2398 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>