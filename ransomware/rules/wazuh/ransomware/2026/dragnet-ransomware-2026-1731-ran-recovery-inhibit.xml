<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1731 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: ba7f81a2-bcd1-53e6-9ab7-e4b2109bd857 -->
  <rule id="388781" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1731 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>