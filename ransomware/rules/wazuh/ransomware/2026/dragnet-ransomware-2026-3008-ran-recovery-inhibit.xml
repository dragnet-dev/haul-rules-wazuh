<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3008 — Recovery Inhibition (everest) | Status: test | Sigma ID: f0980760-8861-5ada-903c-15f24781c45c -->
  <rule id="709807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3008 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>