<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0366 — Recovery Inhibition (blackwater) | Status: stable | Sigma ID: 437d12f5-529d-50d6-81e3-0e9a767e29e6 -->
  <rule id="508207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0366 — Recovery Inhibition (blackwater)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>