<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1787 — Event Log Clearing (beast) | Status: test | Sigma ID: b425396f-9240-565e-8372-d8b4f3ad5b7b -->
  <rule id="342539" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1787 — Event Log Clearing (beast)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>