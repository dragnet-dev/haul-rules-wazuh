<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3388 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 23b6dd78-aeda-5e02-8191-6e408c37f17f -->
  <rule id="819977" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3388 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>