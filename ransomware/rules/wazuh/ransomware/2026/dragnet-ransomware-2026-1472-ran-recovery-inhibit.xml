<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1472 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 99f662d5-771b-525a-9f13-4fc35c74f3be -->
  <rule id="799662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1472 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>