<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2569 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: e4119e30-7cfa-5e80-a055-d2606b056b5d -->
  <rule id="605918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2569 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>