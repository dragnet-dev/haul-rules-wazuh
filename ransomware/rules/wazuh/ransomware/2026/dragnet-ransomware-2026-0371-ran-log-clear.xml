<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0371 — Event Log Clearing (dragonforce) | Status: stable | Sigma ID: 7f8a22ed-77b9-57d0-a0a5-80ae24b4bf08 -->
  <rule id="345822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0371 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>