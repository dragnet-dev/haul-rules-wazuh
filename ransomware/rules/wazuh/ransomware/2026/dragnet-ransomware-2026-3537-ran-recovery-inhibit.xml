<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3537 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 5a272dda-a738-59e0-854c-d1421302d9e1 -->
  <rule id="644365" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3537 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>