<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1231 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: ffdb5729-3a49-50cf-8b11-6391a7f62c68 -->
  <rule id="349957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1231 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>