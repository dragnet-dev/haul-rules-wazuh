<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2397 — Recovery Inhibition (interlock) | Status: stable | Sigma ID: 561faab9-ce41-5f0a-8ea3-0097b59d6b4e -->
  <rule id="601866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2397 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>