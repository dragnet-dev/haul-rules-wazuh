<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3472 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 038e9fcb-c24a-582d-872e-ae859f508a1f -->
  <rule id="794876" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3472 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>