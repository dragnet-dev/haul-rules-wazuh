<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0942 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: 9d7bd2d0-66be-56be-80b5-0da658761dd7 -->
  <rule id="539012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0942 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>