<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2763 — Recovery Inhibition (aurora) | Status: stable | Sigma ID: d900bb6c-b218-55cc-9ae4-db8ca129c972 -->
  <rule id="958587" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2763 — Recovery Inhibition (aurora)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>