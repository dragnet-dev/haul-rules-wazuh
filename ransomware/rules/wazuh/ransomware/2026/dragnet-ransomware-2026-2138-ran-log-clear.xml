<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2138 — Event Log Clearing (LeakBazaar) | Status: stable | Sigma ID: b13e0e0d-69e0-55e7-bea2-726cbdf7485b -->
  <rule id="251534" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2138 — Event Log Clearing (LeakBazaar)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>