<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0190 — Recovery Inhibition (everest) | Status: stable | Sigma ID: f14d334b-b428-5a58-a212-d13e8f2be877 -->
  <rule id="723733" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0190 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>