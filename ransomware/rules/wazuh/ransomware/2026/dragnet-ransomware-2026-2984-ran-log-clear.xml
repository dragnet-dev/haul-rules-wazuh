<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2984 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: f352bf69-ef46-52f6-bbf7-7d52b1bfce3e -->
  <rule id="430303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2984 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>