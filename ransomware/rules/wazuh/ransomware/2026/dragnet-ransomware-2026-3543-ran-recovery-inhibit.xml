<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3543 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 5a360c63-a642-57e1-aacd-7ad8113cd4ec -->
  <rule id="645772" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3543 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>