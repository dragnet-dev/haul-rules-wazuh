<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2348 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 53427bf9-f29e-5cf5-9c49-46d1e650dc11 -->
  <rule id="277503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2348 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
