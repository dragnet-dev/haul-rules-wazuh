<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3246 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: a53e7f8a-e84d-55f8-a6b3-262790f2fa73 -->
  <rule id="998047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3246 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>