<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0483 — Recovery Inhibition (medusalocker) | Status: stable | Sigma ID: 1ed75a37-c5a3-5ac5-a128-3aa697309f4b -->
  <rule id="800103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0483 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>