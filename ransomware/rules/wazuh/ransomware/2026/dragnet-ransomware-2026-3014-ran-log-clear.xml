<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3014 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: d95d3a52-016b-5c4f-9f25-ac9c620d6ca5 -->
  <rule id="973338" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3014 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>