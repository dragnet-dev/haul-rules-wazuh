<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1581 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 8386f9c0-7f78-5c78-8e5e-0f3d26af144d -->
  <rule id="541919" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1581 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>