<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2392 — Event Log Clearing (payload) | Status: stable | Sigma ID: 9175cbcf-2bd0-5cf2-8ea9-f75ad7ae3629 -->
  <rule id="649003" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2392 — Event Log Clearing (payload)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>