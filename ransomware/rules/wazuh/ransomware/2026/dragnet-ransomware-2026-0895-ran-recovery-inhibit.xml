<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0895 — Recovery Inhibition (everest) | Status: stable | Sigma ID: 1ee24072-b913-58f5-9401-1157396a0888 -->
  <rule id="542407" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0895 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>