<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0422 — Recovery Inhibition (beast) | Status: stable | Sigma ID: 96b5be1c-d6a7-5728-85ee-5386f15664a9 -->
  <rule id="461790" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0422 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>