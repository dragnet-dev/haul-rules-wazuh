<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0087 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 8a81004e-79f4-5a22-80da-318d02bf4b33 -->
  <rule id="588100" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0087 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>