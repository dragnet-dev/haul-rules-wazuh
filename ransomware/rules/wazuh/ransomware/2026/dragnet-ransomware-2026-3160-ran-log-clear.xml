<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3160 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 1d03e0d1-75fc-52c8-a620-31c6d55d2aeb -->
  <rule id="333933" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3160 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>