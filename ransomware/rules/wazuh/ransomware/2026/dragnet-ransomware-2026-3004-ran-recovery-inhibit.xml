<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3004 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 50254050-31e9-5a37-981d-93c41ad05298 -->
  <rule id="625405" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3004 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>