<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0621 — Recovery Inhibition (payload) | Status: stable | Sigma ID: 8f32d523-eb79-5630-bb66-e82a7ff95c82 -->
  <rule id="593255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0621 — Recovery Inhibition (payload)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>