<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0159 — Event Log Clearing (coinbasecartel) | Status: stable | Sigma ID: c2f0ae52-d95c-549e-a7ff-c94f687c72d3 -->
  <rule id="635694" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0159 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>