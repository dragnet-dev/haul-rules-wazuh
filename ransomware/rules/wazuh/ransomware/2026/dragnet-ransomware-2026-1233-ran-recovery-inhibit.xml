<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1233 — Recovery Inhibition (m3rx) | Status: stable | Sigma ID: 920bfb0f-3615-5d81-a8ea-d936dad442cd -->
  <rule id="271387" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1233 — Recovery Inhibition (m3rx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>