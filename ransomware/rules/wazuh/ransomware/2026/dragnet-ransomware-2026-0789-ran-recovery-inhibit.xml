<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0789 — Recovery Inhibition (safepay) | Status: stable | Sigma ID: 4e960a3a-b397-5805-a3ac-ce01c7df3048 -->
  <rule id="463370" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0789 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>