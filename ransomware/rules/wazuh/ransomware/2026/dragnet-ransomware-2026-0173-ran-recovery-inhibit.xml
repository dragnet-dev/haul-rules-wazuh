<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0173 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: 6648e565-157f-50c5-a509-0324c7bfd667 -->
  <rule id="263825" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0173 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
