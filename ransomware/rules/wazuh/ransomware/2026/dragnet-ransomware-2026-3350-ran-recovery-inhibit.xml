<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3350 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: a5e1f8d8-9498-57b5-bb00-8cb2c100ecae -->
  <rule id="110718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3350 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>