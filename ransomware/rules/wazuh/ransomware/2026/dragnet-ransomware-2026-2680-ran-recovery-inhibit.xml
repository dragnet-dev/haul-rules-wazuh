<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2680 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 4820b474-eb50-59dc-8d37-9d3d79ffe4f5 -->
  <rule id="613147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2680 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>