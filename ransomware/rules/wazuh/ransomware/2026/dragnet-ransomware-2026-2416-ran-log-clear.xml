<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2416 — Event Log Clearing (exitium) | Status: stable | Sigma ID: 7fa21f18-c4c5-5697-80b1-93b8c982e814 -->
  <rule id="667551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2416 — Event Log Clearing (exitium)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>