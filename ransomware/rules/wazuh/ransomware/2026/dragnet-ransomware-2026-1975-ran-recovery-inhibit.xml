<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1975 — Recovery Inhibition (incransom) | Status: test | Sigma ID: 87058353-1ba6-5e4a-84bb-d6a2fbf5d886 -->
  <rule id="705835" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1975 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>