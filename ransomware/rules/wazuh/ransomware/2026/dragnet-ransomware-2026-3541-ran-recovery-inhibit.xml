<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3541 — Recovery Inhibition (payload) | Status: stable | Sigma ID: aabde8ba-bc83-59e6-b54c-1c63b53f779a -->
  <rule id="793588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3541 — Recovery Inhibition (payload)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>