<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0020 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: 2e20edd4-15fd-5002-bdbf-e0ddcb6a9728 -->
  <rule id="382957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0020 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>