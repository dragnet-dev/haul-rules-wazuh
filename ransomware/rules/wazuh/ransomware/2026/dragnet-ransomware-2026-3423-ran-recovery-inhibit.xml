<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3423 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 653bcf5c-8e26-5754-a40b-0784c1bd4b52 -->
  <rule id="977711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3423 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>