<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0935 — Recovery Inhibition (play) | Status: stable | Sigma ID: 8e5b57ec-1f68-5312-a619-85daf62ea51b -->
  <rule id="581157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0935 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>