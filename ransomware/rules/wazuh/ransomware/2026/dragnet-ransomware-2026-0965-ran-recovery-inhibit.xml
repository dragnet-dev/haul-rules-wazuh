<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0965 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 404285cd-2ce3-5db2-8d01-e03564989154 -->
  <rule id="268572" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0965 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>