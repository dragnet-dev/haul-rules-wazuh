<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3364 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 7dbbde4a-af34-55f8-9a71-ad47ed748bba -->
  <rule id="240094" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3364 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>