<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2335 — Recovery Inhibition (aurora) | Status: stable | Sigma ID: c3ecb8b8-738d-5f8c-8441-6c52e49a6a3e -->
  <rule id="675958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2335 — Recovery Inhibition (aurora)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>