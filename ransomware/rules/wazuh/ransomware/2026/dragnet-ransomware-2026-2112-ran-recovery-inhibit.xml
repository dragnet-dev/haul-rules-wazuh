<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2112 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 906d7451-cb28-5dfe-9b18-9621ed7d9b1f -->
  <rule id="650974" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2112 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>