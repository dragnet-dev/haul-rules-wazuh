<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1406 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: dc5bc933-1848-56d1-bf1b-884ae086beee -->
  <rule id="346689" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1406 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>