<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2334 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 008833a2-6d97-5ff5-b676-b049c4847bae -->
  <rule id="613382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2334 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>