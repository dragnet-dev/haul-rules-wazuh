<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0751 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 60a6c40b-5509-52b7-960a-9843b197718a -->
  <rule id="753084" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0751 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>