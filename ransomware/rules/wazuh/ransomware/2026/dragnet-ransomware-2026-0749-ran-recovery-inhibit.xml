<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0749 — Recovery Inhibition (alphalocker) | Status: stable | Sigma ID: 58445450-9252-5333-9d6d-5da8767c983e -->
  <rule id="544545" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0749 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>