<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0936 — Shadow Copy Deletion (cmdorganization) | Status: deprecated | Sigma ID: bc6e60e3-fb1b-5ea9-a6c0-f06cad943b17 -->
  <rule id="419060" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0936 — Shadow Copy Deletion (cmdorganization)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>