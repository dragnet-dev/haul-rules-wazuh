<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0116 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: aabf8b69-6604-5b3f-b879-a4b6c524b83c -->
  <rule id="793899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0116 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>