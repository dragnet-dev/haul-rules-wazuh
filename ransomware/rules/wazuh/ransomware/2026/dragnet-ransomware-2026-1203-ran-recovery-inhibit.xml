<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1203 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 8a5c5eba-3e65-5083-9979-6830fe574044 -->
  <rule id="947614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1203 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>