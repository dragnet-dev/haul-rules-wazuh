<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3230 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: d1401e48-a6be-5077-9a58-67a42fb1f3aa -->
  <rule id="402430" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3230 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>