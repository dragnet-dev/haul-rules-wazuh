<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1568 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 8eafab07-7364-5b1a-b488-51c17ebe8f0b -->
  <rule id="451083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1568 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>