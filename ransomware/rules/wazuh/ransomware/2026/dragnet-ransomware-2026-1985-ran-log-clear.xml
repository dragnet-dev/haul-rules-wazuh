<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1985 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: abb9af5b-e874-5ae0-9aa7-0eac20d61cc1 -->
  <rule id="834799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1985 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>