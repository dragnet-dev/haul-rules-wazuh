<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0646 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 09f48eed-1bb8-5ff8-bb0a-7ae4d8b15911 -->
  <rule id="582926" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0646 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>