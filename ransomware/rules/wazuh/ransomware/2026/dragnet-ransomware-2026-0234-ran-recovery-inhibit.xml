<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0234 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 2c57c7d5-e492-5459-bc6f-ba75bb51110d -->
  <rule id="711965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0234 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>