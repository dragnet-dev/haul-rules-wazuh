<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1271 — Recovery Inhibition (gunra) | Status: stable | Sigma ID: be220aaa-e880-5b66-834b-50b5ce1f7999 -->
  <rule id="443530" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1271 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>