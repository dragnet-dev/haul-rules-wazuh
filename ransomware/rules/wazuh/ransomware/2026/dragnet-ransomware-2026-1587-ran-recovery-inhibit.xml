<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1587 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: fde151f2-1cf4-5dd4-be56-5289f6b9123e -->
  <rule id="562151" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1587 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>