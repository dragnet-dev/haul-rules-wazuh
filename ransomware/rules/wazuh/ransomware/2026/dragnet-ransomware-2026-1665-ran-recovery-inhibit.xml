<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1665 — Recovery Inhibition (cipherforce) | Status: stable | Sigma ID: 2df80a07-d72f-59b6-a113-7d59beb02532 -->
  <rule id="377290" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1665 — Recovery Inhibition (cipherforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
