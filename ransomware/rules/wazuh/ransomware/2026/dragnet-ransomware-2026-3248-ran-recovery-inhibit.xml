<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3248 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: b4a56627-0ffb-51cc-babc-e5f621852013 -->
  <rule id="134566" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3248 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>