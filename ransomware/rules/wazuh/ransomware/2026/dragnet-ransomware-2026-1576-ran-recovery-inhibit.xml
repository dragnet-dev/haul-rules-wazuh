<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1576 — Recovery Inhibition (blacknevas) | Status: stable | Sigma ID: 70ca9a7a-57f4-5dff-865f-fa63a5a292c2 -->
  <rule id="299674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1576 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>