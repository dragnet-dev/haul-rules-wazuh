<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1310 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 92e5f409-40ab-58a4-b91b-ea0b6e867982 -->
  <rule id="678554" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1310 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>