<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2005 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 3c4fbf47-3c72-51f1-ac11-6100bcaebe17 -->
  <rule id="778015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2005 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>