<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3137 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: c5fe73fb-25fd-5abe-9df5-66fa86e50b36 -->
  <rule id="625473" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3137 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>