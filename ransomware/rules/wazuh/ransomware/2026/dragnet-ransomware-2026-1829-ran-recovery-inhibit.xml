<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1829 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 6fbd4138-6fe8-58ea-944b-f8fe6c9ada1b -->
  <rule id="260541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1829 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>