<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2604 — Recovery Inhibition (sinobi) | Status: stable | Sigma ID: 1e283877-6289-5132-8acc-92e52519fd0e -->
  <rule id="428387" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2604 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>