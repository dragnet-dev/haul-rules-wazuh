<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1490 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 6ec280b5-4e22-5e18-af8d-5fbc9235ed45 -->
  <rule id="972280" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1490 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>