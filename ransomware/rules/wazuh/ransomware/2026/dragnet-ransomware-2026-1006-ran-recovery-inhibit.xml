<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1006 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 6af5ce0c-387f-5e72-aedf-a5d3e303abbf -->
  <rule id="881646" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1006 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>