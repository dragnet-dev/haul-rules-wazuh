<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2126 — Recovery Inhibition (clop) | Status: test | Sigma ID: ab43d617-8735-5dca-a5ca-ab280262a412 -->
  <rule id="143016" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2126 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
