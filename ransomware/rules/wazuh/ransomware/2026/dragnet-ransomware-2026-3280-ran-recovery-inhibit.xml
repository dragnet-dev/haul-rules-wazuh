<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3280 — Recovery Inhibition (payload) | Status: stable | Sigma ID: 1d37afca-053f-5c0d-8d1c-b13e8b26be60 -->
  <rule id="432764" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3280 — Recovery Inhibition (payload)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>