<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2908 — Event Log Clearing (insomnia) | Status: stable | Sigma ID: 3852b159-d396-5ebd-a8d2-1ab962127c55 -->
  <rule id="864315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2908 — Event Log Clearing (insomnia)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>