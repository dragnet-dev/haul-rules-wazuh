<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3043 — Event Log Clearing (coinbasecartel) | Status: stable | Sigma ID: 8980b631-22a3-5b2f-8f2a-0e167041d6f7 -->
  <rule id="636916" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3043 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>