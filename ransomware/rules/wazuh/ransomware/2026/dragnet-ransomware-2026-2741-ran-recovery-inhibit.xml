<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2741 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 5cba867e-4042-5219-b40a-9dc0eb2564e3 -->
  <rule id="673886" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2741 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
