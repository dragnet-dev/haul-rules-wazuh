<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1649 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 231725b5-be96-5cb3-8dc8-23fa7c6054e2 -->
  <rule id="207611" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1649 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>