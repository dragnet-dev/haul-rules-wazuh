<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3540 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 0341b56c-13e3-5c34-a4db-d9629a1ffabc -->
  <rule id="748108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3540 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>