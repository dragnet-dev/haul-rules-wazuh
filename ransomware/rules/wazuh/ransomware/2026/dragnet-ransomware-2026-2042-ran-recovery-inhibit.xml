<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2042 — Recovery Inhibition (blackwater) | Status: stable | Sigma ID: b8f05522-7b86-54dc-a869-979d9ea2bcf7 -->
  <rule id="203055" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2042 — Recovery Inhibition (blackwater)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>