<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0934 — Recovery Inhibition (play) | Status: stable | Sigma ID: ca1a1fc7-ecd8-5197-83dd-de4c7a3e5bbc -->
  <rule id="775391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0934 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>