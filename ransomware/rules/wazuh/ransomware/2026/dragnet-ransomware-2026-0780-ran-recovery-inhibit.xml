<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0780 — Recovery Inhibition (safepay) | Status: stable | Sigma ID: 743e13dd-1f30-558b-a26b-6f70561b8371 -->
  <rule id="390213" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0780 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>