<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2655 — Recovery Inhibition (handala) | Status: stable | Sigma ID: a2f2c763-2503-5789-9940-4ff1fc1856fb -->
  <rule id="935647" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2655 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>