<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2082 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: e47868d5-88a4-5d9f-aac0-ee04a4ca6985 -->
  <rule id="647868" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2082 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>