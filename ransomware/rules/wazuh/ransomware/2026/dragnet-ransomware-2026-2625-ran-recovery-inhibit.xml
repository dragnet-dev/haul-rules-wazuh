<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2625 — Recovery Inhibition (termite) | Status: stable | Sigma ID: c4edbf71-112b-55e4-9059-f12c7eafc0f9 -->
  <rule id="187327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2625 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>