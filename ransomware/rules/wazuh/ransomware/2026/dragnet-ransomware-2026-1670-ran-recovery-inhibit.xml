<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1670 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: c705972f-7e5e-5ac2-98f9-d6b2aeb2e113 -->
  <rule id="470597" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1670 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>