<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1809 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: d8dbb7fc-f3b6-5b4b-b156-e8515521e816 -->
  <rule id="387637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1809 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>