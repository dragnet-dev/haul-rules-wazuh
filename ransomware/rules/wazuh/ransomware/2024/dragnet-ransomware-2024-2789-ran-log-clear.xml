<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2789 — Event Log Clearing (ElDorado) | Status: experimental | Sigma ID: 56fd0fbe-55a3-54b7-b7b5-b14a17c64232 -->
  <rule id="634255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2789 — Event Log Clearing (ElDorado)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>