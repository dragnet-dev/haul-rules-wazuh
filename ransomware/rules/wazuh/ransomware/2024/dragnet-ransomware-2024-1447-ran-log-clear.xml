<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1447 — Event Log Clearing (ElDorado) | Status: deprecated | Sigma ID: b3a8c9f9-feeb-5cc6-b972-fb91224d3167 -->
  <rule id="310209" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1447 — Event Log Clearing (ElDorado)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>