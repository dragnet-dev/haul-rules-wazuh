<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2138 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 73c9c5ee-82e2-5803-a1fc-81b9300e5fa4 -->
  <rule id="189565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2138 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>