<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5997 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 722bd2e2-a293-5fd6-9e10-15256dc00d05 -->
  <rule id="150212" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5997 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>