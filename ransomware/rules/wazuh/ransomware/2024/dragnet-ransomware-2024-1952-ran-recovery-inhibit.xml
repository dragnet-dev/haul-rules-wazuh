<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1952 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 955fa957-2867-5b8b-bb9d-f3721e6a88fc -->
  <rule id="747309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1952 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>