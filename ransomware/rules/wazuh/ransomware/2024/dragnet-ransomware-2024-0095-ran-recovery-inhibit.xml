<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0095 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 9233c89c-8635-5585-b62a-38dd796c9841 -->
  <rule id="677408" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0095 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>