<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1377 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 290798f8-355b-534f-8cd7-a2ae95098488 -->
  <rule id="252783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1377 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>