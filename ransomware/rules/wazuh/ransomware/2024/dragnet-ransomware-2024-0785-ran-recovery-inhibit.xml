<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0785 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: f3b02d3d-64d8-509f-9e0d-17b836a52844 -->
  <rule id="434445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0785 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>