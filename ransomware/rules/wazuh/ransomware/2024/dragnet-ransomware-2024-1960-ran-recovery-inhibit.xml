<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1960 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ea6ff283-ca0e-5cad-adb8-1fd230c9d368 -->
  <rule id="708312" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1960 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>