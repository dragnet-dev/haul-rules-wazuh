<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0234 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: cfddf651-174b-51c3-8aa5-713d3fdae7f3 -->
  <rule id="514236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0234 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>