<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5560 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: e5dd4a73-0ad7-52d1-aabb-02f49e106cf1 -->
  <rule id="674634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5560 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>