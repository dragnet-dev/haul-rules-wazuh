<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1524 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 58595f93-ee2d-5ece-8105-77fc293f4493 -->
  <rule id="475359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1524 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>