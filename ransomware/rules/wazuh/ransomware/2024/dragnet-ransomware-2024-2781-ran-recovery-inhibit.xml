<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2781 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: aa8f2b34-6a4b-5c2a-a67a-c751da15e6c2 -->
  <rule id="874923" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2781 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>