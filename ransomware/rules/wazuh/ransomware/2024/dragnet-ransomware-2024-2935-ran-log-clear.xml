<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2935 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: a729ddb7-76f0-5c75-989a-ee4de7dd5e09 -->
  <rule id="146845" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2935 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>