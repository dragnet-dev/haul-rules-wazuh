<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2472 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: c2b71c65-3f2e-508e-bcdb-3e16322e469c -->
  <rule id="541948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2472 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>