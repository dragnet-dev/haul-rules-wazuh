<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3073 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 97cad35f-a20b-50b2-840d-b29312b9fb24 -->
  <rule id="505573" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3073 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>