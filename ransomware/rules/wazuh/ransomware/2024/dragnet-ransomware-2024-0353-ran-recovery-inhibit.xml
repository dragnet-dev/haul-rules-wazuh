<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0353 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6a69f348-d426-5785-bebd-05e123d5f049 -->
  <rule id="907193" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0353 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>