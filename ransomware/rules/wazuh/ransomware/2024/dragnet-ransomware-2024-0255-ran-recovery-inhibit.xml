<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0255 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: ee069000-2e0d-531a-b1a6-ae8449d5665f -->
  <rule id="680690" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0255 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>