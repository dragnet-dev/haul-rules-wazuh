<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4924 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: bcd3b624-62b8-5f21-b7d4-f04e57f1837c -->
  <rule id="434196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4924 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>