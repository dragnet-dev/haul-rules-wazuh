<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0472 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 79063705-3c63-52bd-8be0-6b344052c4a9 -->
  <rule id="806370" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0472 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>