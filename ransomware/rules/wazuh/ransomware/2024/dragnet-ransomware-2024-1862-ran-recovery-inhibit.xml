<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1862 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 728bb754-6769-504e-8346-96d355cd4efc -->
  <rule id="165557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1862 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>