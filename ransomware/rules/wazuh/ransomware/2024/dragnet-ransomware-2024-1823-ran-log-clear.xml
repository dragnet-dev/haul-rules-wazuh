<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1823 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 903f9fd8-0bcf-5c41-a4cc-87a04d6239ca -->
  <rule id="614239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1823 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>