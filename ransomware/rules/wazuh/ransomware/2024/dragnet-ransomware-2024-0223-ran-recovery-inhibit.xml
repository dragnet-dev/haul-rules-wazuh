<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0223 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 3877330f-1e56-5fe0-a61f-2c9d75b0efe5 -->
  <rule id="377330" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0223 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>