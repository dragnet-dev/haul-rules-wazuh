<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4636 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 37af7b01-022e-5e94-a7b4-f8099db3495f -->
  <rule id="743643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4636 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>