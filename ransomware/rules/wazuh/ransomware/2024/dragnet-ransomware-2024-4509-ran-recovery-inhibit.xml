<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4509 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: cbe42452-fadf-5dd5-a2b9-5f5cd5edb570 -->
  <rule id="662424" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4509 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>