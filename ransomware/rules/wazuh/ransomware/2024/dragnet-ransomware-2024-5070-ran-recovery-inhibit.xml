<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5070 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 10f8a820-7614-5152-ba9d-33b5fd7bc12b -->
  <rule id="213882" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5070 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>