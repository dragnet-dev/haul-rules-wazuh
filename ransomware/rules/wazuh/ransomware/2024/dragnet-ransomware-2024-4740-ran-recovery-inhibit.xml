<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4740 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5ecdad7a-2e5b-5787-8d52-a7cf18249390 -->
  <rule id="913037" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4740 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>