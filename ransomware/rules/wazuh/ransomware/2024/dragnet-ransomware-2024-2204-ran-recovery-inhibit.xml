<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2204 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 10228408-c6fd-57f4-a73f-ed788e2cbe3b -->
  <rule id="222840" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2204 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>