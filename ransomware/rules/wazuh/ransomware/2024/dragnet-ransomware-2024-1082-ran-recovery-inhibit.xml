<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1082 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 253fb7d4-7ae0-593e-9305-2f914500ca2e -->
  <rule id="603165" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1082 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>