<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3359 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 4fd7d606-9d2e-5db3-b23f-3e86e19142e9 -->
  <rule id="344456" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3359 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>