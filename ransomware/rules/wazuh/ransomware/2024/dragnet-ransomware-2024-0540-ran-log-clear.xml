<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0540 — Event Log Clearing (ElDorado) | Status: deprecated | Sigma ID: edbb4c47-125f-5d90-8670-d5d37debf47e -->
  <rule id="837516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0540 — Event Log Clearing (ElDorado)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>