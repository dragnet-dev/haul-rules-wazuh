<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4497 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: e2068398-c3ed-59a7-948c-9855c0ae83ec -->
  <rule id="620683" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4497 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>