<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2427 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: f0babecc-24de-5504-88e5-b0fd64c7b6da -->
  <rule id="978206" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2427 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>