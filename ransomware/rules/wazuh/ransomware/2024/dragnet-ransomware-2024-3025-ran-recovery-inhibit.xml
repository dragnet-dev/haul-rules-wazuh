<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3025 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 916734c6-abb1-5c2e-89dd-b85b6f67ef5d -->
  <rule id="367756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3025 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>