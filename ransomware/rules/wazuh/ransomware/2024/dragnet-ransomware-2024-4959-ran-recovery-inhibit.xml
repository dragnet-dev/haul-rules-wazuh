<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4959 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: fd216b35-c785-5918-bc65-1c94a9b24d95 -->
  <rule id="551467" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4959 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>