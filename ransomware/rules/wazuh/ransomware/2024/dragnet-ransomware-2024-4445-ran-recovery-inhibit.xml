<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4445 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 64c687b5-ce0c-5a68-afd5-19b02e805e48 -->
  <rule id="236687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4445 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>