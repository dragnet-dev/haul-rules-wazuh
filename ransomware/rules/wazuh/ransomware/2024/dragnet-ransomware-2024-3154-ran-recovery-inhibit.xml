<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3154 — Recovery Inhibition (trinity) | Status: experimental | Sigma ID: 75980811-04cd-5f22-bd67-0807d0427029 -->
  <rule id="498081" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3154 — Recovery Inhibition (trinity)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>