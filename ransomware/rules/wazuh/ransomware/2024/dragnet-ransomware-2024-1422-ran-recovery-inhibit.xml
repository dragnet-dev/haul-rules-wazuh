<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1422 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d6ef007f-5305-575b-bc81-0bbc89c42004 -->
  <rule id="905500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1422 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>