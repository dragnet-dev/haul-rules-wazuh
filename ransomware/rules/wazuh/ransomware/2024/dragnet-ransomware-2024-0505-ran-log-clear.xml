<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0505 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 84e7e8a8-9e9c-58c5-8a32-a3ee7cb04b2a -->
  <rule id="474068" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0505 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>