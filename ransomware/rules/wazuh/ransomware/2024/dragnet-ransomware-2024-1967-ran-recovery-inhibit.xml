<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1967 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7c7568b4-959d-539d-9a9a-83057816c271 -->
  <rule id="447568" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1967 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>