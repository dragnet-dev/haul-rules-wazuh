<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4417 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 2018d6c5-7231-5aaa-8bf3-2bf41416fd09 -->
  <rule id="768268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4417 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>