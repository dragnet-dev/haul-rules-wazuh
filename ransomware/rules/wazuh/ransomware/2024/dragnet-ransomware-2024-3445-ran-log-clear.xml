<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3445 — Event Log Clearing (blacknevas) | Status: experimental | Sigma ID: 6fd6fd60-a742-55ee-85e5-0c6a81fac885 -->
  <rule id="181629" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3445 — Event Log Clearing (blacknevas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>