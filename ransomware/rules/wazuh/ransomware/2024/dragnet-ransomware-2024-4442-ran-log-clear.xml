<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4442 — Event Log Clearing (ElDorado) | Status: deprecated | Sigma ID: fe58fff2-d8c3-5bfa-8ad3-890321418c63 -->
  <rule id="317503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4442 — Event Log Clearing (ElDorado)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>