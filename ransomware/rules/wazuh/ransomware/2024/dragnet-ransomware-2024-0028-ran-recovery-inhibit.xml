<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0028 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: e6a59e1f-a466-57b3-a52a-c5cea455b6ce -->
  <rule id="254558" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0028 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>