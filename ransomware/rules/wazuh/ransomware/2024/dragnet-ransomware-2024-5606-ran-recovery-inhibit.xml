<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5606 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2959c6ba-081e-5614-b894-bfda5407b632 -->
  <rule id="477067" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5606 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>