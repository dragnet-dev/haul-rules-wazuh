<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5771 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: e615d776-9e9d-5ee2-aa6a-122c59a72a82 -->
  <rule id="638537" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5771 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>