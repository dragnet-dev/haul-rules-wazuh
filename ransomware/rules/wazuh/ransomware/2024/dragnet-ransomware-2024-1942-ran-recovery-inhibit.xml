<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1942 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: aac8ab7e-ac13-5e53-9735-535b3d936216 -->
  <rule id="796139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1942 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>