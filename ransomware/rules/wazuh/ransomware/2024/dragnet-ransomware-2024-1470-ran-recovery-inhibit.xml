<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1470 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f4ddd9b5-653f-542c-88e0-3c3d1b739e44 -->
  <rule id="143339" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1470 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>