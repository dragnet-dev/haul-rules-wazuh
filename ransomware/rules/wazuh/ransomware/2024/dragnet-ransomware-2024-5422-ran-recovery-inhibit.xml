<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5422 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 335eb5ea-36d9-5775-8185-f48237c9659f -->
  <rule id="359294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5422 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>