<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1876 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 9f2e064c-796c-5564-bb50-629b4d0ecaba -->
  <rule id="848606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1876 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>