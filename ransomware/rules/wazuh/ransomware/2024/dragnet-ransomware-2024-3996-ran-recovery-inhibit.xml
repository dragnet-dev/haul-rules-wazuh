<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3996 — Recovery Inhibition (embargo) | Status: experimental | Sigma ID: 8937ed02-2f03-56bd-826f-2aea4669303a -->
  <rule id="588109" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3996 — Recovery Inhibition (embargo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
