<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4120 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: d3300601-9f23-5fed-a230-f0858f9994f6 -->
  <rule id="533006" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4120 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>