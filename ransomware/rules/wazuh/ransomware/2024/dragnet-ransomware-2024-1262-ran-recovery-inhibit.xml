<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1262 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 802b6cb6-dd78-5091-ac58-5100d2d97b4f -->
  <rule id="354988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1262 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>