<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3546 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 93d01b4c-bc74-5ec5-9f4a-87a1ba45f614 -->
  <rule id="701627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3546 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>