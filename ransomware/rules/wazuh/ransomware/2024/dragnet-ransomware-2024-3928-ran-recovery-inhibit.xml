<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3928 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 502e8327-2c2f-54e9-add5-b5bbdf067be2 -->
  <rule id="946832" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3928 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>