<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3177 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 525f14c5-7db0-5fa9-b095-a7ea721fface -->
  <rule id="964236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3177 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>