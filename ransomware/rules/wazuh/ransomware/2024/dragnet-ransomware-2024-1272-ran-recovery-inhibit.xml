<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1272 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: 10a9d8b9-078b-5410-a7fb-2fbef6e995da -->
  <rule id="877259" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1272 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>