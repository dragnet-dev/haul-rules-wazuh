<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2668 — Recovery Inhibition (play) | Status: experimental | Sigma ID: defa7068-abe9-54f8-b63d-668436275c95 -->
  <rule id="408270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2668 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>