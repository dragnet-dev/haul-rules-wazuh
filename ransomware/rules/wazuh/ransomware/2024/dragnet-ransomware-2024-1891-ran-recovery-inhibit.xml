<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1891 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: 639fc022-788b-54b3-84ad-a98518099067 -->
  <rule id="838360" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1891 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>