<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2517 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 763ad579-4bbc-5684-b6f1-6c4e31494f7e -->
  <rule id="255015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2517 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>