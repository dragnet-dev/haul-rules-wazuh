<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4410 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: d5572064-f7aa-505a-b26a-26a694f3f297 -->
  <rule id="555720" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4410 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>