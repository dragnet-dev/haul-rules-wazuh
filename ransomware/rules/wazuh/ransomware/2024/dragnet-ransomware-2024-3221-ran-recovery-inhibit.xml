<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3221 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 65d97b04-5c62-5d1b-8c89-f5b3addd0d34 -->
  <rule id="886363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3221 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>