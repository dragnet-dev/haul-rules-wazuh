<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1355 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 946275ab-6d77-5c7f-8265-f3bf8d05a493 -->
  <rule id="840410" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1355 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>