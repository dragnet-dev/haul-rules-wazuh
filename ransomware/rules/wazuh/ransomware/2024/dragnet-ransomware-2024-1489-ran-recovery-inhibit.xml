<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1489 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 83520da2-c2bf-5155-87b3-a8841b934535 -->
  <rule id="536333" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1489 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>