<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5228 — Event Log Clearing (fog) | Status: experimental | Sigma ID: 4bc66fc9-d67a-50d3-a523-ebe47e9d05f3 -->
  <rule id="240271" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5228 — Event Log Clearing (fog)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>