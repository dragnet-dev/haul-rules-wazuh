<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4175 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b60b888a-6c4a-586b-8aab-41567946f7eb -->
  <rule id="157188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4175 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>