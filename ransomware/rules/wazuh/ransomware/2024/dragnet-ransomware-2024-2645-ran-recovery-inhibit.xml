<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2645 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4980c6d8-fd5d-5aad-8171-ef6a466f0c38 -->
  <rule id="250829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2645 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>