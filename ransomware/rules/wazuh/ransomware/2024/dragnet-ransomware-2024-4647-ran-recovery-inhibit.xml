<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4647 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: d4ef3636-f115-5ddc-a161-b8732964e6bf -->
  <rule id="854336" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4647 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>