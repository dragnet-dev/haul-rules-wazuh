<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2133 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: acad0e0b-e475-51a6-8126-d1eee4f3d954 -->
  <rule id="872814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2133 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>