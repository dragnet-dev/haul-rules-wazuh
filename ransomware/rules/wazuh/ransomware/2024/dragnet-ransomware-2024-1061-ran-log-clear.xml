<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1061 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: 093bf51f-d14b-5f9e-9672-8eb4cd709b99 -->
  <rule id="699951" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1061 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>