<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4936 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 04f7aa9e-f876-5a49-9a21-61b21250e044 -->
  <rule id="342029" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4936 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>