<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1607 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: ebb6ba8f-bf02-595b-9c27-55c6e355e83e -->
  <rule id="755482" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1607 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>