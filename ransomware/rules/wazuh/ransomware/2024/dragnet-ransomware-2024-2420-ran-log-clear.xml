<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2420 — Event Log Clearing (lockbit5) | Status: experimental | Sigma ID: f44d7c97-a3f7-5f7c-ad98-26264d0fd6b9 -->
  <rule id="454844" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2420 — Event Log Clearing (lockbit5)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>