<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1011 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 565a074d-1c27-5d3f-9800-811ec10e5a91 -->
  <rule id="150074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1011 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>