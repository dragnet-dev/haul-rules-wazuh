<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1615 — Recovery Inhibition (ElDorado) | Status: experimental | Sigma ID: db167edc-7f0d-5336-aa98-a39e4f7947be -->
  <rule id="906686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1615 — Recovery Inhibition (ElDorado)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>