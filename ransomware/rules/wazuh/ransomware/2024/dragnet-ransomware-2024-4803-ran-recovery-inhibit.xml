<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4803 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 5daace96-8311-5a4d-a38d-9b61bc08339f -->
  <rule id="838574" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4803 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>