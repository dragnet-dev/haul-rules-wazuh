<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0713 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 820aa43d-70a4-5e60-a999-90a210d2c580 -->
  <rule id="400904" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0713 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>