<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1945 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 1ad21637-3b57-5c84-8b0b-a7fc4ad5ce82 -->
  <rule id="792163" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1945 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>