<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3599 — Event Log Clearing (handala) | Status: experimental | Sigma ID: db4719f4-188c-5d34-ba13-95acc4dc7b49 -->
  <rule id="494719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3599 — Event Log Clearing (handala)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>