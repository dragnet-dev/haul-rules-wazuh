<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3353 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: e301c7ad-0d44-5e53-8445-6f18d33f18fe -->
  <rule id="588287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3353 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>