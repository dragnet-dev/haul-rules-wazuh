<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1392 — Event Log Clearing (clop) | Status: experimental | Sigma ID: f5a633d4-6a95-5eb7-bda4-42e3f3e4aca8 -->
  <rule id="790633" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1392 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>