<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5639 — Event Log Clearing (mogilevich) | Status: deprecated | Sigma ID: 74e2d022-e4f5-55f2-af1a-a37d2c0561bc -->
  <rule id="217250" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5639 — Event Log Clearing (mogilevich)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>