<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1408 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: bbff48d2-ee26-5443-b472-9cf15b35ea84 -->
  <rule id="412748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1408 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>