<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1814 — Event Log Clearing (qilin) | Status: deprecated | Sigma ID: 3969c7fa-370c-53dd-baaf-e59e5d4e85a5 -->
  <rule id="362687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1814 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>