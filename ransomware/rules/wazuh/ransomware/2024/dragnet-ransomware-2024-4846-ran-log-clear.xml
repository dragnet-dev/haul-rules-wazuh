<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4846 — Event Log Clearing (darkvault) | Status: experimental | Sigma ID: 15f4205a-ffbe-5c22-acdc-0d262a552fa8 -->
  <rule id="854205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4846 — Event Log Clearing (darkvault)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>