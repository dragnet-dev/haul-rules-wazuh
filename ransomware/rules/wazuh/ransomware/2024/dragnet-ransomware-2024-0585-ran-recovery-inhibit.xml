<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0585 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ae947a9f-0a30-589e-997f-6cc923bb7297 -->
  <rule id="199162" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0585 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>