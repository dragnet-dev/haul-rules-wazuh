<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3971 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 86b69bb3-6d00-538c-8f8e-305f0681ccb0 -->
  <rule id="520315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3971 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>