<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3188 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: b0c2987f-0e7c-507e-85f6-3b61a7a3b8f1 -->
  <rule id="972298" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3188 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>