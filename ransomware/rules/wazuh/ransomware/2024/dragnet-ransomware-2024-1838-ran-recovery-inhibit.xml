<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1838 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 821b0e70-00f8-53d5-9097-f1a9f817df01 -->
  <rule id="403534" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1838 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>