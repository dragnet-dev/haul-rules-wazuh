<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1034 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3ba7f31c-70a4-5e5f-a651-183ab507e984 -->
  <rule id="727673" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1034 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>