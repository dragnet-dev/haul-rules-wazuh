<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5149 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: fac5ab28-221f-554c-b21e-257877493899 -->
  <rule id="472171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5149 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>