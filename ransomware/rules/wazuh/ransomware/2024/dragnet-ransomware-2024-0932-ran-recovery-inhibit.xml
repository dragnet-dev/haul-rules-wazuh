<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0932 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 7b0bb14a-e9d1-55de-b33f-5978918e5e15 -->
  <rule id="550671" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0932 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>