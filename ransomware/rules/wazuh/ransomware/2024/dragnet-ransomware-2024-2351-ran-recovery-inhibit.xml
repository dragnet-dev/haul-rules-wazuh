<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2351 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 08713fb1-a095-5b6d-9da3-f037394bce61 -->
  <rule id="530779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2351 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>