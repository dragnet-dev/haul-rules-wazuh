<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5681 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: a3c1e176-726d-596b-be57-cfbba2dd76e8 -->
  <rule id="956301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5681 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>