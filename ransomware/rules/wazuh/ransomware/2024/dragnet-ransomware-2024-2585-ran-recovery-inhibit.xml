  <rule id="415608" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2585 — Recovery Inhibition (0mega)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
