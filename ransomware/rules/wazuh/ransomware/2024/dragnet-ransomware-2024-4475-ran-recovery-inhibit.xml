<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4475 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 0a97fd7f-88da-5c9b-87d6-e2b0e9137ebb -->
  <rule id="210857" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4475 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>