<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2350 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 1d76da51-6957-53d5-8e06-0c7d1a9683f1 -->
  <rule id="520745" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2350 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>