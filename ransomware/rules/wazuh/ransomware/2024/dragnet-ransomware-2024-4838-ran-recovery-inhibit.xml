<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4838 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 1897c4e6-5548-598f-bcd5-836c6237c6a0 -->
  <rule id="458318" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4838 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>