<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4460 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 295ea266-fa59-59ba-bfcf-b07b8d17401d -->
  <rule id="475426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4460 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>