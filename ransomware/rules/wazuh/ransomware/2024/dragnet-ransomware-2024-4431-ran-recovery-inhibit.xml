<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4431 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 72cafb5c-414f-52bf-b211-388d79ed6967 -->
  <rule id="370555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4431 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>