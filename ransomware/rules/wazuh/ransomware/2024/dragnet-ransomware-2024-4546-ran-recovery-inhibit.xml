<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4546 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 72790e99-e520-55a6-9c05-03f22e6fed32 -->
  <rule id="364654" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4546 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>