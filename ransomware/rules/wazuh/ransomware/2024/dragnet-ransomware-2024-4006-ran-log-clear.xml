<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4006 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 45bdf650-da61-5120-98b2-c32ebfc2b1f4 -->
  <rule id="173596" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4006 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>