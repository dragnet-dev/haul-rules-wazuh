<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0148 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 9e7488bc-7dc4-55ed-8c80-b6b4ec2f4fff -->
  <rule id="787488" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0148 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>