<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1431 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 193f84d1-f3e1-5fae-ad72-7af030714951 -->
  <rule id="566157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1431 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>