<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2727 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 5ec095c9-99c6-5137-91a0-cf7191c1261f -->
  <rule id="716095" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2727 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>