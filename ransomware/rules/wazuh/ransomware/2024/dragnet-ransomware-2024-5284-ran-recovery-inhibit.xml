<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5284 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ece23bd0-be73-57a5-905f-62da93c4bd28 -->
  <rule id="764379" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5284 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>