<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1640 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 6b46b967-3306-5728-a3a5-fe3c1180f437 -->
  <rule id="919479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1640 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>