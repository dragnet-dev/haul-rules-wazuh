<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0343 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ad914692-0264-5541-8649-adb71b544844 -->
  <rule id="939146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0343 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>