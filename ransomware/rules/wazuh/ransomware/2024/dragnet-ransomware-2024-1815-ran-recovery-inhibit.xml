<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1815 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4b61cc02-31f2-54dd-a7f6-3eac8bd298b9 -->
  <rule id="235820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1815 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>