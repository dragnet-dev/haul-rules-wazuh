<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1119 — Recovery Inhibition (trisec) | Status: experimental | Sigma ID: e4c8697a-98c6-5324-b7db-ab381995f26f -->
  <rule id="616869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1119 — Recovery Inhibition (trisec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>