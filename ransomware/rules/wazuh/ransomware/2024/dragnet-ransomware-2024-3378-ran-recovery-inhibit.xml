<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3378 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1255db75-4ce0-521e-b894-c26d57d1d781 -->
  <rule id="614997" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3378 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>