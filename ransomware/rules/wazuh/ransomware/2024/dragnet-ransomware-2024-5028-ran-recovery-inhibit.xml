<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5028 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 79aa9313-e6aa-54f5-8890-c9c7eaa9b0c1 -->
  <rule id="339493" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5028 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>