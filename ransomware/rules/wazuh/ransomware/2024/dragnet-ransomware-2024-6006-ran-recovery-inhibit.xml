<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6006 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: aaf2ad30-afb0-51b2-8ded-a7d6e6ddc665 -->
  <rule id="802285" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6006 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>