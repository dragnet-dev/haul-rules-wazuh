<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2379 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: f37e525b-4767-5222-b82c-d1a3cfc3381f -->
  <rule id="760652" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2379 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>