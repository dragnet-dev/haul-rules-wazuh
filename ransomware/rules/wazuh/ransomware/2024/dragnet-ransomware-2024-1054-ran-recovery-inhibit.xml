<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1054 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f890e63d-0791-557b-ad64-5628b7040e9e -->
  <rule id="842546" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1054 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>