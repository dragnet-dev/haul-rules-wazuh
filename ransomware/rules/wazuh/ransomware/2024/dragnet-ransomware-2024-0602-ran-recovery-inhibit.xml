<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0602 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a698a8ff-fa87-5336-9871-16bf917c5454 -->
  <rule id="911788" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0602 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>