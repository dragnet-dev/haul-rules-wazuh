<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5731 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 25e9b9d2-1270-5f22-aaa8-04a005ea8f25 -->
  <rule id="823357" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5731 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>