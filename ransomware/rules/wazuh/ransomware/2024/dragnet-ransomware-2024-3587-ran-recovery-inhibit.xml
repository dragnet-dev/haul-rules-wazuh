<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3587 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: b4c64132-706c-50d3-8718-a79893ced962 -->
  <rule id="136641" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3587 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>