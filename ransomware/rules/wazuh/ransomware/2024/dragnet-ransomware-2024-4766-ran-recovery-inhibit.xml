<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4766 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: a18e2949-37b0-5d31-920f-b4e7596a3aaa -->
  <rule id="830229" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4766 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>