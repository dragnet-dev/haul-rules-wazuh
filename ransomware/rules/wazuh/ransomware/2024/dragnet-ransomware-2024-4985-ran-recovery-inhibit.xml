<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4985 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 510745f6-41f5-55bf-b285-0204d0b28a00 -->
  <rule id="171935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4985 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>