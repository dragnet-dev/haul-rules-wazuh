<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1049 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: a0dc8020-fb1e-53d6-98d0-fae4d1d65023 -->
  <rule id="882080" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1049 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>