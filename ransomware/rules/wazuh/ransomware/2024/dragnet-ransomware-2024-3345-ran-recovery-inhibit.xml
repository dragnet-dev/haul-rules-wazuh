<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3345 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 2cf79773-7a3e-523d-811a-6a2ba65b7f6d -->
  <rule id="997977" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3345 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>