<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5374 — Recovery Inhibition (play) | Status: experimental | Sigma ID: eb8e63a2-b134-5d98-abc5-dd91f2799fdd -->
  <rule id="274263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5374 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>