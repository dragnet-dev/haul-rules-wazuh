<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1247 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: db5d15fd-8ceb-5799-905f-978a2899688b -->
  <rule id="913315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1247 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>