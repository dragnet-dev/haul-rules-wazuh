<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4153 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: a12a262d-b6e3-5e98-b786-f20dd40932ef -->
  <rule id="820226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4153 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>