<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1659 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: bcf779a2-f707-50e4-a7e3-b1ee18b8a7ab -->
  <rule id="423779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1659 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>