<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2056 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 03bab988-5170-5efd-88ef-2bc51f2b3a43 -->
  <rule id="727598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2056 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>