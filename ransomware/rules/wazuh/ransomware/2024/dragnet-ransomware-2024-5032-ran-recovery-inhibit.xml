<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5032 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 5c98e501-6984-5a41-867a-793e32156f6a -->
  <rule id="687825" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5032 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>