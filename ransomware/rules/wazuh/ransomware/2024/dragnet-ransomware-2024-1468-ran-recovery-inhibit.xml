<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1468 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 630f368f-1ec3-54f8-b4ff-f2cd0ef92c79 -->
  <rule id="209536" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1468 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>