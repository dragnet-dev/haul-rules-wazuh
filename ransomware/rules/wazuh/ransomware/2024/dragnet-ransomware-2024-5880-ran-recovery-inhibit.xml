<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5880 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 02f48592-bf5b-5288-a092-cb6e5e239067 -->
  <rule id="348592" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5880 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>