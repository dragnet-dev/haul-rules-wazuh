<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0068 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ed51313f-5be7-5ac2-af4f-2d14221a1207 -->
  <rule id="675131" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0068 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>