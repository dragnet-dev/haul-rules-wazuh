<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1672 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 191e70e2-3891-5561-85ab-2842db3361cf -->
  <rule id="513134" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1672 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>