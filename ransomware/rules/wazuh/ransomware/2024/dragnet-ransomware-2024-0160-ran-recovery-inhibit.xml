<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0160 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 386d0f5d-24f9-5cc5-a8bd-babd2b63b038 -->
  <rule id="102555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0160 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>