<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0764 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7f297c5c-37d7-5e91-8a14-f95e1b6eea25 -->
  <rule id="336764" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0764 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>