<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2880 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 63425073-8a20-5782-9634-675ab1392c15 -->
  <rule id="142507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2880 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>