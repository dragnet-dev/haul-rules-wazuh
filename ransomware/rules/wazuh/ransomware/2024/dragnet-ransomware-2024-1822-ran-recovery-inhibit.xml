<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1822 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 54aef1c5-6d3a-539c-b2e4-6c34fb1e9296 -->
  <rule id="539831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1822 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>