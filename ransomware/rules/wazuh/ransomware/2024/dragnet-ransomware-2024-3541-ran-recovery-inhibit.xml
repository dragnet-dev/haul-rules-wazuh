<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3541 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: cc8190d0-13aa-5b40-9f6e-e4004ae80e84 -->
  <rule id="348190" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3541 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>