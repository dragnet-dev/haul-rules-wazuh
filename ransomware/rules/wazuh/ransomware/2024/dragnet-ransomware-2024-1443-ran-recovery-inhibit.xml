<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1443 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 4c6d9118-df2a-54e9-8234-ef7fed862851 -->
  <rule id="426991" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1443 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>