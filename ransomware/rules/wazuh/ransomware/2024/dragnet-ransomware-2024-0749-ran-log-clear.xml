<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0749 — Event Log Clearing (cicada3301) | Status: experimental | Sigma ID: 9d4a3fa0-5400-56fe-a91f-d09e8defa230 -->
  <rule id="531103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0749 — Event Log Clearing (cicada3301)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>