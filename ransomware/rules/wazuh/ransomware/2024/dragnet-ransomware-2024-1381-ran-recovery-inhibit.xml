<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1381 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 852e453e-3c4d-51b4-bff8-61ac09991f5c -->
  <rule id="564645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1381 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>