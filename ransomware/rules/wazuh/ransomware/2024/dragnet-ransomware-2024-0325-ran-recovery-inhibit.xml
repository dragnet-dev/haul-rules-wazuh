<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0325 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c68d98c5-0ec5-56be-b53f-0c2d626a5606 -->
  <rule id="330198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0325 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>