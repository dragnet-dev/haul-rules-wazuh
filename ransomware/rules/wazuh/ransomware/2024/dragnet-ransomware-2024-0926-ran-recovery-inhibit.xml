<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0926 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2da57749-8237-5c6d-a6a5-f187049f7fcf -->
  <rule id="205774" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0926 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>