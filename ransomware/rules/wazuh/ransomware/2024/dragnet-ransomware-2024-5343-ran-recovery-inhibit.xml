<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5343 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7a012b5e-394d-560d-a7ea-56ec545827b6 -->
  <rule id="252203" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5343 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>