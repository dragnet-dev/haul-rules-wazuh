<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3458 — Event Log Clearing (madliberator) | Status: experimental | Sigma ID: 9a8972b1-1da3-5e9d-9ead-e1fbd66f3fe8 -->
  <rule id="748972" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3458 — Event Log Clearing (madliberator)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>