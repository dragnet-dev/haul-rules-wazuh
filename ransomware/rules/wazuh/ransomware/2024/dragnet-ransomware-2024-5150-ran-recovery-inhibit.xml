<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5150 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 44c4bb93-df3c-567c-bc4e-12064fba1159 -->
  <rule id="134171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5150 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>