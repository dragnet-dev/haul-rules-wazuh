<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2142 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 99bf7dec-d06c-5b1a-baab-e13ee98c5e73 -->
  <rule id="585725" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2142 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>