<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5092 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 70f490cb-2d1e-5e4e-9f4e-c9ceba8e0c53 -->
  <rule id="335490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5092 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>