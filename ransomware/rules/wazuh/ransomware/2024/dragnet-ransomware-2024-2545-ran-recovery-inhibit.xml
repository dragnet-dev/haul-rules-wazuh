<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2545 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 30b88613-dd41-5141-9bf7-a952daa833fd -->
  <rule id="518861" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2545 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>