<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4801 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: ab5d1cd1-55ad-52f9-8071-33138dc8e97c -->
  <rule id="892508" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4801 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>