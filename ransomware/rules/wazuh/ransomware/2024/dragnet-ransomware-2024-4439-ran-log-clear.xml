<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4439 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 413dc002-27c4-5f70-8e75-c7e5ac91b27b -->
  <rule id="259480" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4439 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>