<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1103 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 232964d1-1114-5236-9b82-7672e9b4c7fe -->
  <rule id="227437" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1103 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>