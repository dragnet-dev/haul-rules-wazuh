<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4719 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0839e2e3-1e49-53d8-a5c7-ad8cbf35781c -->
  <rule id="450126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4719 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>