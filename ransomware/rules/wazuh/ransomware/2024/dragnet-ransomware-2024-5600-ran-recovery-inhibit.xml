<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5600 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 553cd1c3-80d5-5b64-86ad-fac1eae4a6b3 -->
  <rule id="617731" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5600 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>