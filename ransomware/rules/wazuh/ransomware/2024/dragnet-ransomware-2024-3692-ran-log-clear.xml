<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3692 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: 52bffe62-4850-5f5d-8f0b-1d821cc196d5 -->
  <rule id="857022" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3692 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>