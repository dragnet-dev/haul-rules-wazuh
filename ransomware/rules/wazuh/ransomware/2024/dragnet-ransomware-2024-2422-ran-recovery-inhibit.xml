<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2422 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1e4cf86a-38d7-5adb-9cf4-f674cc40130f -->
  <rule id="703186" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2422 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>