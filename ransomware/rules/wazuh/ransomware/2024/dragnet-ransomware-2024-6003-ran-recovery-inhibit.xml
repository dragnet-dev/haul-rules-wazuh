<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6003 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 0d508950-74e1-56cf-bf42-a78b4751cf82 -->
  <rule id="550895" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6003 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>