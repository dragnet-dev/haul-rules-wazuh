<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1163 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 6bb34c37-fc4d-533b-89b5-537a144b7c4b -->
  <rule id="157356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1163 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>