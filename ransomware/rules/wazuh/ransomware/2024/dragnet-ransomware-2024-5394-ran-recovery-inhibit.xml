<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5394 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: d877d89c-9714-542e-8dad-297d765e02ab -->
  <rule id="520458" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5394 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>