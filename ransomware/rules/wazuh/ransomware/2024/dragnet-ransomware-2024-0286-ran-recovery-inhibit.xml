<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0286 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: cb8b235a-ad32-5683-8237-9b7acb7113bd -->
  <rule id="661923" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0286 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>