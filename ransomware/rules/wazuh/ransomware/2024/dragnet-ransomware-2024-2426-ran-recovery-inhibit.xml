<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2426 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 2fd17ab7-dfc7-5406-b56d-310b1585d2f5 -->
  <rule id="424282" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2426 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>