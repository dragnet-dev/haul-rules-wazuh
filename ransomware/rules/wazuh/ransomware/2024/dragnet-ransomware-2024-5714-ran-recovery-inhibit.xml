<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5714 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 57e92299-bf43-50d6-ac0f-d2eb6b5a783c -->
  <rule id="369229" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5714 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>