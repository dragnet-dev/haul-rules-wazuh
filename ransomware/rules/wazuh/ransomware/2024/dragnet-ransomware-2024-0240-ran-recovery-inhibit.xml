<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0240 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4a41c401-e2bf-5b7c-9a3f-888a1190307d -->
  <rule id="390684" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0240 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>