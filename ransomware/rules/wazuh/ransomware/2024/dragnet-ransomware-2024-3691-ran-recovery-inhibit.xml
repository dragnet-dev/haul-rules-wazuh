<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3691 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: fd676548-fd2f-5348-b061-8c2ce711297f -->
  <rule id="836765" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3691 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>