<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1139 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 014049d2-5fa1-5147-8611-50cd2358c8ac -->
  <rule id="547972" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1139 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>