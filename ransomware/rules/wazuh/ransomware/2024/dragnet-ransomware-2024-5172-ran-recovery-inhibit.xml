<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5172 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: cd729cfd-3c04-5224-968e-5b6c214d8d89 -->
  <rule id="691676" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5172 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>