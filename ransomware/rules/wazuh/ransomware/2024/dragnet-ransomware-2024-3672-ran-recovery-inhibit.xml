<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3672 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 45d30c02-3286-583d-9caa-5d838c6c4ad0 -->
  <rule id="373292" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3672 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>