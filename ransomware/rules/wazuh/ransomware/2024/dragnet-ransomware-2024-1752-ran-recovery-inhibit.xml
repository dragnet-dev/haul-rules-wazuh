<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1752 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: a9cbd1c8-bc08-54ff-a11f-7a16f8a757ce -->
  <rule id="997251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1752 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>