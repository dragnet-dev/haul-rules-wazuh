<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5084 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 0506d2f9-26fe-5be2-8ef6-265e43aeeeab -->
  <rule id="497487" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5084 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>