<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4374 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: e851654f-2ffc-5a11-a874-a730cf4385c4 -->
  <rule id="685165" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4374 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>