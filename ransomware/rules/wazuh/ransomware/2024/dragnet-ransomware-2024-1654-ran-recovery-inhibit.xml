<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1654 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: 5d0db391-61c8-5461-bb4d-7b36400baec1 -->
  <rule id="682993" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1654 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>