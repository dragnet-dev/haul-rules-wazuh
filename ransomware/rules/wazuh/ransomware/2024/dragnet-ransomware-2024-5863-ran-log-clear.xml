<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5863 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 1a977eb6-6391-51c1-bc5a-d1d7f3e85173 -->
  <rule id="706347" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5863 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>