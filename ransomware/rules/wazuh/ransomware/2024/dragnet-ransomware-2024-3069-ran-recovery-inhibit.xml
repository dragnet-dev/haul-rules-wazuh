<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3069 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 9654c119-9d3e-586c-bcf1-ddcb747b1096 -->
  <rule id="744761" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3069 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>