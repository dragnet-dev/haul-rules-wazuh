<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3864 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 0ca57667-5345-5ab9-b036-8554b7238092 -->
  <rule id="325766" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3864 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>