<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0471 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: f20a9aeb-6c3f-58d4-9007-d81b11e5a58b -->
  <rule id="392954" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0471 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>