<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3764 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: e2295b5a-afcc-5674-96c4-c89800589c33 -->
  <rule id="576731" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3764 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>