<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3905 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 96e50d8b-8bb7-5aab-83e8-3f989a23be95 -->
  <rule id="780813" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3905 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>