<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2940 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: f0f8fd62-cceb-5ef5-806b-c955173a3c00 -->
  <rule id="884701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2940 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>