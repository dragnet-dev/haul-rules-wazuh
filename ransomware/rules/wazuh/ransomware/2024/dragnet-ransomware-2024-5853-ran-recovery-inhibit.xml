<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5853 — Recovery Inhibition (trinity) | Status: experimental | Sigma ID: f402827b-8b98-58fc-bc7a-275c15f07efa -->
  <rule id="740282" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5853 — Recovery Inhibition (trinity)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
