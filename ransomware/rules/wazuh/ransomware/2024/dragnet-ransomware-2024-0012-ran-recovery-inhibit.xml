<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0012 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1b831738-1cdd-525f-873c-271035feb3a0 -->
  <rule id="183173" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0012 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>