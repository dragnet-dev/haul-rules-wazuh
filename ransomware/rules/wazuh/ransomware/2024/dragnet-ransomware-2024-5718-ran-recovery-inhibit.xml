<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5718 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5dcfc2bc-156c-526e-87a3-2ce8ba6e3247 -->
  <rule id="342522" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5718 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>