<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5501 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: c7eafe15-078a-5f60-8318-aacc5eadc6c1 -->
  <rule id="383230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5501 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>