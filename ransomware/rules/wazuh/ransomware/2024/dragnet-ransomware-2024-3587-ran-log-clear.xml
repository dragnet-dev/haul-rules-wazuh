<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3587 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 4ea2dcbe-93fc-56e8-9253-c8fd1ce2d2d1 -->
  <rule id="621212" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3587 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>