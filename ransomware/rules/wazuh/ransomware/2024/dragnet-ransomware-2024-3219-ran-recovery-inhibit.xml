<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3219 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 774c6679-dc25-5c9d-9f4a-3a05b7c2a235 -->
  <rule id="439666" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3219 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>