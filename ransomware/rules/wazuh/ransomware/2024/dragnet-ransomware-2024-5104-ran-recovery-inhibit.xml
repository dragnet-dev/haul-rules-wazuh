<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5104 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1e674458-4b62-5065-8352-12141ba1d158 -->
  <rule id="467445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5104 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>