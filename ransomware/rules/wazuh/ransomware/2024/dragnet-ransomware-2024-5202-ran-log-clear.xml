<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5202 — Event Log Clearing (dAn0n) | Status: experimental | Sigma ID: 6baf2a2b-0f4e-5cb1-bcd2-aae219ff745d -->
  <rule id="910762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5202 — Event Log Clearing (dAn0n)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>