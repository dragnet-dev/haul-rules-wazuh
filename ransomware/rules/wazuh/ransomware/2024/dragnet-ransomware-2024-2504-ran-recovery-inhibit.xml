<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2504 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 806d16df-88e3-57e3-a6f0-025478052f16 -->
  <rule id="490916" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2504 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>