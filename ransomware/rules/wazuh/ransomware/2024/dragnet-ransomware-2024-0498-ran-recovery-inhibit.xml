<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0498 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 202dd5c6-6e37-5e8f-a4a5-7846a65707ba -->
  <rule id="309372" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0498 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>