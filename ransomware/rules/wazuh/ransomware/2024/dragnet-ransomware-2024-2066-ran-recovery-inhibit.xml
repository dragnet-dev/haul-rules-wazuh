<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2066 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 3e03f4dc-115d-56e0-b3bb-b5236a122667 -->
  <rule id="682157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2066 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>