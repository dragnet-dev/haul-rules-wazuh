<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4134 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 46324831-daca-5820-8a9b-a0765c5a15a2 -->
  <rule id="232483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4134 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>