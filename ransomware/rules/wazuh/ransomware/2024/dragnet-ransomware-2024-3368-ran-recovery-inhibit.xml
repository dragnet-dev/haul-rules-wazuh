<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3368 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: d6d4bef5-d0be-5aee-8c08-daaa2072636b -->
  <rule id="305054" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3368 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>