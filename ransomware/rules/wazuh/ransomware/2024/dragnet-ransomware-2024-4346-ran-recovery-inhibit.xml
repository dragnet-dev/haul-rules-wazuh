<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4346 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 5df74335-de9c-58fc-a55e-9389cb62ab47 -->
  <rule id="703743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4346 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>