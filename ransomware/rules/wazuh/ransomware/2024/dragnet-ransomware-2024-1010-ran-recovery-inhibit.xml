<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1010 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: a3afa477-b8bb-5fe3-86e6-bbd2ec3662b1 -->
  <rule id="746984" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1010 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>