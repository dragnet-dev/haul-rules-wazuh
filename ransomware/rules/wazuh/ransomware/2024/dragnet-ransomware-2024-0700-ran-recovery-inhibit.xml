<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0700 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: 76ddac6a-0d79-5c21-87a3-952ed2364a9b -->
  <rule id="637484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0700 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>