<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2376 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 20297a09-989d-55da-8de8-f5f20abbd835 -->
  <rule id="647620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2376 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>