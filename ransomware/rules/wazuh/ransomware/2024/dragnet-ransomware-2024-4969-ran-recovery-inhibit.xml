<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4969 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 1db71df4-189f-5371-ab95-431a4b98c87f -->
  <rule id="578399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4969 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>