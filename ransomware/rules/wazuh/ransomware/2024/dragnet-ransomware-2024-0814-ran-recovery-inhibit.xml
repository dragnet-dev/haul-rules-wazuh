<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0814 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: b5ab4806-4d1f-53a0-9a50-f997297b2308 -->
  <rule id="361148" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0814 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>