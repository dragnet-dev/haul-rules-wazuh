<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1808 — Event Log Clearing (nitrogen) | Status: experimental | Sigma ID: 0d294f3f-4e0d-524a-9a96-8e9bb9835b66 -->
  <rule id="427193" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1808 — Event Log Clearing (nitrogen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>