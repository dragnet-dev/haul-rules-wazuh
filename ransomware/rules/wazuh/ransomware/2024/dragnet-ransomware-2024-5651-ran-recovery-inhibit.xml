<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5651 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: cc38183b-9688-51b0-a7d0-9ceed28dd476 -->
  <rule id="343818" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5651 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>