<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1389 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7e2b500e-d7b7-5c41-bf27-8c686ebff020 -->
  <rule id="320350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1389 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>