<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1513 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 483391b0-d364-58d2-a941-83d0d8a2d4f5 -->
  <rule id="634267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1513 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>