<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1021 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: d7a98ab1-d9da-5bfe-9d93-c5e2d4c22dfb -->
  <rule id="924778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1021 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>