<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3936 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 90e80605-e8c1-5e3e-a5de-7590f9089105 -->
  <rule id="654806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3936 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>