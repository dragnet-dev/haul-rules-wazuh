<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4397 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 9bc6f554-cbda-54f4-872a-9ecbb579461f -->
  <rule id="488315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4397 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>