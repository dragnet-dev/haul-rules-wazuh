<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3746 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 9af4d42f-2c3b-54b8-b164-1d7619e26eaf -->
  <rule id="467174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3746 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>