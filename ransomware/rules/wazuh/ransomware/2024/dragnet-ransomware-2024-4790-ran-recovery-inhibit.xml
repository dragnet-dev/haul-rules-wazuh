<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4790 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 9aac8e2e-3d5d-5296-9206-2be6f1784dc3 -->
  <rule id="135502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4790 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>