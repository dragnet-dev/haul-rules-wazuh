<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2043 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a2df15e7-f4e0-5112-b06a-fdfd7bed7627 -->
  <rule id="933515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2043 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>