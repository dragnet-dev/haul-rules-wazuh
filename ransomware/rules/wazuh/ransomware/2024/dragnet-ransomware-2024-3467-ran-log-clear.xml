<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3467 — Event Log Clearing (chort) | Status: experimental | Sigma ID: 595023a0-5593-544d-b446-5a4d41a31aa3 -->
  <rule id="620378" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3467 — Event Log Clearing (chort)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>