<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4894 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e77417e6-aea8-55ea-a51f-16d2e1677be8 -->
  <rule id="677417" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4894 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>