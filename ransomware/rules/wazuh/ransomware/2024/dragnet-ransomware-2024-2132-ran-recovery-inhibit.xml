<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2132 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8296a42e-1ceb-5d10-b4c5-2b88c7830f78 -->
  <rule id="527464" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2132 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>