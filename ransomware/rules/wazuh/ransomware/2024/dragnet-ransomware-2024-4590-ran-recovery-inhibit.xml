<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4590 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 8ea818f7-0c3f-5205-8e81-435d3a7cdcbf -->
  <rule id="582818" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4590 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>