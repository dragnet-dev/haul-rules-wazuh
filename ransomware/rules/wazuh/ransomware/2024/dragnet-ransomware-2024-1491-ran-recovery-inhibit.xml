<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1491 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: a02f0ebd-29d0-5715-9cc6-b85a5e3d90ab -->
  <rule id="867534" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1491 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>