<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2704 — Event Log Clearing (dragonransomware) | Status: experimental | Sigma ID: 5b6cf4a2-ef25-5f4e-97f6-c8784cfe0070 -->
  <rule id="647034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2704 — Event Log Clearing (dragonransomware)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>