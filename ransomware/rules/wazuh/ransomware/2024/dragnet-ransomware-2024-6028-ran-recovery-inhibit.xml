<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6028 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: 60a3c748-c84d-5e78-8771-47015b167b50 -->
  <rule id="752607" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6028 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>