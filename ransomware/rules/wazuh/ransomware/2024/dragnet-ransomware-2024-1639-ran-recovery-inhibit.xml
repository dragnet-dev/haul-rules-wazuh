<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1639 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 96678e90-6d1e-58dc-8c56-e70ba0cebae4 -->
  <rule id="746862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1639 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>