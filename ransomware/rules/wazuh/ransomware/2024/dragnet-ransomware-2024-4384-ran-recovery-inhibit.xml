<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4384 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 093f5312-d76c-5cac-a448-e8ad4f9b41cc -->
  <rule id="703531" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4384 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>