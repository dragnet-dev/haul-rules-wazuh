<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2963 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 733e9b39-3cff-5b89-aa8e-f2e8d1efff9c -->
  <rule id="178875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2963 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>