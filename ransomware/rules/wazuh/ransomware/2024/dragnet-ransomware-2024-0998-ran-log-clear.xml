<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0998 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 9730ed45-0320-53e4-8fb2-4b2ba7b32cf3 -->
  <rule id="791117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0998 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>