<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0373 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: f25cfdac-e42d-5044-a2b2-f09f13cb5e86 -->
  <rule id="949725" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0373 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>