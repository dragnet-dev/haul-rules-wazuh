<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0231 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c82dbfef-3d96-5174-b4fd-5801e6a4ab71 -->
  <rule id="854591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0231 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>