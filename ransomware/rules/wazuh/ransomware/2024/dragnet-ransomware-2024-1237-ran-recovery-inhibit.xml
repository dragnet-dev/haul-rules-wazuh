<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1237 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e8f4b5f5-c898-5282-87a9-fa8b48e749b4 -->
  <rule id="313555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1237 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>