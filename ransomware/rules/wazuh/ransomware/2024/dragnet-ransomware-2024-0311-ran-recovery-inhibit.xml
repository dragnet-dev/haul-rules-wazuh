<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0311 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 1b903c55-b50d-52d4-a253-4629a38621b7 -->
  <rule id="964605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0311 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>