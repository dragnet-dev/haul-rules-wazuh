<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4000 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 3fa812a8-8450-5fdf-88ce-60515a1b70a0 -->
  <rule id="218812" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4000 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>