<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1462 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: badff4d3-e1e7-5991-b6fa-dc46eebc7641 -->
  <rule id="554394" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1462 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>