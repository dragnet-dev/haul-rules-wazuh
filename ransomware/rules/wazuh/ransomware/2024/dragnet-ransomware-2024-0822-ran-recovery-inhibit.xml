<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0822 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 8d25ffd3-ab9f-55fe-8586-489404d68ae2 -->
  <rule id="116255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0822 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>