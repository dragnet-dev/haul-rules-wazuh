<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4229 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e8d2ec40-cfe3-5810-b4dc-56a73397ec90 -->
  <rule id="796108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4229 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>