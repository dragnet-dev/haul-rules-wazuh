<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1284 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 57ecd6df-30a5-57a2-93ab-b4e82d5b7097 -->
  <rule id="672616" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1284 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>