<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0676 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 4f80043f-6cc7-5c2b-a807-39d418ffd47f -->
  <rule id="880043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0676 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>