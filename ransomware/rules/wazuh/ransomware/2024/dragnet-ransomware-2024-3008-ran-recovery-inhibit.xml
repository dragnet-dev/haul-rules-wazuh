<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3008 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: be1380eb-ec29-5d2d-b04f-cbe1b68c7445 -->
  <rule id="201380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3008 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>