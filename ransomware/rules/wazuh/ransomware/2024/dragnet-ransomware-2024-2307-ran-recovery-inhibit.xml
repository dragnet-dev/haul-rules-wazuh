<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2307 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 37abd18d-02aa-54c1-a6b0-f0be6ed3e850 -->
  <rule id="743011" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2307 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>