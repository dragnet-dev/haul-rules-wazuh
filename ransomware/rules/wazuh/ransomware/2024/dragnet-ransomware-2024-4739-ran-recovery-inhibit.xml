<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4739 — Recovery Inhibition (play) | Status: experimental | Sigma ID: aa35ec7d-fc7f-5b4e-b696-c8df66c8c297 -->
  <rule id="861196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4739 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>