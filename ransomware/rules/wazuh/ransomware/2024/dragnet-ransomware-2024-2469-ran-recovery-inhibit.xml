<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2469 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 69012d81-b2ad-51c3-9611-bdec3102dbe7 -->
  <rule id="304205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2469 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>