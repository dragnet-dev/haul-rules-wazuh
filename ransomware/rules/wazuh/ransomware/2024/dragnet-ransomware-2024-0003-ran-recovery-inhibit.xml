<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0003 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: aae2d985-aefa-535f-9be2-b6a0d131feac -->
  <rule id="874859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0003 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>