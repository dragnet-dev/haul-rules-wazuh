<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5282 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 14427d1c-c9d2-5886-8c9d-0a34c78f1df1 -->
  <rule id="608451" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5282 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>