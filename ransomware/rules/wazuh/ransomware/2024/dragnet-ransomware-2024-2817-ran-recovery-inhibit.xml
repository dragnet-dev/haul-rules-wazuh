<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2817 — Recovery Inhibition (argonauts) | Status: experimental | Sigma ID: b5e4e323-bacd-5dd5-b27b-a5d8f620047a -->
  <rule id="367183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2817 — Recovery Inhibition (argonauts)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>