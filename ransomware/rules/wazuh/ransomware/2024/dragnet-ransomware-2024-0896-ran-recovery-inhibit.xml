<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0896 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 5c544f54-a34f-5fe4-b07d-627a424c801a -->
  <rule id="680719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0896 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>