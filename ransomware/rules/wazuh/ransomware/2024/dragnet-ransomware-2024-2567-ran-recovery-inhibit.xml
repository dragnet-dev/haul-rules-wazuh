<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2567 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: f826e9f8-d9bb-506a-b081-5135ff15ea7d -->
  <rule id="832309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2567 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>