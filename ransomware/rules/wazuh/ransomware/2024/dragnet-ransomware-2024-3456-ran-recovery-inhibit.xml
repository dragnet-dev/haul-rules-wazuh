<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3456 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 2071e339-08d2-54a2-a267-eab818c969ef -->
  <rule id="715033" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3456 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>