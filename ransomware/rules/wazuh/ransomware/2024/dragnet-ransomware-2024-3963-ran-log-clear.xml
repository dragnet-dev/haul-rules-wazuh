<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3963 — Event Log Clearing (funksec) | Status: experimental | Sigma ID: 7a627cdc-e862-5292-b1a0-10bbcbc5e5a7 -->
  <rule id="262044" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3963 — Event Log Clearing (funksec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>