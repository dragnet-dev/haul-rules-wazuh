<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0143 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 40c134d7-5804-5664-ad79-f208279f1e44 -->
  <rule id="634157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0143 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>