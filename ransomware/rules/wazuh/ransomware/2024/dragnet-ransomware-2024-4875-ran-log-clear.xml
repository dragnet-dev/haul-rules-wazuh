<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4875 — Event Log Clearing (darkvault) | Status: experimental | Sigma ID: 2bf039b9-0cc8-566b-ad3b-e2f973e79a15 -->
  <rule id="548635" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4875 — Event Log Clearing (darkvault)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>