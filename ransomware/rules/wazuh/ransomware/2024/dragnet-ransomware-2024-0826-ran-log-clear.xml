<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0826 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 6c87d863-1023-5434-a61c-70dd8f1e7eb7 -->
  <rule id="942058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0826 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>