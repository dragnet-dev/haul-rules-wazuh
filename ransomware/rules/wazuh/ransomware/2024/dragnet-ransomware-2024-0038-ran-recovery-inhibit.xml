<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0038 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 65f99058-6d8b-5878-ab75-e8e86a9a93c5 -->
  <rule id="255990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0038 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>