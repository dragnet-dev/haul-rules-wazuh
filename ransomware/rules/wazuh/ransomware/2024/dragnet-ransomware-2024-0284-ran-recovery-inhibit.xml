<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0284 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5087adbd-ed3f-5872-b5da-ac39e6c2955a -->
  <rule id="502445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0284 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>