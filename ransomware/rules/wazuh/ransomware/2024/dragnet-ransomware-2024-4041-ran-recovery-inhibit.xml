<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4041 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: c3a1c683-c49d-5031-9a77-1471613f9007 -->
  <rule id="565086" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4041 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>