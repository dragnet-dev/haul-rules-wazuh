<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3716 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 5eee5568-037b-5f45-834d-208f60f186b7 -->
  <rule id="730255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3716 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>