<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0669 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 4674f933-2149-51d5-9517-7070c70a89e4 -->
  <rule id="379993" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0669 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>