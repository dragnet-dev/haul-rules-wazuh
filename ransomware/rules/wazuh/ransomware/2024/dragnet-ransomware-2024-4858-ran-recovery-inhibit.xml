<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4858 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: 4ebb25c2-5035-5276-ac22-e3f305e3f144 -->
  <rule id="315525" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4858 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>