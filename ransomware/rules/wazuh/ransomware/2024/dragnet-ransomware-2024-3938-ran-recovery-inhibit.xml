<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3938 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: dc4d4b6d-45ca-5b24-bd2f-a8d8962943ab -->
  <rule id="344395" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3938 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>