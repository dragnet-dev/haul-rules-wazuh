<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3251 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: aaba69ab-0ef3-565d-a6b9-d600342fd4a2 -->
  <rule id="870669" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3251 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>