<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3854 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: c8af744a-de4f-538f-a1e9-924c17798faa -->
  <rule id="694374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3854 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>