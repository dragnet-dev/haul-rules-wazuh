<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5199 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: eb475172-4b4e-5861-9415-83b7d0ec7964 -->
  <rule id="654751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5199 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>