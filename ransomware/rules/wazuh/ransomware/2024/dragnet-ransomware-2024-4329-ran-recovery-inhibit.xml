<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4329 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: c694415f-5ee4-5b3c-99c4-6c024e106d07 -->
  <rule id="469441" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4329 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>