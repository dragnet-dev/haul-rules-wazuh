<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6000 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: ed95b52c-32f1-5824-9e88-17bd4bc1af37 -->
  <rule id="307315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6000 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>