<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5568 — Recovery Inhibition (play) | Status: experimental | Sigma ID: cbfdf2fc-1798-567c-be9b-64ce300485cb -->
  <rule id="355512" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5568 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>