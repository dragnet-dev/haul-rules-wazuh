<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5720 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 782f20cc-a69d-527d-a195-8ba7996a5e35 -->
  <rule id="452720" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5720 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>