<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0182 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 76da0fa0-7423-5ab9-9ebc-8f8bf4b97be8 -->
  <rule id="547855" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0182 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>