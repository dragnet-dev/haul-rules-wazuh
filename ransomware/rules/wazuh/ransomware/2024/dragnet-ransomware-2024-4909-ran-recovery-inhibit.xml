<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4909 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 1290f51a-6edf-531b-877b-4489f8143d90 -->
  <rule id="365551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4909 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>