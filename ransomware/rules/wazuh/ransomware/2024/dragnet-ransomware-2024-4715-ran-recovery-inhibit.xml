<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4715 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8373c0b3-44fb-55f4-a84e-4351f7bdaebc -->
  <rule id="539800" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4715 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>