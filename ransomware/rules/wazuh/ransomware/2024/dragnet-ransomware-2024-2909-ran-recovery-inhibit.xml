<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2909 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: fd76a8d7-abff-5747-bab9-519366dbeb78 -->
  <rule id="560268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2909 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>