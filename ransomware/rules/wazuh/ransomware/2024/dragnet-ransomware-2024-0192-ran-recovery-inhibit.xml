<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0192 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: a37d06dc-8d25-5a8a-80cb-db7c87ee5f3b -->
  <rule id="860506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0192 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>