<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2594 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2e97614b-877f-58e7-a3f6-a7aa099f12a7 -->
  <rule id="297614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2594 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>