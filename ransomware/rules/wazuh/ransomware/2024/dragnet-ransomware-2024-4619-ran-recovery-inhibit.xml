<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4619 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2cef2804-7d71-5570-8e2d-6e6ea5432aee -->
  <rule id="350328" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4619 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>