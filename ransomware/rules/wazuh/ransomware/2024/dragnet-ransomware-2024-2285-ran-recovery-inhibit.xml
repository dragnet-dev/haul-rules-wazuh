<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2285 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 0f119b79-2f11-525d-b344-f5f6c2ab4228 -->
  <rule id="719157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2285 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>