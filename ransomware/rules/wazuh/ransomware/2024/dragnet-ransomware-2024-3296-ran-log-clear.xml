<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3296 — Event Log Clearing (hunters) | Status: experimental | Sigma ID: 832f3b4a-0f64-57b2-a1c1-1d5c9a2dcda0 -->
  <rule id="432379" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3296 — Event Log Clearing (hunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>