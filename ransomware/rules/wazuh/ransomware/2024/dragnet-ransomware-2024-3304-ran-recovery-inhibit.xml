<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3304 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ca59d34b-c239-585d-b166-a613be36324f -->
  <rule id="641573" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3304 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>