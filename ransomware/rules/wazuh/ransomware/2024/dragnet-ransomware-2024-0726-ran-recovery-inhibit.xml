<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0726 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: b21b92b6-b014-563e-9e64-419fffe303cc -->
  <rule id="994792" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0726 — Recovery Inhibition (nitrogen)</description>
