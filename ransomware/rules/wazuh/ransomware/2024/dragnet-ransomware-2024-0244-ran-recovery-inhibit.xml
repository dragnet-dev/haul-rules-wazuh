<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0244 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 6cf220fd-c8df-5584-8095-a25a2899b316 -->
  <rule id="943220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0244 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>