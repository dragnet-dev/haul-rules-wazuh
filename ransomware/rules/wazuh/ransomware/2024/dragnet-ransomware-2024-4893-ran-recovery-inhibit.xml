<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4893 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 8df71f46-f445-5981-968b-2b0b828805ef -->
  <rule id="134751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4893 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
