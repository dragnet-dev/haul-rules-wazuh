<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2733 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6f8d52af-dc44-5575-9902-53c8d0dc3772 -->
  <rule id="990152" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2733 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>