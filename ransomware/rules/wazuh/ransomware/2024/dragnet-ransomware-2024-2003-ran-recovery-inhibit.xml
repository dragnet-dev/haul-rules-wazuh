<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2003 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 45c056e9-946a-5cf3-8fb9-cd136692b2dc -->
  <rule id="112910" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2003 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>