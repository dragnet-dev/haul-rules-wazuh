<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0447 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 5dab20bd-c11e-5ab9-bcf9-e3757b919e54 -->
  <rule id="697920" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0447 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>