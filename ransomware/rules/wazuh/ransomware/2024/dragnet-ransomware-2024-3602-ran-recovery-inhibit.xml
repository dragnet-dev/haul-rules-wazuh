<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3602 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2c5b1000-550e-5ad3-a7bd-6c36d85a525e -->
  <rule id="931100" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3602 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>