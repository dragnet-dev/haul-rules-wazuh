<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3686 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: ccb2ae2c-c460-59f4-aa53-a0175005ed88 -->
  <rule id="384686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3686 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>