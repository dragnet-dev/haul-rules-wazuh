<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4333 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f07a997f-5812-59f7-912a-a5f76469675d -->
  <rule id="712299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4333 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>