<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5456 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: ad5c97a3-680b-5aa2-a7d4-1d1dc5d3c592 -->
  <rule id="177297" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5456 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>