<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1865 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 922d6a9f-dce8-59c1-be88-a61aa8e1dbef -->
  <rule id="662506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1865 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>