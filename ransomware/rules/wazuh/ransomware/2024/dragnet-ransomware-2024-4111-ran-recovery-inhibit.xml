<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4111 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: d1714195-b3fc-510f-b308-cd8c76e46974 -->
  <rule id="517141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4111 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>