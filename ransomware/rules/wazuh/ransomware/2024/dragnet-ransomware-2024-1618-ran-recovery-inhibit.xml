<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1618 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 11c541bb-9a21-58de-b724-75a5b4b64c9d -->
  <rule id="416667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1618 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>