<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0058 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 02cd3a8d-cd01-56f6-972c-dabff85e2751 -->
  <rule id="347788" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0058 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>