<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5222 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 6661c3c8-9d6f-5a5c-8775-4552538f7d57 -->
  <rule id="265883" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5222 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>