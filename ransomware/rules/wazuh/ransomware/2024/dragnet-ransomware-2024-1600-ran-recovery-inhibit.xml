<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1600 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 25b8f510-aeb3-5e87-9257-2e5cee84492f -->
  <rule id="390351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1600 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>