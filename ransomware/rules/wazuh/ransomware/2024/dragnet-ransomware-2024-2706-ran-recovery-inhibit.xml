<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2706 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 5b514d8d-9962-5009-bb90-e299495bc2c0 -->
  <rule id="664237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2706 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>