<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2641 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: 87fcce83-8886-550e-a2b3-da2c9b7e20c7 -->
  <rule id="466350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2641 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>