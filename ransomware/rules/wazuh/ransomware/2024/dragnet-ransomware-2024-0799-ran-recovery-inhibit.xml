<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0799 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 06adeabc-d58b-5d19-b840-4fbf1ebbdf3f -->
  <rule id="803819" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0799 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>