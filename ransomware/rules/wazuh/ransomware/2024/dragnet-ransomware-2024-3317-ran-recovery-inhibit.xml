<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3317 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 9cee409b-7fad-5961-8dbd-71931ad71b58 -->
  <rule id="517440" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3317 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>