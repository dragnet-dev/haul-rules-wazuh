<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5992 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: ca58e714-f360-508f-8aa6-71289fa0e450 -->
  <rule id="641427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5992 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>