<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3730 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 975d6be4-2253-516e-9b2a-596b923abe07 -->
  <rule id="798187" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3730 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>