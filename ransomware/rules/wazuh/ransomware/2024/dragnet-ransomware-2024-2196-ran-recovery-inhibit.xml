<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2196 — Recovery Inhibition (play) | Status: experimental | Sigma ID: cfe87819-5131-5bfc-beaf-6f9a5d477c47 -->
  <rule id="726878" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2196 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>