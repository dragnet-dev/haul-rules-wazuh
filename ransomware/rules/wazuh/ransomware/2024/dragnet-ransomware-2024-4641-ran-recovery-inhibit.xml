<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4641 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 51ab0cb4-e308-5ecd-9f79-6b84ed1e671e -->
  <rule id="416332" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4641 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>