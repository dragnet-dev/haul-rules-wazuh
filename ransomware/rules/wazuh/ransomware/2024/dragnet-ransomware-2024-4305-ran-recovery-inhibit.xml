<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4305 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: de1335e9-ce04-5efb-8373-9fade4823b7f -->
  <rule id="521335" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4305 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>