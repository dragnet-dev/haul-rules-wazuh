<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2633 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 90674fe9-b847-5f23-88e5-a4cb3e93958e -->
  <rule id="650799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2633 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>