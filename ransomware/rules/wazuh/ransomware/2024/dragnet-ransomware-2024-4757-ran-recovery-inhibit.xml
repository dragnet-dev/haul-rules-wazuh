<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4757 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: fafa3615-f8f4-52d3-9275-61c69438ad8f -->
  <rule id="225036" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4757 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>