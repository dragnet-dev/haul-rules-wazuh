<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4004 — Event Log Clearing (threeam) | Status: experimental | Sigma ID: 0cf62445-d9a9-52c3-a4d1-e7c0ea5bd3b9 -->
  <rule id="376244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4004 — Event Log Clearing (threeam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>