<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5396 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: edcbb602-87bc-513d-beb2-c94a217af918 -->
  <rule id="840116" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5396 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>