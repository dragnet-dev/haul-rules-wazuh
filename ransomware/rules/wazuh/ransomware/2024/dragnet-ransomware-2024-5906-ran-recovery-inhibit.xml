<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5906 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 528264f0-e990-5b79-8519-f4ff2be16269 -->
  <rule id="452239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5906 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>