<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4025 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: cbdecee8-aa3e-5eb6-8890-bfc28affa210 -->
  <rule id="860846" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4025 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>