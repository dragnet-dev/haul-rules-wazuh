<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1331 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 9b69a730-bab3-5974-9b68-c4af8b4b05b8 -->
  <rule id="791147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1331 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>