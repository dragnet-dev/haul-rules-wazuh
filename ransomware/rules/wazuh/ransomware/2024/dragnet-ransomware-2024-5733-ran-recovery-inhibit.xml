<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5733 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 9ea19eeb-385d-5cd7-b3b3-917853cc7be1 -->
  <rule id="561118" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5733 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>