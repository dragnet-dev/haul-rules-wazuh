<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2941 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d6e6d2d1-a558-5405-9d7f-f50db7d9a6f5 -->
  <rule id="905092" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2941 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>