<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0927 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: cefee193-95be-5f82-b3b0-71fbd2745c12 -->
  <rule id="478541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0927 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>