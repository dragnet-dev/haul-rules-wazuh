<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5414 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: 6913ba3f-d0fa-5109-af19-30447570f483 -->
  <rule id="969914" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5414 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>