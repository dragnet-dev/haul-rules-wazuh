<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0607 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9d560756-f796-51e3-9f5e-88581989d94b -->
  <rule id="775607" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0607 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>