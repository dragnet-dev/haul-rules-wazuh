<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4128 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 73b9ca76-5658-52a2-b228-eaf9a91053e2 -->
  <rule id="420746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4128 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>