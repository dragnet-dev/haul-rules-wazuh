<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1793 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 008a1e2b-6d05-5e58-8501-7e1e7bd10dbf -->
  <rule id="937643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1793 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>