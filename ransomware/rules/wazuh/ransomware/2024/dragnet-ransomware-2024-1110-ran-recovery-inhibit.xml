<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1110 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 2366cd7c-e15a-53fd-8361-3c3a05be348e -->
  <rule id="759017" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1110 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>