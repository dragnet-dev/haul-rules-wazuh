<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2359 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 79820cd3-ac0c-5e9b-966b-4751ce8d1a75 -->
  <rule id="477132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2359 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>