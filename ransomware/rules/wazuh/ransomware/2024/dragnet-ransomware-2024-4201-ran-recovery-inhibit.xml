<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4201 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: 6eec41bd-7e8f-568e-85e9-ecefe90dc781 -->
  <rule id="239641" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4201 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>