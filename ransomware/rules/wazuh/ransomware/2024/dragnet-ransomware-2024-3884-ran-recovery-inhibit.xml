<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3884 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 0c3564fc-a0cb-5aae-bdc2-66e124a497a1 -->
  <rule id="277039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3884 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>