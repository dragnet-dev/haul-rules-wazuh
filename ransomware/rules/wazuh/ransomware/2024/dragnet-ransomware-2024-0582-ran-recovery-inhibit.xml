<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0582 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 76472877-b367-5dbb-9b82-c15e375eb0ff -->
  <rule id="547287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0582 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>