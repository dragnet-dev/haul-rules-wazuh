<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1083 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: dd6e732d-bbaa-5702-8c93-56dcfacc48ff -->
  <rule id="947073" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1083 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>