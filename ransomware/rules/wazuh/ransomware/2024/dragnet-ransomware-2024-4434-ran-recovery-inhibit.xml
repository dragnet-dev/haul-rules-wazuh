<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4434 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 75aa11c8-03db-567c-98ca-e7487074b447 -->
  <rule id="237011" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4434 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>