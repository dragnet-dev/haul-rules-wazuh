<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1446 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2f9e565c-a7e9-5ed3-8371-e7be04b68f90 -->
  <rule id="578565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1446 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>