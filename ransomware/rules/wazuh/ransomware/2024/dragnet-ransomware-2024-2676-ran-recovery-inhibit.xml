<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2676 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5fb58e94-735a-50b2-801c-836c0e646c7f -->
  <rule id="750542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2676 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>