<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2627 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 1d2a8e66-8379-5134-b7e3-50fb2a4ede3f -->
  <rule id="392626" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2627 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>