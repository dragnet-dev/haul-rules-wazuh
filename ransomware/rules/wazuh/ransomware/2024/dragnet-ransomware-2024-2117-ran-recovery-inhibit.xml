<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2117 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6eab2e20-827c-5698-85a3-12a442b66b66 -->
  <rule id="133006" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2117 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>