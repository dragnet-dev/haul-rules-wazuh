<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3574 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: 75fb8cb8-75eb-5e61-9f79-22764d7f96e9 -->
  <rule id="512300" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3574 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>