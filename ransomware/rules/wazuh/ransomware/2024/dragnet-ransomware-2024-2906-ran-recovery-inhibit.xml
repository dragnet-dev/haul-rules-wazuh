<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2906 — Recovery Inhibition (redransomware) | Status: deprecated | Sigma ID: a5f50082-32b6-5e91-9104-245aeb469db1 -->
  <rule id="895500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2906 — Recovery Inhibition (redransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
