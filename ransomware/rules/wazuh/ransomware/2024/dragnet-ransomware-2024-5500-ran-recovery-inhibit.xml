<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5500 — Recovery Inhibition (play) | Status: experimental | Sigma ID: dbc67498-a25e-515a-b2cb-50b045d90a8c -->
  <rule id="916674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5500 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>