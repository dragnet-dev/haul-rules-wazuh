<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0069 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: 1f6d9109-17eb-543d-b78d-2d3d282ad4a1 -->
  <rule id="669910" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0069 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>