<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3914 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: b22a736d-a7ee-5565-a9cc-f2d54413c5ab -->
  <rule id="996273" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3914 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>