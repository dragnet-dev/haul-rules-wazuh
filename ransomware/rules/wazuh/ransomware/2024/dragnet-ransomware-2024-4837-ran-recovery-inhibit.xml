<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4837 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 772d00e5-5993-51f1-bf99-fb4796794d95 -->
  <rule id="436500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4837 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>