<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4274 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e450b121-e30e-5cf4-9ba6-fd079b335986 -->
  <rule id="612111" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4274 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>