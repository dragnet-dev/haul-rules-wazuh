<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4310 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 57065997-e067-552d-bfa7-d4c147089216 -->
  <rule id="406599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4310 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>