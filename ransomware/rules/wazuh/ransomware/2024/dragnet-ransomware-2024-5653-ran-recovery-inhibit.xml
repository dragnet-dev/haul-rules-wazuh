<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5653 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 4dac3703-8c0d-5227-941b-c6728e431eed -->
  <rule id="288437" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5653 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>