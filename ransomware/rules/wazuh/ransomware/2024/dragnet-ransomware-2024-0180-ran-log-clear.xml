<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0180 — Event Log Clearing (alphalocker) | Status: experimental | Sigma ID: f3e31acf-bc1a-5599-ac58-df8ccf981ec8 -->
  <rule id="439706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0180 — Event Log Clearing (alphalocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>