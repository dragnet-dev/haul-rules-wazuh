<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2503 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: bf422d61-14f0-5117-bafc-87e78e980bb1 -->
  <rule id="462765" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2503 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>