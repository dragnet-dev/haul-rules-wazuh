<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2468 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4969d213-cd13-5bba-9e55-5666e57d3963 -->
  <rule id="851721" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2468 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>