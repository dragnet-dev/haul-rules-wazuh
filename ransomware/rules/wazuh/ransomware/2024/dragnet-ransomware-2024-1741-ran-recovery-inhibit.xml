<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1741 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 38f0db19-e72c-5607-8cd5-3c0b70c00533 -->
  <rule id="795099" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1741 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>