<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1660 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 6c9e995c-d4aa-5825-ad82-6239e293cf3b -->
  <rule id="943899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1660 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>