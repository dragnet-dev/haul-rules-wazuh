<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3526 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 66f9106b-3909-510a-80e3-0d7df800e7c4 -->
  <rule id="271910" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3526 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>