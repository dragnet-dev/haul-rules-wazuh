<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2643 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: ad12649a-9db0-538c-b274-1067938baf68 -->
  <rule id="931264" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2643 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>