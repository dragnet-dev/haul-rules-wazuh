<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4202 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: daae1a88-5cb2-547f-b9ae-b359c9c8774f -->
  <rule id="957146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4202 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>