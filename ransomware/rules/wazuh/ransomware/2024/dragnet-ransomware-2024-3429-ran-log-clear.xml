<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3429 — Event Log Clearing (stormous) | Status: deprecated | Sigma ID: e42ccb19-04c3-5666-a2e3-44f3a0d4b0b9 -->
  <rule id="609707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3429 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>