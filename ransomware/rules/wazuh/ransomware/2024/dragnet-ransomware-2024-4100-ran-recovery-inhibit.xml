<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4100 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 94ff4a25-9f44-590c-8627-75613978b30e -->
  <rule id="391114" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4100 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>