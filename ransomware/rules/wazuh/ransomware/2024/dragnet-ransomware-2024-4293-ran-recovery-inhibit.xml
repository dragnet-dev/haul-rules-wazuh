<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4293 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 90cdbd35-9b48-59b9-9039-5aac7d702ba1 -->
  <rule id="650909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4293 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>