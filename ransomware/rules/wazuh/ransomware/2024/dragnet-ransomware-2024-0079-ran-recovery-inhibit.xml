<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0079 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: a398c0d4-a669-5098-9e3b-9788c2cfabc0 -->
  <rule id="863800" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0079 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>