<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2851 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a46dfc2a-4c62-5ea9-9e14-4aae85df956b -->
  <rule id="787996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2851 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>