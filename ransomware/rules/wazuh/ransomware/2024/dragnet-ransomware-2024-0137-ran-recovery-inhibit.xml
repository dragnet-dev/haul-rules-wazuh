<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0137 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 88995174-3d96-5a62-9363-60811f569d77 -->
  <rule id="899517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0137 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>