<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3281 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: ea488cc9-65c0-5439-a8ce-510714541d8d -->
  <rule id="251820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3281 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>