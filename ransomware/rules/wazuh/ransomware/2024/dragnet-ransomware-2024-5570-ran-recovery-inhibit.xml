<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5570 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 9e68a7fb-fe8a-5b6e-a803-07d14d65459b -->
  <rule id="838987" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5570 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>