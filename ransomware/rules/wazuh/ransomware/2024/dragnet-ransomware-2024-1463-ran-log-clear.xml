<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1463 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: 3a7d89fd-5408-5c0b-9309-4d4fbaf5d9ae -->
  <rule id="749439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1463 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>