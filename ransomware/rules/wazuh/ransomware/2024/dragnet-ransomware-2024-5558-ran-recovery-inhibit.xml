<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5558 — Recovery Inhibition (ElDorado) | Status: experimental | Sigma ID: 2280df70-faba-59c8-82fd-c21e5f5971b6 -->
  <rule id="539037" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5558 — Recovery Inhibition (ElDorado)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>