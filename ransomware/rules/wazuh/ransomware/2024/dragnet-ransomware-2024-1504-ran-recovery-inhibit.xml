<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1504 — Recovery Inhibition (blackout) | Status: experimental | Sigma ID: 278fe066-99d4-5a82-aba9-9b33114db67d -->
  <rule id="942206" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1504 — Recovery Inhibition (blackout)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>