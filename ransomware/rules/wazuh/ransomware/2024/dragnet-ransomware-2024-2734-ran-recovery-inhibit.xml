<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2734 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 9993d310-03ad-5d81-a769-1dbf995dc818 -->
  <rule id="799013" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2734 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>