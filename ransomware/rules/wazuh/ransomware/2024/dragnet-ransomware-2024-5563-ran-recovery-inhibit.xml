<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5563 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c746dafc-c6e1-54da-8d2c-7bd4443f3a78 -->
  <rule id="663194" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5563 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>