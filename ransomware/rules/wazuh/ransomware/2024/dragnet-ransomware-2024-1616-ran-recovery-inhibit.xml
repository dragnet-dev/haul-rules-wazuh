<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1616 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: b8f526fa-8b68-5cfe-a3dc-643af18f9d37 -->
  <rule id="203526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1616 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>