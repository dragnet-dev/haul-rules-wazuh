<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5894 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 71974029-1e8d-5943-84f3-d915ac803ea1 -->
  <rule id="997402" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5894 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>