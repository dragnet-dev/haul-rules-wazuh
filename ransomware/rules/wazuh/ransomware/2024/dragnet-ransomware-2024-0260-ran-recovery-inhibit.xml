<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0260 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ce1edf0d-14f4-5d4e-87b5-2616f82fde3d -->
  <rule id="445663" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0260 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>