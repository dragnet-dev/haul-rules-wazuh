<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1471 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 281c7442-6635-5e47-88e3-3137f7bccbb1 -->
  <rule id="108744" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1471 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>