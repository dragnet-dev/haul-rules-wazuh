<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4042 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 2a0247a7-2751-5674-9d12-fff4acb0d1a1 -->
  <rule id="523962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4042 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>