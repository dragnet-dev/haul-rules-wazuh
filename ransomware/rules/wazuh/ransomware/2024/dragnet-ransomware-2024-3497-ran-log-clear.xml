<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3497 — Event Log Clearing (bluebox) | Status: experimental | Sigma ID: 70f33103-b828-5f1b-ad19-c54e7912ce9c -->
  <rule id="335331" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3497 — Event Log Clearing (bluebox)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>