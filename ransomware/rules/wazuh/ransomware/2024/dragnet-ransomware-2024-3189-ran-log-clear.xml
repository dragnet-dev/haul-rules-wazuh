<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3189 — Event Log Clearing (dragonransomware) | Status: experimental | Sigma ID: 86a4f7f5-e5ef-5d6c-8dce-14e6a4382cf6 -->
  <rule id="518397" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3189 — Event Log Clearing (dragonransomware)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>