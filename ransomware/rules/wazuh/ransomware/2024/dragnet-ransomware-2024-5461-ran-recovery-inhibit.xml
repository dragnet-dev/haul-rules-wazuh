<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5461 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 9940996c-2295-531d-bdc1-90c9afe00f4c -->
  <rule id="140996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5461 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>