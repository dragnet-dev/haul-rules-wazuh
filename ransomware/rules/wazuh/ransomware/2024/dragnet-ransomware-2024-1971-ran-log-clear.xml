<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1971 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: ad5744b1-bbd3-5c2b-b7b3-66dcc74515d3 -->
  <rule id="935744" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1971 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>