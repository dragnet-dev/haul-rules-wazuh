<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3970 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 50ad1dea-96e7-5b85-b245-235d04a37dbb -->
  <rule id="375709" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3970 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>