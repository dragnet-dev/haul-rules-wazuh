<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0723 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 5a415835-db44-5067-a560-acf65ff92bd8 -->
  <rule id="141583" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0723 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>