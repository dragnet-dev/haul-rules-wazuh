<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4772 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 216ac576-323a-5258-a3b5-ab9a2600d652 -->
  <rule id="246857" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4772 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>