<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0483 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 5d36f11f-c7c0-5c34-9894-bbbfac0f9dab -->
  <rule id="693911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0483 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>