<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6013 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: a435441f-537a-5c0d-aa5c-9d0ff06a70f9 -->
  <rule id="243544" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6013 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>