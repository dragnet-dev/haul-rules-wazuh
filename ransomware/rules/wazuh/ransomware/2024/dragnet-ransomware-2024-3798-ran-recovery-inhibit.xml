<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3798 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: b1da3abc-13dc-5a47-baf2-090cba4ecaea -->
  <rule id="181498" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3798 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>