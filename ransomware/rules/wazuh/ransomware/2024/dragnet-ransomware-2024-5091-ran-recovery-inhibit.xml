<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5091 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: e4cd896c-8a74-5cf3-a5c9-6f2a162866d6 -->
  <rule id="206989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5091 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>