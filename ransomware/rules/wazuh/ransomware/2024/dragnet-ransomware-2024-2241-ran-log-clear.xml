<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2241 — Event Log Clearing (cloak) | Status: deprecated | Sigma ID: 9cd10e5b-d1e1-5bbc-b837-43fb930b26b5 -->
  <rule id="514574" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2241 — Event Log Clearing (cloak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>