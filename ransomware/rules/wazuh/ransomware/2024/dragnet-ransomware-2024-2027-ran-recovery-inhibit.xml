<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2027 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: 70ba67cc-abf4-5cdc-bf4e-29a9bc5642fb -->
  <rule id="110667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2027 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
