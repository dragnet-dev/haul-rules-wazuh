<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2946 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 10eefbf8-41d7-5ac9-9c21-cfe9128f9074 -->
  <rule id="764639" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2946 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>