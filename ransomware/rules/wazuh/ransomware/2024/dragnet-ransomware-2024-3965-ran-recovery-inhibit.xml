<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3965 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1f4e1583-d48c-52be-beb6-e2501dd1cbe2 -->
  <rule id="638158" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3965 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>