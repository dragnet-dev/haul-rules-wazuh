<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4662 — Event Log Clearing (funksec) | Status: experimental | Sigma ID: 7cc5d5f3-d4d4-5486-9ede-e61c34f780d9 -->
  <rule id="594535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4662 — Event Log Clearing (funksec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>