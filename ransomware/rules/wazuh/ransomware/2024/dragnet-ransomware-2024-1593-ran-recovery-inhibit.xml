<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1593 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 4bb29872-8b59-5712-9a36-56f588a75aab -->
  <rule id="411298" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1593 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>