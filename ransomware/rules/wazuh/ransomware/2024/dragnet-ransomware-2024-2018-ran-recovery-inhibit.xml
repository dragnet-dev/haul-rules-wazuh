<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2018 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: ec46c8e1-8595-5202-98e2-99422e2c1b98 -->
  <rule id="283488" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2018 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>