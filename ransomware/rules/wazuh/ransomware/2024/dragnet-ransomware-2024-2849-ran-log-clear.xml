<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2849 — Event Log Clearing (zerotolerance) | Status: experimental | Sigma ID: c851815f-dc46-561a-b4f1-9c5bc0556dae -->
  <rule id="485181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2849 — Event Log Clearing (zerotolerance)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>