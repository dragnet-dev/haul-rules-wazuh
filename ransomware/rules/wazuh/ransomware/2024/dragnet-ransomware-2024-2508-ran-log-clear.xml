<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2508 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: c53bcd6e-1de5-583c-b8a6-683c34912240 -->
  <rule id="735309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2508 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>