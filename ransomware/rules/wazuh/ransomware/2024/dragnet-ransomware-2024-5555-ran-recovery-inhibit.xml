<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5555 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: ebf1568e-79ac-5d3f-99ba-836a0333468e -->
  <rule id="275156" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5555 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
