<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1127 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5e75e5fb-15f9-5c0c-84b8-bdfe8bdc9329 -->
  <rule id="716145" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1127 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>