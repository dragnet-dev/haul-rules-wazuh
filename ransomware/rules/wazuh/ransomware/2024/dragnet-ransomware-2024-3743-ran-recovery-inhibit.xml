<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3743 — Recovery Inhibition (dAn0n) | Status: experimental | Sigma ID: cf1ee26c-efa7-5ff2-bea3-1995e35aff0b -->
  <rule id="904142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3743 — Recovery Inhibition (dAn0n)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>