  <rule id="758849" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0868 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
