<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4035 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 64549f39-cf50-5e65-9003-48671c232198 -->
  <rule id="232799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4035 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>