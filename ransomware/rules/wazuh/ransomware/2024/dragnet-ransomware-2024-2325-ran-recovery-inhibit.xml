<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2325 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: fe64e22d-2cbb-5692-81e5-c937135975a8 -->
  <rule id="574382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2325 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>