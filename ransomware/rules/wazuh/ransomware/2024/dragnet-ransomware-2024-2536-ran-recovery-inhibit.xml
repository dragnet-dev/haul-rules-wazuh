<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2536 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: a1427992-f541-54d2-8281-4722597df17d -->
  <rule id="214279" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2536 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>