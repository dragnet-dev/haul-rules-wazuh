<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5515 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: ef5ccfb6-b8ca-54b4-9cba-37680ad2422e -->
  <rule id="913199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5515 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>