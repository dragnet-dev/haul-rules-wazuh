<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5197 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 7a6bcfcc-6a0a-521c-a99d-59bec3eb7d5c -->
  <rule id="624719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5197 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>