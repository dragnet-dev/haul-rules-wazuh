<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1530 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 82a91b43-f1d8-5c73-9b17-a27b40d5bf15 -->
  <rule id="416667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1530 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>