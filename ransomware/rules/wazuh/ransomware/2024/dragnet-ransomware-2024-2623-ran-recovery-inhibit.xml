<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2623 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 75977873-8f95-5556-a8b8-215370c1b55c -->
  <rule id="497787" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2623 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>