<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0299 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 665d3f48-7551-568e-b8cc-b3c65a274383 -->
  <rule id="904543" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0299 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>