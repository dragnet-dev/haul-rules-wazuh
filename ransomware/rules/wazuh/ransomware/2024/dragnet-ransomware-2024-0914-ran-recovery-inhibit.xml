<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0914 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 9b45e405-46c7-5981-bdcf-3526703d4968 -->
  <rule id="787344" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0914 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>