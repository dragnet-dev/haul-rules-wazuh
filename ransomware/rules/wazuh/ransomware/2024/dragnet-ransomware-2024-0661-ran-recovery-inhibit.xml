<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0661 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 008580c0-4ebc-50e9-a384-95775e2598a7 -->
  <rule id="572920" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0661 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>