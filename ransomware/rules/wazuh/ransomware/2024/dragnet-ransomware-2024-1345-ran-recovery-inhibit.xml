<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1345 — Recovery Inhibition (hellcat) | Status: deprecated | Sigma ID: faf5a48a-c649-5e21-8bbb-c613af25498f -->
  <rule id="224904" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1345 — Recovery Inhibition (hellcat)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>