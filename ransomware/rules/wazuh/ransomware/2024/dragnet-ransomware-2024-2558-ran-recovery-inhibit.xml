<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2558 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: fe7e43c9-cdcf-5f30-9287-d99f855b77f3 -->
  <rule id="576643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2558 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>