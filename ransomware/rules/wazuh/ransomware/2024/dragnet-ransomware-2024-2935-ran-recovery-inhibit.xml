<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2935 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 966cde9c-42cf-5274-91d4-aeb0fe4ebcae -->
  <rule id="460030" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2935 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>