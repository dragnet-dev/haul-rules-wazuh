<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3071 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f0adb0fb-2f8f-5d8f-8380-0fd409687a99 -->
  <rule id="871790" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3071 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>