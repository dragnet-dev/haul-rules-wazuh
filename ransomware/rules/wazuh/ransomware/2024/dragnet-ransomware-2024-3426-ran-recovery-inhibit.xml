<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3426 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: dfb5ebf2-de4b-5c65-ab6d-1d6af31a0935 -->
  <rule id="263755" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3426 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>