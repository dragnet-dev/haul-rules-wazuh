<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5507 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: b5013ce6-4774-5cfb-be2b-b4a5c48b4691 -->
  <rule id="140220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5507 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>