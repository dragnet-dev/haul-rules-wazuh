<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5148 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 35976902-c3af-5a7a-8a89-1bba66d12c63 -->
  <rule id="997690" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5148 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>