<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5659 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 521c0f09-d219-5667-9a4f-1751d63cbc7d -->
  <rule id="535695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5659 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>