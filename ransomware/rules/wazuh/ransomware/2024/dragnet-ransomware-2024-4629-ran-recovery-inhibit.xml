<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4629 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 66f1d6d9-f5d4-54db-abc5-6924c0f9f257 -->
  <rule id="913896" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4629 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>