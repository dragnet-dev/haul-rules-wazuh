<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0499 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 4fcafb45-bf3b-5a3b-8059-f635e13544a7 -->
  <rule id="829307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0499 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>