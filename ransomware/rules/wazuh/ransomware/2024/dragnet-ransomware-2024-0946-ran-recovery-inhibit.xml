<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0946 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 5e044831-6ac9-5f26-a0dd-8d4221b6798c -->
  <rule id="504483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0946 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>