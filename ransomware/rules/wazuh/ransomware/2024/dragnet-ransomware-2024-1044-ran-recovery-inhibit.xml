<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1044 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 6645281a-cda8-5993-85e7-5be65d2a114e -->
  <rule id="445281" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1044 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>