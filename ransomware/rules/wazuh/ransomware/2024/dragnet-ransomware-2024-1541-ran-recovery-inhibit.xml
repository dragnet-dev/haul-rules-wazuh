<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1541 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 55873768-fef8-5618-ac87-8bd3939d4275 -->
  <rule id="287376" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1541 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>