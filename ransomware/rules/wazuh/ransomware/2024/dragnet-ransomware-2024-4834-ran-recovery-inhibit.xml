<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4834 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: 4b16de54-dd53-550a-9341-9c01d89e5c50 -->
  <rule id="224318" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4834 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
