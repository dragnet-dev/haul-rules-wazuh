<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2678 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: d9fd3eed-d645-5fdd-a138-12e0467f3cd0 -->
  <rule id="433982" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2678 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>