<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0031 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 8b77eb05-6e2b-5165-8989-60b1a2964e14 -->
  <rule id="978347" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0031 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>