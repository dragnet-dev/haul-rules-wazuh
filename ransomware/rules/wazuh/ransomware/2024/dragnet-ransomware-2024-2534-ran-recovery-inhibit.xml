<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2534 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 2c614cd3-8549-5d50-94e5-97bdf23359ae -->
  <rule id="721389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2534 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>