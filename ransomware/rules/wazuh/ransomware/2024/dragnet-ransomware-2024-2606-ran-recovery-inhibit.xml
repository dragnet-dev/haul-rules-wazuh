<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2606 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: aa21f48e-0235-5475-94a0-8062e731efea -->
  <rule id="123514" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2606 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>