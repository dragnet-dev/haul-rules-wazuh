<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6004 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: b9c2f9fe-05b4-5f78-a3c2-cadc1f0ada3e -->
  <rule id="466079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6004 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>