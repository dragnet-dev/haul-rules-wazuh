<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2419 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: bb999c6f-5265-5ff1-90a2-b5434353c9bf -->
  <rule id="407996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2419 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>