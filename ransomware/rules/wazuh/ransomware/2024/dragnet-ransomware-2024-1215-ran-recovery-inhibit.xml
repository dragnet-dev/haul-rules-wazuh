<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1215 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 3d7740e8-d5ed-5948-b9f9-39e2024f25b8 -->
  <rule id="983854" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1215 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>