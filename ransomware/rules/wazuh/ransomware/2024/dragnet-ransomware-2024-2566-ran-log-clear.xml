<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2566 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: dd6a0e1a-6858-5ad7-bd27-dcbf2f1d9520 -->
  <rule id="374574" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2566 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>