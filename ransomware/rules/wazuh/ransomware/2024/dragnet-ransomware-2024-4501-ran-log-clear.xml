<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4501 — Event Log Clearing (dAn0n) | Status: experimental | Sigma ID: a51a9d43-dbaa-550c-9f9c-ce48ef2a5121 -->
  <rule id="992317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4501 — Event Log Clearing (dAn0n)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>