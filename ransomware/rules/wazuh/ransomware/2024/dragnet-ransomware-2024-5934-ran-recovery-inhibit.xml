<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5934 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: e4254f8c-e6a4-50ff-8258-71bbd9dba2ba -->
  <rule id="608079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5934 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>