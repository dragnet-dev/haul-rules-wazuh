<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4436 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 2ce273b5-6fb4-5c88-a2b8-13ded90a8aef -->
  <rule id="792379" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4436 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>