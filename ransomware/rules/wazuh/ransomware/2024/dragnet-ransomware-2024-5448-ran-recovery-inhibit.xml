<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5448 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: a304384e-e7bd-5fdd-be12-af9529db9ca2 -->
  <rule id="230438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5448 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>