<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0630 — Event Log Clearing (everest) | Status: experimental | Sigma ID: 3a389526-aa5a-5cf6-a1d7-f59fbc2fe33b -->
  <rule id="538952" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0630 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>