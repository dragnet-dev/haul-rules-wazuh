<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5919 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: db6e3db2-75f7-535f-837b-6a5c82991017 -->
  <rule id="324061" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5919 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>