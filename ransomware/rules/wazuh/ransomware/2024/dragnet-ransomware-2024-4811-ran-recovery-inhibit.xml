<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4811 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1407c6e6-55b9-5200-b9e0-13a8ace1e587 -->
  <rule id="103950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4811 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>