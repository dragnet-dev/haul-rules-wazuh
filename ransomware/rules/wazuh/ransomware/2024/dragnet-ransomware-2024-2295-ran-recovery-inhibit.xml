<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2295 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ad47adf2-516f-5ef9-800a-9a813a406070 -->
  <rule id="941005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2295 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>