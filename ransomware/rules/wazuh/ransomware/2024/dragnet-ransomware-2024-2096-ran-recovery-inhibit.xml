<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2096 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 7a361b15-3f11-5ede-8b5d-7d187dfce324 -->
  <rule id="257787" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2096 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>