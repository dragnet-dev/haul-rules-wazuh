<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1642 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 9c2d55a0-6226-596a-8858-bb6727d0bdf5 -->
  <rule id="800555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1642 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>