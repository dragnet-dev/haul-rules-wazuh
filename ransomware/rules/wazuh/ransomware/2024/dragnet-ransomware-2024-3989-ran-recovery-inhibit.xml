<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3989 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1f9bf3d7-e269-533c-a999-9b22dbe17409 -->
  <rule id="596861" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3989 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>