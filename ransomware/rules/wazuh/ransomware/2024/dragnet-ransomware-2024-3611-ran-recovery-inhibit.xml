<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3611 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: c0fc6dd2-94eb-5210-b181-f621d0c701e9 -->
  <rule id="555629" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3611 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>