<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2107 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: baf0be68-8df9-56ed-a7a9-26f786d1d3b8 -->
  <rule id="557150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2107 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>