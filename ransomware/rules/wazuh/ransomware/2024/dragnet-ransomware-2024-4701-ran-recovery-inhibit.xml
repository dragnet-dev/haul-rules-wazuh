<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4701 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: e91cfcd7-5417-54a1-84d8-6deb9dec01cd -->
  <rule id="810460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4701 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>