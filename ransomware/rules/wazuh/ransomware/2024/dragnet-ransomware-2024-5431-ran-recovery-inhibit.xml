<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5431 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5a089f62-f2d8-593b-be5b-85f5f0f6237d -->
  <rule id="641439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5431 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>