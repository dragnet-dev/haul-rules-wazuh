<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1680 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 4a60a457-543e-5186-a30b-21b361226dd9 -->
  <rule id="393704" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1680 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>