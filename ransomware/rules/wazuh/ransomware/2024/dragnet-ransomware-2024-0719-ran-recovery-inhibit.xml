<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0719 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 9d8e5a37-4740-5799-9fdb-d86d69b2a1ec -->
  <rule id="542010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0719 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>