<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4989 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: 8fdb8e77-d115-52e5-b9dd-3971deada3d2 -->
  <rule id="592462" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4989 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>