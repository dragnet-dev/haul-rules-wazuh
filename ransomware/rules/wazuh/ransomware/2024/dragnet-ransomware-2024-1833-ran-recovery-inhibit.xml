<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1833 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: fe245329-3663-58c3-b185-0a83a50f0951 -->
  <rule id="842453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1833 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>