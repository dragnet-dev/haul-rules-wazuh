<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2375 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 5146264f-0106-5805-8cb6-7203ce67646d -->
  <rule id="746264" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2375 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>