<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5921 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: 72e25aee-514e-5b57-bc24-dd7efd375a57 -->
  <rule id="166010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5921 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>