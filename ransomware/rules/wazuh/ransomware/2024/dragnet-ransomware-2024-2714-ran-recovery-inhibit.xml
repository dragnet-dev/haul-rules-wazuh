<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2714 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 1da265a5-3ec7-556c-87b6-00b1671f4539 -->
  <rule id="488250" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2714 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
