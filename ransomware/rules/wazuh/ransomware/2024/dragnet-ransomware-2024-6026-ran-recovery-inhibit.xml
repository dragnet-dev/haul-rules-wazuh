<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6026 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0d60b35c-5138-5a71-92f9-da4d72e30c33 -->
  <rule id="477135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6026 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>