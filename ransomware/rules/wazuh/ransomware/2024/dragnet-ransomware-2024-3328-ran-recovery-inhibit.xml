<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3328 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: b0995af0-b8ae-56c8-b6d3-10ea53ecdf4b -->
  <rule id="975930" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3328 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>