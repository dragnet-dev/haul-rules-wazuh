<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5187 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 2dd29641-d2f5-5649-a856-94736533f66d -->
  <rule id="232964" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5187 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>