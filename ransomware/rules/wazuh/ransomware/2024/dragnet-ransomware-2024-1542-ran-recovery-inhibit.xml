<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1542 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 12f286b6-b670-5564-b3a7-8ad5b79513d1 -->
  <rule id="716587" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1542 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>