<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1246 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: f0186244-45b9-53f5-8f42-d89847bdafb9 -->
  <rule id="701862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1246 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>