<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4447 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 3fdbbd58-dd1e-5bc8-8ef9-9e731b8cbced -->
  <rule id="685021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4447 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>