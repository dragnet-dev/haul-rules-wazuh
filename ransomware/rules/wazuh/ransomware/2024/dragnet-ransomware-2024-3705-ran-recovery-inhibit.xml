<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3705 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 61c3117e-988c-50ca-8901-d4150ea4d5a9 -->
  <rule id="983117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3705 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>