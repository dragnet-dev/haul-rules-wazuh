<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5527 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 9d84a99d-eb60-5ae5-8c58-c3564fe01d94 -->
  <rule id="825549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5527 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>