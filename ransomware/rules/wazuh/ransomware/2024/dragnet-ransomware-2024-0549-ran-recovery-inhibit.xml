<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0549 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1ca6b48c-ab34-50be-862f-2f45f66469d0 -->
  <rule id="238748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0549 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>