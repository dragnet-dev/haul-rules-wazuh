<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2746 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: ace66397-e657-53c9-baf8-9b3142c9e7f5 -->
  <rule id="166663" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2746 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>