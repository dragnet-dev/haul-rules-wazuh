<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6012 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: ed0f79bd-edda-568f-bebe-e9b0b72261b6 -->
  <rule id="293579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6012 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>