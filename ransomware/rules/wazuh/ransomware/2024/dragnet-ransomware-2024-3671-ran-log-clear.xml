<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3671 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: a89859bf-5d8e-5f7b-8dc3-2f9f9cbacf6c -->
  <rule id="289859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3671 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>