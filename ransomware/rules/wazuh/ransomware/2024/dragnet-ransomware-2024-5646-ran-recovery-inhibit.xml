<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5646 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: c3a3ef56-58d8-50d5-9855-2a3503020c8a -->
  <rule id="664687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5646 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>