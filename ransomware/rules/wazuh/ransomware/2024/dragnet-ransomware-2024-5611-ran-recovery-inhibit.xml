<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5611 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 840ce537-e392-5e7b-9318-fcd7bd1600b9 -->
  <rule id="452465" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5611 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>