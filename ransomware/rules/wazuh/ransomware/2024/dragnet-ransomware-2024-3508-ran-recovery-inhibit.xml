<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3508 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 83fbd2bb-ae01-5989-a2e1-dc06270391d5 -->
  <rule id="839972" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3508 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>