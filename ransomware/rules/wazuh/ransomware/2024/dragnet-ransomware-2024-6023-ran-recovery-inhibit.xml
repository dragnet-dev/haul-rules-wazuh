<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6023 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: fcd696a6-00cb-504e-8591-0f6f23da4a2c -->
  <rule id="545696" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6023 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>