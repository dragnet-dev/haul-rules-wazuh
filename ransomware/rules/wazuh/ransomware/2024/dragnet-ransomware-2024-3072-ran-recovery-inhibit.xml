<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3072 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: edd239a5-fbec-57bf-9bc2-ff84ffbe17f6 -->
  <rule id="305239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3072 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>