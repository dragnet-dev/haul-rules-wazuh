<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5403 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 945a6fe7-9798-582c-9925-d02965b49d96 -->
  <rule id="720911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5403 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>