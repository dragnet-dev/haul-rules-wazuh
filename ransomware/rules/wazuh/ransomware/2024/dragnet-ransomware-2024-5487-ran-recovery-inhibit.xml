<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5487 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 7eacfc46-15d3-53fc-8168-92a368730fe5 -->
  <rule id="301820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5487 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>