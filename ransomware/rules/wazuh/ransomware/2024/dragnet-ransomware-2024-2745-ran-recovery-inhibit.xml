<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2745 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 151d4004-7e20-5726-800f-8b9342d6de8d -->
  <rule id="729400" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2745 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>