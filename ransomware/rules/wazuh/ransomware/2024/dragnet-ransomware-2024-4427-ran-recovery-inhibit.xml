<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4427 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: f0626c34-0bf4-553d-9704-2f7a389627af -->
  <rule id="710028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4427 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>