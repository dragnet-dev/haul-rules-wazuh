<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4183 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 4331985a-9b7f-5f06-876c-7e7f4c6f2a5d -->
  <rule id="831985" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4183 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>