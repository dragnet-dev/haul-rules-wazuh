<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0630 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 2245e6ef-28d7-5368-a277-0b270b2be71f -->
  <rule id="449550" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0630 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>