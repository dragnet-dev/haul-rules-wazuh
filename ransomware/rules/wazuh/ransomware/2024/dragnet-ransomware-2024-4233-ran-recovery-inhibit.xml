<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4233 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: eb9d18aa-0ac2-5ee8-9818-ad43f48d93e9 -->
  <rule id="275718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4233 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>