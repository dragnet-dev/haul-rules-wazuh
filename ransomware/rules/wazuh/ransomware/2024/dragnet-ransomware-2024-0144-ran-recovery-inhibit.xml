<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0144 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: c1d0d957-ed07-5c95-b38c-3a2113002f3a -->
  <rule id="518539" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0144 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>