<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1191 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 3f388c8c-15d6-52e8-aee2-280e24cc6ec4 -->
  <rule id="214220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1191 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>