<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1226 — Recovery Inhibition (dAn0n) | Status: experimental | Sigma ID: b34677b4-2ed9-5018-853b-eeaf8903ffd5 -->
  <rule id="334677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1226 — Recovery Inhibition (dAn0n)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>