<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0105 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: eb057930-86ff-550a-88cc-03270d1ce85e -->
  <rule id="650579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0105 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>