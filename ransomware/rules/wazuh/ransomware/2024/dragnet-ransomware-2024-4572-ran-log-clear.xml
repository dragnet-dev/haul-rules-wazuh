<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4572 — Event Log Clearing (blackout) | Status: experimental | Sigma ID: d0e6e282-6e88-5fe5-95b0-565c2c70744d -->
  <rule id="751502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4572 — Event Log Clearing (blackout)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>