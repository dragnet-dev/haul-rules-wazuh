<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5452 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 33916f6e-e69c-5dc5-8fee-ea89321d796f -->
  <rule id="126716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5452 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>