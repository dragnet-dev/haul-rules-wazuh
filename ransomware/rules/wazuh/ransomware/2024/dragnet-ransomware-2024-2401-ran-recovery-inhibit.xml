<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2401 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 4f9d652e-5497-555e-b28c-9a0c0e1f22e9 -->
  <rule id="479765" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2401 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>