<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5536 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ff42d9f3-fbfb-5c7f-965a-a34653014335 -->
  <rule id="586859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5536 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>