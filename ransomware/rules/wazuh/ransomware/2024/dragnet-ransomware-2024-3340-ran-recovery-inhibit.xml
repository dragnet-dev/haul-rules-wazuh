<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3340 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 465b9049-5ca5-5b8e-ab5d-4f0577402f77 -->
  <rule id="351904" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3340 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>