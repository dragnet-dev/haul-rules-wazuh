<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4960 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1e6b7ac9-dd59-5872-a0ee-e5ec320acd69 -->
  <rule id="963884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4960 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>