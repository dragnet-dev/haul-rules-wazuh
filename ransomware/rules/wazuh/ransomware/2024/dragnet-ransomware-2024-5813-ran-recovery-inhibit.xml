<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5813 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 4fc7fe13-5aae-5cc7-abad-7640dbf9a3a7 -->
  <rule id="668606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5813 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>