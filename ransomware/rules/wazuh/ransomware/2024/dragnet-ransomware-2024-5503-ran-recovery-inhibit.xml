<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5503 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 1dedfae6-589d-55c2-8b65-90325f61ab98 -->
  <rule id="261466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5503 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>