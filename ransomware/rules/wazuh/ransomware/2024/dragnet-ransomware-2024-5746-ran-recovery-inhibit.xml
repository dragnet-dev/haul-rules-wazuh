<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5746 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: bc49b7aa-946c-5b6d-935e-a0dc5810597b -->
  <rule id="415957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5746 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>