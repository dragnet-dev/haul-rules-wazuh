<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6018 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 79eca5c8-fe49-55a2-ae46-2207f6002224 -->
  <rule id="673705" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6018 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>