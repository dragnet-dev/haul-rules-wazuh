<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2691 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 9a7030ad-82b0-5f43-91e4-4e4c1491d328 -->
  <rule id="747030" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2691 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>