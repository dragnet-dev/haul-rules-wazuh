<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1768 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: cfedafbf-0087-55cb-b6d7-f83fdb3b1abd -->
  <rule id="226799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1768 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>