<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3381 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b7a6cc5b-a803-5e82-82a9-97d8c4a5139f -->
  <rule id="419660" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3381 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>