<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4386 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 09c99bcd-9f8d-55ab-bfdd-0a3bff296b4b -->
  <rule id="519132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4386 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>