<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5261 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 035da179-78e5-5039-a2d1-4e23f1a1b62a -->
  <rule id="278179" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5261 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>