<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4836 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: 54937d8f-7315-5541-a75a-18beb2e647d8 -->
  <rule id="790058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4836 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>