<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0815 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 54584c95-96fd-5ee1-8ace-0962e91bb81f -->
  <rule id="733569" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0815 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>