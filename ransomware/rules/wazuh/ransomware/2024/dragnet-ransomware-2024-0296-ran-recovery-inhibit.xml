<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0296 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 1a4953c8-4968-5cdf-8133-760d64180ffb -->
  <rule id="739260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0296 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>