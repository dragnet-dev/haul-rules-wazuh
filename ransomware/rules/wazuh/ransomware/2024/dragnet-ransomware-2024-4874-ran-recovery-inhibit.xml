<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4874 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 99bb7c3f-bd96-538e-b622-48edeede8403 -->
  <rule id="585084" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4874 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>