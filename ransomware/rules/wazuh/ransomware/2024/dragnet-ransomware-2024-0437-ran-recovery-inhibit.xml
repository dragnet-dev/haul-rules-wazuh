<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0437 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 44eafff4-eb79-5544-8b2e-1cc0f0a6ba75 -->
  <rule id="343743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0437 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>