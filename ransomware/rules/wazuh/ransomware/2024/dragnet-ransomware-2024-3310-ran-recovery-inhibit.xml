<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3310 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: feaa85c5-6d8c-5b7b-a40a-38387cbae887 -->
  <rule id="319485" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3310 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>