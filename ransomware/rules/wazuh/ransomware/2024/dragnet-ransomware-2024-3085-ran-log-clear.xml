<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3085 — Event Log Clearing (moneymessage) | Status: experimental | Sigma ID: 9c325dca-4b8d-5e4f-8530-5bd58febc9d2 -->
  <rule id="801213" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3085 — Event Log Clearing (moneymessage)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>