<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2254 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c6a287b2-66e3-5cff-a6c3-0fd7c9539d56 -->
  <rule id="326287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2254 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>