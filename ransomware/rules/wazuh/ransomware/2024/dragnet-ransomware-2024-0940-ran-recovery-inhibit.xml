<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0940 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 10721f62-9322-5e3c-99fd-ac8621dbd0ae -->
  <rule id="915516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0940 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>