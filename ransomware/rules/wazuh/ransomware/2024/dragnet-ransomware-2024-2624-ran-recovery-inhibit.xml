<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2624 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 514669db-945b-5b71-aa78-77d7c236ed80 -->
  <rule id="234717" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2624 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>