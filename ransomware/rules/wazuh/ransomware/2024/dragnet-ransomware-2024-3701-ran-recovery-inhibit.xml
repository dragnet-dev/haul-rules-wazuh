<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3701 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7de586b4-bd18-5afb-beed-964137b162da -->
  <rule id="314586" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3701 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>