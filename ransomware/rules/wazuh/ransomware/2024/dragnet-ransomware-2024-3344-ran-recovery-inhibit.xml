<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3344 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 2bc48a17-71ed-5351-a742-80afcd34bb63 -->
  <rule id="320778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3344 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>