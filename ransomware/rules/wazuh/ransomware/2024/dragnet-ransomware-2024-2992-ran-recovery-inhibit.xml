<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2992 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 2e79154b-600c-54fa-9a8f-6f591be78a37 -->
  <rule id="279154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2992 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>