<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2755 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 2a1ce09f-a1d6-51a6-9ce4-cfbd049d405e -->
  <rule id="279820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2755 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>