<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3361 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5b1d409a-502a-5f3d-aa49-e877c7b01b56 -->
  <rule id="658940" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3361 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>