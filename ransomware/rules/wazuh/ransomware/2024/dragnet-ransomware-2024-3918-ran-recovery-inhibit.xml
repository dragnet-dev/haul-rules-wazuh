<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3918 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 9b3b03ee-6a1f-5426-82e4-52ec5f2d8524 -->
  <rule id="785903" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3918 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>