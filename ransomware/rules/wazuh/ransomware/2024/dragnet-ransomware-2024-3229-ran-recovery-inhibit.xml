<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3229 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 24a1e453-8a63-5d3d-952f-88af23b52b0a -->
  <rule id="107045" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3229 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>