<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1039 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 888728fd-e346-5ec8-b2ea-41d9279e0e88 -->
  <rule id="819663" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1039 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>