<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5768 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8d72689b-179d-5077-9059-0efdcfebd08a -->
  <rule id="617268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5768 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>