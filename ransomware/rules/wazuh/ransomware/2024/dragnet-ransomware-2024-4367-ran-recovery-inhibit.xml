<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4367 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: a518ac5e-093f-5c04-aacb-09c75b742ab5 -->
  <rule id="992780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4367 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>