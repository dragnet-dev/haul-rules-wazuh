<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3808 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 9a01d5df-af70-5c28-b883-1b38eea9b37b -->
  <rule id="764295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3808 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>