<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2434 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a035be07-ad8f-55c1-8fde-76c61617a8fb -->
  <rule id="869150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2434 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>