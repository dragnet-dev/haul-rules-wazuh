  <rule id="468413" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2288 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
