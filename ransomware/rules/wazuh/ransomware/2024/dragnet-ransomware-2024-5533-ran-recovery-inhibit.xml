<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5533 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 49046268-6201-5b9f-9508-fd4b028ad052 -->
  <rule id="504626" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5533 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>