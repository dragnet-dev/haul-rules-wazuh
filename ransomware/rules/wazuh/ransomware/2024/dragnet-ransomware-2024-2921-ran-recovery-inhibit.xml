<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2921 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 266b0d07-95df-5c1c-9c2d-53cccc1b10d1 -->
  <rule id="627330" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2921 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>