<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4640 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: f3312d56-408e-5f85-9a97-afd08dd0d3f4 -->
  <rule id="753005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4640 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>