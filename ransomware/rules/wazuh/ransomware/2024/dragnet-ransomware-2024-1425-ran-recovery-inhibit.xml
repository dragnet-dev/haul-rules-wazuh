<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1425 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0a86abd0-be71-5933-a100-857829904578 -->
  <rule id="951005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1425 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>