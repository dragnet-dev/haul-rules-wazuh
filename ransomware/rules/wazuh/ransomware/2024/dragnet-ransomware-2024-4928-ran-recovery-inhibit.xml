<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4928 — Recovery Inhibition (malekteam) | Status: experimental | Sigma ID: d1bed770-148c-5d45-8863-5ad19b7d629c -->
  <rule id="996297" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4928 — Recovery Inhibition (malekteam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>