<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1598 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: c703bea4-be35-5751-a954-22c6dca6f1b6 -->
  <rule id="652158" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1598 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>