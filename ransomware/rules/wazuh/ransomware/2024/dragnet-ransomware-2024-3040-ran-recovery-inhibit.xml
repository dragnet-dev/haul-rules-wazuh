<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3040 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: fad17395-bdf1-505a-b2e8-e9190478e94c -->
  <rule id="513173" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3040 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>