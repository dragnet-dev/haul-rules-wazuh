<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5697 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: d184e02e-291d-5f56-8010-55d46d379f60 -->
  <rule id="409580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5697 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>