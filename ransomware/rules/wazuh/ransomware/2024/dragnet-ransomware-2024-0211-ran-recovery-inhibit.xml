<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0211 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 2db08dc3-3775-5fa0-b051-5faab431424e -->
  <rule id="369741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0211 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>