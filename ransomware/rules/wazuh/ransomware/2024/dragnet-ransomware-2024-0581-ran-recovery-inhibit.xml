<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0581 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3907cad7-d695-5128-a0a7-0a2cd7c13462 -->
  <rule id="200394" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0581 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>