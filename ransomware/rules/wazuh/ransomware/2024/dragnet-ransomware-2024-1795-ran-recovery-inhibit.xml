<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1795 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 75467a63-3c11-5e04-b2af-12fdc78779f7 -->
  <rule id="407482" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1795 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>