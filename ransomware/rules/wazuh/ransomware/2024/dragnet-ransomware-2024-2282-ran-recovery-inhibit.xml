<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2282 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2ca48c00-9afb-51fc-bc68-118c02a9635e -->
  <rule id="343180" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2282 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>