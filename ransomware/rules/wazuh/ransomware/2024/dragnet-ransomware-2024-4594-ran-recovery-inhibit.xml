<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4594 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: 2d658f27-ae7a-51cb-8a25-4619739c0212 -->
  <rule id="205432" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4594 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>