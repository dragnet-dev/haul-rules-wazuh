<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1751 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: af98bb00-9869-57dc-abc9-5777cfdcb29f -->
  <rule id="105275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1751 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>