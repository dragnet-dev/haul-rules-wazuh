<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5864 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 5f1b5f4d-0709-58e2-addb-b6214e3241a2 -->
  <rule id="736415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5864 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>