<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0460 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: e7cda94f-a1e3-541e-9864-f2008b0557a1 -->
  <rule id="754029" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0460 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>