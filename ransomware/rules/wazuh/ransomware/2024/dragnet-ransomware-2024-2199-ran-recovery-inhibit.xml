<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2199 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 5d75fa6a-803e-5a54-870b-b1ea34a83634 -->
  <rule id="700250" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2199 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>