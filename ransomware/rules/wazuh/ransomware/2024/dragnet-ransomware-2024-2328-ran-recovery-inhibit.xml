<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2328 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 98448e15-e6f3-5b7d-9d5b-5d80ac86f984 -->
  <rule id="775182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2328 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>