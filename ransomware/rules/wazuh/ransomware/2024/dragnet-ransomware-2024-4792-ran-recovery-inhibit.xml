<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4792 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: b21e10ad-06b2-5383-a879-04bae5335df5 -->
  <rule id="995010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4792 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>