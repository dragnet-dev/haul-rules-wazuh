<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2384 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 10a2b41a-4ab0-5e9a-81ea-15ddb8c340fe -->
  <rule id="124341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2384 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>