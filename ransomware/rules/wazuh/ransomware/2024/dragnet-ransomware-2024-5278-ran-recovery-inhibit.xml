<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5278 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: e7da4514-4ea9-5c1c-b29a-1bfdc3f6235d -->
  <rule id="285045" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5278 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>