<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5345 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 4f9ba3ca-6610-5d65-bae8-3adae24fa5d6 -->
  <rule id="347303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5345 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>