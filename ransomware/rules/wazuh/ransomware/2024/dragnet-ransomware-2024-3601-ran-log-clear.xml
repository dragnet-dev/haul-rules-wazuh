<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3601 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: c7f34c8d-2d93-5aab-ab7a-f5d51c34071f -->
  <rule id="675756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3601 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>