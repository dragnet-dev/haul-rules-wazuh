<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3892 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f4c35917-dd66-54f7-93ef-032963d4ea9d -->
  <rule id="776359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3892 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>