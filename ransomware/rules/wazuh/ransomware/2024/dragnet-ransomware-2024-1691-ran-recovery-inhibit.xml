<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1691 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 29c54aac-9ede-5ae1-a872-485934bba7a1 -->
  <rule id="599594" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1691 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>