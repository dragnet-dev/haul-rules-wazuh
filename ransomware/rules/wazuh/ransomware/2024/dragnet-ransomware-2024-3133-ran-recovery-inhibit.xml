<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3133 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 3e6fa5f9-648b-5304-aaca-ecaa159c1d9f -->
  <rule id="805065" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3133 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>