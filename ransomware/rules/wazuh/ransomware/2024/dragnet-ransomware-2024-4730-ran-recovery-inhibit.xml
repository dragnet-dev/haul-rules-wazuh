<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4730 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 19c110b5-9c54-5391-9334-045c127a9b75 -->
  <rule id="657771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4730 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
