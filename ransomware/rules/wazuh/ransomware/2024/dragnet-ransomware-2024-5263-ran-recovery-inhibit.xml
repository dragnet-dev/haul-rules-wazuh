<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5263 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: e023beef-4df7-55fc-9657-e8008f44e891 -->
  <rule id="990078" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5263 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>