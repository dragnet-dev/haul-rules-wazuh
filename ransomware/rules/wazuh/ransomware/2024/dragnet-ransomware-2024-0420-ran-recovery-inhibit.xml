<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0420 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 40a564ae-07b9-5366-8bc0-7a2be6f54868 -->
  <rule id="609034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0420 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
