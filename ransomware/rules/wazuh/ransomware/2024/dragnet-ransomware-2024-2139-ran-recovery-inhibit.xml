<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2139 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 13e23510-786a-57cc-be57-9929ba975513 -->
  <rule id="522351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2139 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>