<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3187 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: 2b353f2f-aa9f-5b58-a2a1-86ae316fd24a -->
  <rule id="736632" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3187 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>