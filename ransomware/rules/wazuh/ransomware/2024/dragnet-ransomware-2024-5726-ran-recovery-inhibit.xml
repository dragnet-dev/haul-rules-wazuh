<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5726 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: cd842c18-8a2e-570f-8020-aeb9ac69ef3d -->
  <rule id="693484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5726 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>