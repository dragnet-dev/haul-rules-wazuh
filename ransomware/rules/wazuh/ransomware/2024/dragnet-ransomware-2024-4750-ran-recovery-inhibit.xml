<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4750 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 47f233b6-90e9-56e7-a158-1630d2377262 -->
  <rule id="675739" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4750 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>