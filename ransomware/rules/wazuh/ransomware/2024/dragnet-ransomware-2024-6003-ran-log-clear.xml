<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6003 — Event Log Clearing (hunters) | Status: experimental | Sigma ID: a6060fd9-5d28-594e-b6d0-032f37c028d3 -->
  <rule id="896975" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6003 — Event Log Clearing (hunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>