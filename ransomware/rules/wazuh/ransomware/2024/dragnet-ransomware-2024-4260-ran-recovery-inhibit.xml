<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4260 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f19a4698-ceeb-5a5c-a1a7-d427dfa399f9 -->
  <rule id="731446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4260 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>