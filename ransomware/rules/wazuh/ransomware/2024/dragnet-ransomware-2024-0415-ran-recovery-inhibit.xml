<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0415 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7a01d434-d2ae-5d8f-9a26-8b9460b1add5 -->
  <rule id="252294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0415 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>