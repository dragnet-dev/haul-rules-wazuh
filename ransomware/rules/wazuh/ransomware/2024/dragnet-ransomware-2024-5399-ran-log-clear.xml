<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5399 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 1db8c4c8-15fa-57c1-b0d9-6a081844a614 -->
  <rule id="582476" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5399 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>