<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4358 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8b267610-84a0-5350-931a-6f9e96387941 -->
  <rule id="592676" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4358 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>