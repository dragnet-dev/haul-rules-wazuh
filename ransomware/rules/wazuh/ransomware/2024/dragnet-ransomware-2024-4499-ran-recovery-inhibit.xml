<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4499 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f7b2e79e-7a17-5aec-a463-8768b9201024 -->
  <rule id="537267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4499 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>