<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5196 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e75aedef-15ba-5f0a-9689-420d15ff4d3f -->
  <rule id="744397" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5196 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>