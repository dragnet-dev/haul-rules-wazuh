<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1300 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: e294a649-355c-5e82-b2a2-fc7545ac4ee9 -->
  <rule id="587146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1300 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>