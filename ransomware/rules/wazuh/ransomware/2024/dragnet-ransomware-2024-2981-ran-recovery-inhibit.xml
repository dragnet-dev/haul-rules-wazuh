<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2981 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c622285a-6e42-5746-a1c0-3746c5557fd5 -->
  <rule id="462228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2981 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>