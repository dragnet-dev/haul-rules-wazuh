<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1113 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: da3516ec-643a-582a-a897-09990b093558 -->
  <rule id="483516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1113 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>