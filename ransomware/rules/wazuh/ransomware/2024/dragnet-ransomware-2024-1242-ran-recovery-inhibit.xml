<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1242 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 1492f9ab-9c2a-59e3-a5a6-7fbde292c519 -->
  <rule id="322074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1242 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>