<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5548 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 297971fe-e8ea-5330-8c66-211ac99558e4 -->
  <rule id="367551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5548 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>