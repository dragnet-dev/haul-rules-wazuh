<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4720 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: b0666f61-8d3d-5e87-a640-6672dda08e79 -->
  <rule id="970671" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4720 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>