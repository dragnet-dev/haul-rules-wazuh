<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3289 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 1aaa858c-610b-5416-80eb-e0210bd85990 -->
  <rule id="626858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3289 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>