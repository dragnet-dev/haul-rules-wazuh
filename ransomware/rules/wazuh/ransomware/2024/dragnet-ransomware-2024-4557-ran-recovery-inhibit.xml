<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4557 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 26307d1f-c925-57be-a591-5a367ce1854c -->
  <rule id="709251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4557 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>