<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5676 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 12677cb8-6893-5874-b166-36c7c8b5f3aa -->
  <rule id="645515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5676 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>