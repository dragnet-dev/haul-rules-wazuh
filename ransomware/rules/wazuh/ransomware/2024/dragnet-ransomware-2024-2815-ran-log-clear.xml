<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2815 — Event Log Clearing (frag) | Status: deprecated | Sigma ID: 8c8138cb-2629-5b17-bd73-b64ba59f938e -->
  <rule id="608138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2815 — Event Log Clearing (frag)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>