<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3939 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 911ba21d-e39b-52c3-968d-3f9bb13af664 -->
  <rule id="634022" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3939 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>