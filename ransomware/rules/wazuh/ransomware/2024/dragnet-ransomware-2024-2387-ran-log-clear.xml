<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2387 — Event Log Clearing (hunters) | Status: experimental | Sigma ID: a59a811f-6713-5c5b-8f52-4cb9b5cfe6f3 -->
  <rule id="895481" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2387 — Event Log Clearing (hunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>