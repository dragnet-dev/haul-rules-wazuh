<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0986 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: cd368b8d-f775-5868-b025-9c4146449ec5 -->
  <rule id="685899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0986 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>