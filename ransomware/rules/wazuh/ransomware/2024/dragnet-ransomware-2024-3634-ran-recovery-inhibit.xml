<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3634 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e5d50174-ad29-53a7-86ba-1a06ccd91131 -->
  <rule id="633501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3634 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>