<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2247 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 18d51d6f-ebcb-52d6-a86c-a6de6479e767 -->
  <rule id="424296" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2247 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>