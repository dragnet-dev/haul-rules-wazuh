<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2779 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: f930c3e7-8fca-5675-944d-dcc3536f5716 -->
  <rule id="848923" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2779 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>