<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4842 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a073a798-fe82-51de-956c-827212a21eab -->
  <rule id="811787" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4842 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>