<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1509 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 9fc912bf-f566-5760-807a-5c466c9d0548 -->
  <rule id="856912" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1509 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>