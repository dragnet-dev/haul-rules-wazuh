<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0344 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 38511c6f-c3f6-58c7-9067-03792719ec97 -->
  <rule id="861886" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0344 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>