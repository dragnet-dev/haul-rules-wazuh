<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0087 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: f7d89370-8e31-527c-8df3-b943410c425c -->
  <rule id="825893" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0087 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>