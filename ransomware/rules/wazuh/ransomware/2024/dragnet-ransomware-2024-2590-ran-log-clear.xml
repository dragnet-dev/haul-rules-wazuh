<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2590 — Event Log Clearing (monti) | Status: experimental | Sigma ID: 14771956-10fa-5c88-9d54-be8971e4ec21 -->
  <rule id="677195" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2590 — Event Log Clearing (monti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>