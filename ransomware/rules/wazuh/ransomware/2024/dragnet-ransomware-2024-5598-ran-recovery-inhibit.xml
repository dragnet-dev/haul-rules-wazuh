<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5598 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 6bd6acab-1c65-573f-bfdf-0906a7050222 -->
  <rule id="917708" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5598 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>