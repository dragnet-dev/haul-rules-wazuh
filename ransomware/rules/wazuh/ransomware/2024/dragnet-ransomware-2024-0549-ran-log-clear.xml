<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0549 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 31bf4758-45bd-5c2c-b6a9-0ac9af0078ca -->
  <rule id="127475" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0549 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>