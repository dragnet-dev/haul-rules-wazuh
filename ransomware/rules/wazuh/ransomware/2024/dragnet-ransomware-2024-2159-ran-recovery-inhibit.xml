<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2159 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 507fc892-6171-54ae-a023-3cc353bab1c9 -->
  <rule id="500448" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2159 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>