<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0525 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: fd2df835-dd5d-56fc-b3b9-3d6bc5fd5c82 -->
  <rule id="284158" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0525 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>