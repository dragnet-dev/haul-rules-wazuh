<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2292 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 3675447d-2f50-5d0d-b9cd-5248b6035cce -->
  <rule id="175447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2292 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>