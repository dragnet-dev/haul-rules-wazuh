<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2466 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: fc1cd12c-d089-5d6c-80cb-5c116ff42219 -->
  <rule id="255811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2466 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>