<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4866 — Recovery Inhibition (ElDorado) | Status: experimental | Sigma ID: 38add329-37d8-54ab-af15-ea044cc18fe2 -->
  <rule id="784293" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4866 — Recovery Inhibition (ElDorado)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>