<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3644 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: ae6a3560-f595-5f4a-9d50-4fad70c55226 -->
  <rule id="194635" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3644 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>