<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1210 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: f3fcc7c8-b9ed-5bda-87a3-a6db17a62b53 -->
  <rule id="107327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1210 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>