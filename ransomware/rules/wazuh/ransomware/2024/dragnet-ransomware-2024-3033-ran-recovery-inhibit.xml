<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3033 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b1a2bdc3-0498-5905-bd1f-6468526e8d28 -->
  <rule id="172861" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3033 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>