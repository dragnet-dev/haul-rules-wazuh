<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4824 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: ddecb314-385a-503e-a4d3-7637e5b46be7 -->
  <rule id="190033" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4824 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>