<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5848 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 12142603-b757-5096-a779-12c6dd54f9e3 -->
  <rule id="414260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5848 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>