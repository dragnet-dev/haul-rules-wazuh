<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0956 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 6ab4f4b3-a277-5802-91ad-4b418f3d665c -->
  <rule id="131994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0956 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>