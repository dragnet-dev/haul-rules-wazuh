<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4687 — Event Log Clearing (babuk2) | Status: experimental | Sigma ID: a1eabaf6-2ce7-5f83-945a-a5d83a315b95 -->
  <rule id="479226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4687 — Event Log Clearing (babuk2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>