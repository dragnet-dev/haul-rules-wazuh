  <rule id="419963" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4257 — Recovery Inhibition (redransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>