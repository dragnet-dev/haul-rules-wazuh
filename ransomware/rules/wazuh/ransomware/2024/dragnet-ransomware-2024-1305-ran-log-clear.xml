<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1305 — Event Log Clearing (safepay) | Status: deprecated | Sigma ID: 0b001c8f-8653-5a0c-be1f-74a7dc22aea7 -->
  <rule id="960288" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1305 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>