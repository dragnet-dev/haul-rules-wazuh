<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5288 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2f8f6bf2-0596-5e17-a9a8-b36e96d2f952 -->
  <rule id="426187" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5288 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>