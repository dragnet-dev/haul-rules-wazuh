<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4750 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: 00c3be0a-f1c0-5a7b-8df7-e40634d9870c -->
  <rule id="668490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4750 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>