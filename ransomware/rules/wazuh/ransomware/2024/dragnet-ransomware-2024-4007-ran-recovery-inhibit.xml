<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4007 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: a2b336f6-1fa0-5508-a40f-d4bd94edc073 -->
  <rule id="843336" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4007 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>