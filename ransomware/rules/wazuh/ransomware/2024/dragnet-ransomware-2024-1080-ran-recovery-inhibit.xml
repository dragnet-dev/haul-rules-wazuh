<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1080 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 70332999-f386-5966-8e8b-47286d0ec37f -->
  <rule id="833299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1080 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>