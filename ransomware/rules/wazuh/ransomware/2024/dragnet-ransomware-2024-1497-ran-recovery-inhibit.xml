<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1497 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e698f251-c36c-5701-b582-9e56d2431721 -->
  <rule id="651832" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1497 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>