<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2646 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 16dcced8-83c7-5a94-aa6f-cba22150229c -->
  <rule id="305102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2646 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>