<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0005 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: da79a5da-e78f-5c87-b025-b65d4a76a4a1 -->
  <rule id="900745" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0005 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>