<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1537 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2f2f2beb-2ed0-56a9-8522-345776061256 -->
  <rule id="410763" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1537 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>