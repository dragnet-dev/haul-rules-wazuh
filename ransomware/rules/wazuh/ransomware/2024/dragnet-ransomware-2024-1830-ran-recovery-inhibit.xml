<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1830 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: a4533013-5811-5db6-a074-4a54a1785fc7 -->
  <rule id="245330" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1830 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>