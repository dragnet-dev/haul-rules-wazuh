<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2823 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 26dd1049-6b8a-5a6c-9a80-503015cf707d -->
  <rule id="677104" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2823 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>