<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3621 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d42fbff5-70a3-5ee6-979d-2994c9052411 -->
  <rule id="200863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3621 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>