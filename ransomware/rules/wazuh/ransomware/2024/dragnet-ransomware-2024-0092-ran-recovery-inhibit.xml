<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0092 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: fbccb261-580b-5f98-8a42-46c88c288980 -->
  <rule id="231371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0092 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>