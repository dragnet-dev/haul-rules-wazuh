<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0855 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: fd5b4b85-32d1-5a01-9001-9a2ab6a067e4 -->
  <rule id="291435" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0855 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>