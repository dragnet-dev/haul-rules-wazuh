<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0650 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c4f5f62d-ac14-517f-958d-e80c27af04df -->
  <rule id="599356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0650 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>