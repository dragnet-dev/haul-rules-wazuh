<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4643 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 639ec9ff-1e18-52c6-b944-b073cd8bea28 -->
  <rule id="838209" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4643 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>