<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1966 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d2135314-8ab7-55b5-a25e-6cd3c46fe9d9 -->
  <rule id="521353" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1966 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>