<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5504 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 8e6e43b6-794a-57a4-8ca3-cfab8a4f2039 -->
  <rule id="583043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5504 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>