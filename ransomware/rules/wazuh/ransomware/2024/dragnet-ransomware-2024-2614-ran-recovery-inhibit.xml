<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2614 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: a3556898-899f-57f6-a9f1-d560b302f85e -->
  <rule id="235568" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2614 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>