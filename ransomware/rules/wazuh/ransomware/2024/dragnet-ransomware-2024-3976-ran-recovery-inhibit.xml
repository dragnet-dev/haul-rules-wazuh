<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3976 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: a9ee4cc3-c751-5a9f-be36-92caf972b633 -->
  <rule id="102796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3976 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>