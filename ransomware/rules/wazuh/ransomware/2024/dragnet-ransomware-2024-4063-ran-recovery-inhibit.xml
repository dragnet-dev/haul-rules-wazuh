<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4063 — Recovery Inhibition (play) | Status: experimental | Sigma ID: bd759c52-2e0a-581b-afd0-e4e05e66a59f -->
  <rule id="436156" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4063 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>