<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2560 — Event Log Clearing (frag) | Status: deprecated | Sigma ID: 56f5bf50-01fc-52c0-84e0-3188e7c1fb17 -->
  <rule id="633631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2560 — Event Log Clearing (frag)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>