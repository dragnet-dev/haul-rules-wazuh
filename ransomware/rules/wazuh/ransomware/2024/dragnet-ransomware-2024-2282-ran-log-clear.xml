<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2282 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 3e7f359d-8f28-5ca2-97be-15f487f4aef0 -->
  <rule id="204735" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2282 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>