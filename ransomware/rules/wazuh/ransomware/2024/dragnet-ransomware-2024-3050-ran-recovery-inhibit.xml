<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3050 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: e4f1bb44-a20d-5e37-bd73-9d5bb77640fe -->
  <rule id="637083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3050 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>