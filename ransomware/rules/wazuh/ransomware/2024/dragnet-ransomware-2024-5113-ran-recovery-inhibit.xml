<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5113 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 84900c04-7910-5108-8110-253034617364 -->
  <rule id="558412" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5113 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>