<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4896 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 05900ae4-f813-5a60-a3e8-04185fd11149 -->
  <rule id="710574" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4896 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>