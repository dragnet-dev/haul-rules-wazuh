<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2507 — Shadow Copy Deletion (donutleaks) | Status: experimental | Sigma ID: b4b6328a-a443-530f-9357-085284af3f5f -->
  <rule id="135632" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2507 — Shadow Copy Deletion (donutleaks)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>