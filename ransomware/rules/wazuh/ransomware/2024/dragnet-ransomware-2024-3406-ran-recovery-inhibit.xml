<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3406 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 918ce09c-f5f0-5c02-872e-1733bc9bb22b -->
  <rule id="652140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3406 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>