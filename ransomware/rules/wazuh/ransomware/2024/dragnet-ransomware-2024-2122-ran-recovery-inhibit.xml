<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2122 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7979f3d4-8751-5384-abfe-a5d4a8a2ad3e -->
  <rule id="476793" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2122 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>