<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2605 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ec0c1b5e-2b46-53d8-a625-4095f86e23f6 -->
  <rule id="743547" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2605 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>