<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2700 — Event Log Clearing (funksec) | Status: experimental | Sigma ID: 5edce1fb-5f3b-5ae9-9f6d-a246f1fbab57 -->
  <rule id="385581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2700 — Event Log Clearing (funksec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>