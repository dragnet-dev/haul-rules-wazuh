<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4554 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 3d023c75-56ba-5d80-9792-25a624ec8230 -->
  <rule id="863807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4554 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>