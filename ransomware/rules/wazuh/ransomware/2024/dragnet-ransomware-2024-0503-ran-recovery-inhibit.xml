<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0503 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: e70428f3-d50b-5105-89b7-e5aadef06a3d -->
  <rule id="670428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0503 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>