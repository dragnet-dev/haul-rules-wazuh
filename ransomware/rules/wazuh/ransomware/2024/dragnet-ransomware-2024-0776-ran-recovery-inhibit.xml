<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0776 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 2d1fedc3-95f2-5dfd-b79f-a1a65402c12e -->
  <rule id="151373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0776 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>