<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5658 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 68cae245-c163-57df-9d64-1494f2b2ffe6 -->
  <rule id="217742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5658 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>