<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4350 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: f9e9ebdc-fad4-5962-a3cd-6b39f866e2eb -->
  <rule id="351019" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4350 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>