<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4473 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6503dd54-b9e3-57d5-b001-a2d6e648ff53 -->
  <rule id="864989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4473 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>