<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1378 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d0af423f-cc91-5b61-ae0f-2bce3266042c -->
  <rule id="745542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1378 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>