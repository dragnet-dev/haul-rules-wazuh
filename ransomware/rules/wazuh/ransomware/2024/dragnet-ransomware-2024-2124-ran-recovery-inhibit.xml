<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2124 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: a1c8eb00-fbd0-5b6e-9259-902dc80bd5e8 -->
  <rule id="669963" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2124 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>