<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4813 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: d07a230e-bae6-5aa2-9b3b-64b5d3b117d7 -->
  <rule id="392223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4813 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>