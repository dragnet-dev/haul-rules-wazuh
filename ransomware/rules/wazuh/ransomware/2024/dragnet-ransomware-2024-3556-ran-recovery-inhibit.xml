<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3556 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: c672e6ee-6834-5858-85e4-65b647c91c7f -->
  <rule id="327666" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3556 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>