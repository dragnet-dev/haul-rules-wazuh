<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0034 — Event Log Clearing (killsec) | Status: experimental | Sigma ID: b4fd2268-e86d-5b1b-bfc2-d3a9acd0f303 -->
  <rule id="343722" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0034 — Event Log Clearing (killsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>