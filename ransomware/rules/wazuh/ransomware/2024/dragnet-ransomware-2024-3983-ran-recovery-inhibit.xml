<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3983 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: f7ed2346-d4ef-5236-aa9e-474ee1caa924 -->
  <rule id="542923" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3983 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>