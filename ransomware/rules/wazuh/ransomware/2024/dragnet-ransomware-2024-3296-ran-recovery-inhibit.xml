<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3296 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: ffc2f514-e6af-52f0-80b2-8f9b862847bd -->
  <rule id="347675" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3296 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>