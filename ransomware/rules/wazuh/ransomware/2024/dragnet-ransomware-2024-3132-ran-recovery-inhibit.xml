<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3132 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 5d989d48-23a4-552f-a64b-fefdfa7918b5 -->
  <rule id="703837" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3132 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>