<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5340 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: f69d8803-82e1-57d5-b8ac-04176fd11230 -->
  <rule id="811788" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5340 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>