<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0704 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1cd67eda-6607-557b-8fe1-d3a5506da465 -->
  <rule id="218989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0704 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>