<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4245 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: f1b5c0bc-f48e-5109-a2be-e441568a10c8 -->
  <rule id="384120" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4245 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>