<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0744 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7918e583-dea4-521a-92e0-ebb310725da1 -->
  <rule id="467025" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0744 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>