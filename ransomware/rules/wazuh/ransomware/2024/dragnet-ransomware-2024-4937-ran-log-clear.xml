<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4937 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: aaadb465-5d1f-51d4-b698-9fb7ea6f18d0 -->
  <rule id="790994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4937 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>