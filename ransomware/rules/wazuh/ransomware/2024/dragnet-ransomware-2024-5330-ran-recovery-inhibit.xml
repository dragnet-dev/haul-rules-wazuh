<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5330 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1aa1290d-cc69-5cbc-b4cf-05488c7358e2 -->
  <rule id="761290" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5330 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
