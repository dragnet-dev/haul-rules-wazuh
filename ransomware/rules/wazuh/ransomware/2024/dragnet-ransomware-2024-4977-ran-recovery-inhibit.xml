<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4977 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 2facac20-8456-5424-9a17-1402249497c1 -->
  <rule id="524396" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4977 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>