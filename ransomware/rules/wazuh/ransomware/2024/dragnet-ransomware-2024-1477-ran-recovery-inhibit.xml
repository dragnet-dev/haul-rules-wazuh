<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1477 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 2a45e67a-ea04-55ca-9a91-7978f16b20d4 -->
  <rule id="593467" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1477 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>