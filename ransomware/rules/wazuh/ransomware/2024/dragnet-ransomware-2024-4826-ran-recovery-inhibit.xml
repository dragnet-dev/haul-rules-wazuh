<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4826 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 4e6bef16-c974-5067-acba-6f58e6b456eb -->
  <rule id="622511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4826 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>