<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0354 — Event Log Clearing (spacebears) | Status: experimental | Sigma ID: c81de976-5a2a-51ad-8ce9-302b701e94e5 -->
  <rule id="681589" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0354 — Event Log Clearing (spacebears)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>