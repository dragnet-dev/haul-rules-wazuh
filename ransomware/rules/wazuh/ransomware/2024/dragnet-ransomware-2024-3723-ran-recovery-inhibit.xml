<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3723 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: f8b00ee2-f870-52bd-9b07-a79b6b6a8489 -->
  <rule id="562414" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3723 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>