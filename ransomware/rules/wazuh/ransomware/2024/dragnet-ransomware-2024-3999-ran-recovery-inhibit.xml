<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3999 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 942fbfee-e9e1-5613-b03c-5b67904a0874 -->
  <rule id="362463" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3999 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>