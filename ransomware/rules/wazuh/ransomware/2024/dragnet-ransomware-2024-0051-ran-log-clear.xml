<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0051 — Event Log Clearing (helldown) | Status: experimental | Sigma ID: 3d434f00-7bb5-5fd6-b0ea-43c6fe5a199a -->
  <rule id="929590" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0051 — Event Log Clearing (helldown)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>