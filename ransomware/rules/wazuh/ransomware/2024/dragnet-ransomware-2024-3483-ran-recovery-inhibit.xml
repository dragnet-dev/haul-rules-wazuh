<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3483 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: f3c98ee3-500c-5cfa-aa8a-538c43829c83 -->
  <rule id="437582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3483 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>