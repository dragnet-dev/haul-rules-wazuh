<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1648 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 83eef7eb-5195-5128-9170-d842601865ce -->
  <rule id="837917" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1648 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>