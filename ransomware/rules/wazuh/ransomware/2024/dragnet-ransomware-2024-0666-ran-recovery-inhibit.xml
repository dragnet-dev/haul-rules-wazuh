<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0666 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 81c99f00-fa5b-5a28-a529-f3f874846907 -->
  <rule id="394399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0666 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>