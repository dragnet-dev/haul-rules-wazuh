<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3144 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 5c5b397b-03d6-54b1-b46c-bd823b9fd82a -->
  <rule id="681139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3144 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>