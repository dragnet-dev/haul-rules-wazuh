<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0181 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 3ae57fb4-139a-51ca-adbe-f00c595e7d56 -->
  <rule id="708127" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0181 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>