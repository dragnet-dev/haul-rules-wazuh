<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5644 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: f31dc372-eea5-5bac-bcaf-777408012ae5 -->
  <rule id="421563" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5644 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>