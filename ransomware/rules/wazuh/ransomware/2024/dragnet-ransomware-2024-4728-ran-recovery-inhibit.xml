<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4728 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: c6b0e674-cc64-570a-a943-9958c36ef186 -->
  <rule id="643346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4728 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
