<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4523 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 9e49e6c5-6e51-5146-9f3f-03310931d619 -->
  <rule id="835986" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4523 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>