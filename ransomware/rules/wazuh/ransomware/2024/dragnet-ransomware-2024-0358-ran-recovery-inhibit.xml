<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0358 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: acd135e0-cc96-5a3b-92c1-ac7d3523d367 -->
  <rule id="165135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0358 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>