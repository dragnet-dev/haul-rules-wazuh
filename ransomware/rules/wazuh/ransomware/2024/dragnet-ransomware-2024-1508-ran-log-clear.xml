<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1508 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 94c5b8de-e1ef-54a5-aa7a-3ea17fc6cfb4 -->
  <rule id="726518" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1508 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>