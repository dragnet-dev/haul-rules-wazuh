<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1545 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 22ac9d44-b1ed-5ab7-a3e6-c7ee0b5d7378 -->
  <rule id="387974" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1545 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>