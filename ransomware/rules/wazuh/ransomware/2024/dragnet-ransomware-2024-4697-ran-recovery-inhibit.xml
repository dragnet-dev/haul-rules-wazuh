<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4697 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 205b130f-7802-569b-8847-6af8bc1d469b -->
  <rule id="691130" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4697 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>