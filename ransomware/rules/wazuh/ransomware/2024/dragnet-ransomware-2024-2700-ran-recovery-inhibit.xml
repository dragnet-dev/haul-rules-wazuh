<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2700 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 1296c6ab-0626-5c0e-a904-7d3ad8205259 -->
  <rule id="719786" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2700 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>