<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3807 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0390d19d-023f-5663-be67-145bb3f733ea -->
  <rule id="205117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3807 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>