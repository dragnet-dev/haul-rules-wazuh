<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3443 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 84764061-7fbe-5675-9695-dbff797de5c8 -->
  <rule id="476406" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3443 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>