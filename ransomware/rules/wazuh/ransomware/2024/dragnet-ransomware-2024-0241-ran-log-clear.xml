<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0241 — Event Log Clearing (mallox) | Status: deprecated | Sigma ID: 220e14f1-ba35-58ed-9fd0-56c6b84b82f4 -->
  <rule id="354639" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0241 — Event Log Clearing (mallox)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>