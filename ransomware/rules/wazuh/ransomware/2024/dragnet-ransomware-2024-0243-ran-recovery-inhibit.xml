<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0243 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8e2bffb6-3dd0-5eaa-95b5-6e6cf50eb266 -->
  <rule id="527583" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0243 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>