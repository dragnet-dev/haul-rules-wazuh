<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4129 — Event Log Clearing (play) | Status: experimental | Sigma ID: 08c86370-ca27-5ff4-9ffb-1b9b0d6f12d7 -->
  <rule id="608637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4129 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>