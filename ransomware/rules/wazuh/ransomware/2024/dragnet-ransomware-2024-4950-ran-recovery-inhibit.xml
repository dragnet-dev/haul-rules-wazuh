<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4950 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: b3ff635f-eda6-5915-8f6d-401807fea7c8 -->
  <rule id="318363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4950 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>