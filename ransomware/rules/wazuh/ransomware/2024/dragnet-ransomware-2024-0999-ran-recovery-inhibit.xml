<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0999 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: d4354c53-22b5-588f-a470-fbbbc99274dc -->
  <rule id="449676" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0999 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>