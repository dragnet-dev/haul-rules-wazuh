<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1423 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3fc2fa79-b34d-5b18-a3ee-2377ab1b9039 -->
  <rule id="911962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1423 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>