<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2260 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 54310cfd-62f7-5f91-85ea-8740719e9f83 -->
  <rule id="503567" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2260 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>