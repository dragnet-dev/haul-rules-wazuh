<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1303 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 2291e12d-46a4-5763-b223-25956b5951c5 -->
  <rule id="167012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1303 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>