<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3572 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 4fc2dd2d-9283-53fe-8c3d-f633007eb9e0 -->
  <rule id="667293" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3572 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>