<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4518 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 2aa7d64a-0330-551f-838d-67d19b724df9 -->
  <rule id="292456" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4518 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>