<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5164 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e5c425da-2bc0-55b4-91ef-c2047212760c -->
  <rule id="632425" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5164 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>