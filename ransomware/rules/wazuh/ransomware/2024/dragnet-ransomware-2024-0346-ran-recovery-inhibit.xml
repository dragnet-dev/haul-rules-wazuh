<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0346 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 9cb11a66-79bc-5adf-a9d7-e0776b9a86f6 -->
  <rule id="511386" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0346 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>