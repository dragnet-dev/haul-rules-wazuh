<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2497 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 576d3a04-9490-5601-bc44-4e1f10525087 -->
  <rule id="676698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2497 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>