<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2371 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 2decaf9c-accf-572d-ade3-989305a9bbe6 -->
  <rule id="409711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2371 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>