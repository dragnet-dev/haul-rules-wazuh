<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4861 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7d41dbee-6b46-5ed8-8118-d95d1f5cafc6 -->
  <rule id="610715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4861 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>