<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5329 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ae9727f2-8530-53b7-9ff0-a9dd4d22f3a8 -->
  <rule id="949727" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5329 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>