<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4501 — Recovery Inhibition (dAn0n) | Status: experimental | Sigma ID: b4ac53e6-dd11-532c-83a7-82acbe972744 -->
  <rule id="335653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4501 — Recovery Inhibition (dAn0n)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>