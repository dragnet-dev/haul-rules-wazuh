<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2637 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 5857dbae-7a79-5b3a-939d-642ba6cd25cb -->
  <rule id="699611" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2637 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>