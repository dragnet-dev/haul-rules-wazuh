<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3862 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: a414fa69-2410-5a1e-8306-192cae44a784 -->
  <rule id="966234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3862 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>