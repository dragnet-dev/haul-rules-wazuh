<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3712 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: fdc5b081-43e8-5679-8411-06ac893d8204 -->
  <rule id="296910" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3712 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>