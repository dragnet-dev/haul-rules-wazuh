<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4368 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 26cad4f5-f78e-5b46-9940-66d3ddd13563 -->
  <rule id="297414" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4368 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>