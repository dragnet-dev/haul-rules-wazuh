<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0768 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 601e3bf1-0f67-52be-aa63-7b406e10de4d -->
  <rule id="740859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0768 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>