<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3224 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1396c639-e0bf-5aea-b24f-262b262fbf2f -->
  <rule id="534863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3224 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>