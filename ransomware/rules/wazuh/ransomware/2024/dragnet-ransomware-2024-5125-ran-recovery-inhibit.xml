<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5125 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 60604d59-8efa-5d02-95f4-ccd7796652fc -->
  <rule id="796775" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5125 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>