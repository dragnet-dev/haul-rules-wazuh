<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2655 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 907f3b83-ffc1-5497-92c3-cda59678db24 -->
  <rule id="624379" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2655 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>