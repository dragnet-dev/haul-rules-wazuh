<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0010 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: e3f74276-07e3-5659-bac0-0eaa60fd22fd -->
  <rule id="603742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0010 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>