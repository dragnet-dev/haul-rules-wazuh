<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5416 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b1e39a5a-85e6-5f75-81a5-a67450798e2c -->
  <rule id="264634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5416 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>