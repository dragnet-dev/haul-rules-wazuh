<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4277 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: f16befbe-6cbb-59c7-9f02-55040a90d86a -->
  <rule id="912591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4277 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>