<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0206 — Recovery Inhibition (ciphbit) | Status: deprecated | Sigma ID: afc78452-aac9-57f7-b299-dc1be447bb48 -->
  <rule id="212784" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0206 — Recovery Inhibition (ciphbit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>