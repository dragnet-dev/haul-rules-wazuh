<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1111 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: a4e4c2e0-3a0d-5105-8f18-1ab71c6ce103 -->
  <rule id="985562" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1111 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>