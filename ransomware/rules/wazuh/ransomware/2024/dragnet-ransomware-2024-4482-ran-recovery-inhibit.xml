<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4482 — Recovery Inhibition (dAn0n) | Status: experimental | Sigma ID: 531068f8-7072-5635-9015-7b4467a103c7 -->
  <rule id="497103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4482 — Recovery Inhibition (dAn0n)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>