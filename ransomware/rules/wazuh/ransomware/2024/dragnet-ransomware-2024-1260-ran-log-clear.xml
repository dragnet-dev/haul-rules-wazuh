<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1260 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 90ef9ac9-39f8-52ed-aeb5-d85adeaba0ba -->
  <rule id="224794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1260 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>