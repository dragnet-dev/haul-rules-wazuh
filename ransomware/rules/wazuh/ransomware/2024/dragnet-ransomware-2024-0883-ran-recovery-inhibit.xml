<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0883 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d5a93265-d704-5b11-98fb-2d19c7b32113 -->
  <rule id="470932" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0883 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>