<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5805 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: cf3398db-1f97-5eef-8192-6ff41efbf2fb -->
  <rule id="373398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5805 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>