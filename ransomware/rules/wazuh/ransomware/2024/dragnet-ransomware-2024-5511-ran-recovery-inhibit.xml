<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5511 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8c4577be-4975-503d-bad9-75e8eb46b7e2 -->
  <rule id="604577" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5511 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>