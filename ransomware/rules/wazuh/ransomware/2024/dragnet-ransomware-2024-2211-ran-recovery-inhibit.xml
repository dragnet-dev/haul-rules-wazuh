<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2211 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 240a38ae-ee2c-5369-b0df-787d232937a2 -->
  <rule id="860618" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2211 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>