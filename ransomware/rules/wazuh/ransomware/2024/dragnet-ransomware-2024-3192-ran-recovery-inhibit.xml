<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3192 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: cbd78c18-22fd-5b5c-8534-bff926f61362 -->
  <rule id="818860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3192 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>