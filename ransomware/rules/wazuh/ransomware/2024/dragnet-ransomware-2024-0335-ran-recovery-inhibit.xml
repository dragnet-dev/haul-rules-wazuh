<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0335 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: f68dccc4-4efb-5beb-bd34-a5884ea8946e -->
  <rule id="226060" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0335 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>