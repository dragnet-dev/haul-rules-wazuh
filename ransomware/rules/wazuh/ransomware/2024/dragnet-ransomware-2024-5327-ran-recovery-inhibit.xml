<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5327 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 6f3ddf0e-4e46-525d-abff-d2f29312b084 -->
  <rule id="162399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5327 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>