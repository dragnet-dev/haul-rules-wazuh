<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4612 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 88129e59-187c-5947-a213-6f05e78a77f2 -->
  <rule id="610078" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4612 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>