<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5680 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 5a14999c-e8c1-5507-afd9-e4cffac7d3ea -->
  <rule id="114999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5680 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>