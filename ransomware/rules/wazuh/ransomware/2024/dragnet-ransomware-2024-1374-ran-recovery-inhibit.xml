<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1374 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 67842a8b-a960-56c1-85e4-9f6bcd720257 -->
  <rule id="285482" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1374 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>