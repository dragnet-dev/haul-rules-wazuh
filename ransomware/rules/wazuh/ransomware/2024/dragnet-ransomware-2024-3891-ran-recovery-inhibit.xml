<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3891 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 5f9d1e30-72c7-553c-abef-6b4729b65f5a -->
  <rule id="757150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3891 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>