<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3951 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 69a1428b-24f7-56fd-a520-b84618923b61 -->
  <rule id="314142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3951 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>