<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3754 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8e9ba6d2-b6c3-5a5a-973c-29acab5e5ffc -->
  <rule id="160106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3754 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>