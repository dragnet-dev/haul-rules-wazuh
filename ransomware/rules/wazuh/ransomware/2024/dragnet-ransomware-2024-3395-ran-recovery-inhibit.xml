<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3395 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: cedd1ae3-668b-5d7d-b40d-d542cad1fffa -->
  <rule id="473146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3395 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>