<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2748 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: d2959660-b152-5d07-85a6-e621bf565435 -->
  <rule id="529596" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2748 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>