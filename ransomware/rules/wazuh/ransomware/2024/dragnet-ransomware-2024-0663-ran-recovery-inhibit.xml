<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0663 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 03cc5e45-0208-5556-90b2-7ab523fb3648 -->
  <rule id="756144" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0663 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>