<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5552 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 526866b2-bfee-5ae6-93fa-1967a30df112 -->
  <rule id="429867" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5552 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
