<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4598 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 6681d021-6dbc-51c8-beae-dae79addc5b0 -->
  <rule id="269090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4598 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>