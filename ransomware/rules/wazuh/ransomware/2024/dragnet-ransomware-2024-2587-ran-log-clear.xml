<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2587 — Event Log Clearing (redransomware) | Status: deprecated | Sigma ID: 224b0565-43e6-54df-badc-9472e82403e1 -->
  <rule id="995056" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2587 — Event Log Clearing (redransomware)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>