<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4621 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: e1aa7466-c3ef-5d1e-b79c-86f9b1928fb1 -->
  <rule id="126674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4621 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>