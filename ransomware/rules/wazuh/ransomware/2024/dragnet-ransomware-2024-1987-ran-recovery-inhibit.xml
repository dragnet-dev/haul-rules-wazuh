<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1987 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: f74e9ee2-fd00-51bd-bfb9-db53e42b05da -->
  <rule id="531838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1987 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>