<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3932 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 288120ea-4a07-5a1e-8f08-e1f63c7568e7 -->
  <rule id="209934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3932 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>