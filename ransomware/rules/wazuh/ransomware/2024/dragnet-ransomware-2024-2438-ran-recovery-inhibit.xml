<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2438 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1ef3ab0a-d20a-547d-9867-a7b33addffb5 -->
  <rule id="468139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2438 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>