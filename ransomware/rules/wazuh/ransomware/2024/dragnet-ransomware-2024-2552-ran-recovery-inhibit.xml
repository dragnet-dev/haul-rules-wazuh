<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2552 — Recovery Inhibition (madliberator) | Status: experimental | Sigma ID: e50e1f72-7e01-5779-8aa7-b3608a8e3503 -->
  <rule id="214271" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2552 — Recovery Inhibition (madliberator)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>