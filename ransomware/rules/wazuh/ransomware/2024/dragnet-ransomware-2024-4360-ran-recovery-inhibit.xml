<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4360 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 80eaf214-606d-53c4-bb35-21becab170d4 -->
  <rule id="714392" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4360 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>