<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5708 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 0f3536e5-2a1a-53db-b3bd-afaeb5ad9d94 -->
  <rule id="756590" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5708 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>