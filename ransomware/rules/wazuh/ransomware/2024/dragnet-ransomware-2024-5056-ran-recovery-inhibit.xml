<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5056 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 9fbe828c-8095-5acb-9079-780ea2069810 -->
  <rule id="589482" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5056 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>