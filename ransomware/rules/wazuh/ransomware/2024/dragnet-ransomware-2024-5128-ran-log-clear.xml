<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5128 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 0bd0336c-3fc0-5ef5-9c18-f8c73a36291c -->
  <rule id="190336" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5128 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>