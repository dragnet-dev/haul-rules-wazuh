<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1692 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b48eca75-9222-5703-8421-e9e3bb90da89 -->
  <rule id="305994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1692 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>