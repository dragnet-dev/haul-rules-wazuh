<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3109 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: a08c0f43-240a-56e5-8a19-df6b48f5da8c -->
  <rule id="882415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3109 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>