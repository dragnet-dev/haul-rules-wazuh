<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3153 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: f56e230f-f8e7-5c5c-b90d-2cd0140137d1 -->
  <rule id="791023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3153 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>