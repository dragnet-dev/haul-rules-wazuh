<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5030 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: e52768c1-3608-5a24-85c6-727eb89df3e1 -->
  <rule id="652768" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5030 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>