<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5462 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 1066638f-68e4-5e54-907c-d62ea1df2f6e -->
  <rule id="266638" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5462 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>