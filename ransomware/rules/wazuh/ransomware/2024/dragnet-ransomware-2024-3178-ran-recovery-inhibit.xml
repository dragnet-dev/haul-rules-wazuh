<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3178 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 05d1a79a-3e9f-52e0-8055-74a472f0ee93 -->
  <rule id="690679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3178 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>