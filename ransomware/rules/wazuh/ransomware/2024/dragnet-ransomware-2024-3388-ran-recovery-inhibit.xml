<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3388 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 4c7172a4-c563-596f-9e88-0b505cc4e656 -->
  <rule id="674762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3388 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>