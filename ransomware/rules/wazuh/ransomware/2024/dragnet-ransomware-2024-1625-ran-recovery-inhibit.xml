<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1625 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ead54e85-c3c7-5a08-86d6-b5fb0e515c19 -->
  <rule id="712078" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1625 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>