<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1611 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 9877660a-93e5-58d1-a62d-e752e366fc21 -->
  <rule id="977660" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1611 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>