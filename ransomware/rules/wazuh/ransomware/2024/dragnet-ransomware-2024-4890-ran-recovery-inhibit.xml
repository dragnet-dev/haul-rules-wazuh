<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4890 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 0629abfd-98ff-55a7-88c4-fa5353c63f55 -->
  <rule id="879135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4890 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>