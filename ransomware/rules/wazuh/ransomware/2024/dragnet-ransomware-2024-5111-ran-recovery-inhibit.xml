<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5111 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: d9b13397-7e26-5406-bb15-3bd739e70ea1 -->
  <rule id="535133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5111 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>