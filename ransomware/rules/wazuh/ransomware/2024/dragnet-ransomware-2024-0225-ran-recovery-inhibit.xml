<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0225 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 24b50457-b432-5801-9fba-c2e0a7e344fa -->
  <rule id="455045" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0225 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>