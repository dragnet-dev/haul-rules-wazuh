<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1958 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: b6afe0d2-c312-562c-ba83-dd10fc5bfa9d -->
  <rule id="379500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1958 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>