<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1166 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a2f2899e-d67e-5cff-bab4-2211da961dc3 -->
  <rule id="847289" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1166 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>