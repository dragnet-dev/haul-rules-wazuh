<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3710 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e86f62e0-d4cf-5d22-ac55-5465437830b6 -->
  <rule id="679162" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3710 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>