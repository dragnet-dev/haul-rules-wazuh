<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0554 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 1313263f-e81f-5aee-8e63-9018d9e3a2d1 -->
  <rule id="513263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0554 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>