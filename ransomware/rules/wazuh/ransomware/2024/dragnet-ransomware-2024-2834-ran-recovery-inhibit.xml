<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2834 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1a50d494-ed59-51d9-8951-10d7d4576e09 -->
  <rule id="741349" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2834 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>