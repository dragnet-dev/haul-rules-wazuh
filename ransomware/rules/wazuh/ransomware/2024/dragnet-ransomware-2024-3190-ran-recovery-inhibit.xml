<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3190 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 122fbba9-e5ed-5188-bb51-a9e1881132e7 -->
  <rule id="959834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3190 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>