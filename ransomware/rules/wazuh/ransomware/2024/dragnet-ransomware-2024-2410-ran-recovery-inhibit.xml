<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2410 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b76a401b-c1d3-5330-8435-a83f170d5125 -->
  <rule id="182640" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2410 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>