<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0989 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3b2b5d83-548e-5e44-875f-58aa8dc2989a -->
  <rule id="717373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0989 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>