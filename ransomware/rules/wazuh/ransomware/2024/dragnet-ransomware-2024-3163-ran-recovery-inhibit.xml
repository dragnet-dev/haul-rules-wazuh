<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3163 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: a0bdd315-b077-5a4b-ae01-3b111bad1efb -->
  <rule id="626373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3163 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>