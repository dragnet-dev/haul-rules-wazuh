<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5189 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: 0a0af4c1-5841-5578-bbe1-f227cbcd811a -->
  <rule id="624076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5189 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>