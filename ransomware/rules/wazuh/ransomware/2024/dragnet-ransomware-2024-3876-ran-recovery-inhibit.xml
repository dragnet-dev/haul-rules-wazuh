<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3876 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 322c06bd-55ca-5f4d-b1d7-e8fc634de327 -->
  <rule id="262507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3876 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>