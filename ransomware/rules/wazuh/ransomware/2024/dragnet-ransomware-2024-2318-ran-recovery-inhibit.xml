<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2318 — Recovery Inhibition (dAn0n) | Status: experimental | Sigma ID: c812d3cb-f6d7-5262-9eff-7eaa80042b7f -->
  <rule id="350053" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2318 — Recovery Inhibition (dAn0n)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>