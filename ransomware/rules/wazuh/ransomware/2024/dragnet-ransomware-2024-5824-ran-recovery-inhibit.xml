<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5824 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ef58192e-cb0c-5c50-8cce-147e368f7a01 -->
  <rule id="695819" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5824 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>