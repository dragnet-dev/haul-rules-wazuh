<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0512 — Event Log Clearing (lynx) | Status: experimental | Sigma ID: def2b89a-4c20-5e2a-91b5-7bf1f7c2fb13 -->
  <rule id="407638" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0512 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>