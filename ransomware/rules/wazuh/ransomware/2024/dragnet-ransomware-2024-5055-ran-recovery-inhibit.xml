<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5055 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 72aea910-4faf-5a89-a86e-2cd72d2694ad -->
  <rule id="377069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5055 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>