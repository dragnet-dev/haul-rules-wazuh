<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4746 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 9657380c-8211-5d64-b6fa-1e2786e64a1d -->
  <rule id="757380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4746 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>