<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5349 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 0534974b-df4d-556e-8e9b-43529a9608a4 -->
  <rule id="559595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5349 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>