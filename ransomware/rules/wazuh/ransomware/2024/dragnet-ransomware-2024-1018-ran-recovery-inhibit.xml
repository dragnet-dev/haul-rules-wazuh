<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1018 — Recovery Inhibition (play) | Status: experimental | Sigma ID: da04ef9e-722b-54b2-9ad7-bfcfa7cc0fcd -->
  <rule id="282063" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1018 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>