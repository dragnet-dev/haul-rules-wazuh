<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5243 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 047f35e1-d1a5-57cf-b8ee-da632e168cef -->
  <rule id="427774" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5243 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>