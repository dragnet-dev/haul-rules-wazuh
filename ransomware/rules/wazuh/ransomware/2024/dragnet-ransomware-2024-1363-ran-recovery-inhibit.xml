<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1363 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 8e2844b2-ea1a-57f6-bf90-ba59851f218c -->
  <rule id="622844" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1363 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>