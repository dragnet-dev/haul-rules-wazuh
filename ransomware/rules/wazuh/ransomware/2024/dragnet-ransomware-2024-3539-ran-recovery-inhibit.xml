<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3539 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8f4812c3-289e-5551-bd2a-97498651425c -->
  <rule id="634812" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3539 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>