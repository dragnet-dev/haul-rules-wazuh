<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1512 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: f8a48ac0-96d3-5d84-a477-10a1819cb8f8 -->
  <rule id="561578" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1512 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>