<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5648 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: beb50ef7-000d-5e4d-8577-290c0d288eee -->
  <rule id="482414" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5648 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>