<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4776 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 4effb1b3-6469-5c52-b116-b1d8e81ff3cc -->
  <rule id="635791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4776 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>