<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0652 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 6ef06427-4ab9-5f3c-99df-350a5036bb2f -->
  <rule id="975064" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0652 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>