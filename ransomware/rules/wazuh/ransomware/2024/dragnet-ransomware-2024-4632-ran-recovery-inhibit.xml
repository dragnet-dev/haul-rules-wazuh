<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4632 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 5b09aaec-d853-5ce9-9e16-07a0fb14106e -->
  <rule id="632074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4632 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>