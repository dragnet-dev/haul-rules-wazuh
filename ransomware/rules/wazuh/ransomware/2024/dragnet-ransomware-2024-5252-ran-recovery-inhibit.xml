<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5252 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 31a90428-969b-56a1-979a-f5fa2c4ce818 -->
  <rule id="669042" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5252 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>