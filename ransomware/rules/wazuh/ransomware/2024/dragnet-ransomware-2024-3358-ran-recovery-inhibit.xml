<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3358 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6c96ffc2-e0b1-5f4a-a19f-c7abc5629df2 -->
  <rule id="189631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3358 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>