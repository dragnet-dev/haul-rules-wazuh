<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4756 — Event Log Clearing (hunters) | Status: experimental | Sigma ID: 8dfa3a94-4047-5f4b-af31-3f5f0cdf39c4 -->
  <rule id="515418" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4756 — Event Log Clearing (hunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>