<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0870 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: b41ad201-a479-5f79-a9ac-1633ca8dfe78 -->
  <rule id="322692" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0870 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>