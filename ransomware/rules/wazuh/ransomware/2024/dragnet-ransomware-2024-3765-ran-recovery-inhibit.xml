<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3765 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 875774fc-c9c1-55ff-93c7-b96e90a72215 -->
  <rule id="612399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3765 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>