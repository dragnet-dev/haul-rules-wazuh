<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0917 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: 43882db2-b497-5cd1-8ec1-80f508351243 -->
  <rule id="534011" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0917 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>