<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1813 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 02488e95-bd7b-54c9-bd6e-6238bc5df4f9 -->
  <rule id="482295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1813 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>