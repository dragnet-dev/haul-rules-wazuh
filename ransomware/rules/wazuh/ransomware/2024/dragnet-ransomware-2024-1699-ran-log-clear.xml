<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1699 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 1e86f5ca-2976-5dc8-b90a-9c1e05c20a04 -->
  <rule id="802652" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1699 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>