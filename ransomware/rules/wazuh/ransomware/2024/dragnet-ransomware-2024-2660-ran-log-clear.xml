<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2660 — Event Log Clearing (killsec) | Status: experimental | Sigma ID: 0c65a7b0-09ba-5337-8d2a-6ed9ebd9ccd9 -->
  <rule id="640123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2660 — Event Log Clearing (killsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>