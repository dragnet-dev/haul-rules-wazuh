<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6017 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 5f252214-ef2d-5888-9e5c-0f6eed1b2d67 -->
  <rule id="625221" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6017 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>