<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2870 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 854dd213-c67d-5e01-9520-ba6d83f6bcc2 -->
  <rule id="488452" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2870 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>