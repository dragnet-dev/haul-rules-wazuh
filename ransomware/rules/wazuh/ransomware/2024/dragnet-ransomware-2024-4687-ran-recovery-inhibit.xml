<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4687 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 18f8dd06-926a-5c25-99b2-75da2b4c019a -->
  <rule id="679490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4687 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>