<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5790 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 8e454913-3a78-51bf-960d-859a69b71da0 -->
  <rule id="624549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5790 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>