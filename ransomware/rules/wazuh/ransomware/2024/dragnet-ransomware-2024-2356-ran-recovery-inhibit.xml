<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2356 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: a79f11bc-44ab-57ea-8930-20f2b3ba09f8 -->
  <rule id="927911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2356 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>