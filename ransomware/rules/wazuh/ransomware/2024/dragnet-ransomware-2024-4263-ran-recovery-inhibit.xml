<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4263 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 7f9ac4c3-973f-5960-9f31-0e9520cdf10a -->
  <rule id="675964" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4263 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>