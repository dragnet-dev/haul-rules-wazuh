<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0590 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c1ee8257-b63e-58fd-9576-cfe3517fd464 -->
  <rule id="521482" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0590 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>