<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0277 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 1cfedce7-91ce-5d5a-99a4-d55bf66c5b00 -->
  <rule id="200252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0277 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>