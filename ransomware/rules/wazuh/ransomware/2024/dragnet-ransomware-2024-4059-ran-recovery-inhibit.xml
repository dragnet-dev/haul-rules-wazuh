<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4059 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c75d4fea-10e6-579b-8cb9-c4c433fd410a -->
  <rule id="666159" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4059 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>