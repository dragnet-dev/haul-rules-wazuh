<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5493 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 8632eff3-d7bb-5ff1-b32a-dce795f094f4 -->
  <rule id="510031" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5493 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>