<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1500 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ec2f2680-4143-5b17-bf26-7028351b2d6f -->
  <rule id="280726" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1500 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>