<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3895 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0e44d623-eb52-5d1a-b445-46ad42f64a85 -->
  <rule id="611762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3895 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>