<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1413 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 26b2582c-82a3-521a-b2cc-5201a4bda86a -->
  <rule id="772582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1413 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>