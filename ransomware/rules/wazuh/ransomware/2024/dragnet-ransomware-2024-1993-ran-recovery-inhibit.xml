<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1993 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 642fbc7f-efdd-509e-bcf0-153a00967ece -->
  <rule id="933660" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1993 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>