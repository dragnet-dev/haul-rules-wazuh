<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3210 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 17157c7f-c49a-5aed-b7ae-5a72d42b3960 -->
  <rule id="145247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3210 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>