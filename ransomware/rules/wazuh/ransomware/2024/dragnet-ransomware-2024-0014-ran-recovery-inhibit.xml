<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0014 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 8393c5ad-8608-5ead-b01c-c41b5c56fe34 -->
  <rule id="543005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0014 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>