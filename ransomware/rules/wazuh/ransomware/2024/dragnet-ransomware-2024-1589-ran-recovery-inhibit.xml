<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1589 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 105109d4-b803-5336-8ffb-eda82acd875a -->
  <rule id="881757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1589 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>