<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0832 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: d23431e7-b6cb-5bfe-8047-1ed443a031ec -->
  <rule id="523431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0832 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>