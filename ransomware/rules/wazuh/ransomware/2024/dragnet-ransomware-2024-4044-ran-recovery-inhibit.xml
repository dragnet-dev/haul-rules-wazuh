<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4044 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 7d6af5e3-05a7-5c8e-8a56-19c12027cc2b -->
  <rule id="617115" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4044 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>