<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4125 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8eff6f94-7607-514b-8aec-7d735603373e -->
  <rule id="557231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4125 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>