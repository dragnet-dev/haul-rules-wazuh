<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5033 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 885b330d-ed61-5517-8385-a842b999694f -->
  <rule id="617133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5033 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>