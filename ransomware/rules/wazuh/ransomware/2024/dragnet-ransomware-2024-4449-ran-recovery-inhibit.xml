<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4449 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 77e39d7c-f410-5d52-af30-da25237d1fe8 -->
  <rule id="294237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4449 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>