<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0191 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: edf0e648-26bf-5fb7-a9f3-5412f9d6ea27 -->
  <rule id="791346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0191 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>