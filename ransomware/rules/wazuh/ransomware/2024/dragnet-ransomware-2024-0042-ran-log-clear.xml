<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0042 — Event Log Clearing (funksec) | Status: experimental | Sigma ID: c56641f1-caf5-5999-b135-2703606f0249 -->
  <rule id="456641" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0042 — Event Log Clearing (funksec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>