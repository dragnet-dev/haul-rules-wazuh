<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0517 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a359b4e8-ab8e-5c20-85c6-877c865a388e -->
  <rule id="857554" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0517 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>