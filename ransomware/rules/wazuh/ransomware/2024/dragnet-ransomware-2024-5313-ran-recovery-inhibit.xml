<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5313 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6002f8df-9e85-5ed8-aaf5-5695e6ab7690 -->
  <rule id="167661" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5313 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>