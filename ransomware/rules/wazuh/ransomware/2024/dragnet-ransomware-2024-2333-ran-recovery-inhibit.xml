<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2333 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 20d22fd4-7317-5ef3-9643-6f761305586e -->
  <rule id="530685" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2333 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>