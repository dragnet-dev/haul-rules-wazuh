<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5986 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c5040d03-9e62-5bc3-938a-eb141d42f1e4 -->
  <rule id="300653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5986 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>