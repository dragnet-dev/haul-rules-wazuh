<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2952 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: a65114a2-f084-571e-8653-1c23371c740b -->
  <rule id="265114" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2952 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>