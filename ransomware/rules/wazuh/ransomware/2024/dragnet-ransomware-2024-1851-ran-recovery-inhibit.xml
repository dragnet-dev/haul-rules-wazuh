<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1851 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 2939f834-b282-5a27-80ba-1217507adcd3 -->
  <rule id="303983" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1851 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>