<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1713 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 6991b6c3-c9a4-56c0-9a5a-48ea61cf187f -->
  <rule id="318676" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1713 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>