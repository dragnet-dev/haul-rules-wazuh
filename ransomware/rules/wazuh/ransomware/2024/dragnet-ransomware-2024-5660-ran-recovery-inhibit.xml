<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5660 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4105478e-7acf-52a8-9d02-fc5f7c1ceaac -->
  <rule id="605478" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5660 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>