<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4736 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c1e4fc9b-ddc1-5b5e-a687-b34adfcb85cf -->
  <rule id="593276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4736 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>