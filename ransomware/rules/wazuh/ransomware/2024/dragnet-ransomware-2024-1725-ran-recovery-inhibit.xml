<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1725 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 2627427a-80fc-5ec0-8ea4-675ece77bea5 -->
  <rule id="927427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1725 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>