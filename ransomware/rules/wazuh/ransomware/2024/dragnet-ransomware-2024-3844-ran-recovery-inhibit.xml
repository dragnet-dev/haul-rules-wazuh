<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3844 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 7283e584-c8f0-55d7-80a3-6b7bc789ec5a -->
  <rule id="365425" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3844 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>