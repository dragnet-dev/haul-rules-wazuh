<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4161 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5b90e519-e193-5523-b027-df74a156c531 -->
  <rule id="670545" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4161 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>