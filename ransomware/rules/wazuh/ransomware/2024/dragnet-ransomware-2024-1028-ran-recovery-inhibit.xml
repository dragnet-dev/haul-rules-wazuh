<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1028 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 66471c62-ad3f-54d0-881f-8918e061cce6 -->
  <rule id="263548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1028 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>