<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5238 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 9b41bc58-6bf8-514c-823e-056fa14ba1ab -->
  <rule id="478684" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5238 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>