<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0612 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 926619f2-d78f-5390-b8c8-884b81525787 -->
  <rule id="525919" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0612 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>