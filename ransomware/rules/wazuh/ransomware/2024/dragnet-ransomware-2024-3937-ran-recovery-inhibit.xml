<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3937 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 29fc1a9b-46ca-5f1a-83dd-8d6ca55312a8 -->
  <rule id="428186" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3937 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>