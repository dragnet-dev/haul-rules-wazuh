<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0414 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: f24b255d-e6c1-50b1-ac2c-4696ba8b9dd9 -->
  <rule id="739525" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0414 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>