<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4897 — Event Log Clearing (chort) | Status: experimental | Sigma ID: 6bb593e5-25c6-50bd-ba29-0d3da3521296 -->
  <rule id="923593" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4897 — Event Log Clearing (chort)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>