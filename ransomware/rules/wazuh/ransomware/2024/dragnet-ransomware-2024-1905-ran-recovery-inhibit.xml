<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1905 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: f3f1e682-bd67-578b-8d9f-08428e94ab30 -->
  <rule id="441106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1905 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>