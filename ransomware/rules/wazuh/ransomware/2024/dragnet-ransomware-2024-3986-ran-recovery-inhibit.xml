<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3986 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: aea99958-ee1b-5e4c-b1b4-d4614b3b3f1b -->
  <rule id="194999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3986 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>