<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5245 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: e38e8339-9fd6-56c3-80ec-c8c5440cdf87 -->
  <rule id="602283" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5245 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>