<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5063 — Event Log Clearing (threeam) | Status: experimental | Sigma ID: dd30fd9d-a397-59ef-97fe-d770de5eda6c -->
  <rule id="365533" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5063 — Event Log Clearing (threeam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>