<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5978 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 933ea590-77d7-5f74-aa01-25b228208197 -->
  <rule id="690825" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5978 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>