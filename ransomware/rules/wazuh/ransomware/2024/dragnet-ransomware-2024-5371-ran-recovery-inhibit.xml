<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5371 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 168a665c-8ca9-52e9-9f22-2ef6a8dd9ac4 -->
  <rule id="998665" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5371 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>