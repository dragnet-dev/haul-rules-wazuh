<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4297 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 4a630838-93f9-5ed2-ab30-49b0057690d8 -->
  <rule id="363083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4297 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>