<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0477 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 88c0fd6f-5688-5f55-95ee-b914f1a63612 -->
  <rule id="135453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0477 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>