<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4344 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c6e01f5a-d163-53b9-a38d-130568a37baf -->
  <rule id="648031" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4344 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>