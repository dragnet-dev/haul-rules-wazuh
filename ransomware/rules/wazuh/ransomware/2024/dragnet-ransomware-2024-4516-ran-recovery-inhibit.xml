<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4516 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 53d9e170-e42d-508c-ad67-13ff9e69598e -->
  <rule id="579181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4516 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>