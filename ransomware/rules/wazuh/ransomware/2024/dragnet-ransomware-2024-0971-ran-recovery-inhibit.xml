<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0971 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 44d1c9ec-5b15-5272-884a-445592d5a490 -->
  <rule id="347489" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0971 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>