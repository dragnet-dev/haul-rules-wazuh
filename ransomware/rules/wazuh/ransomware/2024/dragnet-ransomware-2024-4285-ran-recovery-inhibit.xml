<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4285 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 1f45a49b-d6f3-5dce-a81a-f00ee905e42b -->
  <rule id="633049" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4285 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
