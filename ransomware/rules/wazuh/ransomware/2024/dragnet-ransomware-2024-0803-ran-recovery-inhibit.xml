<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0803 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: d618d944-600e-548f-8ad8-6170d64988a9 -->
  <rule id="479019" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0803 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>