<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1432 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3674c412-e049-5c8d-b20f-a96923416fec -->
  <rule id="579641" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1432 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>