<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4625 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 98ed5182-3250-5dea-b74f-3f1265ff8040 -->
  <rule id="832551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4625 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>