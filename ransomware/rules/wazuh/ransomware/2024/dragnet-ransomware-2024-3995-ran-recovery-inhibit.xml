<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3995 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d2a0b9d2-95ed-565c-92af-cc08ddf0b791 -->
  <rule id="795319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3995 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>