<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5535 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: df358008-2316-55cf-82e1-f49f3917cbf1 -->
  <rule id="533580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5535 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>