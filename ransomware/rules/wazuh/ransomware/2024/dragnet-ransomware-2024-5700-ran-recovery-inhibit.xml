<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5700 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0b05b047-d6e5-528f-bab3-ba676c50eef7 -->
  <rule id="969104" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5700 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
