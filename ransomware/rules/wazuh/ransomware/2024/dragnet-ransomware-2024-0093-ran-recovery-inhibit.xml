<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0093 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 3214f844-05b9-5bec-89ba-69fc1f423a16 -->
  <rule id="743984" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0093 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>