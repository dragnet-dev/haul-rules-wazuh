<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5267 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 98522c79-897f-5c6f-817f-13d015763f9f -->
  <rule id="776364" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5267 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>