<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5490 — Event Log Clearing (abyss) | Status: deprecated | Sigma ID: 21174744-2902-5ae3-8bba-3a01fc6890bd -->
  <rule id="417474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5490 — Event Log Clearing (abyss)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>