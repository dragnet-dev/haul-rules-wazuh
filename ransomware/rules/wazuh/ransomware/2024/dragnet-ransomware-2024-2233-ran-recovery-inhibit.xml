<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2233 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f9f1ac20-db53-5a06-b100-923870875900 -->
  <rule id="351468" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2233 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>