<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4511 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 2bcd7afb-c835-59fb-8e0a-a6d286a42017 -->
  <rule id="994202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4511 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>