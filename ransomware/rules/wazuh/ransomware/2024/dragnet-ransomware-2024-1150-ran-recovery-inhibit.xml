<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1150 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 9017ad2a-5191-5215-a844-58a6a8131c9f -->
  <rule id="608525" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1150 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>