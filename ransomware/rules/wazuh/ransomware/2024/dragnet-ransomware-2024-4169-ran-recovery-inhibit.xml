<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4169 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 9339cdfe-1f63-5f9d-958b-b0ad03dde6eb -->
  <rule id="690989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4169 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>