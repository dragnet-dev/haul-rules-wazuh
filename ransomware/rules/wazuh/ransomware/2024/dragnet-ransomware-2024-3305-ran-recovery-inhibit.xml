<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3305 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 37ff6bd5-dc33-524b-9964-9882bbe14625 -->
  <rule id="756427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3305 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>