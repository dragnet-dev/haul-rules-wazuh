<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0165 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 376c9a91-4985-55b5-bfe6-b468e24f58d6 -->
  <rule id="746349" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0165 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>