<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5722 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 7d2421b4-4bfa-58f1-bde6-b2c793536fa8 -->
  <rule id="452421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5722 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>