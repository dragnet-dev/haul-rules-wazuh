<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2539 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 9d98021c-9702-5365-b443-43bb34d608a1 -->
  <rule id="779802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2539 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>