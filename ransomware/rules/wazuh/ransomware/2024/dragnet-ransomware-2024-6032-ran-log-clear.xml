<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6032 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 14f040a7-7f8e-56cf-ba41-b75ac3dea5ae -->
  <rule id="324650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6032 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>