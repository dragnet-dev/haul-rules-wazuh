<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3998 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 8d0f28fc-b105-5e07-8545-e73e235aa643 -->
  <rule id="557528" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3998 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>