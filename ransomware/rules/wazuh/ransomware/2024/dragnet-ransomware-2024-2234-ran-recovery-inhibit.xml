<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2234 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 67663d7e-5b06-55bc-a088-25749d3f7e90 -->
  <rule id="282621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2234 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>