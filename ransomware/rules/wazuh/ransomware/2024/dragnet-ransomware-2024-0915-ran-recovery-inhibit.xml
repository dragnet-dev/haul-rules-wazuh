<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0915 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: dbda61c3-1764-5f5a-9e8f-9e1144f906b2 -->
  <rule id="328261" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0915 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>