<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4815 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5e6d0d9d-1e0e-52ea-a2ad-bc36bc1763d5 -->
  <rule id="723853" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4815 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>