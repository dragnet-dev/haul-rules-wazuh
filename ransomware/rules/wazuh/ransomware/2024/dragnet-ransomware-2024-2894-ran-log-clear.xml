<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2894 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 60c48d65-c4bd-5e6a-b8a5-2e39f8f62e15 -->
  <rule id="755981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2894 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>