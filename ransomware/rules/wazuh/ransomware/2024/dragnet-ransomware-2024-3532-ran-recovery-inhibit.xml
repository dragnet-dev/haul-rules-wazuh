<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3532 — Recovery Inhibition (play) | Status: experimental | Sigma ID: bd0c55c5-7f3f-5f3e-a477-89b43617b680 -->
  <rule id="425255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3532 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>