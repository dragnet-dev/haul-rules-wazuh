<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4648 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: e9c6a779-e474-5be1-b465-e24b34b22fcf -->
  <rule id="334667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4648 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>