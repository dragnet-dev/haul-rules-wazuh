<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4138 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 100170c0-7556-5236-af5a-0dba80ffebe6 -->
  <rule id="802732" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4138 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>