<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0817 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 57eab482-d88e-5c93-a83d-a8da8a8d1beb -->
  <rule id="672274" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0817 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>