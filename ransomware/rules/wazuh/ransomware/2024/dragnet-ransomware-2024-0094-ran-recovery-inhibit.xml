<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0094 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f47948eb-ec86-59f8-855d-ef9ba2f2481f -->
  <rule id="747948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0094 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>