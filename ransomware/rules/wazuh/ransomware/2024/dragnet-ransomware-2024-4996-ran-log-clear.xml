<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4996 — Event Log Clearing (killsec) | Status: experimental | Sigma ID: edaf1575-c19a-5285-8ee9-79891d9c0a1e -->
  <rule id="784715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4996 — Event Log Clearing (killsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>