<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1189 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 2926d8c5-6231-52b6-80dd-dd1c477c484e -->
  <rule id="392780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1189 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>