<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5262 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7ccbf882-37b1-53bd-8052-a785771ee419 -->
  <rule id="711678" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5262 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>