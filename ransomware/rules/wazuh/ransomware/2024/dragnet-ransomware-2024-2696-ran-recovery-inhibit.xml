<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2696 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4dc0a16d-1a2a-5cf6-b2be-7a4483db7934 -->
  <rule id="290501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2696 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>