<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4190 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d87826cf-7796-5fba-8e06-5227332aa27b -->
  <rule id="587826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4190 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>