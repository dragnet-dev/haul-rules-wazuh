<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1036 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: a2dcfd1d-d2dd-52cb-a44f-ddeb0daf7345 -->
  <rule id="541245" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1036 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>