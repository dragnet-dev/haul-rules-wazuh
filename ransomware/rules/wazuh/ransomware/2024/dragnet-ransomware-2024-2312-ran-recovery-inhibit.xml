<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2312 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 4b390a2f-c918-5e53-984f-06e12537f998 -->
  <rule id="406250" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2312 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>