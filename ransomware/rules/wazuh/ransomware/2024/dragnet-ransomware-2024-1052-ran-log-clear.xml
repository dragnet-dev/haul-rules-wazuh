<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1052 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: c1eeed32-db5a-5b8d-9d4c-4aef6ca7776c -->
  <rule id="891021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1052 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>