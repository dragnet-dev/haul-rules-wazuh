<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0413 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4fa8e3e7-f98a-5122-b56a-16c87fe55e42 -->
  <rule id="339823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0413 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>