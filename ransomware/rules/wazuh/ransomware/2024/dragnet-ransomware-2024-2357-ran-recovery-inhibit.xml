<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2357 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 9e8aa882-eb03-5d28-986b-6cf1b16d9886 -->
  <rule id="566988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2357 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>