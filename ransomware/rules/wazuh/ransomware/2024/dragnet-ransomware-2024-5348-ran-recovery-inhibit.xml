<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5348 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: a18ba55a-b796-5041-ab3e-82abbdced788 -->
  <rule id="907945" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5348 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>