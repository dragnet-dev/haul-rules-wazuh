<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2933 — Event Log Clearing (darkvault) | Status: experimental | Sigma ID: 06e7f2a0-db36-566e-9ee6-401b6d9ebe11 -->
  <rule id="236362" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2933 — Event Log Clearing (darkvault)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>