<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3653 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: a9211dba-b2f6-5c4f-a6f9-1f7520ff1e00 -->
  <rule id="947389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3653 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>