<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4191 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: cdef66a7-ca22-53b5-bc4d-b6e0d627f873 -->
  <rule id="871966" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4191 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>