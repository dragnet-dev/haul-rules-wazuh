<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3868 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 09b3c2ae-48fd-5c0b-83cd-69a5b4eab340 -->
  <rule id="477642" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3868 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>