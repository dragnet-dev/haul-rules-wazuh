<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1705 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f0e604df-4b3c-5fcd-98a2-b5c8e42e3afb -->
  <rule id="714604" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1705 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>