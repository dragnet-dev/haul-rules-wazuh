<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1992 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: df409fe8-4533-5807-b29a-68e943779078 -->
  <rule id="974559" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1992 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>