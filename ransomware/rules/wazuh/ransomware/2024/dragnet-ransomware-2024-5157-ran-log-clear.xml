<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5157 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: 4b26aa8e-b2f5-5cc9-9195-d8d995104ed5 -->
  <rule id="226826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5157 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>