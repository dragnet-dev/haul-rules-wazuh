<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2084 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 40fa0c63-5aee-5f87-9466-f3afa83cfd08 -->
  <rule id="878412" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2084 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>