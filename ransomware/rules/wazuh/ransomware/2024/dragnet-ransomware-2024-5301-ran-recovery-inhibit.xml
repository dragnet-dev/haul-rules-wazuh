<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5301 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 888ab85c-e4f0-55fd-99e7-8a3fb7015364 -->
  <rule id="574998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5301 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>