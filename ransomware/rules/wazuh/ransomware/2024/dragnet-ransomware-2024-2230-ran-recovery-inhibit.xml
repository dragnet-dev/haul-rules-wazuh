<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2230 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 615c4266-e544-5e4a-914a-4e4a1cf5b28c -->
  <rule id="952426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2230 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>