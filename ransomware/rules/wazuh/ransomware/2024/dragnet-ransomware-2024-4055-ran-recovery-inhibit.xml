<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4055 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: a7ef2273-df03-5434-b0ca-786a2843e5bc -->
  <rule id="163122" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4055 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>