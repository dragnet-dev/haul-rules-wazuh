<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5134 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 43290ddb-f80f-5563-a56f-b1531ed7d7c6 -->
  <rule id="382461" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5134 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>