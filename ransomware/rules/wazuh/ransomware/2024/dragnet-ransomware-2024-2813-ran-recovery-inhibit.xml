<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2813 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ddc1d9ed-9b2e-517f-be68-8c01b72b612a -->
  <rule id="377099" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2813 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>