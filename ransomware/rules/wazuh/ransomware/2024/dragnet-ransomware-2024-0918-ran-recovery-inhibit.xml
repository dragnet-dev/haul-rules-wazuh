<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0918 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: 08b30a5b-23ed-551f-9cd5-b26bbd44748b -->
  <rule id="528905" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0918 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>