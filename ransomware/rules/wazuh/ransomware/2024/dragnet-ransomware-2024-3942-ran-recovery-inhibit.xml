<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3942 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 0398779b-83cb-59da-959e-ac845e431f1e -->
  <rule id="180475" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3942 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>