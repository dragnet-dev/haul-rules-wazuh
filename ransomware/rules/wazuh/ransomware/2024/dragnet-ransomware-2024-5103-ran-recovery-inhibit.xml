<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5103 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0a8b58c1-f234-5bec-9368-bbbc094cb241 -->
  <rule id="183340" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5103 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
