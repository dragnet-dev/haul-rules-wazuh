<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5947 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 655fa7a4-5c54-5364-ad62-036242b42396 -->
  <rule id="879307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5947 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>