<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0429 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: a0fb7f42-e153-5ed1-9bc1-c4c8cbef6f63 -->
  <rule id="636287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0429 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>