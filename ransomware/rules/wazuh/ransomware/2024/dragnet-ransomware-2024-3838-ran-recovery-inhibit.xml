<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3838 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: c1a228b4-e463-52a9-ab66-283f558f0ad4 -->
  <rule id="246228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3838 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>