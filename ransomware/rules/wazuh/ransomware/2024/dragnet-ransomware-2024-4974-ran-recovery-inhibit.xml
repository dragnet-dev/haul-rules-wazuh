<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4974 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 7a05263b-a703-5576-a588-761fa622d3db -->
  <rule id="420526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4974 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>