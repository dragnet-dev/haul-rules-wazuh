<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4179 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3d4c67e7-340b-5634-9191-06259390c51a -->
  <rule id="538686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4179 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>