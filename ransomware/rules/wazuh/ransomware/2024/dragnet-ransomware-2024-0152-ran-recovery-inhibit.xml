<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0152 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 63e1d571-60de-592b-9f39-7044ae579d7b -->
  <rule id="835495" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0152 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>