<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5366 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: ff6e3cc6-8cb7-5f52-925b-8a97fff562e7 -->
  <rule id="345660" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5366 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>