<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4114 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: b95904cf-992b-533e-82da-70eea5207a71 -->
  <rule id="395904" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4114 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>