<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3521 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: 272c36e9-6610-5e23-bd04-a6bb98c01f22 -->
  <rule id="782990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3521 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>