<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5481 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b9f2b884-705a-5717-938c-bffc47195369 -->
  <rule id="470838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5481 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>