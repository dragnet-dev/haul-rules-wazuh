<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0432 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 6ce4fb2b-96c5-5064-b431-3da08ea7eceb -->
  <rule id="960795" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0432 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>