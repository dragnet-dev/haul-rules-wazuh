<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4558 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 0496527a-358b-5f41-80cd-8a043cedc745 -->
  <rule id="844442" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4558 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>