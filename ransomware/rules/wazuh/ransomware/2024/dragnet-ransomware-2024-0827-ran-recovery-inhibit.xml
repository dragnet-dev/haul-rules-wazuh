<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0827 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6d5ae3b3-b832-5b3e-8e81-e37ec844be7d -->
  <rule id="204943" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0827 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>