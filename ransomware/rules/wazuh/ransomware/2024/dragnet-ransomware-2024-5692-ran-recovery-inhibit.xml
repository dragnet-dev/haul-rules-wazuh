<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5692 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 117b6ad3-0c63-594a-8e16-31e40ea2c94a -->
  <rule id="422189" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5692 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>