<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0111 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 1ae0bddb-0968-5f01-9a29-800044ff31a9 -->
  <rule id="300989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0111 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>