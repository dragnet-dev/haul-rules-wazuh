<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1699 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ae80ed0b-3613-5f52-9da1-94ae3957e2d8 -->
  <rule id="975117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1699 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>