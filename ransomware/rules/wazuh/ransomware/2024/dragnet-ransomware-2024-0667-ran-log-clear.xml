<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0667 — Event Log Clearing (helldown) | Status: experimental | Sigma ID: eac070ad-12c6-5c42-b984-981d490ad8e0 -->
  <rule id="256070" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0667 — Event Log Clearing (helldown)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>