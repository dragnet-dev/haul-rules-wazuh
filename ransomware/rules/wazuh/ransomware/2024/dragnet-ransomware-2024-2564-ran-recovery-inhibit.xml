<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2564 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 4a4afc45-24e3-5ae2-a171-81c35675b2d3 -->
  <rule id="450236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2564 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>