<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1972 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 59b72506-5a97-50a7-92c2-f605e2a02769 -->
  <rule id="657250" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1972 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>