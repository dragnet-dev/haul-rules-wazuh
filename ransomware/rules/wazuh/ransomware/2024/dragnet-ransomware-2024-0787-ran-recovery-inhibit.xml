<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0787 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 5733dccd-2ab8-5e8b-b230-a0f423f66c8b -->
  <rule id="667868" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0787 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>