<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5729 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5b492849-fa8d-5aba-97cd-603457341b5f -->
  <rule id="249284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5729 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>