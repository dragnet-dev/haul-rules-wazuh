<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0544 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 9a19bf42-4cdd-5508-a2f5-97b61a159b4b -->
  <rule id="447455" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0544 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>