<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3119 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d7c30d3e-01ff-532c-ba3a-c92704853f42 -->
  <rule id="926893" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3119 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>