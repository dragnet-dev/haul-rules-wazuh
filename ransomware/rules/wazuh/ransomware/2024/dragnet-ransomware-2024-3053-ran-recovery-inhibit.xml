<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3053 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 88f21f5c-0801-56ed-9990-0439b9c01266 -->
  <rule id="577151" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3053 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>