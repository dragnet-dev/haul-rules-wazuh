<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0852 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 134b72cb-e29f-53bb-80bf-c6e966ff8835 -->
  <rule id="849164" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0852 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
