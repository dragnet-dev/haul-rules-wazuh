<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3545 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 357ce100-33ea-5695-b814-daf9d5e529fa -->
  <rule id="259810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3545 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>