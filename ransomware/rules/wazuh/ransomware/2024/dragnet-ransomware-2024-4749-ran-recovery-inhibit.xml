<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4749 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 4049fda5-4fa8-5a5c-9146-bec56c828b8f -->
  <rule id="236797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4749 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>