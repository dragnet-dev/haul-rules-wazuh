<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1234 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 581b1c79-b123-5950-9a6d-284e86d29fe4 -->
  <rule id="689148" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1234 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>