<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5144 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 5eab7999-a65d-5c69-9a7a-4078ca40533d -->
  <rule id="723579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5144 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>