<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2865 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 3d7d1977-56a8-567b-be75-63daba3d429b -->
  <rule id="985197" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2865 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>