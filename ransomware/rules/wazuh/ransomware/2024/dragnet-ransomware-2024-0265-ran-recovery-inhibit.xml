<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0265 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8d280db1-3ba5-51b5-b7fd-ad6a96149cbf -->
  <rule id="560493" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0265 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>