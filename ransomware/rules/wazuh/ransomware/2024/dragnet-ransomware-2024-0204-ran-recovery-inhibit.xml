<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0204 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f1862f8e-7185-591a-a1f3-526afcb02968 -->
  <rule id="729807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0204 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>