<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1125 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 47bcc4da-2bfe-59cf-b74a-8d5110807d14 -->
  <rule id="255324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1125 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>