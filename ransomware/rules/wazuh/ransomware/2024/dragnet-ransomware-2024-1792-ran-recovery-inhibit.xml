<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1792 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 8fbe4d2c-bf8e-532c-8520-168484061027 -->
  <rule id="587757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1792 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>