<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5703 — Event Log Clearing (underground) | Status: experimental | Sigma ID: 6aca5493-9d73-54a4-9b61-685df5bc131e -->
  <rule id="133854" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5703 — Event Log Clearing (underground)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>