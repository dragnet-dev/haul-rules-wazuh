<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4471 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: b7bb4f2b-c30e-51e4-89f3-06201000456e -->
  <rule id="422319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4471 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>