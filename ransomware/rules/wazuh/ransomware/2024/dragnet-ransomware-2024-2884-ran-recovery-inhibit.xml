<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2884 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e1431d0b-0583-574c-a8d5-42557a375972 -->
  <rule id="562909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2884 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>