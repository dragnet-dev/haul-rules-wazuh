<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5526 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 17fdfca0-0da2-5bab-b720-c5039d8d91a4 -->
  <rule id="379132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5526 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>