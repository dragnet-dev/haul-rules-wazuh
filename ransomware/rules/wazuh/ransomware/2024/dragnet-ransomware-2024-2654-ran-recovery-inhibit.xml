<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2654 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 338e09d2-deed-5184-b9db-0ab3b087760e -->
  <rule id="675357" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2654 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>