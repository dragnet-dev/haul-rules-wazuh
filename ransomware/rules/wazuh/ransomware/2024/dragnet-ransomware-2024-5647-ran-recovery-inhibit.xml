<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5647 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 7b6a08f5-9fb5-587d-b862-dcf0e17196fc -->
  <rule id="278608" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5647 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>