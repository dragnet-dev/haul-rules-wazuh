<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4753 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 0424b258-9697-5057-bf10-5055b84fb91a -->
  <rule id="595258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4753 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>