<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4290 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e3097d02-7b79-580c-bd5b-65f5e91837a6 -->
  <rule id="589565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4290 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>