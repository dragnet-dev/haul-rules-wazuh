<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5178 — Event Log Clearing (dragonforce) | Status: experimental | Sigma ID: 4a2c08fb-03e5-5033-9af9-33e8c12b5bd6 -->
  <rule id="388408" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5178 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>