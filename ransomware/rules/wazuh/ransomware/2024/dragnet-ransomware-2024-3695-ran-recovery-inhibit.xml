<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3695 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: a189ab92-d200-5f1f-a213-b9cb0b66d8e7 -->
  <rule id="908555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3695 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
