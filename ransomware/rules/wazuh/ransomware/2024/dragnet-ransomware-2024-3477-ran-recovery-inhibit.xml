<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3477 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 6b1e80b1-a4f2-5543-8429-c36455b93599 -->
  <rule id="915080" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3477 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>