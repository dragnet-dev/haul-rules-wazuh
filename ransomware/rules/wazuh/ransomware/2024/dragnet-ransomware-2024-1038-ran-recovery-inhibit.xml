<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1038 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: a4caddff-eb02-5848-8b69-de9efbc96a93 -->
  <rule id="667677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1038 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>