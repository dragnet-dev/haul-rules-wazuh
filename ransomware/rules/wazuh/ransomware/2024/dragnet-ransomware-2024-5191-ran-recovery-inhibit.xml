<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5191 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 5683c9e6-a55e-5a41-947b-bf06e40b7468 -->
  <rule id="250558" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5191 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>