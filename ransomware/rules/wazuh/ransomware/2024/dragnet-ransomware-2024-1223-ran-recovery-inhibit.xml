<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1223 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b0da83d7-a9f2-5bc4-8a60-a78c7d77c35b -->
  <rule id="237883" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1223 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>