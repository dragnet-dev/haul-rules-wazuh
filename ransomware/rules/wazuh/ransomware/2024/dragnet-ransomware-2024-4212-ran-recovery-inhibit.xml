<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4212 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9a49ba12-15a6-5b54-a75a-5ff2bc525f8c -->
  <rule id="455130" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4212 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>