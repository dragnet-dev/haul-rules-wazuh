<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0249 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c866b32b-3206-5434-9d1a-537c6980967d -->
  <rule id="358673" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0249 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>