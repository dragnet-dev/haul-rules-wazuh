<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3665 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 15234ac3-9fd4-5d04-a533-60b7cf185f33 -->
  <rule id="400076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3665 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>