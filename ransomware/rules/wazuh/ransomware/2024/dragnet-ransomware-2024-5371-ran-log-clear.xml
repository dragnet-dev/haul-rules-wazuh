<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5371 — Event Log Clearing (8base) | Status: experimental | Sigma ID: 1c7ec7f1-7a2f-59ec-8fa2-95634ebbbb0c -->
  <rule id="193407" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5371 — Event Log Clearing (8base)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>