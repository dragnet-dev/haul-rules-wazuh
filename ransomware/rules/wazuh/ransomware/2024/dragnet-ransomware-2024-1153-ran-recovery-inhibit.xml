<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1153 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6af510eb-2348-5717-96fc-133ed2899175 -->
  <rule id="911510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1153 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>