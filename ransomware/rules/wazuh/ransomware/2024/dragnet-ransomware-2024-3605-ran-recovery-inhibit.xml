<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3605 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 4d887c2a-8c6d-5448-8067-0e9fce08b33f -->
  <rule id="446204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3605 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>