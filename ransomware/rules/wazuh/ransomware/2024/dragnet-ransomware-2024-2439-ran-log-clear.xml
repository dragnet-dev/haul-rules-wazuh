<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2439 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 20f9e027-a4a7-5d16-b01d-8957b2fccfb6 -->
  <rule id="975802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2439 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>