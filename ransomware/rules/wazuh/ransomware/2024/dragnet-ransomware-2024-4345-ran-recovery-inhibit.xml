<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4345 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 3da25bff-6b44-527f-8127-3d3b3920a9e3 -->
  <rule id="778011" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4345 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>