<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2097 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 8674ea29-3a21-50b3-af2f-aaad5200cfe2 -->
  <rule id="520778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2097 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>