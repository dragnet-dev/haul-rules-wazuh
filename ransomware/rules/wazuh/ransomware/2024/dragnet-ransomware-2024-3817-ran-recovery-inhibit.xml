<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3817 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3fb61b3c-631f-5cb5-9d0b-c91e29dbddfb -->
  <rule id="831387" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3817 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
