<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4714 — Event Log Clearing (ElDorado) | Status: deprecated | Sigma ID: 5c6c8cb9-193d-56e4-86f8-073e34c174ad -->
  <rule id="672620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4714 — Event Log Clearing (ElDorado)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>