<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5719 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ea845f53-19ca-5cb2-b4d6-63f6efa63f30 -->
  <rule id="257535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5719 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>