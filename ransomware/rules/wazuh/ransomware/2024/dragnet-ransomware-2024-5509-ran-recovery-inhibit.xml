<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5509 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 870752b9-41fd-5ec5-a169-04c496f13b6d -->
  <rule id="532043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5509 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>