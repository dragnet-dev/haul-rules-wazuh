<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3504 — Recovery Inhibition (trinity) | Status: experimental | Sigma ID: 4fc91acf-2ebd-549c-b011-05ea6a66df35 -->
  <rule id="343066" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3504 — Recovery Inhibition (trinity)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>