<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3850 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 689770c3-a9a5-55e1-830c-2759bc05e271 -->
  <rule id="336332" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3850 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>