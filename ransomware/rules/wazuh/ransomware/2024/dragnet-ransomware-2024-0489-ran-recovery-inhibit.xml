<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0489 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 77e6e120-2aec-52f5-9fd6-018ffb90b3da -->
  <rule id="294701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0489 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>