<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1322 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d57e8f13-22e8-5ce4-8366-bf22c52a1a0d -->
  <rule id="876303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1322 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>