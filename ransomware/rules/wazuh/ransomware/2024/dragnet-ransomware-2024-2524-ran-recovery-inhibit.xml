<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2524 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 35aa2b5c-35a6-5bcb-a484-4fb84c1ccb58 -->
  <rule id="660843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2524 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>