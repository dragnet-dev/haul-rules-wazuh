<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2010 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 531d54ba-aab1-56b3-8093-a9e135558c33 -->
  <rule id="215275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2010 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>