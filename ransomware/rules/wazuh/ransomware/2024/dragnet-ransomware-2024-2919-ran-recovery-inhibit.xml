<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2919 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d2a4bc84-a9d5-5da2-921a-f705835e2f00 -->
  <rule id="133532" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2919 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>