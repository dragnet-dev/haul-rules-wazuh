<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5280 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6326eadc-efec-5afc-9549-cf4b018eb8e1 -->
  <rule id="819690" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5280 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>