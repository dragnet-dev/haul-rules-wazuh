<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4588 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 88a9733f-068a-5f8c-bdbb-0be62d6f5e11 -->
  <rule id="618973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4588 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>