<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1463 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: eabd0bab-e9a1-518f-9aa3-53a4438eb03c -->
  <rule id="714891" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1463 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>