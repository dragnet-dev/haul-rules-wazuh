<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1830 — Event Log Clearing (dragonransomware) | Status: experimental | Sigma ID: b9be5e0d-7a69-5227-88ff-2a5e0cf01d83 -->
  <rule id="504734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1830 — Event Log Clearing (dragonransomware)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>