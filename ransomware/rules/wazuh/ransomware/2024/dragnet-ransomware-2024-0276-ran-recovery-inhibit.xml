<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0276 — Recovery Inhibition (blackout) | Status: experimental | Sigma ID: 2aef2a1d-cd51-52be-9bc5-ffedb0b7d17b -->
  <rule id="958602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0276 — Recovery Inhibition (blackout)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>