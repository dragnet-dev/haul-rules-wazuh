<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1950 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a94ecd66-fb33-5461-bc96-a926fe6fb539 -->
  <rule id="984813" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1950 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>