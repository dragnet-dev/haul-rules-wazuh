<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2372 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: ed1e0dbd-27df-5b59-95c6-f4984b3c2993 -->
  <rule id="772013" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2372 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>