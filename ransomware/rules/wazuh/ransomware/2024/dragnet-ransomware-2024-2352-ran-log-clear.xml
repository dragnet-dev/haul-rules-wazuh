<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2352 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: 861761cd-2c1a-5cf1-86c1-ed9c9e9795c0 -->
  <rule id="388188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2352 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>