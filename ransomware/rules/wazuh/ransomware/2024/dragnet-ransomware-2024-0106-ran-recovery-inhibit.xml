<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0106 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 54bc3187-3954-555a-8b26-65a0373207c3 -->
  <rule id="601231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0106 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>