<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4180 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 59dcaaf2-738f-5008-a15e-0f9235f5376b -->
  <rule id="423114" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4180 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>