<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1191 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: adbedad3-cbe6-5a23-8297-d84a8c992afb -->
  <rule id="686586" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1191 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>