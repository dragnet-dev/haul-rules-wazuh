<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5110 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 7810de54-f3ce-5ee7-a556-23ee83944dce -->
  <rule id="299582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5110 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>