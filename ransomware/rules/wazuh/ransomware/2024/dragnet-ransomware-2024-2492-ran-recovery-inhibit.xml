<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2492 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 7b6f8756-4506-5f3c-929f-162b33fb0436 -->
  <rule id="279187" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2492 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>