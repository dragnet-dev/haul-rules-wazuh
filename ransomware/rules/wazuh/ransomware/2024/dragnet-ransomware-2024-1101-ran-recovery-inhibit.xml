<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1101 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 719ca1eb-d569-5eeb-a1e9-acea7eee33e7 -->
  <rule id="142661" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1101 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>