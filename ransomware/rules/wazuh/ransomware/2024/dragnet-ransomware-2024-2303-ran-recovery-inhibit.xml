<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2303 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 781ef667-6825-5c60-aef3-d03fc823972e -->
  <rule id="301756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2303 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>