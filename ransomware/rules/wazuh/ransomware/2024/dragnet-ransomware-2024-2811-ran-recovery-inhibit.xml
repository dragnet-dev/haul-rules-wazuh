<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2811 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: b3844906-c253-5bd5-b5f7-726537d85b6f -->
  <rule id="338449" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2811 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>