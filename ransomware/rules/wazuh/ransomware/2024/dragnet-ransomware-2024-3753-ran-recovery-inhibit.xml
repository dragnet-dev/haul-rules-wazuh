<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3753 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: d3bfb18b-acd6-5891-8b18-969a72190186 -->
  <rule id="178351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3753 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>