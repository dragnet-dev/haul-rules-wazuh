<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1236 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: d4a76f37-175c-5a45-bcc6-24f877a157dc -->
  <rule id="847631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1236 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>