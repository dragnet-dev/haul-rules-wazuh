<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2576 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: eedb48b4-ece2-52f6-a403-1a73cd7674c6 -->
  <rule id="814748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2576 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>