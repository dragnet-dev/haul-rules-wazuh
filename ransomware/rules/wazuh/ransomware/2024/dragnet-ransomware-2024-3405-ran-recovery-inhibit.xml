<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3405 — Recovery Inhibition (play) | Status: experimental | Sigma ID: cdead17f-a3d5-5a8a-8279-fe09ea16464c -->
  <rule id="434371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3405 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>