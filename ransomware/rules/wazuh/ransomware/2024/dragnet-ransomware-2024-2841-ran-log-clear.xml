<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2841 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: d48c619f-ab1d-5e1e-a4d0-6ad9a542413f -->
  <rule id="458061" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2841 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>