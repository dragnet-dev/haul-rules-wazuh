<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2042 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 607f2f95-64b9-5056-a43e-24b4e4e597f9 -->
  <rule id="756367" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2042 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>