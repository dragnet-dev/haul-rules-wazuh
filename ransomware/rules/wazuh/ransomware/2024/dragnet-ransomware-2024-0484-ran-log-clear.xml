<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0484 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: e938f7a6-ab3d-5be4-a6b8-8e7e8f799564 -->
  <rule id="690237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0484 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>