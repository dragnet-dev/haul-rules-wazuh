<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1904 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 59f553b4-e5b2-5299-b6d9-177597c18dce -->
  <rule id="152859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1904 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>