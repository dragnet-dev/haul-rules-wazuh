<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5582 — Recovery Inhibition (play) | Status: experimental | Sigma ID: baa16958-59ed-596f-9579-cb5a1066291d -->
  <rule id="386169" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5582 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>