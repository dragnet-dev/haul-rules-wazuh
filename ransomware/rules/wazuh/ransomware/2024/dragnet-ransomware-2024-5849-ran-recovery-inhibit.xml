<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5849 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 7d031afa-bcbe-546b-a5c2-85a4807a87b2 -->
  <rule id="300506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5849 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>