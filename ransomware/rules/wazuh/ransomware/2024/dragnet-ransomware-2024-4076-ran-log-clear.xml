<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4076 — Event Log Clearing (madliberator) | Status: experimental | Sigma ID: dca6fc6c-3ed7-5da1-b3e1-fcdccf631690 -->
  <rule id="138588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4076 — Event Log Clearing (madliberator)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>