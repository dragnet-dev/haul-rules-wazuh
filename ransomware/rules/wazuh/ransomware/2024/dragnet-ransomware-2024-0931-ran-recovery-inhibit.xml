<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0931 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 24589064-6de8-5561-8d82-d8d08385c086 -->
  <rule id="758906" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0931 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>