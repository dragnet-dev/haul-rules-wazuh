<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3349 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: bf63b147-48a3-5b20-b50f-52c176c786c6 -->
  <rule id="466191" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3349 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>