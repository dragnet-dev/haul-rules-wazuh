<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5000 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c6522096-d2aa-5f72-894c-8971aa2174e2 -->
  <rule id="465220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5000 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>