<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4029 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 718fee79-ebbf-520a-bb17-81bde728a571 -->
  <rule id="345006" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4029 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
