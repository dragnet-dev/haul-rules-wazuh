<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0242 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: e8501938-eb5f-5893-b9d8-beeb0d9ee806 -->
  <rule id="685019" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0242 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>