<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5289 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 0a06e067-880b-568d-99de-2b09d639622e -->
  <rule id="811006" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5289 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>