<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5636 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7164f8e2-92d0-53b9-af70-2ef7090a9dd1 -->
  <rule id="346398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5636 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>