<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3793 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 1a5117cd-7418-531d-a97a-a6103531fba2 -->
  <rule id="741884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3793 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>