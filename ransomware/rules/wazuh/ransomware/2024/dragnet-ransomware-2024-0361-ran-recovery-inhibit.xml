<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0361 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 10294cf4-6c65-5e9c-b288-5a0bfc841948 -->
  <rule id="935471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0361 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>