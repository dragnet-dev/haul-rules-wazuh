<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3205 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 15d25443-7eda-5aee-a746-ee78f55d51c0 -->
  <rule id="832544" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3205 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>