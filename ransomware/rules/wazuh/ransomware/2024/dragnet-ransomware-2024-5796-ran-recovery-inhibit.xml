<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5796 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: dcab88e4-2384-5ba4-9dcd-7ee9035de64a -->
  <rule id="349188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5796 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>