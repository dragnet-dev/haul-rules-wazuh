<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4162 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: bd456852-53e5-5758-b1bd-770f5581cc81 -->
  <rule id="194568" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4162 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>