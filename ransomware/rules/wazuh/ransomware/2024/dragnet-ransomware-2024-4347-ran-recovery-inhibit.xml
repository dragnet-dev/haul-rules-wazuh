<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4347 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: f0eea117-3c07-5e3b-aad8-6c68cb77af31 -->
  <rule id="882181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4347 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>