<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5661 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: df578c06-6af5-5707-8d39-c15220e14b23 -->
  <rule id="977260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5661 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>