<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4176 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ea3d788b-e202-501a-b55e-c1e0761513c6 -->
  <rule id="250178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4176 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>