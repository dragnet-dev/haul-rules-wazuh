<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1286 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2f51180a-dd50-5833-aee6-03ae483b0f5f -->
  <rule id="351180" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1286 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>