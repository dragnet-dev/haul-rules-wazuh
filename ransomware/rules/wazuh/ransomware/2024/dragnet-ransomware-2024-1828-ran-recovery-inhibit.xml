<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1828 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 9f7b8f62-bd07-5cf9-accf-c3d20cc31ee9 -->
  <rule id="590223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1828 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>