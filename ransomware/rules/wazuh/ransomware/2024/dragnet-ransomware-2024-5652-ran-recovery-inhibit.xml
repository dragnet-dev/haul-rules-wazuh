<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5652 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 067160ee-3412-5d8b-8f60-e8d030fbac16 -->
  <rule id="274574" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5652 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>