<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2788 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 85886693-43ef-5d01-a74a-26a37328bacf -->
  <rule id="588669" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2788 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
