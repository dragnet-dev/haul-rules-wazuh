<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2219 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: b406b477-160a-5f70-8dea-848e99395622 -->
  <rule id="125074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2219 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>