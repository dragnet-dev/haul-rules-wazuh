<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1125 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: a6a6d2aa-b153-531e-a5c4-ad6f11b5ee5d -->
  <rule id="130692" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1125 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>