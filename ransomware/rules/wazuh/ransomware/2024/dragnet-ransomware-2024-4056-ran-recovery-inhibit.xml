<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4056 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: 80feccc6-3261-5702-8a39-78dc78745da0 -->
  <rule id="908108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4056 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>