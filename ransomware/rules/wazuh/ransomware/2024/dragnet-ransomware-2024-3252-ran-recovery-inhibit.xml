<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3252 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 08c8247b-619c-5883-8ea9-cc48f03e9e8f -->
  <rule id="608247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3252 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>