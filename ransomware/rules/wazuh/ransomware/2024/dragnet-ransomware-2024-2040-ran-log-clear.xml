<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2040 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: b5e5e7a0-6b0b-5a65-b2c5-356c1b75a8b5 -->
  <rule id="367347" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2040 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>