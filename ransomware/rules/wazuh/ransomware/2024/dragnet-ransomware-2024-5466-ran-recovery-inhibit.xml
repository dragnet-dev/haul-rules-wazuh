<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5466 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 9cfc6dca-875d-5525-be41-06f2fe0e4c57 -->
  <rule id="230189" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5466 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>