<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5052 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: 0a9caa5d-4453-5b53-a925-f6e85e4392c1 -->
  <rule id="997065" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5052 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>