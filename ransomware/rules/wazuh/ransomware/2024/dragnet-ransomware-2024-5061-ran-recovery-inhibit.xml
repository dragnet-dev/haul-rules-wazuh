<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5061 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d71ff71d-f698-58c4-95c8-51e8cb63c8ce -->
  <rule id="912317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5061 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>