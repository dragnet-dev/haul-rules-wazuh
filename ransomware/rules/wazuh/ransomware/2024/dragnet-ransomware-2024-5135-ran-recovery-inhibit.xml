<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5135 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: ae8ade06-1606-529b-a77a-e725184a83ae -->
  <rule id="962590" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5135 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>