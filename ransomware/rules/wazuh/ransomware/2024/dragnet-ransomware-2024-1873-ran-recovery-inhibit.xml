<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1873 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 3f734d54-524d-56af-bd22-6f99d3c35a0a -->
  <rule id="219757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1873 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>