<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4652 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 7521f862-d06d-5685-b3b4-91e7610205e1 -->
  <rule id="403518" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4652 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>