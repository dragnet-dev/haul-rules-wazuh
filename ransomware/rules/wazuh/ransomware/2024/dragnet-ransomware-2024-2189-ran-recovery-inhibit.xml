<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2189 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f58b464d-5d8d-5378-aefa-9d12359b25aa -->
  <rule id="793946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2189 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>