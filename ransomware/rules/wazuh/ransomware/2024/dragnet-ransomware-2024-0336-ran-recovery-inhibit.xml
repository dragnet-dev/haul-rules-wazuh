<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0336 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: bb0cec40-7a23-5d79-9af6-dae713c0a7f7 -->
  <rule id="562828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0336 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>