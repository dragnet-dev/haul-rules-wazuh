<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3027 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e67d022e-ddad-5982-b03b-6029f1be6ecb -->
  <rule id="648502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3027 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>