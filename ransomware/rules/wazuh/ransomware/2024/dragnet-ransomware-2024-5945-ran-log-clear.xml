<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5945 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 2ab9132a-f80c-5394-8bf1-1c7ffd3a46c0 -->
  <rule id="639132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5945 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>