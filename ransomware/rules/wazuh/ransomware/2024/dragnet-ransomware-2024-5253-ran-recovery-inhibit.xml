<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5253 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 3006954c-2696-5de5-b03b-3909ae4b8855 -->
  <rule id="406954" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5253 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>