<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4135 — Event Log Clearing (trigona) | Status: experimental | Sigma ID: ee8c7fc3-9ba8-58a1-acee-69ffb6cd4c21 -->
  <rule id="815327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4135 — Event Log Clearing (trigona)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>