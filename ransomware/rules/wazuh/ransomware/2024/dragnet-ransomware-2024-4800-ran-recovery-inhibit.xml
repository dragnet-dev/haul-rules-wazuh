<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4800 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 712c6fc8-4a50-571d-b6f8-dca33ad92432 -->
  <rule id="124751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4800 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>