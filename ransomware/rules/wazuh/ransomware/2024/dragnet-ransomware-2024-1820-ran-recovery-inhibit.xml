<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1820 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: be32699a-befe-5487-8f18-3fd1ed4b7b27 -->
  <rule id="203269" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1820 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>