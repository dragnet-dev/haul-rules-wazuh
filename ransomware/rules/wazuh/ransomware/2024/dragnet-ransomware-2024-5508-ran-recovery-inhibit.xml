<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5508 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 8680dd22-101a-5b1b-9498-6d76a3eb1b24 -->
  <rule id="522301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5508 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>