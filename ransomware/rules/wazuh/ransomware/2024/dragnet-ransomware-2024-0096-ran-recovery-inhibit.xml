<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0096 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: c1af5af7-c9d0-51ef-bb0e-08ee7e664d21 -->
  <rule id="584250" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0096 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>