<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0854 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 44e1085a-30df-5cc2-9579-d61f08502799 -->
  <rule id="981085" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0854 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>