<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0347 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 1be1c6ae-4530-5944-be88-134c1fc10326 -->
  <rule id="722186" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0347 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>