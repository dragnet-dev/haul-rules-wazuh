<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1673 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8791d52c-6f95-5422-9bf3-120b4afe71e7 -->
  <rule id="606695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1673 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>