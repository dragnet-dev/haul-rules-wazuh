<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5623 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: ed565696-b9a6-5aa4-bc52-1b72d345d615 -->
  <rule id="675656" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5623 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>