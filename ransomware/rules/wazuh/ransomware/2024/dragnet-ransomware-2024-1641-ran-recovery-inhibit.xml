<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1641 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f52cbc35-86c9-501f-a2fe-7486dfbd3dab -->
  <rule id="160252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1641 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>