<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4628 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: aa07347b-7758-53df-894a-87276c8989f3 -->
  <rule id="900734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4628 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>