<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0745 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 26ec9e73-f0d1-56e9-b3c3-98d4f5096b90 -->
  <rule id="302878" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0745 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>