<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2569 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 906a7aaa-a7b4-536d-b0e9-4ff12987d812 -->
  <rule id="621082" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2569 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>