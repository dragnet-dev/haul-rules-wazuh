<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4133 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e5f8fbc9-8551-53bb-b61e-4160225876bc -->
  <rule id="679899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4133 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>