<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5097 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: f10789e9-d729-522d-b508-c87aeac13ad1 -->
  <rule id="710789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5097 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>