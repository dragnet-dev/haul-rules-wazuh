<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1137 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 93b15835-9eca-59de-9688-7f7cbfeb0c0d -->
  <rule id="699158" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1137 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>