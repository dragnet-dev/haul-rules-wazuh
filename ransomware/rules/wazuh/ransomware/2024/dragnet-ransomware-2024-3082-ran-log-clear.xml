<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3082 — Event Log Clearing (play) | Status: experimental | Sigma ID: 7c7467ca-f9d0-5e8f-8c0b-34f9265cfb70 -->
  <rule id="447467" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3082 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>