<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0599 — Recovery Inhibition (play) | Status: experimental | Sigma ID: fc07e143-d408-57e0-80e8-9600916cebf8 -->
  <rule id="533261" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0599 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>