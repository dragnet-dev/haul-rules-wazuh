<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0839 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 1736fced-7a8d-5435-968b-d486753d4f3c -->
  <rule id="914702" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0839 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>