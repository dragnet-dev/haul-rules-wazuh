<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1193 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: f3d39789-6978-559c-975a-6c2239d413d5 -->
  <rule id="761397" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1193 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>