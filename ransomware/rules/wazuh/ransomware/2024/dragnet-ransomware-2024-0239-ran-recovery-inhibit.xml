<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0239 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0b93013e-d5f4-53c9-bdc3-c1da6a748a12 -->
  <rule id="393013" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0239 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>