<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3803 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 85746c44-efd7-5af7-90c2-271e8251b7e1 -->
  <rule id="571948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3803 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>