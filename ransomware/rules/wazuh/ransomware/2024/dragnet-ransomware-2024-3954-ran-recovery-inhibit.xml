<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3954 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4477de16-42fc-54b3-9e81-34307094a4ce -->
  <rule id="346334" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3954 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>