<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5062 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 46dcd043-61db-550a-bb9f-1b7b71965bec -->
  <rule id="219490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5062 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>