<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5391 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 04804ea3-5be1-59f6-86d9-84a964cff881 -->
  <rule id="430058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5391 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>