<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5897 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 6b8f0353-ed97-5148-a281-6a1e1ddd80d1 -->
  <rule id="926303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5897 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>