<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3113 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b1d55d1a-462f-5dfd-912c-4423cb18a810 -->
  <rule id="263293" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3113 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>