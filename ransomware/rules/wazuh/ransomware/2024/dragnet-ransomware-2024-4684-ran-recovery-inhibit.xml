<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4684 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 12897b96-1f95-5c14-aabc-b8ae45d91845 -->
  <rule id="363639" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4684 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>