<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3667 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 39922965-b3d8-5450-94d0-a00c4c454201 -->
  <rule id="492296" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3667 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>