<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4481 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 8ade2c5e-17c5-5c89-b199-db2a73eecb21 -->
  <rule id="388044" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4481 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>