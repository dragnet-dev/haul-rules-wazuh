<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2857 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 4865c2f0-f411-518d-ba8c-3fc037240d49 -->
  <rule id="856367" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2857 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>