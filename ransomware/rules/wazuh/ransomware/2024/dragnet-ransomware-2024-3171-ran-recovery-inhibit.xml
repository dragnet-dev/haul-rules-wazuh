<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3171 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 1dbcb828-ac45-5014-bc4f-f8a8f885c8e9 -->
  <rule id="418038" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3171 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>