<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4140 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f0aa3a95-100e-5807-9547-e4c56153c3ef -->
  <rule id="871258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4140 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>