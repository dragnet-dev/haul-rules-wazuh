<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3273 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 13dcba8e-a987-5ca5-8c17-b62537f0636f -->
  <rule id="184748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3273 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>