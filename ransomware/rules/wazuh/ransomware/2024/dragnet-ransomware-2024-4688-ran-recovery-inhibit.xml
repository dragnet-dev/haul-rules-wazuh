<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4688 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0704232b-09a3-5b88-8c75-f4aa4c0ec11f -->
  <rule id="567723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4688 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>