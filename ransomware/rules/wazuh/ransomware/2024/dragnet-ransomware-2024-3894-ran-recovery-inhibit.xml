<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3894 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 259ab859-7ee1-5589-b315-1efc612ed3d3 -->
  <rule id="447585" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3894 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>