<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4414 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 1b5ddf6e-3327-55ff-8394-3641d0df4e00 -->
  <rule id="329951" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4414 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>