<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3711 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 81d81f24-dc15-5348-935e-c3fd6314b33f -->
  <rule id="395711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3711 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>