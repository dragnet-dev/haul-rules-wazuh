<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0433 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2938fb2b-9083-5414-a3f5-79a213ecc1f4 -->
  <rule id="423792" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0433 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>