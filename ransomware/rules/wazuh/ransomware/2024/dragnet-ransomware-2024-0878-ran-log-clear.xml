<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0878 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: cc74b2a8-f3ab-51cd-b2c3-e9951fd6a5b1 -->
  <rule id="675952" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0878 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>