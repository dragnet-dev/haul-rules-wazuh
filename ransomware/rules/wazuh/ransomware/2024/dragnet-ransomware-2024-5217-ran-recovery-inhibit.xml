<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5217 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 291dfdec-0b96-570a-8ca3-f2111cfbb9e4 -->
  <rule id="395517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5217 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>