<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0670 — Event Log Clearing (mogilevich) | Status: deprecated | Sigma ID: 77384bfe-ef98-5b53-987a-ca377f48e827 -->
  <rule id="438155" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0670 — Event Log Clearing (mogilevich)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>