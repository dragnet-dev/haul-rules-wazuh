<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5640 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 22c9d184-9d25-5c4b-afdb-cd5cefdc3249 -->
  <rule id="539718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5640 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>