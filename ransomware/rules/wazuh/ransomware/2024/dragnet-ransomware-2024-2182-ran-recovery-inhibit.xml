<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2182 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 03045fd3-6ba1-5b7f-bb92-bdec999115d0 -->
  <rule id="697733" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2182 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>