<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5807 — Event Log Clearing (play) | Status: experimental | Sigma ID: c778d8c5-2d7e-5ce2-9bf3-8468c07fc7d8 -->
  <rule id="344618" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5807 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>