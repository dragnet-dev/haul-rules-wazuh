<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5564 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: b9f0b4ad-5677-5ede-892d-64090a6489e9 -->
  <rule id="470514" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5564 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>