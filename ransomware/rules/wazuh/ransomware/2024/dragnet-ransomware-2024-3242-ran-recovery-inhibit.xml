<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3242 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ef0b99ad-c13b-524a-84a2-3d087cecede9 -->
  <rule id="325199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3242 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>