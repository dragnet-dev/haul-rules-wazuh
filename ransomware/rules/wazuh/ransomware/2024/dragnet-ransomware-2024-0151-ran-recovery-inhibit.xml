<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0151 — Recovery Inhibition (play) | Status: experimental | Sigma ID: bc3d7439-a227-5754-bbfd-629ffee24b99 -->
  <rule id="414174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0151 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>