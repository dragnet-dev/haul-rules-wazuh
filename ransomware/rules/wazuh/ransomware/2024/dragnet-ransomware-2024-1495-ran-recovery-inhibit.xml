<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1495 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 89779dc3-1c1d-5ce6-a46b-8295c7731ee1 -->
  <rule id="636477" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1495 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>