<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1604 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 2de61ec6-7d77-5cf7-9f6c-d1f9e303483a -->
  <rule id="375390" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1604 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>