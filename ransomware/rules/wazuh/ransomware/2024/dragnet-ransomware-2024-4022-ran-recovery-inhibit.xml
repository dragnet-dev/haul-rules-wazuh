<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4022 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 793da74b-b52a-5647-8559-97995fe23ba0 -->
  <rule id="332267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4022 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>