<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5886 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 355d238a-1d77-5287-a4e5-92d5a7c68c69 -->
  <rule id="393238" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5886 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>