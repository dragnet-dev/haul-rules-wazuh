<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2698 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: c7fd297a-c7ad-52c4-8849-3a096ac6775f -->
  <rule id="676529" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2698 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>