<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2390 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 7d47b231-189a-5899-a886-7d69a7050910 -->
  <rule id="307632" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2390 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
