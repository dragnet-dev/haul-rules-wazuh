<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2216 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 0b7515ec-fb17-533e-81ee-7874aa716b52 -->
  <rule id="180254" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2216 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>