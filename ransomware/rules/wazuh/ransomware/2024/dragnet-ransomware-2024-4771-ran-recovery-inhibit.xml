<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4771 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 6e11f88f-437c-5dae-a5bd-ef4443e9a97d -->
  <rule id="961918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4771 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>