<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1745 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 8e19bfc9-fb46-5a62-8f49-f827ff74a8a8 -->
  <rule id="140255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1745 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>