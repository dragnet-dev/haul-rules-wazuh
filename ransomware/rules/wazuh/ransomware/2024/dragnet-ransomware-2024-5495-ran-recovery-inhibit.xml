<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5495 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 48de2f7e-b092-5262-854b-dfb9c08af691 -->
  <rule id="301647" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5495 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>