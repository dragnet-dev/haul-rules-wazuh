<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5641 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 5a7430dc-1686-5212-a1e9-2326cdb8803c -->
  <rule id="218893" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5641 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>