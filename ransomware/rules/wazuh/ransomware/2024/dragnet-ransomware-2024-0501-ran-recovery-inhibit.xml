<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0501 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 78007d15-6cd8-5654-9ed4-a24f57b50fec -->
  <rule id="448125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0501 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>