<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3194 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: b9aa5b3d-59df-5eed-b646-a050483d22ee -->
  <rule id="501531" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3194 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>