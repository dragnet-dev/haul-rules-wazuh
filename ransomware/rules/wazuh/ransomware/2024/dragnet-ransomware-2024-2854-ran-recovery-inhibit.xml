<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2854 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 296ea329-d297-58f2-a8dc-44c5e8b652c6 -->
  <rule id="501032" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2854 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>