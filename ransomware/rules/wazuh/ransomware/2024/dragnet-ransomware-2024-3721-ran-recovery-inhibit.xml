<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3721 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 22d127ca-4f68-5255-a31b-ccef62e14fb4 -->
  <rule id="542044" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3721 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>