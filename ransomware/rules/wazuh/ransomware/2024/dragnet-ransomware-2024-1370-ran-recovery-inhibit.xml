<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1370 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: fc75840c-ba55-5c15-8791-49503e9780ce -->
  <rule id="827584" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1370 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>