<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3189 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 928dff56-8613-5243-887a-e35c4369f48c -->
  <rule id="304671" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3189 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>