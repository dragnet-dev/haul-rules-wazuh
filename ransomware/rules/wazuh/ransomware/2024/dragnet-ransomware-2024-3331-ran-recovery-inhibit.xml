<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3331 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b4d1207d-7e5b-5b63-80f5-6396414c1ccf -->
  <rule id="137120" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3331 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>