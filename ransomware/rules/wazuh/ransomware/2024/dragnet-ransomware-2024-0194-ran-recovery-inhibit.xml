<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0194 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 7b6b9c2f-50c7-5268-946b-54946e5237eb -->
  <rule id="566076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0194 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>