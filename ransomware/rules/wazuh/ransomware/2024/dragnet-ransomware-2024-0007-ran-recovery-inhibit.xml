<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0007 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: ae45b2d2-8027-5060-92ce-d12b59980520 -->
  <rule id="191312" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0007 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
