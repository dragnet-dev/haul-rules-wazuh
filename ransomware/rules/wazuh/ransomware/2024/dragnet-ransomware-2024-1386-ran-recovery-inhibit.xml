<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1386 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e2642e7b-a70f-5241-b12c-fb070cbaf98a -->
  <rule id="582286" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1386 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>