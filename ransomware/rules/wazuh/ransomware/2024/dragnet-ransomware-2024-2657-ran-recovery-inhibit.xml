<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2657 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6988e63f-b06d-54e7-913e-60db6b564439 -->
  <rule id="318226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2657 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>