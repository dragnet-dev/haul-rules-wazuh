<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0465 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 25483da6-1b15-54b5-9301-a26d740f5452 -->
  <rule id="323866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0465 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>