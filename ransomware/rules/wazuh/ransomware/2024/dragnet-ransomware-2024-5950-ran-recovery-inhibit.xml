<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5950 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 828acb42-0b64-5e9f-b568-4a1a7c3ac8fd -->
  <rule id="794251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5950 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>