<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1327 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 31044462-36ae-5d02-8ad3-0c7431d74e0f -->
  <rule id="504446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1327 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>