<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3519 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 721e4141-42f9-5f3f-8c00-01c742f77504 -->
  <rule id="355041" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3519 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>