<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4735 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: c1ad0753-b412-57fd-9c58-9a8260198697 -->
  <rule id="514907" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4735 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>