<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4148 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: cd0d21e1-995a-5c08-9513-234c4cbf817d -->
  <rule id="681321" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4148 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>