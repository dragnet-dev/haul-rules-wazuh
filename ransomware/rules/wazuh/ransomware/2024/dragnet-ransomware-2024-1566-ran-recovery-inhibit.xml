<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1566 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 3ef951ca-249c-5916-80cd-ef2b63251660 -->
  <rule id="207951" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1566 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>