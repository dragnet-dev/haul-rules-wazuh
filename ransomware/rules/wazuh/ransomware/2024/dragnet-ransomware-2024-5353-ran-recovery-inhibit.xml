<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5353 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 8919ac42-be64-5152-88c6-3a7cca975d73 -->
  <rule id="583436" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5353 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>