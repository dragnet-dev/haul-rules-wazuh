<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3120 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 13fe590d-69b0-5bdd-a29e-f6d3be8a38ec -->
  <rule id="982590" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3120 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>