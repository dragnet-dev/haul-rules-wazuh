<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0692 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 113649af-04f5-5a4d-a1b6-bde8bc2b99e1 -->
  <rule id="118394" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0692 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>