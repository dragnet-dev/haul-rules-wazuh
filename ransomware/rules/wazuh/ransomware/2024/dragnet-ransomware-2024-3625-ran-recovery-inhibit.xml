<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3625 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: fd0c658e-abdc-59ac-b9bc-8e09ead725cd -->
  <rule id="549265" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3625 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>