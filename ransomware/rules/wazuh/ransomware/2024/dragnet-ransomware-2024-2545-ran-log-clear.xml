<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2545 — Event Log Clearing (handala) | Status: experimental | Sigma ID: 59fc6ca2-ec2b-5e35-b0e1-8a5ca6569520 -->
  <rule id="757068" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2545 — Event Log Clearing (handala)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>