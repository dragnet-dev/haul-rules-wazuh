<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5299 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 0c137eeb-ffc0-5eac-a903-242ea37d81d7 -->
  <rule id="507310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5299 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
