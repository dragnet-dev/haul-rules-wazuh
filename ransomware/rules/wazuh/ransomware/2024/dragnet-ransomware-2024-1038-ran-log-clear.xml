<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1038 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: 8a40a165-f0f6-5c7c-ac14-21b3763b1d26 -->
  <rule id="514501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1038 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>