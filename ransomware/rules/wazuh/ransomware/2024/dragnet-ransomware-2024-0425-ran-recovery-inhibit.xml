<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0425 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: d5dfaa20-6bca-574b-be66-8d3ff564ebe2 -->
  <rule id="904618" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0425 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>