<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4744 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 54e8d86e-ee9e-590c-a6b9-aecf78783d87 -->
  <rule id="606218" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4744 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>