<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5893 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: d885175c-0819-5a80-a9aa-cc55271dddd3 -->
  <rule id="588517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5893 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>