<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5356 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 1ad213ce-995f-56b1-bb2e-7f4ca75e7bbc -->
  <rule id="667420" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5356 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>