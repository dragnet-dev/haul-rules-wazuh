<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0360 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 26d73804-f861-5d98-837d-2140eda80ba6 -->
  <rule id="797380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0360 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>