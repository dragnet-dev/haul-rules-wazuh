<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3881 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 454f4be5-e9b0-5502-b9cb-15e0433ea3e6 -->
  <rule id="364715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3881 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>