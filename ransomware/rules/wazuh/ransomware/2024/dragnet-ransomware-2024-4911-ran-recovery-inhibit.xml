<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4911 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 47de899e-35f4-5048-99c4-a3dff0fdd4e9 -->
  <rule id="425489" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4911 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>