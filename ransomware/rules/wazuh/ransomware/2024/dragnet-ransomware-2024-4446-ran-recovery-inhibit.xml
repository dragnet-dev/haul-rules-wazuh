<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4446 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 6bba4b99-cb86-5788-b71f-042eaa8da8df -->
  <rule id="912555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4446 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>