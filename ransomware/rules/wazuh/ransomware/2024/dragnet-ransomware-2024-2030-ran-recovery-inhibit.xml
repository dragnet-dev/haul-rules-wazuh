<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2030 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 40c6c742-30db-5ca0-b1c2-876cbe174a61 -->
  <rule id="244287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2030 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>