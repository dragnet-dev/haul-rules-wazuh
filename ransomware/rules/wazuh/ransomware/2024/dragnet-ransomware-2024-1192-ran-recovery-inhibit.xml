<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1192 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: cb165a44-9d20-5eae-844d-0917ea17d2b3 -->
  <rule id="650650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1192 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>