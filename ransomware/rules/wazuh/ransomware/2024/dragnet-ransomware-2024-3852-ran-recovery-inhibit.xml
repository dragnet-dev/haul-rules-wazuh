<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3852 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0b8ce36b-a3bc-58a9-abe7-074606958948 -->
  <rule id="441436" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3852 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>