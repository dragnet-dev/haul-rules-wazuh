<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5445 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 7b1d7526-40fb-5119-8837-e7e8e003c513 -->
  <rule id="270975" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5445 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>