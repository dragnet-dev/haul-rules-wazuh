<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2453 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 100efbe8-ae92-560e-89fa-eb0ce583d12f -->
  <rule id="414974" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2453 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>