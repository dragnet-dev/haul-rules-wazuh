<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1273 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: e0b9dfc3-8023-546a-8ed6-6a7eb0a2d76f -->
  <rule id="465087" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1273 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>