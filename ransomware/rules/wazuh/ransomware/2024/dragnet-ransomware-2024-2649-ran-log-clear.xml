<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2649 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: 3e1af11e-1797-5eb1-87c1-ae90bfc472d6 -->
  <rule id="791511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2649 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>