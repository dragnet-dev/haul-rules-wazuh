<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4683 — Recovery Inhibition (blackout) | Status: experimental | Sigma ID: b9749ca8-14b2-5e86-b859-0965f546c340 -->
  <rule id="215996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4683 — Recovery Inhibition (blackout)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>