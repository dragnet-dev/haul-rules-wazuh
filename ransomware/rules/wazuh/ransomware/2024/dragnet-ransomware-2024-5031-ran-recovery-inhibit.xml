<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5031 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 6d6037f5-bf26-5ab8-b07f-021337d78d81 -->
  <rule id="296037" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5031 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>