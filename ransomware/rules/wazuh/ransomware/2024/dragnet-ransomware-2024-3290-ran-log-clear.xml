<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3290 — Event Log Clearing (play) | Status: experimental | Sigma ID: 02c57007-b5ac-5dcb-a59f-91e0a70f22dd -->
  <rule id="957007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3290 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>