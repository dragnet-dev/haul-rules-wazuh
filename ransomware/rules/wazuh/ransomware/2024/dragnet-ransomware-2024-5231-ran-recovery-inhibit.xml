<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5231 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 38c1a79e-690a-5861-b29d-9dfb86ce8d18 -->
  <rule id="122679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5231 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>