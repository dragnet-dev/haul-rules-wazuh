<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3125 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: a57fe788-3cac-5325-b67e-95664d533e62 -->
  <rule id="108467" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3125 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>