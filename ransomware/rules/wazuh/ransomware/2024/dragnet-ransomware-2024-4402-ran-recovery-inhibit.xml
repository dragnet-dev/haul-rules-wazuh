<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4402 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: cfb386b1-133d-5ce0-ad81-571a0a57b7d4 -->
  <rule id="723386" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4402 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>