<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1704 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8e2033e5-c2de-5a11-af6d-679e4685b212 -->
  <rule id="622033" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1704 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>