<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3054 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e2fd5610-d014-533e-a8f7-ec11f323fee9 -->
  <rule id="160556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3054 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>