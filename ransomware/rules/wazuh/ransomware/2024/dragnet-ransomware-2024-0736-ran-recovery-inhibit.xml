<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0736 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 3672df1f-0d2d-51c2-9745-e72e3ae14d5f -->
  <rule id="502551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0736 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>