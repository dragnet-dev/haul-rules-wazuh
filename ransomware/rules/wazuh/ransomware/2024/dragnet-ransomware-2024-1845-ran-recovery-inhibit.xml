<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1845 — Recovery Inhibition (qiulong) | Status: experimental | Sigma ID: 1eb05ac5-ca75-5db8-8f42-2a17aa17f1ca -->
  <rule id="971052" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1845 — Recovery Inhibition (qiulong)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>