<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0587 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 637f44cb-aa48-5a65-a6e3-69dc8253e709 -->
  <rule id="220744" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0587 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
