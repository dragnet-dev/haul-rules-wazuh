<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2703 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d98ac29a-e029-58ee-bac7-20007b355f7d -->
  <rule id="980602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2703 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>