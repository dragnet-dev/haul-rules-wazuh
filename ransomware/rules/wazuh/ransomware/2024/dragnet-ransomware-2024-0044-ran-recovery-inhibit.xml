<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0044 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 3ef0dfee-c851-51e2-8243-8558338e288e -->
  <rule id="878143" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0044 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>