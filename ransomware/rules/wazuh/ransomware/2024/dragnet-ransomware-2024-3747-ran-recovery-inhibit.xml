<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3747 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b5fc44d3-99c7-53ee-8957-5a2917cc697e -->
  <rule id="369244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3747 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>