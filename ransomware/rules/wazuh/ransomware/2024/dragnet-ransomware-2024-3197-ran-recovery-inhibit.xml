<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3197 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4f59b066-da56-5976-b405-6572670df1dd -->
  <rule id="473550" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3197 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>