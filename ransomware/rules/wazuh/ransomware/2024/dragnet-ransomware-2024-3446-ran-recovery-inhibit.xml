<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3446 — Recovery Inhibition (dAn0n) | Status: experimental | Sigma ID: 8f54e08a-6ead-57de-8486-632f25d53576 -->
  <rule id="596780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3446 — Recovery Inhibition (dAn0n)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>