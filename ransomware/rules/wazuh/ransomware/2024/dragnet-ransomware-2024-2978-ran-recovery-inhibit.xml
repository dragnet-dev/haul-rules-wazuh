<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2978 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 435e83eb-c56f-5bdc-a8ea-df4fbae48a2d -->
  <rule id="459742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2978 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>