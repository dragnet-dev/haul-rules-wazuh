<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2764 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c3ec5dff-7577-530b-857f-9f9b7f7ea482 -->
  <rule id="675933" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2764 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>