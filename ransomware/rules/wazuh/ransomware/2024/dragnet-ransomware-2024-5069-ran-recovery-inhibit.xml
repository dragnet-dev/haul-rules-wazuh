<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5069 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: f9933eed-9348-5506-86cb-580870d5a17f -->
  <rule id="858942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5069 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>