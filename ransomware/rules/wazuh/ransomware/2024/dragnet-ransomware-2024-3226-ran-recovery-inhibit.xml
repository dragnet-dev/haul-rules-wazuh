<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3226 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 9816bb52-cfd1-5136-abc8-595dee2afc50 -->
  <rule id="813083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3226 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>