<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3026 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: af873eb6-0175-573d-9149-136dd32e6738 -->
  <rule id="213982" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3026 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>