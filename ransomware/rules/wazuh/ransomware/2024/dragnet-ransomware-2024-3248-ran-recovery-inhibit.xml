<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3248 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 52379312-9418-578b-9322-ad3b4b653344 -->
  <rule id="837931" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3248 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>