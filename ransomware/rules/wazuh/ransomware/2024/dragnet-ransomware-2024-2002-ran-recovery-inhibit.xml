<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2002 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 763a71a1-c0ec-569c-86d7-b59099d76deb -->
  <rule id="421871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2002 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>