<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0125 — Recovery Inhibition (cloak) | Status: experimental | Sigma ID: 43ea37b8-ed8e-5375-9de1-cc5c4f18ab0a -->
  <rule id="324237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0125 — Recovery Inhibition (cloak)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>