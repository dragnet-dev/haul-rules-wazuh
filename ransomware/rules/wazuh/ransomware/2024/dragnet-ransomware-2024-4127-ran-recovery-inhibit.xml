<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4127 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b1ec1fa9-4b31-50ff-99f5-4c4bb079efb6 -->
  <rule id="184351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4127 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>