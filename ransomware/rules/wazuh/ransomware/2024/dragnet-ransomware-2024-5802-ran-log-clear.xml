<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5802 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 0a1c3ea9-1833-56c2-8d41-f53f5fdc8d85 -->
  <rule id="668682" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5802 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>