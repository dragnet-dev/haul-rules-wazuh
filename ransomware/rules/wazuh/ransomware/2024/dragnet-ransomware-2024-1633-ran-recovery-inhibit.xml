<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1633 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c9a1a291-bfb6-5eb3-94ec-2d6149351bd6 -->
  <rule id="718662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1633 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>