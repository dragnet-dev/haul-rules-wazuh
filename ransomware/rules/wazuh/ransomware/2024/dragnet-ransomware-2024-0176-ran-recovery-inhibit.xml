<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0176 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 19de007f-033f-5dfc-b13f-d3ef2ac6e66f -->
  <rule id="686007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0176 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>