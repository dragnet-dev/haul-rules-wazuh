<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4987 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 901bc9c5-05ea-55b9-ad73-502eda600026 -->
  <rule id="608449" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4987 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>