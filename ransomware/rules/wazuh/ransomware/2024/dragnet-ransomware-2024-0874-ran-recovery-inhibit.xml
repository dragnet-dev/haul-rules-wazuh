<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0874 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 57b2a71e-3b7d-5cd8-aedb-d4ee96f92b50 -->
  <rule id="677227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0874 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>