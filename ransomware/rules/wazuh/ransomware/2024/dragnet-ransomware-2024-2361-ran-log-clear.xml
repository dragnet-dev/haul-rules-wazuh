<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2361 — Event Log Clearing (BrainCipher) | Status: experimental | Sigma ID: 0e8eb6d2-7fd8-5f42-980a-499d6441ee34 -->
  <rule id="799789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2361 — Event Log Clearing (BrainCipher)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>