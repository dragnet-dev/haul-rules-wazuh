<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2183 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 2cbd6f22-4ecf-534d-9505-9176305f3231 -->
  <rule id="132591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2183 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>