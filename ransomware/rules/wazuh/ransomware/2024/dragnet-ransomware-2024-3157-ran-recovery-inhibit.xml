<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3157 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 80c35567-df88-5be7-9ceb-26fe447d4eba -->
  <rule id="492355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3157 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>