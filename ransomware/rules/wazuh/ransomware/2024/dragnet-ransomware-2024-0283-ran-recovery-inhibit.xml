<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0283 — Recovery Inhibition (play) | Status: experimental | Sigma ID: fec2ca0c-094a-5ece-ba9d-176d14ff7206 -->
  <rule id="635274" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0283 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>