<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2523 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 8d9b1476-5dc7-5bf6-b6ab-c532b2acf75d -->
  <rule id="571514" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2523 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>