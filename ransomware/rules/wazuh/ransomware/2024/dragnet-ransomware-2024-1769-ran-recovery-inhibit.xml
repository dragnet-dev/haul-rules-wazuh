<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1769 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: f2f3b2d7-83ad-5d90-b114-ecabe91ccbd5 -->
  <rule id="415792" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1769 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>