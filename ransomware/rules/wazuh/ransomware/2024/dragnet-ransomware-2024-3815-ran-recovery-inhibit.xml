<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3815 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 571e53a7-64ca-5711-a6b6-4b68b809fc5a -->
  <rule id="340858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3815 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>