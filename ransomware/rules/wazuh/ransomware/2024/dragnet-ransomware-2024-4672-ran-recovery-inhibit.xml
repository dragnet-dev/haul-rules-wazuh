<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4672 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 3bfe3edc-e853-56b9-b7ab-66e8149c9883 -->
  <rule id="757342" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4672 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>