<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5706 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: c5747297-71b5-583d-8706-3597d02aa27a -->
  <rule id="457472" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5706 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>