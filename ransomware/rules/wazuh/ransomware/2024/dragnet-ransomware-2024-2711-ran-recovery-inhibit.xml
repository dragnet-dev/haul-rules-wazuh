<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2711 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 49710805-d8d5-595b-a5fd-0ed3e0417b43 -->
  <rule id="571080" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2711 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>