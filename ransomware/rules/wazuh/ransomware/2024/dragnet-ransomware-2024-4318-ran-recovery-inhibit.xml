<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4318 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 2ada5fcf-cb5e-5efe-9132-2aeb701d2c63 -->
  <rule id="955295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4318 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>