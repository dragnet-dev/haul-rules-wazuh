<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4888 — Recovery Inhibition (cicada3301) | Status: experimental | Sigma ID: 36346b28-2dea-5a60-bc12-24800a3ba027 -->
  <rule id="515472" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4888 — Recovery Inhibition (cicada3301)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>