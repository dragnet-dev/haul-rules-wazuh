<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4145 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: bef99955-6ab4-51f5-a2d0-7283f0d93fee -->
  <rule id="455999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4145 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>