<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1024 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: d66925c7-7783-5be8-bf54-06978dd5de17 -->
  <rule id="566925" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1024 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>