<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2845 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 9ef761f0-95a6-5a39-bbd6-5edf22ff0421 -->
  <rule id="843761" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2845 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>