<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3116 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 66b37f34-03d1-5c70-9428-bf9877d2dc7d -->
  <rule id="907807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3116 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>