<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2251 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 152d34fb-63b4-5b88-a8cf-94a802b4ebee -->
  <rule id="412559" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2251 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>