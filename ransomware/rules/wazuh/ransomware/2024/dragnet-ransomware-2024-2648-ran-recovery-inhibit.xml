<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2648 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: f6ddb520-addf-5934-bcb5-c98af9b90c5a -->
  <rule id="225235" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2648 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>