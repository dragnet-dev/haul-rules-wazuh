<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5898 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d6bcd16d-4d9a-54de-afea-a9b260b7c643 -->
  <rule id="300771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5898 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>