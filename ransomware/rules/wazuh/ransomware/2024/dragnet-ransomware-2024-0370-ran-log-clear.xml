<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0370 — Event Log Clearing (killsec) | Status: experimental | Sigma ID: 94e1b6a5-c60a-5e8b-b182-cc720b3c1be5 -->
  <rule id="729076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0370 — Event Log Clearing (killsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>