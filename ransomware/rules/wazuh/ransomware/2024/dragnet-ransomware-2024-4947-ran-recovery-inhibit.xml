<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4947 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 15522a76-8b17-5f3e-a250-598b818a6512 -->
  <rule id="783627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4947 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>