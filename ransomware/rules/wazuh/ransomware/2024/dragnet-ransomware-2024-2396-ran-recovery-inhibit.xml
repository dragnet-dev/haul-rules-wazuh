<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2396 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 17ddfbd2-0719-502f-b2b4-c362d5672ec1 -->
  <rule id="370939" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2396 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>