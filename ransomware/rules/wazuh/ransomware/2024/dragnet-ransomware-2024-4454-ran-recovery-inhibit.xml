<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4454 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 79c27d56-1de3-5d52-903e-6bea5631cf7b -->
  <rule id="342045" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4454 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>