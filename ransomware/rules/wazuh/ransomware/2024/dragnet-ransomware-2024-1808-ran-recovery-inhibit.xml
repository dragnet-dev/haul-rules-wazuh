<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1808 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: 164abd36-ec3d-5100-a06d-83497c2d165a -->
  <rule id="544933" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1808 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>