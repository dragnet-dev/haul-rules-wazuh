<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3284 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: feecbb25-8a15-58a7-9494-a744b67948bd -->
  <rule id="244171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3284 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>