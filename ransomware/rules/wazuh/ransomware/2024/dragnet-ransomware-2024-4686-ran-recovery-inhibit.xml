<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4686 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 097a2a49-7b28-5ffc-a23a-fa99522f8f99 -->
  <rule id="799624" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4686 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>