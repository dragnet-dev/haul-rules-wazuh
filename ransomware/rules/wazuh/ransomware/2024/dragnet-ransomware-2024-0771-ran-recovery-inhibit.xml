<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0771 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 248cd194-2240-57a7-a12a-f21358460a6a -->
  <rule id="169319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0771 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>