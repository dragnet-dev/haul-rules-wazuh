<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1249 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 00985651-8695-5d52-896c-b9df8263a129 -->
  <rule id="956518" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1249 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>