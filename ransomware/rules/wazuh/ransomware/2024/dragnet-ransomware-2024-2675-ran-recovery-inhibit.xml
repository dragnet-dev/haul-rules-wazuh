<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2675 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: e9686e58-6c6a-55e8-b02a-72ef7e2e93d6 -->
  <rule id="694990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2675 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>