<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2638 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: b8d9171f-2a3a-51da-ba7a-0206a70df3a5 -->
  <rule id="201917" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2638 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>