<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4110 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 9306fb9f-9783-5d01-abea-28a4a5f5653c -->
  <rule id="682587" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4110 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>