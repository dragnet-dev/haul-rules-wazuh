<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2772 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 90a2a434-3f59-5e93-b23b-f7b64ed313e6 -->
  <rule id="620424" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2772 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>