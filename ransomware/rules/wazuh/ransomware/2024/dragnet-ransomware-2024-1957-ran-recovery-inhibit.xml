<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1957 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 037abbe9-6742-5a8d-ba72-b1832f9d5274 -->
  <rule id="768798" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1957 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>