<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2947 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 686e8c45-5349-5b79-9688-bee87823247f -->
  <rule id="958540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2947 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>