<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0027 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: cf1c85e2-4422-5a05-93b6-f8c8198fdc7e -->
  <rule id="714885" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0027 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>