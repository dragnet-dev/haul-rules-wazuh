<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1721 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 46172247-18fd-586b-8e5c-4e27e61b669a -->
  <rule id="217224" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1721 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>