<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3985 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 80e1c866-9ab2-53b0-98a9-d04172bf31d6 -->
  <rule id="370688" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3985 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>