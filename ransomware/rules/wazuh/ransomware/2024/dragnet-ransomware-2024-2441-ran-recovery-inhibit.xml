<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2441 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: eecef266-b436-5b4c-b989-4223d9cf79e2 -->
  <rule id="881592" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2441 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>