<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0118 — Event Log Clearing (darkvault) | Status: experimental | Sigma ID: 1db786ad-1d6d-5e2e-8d7f-1decc4e8336e -->
  <rule id="512586" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0118 — Event Log Clearing (darkvault)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>