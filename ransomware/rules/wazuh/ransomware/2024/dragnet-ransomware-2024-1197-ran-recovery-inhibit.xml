<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1197 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 068c332f-f305-5fbe-9354-cb59859b3a8e -->
  <rule id="300332" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1197 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>