<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5579 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 801815ae-4953-5a8e-8e22-e89708edb91f -->
  <rule id="329050" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5579 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>