<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0309 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: a733db8a-2584-5b6b-b76b-f35b69526553 -->
  <rule id="147867" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0309 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>