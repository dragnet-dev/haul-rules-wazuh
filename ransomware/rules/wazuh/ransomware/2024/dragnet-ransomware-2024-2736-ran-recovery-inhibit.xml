<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2736 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 802c3f11-37ff-52e5-a255-e4b82f982979 -->
  <rule id="355103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2736 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>