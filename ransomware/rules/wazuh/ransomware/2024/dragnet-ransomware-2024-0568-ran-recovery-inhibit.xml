<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0568 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 215dbeef-794d-556e-9778-14c8f1cc658e -->
  <rule id="746542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0568 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>