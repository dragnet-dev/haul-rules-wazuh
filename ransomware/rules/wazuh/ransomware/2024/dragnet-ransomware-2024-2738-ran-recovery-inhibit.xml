<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2738 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 4234e59e-d773-5ab7-a379-42373abfe4cb -->
  <rule id="575859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2738 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>