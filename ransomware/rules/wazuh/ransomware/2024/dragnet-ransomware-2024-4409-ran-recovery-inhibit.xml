<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4409 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 42f5274e-9e8b-5879-9ab9-b4ed7d5b0cff -->
  <rule id="675274" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4409 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>