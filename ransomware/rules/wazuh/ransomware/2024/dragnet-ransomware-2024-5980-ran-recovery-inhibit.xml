<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5980 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 2859019c-1440-5774-a46f-a81ce9b35180 -->
  <rule id="259019" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5980 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>