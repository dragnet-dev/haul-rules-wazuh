<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1050 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 6f73dd49-75a7-5e2c-bfbf-c31321fdbd71 -->
  <rule id="260509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1050 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>