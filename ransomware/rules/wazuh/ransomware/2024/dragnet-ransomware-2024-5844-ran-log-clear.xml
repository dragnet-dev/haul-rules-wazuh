<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5844 — Event Log Clearing (8base) | Status: experimental | Sigma ID: e2a5aa8c-d4b2-55b8-9eeb-9faf57b49cd4 -->
  <rule id="543370" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5844 — Event Log Clearing (8base)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>