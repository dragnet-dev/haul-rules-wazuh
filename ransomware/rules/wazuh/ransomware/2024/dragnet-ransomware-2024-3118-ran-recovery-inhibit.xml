<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3118 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 91ff0738-e61f-516a-b62b-7f5ab1813de1 -->
  <rule id="655107" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3118 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>