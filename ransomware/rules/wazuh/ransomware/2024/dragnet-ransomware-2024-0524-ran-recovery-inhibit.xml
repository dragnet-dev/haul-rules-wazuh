<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0524 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d4420bdd-d2f5-5d2c-bf53-06710b70d89e -->
  <rule id="450731" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0524 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>