<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0648 — Recovery Inhibition (dAn0n) | Status: experimental | Sigma ID: ce945108-babb-5bfc-92fc-e7b711075e19 -->
  <rule id="369451" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0648 — Recovery Inhibition (dAn0n)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>