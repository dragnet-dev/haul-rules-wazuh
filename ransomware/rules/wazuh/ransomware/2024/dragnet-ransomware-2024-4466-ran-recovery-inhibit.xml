<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4466 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: b223636e-59d7-58ec-891b-865b2f063c56 -->
  <rule id="322363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4466 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>