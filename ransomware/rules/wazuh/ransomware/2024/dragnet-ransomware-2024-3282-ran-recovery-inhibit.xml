<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3282 — Recovery Inhibition (trinity) | Status: experimental | Sigma ID: 8c0a0e86-c164-579f-8645-d06327c2a465 -->
  <rule id="985614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3282 — Recovery Inhibition (trinity)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
