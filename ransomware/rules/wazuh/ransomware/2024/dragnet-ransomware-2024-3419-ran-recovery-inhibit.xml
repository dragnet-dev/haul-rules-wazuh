<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3419 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4037196c-d65c-589b-a986-f03aed0e48b3 -->
  <rule id="537196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3419 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>