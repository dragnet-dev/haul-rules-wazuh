<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4710 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: d86179f6-5968-54a2-be64-0e867e0c1535 -->
  <rule id="586179" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4710 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>