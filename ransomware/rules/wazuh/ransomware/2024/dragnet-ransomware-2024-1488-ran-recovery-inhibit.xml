<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1488 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: aa7557ec-1e44-5b8e-a626-ab3e9c70f6ce -->
  <rule id="907557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1488 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>