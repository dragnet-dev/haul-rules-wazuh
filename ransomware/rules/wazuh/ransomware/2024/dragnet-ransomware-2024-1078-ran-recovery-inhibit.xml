<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1078 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a9f2f234-dfd0-5741-92eb-1fb510102873 -->
  <rule id="214872" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1078 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>