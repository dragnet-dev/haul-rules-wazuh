<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3717 — Event Log Clearing (blackout) | Status: experimental | Sigma ID: 0a69656d-4295-561a-86cc-a47b2392d558 -->
  <rule id="269656" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3717 — Event Log Clearing (blackout)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>