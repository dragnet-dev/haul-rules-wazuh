<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2658 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 33268f85-cb34-52b3-9da5-4a0fe35fa21a -->
  <rule id="923038" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2658 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>