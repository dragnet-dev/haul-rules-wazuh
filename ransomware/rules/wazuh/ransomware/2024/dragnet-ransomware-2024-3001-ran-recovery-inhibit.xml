<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3001 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 42235cb0-fcdd-5044-9dc2-2efdf99aa495 -->
  <rule id="112363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3001 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>