<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3461 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: a4172513-6f3d-501a-b38e-f07decf98276 -->
  <rule id="241725" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3461 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>