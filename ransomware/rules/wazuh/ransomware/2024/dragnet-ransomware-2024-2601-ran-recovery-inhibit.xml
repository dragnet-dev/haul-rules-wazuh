<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2601 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: bee61633-080c-5f62-810c-893da6494744 -->
  <rule id="454616" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2601 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>