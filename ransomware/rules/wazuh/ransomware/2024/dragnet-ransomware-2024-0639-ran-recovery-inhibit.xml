<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0639 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: ea77eeec-8947-57f1-acdb-c77a0ca2201b -->
  <rule id="710350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0639 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>