<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2057 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6040d840-f08a-52ae-90e2-ec12f1b165ef -->
  <rule id="765384" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2057 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>