<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3764 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: c53bc5df-f6f5-55ad-9ce8-82f9b19b8d50 -->
  <rule id="609565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3764 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>