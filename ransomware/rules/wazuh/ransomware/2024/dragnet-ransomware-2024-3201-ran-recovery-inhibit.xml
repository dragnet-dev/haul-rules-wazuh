<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3201 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 6480cee5-9d40-5aa3-bec4-c975c4c41fd9 -->
  <rule id="859086" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3201 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>