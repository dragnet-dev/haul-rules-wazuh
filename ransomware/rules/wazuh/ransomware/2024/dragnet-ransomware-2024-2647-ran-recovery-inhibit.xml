<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2647 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 027aa6e5-6cff-537a-ade7-b97030b6c889 -->
  <rule id="333230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2647 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>