<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5427 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 8f789f60-2637-5cd6-b53a-6f964c88ff8a -->
  <rule id="600639" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5427 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>