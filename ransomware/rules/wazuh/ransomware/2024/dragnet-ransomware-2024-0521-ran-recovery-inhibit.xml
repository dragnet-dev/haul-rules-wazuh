<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0521 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 58fea4e5-2785-54a6-8c2d-6754c3c3a30d -->
  <rule id="716424" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0521 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>