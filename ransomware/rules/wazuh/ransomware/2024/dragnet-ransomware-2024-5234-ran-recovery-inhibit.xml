<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5234 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 65653b3a-2207-5de1-811c-e99c068acd96 -->
  <rule id="250459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5234 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>