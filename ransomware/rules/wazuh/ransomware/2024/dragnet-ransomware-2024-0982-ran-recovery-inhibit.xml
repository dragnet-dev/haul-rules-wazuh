<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0982 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: ec585637-d5f3-5a5a-9d99-fca99eff7969 -->
  <rule id="665856" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0982 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>