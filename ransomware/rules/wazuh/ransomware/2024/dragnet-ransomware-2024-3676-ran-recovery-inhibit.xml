<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3676 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: beb92d5d-0d53-55bb-8804-4b7ad196b943 -->
  <rule id="483085" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3676 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
