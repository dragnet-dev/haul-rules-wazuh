<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4137 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 5dd05730-47ff-5a5e-b52a-968ffb8c83b7 -->
  <rule id="701057" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4137 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>