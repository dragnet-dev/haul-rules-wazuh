<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0063 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 885c9eb0-204f-58a9-87c3-448410b4f6f3 -->
  <rule id="567678" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0063 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>