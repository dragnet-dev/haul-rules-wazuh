<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5119 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 62e81491-1e75-5f60-9b4e-efd6cdc018da -->
  <rule id="206814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5119 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>