<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0086 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 9301a15e-fcb0-5f76-aa56-c3984444ea10 -->
  <rule id="688261" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0086 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>