<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4046 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 18acb896-682a-5c03-a9ee-e838e734da28 -->
  <rule id="549189" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4046 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>