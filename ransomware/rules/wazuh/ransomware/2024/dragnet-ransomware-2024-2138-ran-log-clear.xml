<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2138 — Event Log Clearing (apt73) | Status: experimental | Sigma ID: 5c8dc0b3-45e1-5aab-8934-b9b9150ad3bb -->
  <rule id="677880" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2138 — Event Log Clearing (apt73)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>