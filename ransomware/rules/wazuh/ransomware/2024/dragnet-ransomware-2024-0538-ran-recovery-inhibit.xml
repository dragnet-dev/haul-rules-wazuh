<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0538 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 25ac826c-da94-591b-b357-057662d8bd81 -->
  <rule id="372826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0538 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>