<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2792 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 772c02d9-2a1d-56b7-a4eb-c40e619c78d6 -->
  <rule id="436402" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2792 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>