<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3471 — Recovery Inhibition (trisec) | Status: experimental | Sigma ID: 76b63e24-b392-5f7e-abce-1c314cffa7cd -->
  <rule id="264222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3471 — Recovery Inhibition (trisec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>