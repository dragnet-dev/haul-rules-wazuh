<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2047 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 15dd35e8-6325-5562-a0bd-f2880b0bc069 -->
  <rule id="298174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2047 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>