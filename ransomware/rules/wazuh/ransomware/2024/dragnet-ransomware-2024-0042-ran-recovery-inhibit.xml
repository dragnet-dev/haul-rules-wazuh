<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0042 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: f826c188-40fd-5b13-b3ad-4befc32fb2ef -->
  <rule id="832281" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0042 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>