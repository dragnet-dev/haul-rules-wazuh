<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1619 — Event Log Clearing (blacklock) | Status: experimental | Sigma ID: 3e1a3a76-34b8-5b78-93c8-f8c5c9acaf00 -->
  <rule id="791418" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1619 — Event Log Clearing (blacklock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>