<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0856 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: b7620fa1-7d07-502a-8697-614bcf9c301a -->
  <rule id="181935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0856 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>