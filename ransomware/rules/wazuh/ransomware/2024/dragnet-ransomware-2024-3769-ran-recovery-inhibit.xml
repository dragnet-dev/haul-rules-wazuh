<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3769 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 5c2183df-2b20-53c7-a086-1af44322a59f -->
  <rule id="454941" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3769 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>