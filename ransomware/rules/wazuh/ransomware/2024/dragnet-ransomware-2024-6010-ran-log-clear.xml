<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6010 — Event Log Clearing (cicada3301) | Status: experimental | Sigma ID: af033bfe-dc4b-5ab2-a37a-a7f5bacbdde7 -->
  <rule id="200539" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6010 — Event Log Clearing (cicada3301)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>