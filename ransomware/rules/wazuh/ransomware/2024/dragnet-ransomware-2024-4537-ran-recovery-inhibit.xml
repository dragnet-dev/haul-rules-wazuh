<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4537 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 5907fbbe-5952-50e3-89a8-b67be3431456 -->
  <rule id="712443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4537 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>