<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5664 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 8afc0bb5-42af-5118-9ed9-83ecd8bfd99e -->
  <rule id="392811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5664 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>