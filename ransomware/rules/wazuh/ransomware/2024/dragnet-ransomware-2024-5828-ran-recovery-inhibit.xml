<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5828 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: cf1ffbab-d387-5604-ac1f-552a0e889b7d -->
  <rule id="486907" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5828 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>