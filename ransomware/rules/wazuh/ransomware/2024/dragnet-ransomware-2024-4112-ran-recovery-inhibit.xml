<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4112 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e5265c1c-c531-5175-b65f-45967e0df654 -->
  <rule id="624252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4112 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>