<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1338 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c9215de7-08cf-5a5d-908b-e8b227317822 -->
  <rule id="367453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1338 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>