<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4056 — Event Log Clearing (nitrogen) | Status: experimental | Sigma ID: 4df843eb-89b7-538c-bf32-11c47024e46a -->
  <rule id="447843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4056 — Event Log Clearing (nitrogen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>