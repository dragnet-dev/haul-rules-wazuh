<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1230 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 5e46094f-8717-5740-9b8a-90c4d7f639ee -->
  <rule id="546094" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1230 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>