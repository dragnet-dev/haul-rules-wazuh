<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5572 — Recovery Inhibition (ValenciaLeaks) | Status: experimental | Sigma ID: 14212918-8ac7-5cd8-80ed-efa21e259128 -->
  <rule id="621291" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5572 — Recovery Inhibition (ValenciaLeaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>