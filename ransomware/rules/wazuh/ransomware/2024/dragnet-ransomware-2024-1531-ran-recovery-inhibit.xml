<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1531 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 1da96d4b-28de-5ba5-a52d-768a24454552 -->
  <rule id="499494" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1531 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>