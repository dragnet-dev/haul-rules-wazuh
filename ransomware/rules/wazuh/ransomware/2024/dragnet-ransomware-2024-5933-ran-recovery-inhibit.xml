<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5933 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: d4585b27-1556-5cbc-8f54-7e73c725d3d2 -->
  <rule id="453371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5933 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>