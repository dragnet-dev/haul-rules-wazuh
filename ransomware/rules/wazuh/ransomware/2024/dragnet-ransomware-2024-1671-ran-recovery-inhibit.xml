<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1671 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 4399a961-e834-58ab-bbaa-7295c11ead76 -->
  <rule id="839496" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1671 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>