<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3505 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 29989733-d4fa-558e-a679-53d5b48e7ebe -->
  <rule id="398973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3505 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>