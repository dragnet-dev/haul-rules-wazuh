<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5840 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: b2d10a08-5562-5b27-91e0-4141df773d87 -->
  <rule id="288170" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5840 — Recovery Inhibition (funksec)</description>
