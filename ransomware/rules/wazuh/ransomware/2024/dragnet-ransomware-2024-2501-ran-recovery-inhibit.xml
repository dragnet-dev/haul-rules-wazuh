<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2501 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 90edfa0f-ad09-5c09-bd1c-7933d7afe3de -->
  <rule id="659162" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2501 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>