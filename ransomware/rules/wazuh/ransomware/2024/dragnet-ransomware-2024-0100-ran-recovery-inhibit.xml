<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0100 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 53cf10c5-21e7-5266-bd31-adada7ddfe46 -->
  <rule id="577510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0100 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>