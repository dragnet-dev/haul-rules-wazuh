<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1417 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9d281efa-d6a2-55f9-96d8-db2542fec576 -->
  <rule id="816510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1417 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>