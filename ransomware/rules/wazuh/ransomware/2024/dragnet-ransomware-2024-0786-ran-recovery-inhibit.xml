<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0786 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0d0dbfcf-0fd3-5a7f-8d88-bc1a1b637369 -->
  <rule id="575996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0786 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>