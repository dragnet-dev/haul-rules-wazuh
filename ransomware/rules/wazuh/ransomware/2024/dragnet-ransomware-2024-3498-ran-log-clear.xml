<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3498 — Event Log Clearing (mogilevich) | Status: deprecated | Sigma ID: 2c8677b7-6da2-53ed-9ac2-99230fd921e7 -->
  <rule id="978843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3498 — Event Log Clearing (mogilevich)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>