<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1478 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: cdaf68cc-009a-5165-8a49-a02ab84f6a05 -->
  <rule id="865568" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1478 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>