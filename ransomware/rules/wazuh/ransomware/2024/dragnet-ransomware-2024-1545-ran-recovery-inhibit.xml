<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1545 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ca6241a6-2783-5217-9338-d70aadd41b94 -->
  <rule id="326241" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1545 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>