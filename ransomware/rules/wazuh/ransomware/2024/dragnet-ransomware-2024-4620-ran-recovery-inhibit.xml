<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4620 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 062457b7-4578-5f30-9747-83ef69220e99 -->
  <rule id="193237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4620 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>