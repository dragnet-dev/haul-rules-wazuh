<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3957 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 5fe076d9-fdac-5ad3-9e46-8437edc416cc -->
  <rule id="734076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3957 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>