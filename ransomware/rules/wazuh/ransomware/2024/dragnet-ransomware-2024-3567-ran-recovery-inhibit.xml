<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3567 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 8738b7e7-1d88-5eb3-a550-fa82f52c1905 -->
  <rule id="598197" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3567 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>