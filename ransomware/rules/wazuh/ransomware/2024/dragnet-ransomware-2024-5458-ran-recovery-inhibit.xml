<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5458 — Recovery Inhibition (qiulong) | Status: experimental | Sigma ID: 881b95b7-7888-5cb3-96ba-3773026a122d -->
  <rule id="610795" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5458 — Recovery Inhibition (qiulong)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>