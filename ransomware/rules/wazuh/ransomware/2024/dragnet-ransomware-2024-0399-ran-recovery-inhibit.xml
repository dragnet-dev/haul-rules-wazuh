<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0399 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8ede26fe-40b7-5e08-8068-85522eb33ee6 -->
  <rule id="157426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0399 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>