<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3394 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6894bfc5-ceff-57a0-94a4-11f4a3808308 -->
  <rule id="965055" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3394 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>