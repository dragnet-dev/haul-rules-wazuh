<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3425 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 52811e38-f73c-52ee-8cc1-cdbcef5a76cb -->
  <rule id="449903" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3425 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>