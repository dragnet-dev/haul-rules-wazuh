<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5914 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: fa0ad184-68a6-5f7c-b106-7874d90b36c6 -->
  <rule id="201731" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5914 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>