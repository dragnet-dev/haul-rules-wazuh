<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3470 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 70fddc74-6043-5832-b84d-a20ca5fbec5c -->
  <rule id="252508" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3470 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>