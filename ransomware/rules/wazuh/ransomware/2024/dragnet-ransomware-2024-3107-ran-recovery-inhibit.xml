<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3107 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 71e7199b-d203-5f33-89dd-884d1f64f0a0 -->
  <rule id="350719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3107 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>