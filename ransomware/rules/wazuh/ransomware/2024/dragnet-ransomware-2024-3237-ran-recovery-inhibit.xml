<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3237 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 548f0ffe-faea-576b-9d0c-37eacf6165b1 -->
  <rule id="605295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3237 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>