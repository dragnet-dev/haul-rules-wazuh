<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4283 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: cdd699dd-2f35-536a-a4a6-22405e9c8185 -->
  <rule id="693699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4283 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>