<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1546 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 194ad1fd-6b55-53b3-9438-3c387a9d1ce6 -->
  <rule id="873951" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1546 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>