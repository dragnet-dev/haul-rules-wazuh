<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5550 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 84ebe213-de68-545e-9ec2-a767d70aacc2 -->
  <rule id="878382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5550 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>