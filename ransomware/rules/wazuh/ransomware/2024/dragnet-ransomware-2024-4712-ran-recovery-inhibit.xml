<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4712 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: 9ca3f83c-daab-504c-b66b-79ab81634f4a -->
  <rule id="510238" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4712 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>