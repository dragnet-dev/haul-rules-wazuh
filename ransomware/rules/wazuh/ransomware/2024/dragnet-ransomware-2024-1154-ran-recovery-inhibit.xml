<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1154 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 8100980c-26ec-529d-9934-4b40b3a727be -->
  <rule id="100980" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1154 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>