<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5328 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 86156e4a-f929-5130-86ea-d0395d256a68 -->
  <rule id="578510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5328 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>