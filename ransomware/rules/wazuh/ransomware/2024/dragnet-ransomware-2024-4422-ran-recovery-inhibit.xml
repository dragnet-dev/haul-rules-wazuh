<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4422 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: e14ab71c-dcdd-562c-b830-e29ba755e0d9 -->
  <rule id="121557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4422 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>