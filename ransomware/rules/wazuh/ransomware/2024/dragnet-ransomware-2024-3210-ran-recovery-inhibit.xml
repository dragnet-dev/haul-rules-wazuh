<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3210 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 50fb1cb3-c06c-57dd-b73f-5d418f7e1334 -->
  <rule id="388188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3210 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>