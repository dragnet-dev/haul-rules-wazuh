<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1767 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: a2a1e6cc-844e-56fd-b4a9-ceb4cbbdc6aa -->
  <rule id="927506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1767 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>