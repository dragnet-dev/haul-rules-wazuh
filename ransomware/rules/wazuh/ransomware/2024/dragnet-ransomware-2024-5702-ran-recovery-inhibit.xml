<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5702 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: 499e7deb-7fff-5660-8239-0f078d1aa1e8 -->
  <rule id="479805" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5702 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
