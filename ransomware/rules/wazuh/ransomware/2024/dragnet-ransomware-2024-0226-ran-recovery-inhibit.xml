<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0226 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 1bbbc011-e877-53dd-bed1-1b3aa506d1d3 -->
  <rule id="335960" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0226 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>