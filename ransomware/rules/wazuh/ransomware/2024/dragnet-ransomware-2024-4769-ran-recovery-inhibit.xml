<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4769 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: c86c8fd1-25ec-5b8c-a6f3-277c70f67980 -->
  <rule id="694223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4769 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>