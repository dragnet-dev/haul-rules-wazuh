<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0954 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 5316f5e8-0ea6-52e4-bc59-4bb0194b55d2 -->
  <rule id="211454" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0954 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>