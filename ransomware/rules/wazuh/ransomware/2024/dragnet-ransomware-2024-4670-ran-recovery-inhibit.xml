<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4670 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 80e2cac5-ffc8-5d76-be65-1ec60c2e02b3 -->
  <rule id="713354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4670 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>