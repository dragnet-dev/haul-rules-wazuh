<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3421 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 3d519bd2-47bf-5a7a-93bb-7f3145407386 -->
  <rule id="549053" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3421 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>