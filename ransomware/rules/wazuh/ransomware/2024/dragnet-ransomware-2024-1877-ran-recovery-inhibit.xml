<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1877 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 961c0c6f-1257-5f6f-ab7d-fa1fa369d576 -->
  <rule id="762092" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1877 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>