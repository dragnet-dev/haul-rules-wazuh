<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4226 — Event Log Clearing (ElDorado) | Status: deprecated | Sigma ID: 25007d11-4a93-5b14-8b63-16ebcc7b85a6 -->
  <rule id="501251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4226 — Event Log Clearing (ElDorado)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>