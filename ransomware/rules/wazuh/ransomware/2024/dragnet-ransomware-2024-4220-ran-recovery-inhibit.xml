<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4220 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: cbf12b6a-8382-5651-9916-e362c1150dab -->
  <rule id="821003" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4220 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>