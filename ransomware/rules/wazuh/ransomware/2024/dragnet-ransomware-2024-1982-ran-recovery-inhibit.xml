<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1982 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: cc1e329a-30e9-58ba-8485-3530fca70587 -->
  <rule id="667032" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1982 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>