<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2433 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: d4cd1365-71a9-5584-a814-40bbeb527344 -->
  <rule id="850913" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2433 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>