<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3973 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9781bebf-1b74-5e1f-9240-a21fd629d11a -->
  <rule id="804126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3973 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>