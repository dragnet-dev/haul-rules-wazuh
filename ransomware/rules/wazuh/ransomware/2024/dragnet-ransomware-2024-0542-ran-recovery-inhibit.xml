<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0542 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 7517c19d-0465-58d4-8d79-a82f04fb423f -->
  <rule id="402841" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0542 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>