<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4167 — Shadow Copy Deletion (ValenciaLeaks) | Status: experimental | Sigma ID: c3a62c71-8e36-5bf5-ad10-0955e2cdb427 -->
  <rule id="565804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4167 — Shadow Copy Deletion (ValenciaLeaks)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>