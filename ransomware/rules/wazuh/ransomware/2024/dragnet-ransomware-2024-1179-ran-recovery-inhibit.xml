<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1179 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 48b3e6ab-c50a-5843-a614-d291868fb569 -->
  <rule id="447026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1179 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>