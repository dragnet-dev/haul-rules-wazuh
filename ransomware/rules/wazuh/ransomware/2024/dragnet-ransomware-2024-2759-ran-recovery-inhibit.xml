<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2759 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: a5619075-70f3-548a-9b5f-e36608d81f4a -->
  <rule id="256190" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2759 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>