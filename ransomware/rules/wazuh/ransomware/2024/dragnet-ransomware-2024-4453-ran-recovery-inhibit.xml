<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4453 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 3913a7a9-53a8-5db6-aea0-9f9ee5e620bc -->
  <rule id="219002" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4453 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>