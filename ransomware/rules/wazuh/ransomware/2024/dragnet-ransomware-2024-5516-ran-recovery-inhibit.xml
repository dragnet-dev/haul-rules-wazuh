<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5516 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 843981e3-416e-576f-bbe8-56294c64fe9e -->
  <rule id="103710" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5516 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>