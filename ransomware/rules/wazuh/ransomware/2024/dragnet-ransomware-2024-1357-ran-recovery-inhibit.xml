<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1357 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 6938983f-89ce-54b6-addf-e25fee4c1bfe -->
  <rule id="738983" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1357 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>