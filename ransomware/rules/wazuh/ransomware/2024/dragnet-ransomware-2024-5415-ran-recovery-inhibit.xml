<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5415 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 75ba0adb-bcc6-518e-849b-43348895856a -->
  <rule id="501770" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5415 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>