<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3533 — Event Log Clearing (fog) | Status: experimental | Sigma ID: f39f0469-c51f-53f3-94a3-835b487b0d2d -->
  <rule id="763904" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3533 — Event Log Clearing (fog)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>