<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3865 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 9c2e2458-708e-52a7-a708-eb052670fef0 -->
  <rule id="800624" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3865 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>