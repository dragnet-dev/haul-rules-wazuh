<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5090 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: bca4b1ce-2dc4-5da8-9785-ae1bbb5b053b -->
  <rule id="429551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5090 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>