<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4716 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 14aeb3f1-c341-5f04-b998-94debe72d583 -->
  <rule id="722303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4716 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>