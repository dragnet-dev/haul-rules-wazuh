<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5904 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 9cd1ad44-f002-5cbf-be57-fc0d53596f0f -->
  <rule id="223469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5904 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>