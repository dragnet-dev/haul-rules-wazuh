<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3097 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: dc06680c-75e9-5976-b20e-9b91657245d0 -->
  <rule id="500668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3097 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>