<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2079 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: fbd85f03-e44f-58a7-a971-7eef54f149f4 -->
  <rule id="247775" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2079 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>