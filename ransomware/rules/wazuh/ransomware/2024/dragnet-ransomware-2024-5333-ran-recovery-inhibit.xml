<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5333 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: cc00c223-81c8-5c1c-9d40-d6b9b20ee44d -->
  <rule id="664122" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5333 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>