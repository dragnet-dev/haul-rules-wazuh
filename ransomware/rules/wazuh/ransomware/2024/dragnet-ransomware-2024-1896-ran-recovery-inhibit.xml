<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1896 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 76b58069-f4c4-5ed8-a2c4-db7fb3343df5 -->
  <rule id="427580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1896 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>