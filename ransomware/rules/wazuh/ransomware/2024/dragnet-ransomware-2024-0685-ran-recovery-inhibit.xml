<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0685 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 244646bb-f33d-5f5f-bcc6-2c2f154f2546 -->
  <rule id="414347" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0685 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>