<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0574 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ed2d1261-feaa-5f57-ba1f-3023fb98a61b -->
  <rule id="296512" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0574 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>