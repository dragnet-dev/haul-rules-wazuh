<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5357 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d28a4062-d4c8-5089-8d41-534c90127b03 -->
  <rule id="425840" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5357 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>