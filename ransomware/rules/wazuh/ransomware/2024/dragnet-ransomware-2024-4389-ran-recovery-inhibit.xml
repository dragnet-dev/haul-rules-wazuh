<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4389 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 13ac101d-de8d-5ec4-9f8f-ac54b84b1d96 -->
  <rule id="900101" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4389 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>