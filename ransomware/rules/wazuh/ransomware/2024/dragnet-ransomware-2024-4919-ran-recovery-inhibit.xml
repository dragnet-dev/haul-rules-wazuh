<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4919 — Recovery Inhibition (play) | Status: experimental | Sigma ID: afc85238-b7e9-55a7-98dd-17dbe848cc77 -->
  <rule id="212852" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4919 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>