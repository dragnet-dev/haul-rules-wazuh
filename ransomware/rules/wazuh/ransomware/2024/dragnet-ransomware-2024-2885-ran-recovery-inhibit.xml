<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2885 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 158e57b8-62a9-5d99-a7d3-9968421eb235 -->
  <rule id="568123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2885 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>