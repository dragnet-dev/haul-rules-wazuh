<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1539 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: dc329fd2-d78c-5897-8bc7-e825f1535a41 -->
  <rule id="925279" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1539 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>