<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2828 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 64a5d476-2b66-55ee-88f6-1b755e42c381 -->
  <rule id="855334" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2828 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>