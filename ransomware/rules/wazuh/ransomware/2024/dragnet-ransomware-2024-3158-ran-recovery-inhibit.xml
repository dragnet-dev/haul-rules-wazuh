<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3158 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9f2d84cb-71a4-5bc4-9e3c-546176989678 -->
  <rule id="848584" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3158 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>