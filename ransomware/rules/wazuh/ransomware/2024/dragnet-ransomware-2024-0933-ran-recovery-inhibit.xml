<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0933 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 74496b2c-2d39-5359-b425-1dee494c10ee -->
  <rule id="391947" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0933 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>