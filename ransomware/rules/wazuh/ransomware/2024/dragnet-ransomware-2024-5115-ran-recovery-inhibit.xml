<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5115 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 9096b7b1-e8f8-5b10-8f0d-54c111df027b -->
  <rule id="655477" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5115 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>