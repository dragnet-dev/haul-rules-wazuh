<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1271 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: 53de821e-9a68-57a4-8118-7a1b2968efea -->
  <rule id="579082" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1271 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>