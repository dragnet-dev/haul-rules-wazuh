<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2737 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 94b60a41-09d7-5dee-88b1-53c100f590c4 -->
  <rule id="724970" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2737 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>