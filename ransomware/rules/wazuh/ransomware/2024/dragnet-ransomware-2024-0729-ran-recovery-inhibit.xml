<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0729 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 51bb681f-d06c-5e51-b92f-6b8b6e494b5f -->
  <rule id="524368" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0729 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
