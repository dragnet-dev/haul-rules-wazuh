<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5744 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 6e6ec6d4-8f0a-513a-8262-ba58f2cb4b30 -->
  <rule id="233726" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5744 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>