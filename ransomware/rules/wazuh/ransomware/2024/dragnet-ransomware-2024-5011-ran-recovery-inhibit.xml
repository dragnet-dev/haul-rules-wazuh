<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5011 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 8454f860-36ad-5639-805e-0b9ec1d564a8 -->
  <rule id="552798" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5011 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>