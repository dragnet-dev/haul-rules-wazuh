<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1072 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: ddb97edc-8843-567f-8ba0-4f220b7b04ba -->
  <rule id="376766" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1072 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>