<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0241 — Recovery Inhibition (mallox) | Status: deprecated | Sigma ID: 68b8abcd-38b8-54f2-bfdd-1f1509403889 -->
  <rule id="215659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0241 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
