<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0759 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: b2c29871-230f-538d-ad4b-b1f47a17276f -->
  <rule id="104298" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0759 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>