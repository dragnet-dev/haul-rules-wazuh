<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5206 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: aa43830f-d0b9-5f2e-87ea-0cb4c7f8ff16 -->
  <rule id="904383" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5206 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>