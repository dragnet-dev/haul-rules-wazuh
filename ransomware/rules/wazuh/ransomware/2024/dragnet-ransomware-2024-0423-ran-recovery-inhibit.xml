<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0423 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0e8fc6f6-a9d3-5ff5-9eab-cbb53af96a12 -->
  <rule id="802511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0423 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>