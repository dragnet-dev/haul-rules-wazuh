<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3590 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2309ab6d-fd2c-57f7-aa54-07e79988bdb9 -->
  <rule id="612756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3590 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>