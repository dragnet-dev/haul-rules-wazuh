<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4979 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: a9faa96b-b27c-5c7d-833d-f1cc7e2336b1 -->
  <rule id="104749" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4979 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>