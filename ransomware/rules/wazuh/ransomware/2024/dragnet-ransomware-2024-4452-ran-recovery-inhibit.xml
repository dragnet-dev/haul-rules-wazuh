<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4452 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 93d5084d-ea3c-5e1f-9f6c-0c4872d5a62a -->
  <rule id="701508" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4452 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>