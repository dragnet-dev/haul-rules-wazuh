<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0444 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 4a3888ad-d5b1-55a6-8325-753969f219db -->
  <rule id="302218" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0444 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>