<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2580 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 10e805a5-29d9-5aef-b6c8-26f2d43a0393 -->
  <rule id="196890" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2580 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>