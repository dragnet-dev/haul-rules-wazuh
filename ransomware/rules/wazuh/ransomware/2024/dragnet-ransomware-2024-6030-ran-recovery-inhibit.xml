<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6030 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 8257f674-5820-57f3-9d09-5c47c15ea514 -->
  <rule id="521276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6030 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>