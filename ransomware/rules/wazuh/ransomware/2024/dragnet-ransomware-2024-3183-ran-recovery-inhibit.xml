<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3183 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: ab50cdcf-ad2f-5c1a-a3b2-a51187954cd6 -->
  <rule id="890605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3183 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>