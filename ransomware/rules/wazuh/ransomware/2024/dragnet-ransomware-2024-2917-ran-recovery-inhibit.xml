<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2917 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 46807467-db73-576b-a828-8d27f6bd09b8 -->
  <rule id="280746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2917 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>