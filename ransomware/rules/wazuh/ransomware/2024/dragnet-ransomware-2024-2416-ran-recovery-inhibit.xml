<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2416 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: aa3092f7-38d7-5728-950d-d876a5a0c555 -->
  <rule id="903092" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2416 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>