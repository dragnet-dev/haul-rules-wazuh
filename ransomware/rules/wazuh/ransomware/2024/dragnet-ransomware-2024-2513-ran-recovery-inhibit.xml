<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2513 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 906a74f9-3449-507f-b089-6f4e01f0ffaa -->
  <rule id="650674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2513 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>