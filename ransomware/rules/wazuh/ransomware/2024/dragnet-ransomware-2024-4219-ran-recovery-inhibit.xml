<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4219 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a09b738d-899e-5dad-a52e-f92ffc147ebd -->
  <rule id="815573" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4219 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>