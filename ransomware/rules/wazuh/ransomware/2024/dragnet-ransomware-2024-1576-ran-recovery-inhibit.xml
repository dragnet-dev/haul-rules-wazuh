<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1576 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: d2ffcf74-7f03-5a4c-b339-eac0905ed8f1 -->
  <rule id="716239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1576 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>