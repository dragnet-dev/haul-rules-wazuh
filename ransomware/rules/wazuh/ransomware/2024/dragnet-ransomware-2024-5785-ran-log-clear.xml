<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5785 — Event Log Clearing (metaencryptor) | Status: experimental | Sigma ID: 69faffd5-3cdb-5e0c-98f8-61287cb2aeb8 -->
  <rule id="186239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5785 — Event Log Clearing (metaencryptor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>