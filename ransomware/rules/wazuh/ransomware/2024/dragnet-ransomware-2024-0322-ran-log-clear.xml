<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0322 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: b96c7dc9-d5a5-5980-a92e-59c2fe60f4e2 -->
  <rule id="463805" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0322 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>