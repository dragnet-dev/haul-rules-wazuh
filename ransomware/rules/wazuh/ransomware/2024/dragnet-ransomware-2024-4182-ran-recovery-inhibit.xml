<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4182 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: f9b2288d-92b1-581c-895c-5ec2a26e3834 -->
  <rule id="855228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4182 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>