<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4420 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 3bcd18ab-f26c-5af9-8c7f-5e31fcea1d98 -->
  <rule id="730918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4420 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>