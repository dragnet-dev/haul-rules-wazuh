<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1546 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ccbc4d32-db95-5677-a03f-f291bd25c864 -->
  <rule id="385997" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1546 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>