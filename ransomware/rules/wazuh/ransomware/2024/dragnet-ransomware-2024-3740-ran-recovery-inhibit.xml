<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3740 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5421faa5-94e9-5b59-900d-55b32a4272d7 -->
  <rule id="588026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3740 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>