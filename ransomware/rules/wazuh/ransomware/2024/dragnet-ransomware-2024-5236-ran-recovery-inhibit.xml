<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5236 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 45fe6601-a27d-5d73-a2d9-126394eaf756 -->
  <rule id="377466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5236 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>