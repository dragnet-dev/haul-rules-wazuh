<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4115 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: f460af91-624b-566e-9a40-8999b25f65ca -->
  <rule id="457935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4115 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>