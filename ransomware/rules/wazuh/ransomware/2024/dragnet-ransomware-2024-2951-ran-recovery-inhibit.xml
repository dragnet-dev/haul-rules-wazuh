<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2951 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: 15742033-aa81-5c76-ab2e-7cc478fc29d2 -->
  <rule id="774203" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2951 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>