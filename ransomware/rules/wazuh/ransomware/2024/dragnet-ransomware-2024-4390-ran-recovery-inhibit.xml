<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4390 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: fc7ab018-4820-5e89-8bec-6d461a47a0b3 -->
  <rule id="270830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4390 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>