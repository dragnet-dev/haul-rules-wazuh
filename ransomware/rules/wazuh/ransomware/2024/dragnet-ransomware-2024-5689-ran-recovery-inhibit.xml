<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5689 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 28326a1e-658a-51fd-91a4-781004e63a53 -->
  <rule id="132261" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5689 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>