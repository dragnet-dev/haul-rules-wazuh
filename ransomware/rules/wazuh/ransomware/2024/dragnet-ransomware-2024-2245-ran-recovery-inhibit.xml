<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2245 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: b878bf6a-4d81-5c37-a8ca-2c4e5c5bef40 -->
  <rule id="440959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2245 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>