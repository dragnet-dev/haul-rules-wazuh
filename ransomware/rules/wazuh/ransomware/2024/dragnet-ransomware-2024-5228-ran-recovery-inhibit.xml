<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5228 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: dce6d335-4e11-5276-9de9-1202e428f6ad -->
  <rule id="355493" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5228 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>