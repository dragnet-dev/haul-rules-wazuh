<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4733 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 2f3803f1-365c-5c80-b417-441213acb1f9 -->
  <rule id="480863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4733 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>