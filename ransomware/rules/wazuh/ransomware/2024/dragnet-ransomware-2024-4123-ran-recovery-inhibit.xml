<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4123 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5b2575e6-89a2-51dc-819e-1588f25b276a -->
  <rule id="301214" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4123 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>