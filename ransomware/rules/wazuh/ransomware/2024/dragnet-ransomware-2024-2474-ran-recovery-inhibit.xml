<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2474 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7fed8848-575c-5074-81a4-52277493f48c -->
  <rule id="674988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2474 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>