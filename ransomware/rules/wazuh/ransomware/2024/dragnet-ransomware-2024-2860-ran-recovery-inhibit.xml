<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2860 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 9662edff-3f60-55e9-95bc-6e1631e6f34e -->
  <rule id="773709" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2860 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>