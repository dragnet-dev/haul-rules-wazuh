<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1211 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 58812952-be77-5b0c-ace0-4f2a8843a865 -->
  <rule id="581295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1211 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>