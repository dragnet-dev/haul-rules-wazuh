<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4242 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 275c5e0d-526f-5992-ae41-dcaba8c6f15e -->
  <rule id="860140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4242 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>