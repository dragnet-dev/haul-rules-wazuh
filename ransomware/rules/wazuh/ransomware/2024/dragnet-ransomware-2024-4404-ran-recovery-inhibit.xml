<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4404 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: f944ae4b-630e-51e0-b630-32eb1ffb2556 -->
  <rule id="581838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4404 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>