<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1907 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 3368851d-59e5-59dc-a849-0dcd3b589c65 -->
  <rule id="768851" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1907 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>