<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4406 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 29fecb5a-5727-51ba-a7a5-88a08888ea0c -->
  <rule id="265771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4406 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>