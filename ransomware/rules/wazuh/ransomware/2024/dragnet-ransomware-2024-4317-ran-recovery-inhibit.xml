<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4317 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 24c1d565-cb2e-511b-b779-d8750e9e33c8 -->
  <rule id="138956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4317 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>