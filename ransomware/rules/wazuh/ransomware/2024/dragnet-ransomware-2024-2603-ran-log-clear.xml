<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2603 — Event Log Clearing (underground) | Status: experimental | Sigma ID: a2deeb34-3cca-5f19-9889-79c151ce97a6 -->
  <rule id="541739" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2603 — Event Log Clearing (underground)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>