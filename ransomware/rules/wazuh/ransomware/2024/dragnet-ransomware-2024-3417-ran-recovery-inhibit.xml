<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3417 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4b488f80-f9b0-514e-91c4-c1060c526914 -->
  <rule id="407823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3417 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>