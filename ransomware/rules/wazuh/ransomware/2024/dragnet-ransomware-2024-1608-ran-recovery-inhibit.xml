<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1608 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: d5481345-d6ab-55a4-867a-3d32feb34c86 -->
  <rule id="554813" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1608 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>