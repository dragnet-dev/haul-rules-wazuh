<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1499 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 6a371ab2-c1cd-5589-bd32-b1fa5755f547 -->
  <rule id="901946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1499 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>