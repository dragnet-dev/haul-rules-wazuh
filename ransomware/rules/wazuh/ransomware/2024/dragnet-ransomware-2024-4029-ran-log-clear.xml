<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4029 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 1d1f9715-3fa2-5fd9-95c7-dde9ee9cb995 -->
  <rule id="271971" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4029 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>