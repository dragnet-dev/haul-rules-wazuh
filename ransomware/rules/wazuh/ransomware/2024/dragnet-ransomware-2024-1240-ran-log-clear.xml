<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1240 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: b30bbe9f-02a2-5c8f-bd8c-5227383a8075 -->
  <rule id="231486" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1240 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>