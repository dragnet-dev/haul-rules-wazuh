<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2730 — Event Log Clearing (meow) | Status: experimental | Sigma ID: b2fc1f74-c7c3-5995-b2dd-eb8e3bbf3556 -->
  <rule id="227871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2730 — Event Log Clearing (meow)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>