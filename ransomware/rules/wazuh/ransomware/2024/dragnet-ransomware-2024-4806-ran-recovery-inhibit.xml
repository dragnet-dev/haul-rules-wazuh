<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4806 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: a1664b76-9e7d-5d6f-8611-b7cbff43a46a -->
  <rule id="826635" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4806 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>