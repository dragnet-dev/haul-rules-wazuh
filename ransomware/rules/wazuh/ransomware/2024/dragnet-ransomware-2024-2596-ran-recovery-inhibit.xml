<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2596 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 8c8fc572-a947-58ba-9d56-f65f0a11ccb7 -->
  <rule id="107005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2596 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>