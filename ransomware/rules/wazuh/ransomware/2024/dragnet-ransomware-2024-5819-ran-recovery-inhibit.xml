<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5819 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 84acafec-a9a5-5f2e-8b45-dff23f36177a -->
  <rule id="249231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5819 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>