<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3434 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 34577018-4d7f-5fb7-a1c8-3feb6695277e -->
  <rule id="857701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3434 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>