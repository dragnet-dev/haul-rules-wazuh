<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3697 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f3a1aa7d-0523-5be1-8083-d313c059446e -->
  <rule id="992906" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3697 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>