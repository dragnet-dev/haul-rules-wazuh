<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3327 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: b6bea555-e3a5-5a0b-9c8a-700b1ebfd9b2 -->
  <rule id="381865" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3327 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>