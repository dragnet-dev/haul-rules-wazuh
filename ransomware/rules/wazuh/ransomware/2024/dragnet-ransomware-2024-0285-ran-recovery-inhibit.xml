<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0285 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: db88f485-a547-5038-a6ec-a6a0ade27bc7 -->
  <rule id="918234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0285 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>