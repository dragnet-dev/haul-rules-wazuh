  <rule id="724117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0289 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
