<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1595 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: c63f6b59-6a32-576c-adee-e30f9233e5b0 -->
  <rule id="635787" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1595 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>