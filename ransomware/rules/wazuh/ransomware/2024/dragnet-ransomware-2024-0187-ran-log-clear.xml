<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0187 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 58c5dbf5-4f6b-567d-8260-52f6a67bb560 -->
  <rule id="707899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0187 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>