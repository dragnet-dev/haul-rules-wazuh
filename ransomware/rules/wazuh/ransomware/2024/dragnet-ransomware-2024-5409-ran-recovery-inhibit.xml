<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5409 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 62803cbd-f882-5c58-ab3b-fcaa7cd89c22 -->
  <rule id="204860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5409 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>