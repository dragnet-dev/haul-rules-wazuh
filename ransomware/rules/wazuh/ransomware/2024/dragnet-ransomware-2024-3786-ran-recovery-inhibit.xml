<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3786 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: b08a30ed-dd12-515f-b47f-eafae38dddc2 -->
  <rule id="973830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3786 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>