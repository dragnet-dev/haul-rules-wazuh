<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4049 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 582a8146-fb24-5d7f-9463-daa303807432 -->
  <rule id="422814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4049 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>