<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1800 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 69cba190-abe0-5df3-ab35-74766a43489d -->
  <rule id="258821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1800 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>