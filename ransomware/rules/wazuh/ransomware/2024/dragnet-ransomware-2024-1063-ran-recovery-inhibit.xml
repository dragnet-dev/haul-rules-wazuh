<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1063 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 7ab05316-029b-50c3-8e3b-3ea6e4d8e9a6 -->
  <rule id="263053" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1063 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>