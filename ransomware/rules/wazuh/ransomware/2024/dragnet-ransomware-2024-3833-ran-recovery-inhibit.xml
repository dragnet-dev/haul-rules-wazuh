<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3833 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: 7f9609d8-7448-554e-958f-ad493ec069a9 -->
  <rule id="479609" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3833 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>