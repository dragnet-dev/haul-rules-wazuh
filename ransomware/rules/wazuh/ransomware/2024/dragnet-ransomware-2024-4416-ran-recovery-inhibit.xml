<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4416 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 7d935f9d-015c-5017-9166-df421d71eccc -->
  <rule id="314975" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4416 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>