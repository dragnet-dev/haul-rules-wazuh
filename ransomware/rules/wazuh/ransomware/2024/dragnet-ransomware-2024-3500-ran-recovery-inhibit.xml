<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3500 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 1f0219b1-0845-5158-b471-a6e725889d61 -->
  <rule id="563515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3500 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>