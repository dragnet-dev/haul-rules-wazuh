<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1418 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 243b8fc9-ba66-50ff-9068-6609da691969 -->
  <rule id="183740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1418 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>