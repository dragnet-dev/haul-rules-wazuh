<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2428 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: bbbda7ca-2a43-5733-babf-ad82535e9c86 -->
  <rule id="589867" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2428 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>