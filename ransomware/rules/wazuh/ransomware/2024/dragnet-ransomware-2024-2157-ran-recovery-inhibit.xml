<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2157 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 80678aa9-41bc-5e9b-89b1-6ce3cdf75861 -->
  <rule id="490858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2157 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>