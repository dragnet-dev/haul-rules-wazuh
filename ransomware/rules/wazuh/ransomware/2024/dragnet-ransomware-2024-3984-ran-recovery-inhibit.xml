<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3984 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: eb1e8ff6-8421-5c83-8304-76e86415a770 -->
  <rule id="720943" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3984 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>