<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0949 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 242b1e83-8e79-58bd-9340-df0d770ab344 -->
  <rule id="913108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0949 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>