<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2877 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0c7a8af8-349a-5ced-ab73-1a325d2c31e6 -->
  <rule id="829743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2877 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>