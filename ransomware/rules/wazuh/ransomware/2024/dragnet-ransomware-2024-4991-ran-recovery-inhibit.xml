<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4991 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: aeca1b01-81aa-58d2-b30d-1e193ddf0414 -->
  <rule id="959387" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4991 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>