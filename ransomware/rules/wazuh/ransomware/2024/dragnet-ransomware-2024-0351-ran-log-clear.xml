<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0351 — Event Log Clearing (datacarry) | Status: deprecated | Sigma ID: 55c5a0a5-792d-59ae-b98d-427b18ff9d78 -->
  <rule id="628100" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0351 — Event Log Clearing (datacarry)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>