<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2557 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 7ef93074-87f2-5eec-8b00-119adddd4bf6 -->
  <rule id="331930" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2557 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>