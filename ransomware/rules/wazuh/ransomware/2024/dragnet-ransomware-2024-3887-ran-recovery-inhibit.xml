<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3887 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: de450a24-6b98-5684-952a-b990a95a0b19 -->
  <rule id="959210" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3887 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>