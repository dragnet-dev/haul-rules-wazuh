<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5274 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2b5363f0-41d2-540f-a330-adf53f0e1ea8 -->
  <rule id="765823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5274 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>