<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3656 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: e9d6b186-e9d7-5f3f-8a05-d6a214190741 -->
  <rule id="336271" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3656 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>