<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5059 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 552bd8d6-6f86-5f08-a41a-55e0598246f0 -->
  <rule id="615018" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5059 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
