<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4188 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 9e627a3e-f8ed-5ae6-8e35-b2fecfb04465 -->
  <rule id="838042" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4188 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>