<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5141 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: cdae451f-1550-5530-bdc0-7e1c98ccbdda -->
  <rule id="865445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5141 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>