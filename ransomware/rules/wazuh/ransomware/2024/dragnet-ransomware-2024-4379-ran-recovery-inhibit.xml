<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4379 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 15179f56-6813-5a2d-ac6b-a1cd940d7198 -->
  <rule id="728795" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4379 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>