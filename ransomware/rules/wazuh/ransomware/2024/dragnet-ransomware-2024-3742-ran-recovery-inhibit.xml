<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3742 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: 0570a061-2cfd-524d-bd70-249073f32992 -->
  <rule id="230061" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3742 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>