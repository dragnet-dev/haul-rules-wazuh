<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3294 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c071a570-39a6-527d-a74e-5bfc05b3849a -->
  <rule id="231465" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3294 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>