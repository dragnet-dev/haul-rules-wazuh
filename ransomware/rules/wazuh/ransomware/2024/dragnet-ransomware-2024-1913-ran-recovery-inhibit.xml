<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1913 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: c40b435d-533b-5f6c-accc-6d8b2e429dce -->
  <rule id="285143" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1913 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>