<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0002 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: a22aad4e-540c-50a1-ae35-0cda83e0f889 -->
  <rule id="688845" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0002 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>