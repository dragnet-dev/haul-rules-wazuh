<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1208 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 8ce8da66-e185-52d7-8609-e7fa37c2e4c6 -->
  <rule id="472506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1208 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>