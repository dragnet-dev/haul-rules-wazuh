<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1362 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 15851527-825c-5c70-bf9f-5d488e3d0574 -->
  <rule id="785152" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1362 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>