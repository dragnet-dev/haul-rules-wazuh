<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0004 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9fa26a4b-2d9a-59f3-bfec-6b6db3143777 -->
  <rule id="586826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0004 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>