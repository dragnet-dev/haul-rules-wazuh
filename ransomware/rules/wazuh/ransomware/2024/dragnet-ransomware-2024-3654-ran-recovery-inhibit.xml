<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3654 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 823381eb-d21e-5133-8f32-31b4e49057b3 -->
  <rule id="674110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3654 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>