<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4254 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 35391e0e-604d-590b-8939-8ec8f5f8c83b -->
  <rule id="362700" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4254 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>