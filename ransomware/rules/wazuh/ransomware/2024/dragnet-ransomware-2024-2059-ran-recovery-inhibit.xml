<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2059 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: e2bce545-3782-59da-942a-e07d55a8b621 -->
  <rule id="546545" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2059 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>