<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0006 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 55c4aa99-cc3f-54a7-a1d4-e4c340dd0417 -->
  <rule id="584714" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0006 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>