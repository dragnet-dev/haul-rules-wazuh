<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4723 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a1d2b2d5-10bc-5b08-948e-9a12ee47a385 -->
  <rule id="906832" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4723 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>