<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4907 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 20809cae-9f02-5f92-8b43-1da20ed855b0 -->
  <rule id="927306" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4907 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>