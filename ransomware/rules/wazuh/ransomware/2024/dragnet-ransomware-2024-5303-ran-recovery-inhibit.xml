<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5303 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 4497dc61-a2f6-5b30-8b24-193936f15296 -->
  <rule id="351452" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5303 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>