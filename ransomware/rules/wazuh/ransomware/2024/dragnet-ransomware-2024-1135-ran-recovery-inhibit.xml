<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1135 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 890a01ed-a0a6-5fdb-b71a-e1bb423ee04a -->
  <rule id="625001" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1135 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>