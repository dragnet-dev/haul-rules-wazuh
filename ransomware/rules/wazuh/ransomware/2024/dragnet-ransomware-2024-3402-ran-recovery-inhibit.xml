<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3402 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 2a176acd-3f65-59e1-8627-486061c685c5 -->
  <rule id="997228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3402 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>