<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1412 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 592d1ee4-6a90-54c0-a59d-6df500193a41 -->
  <rule id="717630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1412 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>