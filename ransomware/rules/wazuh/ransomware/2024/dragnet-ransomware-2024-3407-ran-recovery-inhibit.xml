<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3407 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 2e70f8d1-2f95-5be9-b5b0-67248d3db95d -->
  <rule id="357741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3407 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>