<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2869 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 6a6e70ca-900b-5634-a2f4-146152ee6746 -->
  <rule id="907070" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2869 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>