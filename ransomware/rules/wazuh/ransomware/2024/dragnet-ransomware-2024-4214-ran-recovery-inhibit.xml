<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4214 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 9124d8a4-d31d-5769-9bea-7e6466190940 -->
  <rule id="659978" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4214 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>