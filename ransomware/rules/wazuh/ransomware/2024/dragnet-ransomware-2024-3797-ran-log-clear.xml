<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3797 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: ee613d3b-20fb-5f88-9a78-b4b3aee4ddc9 -->
  <rule id="317821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3797 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>