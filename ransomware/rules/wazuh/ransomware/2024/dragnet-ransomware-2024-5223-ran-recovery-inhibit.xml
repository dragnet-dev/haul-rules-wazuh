<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5223 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4b197f32-7e36-5b3e-b7b7-d82631040b1c -->
  <rule id="403167" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5223 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>