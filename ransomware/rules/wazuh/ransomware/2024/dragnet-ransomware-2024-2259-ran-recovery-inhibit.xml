<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2259 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: e7e8afb5-b4f0-5d52-be78-9baccf37f44c -->
  <rule id="759183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2259 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>