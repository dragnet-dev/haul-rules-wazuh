<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4898 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 649fdece-77b0-597b-ac81-bafd65d44f5e -->
  <rule id="962366" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4898 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>