<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1979 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: 96cac778-8f4d-5849-b4cb-c0b6c1bc38b6 -->
  <rule id="464607" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1979 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>