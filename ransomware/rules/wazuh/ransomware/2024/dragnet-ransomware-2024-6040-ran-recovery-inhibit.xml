<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6040 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 572014f5-d73d-5a48-bd74-72b6fede555e -->
  <rule id="252239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6040 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>