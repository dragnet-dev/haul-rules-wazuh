<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0539 — Recovery Inhibition (ElDorado) | Status: experimental | Sigma ID: 883555e8-ef54-5456-b977-5310f764ae66 -->
  <rule id="736894" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0539 — Recovery Inhibition (ElDorado)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>