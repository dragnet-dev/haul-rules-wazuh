<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1785 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 2b9c62e3-55ba-5c3b-a722-33b2adaabacd -->
  <rule id="558606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1785 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>