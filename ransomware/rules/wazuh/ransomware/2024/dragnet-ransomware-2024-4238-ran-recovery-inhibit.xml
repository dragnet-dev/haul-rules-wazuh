<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4238 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 21076253-8ce2-55f3-adb4-7aa75b3990be -->
  <rule id="407625" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4238 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>