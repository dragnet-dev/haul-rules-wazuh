<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2588 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: e51c1ef6-c0ca-5c37-a335-a5f284b8f2dd -->
  <rule id="216510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2588 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>