<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4848 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c31efcb0-f64a-5c88-9904-53ecc463e5f8 -->
  <rule id="646012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4848 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>