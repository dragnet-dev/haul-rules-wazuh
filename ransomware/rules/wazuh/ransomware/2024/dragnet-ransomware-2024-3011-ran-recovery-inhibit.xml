<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3011 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d15bc6b2-8f74-5dca-949f-b1c9ac740c6f -->
  <rule id="768286" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3011 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>