<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4795 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d7ba8faf-56c5-5c7c-859c-88d97933d396 -->
  <rule id="341423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4795 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>