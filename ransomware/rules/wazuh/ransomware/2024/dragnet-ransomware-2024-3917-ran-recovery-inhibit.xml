<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3917 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 1817dd65-714c-5a49-a64e-81aba9ecece8 -->
  <rule id="253736" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3917 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>