<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5610 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: e19222b0-0623-5c75-ab60-c75d3240c559 -->
  <rule id="619222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5610 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>