<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3114 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 0bc06fa4-d28d-59cb-87f7-2f910724ce3a -->
  <rule id="414586" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3114 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>