<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5863 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 711b331d-295d-5ef2-a2f1-cd27788fdae2 -->
  <rule id="338733" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5863 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>