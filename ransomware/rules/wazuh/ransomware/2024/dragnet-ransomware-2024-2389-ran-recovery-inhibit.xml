<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2389 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: afc9c25a-a0b8-578b-a290-76b69ff84464 -->
  <rule id="100762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2389 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>