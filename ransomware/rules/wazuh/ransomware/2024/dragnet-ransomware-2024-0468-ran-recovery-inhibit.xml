<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0468 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 160487a5-ecac-56f6-b86c-c0cd7ae707d4 -->
  <rule id="867802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0468 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>