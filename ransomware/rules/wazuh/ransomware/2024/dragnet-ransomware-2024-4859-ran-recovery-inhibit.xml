<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4859 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: f1316f9a-7e37-5f0d-ab44-a860fd79e26f -->
  <rule id="721071" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4859 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>