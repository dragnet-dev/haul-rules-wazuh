<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5112 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 724131ee-1b27-5107-9443-e8347050ea51 -->
  <rule id="886110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5112 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>