<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0224 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: c95f7b46-5df6-5e3f-b422-b7144bae8032 -->
  <rule id="717723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0224 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>