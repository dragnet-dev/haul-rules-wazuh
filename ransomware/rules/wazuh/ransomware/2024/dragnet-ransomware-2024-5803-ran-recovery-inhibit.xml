<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5803 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 7b49798c-953c-5797-a80f-fe1c4015ddae -->
  <rule id="434979" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5803 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>