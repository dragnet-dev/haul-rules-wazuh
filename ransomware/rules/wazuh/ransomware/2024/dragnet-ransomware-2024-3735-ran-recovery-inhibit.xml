<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3735 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 5df69bab-8d11-5c4e-b9ec-37cb6ebc950a -->
  <rule id="705915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3735 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>