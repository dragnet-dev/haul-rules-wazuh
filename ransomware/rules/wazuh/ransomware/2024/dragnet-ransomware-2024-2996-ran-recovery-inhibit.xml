<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2996 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: cef7abe5-bf16-5d5d-aed6-a5fd36a3448a -->
  <rule id="478123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2996 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>