<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4331 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 8021ece1-3f6a-5d43-a531-7a23d3eba85d -->
  <rule id="353612" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4331 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>