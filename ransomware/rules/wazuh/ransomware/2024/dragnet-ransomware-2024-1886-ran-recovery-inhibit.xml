<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1886 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 8435ef82-d812-545d-b357-8cd136f504f3 -->
  <rule id="459599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1886 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>