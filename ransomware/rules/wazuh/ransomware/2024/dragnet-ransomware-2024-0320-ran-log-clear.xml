<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0320 — Event Log Clearing (orca) | Status: experimental | Sigma ID: 8a96ec1b-0f20-5571-b7b0-a11b1758e56f -->
  <rule id="957612" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0320 — Event Log Clearing (orca)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>