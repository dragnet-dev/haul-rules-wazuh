<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1081 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 7b6c3448-394f-5092-91c5-ba502f375422 -->
  <rule id="278834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1081 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>