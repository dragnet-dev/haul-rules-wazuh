<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0481 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: cac60c8c-cba9-59eb-9f05-e3c38a07b10d -->
  <rule id="791372" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0481 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>