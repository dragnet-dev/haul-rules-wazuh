<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0256 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: baae7876-9db2-5672-b614-5cae0007c81f -->
  <rule id="379078" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0256 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>