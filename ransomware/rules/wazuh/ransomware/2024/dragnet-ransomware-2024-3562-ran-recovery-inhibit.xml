<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3562 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f29a3a46-7611-5c27-8071-d56bc5fe2624 -->
  <rule id="415898" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3562 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>