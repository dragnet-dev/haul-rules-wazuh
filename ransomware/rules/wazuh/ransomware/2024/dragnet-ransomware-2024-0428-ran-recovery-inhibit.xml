<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0428 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 1d8c94f1-5f06-5006-a1cb-62b571c8a632 -->
  <rule id="549519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0428 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>