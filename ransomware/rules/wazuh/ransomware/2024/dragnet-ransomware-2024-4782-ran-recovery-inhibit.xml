<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4782 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 8416c4a6-984a-51fc-a86d-93026e600520 -->
  <rule id="546684" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4782 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>