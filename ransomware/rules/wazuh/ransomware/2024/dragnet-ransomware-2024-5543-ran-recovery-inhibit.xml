<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5543 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 80c6f992-dbcc-5f60-a36c-09ed7a9239b8 -->
  <rule id="368319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5543 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>