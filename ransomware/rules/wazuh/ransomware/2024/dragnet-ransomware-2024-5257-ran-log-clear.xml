<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5257 — Event Log Clearing (trinity) | Status: experimental | Sigma ID: 250aee39-bd53-5983-8126-8666695b3646 -->
  <rule id="226798" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5257 — Event Log Clearing (trinity)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>