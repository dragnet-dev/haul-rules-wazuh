<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3385 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ea815b00-2727-56ba-b442-d135ba54d269 -->
  <rule id="257051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3385 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>