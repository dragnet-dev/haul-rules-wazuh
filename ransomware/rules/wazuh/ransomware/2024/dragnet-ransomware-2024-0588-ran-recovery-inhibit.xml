<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0588 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 11e86c56-22ba-5353-b922-86e4b0543464 -->
  <rule id="453885" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0588 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>