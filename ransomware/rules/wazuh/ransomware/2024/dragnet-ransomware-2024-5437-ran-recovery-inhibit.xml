<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5437 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 46ea4887-f38f-5c8a-9217-aa05a4925d9c -->
  <rule id="401048" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5437 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>