<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5671 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 61e4cdab-c60b-5ac7-858f-88b1f6af08cc -->
  <rule id="835629" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5671 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>