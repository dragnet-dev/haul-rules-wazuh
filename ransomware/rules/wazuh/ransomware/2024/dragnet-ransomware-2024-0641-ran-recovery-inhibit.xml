<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0641 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 55ff95a7-80f0-5650-b9d7-56826545c90b -->
  <rule id="633595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0641 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>