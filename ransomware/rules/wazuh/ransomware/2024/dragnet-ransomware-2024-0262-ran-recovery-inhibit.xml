<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0262 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3448f35d-0b29-52a1-b054-9a0ba2fe83af -->
  <rule id="218335" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0262 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>