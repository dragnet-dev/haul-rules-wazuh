<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4616 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 5eeeacfc-bc5a-5db5-9787-10d206be99b7 -->
  <rule id="921484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4616 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>