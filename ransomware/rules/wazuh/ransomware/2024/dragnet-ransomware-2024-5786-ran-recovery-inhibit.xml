<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5786 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: be12c65d-30d3-5e46-8d93-ffc0f2b03900 -->
  <rule id="442046" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5786 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>