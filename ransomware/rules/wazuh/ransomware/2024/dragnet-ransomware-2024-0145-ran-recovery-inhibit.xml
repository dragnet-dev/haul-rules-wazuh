<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0145 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 6dc944da-ff74-5940-a75b-b874a65aa9eb -->
  <rule id="956944" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0145 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>