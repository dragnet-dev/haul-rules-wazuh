<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1628 — Event Log Clearing (ElDorado) | Status: deprecated | Sigma ID: e525ff49-54e6-5ff9-b2b6-3a0926aa0c2a -->
  <rule id="218655" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1628 — Event Log Clearing (ElDorado)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>