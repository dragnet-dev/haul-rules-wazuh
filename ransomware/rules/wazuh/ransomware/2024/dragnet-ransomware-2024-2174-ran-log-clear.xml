<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2174 — Event Log Clearing (cloak) | Status: deprecated | Sigma ID: 4227bd44-ec42-5ab3-81b6-7df2b8b89131 -->
  <rule id="282301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2174 — Event Log Clearing (cloak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>