<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2650 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: f8a293c0-bc7c-5f4c-a608-f2cd8dd56de9 -->
  <rule id="838293" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2650 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>