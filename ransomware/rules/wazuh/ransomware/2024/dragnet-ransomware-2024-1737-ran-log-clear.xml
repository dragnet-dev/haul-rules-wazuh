<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1737 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: f052a8fd-7fcc-5a3a-8cd4-1d9b2f4cbdfa -->
  <rule id="708428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1737 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>