<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3448 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: c2124204-5ff1-5eb8-abea-6d2e3a6bfeec -->
  <rule id="421242" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3448 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>