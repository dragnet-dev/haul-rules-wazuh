<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4807 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 5e12d7d7-4eb1-52e5-9eeb-b8ee5624cefd -->
  <rule id="706057" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4807 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>