<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0780 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 1921fd57-67d0-54bc-8d6b-5430fd0e27a4 -->
  <rule id="520295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0780 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>