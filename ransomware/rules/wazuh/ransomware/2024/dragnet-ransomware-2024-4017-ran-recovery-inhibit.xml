<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4017 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 6615cb4f-dea1-5236-9e79-a5afecccd314 -->
  <rule id="893643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4017 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>