<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4206 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8d58c79b-a099-58d7-b868-b1bd4e687973 -->
  <rule id="565407" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4206 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>