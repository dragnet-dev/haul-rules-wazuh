<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0490 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: cf8125a2-e1a4-5cfe-b8f6-7f9775a11464 -->
  <rule id="378125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0490 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>