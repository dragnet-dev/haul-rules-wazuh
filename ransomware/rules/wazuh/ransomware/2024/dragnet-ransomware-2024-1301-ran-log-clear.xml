<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1301 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 65e8744f-55a3-5eb6-985c-4f8cef4029e4 -->
  <rule id="254874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1301 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>