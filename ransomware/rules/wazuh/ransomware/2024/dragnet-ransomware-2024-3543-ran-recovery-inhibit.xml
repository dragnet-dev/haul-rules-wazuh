<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3543 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: cb522cfa-126e-5bda-813b-99c7e239ad6f -->
  <rule id="656364" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3543 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>