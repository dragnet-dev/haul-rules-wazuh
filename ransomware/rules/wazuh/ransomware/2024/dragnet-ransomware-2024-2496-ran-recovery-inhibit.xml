<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2496 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: eb6fccba-9e8b-5686-a973-26b162b1daed -->
  <rule id="754220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2496 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>