<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1521 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3c92b2dd-4cca-5fb6-ad62-86f7b7b38af5 -->
  <rule id="397325" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1521 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>