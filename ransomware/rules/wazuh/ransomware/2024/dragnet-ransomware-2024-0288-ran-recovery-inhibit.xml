<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0288 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: 65101535-f961-5a68-a81d-dcf5baa4bfed -->
  <rule id="310153" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0288 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>