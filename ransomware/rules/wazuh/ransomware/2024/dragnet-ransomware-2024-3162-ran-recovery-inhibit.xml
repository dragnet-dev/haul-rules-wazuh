<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3162 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 44e970db-e1a8-5ed8-b6a5-657764f16b78 -->
  <rule id="803533" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3162 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>