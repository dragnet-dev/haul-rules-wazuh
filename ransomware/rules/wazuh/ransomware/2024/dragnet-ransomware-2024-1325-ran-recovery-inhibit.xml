<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1325 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 0f8215ed-a16a-55d3-b61d-7c7747a4b6c8 -->
  <rule id="831454" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1325 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>