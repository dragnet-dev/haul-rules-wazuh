<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5927 — Recovery Inhibition (cloak) | Status: experimental | Sigma ID: 8070f644-bdfa-59a8-b17e-d51cb75078cd -->
  <rule id="491356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5927 — Recovery Inhibition (cloak)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>