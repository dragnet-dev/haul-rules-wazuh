<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3182 — Event Log Clearing (BrainCipher) | Status: experimental | Sigma ID: 6766cf6e-d9cc-57f6-a3cb-53e86e0499b1 -->
  <rule id="932303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3182 — Event Log Clearing (BrainCipher)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>