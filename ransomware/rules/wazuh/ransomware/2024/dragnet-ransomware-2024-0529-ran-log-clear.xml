<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0529 — Event Log Clearing (apt73) | Status: experimental | Sigma ID: 2f2bd5a1-d9e2-5b4c-a715-b8b9edaf3272 -->
  <rule id="410215" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0529 — Event Log Clearing (apt73)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>