<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3536 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 5f2a433e-47e7-50ce-861a-9bd5f546bde0 -->
  <rule id="724243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3536 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>