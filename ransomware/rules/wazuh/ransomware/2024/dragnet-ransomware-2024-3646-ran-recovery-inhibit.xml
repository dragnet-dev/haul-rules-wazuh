<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3646 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 45f12e99-fdba-5f8f-9d27-b10938b1f085 -->
  <rule id="376206" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3646 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>