<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3235 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3a695b3d-f24a-51e2-b52c-8fe7c8d7916d -->
  <rule id="491313" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3235 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>