<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5679 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: db7bea8b-717a-58c2-8b31-5cbab79f652d -->
  <rule id="101962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5679 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>