<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4282 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 06f08171-cd86-540e-bfa6-d9ecf6ad05ba -->
  <rule id="310817" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4282 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>