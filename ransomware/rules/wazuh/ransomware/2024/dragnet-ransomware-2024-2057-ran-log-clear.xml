<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2057 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: d12a8eca-8b15-56c2-a5cb-60b8a3722f3b -->
  <rule id="760462" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2057 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>