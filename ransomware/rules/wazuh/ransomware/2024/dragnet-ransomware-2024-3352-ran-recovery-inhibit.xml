<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3352 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: 2adfdc3a-a685-5c3a-864d-7b890ef52a0d -->
  <rule id="209820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3352 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>