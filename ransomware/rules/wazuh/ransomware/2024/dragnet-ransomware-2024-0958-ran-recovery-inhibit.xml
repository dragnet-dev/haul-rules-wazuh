<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0958 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 97327ac7-bfea-58a9-a048-6bd8e1cb9c0f -->
  <rule id="757242" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0958 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>