<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4981 — Recovery Inhibition (dAn0n) | Status: experimental | Sigma ID: 81c226f6-3093-5842-b81d-3731a0cc72a3 -->
  <rule id="508226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4981 — Recovery Inhibition (dAn0n)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>