<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1384 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 81718fc8-dddd-5693-9b03-21857de76774 -->
  <rule id="507503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1384 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>