<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5963 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: e0b3d7b4-500a-511f-874a-56e5f4c28086 -->
  <rule id="102217" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5963 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>