<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3464 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: 0528440b-c46d-5c8a-bf5f-2bc6f12cf3e5 -->
  <rule id="455051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3464 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>