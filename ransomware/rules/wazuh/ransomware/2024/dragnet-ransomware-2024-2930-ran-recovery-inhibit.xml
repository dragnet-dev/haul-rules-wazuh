<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2930 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 792ba8a0-2b69-5b7c-9cc4-ab62cbc18f07 -->
  <rule id="329388" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2930 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>