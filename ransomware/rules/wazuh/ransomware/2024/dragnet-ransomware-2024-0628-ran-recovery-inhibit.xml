<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0628 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 6c7428f4-2d34-5bb6-8332-8eb6c6147e18 -->
  <rule id="287428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0628 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>