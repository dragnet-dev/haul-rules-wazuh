<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0302 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 43fb34da-fc22-571c-90f4-ae8eb92819dd -->
  <rule id="325934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0302 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>