<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1172 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: ed7f625c-ea2e-54d6-968e-442a1cb30fd9 -->
  <rule id="304762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1172 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>