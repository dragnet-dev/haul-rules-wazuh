<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1570 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: 1e3437ff-75fe-5239-97a4-e1c8b2bffb23 -->
  <rule id="455007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1570 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>