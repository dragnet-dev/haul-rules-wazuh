<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2979 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 92f1cec5-e441-5c62-b171-067050c0987a -->
  <rule id="307182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2979 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>