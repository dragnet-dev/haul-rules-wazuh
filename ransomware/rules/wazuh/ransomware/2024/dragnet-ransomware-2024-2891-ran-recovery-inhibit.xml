<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2891 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 3e008dbe-22c9-504a-80e9-6fdb974bc200 -->
  <rule id="674267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2891 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>