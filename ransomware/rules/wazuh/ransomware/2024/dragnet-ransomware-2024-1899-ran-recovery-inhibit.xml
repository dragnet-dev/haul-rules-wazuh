<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1899 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 22060f89-c421-5209-badf-00ab3a4ec90d -->
  <rule id="929758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1899 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>