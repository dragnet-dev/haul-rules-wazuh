<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5459 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 00717346-870f-5bcd-b748-c0364c311465 -->
  <rule id="973468" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5459 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>