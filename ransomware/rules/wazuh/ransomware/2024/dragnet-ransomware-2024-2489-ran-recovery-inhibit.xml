<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2489 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 6d897211-b7c7-5646-aafa-c400ed6b1454 -->
  <rule id="298972" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2489 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>