<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4847 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: db70047a-7008-55d0-8d1e-238ca9cb86cb -->
  <rule id="497004" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4847 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>