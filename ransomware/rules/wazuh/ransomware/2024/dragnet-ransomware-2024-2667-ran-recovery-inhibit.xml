<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2667 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 5c45dc80-f9a6-5968-a39d-fab530c4624b -->
  <rule id="666940" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2667 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>