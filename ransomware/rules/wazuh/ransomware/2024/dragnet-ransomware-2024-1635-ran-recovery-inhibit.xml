<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1635 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: ff5b61ce-b1d2-5e55-9dec-d1d359a90a91 -->
  <rule id="589161" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1635 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>