<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5539 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 0a933597-e180-5865-8a96-e33f8c0788b7 -->
  <rule id="293359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5539 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>