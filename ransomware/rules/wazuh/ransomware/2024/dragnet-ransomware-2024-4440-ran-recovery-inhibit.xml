<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4440 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 00c133ab-bafa-5f4b-bc38-0ab72decc1c0 -->
  <rule id="506219" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4440 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>