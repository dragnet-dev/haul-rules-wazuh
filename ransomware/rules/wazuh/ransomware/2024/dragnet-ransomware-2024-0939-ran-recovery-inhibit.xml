<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0939 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: a7e44c27-f9fb-530b-b061-608d1ca38b59 -->
  <rule id="162316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0939 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>