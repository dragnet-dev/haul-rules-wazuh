<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5693 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 887762ce-d0ed-55d2-ad0b-7e415a383b32 -->
  <rule id="804204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5693 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>