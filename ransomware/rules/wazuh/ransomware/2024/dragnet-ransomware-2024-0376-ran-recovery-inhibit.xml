<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0376 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: ca4834e7-72bd-5b86-a3b7-6365eb734636 -->
  <rule id="324834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0376 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>