<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3481 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 9a5a13c9-b1cc-5d63-9db5-6bfc6108df1f -->
  <rule id="773013" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3481 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>