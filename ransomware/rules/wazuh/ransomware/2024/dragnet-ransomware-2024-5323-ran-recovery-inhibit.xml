<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5323 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 6a13e732-5157-5671-b290-45de394c4e07 -->
  <rule id="898227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5323 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>