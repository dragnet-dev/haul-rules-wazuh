<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2171 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 81612ecc-891e-5423-800a-19bc9cf0c1a1 -->
  <rule id="505806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2171 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>