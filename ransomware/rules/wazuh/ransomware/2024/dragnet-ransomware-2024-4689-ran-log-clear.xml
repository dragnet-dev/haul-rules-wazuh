<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4689 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 3b0d8ff6-cf6c-57e2-b4d0-d0188aaf38f8 -->
  <rule id="712623" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4689 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>