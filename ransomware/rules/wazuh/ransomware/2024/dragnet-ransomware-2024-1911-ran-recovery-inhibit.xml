<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1911 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 5b6245b7-9baf-5085-ad88-ff2ed407530b -->
  <rule id="359931" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1911 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>