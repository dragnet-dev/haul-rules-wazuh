<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4250 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: d8f800b4-04af-505d-b648-1a03468639d0 -->
  <rule id="523800" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4250 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>