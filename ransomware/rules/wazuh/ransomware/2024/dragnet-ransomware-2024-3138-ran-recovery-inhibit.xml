<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3138 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6d1935bd-9839-5291-818f-8c3edf48d820 -->
  <rule id="291935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3138 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>