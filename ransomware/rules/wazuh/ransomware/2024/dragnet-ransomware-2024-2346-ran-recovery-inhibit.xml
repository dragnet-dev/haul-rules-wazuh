<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2346 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 421dbec8-b3b9-5ac8-8758-c5173d57a192 -->
  <rule id="927934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2346 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>