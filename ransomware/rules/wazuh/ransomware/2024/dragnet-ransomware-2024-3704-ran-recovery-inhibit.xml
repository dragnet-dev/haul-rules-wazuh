<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3704 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 733f12a8-8d46-57ec-84d5-f713cff78c76 -->
  <rule id="374312" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3704 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>