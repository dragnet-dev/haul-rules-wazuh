<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0135 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: ef4c7ed4-299e-5103-903e-9c0de29d3123 -->
  <rule id="830686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0135 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>