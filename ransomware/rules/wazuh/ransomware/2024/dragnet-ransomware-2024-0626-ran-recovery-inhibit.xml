<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0626 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4cd1a509-2efe-5d7f-b16f-5f4194d81a4d -->
  <rule id="266665" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0626 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>