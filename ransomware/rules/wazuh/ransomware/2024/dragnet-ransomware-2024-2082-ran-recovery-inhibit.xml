<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2082 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d17b51ac-12ba-5821-8cb9-7539dcdab091 -->
  <rule id="408351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2082 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>