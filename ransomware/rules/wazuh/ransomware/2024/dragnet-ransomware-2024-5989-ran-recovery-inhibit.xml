<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5989 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: b2b5798a-e8e3-51de-b170-2925c4d47aee -->
  <rule id="103579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5989 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>