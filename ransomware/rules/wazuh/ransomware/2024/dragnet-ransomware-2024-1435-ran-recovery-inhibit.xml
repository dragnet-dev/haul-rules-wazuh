<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1435 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 482e9601-99ce-5a32-80cd-2fae89f0b6cc -->
  <rule id="626960" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1435 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>