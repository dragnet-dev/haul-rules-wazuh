<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1525 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 71157752-a48e-5e04-8776-d68dcecbbb8d -->
  <rule id="915775" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1525 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>