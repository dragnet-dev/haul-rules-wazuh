<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0269 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: ad7b87bd-9143-5e79-b418-1e92623263f0 -->
  <rule id="180387" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0269 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>