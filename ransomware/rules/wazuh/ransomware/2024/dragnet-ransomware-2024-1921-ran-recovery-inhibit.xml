<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1921 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 10250bbd-719f-5f20-91b1-5a8a876ced88 -->
  <rule id="924187" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1921 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>