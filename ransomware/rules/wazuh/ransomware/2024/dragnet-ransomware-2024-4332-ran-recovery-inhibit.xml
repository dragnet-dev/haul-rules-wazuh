<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4332 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d375a9a6-a21d-5aa9-9106-6e30925edcef -->
  <rule id="440109" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4332 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>