<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1690 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: fcedfd1e-84db-5f60-9bb1-ce570b2481d2 -->
  <rule id="235999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1690 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>