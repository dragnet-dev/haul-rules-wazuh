<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2843 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 03955af2-a17a-5d78-b4ed-4d6f0d402517 -->
  <rule id="212655" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2843 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>