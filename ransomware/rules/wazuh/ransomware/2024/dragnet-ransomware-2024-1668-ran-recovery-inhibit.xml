<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1668 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ca3fbe1e-4615-5081-bc67-7b76d661d13f -->
  <rule id="290238" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1668 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>