<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5089 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 97fff5fd-11d5-588a-a112-aad7cb4006c9 -->
  <rule id="514075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5089 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>