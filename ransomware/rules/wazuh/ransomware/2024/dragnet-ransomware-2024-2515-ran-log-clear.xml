<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2515 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: 148c958d-a2f0-5c17-9fa2-ef95f4e6fe6f -->
  <rule id="680958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2515 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>