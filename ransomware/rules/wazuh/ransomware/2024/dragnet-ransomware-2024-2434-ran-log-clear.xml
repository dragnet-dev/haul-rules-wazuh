<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2434 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 60b05421-abee-5c6d-947e-8cba3cd9c9b5 -->
  <rule id="810542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2434 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>