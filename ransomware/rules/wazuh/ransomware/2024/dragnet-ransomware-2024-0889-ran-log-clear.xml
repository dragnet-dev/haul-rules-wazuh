<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0889 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: f9540c97-695b-5c3c-91e7-b38296d49c32 -->
  <rule id="852652" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0889 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>