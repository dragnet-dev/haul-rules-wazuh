<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1757 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 3a96db44-3c8d-556d-9525-e905908428e1 -->
  <rule id="709595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1757 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>