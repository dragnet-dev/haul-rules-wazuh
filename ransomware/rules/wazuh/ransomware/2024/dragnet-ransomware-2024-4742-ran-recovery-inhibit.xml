<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4742 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c00bf0c1-2af7-5870-907d-e8699de77b28 -->
  <rule id="473910" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4742 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>