<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5388 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: d506f32b-4c73-5dae-bace-2f5be06f613b -->
  <rule id="461113" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5388 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>