<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5230 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 08afead1-6597-5fa4-b62f-9aece20b88a8 -->
  <rule id="209165" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5230 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>