<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1480 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: a3520c79-a3ed-5945-8bf0-95c747c478ad -->
  <rule id="856332" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1480 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>