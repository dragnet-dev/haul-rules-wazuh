<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4964 — Event Log Clearing (interlock) | Status: experimental | Sigma ID: 84e9e67f-b0e5-5a41-b1fb-2c023c20aac0 -->
  <rule id="474386" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4964 — Event Log Clearing (interlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>