<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3558 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 03a42014-7a60-5650-acaf-075d9404d5b8 -->
  <rule id="542014" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3558 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>