<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4062 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 1ddd12cb-2005-559d-a380-1ce125f84c59 -->
  <rule id="632204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4062 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>