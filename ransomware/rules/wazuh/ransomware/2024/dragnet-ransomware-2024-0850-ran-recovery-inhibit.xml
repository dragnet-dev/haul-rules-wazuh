<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0850 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 4e395cbb-7582-5f15-ad37-b4dee836ac4f -->
  <rule id="454332" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0850 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>