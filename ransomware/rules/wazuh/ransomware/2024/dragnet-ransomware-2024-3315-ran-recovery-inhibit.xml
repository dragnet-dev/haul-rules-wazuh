<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3315 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: af65056d-5e52-50bb-9329-bb2f579aff06 -->
  <rule id="956505" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3315 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>