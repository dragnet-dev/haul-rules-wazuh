<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4868 — Recovery Inhibition (dAn0n) | Status: experimental | Sigma ID: 03bb41ae-2037-5773-9a1a-e356582c46c2 -->
  <rule id="728666" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4868 — Recovery Inhibition (dAn0n)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>