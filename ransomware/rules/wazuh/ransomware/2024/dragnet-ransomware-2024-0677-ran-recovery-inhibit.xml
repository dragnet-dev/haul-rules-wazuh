<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0677 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7cd7c542-df50-543f-a198-bb75025a80c5 -->
  <rule id="596445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0677 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>