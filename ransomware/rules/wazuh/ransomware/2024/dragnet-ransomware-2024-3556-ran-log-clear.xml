<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3556 — Event Log Clearing (BrainCipher) | Status: experimental | Sigma ID: f453af83-bcbc-56da-96ed-31bbb8d4dcd6 -->
  <rule id="456143" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3556 — Event Log Clearing (BrainCipher)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>