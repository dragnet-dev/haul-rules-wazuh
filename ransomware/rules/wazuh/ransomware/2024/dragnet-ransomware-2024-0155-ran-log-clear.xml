<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0155 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 1b5cc6dc-af49-547c-8d6f-dd30c4fe6d8f -->
  <rule id="596749" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0155 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>