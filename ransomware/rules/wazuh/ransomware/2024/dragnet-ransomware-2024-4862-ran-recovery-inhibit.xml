<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4862 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3df2cd01-c3c3-5554-82f0-1aa6d2ee1fd8 -->
  <rule id="837677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4862 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>