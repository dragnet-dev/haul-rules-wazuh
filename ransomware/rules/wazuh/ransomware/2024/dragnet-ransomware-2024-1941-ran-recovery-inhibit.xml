<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1941 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: cb3cabaa-cf9c-5376-a2b4-5c92ad3871fb -->
  <rule id="330411" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1941 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>