<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2064 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: ce5f768c-c81b-542a-a57e-682ceae838bd -->
  <rule id="705576" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2064 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>