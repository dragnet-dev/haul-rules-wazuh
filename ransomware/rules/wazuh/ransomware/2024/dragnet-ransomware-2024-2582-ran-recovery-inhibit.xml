<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2582 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: a1a7e603-d059-5c8a-b6e9-5bbafbe6c22f -->
  <rule id="902866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2582 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>