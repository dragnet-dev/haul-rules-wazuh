<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4634 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 735eac30-98fa-5d4f-b431-4211385b4541 -->
  <rule id="414316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4634 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>