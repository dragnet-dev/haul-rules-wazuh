<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4981 — Event Log Clearing (dAn0n) | Status: experimental | Sigma ID: 9a2adb04-48a1-5aa0-9084-1862b559f9d5 -->
  <rule id="118811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4981 — Event Log Clearing (dAn0n)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>