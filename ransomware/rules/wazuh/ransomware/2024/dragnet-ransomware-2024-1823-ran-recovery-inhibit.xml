<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1823 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 38d7ad64-2081-5060-b3e5-acf9c0f76b00 -->
  <rule id="791725" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1823 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>