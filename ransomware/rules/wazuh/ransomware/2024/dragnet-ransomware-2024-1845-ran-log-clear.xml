<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1845 — Event Log Clearing (qiulong) | Status: experimental | Sigma ID: b7ab6272-3f64-5035-8b6e-0cfdad5a2ada -->
  <rule id="412362" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1845 — Event Log Clearing (qiulong)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>