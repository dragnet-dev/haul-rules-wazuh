<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3287 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7d1c8dfe-6f1d-5a30-9314-d67f09f8411a -->
  <rule id="604621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3287 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
