<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2762 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c1958294-0b17-5fd0-8c7e-520e9eb1068e -->
  <rule id="419582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2762 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>