<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5473 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 9a1e06cd-a23c-5e7d-a784-79eb59e85bfb -->
  <rule id="767006" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5473 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>