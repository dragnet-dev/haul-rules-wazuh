<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4072 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 70bb1d58-d9bb-5659-9915-45366955c244 -->
  <rule id="297149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4072 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>