<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1675 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 66e0a200-e651-5c0a-b66c-64cfd64ac088 -->
  <rule id="912102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1675 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>