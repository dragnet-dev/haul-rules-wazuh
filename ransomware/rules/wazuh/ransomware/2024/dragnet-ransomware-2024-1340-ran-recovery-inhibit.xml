<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1340 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2085106e-95a9-503f-91d2-dd92a1cc95d2 -->
  <rule id="385106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1340 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>