<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2976 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: e25f11bb-570a-5374-bc9f-e90d61861c27 -->
  <rule id="581511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2976 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>