<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4572 — Recovery Inhibition (blackout) | Status: experimental | Sigma ID: 47449634-7bf0-556c-af1c-3818a7dc4f80 -->
  <rule id="344963" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4572 — Recovery Inhibition (blackout)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>