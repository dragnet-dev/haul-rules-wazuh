<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1774 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4b2400a5-90d7-57c0-8fb7-adda22c98816 -->
  <rule id="438410" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1774 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>