<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5250 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 424b4032-5e5d-5471-b70d-61560398ea1b -->
  <rule id="595403" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5250 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>