<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5855 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: dadbea28-d86e-5f38-be22-3c130832de36 -->
  <rule id="943146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5855 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>