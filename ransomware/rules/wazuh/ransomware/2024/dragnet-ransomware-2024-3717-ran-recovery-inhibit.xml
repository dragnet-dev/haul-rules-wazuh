<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3717 — Recovery Inhibition (blackout) | Status: experimental | Sigma ID: a3b8b470-e33c-5ab9-a2dd-8896be6aeda1 -->
  <rule id="955794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3717 — Recovery Inhibition (blackout)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>