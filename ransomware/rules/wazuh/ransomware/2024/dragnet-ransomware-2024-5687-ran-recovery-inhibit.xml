<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5687 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 40415265-7f27-5ffc-b3b4-4d828aa9cdd8 -->
  <rule id="541526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5687 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>