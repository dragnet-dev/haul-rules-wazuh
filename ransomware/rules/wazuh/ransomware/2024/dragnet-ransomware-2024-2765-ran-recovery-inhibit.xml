<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2765 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 92ae2f46-00c6-5c5e-96e3-4c16e437a148 -->
  <rule id="296207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2765 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>