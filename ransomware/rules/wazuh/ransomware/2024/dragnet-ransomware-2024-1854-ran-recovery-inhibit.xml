<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1854 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7ca0e8fe-a741-55ad-bdba-a5da5cbbe1b4 -->
  <rule id="590548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1854 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>