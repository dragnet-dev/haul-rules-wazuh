<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1658 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: a15eae95-aa9a-53f3-a6e1-f39830cfd5a8 -->
  <rule id="661198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1658 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>