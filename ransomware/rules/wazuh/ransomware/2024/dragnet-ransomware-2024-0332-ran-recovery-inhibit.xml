<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0332 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: c8cb3f5c-923b-5496-9e09-7e2080d13fec -->
  <rule id="875423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0332 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>