<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0774 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: cbaf2312-37ea-5ded-84b8-806b27ddb328 -->
  <rule id="814323" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0774 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>