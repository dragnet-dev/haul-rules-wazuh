<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0455 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 02a19d8c-cd45-588e-9366-c793355fa479 -->
  <rule id="102860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0455 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>