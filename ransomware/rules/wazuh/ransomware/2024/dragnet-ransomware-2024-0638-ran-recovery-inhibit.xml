<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0638 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: c477aaef-8d52-5f10-96cd-f4c2022c8cfd -->
  <rule id="594282" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0638 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>