<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3733 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 92990c0d-c973-5a72-9ca3-abcafd092662 -->
  <rule id="687852" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3733 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>