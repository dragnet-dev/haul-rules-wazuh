<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1810 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: adfd69bb-a07c-5d00-85e8-59d6ca2bfef8 -->
  <rule id="954169" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1810 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>