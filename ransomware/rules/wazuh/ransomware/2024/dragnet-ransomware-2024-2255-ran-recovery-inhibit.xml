<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2255 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f0b61cf0-c7c6-5d50-a6ba-e1f8fc34639d -->
  <rule id="358588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2255 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>