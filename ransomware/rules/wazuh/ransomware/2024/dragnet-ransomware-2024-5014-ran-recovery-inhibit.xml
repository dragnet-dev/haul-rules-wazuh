<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5014 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e1fb0621-a76a-5ac7-a3a5-2191fe312ec4 -->
  <rule id="134706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5014 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>