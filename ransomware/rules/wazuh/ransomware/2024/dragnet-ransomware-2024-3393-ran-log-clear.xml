<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3393 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: fcc2e4f1-14fd-5edf-aa07-c5de4f47fd4d -->
  <rule id="270864" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3393 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>