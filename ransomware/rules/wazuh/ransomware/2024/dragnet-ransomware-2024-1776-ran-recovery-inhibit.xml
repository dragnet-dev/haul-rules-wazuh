<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1776 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a57a5a00-f1f5-5546-b72d-15a2ed77f307 -->
  <rule id="107610" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1776 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>