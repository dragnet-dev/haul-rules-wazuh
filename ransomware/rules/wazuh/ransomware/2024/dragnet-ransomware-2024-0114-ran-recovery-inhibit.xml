<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0114 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 9f6d14e1-49fd-5f9f-9d97-596dc81ae2ab -->
  <rule id="854914" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0114 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>