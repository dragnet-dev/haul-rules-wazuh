<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0825 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 3352f42c-201f-5316-b125-e7687d9d709e -->
  <rule id="964742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0825 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>