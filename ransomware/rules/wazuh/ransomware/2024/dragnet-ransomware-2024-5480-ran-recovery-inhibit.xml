<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5480 — Recovery Inhibition (play) | Status: experimental | Sigma ID: eeb33af7-495b-5efb-a539-56fedc775c32 -->
  <rule id="810938" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5480 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>