<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2974 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 9e38d6ed-369c-52ed-9b66-3285738e645c -->
  <rule id="834216" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2974 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>