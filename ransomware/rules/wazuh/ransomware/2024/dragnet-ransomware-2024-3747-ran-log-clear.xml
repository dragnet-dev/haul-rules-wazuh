<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3747 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 9c34ce33-2efe-59f4-a3e3-5ca43b079bb5 -->
  <rule id="502510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3747 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>