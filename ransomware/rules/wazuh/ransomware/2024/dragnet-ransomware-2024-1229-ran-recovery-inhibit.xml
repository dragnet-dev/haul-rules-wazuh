<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1229 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 281eec7f-e6a0-54be-9110-34b093aacd2d -->
  <rule id="354796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1229 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>