<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3152 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: c3ebc210-a980-5f82-9da2-7b50b879a152 -->
  <rule id="675802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3152 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>