<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4381 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 2f8b8897-82c1-5855-8603-d3209752a7fd -->
  <rule id="559889" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4381 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>