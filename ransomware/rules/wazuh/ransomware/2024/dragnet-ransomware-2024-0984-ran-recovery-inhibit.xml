<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0984 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 1d6d7683-30e7-5f64-92e4-800dfffcf55f -->
  <rule id="349768" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0984 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>