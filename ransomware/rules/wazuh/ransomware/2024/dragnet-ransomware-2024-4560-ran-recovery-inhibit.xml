<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4560 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: f1db5366-8874-5c82-8908-d104ee501c79 -->
  <rule id="387553" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4560 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>