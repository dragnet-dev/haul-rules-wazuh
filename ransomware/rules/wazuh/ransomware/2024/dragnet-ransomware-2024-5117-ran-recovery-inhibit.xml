<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5117 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: fc9f7fd2-0e31-518d-8438-ff6edd73ce38 -->
  <rule id="276767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5117 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>