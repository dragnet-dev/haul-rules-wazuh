<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3565 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: c5cb1270-f4d5-580d-b7cf-ee18087b1cd9 -->
  <rule id="620312" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3565 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>