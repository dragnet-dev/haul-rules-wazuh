<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2297 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 81ec5bc6-2952-5914-b9e6-be22f56b6d11 -->
  <rule id="755611" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2297 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>