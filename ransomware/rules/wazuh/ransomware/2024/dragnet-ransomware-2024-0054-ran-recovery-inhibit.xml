<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0054 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0c45aad2-291d-5b06-ac69-30617d0cc2f5 -->
  <rule id="702253" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0054 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>