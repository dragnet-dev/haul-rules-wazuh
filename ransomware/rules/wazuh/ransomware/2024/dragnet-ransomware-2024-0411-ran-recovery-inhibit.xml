<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0411 — Recovery Inhibition (ElDorado) | Status: experimental | Sigma ID: 1a611758-419d-5835-86f6-f9ab38231b45 -->
  <rule id="961175" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0411 — Recovery Inhibition (ElDorado)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>