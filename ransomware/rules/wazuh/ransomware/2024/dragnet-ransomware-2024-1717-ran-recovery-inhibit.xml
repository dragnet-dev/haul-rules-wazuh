<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1717 — Recovery Inhibition (play) | Status: experimental | Sigma ID: aa866ad1-6dc7-5c77-9e7e-35f08691592b -->
  <rule id="133866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1717 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>