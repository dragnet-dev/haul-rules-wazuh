<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3145 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 55642b31-520c-57eb-9b09-fad9853d5c02 -->
  <rule id="902833" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3145 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>