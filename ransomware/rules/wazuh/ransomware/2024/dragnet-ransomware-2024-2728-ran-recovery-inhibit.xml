<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2728 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 2d15f860-2b48-51c7-8dab-ce6183a7715d -->
  <rule id="125586" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2728 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>