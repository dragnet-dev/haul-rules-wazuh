<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4315 — Recovery Inhibition (play) | Status: experimental | Sigma ID: fe71f3e4-75c6-59cb-a99c-735139de1007 -->
  <rule id="575513" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4315 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>