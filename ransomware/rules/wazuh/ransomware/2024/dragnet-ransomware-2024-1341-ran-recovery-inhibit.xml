<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1341 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 95d0ac26-432d-5a50-850c-4015d7cdf2ae -->
  <rule id="424652" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1341 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>