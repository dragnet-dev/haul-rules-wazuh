<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5937 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 9d9736a8-f8e4-5e28-869c-a5e66cd349c5 -->
  <rule id="779736" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5937 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>