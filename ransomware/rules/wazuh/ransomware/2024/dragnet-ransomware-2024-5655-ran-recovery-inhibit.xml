<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5655 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: a07c6518-9725-560d-b3e0-7aec1fe894b0 -->
  <rule id="812465" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5655 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>