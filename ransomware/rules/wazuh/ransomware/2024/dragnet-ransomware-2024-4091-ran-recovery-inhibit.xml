<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4091 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 7434e1d9-be46-577d-9880-659ca4a88a43 -->
  <rule id="389581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4091 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>