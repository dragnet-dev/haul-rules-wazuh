<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2969 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 455684e6-c169-5ba9-85f2-ba37133586d1 -->
  <rule id="190958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2969 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>