<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2270 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 10b34ff1-521c-56bb-8a5a-a9d2beba2f61 -->
  <rule id="886559" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2270 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>