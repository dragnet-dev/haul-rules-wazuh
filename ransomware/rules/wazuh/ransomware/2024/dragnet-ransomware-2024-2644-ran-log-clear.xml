<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2644 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 29f2d422-3d52-5ffc-861b-9022c8bdb445 -->
  <rule id="568542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2644 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>