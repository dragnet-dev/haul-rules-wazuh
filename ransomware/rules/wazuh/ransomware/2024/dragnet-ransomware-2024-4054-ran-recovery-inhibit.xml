<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4054 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: c3708c30-9e64-55b8-a267-355537d43feb -->
  <rule id="279340" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4054 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
