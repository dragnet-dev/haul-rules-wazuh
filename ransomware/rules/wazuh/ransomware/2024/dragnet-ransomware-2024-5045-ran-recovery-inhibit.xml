<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5045 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: c23682b7-d8c4-5b6d-b0d7-45fb5478e224 -->
  <rule id="423682" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5045 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>