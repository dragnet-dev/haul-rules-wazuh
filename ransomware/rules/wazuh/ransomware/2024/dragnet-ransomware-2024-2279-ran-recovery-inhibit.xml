<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2279 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 389ae2c8-482a-5016-b36d-8f2c7ac8dbc5 -->
  <rule id="761324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2279 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>