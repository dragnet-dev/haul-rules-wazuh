<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4702 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2f8e1591-e47a-502f-94cc-27576cf7a22f -->
  <rule id="562159" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4702 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>