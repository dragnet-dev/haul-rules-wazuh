<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1612 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: d1d02594-1c60-5b9a-9daa-2a578b905eee -->
  <rule id="409025" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1612 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>