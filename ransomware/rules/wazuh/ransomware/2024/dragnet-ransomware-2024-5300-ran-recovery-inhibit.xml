<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5300 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 7308521a-3068-5589-92ea-44bf187c0d1e -->
  <rule id="208521" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5300 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>