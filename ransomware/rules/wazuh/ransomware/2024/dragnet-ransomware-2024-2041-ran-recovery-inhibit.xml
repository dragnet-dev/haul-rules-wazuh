<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2041 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 42530122-045a-500f-bb0e-73bb91fbfc70 -->
  <rule id="753012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2041 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>