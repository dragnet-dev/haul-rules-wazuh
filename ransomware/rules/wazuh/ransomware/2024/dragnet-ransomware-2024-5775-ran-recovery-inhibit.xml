<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5775 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: f798a24e-52d2-597d-88ce-2ccf030e1bc1 -->
  <rule id="827782" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5775 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>