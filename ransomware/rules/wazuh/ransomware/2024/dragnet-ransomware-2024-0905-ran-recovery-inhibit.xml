<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0905 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: dc985361-a4c6-5225-b02a-5f94391134cb -->
  <rule id="509853" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0905 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>