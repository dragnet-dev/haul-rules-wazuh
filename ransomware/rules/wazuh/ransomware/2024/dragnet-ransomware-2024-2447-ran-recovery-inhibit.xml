<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2447 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: d4a31f75-3ab8-5440-839b-53e34e366c53 -->
  <rule id="846911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2447 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>