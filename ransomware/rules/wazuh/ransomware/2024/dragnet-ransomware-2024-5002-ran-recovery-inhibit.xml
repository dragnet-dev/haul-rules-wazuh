<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5002 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: fadf3f24-3a55-56b6-84bc-9cea7995f94d -->
  <rule id="475743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5002 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>