<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2864 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3351e377-ef0a-54a5-857a-e177dba40c7e -->
  <rule id="963037" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2864 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>