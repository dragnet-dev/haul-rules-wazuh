<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4152 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 3dcd1fe2-8bf8-5d47-913f-75f351206657 -->
  <rule id="831391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4152 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>