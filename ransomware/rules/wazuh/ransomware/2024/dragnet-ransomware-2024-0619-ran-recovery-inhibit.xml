<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0619 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 30ab92f5-e281-5989-9e90-2c5208e2b4ec -->
  <rule id="963087" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0619 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>