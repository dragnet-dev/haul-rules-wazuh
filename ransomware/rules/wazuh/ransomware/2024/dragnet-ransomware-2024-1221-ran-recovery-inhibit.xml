<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1221 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: f8aab49b-7076-573b-b131-11e15c340810 -->
  <rule id="298994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1221 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>