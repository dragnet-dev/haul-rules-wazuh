<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4252 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 8096cbdf-138a-574d-ab9e-6a8a65d61fdf -->
  <rule id="372779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4252 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>