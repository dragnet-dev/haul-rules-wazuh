<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4832 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 9f1ea773-20b1-5697-829d-90fdc968fbd8 -->
  <rule id="575307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4832 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>