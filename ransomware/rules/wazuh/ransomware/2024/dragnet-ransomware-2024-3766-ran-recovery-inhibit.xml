<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3766 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a0c075df-d92c-57ac-a262-0ec44d47e528 -->
  <rule id="812075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3766 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>