<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4077 — Event Log Clearing (madliberator) | Status: experimental | Sigma ID: bd63322b-d712-5a6c-b6fd-5c74b98b080c -->
  <rule id="196332" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4077 — Event Log Clearing (madliberator)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>