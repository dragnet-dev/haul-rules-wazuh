<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0821 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 1abda5ef-2039-5268-98ff-366c984a050a -->
  <rule id="295305" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0821 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>