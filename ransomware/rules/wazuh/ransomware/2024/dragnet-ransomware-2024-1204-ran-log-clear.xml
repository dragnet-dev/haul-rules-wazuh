<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1204 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 053ae7c5-69e7-5d66-8c6e-d4bf69c93286 -->
  <rule id="498844" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1204 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>