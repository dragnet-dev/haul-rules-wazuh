<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0555 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 974a670f-d644-542f-bea1-96dff5eaa77a -->
  <rule id="759467" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0555 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>