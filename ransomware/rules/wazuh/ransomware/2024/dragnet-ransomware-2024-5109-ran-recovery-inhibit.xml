<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5109 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 79dacaac-f0a7-511f-84eb-8e956d8e6980 -->
  <rule id="833354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5109 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>