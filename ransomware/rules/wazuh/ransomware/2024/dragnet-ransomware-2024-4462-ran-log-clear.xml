<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4462 — Event Log Clearing (ciphbit) | Status: deprecated | Sigma ID: 622ee0a6-d3dd-5a2a-b6c8-61c1f1603d52 -->
  <rule id="794700" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4462 — Event Log Clearing (ciphbit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>