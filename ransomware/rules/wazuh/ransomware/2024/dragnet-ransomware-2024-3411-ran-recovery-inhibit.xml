<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3411 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 82d52b1e-6041-560b-9d17-0dd9ce3a073f -->
  <rule id="420843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3411 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>