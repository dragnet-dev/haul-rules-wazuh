<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5915 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 749496a5-0cfb-5b08-909e-61ff5ba9abfd -->
  <rule id="391946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5915 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>