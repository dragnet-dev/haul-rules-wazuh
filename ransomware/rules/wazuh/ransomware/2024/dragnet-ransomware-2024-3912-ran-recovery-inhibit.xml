<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3912 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 577428f5-2dd5-559b-a44e-e8ad2852571d -->
  <rule id="338863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3912 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>