<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1022 — Recovery Inhibition (kraken) | Status: experimental | Sigma ID: 20cc4068-c12e-522c-8d98-f46cee9e4433 -->
  <rule id="924406" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1022 — Recovery Inhibition (kraken)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>