<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4721 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: e21dccfb-708a-58a6-addb-26e6efa6c457 -->
  <rule id="523948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4721 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>