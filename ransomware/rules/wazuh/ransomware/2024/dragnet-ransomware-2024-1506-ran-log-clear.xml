<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1506 — Event Log Clearing (cloak) | Status: deprecated | Sigma ID: e3865dec-55b4-59e7-8897-9e2b5f3f2aa9 -->
  <rule id="601853" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1506 — Event Log Clearing (cloak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>