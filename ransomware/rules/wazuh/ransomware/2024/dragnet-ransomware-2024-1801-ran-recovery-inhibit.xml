<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1801 — Recovery Inhibition (trinity) | Status: experimental | Sigma ID: 6af4dc2c-d670-5475-80bd-3291c1fbd4a5 -->
  <rule id="881404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1801 — Recovery Inhibition (trinity)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
