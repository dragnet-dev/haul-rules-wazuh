<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4781 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: eb5c3273-688c-5212-8d38-dcd8b4281222 -->
  <rule id="269232" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4781 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>