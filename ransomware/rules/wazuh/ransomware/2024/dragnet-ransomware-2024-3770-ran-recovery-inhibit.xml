<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3770 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: fb94bf6a-03be-53f1-9fae-dd1938c4edae -->
  <rule id="249855" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3770 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>