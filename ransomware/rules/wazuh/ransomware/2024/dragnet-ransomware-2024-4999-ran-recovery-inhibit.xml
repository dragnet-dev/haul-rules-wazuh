<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4999 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 02f8fea6-5f4c-5de8-9386-9925f1c164eb -->
  <rule id="261962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4999 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>