<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1424 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6770eb0b-4c13-5a9c-8e71-54d56e7100c5 -->
  <rule id="933355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1424 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>