<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5629 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: dc843f12-6d99-5a1e-ad68-a7a0185e03b1 -->
  <rule id="933503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5629 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>