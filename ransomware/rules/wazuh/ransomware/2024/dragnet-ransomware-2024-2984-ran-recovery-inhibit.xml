<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2984 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9983eaa6-7c3e-5ee0-9138-ea0977faa91d -->
  <rule id="855882" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2984 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>