<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0101 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 8b31979f-f2b1-5a6c-9416-d3f16c5f0d77 -->
  <rule id="593197" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0101 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>