<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2993 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: ca89e2ed-3ce0-5694-b4d8-457f77d163fc -->
  <rule id="646382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2993 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>