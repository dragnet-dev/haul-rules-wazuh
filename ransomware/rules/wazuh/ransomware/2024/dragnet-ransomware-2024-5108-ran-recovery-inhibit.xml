<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5108 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 582b591d-9659-5d2e-b485-f2b46d151a7c -->
  <rule id="423591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5108 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>