<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5932 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 2e8f9505-57aa-50ab-be99-659e6623e9b7 -->
  <rule id="403950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5932 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>