<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1240 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c19b3a5a-e487-5558-b483-720b0a31ea38 -->
  <rule id="522458" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1240 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>