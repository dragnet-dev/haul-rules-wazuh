<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2502 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b518eb62-0055-55b4-8ed8-5f880b897952 -->
  <rule id="348843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2502 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>