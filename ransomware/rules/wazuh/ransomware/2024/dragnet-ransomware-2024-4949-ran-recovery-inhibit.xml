<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4949 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 5e47a10d-7786-5beb-8c6f-b8b384aec387 -->
  <rule id="711621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4949 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>