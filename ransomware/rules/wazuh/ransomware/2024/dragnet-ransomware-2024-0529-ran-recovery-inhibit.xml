<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0529 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 1322995b-07db-5734-aef5-58b0cf94fa1b -->
  <rule id="522995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0529 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>