<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3771 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 1b1b0cc8-1a9f-5267-a8df-6f13663990b2 -->
  <rule id="428524" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3771 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>