<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4425 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 7235641d-3d47-549d-8f1b-68085978b94b -->
  <rule id="135641" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4425 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>