<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2075 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 493ded46-cce4-5eb0-9ee1-6b17f543151d -->
  <rule id="322893" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2075 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>