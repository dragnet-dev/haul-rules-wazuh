<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2798 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0c3cad4a-eda3-5182-8fdb-a6a1ad25248a -->
  <rule id="670534" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2798 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>