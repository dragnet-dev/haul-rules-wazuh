<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4742 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: e69acb0f-1e87-5e4b-80b8-4fbef9a9c409 -->
  <rule id="719787" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4742 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>