<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5521 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: aef760fd-76e0-547f-a16c-1a222ad85e2c -->
  <rule id="199760" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5521 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>