<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0774 — Event Log Clearing (donutleaks) | Status: experimental | Sigma ID: de7ed2b5-29ab-5f8e-9c84-0abe9c5b80fc -->
  <rule id="403492" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0774 — Event Log Clearing (donutleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>