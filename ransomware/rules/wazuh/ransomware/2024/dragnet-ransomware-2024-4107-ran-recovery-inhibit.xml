<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4107 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: f7b54dd7-a2de-5edc-ae88-fc1419287dfd -->
  <rule id="537677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4107 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>