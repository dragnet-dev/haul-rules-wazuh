<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2034 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f872b0ab-a934-57d2-96aa-522932c8a541 -->
  <rule id="839630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2034 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>