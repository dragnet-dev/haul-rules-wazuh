<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2137 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 216bce53-1bc2-5f00-b694-9c2936221a74 -->
  <rule id="877585" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2137 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>