<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1047 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7a6c5bd5-eda9-5c21-98e5-af4584e99f16 -->
  <rule id="540571" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1047 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>