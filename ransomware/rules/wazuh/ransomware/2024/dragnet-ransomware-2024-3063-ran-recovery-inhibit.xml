<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3063 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c28d0a75-59ad-5a50-8f4f-966de5a29c6d -->
  <rule id="545770" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3063 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>