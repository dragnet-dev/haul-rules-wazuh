<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5825 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: ef9da18f-4026-58d8-b316-d68e8dadb496 -->
  <rule id="843621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5825 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>