<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0561 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 9cb1d882-03b7-5104-aa58-dfee3689506b -->
  <rule id="511498" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0561 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>