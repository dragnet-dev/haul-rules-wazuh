<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5648 — Event Log Clearing (meow) | Status: experimental | Sigma ID: d65ae093-f9ef-5e8f-a96c-c7ba37ed83f3 -->
  <rule id="896140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5648 — Event Log Clearing (meow)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>