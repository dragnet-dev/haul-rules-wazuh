<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4142 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 567c457b-b5d2-547a-b85e-58c4e434c9a3 -->
  <rule id="184457" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4142 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>