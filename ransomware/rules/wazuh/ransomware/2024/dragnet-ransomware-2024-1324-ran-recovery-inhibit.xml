<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1324 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9ec0d94c-6673-507a-92a9-c4028b1637cf -->
  <rule id="564139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1324 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>