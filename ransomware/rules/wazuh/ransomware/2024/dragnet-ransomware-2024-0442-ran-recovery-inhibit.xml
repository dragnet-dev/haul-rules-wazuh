<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0442 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 15d00f4b-bb9d-52a5-86ed-57669ce42ec5 -->
  <rule id="548154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0442 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>