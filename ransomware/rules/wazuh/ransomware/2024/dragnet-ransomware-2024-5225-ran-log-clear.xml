<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5225 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: a265fa43-e92f-5a08-8dc9-bff1191f2d09 -->
  <rule id="928090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5225 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>