<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3883 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 388aa909-72ab-525d-b30c-5f1179aa3e67 -->
  <rule id="149890" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3883 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>