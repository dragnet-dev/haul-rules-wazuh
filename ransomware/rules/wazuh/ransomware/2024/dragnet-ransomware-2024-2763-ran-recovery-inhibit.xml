<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2763 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: dc8134be-368e-5a6d-9203-bb30f8f4d9bf -->
  <rule id="508134" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2763 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>