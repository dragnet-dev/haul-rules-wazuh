<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4353 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 31a6295a-a652-5196-88a7-2039be13a7db -->
  <rule id="666295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4353 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>