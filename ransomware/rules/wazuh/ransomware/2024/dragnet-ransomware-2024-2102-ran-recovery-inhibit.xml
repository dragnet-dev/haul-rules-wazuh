<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2102 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1fba5e79-5e94-5c81-be33-64f5ae69b30c -->
  <rule id="499614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2102 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>