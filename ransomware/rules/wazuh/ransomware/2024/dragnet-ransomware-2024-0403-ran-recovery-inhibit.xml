<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0403 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 5bf76795-6332-5635-8960-b0173f60d50a -->
  <rule id="671767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0403 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>