<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5738 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 60f13278-28c1-530b-8812-268dedf9c20b -->
  <rule id="851327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5738 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>