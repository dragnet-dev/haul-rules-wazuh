<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4057 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 65bd9b9a-e5de-5c5a-9e47-a6f9df2fee61 -->
  <rule id="992795" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4057 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>