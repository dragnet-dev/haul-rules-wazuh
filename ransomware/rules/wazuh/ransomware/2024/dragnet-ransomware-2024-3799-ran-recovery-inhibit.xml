<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3799 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 9f386644-dfec-5e1c-96dc-5f2fa72d4fc4 -->
  <rule id="793866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3799 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>