<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4200 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 21af78e7-0783-54dd-96a4-537b476048e1 -->
  <rule id="882862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4200 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>