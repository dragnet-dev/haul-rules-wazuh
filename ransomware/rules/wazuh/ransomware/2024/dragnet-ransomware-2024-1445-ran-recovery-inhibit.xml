<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1445 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 7d293a2a-5a35-55de-84a8-c996cce47d21 -->
  <rule id="304698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1445 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>