<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0508 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 61739dca-634f-5b79-9793-860e61d0cc0b -->
  <rule id="605404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0508 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>