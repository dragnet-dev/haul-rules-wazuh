<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4563 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 29297c29-6e70-52bc-a091-48f58006ff4b -->
  <rule id="287642" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4563 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>