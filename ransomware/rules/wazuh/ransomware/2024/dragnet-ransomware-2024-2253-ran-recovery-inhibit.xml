<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2253 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6b248f13-f89d-5653-9064-a55a35afcd2b -->
  <rule id="915983" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2253 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>