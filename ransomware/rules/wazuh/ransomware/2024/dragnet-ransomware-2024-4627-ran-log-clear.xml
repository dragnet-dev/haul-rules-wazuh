<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4627 — Event Log Clearing (dragonforce) | Status: experimental | Sigma ID: b9cb78ee-df80-50b9-8daa-a9c0b1ac49ce -->
  <rule id="466778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4627 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>