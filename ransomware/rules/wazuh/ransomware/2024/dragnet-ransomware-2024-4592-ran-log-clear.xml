<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4592 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 84fe3fc4-c3d5-59f2-bc7e-0df426cdc4e3 -->
  <rule id="881343" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4592 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>