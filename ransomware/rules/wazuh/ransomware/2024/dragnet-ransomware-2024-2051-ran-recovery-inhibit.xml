<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2051 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 77eadf08-8562-532f-90d8-ab150b05b400 -->
  <rule id="706399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2051 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>