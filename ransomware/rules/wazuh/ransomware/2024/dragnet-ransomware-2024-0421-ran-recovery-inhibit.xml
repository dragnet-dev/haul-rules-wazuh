<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0421 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 151f2040-c7f8-5d96-bfe3-8552f6afd227 -->
  <rule id="731204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0421 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>