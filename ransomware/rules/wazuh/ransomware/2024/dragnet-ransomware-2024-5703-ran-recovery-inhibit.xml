<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5703 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: a7f1581a-6f60-5b55-86c3-64a922b76cc6 -->
  <rule id="927158" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5703 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>