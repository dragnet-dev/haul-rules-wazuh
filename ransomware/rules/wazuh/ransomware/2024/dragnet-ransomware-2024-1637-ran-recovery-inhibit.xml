<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1637 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5c5ab05e-cbc3-569b-a6b2-c49b1dd38b0a -->
  <rule id="669710" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1637 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>