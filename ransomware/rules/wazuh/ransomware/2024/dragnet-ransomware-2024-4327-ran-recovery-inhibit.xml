<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4327 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: aa8d804b-3be6-59f7-9b03-819321aad7e7 -->
  <rule id="134180" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4327 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>