<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5701 — Event Log Clearing (bluebox) | Status: experimental | Sigma ID: 3e003fcb-ba79-5616-b235-07cce1480e7d -->
  <rule id="673020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5701 — Event Log Clearing (bluebox)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>