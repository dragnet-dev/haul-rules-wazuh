<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4507 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2c78c982-85df-5bd3-a02e-f1abb8b624aa -->
  <rule id="966098" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4507 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>