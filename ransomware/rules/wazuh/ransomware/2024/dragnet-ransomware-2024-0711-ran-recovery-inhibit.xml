<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0711 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 76504dcf-2dc7-5241-85e1-f62db02f1dba -->
  <rule id="424077" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0711 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>