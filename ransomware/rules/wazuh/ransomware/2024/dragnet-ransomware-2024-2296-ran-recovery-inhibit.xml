<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2296 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4891271a-0d3a-5c74-81a0-625357e2e082 -->
  <rule id="491271" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2296 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>