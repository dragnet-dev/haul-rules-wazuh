<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4458 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: d870b99f-56d4-54ca-bef9-81b5d7c6174c -->
  <rule id="519319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4458 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>