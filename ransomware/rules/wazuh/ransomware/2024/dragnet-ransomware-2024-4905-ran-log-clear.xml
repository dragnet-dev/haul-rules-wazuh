<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4905 — Event Log Clearing (cicada3301) | Status: experimental | Sigma ID: 14b22b8d-9a3a-5137-bfd7-c9834f6da545 -->
  <rule id="263638" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4905 — Event Log Clearing (cicada3301)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>