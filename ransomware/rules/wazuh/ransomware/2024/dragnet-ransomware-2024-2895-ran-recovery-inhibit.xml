<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2895 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: e11a50d9-ed03-5900-89f3-ec785ab833dc -->
  <rule id="558650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2895 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>