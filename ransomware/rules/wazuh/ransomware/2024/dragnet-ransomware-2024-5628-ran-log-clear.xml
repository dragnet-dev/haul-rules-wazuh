<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5628 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 1d0b2022-b343-5864-aeea-b556f2b75dc2 -->
  <rule id="251202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5628 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>