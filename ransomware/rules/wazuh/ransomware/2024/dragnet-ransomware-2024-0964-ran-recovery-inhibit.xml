<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0964 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f000e32a-8d56-5147-b024-6645f9647dcd -->
  <rule id="700143" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0964 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>