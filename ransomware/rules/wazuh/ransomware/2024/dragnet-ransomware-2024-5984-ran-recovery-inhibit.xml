<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5984 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: a3be9d76-20b7-5242-960c-aa824f5621e5 -->
  <rule id="749437" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5984 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>