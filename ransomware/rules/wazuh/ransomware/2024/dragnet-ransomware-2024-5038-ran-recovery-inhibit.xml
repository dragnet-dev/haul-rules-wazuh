<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5038 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: c28a150a-3867-5cdc-b006-d1d15d649632 -->
  <rule id="265815" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5038 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>