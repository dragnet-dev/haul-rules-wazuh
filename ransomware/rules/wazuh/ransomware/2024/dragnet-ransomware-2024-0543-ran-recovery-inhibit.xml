<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0543 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: df8e8789-1d7e-5741-8d87-3dd5247176b6 -->
  <rule id="982287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0543 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>