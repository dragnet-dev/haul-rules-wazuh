<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5595 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 82a1e8ae-d70a-5ba7-a511-afbd0f772a1b -->
  <rule id="415508" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5595 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>