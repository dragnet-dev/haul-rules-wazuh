<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4174 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 56751913-52aa-510b-afb4-f9c7e099690c -->
  <rule id="375191" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4174 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>