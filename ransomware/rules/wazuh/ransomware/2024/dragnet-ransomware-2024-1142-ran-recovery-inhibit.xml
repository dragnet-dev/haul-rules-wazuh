<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1142 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5a172082-cca7-59ce-b83c-3e841a05e40b -->
  <rule id="117208" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1142 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>