<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4886 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ed71e3ce-4e90-53d2-b3cd-0b39973dfc3d -->
  <rule id="303503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4886 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>