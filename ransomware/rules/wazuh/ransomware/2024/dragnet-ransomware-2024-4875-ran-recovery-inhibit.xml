<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4875 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 9910e630-fb5d-583b-86a5-75326ac0691c -->
  <rule id="785746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4875 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>