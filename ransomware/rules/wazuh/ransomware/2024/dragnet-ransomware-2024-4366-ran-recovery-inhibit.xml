<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4366 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a5a9d976-d027-50b0-bafd-43c6b8a0ce61 -->
  <rule id="105579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4366 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>