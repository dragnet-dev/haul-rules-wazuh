<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1821 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 867edee0-5dfd-54bc-8b3c-8c13398834c1 -->
  <rule id="955038" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1821 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>