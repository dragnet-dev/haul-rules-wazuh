<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4014 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: b4ce241b-279c-5f21-9eac-45377eddd326 -->
  <rule id="339024" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4014 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>