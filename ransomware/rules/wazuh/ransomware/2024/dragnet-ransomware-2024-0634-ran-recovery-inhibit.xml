<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0634 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 4dbad049-cd6f-5355-9871-2df9d76148d1 -->
  <rule id="583810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0634 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>