<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2146 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: ae790e83-1ea8-5fb0-b9bd-f64b66b1f6a2 -->
  <rule id="196654" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2146 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>