<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0380 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: 6df89bb2-83d9-5bfb-b67d-0ce14ce60f96 -->
  <rule id="215835" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0380 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>