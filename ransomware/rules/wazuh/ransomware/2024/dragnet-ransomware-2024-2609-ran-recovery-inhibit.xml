<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2609 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 5da54577-f72d-57a1-8df3-0c57f54ebc87 -->
  <rule id="698545" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2609 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>