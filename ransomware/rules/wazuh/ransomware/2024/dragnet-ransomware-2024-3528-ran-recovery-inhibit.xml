<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3528 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 587376f7-341e-5861-a77a-61112960242d -->
  <rule id="498031" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3528 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>