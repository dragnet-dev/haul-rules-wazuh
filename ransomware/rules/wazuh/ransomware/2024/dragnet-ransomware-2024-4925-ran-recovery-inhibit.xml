<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4925 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: bf0974e3-8c54-5159-af9f-76bced6a7a36 -->
  <rule id="210974" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4925 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>