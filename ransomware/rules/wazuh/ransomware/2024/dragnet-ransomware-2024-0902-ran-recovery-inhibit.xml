<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0902 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: f17358c1-5442-55ec-8acf-1f2cbd784efe -->
  <rule id="717358" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0902 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>