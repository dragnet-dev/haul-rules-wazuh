<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5594 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 23ceed69-4781-5b5d-b82b-53ddfb31659a -->
  <rule id="760301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5594 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>