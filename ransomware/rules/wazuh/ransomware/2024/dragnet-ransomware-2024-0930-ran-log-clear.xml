<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0930 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: ac06b3dd-93c9-51dd-896e-7ae1aecb6f47 -->
  <rule id="153073" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0930 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>