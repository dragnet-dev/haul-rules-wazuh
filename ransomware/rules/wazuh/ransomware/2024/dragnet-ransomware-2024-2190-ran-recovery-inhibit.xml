<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2190 — Recovery Inhibition (argonauts) | Status: experimental | Sigma ID: 0ef83d07-e4d3-5f5b-8af9-ea7f6c087600 -->
  <rule id="337410" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2190 — Recovery Inhibition (argonauts)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>