<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2760 — Event Log Clearing (termite) | Status: experimental | Sigma ID: 6cdaefde-7c12-5af4-8532-d0d9cab7fdc7 -->
  <rule id="933935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2760 — Event Log Clearing (termite)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>