<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4173 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5a602240-a32f-55c7-8407-2c0d502de281 -->
  <rule id="160224" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4173 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>