<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0140 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: b5613c12-26a8-506e-9474-af8e1a611b49 -->
  <rule id="149820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0140 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>