<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1148 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 345d979d-a7af-58d7-b82a-625e0d57f4c3 -->
  <rule id="233979" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1148 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>