<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2116 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 60c49ac8-29dc-54cf-b4cf-d4de6c339708 -->
  <rule id="755994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2116 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>