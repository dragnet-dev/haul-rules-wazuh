<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0046 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: cdedea7c-5e1c-5488-a24c-e30da3a0f653 -->
  <rule id="995786" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0046 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>