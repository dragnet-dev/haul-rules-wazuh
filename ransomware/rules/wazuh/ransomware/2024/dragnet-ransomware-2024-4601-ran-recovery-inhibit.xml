<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4601 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: f343b4f8-05fd-5410-9cfc-9e2a9c524d11 -->
  <rule id="754994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4601 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>