<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4725 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 61dd0568-6d3b-5ea6-bcf9-73fadbd9acf1 -->
  <rule id="783705" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4725 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>