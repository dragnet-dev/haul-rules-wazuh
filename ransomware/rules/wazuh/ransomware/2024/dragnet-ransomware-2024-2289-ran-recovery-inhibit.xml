<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2289 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 53886b77-9c8c-5a7c-8300-58657efc599c -->
  <rule id="621877" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2289 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>