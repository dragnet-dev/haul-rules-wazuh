<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5806 — Recovery Inhibition (akira) | Status: experimental | Sigma ID: 752a8ca7-85a2-50d3-9f82-034eedec6730 -->
  <rule id="226860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5806 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>