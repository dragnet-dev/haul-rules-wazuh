<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2072 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 3e334e97-6378-5484-b0a7-a47e09093a37 -->
  <rule id="173589" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2072 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>