<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4584 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6fe73437-ab74-57ad-9e76-6044caa4ab82 -->
  <rule id="990734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4584 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>