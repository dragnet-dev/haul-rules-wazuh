<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5544 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 16d4dcad-84b2-54a7-b1cf-2d27a46f5ffb -->
  <rule id="338154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5544 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>