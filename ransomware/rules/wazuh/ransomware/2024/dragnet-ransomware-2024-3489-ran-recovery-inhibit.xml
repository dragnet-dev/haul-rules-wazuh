<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3489 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: ff6c395b-c7b1-5c7e-ac45-221a18609a94 -->
  <rule id="590839" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3489 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>