<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0066 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: aab11fa8-6e36-535e-8c85-29b5e552c29a -->
  <rule id="869791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0066 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>