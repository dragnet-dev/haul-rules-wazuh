<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2841 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6a66cbc2-a06d-56c0-a444-576ca5a328ea -->
  <rule id="130699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2841 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>