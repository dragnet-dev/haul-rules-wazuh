<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1053 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 307d1dcc-903d-558e-8386-5cf42944f352 -->
  <rule id="108476" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1053 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>