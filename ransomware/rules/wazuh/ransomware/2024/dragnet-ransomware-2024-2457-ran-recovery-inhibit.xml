<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2457 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b98a9f4d-ced6-5e16-8575-d0a400c6cf0a -->
  <rule id="468639" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2457 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>