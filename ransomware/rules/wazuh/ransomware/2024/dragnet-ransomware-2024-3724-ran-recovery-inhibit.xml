<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3724 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 730d7657-4564-5486-8dd3-1f5c053ff5de -->
  <rule id="369376" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3724 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>