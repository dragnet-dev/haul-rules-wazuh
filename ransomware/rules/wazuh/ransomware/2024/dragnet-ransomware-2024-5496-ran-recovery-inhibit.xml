<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5496 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 0d6b964e-e0df-567c-9875-35ac3812f15d -->
  <rule id="487964" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5496 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
