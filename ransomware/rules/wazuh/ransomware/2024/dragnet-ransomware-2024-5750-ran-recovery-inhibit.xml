<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5750 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ff56c26a-2f59-5e42-ab21-fe3be103da21 -->
  <rule id="589082" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5750 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>