<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2988 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 3de69f21-19d3-5615-b9f9-ddd6dcb9f79e -->
  <rule id="785119" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2988 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>