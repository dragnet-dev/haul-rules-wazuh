<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4352 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c10d5277-ffb7-5979-aa67-62261c46b409 -->
  <rule id="237352" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4352 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>