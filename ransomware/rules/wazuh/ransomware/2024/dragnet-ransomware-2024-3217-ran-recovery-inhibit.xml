<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3217 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: dac2dad1-cab2-57b5-bbb3-df4ae73c700b -->
  <rule id="960730" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3217 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>