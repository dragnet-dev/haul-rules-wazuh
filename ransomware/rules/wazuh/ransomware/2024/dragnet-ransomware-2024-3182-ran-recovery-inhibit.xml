<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3182 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: e6d5410c-6e8a-5320-8c2b-9a5eba955aa9 -->
  <rule id="649541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3182 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>