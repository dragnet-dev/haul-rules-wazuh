<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1599 — Event Log Clearing (unsafe) | Status: deprecated | Sigma ID: 7edd5538-f220-5e9d-86b9-6d95ede5889a -->
  <rule id="647755" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1599 — Event Log Clearing (unsafe)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>