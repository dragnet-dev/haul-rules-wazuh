<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4011 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: 942c526f-6352-5309-ae42-92c77e2fd06f -->
  <rule id="708452" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4011 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>