<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4752 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7ffb0ec8-029a-55fd-a6e8-5c4655800ed6 -->
  <rule id="842094" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4752 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>