<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5991 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d759bf8e-3753-5af4-b264-c69f95c993b6 -->
  <rule id="922495" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5991 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
