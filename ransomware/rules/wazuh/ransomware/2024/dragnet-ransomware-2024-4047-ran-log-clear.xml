<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4047 — Event Log Clearing (ElDorado) | Status: deprecated | Sigma ID: f0d858bc-383c-500e-ba2d-aa31d8dc4061 -->
  <rule id="713858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4047 — Event Log Clearing (ElDorado)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>