<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0889 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: ff083d51-0a7b-524e-aea2-9bc73be79514 -->
  <rule id="581341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0889 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>