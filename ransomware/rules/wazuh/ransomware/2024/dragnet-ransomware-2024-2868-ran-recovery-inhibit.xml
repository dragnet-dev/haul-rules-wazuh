<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2868 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 3fb9cc6d-cd5b-5f42-8c33-f7424f79c223 -->
  <rule id="911148" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2868 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>