<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2281 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 19d8f8ed-9cb8-5b97-95bc-62d04fb8e1f2 -->
  <rule id="138222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2281 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>