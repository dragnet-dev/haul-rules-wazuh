<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4147 — Event Log Clearing (dAn0n) | Status: experimental | Sigma ID: 4cffe0c4-36b9-5aa5-94ca-5a75f2a6ac1f -->
  <rule id="553900" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4147 — Event Log Clearing (dAn0n)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>