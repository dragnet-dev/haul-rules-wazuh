<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0036 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 2944ac94-796c-5ccf-a411-0d1ac9f6c400 -->
  <rule id="438369" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0036 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>