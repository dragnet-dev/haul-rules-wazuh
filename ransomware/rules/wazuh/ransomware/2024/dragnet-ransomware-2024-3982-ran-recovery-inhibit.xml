<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3982 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5eed2803-5c29-5bab-af9a-82b817bb2b6c -->
  <rule id="730128" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3982 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>