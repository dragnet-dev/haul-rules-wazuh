<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0672 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 175d2f49-1c50-5134-b11b-045c88ca50f7 -->
  <rule id="101274" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0672 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>