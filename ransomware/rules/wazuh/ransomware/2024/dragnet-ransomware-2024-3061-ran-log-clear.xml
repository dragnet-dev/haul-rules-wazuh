<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3061 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 1e7cb1a3-8187-50d8-ae2b-43ca4b8c9a67 -->
  <rule id="107226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3061 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>