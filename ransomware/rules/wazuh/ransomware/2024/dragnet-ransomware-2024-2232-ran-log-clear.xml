<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2232 — Event Log Clearing (threeam) | Status: experimental | Sigma ID: af0d7648-7dd6-5a6d-b27a-cdf9ca1d6deb -->
  <rule id="201376" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2232 — Event Log Clearing (threeam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>