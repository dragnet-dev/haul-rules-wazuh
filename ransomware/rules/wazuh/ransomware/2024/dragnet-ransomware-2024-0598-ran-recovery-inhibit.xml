<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0598 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 7a66d8d5-6e2f-55f7-9783-c4ce005ca6fa -->
  <rule id="262698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0598 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>