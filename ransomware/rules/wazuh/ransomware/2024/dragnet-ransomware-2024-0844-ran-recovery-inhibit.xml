<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0844 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 3f5b2939-6dec-5dd4-a3d9-a8a3e4770822 -->
  <rule id="217129" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0844 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>