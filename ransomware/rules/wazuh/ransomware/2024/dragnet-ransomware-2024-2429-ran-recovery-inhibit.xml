<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2429 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ce607a79-0451-523b-afdf-dd84f40be92b -->
  <rule id="705722" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2429 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>