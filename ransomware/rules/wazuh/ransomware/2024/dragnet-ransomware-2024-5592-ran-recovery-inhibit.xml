<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5592 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 9fd322d0-02e5-5b44-8b06-0c1b955f254b -->
  <rule id="857322" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5592 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>