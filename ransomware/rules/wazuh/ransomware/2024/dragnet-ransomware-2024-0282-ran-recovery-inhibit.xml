<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0282 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 4f2efe25-e749-57ef-94aa-2567280bf5d5 -->
  <rule id="647870" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0282 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>