<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2378 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 0de110dd-5a0a-53ed-8680-1de2c58a8b15 -->
  <rule id="953773" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2378 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>