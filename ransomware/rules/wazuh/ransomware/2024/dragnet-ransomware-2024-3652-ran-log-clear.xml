<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3652 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: b4d2a0b8-edd9-5da9-8127-95bffb5183f2 -->
  <rule id="339620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3652 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>