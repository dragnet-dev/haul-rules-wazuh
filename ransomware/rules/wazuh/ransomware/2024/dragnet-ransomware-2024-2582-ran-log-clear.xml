<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2582 — Event Log Clearing (arcusmedia) | Status: experimental | Sigma ID: af1e504f-ae14-5e71-bf5b-ac3d70a1a811 -->
  <rule id="203050" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2582 — Event Log Clearing (arcusmedia)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>