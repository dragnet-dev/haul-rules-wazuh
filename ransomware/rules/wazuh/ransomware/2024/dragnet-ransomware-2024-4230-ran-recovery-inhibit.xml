<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4230 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: d4baade2-4ac3-5634-8485-38a013028ce1 -->
  <rule id="829613" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4230 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>