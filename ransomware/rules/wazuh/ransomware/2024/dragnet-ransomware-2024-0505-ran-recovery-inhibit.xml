<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0505 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 26398831-47f8-57cd-8784-4337688c1157 -->
  <rule id="939883" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0505 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>