<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2209 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f0edadf4-5de5-5be2-89b3-0987b5820cc8 -->
  <rule id="991245" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2209 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>