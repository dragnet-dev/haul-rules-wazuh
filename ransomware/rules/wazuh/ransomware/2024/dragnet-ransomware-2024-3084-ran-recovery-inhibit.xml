<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3084 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 2f420bd3-6fcd-5d6e-8180-d9d40e6d4b01 -->
  <rule id="539709" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3084 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>