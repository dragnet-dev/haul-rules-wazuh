<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4363 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 88498275-6cb2-56cd-9a93-5037ef03ddc5 -->
  <rule id="849827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4363 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>