<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0065 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8a5c9b97-3f67-5a9b-9914-d17d6d3c7459 -->
  <rule id="947675" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0065 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>