<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5764 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: a6846899-d148-5c05-8dc9-6ffc480fe19d -->
  <rule id="268468" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5764 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>