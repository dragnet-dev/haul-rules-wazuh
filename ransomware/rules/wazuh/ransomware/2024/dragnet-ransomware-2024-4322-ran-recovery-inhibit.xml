<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4322 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 65d849d8-4adc-5dd3-8a86-ed354b41adb7 -->
  <rule id="253849" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4322 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>