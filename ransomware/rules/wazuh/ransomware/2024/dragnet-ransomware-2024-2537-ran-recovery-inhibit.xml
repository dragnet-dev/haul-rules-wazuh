<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2537 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: e8dea83b-8c87-5566-9465-41b6d0ae4ffd -->
  <rule id="797708" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2537 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>