<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1219 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 845898ad-c2e8-55da-b242-968e10820181 -->
  <rule id="134378" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1219 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>