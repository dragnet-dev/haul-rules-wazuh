<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5260 — Recovery Inhibition (orca) | Status: experimental | Sigma ID: 68e7efd8-e516-59bd-88fa-06f68379b715 -->
  <rule id="223151" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5260 — Recovery Inhibition (orca)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>