<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3880 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: ce463536-8f60-53f0-b4ed-75cadd879ee2 -->
  <rule id="364635" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3880 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>