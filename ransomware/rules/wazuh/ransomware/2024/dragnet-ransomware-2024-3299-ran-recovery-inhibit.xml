<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3299 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 81bdfc5c-3017-574b-a253-707594fced42 -->
  <rule id="957052" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3299 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>