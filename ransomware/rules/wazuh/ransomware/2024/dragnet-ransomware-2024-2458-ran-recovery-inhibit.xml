<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2458 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 577f7fe2-dfa3-5a79-952e-27eb3f8d7b48 -->
  <rule id="679647" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2458 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>