<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1933 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: c24ef195-df43-5d8f-9f0d-2959071722f7 -->
  <rule id="535831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1933 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>