<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2794 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8a31b800-c095-5a76-9f3f-d0a69ec78d0c -->
  <rule id="513078" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2794 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>