<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2771 — Recovery Inhibition (bluebox) | Status: experimental | Sigma ID: 1172ed5f-84e4-5f5d-9b79-135ab7e4d063 -->
  <rule id="402695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2771 — Recovery Inhibition (bluebox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>