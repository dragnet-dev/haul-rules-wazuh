<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0944 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 5fad790a-d28e-544b-8b59-18780e0c3bfe -->
  <rule id="749379" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0944 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>