<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6037 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6ad2ecce-b1e1-5161-986c-25be7ad728b8 -->
  <rule id="875788" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6037 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>