<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4089 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: f6c704bc-e301-532c-8c37-0aa40b14a3f3 -->
  <rule id="808704" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4089 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>