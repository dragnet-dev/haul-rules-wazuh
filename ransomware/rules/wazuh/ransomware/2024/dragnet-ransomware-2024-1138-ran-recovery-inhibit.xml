<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1138 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 002dcc65-d822-5f34-bff7-54bd349757bd -->
  <rule id="372465" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1138 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>