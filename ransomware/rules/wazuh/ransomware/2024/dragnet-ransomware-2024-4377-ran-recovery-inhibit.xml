<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4377 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 57121405-2dd3-51f8-9aec-52d3bce26303 -->
  <rule id="412140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4377 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>