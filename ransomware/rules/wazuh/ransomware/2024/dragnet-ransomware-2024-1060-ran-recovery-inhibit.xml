<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1060 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: d845c30f-8864-5e98-b5d8-9a125a8ff935 -->
  <rule id="515323" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1060 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>