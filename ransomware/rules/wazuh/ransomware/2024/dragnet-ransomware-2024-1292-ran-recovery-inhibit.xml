<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1292 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: aae974bc-f040-5964-b029-c90dd947311a -->
  <rule id="134974" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1292 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>