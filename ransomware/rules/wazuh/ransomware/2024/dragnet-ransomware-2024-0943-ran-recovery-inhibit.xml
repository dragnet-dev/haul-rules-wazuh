<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0943 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: f9209b6c-ae3a-5f34-90da-6f52acae8d12 -->
  <rule id="847355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0943 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>