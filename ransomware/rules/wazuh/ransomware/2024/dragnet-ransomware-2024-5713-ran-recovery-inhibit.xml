<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5713 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: bafd9105-af3e-5e1a-bfe9-0eeb5a0f34c4 -->
  <rule id="386991" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5713 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>