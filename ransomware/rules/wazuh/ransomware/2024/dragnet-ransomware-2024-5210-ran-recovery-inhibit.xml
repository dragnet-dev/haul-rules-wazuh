<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5210 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 294bdb93-74d2-59d0-89af-5dfdecc886d0 -->
  <rule id="407259" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5210 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>