<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2300 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: f1259640-879f-585a-93b8-75ec652de13a -->
  <rule id="712596" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2300 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>