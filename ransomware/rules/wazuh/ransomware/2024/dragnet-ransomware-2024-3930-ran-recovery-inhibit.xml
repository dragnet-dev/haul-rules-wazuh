<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3930 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 4f6b8a02-a7cf-5ba2-bb67-06f187feb392 -->
  <rule id="339658" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3930 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>