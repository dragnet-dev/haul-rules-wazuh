<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3648 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: 92bb92c5-9f8f-5a9b-a0c2-292cb08de6e2 -->
  <rule id="673992" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3648 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>