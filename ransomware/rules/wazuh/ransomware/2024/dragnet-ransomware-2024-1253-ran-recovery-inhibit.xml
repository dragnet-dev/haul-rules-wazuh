<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1253 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 4a42c22a-69ad-5996-8f65-72bf920d986d -->
  <rule id="390842" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1253 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>