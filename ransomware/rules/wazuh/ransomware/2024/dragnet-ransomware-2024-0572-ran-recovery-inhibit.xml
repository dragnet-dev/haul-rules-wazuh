<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0572 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 177a9b15-6595-5ba9-ac27-1f8e2650771f -->
  <rule id="148751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0572 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>