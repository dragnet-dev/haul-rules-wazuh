<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0892 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4ccba08f-5d66-5e07-8b7c-67f8c5143614 -->
  <rule id="545540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0892 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>