<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0062 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: f66b1c93-323a-546c-bb00-995f52659b66 -->
  <rule id="510748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0062 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>