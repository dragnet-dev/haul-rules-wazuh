<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5273 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 10e857b5-1e21-5ac8-95fa-15306c144df9 -->
  <rule id="197723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5273 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>