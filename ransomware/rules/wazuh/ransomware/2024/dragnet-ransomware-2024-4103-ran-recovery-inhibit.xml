<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4103 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 48c5cd25-ca17-57a1-8b13-f682a123968d -->
  <rule id="298285" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4103 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>