<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1173 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1306d057-0d35-5c2f-ba75-95bd64bab58e -->
  <rule id="390905" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1173 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>