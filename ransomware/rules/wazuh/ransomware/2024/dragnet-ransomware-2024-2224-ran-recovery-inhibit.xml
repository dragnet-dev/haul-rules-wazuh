<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2224 — Recovery Inhibition (hellcat) | Status: deprecated | Sigma ID: 70303ebc-7b9b-5bb2-9612-2615e6db3515 -->
  <rule id="324862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2224 — Recovery Inhibition (hellcat)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>