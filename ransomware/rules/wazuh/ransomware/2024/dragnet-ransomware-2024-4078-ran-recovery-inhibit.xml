<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4078 — Recovery Inhibition (madliberator) | Status: experimental | Sigma ID: 9de8d6df-0767-595c-9f34-985dde7af2d9 -->
  <rule id="543016" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4078 — Recovery Inhibition (madliberator)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>