<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1474 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 53bfed48-aece-546b-bc72-964e74cfe6cc -->
  <rule id="922541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1474 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>