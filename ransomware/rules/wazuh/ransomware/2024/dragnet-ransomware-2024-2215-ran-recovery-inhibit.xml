<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2215 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d424ac75-f85f-5f5f-a333-4cebf7173ac1 -->
  <rule id="836716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2215 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>