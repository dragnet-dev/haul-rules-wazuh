<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4225 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: b8102040-ac9a-5e3d-b086-295f2057e26d -->
  <rule id="381020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4225 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>