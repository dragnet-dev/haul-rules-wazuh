<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5085 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 60db375e-523f-5c01-8dbe-14e7250d66f1 -->
  <rule id="757937" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5085 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>