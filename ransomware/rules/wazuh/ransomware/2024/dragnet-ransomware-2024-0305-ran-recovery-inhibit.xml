<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0305 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: 1756fd95-6d32-5978-86ea-26cf204bb7c2 -->
  <rule id="997899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0305 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>