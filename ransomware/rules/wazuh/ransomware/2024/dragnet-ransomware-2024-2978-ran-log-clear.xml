<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2978 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: 0ca12ce0-2b1b-5f48-8c04-0e8fdf4e08f1 -->
  <rule id="774478" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2978 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>