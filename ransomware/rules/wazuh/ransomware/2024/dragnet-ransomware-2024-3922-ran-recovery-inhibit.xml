<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3922 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ca5d3c92-e278-50eb-8f68-46d586ccfa80 -->
  <rule id="786140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3922 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>