<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1710 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e7f5cdcf-a8f6-5de4-831f-e4f0d0575498 -->
  <rule id="761005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1710 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>