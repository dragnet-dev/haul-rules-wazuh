<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5795 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: addc5809-7db0-565a-abd8-6de696e0f0ac -->
  <rule id="950858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5795 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>