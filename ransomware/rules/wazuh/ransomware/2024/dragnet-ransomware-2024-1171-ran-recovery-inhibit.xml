<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1171 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f523d4d8-41b0-58b4-8a66-d63e5341e93d -->
  <rule id="783814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1171 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>