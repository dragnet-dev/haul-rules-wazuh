<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1559 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 99d3114a-ebce-56fc-8ca5-bf667e528485 -->
  <rule id="797311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1559 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>