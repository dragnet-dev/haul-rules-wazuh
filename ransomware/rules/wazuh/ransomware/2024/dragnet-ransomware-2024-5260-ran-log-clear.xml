<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5260 — Event Log Clearing (orca) | Status: experimental | Sigma ID: 49073668-6121-5707-970e-2656c078d738 -->
  <rule id="507366" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5260 — Event Log Clearing (orca)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>