<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1803 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 1f3ea485-3a8f-5a46-9e1f-95c6cd6ff464 -->
  <rule id="936248" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1803 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>