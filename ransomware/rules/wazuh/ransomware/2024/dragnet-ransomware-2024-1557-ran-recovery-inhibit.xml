<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1557 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: a37ad6f5-1ab0-5bb3-abe7-41ac03318bc8 -->
  <rule id="956456" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1557 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>