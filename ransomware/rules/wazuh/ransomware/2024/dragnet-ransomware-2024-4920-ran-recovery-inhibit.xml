<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4920 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 7344b472-4167-57e3-a05a-45c94a8815bd -->
  <rule id="375154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4920 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>