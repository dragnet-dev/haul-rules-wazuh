<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3270 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 380abe62-b803-55ae-bfd3-a14ffc395552 -->
  <rule id="759230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3270 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>