<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3623 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: e48991e8-f3c9-5965-82eb-3bb033ab14cc -->
  <rule id="648991" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3623 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>