<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4144 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 64aac7ad-7687-5e79-ba8a-310a9b212249 -->
  <rule id="948767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4144 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>