<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4525 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 9607e5bc-d9ae-599c-8c13-29a7d1d57835 -->
  <rule id="737265" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4525 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>