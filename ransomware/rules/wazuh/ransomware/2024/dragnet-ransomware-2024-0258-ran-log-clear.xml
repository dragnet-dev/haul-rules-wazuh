<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0258 — Event Log Clearing (hunters) | Status: experimental | Sigma ID: 6d75b5fa-0ff7-5eab-a4a9-ac376591f5ca -->
  <rule id="956115" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0258 — Event Log Clearing (hunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>