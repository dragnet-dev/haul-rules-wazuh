<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5754 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f7f9e906-25d1-5b8e-a29f-934902428c95 -->
  <rule id="544789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5754 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>