<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1522 — Event Log Clearing (threeam) | Status: experimental | Sigma ID: bd857418-b9ab-597d-9e96-48419e6d248f -->
  <rule id="198574" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1522 — Event Log Clearing (threeam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>