<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1748 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: abccd623-2e04-5a1f-b961-a3da69386f2a -->
  <rule id="836936" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1748 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>