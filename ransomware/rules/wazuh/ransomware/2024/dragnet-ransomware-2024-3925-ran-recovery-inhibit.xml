<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3925 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 111fd6be-aa92-527b-b021-a6c0da7b9720 -->
  <rule id="187147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3925 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>