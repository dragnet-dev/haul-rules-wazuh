<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0710 — Event Log Clearing (safepay) | Status: deprecated | Sigma ID: 030ed3eb-b94b-53a2-b9ae-cf5ba2ce969f -->
  <rule id="466782" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0710 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>