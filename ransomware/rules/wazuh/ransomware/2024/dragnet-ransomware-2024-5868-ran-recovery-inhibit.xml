<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5868 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f89a4145-b8af-5576-88f0-7948ed735ce4 -->
  <rule id="843441" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5868 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>