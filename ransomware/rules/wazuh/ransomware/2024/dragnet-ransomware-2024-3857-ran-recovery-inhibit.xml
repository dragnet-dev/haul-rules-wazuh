<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3857 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 04326e57-b80b-5d6a-85e2-b61479defae8 -->
  <rule id="723057" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3857 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>