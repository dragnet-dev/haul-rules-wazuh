<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4991 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 2d0dc4be-d179-5eb2-b7bf-f47a1ad26cd3 -->
  <rule id="354204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4991 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>