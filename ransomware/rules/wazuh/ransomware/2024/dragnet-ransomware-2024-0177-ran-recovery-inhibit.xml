<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0177 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 65892f38-b5aa-51ec-8510-8b2cf62e6b99 -->
  <rule id="254287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0177 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>