<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2893 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: a2d84846-3cda-5a0e-a3ff-c70cd95052d7 -->
  <rule id="845848" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2893 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
