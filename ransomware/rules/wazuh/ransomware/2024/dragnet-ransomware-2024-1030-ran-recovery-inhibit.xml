<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1030 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: dfd6ee8e-3f4f-511d-8c19-b230b2a9f424 -->
  <rule id="269134" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1030 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>