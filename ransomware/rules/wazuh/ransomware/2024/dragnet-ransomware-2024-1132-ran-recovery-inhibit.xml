<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1132 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ccc0d8bc-40d0-594e-b69b-329c0378303e -->
  <rule id="841738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1132 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>