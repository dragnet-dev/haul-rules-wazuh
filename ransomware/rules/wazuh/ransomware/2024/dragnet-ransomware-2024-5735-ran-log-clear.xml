<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5735 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: d6a36de5-8d4f-5fde-baaa-90ec1de2f002 -->
  <rule id="898189" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5735 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>