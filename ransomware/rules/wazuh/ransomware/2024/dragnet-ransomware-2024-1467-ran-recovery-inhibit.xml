<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1467 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 70f76a7e-427f-5781-a604-47b9e899f90f -->
  <rule id="117226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1467 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>