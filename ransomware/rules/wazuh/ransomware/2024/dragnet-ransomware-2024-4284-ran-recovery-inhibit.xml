<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4284 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 94628b47-d356-5893-a9f1-f589157eb3a8 -->
  <rule id="714059" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4284 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>