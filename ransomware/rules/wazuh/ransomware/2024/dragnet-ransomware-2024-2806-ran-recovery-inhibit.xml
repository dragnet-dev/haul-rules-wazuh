<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2806 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: cf7eaa2f-7cb6-5d29-a8b6-7616a62d6772 -->
  <rule id="511146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2806 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>