<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5132 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 600a687c-8a28-5762-996c-77b7ca93ba4d -->
  <rule id="710687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5132 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>