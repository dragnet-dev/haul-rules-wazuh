<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1969 — Recovery Inhibition (play) | Status: experimental | Sigma ID: aef3cf4b-c043-557c-a8c6-9bc06cd721a9 -->
  <rule id="966415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1969 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>