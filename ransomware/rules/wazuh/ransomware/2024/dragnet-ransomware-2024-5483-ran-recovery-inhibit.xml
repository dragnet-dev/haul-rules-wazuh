<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5483 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e6266b2c-f6a1-5954-bd17-6d1b224fe90a -->
  <rule id="640267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5483 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>