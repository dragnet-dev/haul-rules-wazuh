<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5575 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 31c81612-0f18-5556-a955-7e50be39a06c -->
  <rule id="688161" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5575 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>