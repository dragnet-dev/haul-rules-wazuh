<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4869 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: ae2bd91d-f624-504a-b42d-5530d4b480ae -->
  <rule id="961419" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4869 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>