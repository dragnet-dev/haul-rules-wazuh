<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5279 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 739941f5-acbc-5c11-9b7f-fa32c07f6129 -->
  <rule id="239071" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5279 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>