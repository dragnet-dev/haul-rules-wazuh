<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0303 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 80008cec-ec41-552c-bec3-8e6233739257 -->
  <rule id="480140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0303 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>