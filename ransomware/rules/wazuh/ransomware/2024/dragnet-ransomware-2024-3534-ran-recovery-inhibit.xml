<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3534 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 605ec84f-511d-55f8-b27a-8d6ae7d521f2 -->
  <rule id="751168" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3534 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>