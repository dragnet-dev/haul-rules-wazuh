<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2181 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 2ee46c5b-6c32-5bf7-bb46-f66409f291d8 -->
  <rule id="400748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2181 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>