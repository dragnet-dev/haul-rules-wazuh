<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5272 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 0b4ddec5-fba4-5e08-8633-f2f9cdd43cfe -->
  <rule id="427916" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5272 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>