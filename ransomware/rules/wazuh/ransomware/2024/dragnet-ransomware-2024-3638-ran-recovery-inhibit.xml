<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3638 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 217aac7b-bbb3-5132-a29d-31860d8e87cc -->
  <rule id="915647" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3638 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>