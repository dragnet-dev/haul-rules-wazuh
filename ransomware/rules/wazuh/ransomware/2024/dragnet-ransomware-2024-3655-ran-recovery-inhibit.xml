<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3655 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: aaa001a2-2de4-5cc5-82ee-e8096431f387 -->
  <rule id="130001" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3655 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>