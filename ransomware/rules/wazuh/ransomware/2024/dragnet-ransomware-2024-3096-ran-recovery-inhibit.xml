<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3096 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e798b63c-5e64-5186-9af8-022695f2aa2c -->
  <rule id="667796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3096 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>