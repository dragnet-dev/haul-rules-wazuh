<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2820 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: a80e4785-c353-56bf-9997-c96f5d4d9a2a -->
  <rule id="929447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2820 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>