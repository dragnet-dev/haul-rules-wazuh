<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3271 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2c1f584e-095e-5640-95f7-83426b74edf6 -->
  <rule id="871584" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3271 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>