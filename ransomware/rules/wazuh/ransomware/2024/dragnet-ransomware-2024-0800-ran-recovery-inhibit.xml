<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0800 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: a5fd8ba8-1067-55be-8af5-084158c334f5 -->
  <rule id="841419" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0800 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>