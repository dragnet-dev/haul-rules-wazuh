<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0322 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 4c89cd64-f03f-5de0-8e3e-19e1c75dfaee -->
  <rule id="268589" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0322 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>