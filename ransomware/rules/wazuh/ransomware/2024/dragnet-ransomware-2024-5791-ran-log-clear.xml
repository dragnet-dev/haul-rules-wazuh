<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5791 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 9a5bac5d-b8f1-5f3a-b980-94c6e62ad8e5 -->
  <rule id="131308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5791 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>