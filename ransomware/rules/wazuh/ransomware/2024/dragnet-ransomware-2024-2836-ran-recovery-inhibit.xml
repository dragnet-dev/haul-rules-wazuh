<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2836 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: e2af9d4a-2f12-545f-8d3e-1221c9577c5f -->
  <rule id="544477" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2836 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>