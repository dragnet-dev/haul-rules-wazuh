<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0034 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 2954d3b4-de00-566a-b5c3-034ee5aca21d -->
  <rule id="464379" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0034 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>