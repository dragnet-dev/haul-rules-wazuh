<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5310 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: a9bc6b07-d2ab-57c7-a04c-34973ce74098 -->
  <rule id="994827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5310 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>