<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4251 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 4f55e5a4-d7dd-5857-afb3-07ece79521ce -->
  <rule id="472945" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4251 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>