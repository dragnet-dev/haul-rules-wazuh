<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3786 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: 3df602f4-97e2-5f39-bb07-f87b2ef5b9b6 -->
  <rule id="665647" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3786 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>