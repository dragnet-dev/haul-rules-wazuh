<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3185 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 906de743-5110-58f4-83ea-30740b4dbcb0 -->
  <rule id="621587" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3185 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>