<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3836 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f040e0e4-4650-5e1c-a217-933821bf7474 -->
  <rule id="706540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3836 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>