<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5265 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 3678d7d6-6c9c-5db3-a53a-7f7f4e0a4e73 -->
  <rule id="517885" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5265 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>