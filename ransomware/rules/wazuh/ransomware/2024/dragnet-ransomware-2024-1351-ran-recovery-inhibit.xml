<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1351 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: 68ed396c-df34-57d0-903e-e3167a471bd0 -->
  <rule id="964539" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1351 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>