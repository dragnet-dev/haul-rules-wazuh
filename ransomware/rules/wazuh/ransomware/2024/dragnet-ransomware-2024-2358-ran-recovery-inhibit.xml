<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2358 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: ddb5e433-0d1d-5057-96fe-ba6802fe6562 -->
  <rule id="376144" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2358 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>