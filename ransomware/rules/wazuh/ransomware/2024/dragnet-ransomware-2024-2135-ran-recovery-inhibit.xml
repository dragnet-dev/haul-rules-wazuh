<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2135 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7180161d-9e02-52b2-9c63-b4cc396ba4c2 -->
  <rule id="980161" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2135 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>