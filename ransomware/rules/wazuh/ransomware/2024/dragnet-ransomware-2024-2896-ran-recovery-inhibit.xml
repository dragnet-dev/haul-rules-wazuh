<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2896 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 0e34e263-fa8b-5413-9e15-821ecd815523 -->
  <rule id="595826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2896 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>