<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4524 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 53ea88e5-01c4-5349-a94a-145b6022962b -->
  <rule id="580288" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4524 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>