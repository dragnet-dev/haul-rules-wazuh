<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5242 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 5d782105-e3f7-536a-a04f-0c9b60933459 -->
  <rule id="478210" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5242 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>