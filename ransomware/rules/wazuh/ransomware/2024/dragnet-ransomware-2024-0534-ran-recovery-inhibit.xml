<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0534 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a60aa9c8-a225-59e7-bc9f-1f5b03418326 -->
  <rule id="115309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0534 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>