<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2729 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 6fdc6356-4694-5a74-8af7-c6c940d76f90 -->
  <rule id="263663" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2729 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>