<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5698 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 5d403d1b-603b-59c4-ab28-0b7032dd38ed -->
  <rule id="694461" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5698 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>