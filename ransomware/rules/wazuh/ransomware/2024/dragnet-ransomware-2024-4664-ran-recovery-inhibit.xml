<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4664 — Recovery Inhibition (ransomcortex) | Status: experimental | Sigma ID: 87abc9c2-b717-5fba-97d2-646d936f8f8f -->
  <rule id="991009" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4664 — Recovery Inhibition (ransomcortex)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
