<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0965 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 26751692-da65-56d5-837f-2fa7509a2969 -->
  <rule id="975169" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0965 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>