<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5063 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 0d9d9bbe-df55-5f30-a2a7-845538edc670 -->
  <rule id="429211" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5063 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>