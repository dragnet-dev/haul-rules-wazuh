<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2505 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: f1473232-c869-5792-a465-e3c7ef9bf7a0 -->
  <rule id="714732" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2505 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>