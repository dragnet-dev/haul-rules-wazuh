<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2103 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 47b7615b-ec08-5471-bc16-7dd3bee07d9f -->
  <rule id="537615" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2103 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>