<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1869 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 687fe538-9bb1-5347-b9cf-1e8e977f84b2 -->
  <rule id="961265" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1869 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>