<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0316 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: f0e9d9ea-13eb-5b21-8b35-f69190ddabf9 -->
  <rule id="363979" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0316 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>