<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3375 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3a8140e8-6f30-597e-b74c-de9e72bc2bc6 -->
  <rule id="510254" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3375 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>