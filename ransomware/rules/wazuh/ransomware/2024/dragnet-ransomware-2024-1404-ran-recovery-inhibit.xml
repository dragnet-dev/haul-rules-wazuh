<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1404 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: dd29e366-0e12-541d-9e53-2bd6917ac9a4 -->
  <rule id="940783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1404 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>