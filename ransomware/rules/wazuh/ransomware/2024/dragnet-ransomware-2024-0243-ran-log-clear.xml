<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0243 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 3a4d10d2-9ade-5a0b-ae3e-8ee4a0c56275 -->
  <rule id="671373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0243 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>