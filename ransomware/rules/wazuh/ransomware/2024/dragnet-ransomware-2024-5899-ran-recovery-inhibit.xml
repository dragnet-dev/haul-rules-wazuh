<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5899 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5834c67a-aa51-5c85-8645-54bbb9a82e45 -->
  <rule id="435667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5899 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>