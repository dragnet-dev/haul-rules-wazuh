<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4094 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2c0ca144-90df-58c1-b71e-2eb765ddc112 -->
  <rule id="328421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4094 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
