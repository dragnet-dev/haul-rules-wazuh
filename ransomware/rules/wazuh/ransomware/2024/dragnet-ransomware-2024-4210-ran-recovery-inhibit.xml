<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4210 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f39448c6-0c88-5731-b19e-97dd4d85c3d2 -->
  <rule id="739448" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4210 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>