<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5005 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 1e74af04-bb23-5f4e-bb27-4481b88acd44 -->
  <rule id="771190" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5005 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>