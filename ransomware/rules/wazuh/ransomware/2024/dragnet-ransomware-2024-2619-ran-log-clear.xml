<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2619 — Event Log Clearing (abyss) | Status: deprecated | Sigma ID: e012908e-c0f5-5eb7-a9b7-1aa38b6fe9f8 -->
  <rule id="601290" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2619 — Event Log Clearing (abyss)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>