<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2862 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 777cfe5b-c611-5cd9-beec-573b5a537cda -->
  <rule id="585918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2862 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>