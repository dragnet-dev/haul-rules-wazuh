<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3298 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 06ae7390-d208-56c6-ac8e-13084390d8e7 -->
  <rule id="910739" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3298 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>