<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3357 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5296671c-1821-564a-a5c1-18f21796238b -->
  <rule id="896671" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3357 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>