<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4818 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: c0c2deaa-35db-5f54-8ef2-1088b67a39a0 -->
  <rule id="546654" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4818 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>