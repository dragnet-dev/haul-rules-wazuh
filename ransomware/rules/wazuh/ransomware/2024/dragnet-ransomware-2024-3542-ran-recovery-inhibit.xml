<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3542 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: a881ee09-b534-535a-b61d-8555e2656dbe -->
  <rule id="185774" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3542 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>