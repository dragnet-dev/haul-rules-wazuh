<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1806 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e721ac3c-326a-5edc-9fc5-9ac99a9a45c9 -->
  <rule id="268748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1806 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>