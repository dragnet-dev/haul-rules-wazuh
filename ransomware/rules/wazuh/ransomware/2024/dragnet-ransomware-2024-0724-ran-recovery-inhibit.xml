<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0724 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0e749352-44ae-576a-b80e-40eb040c23c0 -->
  <rule id="674935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0724 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
