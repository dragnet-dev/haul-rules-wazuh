<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4243 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 6ce7678b-010a-5a66-92ee-aef5994289cc -->
  <rule id="942767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4243 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>