<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2055 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 2bd668b9-0164-5cfa-b5f3-8980e14f8c4b -->
  <rule id="526699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2055 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>