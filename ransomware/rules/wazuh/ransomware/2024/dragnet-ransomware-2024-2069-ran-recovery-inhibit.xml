<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2069 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c351d6f3-a2d8-536b-baf4-b75dfeeee137 -->
  <rule id="276296" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2069 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>