<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1167 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 8e3ef21d-ddf4-534f-96a2-89f45c965526 -->
  <rule id="145272" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1167 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>