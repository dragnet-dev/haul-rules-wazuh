<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5784 — Event Log Clearing (ElDorado) | Status: deprecated | Sigma ID: d1d8189e-1b38-59ee-b59d-aa88fc79b540 -->
  <rule id="409818" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5784 — Event Log Clearing (ElDorado)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>