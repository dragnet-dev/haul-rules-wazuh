<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4008 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 0e431932-f069-5db6-905b-dc5dfc086e33 -->
  <rule id="643193" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4008 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>