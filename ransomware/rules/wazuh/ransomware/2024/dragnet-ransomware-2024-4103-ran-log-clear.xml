<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4103 — Event Log Clearing (hunters) | Status: experimental | Sigma ID: be12b262-2c4a-5f45-8000-6ead1e881f95 -->
  <rule id="442032" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4103 — Event Log Clearing (hunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>