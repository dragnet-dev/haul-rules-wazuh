<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5589 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: 33e7cc64-5e3b-5921-b72d-633863ab362f -->
  <rule id="589516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5589 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>