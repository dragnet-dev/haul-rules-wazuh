<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3580 — Event Log Clearing (cloak) | Status: deprecated | Sigma ID: fa10a518-7d47-5ef2-8719-9e7ded2ae9f6 -->
  <rule id="501705" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3580 — Event Log Clearing (cloak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>