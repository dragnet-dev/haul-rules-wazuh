<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3906 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: e36beec7-7c07-52af-9486-8c71ec98a3e2 -->
  <rule id="584910" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3906 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>