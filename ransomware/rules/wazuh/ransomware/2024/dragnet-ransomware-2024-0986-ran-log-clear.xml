<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0986 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 8cfe6da6-8dc5-5b97-b2b9-0009dff494e9 -->
  <rule id="475149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0986 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>