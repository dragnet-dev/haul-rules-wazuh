<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1061 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 0c6a828a-6a2a-5639-9ea3-64efaaa174e0 -->
  <rule id="326828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1061 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>