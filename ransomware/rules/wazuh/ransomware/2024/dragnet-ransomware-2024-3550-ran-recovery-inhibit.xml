<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3550 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 3f716bc4-50d0-5139-a536-81139c5b351d -->
  <rule id="219467" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3550 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>