<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2975 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c232ad6a-0bf3-536d-b282-905ddedfd17c -->
  <rule id="531565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2975 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>