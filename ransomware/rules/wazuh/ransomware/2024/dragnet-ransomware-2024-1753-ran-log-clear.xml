<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1753 — Event Log Clearing (RunSomeWares) | Status: experimental | Sigma ID: 62c246f0-3f1e-59b2-8f6f-0dd8e7f66d89 -->
  <rule id="204246" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1753 — Event Log Clearing (RunSomeWares)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>