<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3920 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 44afa24d-d0b5-5c49-8d68-a26bdf9beaa9 -->
  <rule id="130342" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3920 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>