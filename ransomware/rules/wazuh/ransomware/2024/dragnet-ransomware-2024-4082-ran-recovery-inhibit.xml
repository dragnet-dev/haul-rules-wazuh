<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4082 — Recovery Inhibition (madliberator) | Status: experimental | Sigma ID: 5af9e4b4-9140-5628-b2bd-ed8e85c42d23 -->
  <rule id="629584" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4082 — Recovery Inhibition (madliberator)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>