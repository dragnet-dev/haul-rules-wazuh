<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0506 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 122016bf-c88a-5486-aaca-7b6039e967e0 -->
  <rule id="252267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0506 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>