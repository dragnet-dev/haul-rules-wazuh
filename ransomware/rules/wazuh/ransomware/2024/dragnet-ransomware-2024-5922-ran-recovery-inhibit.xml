<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5922 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 15699fb3-49bb-5cc5-a10c-108a6bc271d2 -->
  <rule id="519195" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5922 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>