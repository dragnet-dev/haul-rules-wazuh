<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4438 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: 50dc98e5-3969-5fb1-87e3-9756ada3e6cc -->
  <rule id="502098" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4438 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>