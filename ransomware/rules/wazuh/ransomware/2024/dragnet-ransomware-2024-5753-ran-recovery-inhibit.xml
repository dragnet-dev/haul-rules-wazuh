<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5753 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c94f15d8-c02c-556a-a7a6-31959b4fa88c -->
  <rule id="371915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5753 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>