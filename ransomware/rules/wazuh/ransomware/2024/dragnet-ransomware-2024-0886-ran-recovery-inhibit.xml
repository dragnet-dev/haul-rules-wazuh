<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0886 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: dc47b4a7-b40e-5a9e-991d-43bdca78a99c -->
  <rule id="927634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0886 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>