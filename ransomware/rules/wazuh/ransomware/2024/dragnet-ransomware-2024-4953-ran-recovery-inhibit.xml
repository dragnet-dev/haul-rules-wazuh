<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4953 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 32a70825-20a8-532c-a692-bc7872acf547 -->
  <rule id="827082" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4953 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>