<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1763 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: f1ba0248-8b79-5dd6-95bf-674651047bde -->
  <rule id="384202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1763 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>