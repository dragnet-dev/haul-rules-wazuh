<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3360 — Recovery Inhibition (argonauts) | Status: experimental | Sigma ID: 183bed08-1460-56c8-a66b-5e96888d429e -->
  <rule id="426210" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3360 — Recovery Inhibition (argonauts)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>