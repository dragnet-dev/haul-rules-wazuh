<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6021 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3bbe6288-d054-5977-b70e-6575c2ef0184 -->
  <rule id="729462" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6021 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>