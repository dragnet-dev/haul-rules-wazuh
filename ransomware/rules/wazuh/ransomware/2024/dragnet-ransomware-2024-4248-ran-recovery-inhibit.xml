<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4248 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 2698668d-c2a3-5720-913b-8f5341285121 -->
  <rule id="998668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4248 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>