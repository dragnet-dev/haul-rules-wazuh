<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2170 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: 67566910-c8a1-53df-83ef-671282d3721d -->
  <rule id="556691" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2170 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>