<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2534 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: b4cf9a9f-6c81-5e2c-9fe7-dd3e08c8493b -->
  <rule id="302714" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2534 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>