<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5522 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 4de71b24-2ea8-51d4-bb25-f6e518d3bc11 -->
  <rule id="294747" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5522 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>