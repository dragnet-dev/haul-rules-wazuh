<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4783 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 8c462d38-4b32-56bf-92e9-d4dc5da0ea1a -->
  <rule id="547405" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4783 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>