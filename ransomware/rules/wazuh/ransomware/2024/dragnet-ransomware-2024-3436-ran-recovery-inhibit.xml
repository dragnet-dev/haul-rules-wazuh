<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3436 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 51201964-227c-54bc-a56f-946e3cdc54fb -->
  <rule id="720196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3436 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>