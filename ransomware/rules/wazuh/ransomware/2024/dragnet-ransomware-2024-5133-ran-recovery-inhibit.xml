<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5133 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e3c879d1-177a-57cd-8d22-9ccdcaeb63e8 -->
  <rule id="600879" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5133 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>