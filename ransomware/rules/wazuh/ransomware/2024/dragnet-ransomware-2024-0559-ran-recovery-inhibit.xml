<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0559 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ad001243-44f4-537b-a69f-3b2bb731fc7f -->
  <rule id="930012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0559 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>