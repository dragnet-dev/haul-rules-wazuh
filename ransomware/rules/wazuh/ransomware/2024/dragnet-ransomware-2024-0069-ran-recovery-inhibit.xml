<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0069 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 117cd74d-da00-5da6-a739-6565dc3e0035 -->
  <rule id="415774" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0069 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>