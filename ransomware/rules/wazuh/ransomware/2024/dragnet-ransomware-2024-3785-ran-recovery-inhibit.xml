<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3785 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f2917974-a723-5d07-81da-6f9f770a41f7 -->
  <rule id="729179" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3785 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>