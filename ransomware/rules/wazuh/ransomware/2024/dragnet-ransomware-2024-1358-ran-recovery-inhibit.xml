<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1358 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2083dd77-e845-5b91-8533-2559a5a5e9a8 -->
  <rule id="934697" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1358 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>