<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0788 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 1926ee63-bc10-54af-b929-f26ea0988c49 -->
  <rule id="532946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0788 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>