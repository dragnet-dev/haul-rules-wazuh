<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1538 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 912ed0bd-7f48-57b2-aab7-6c0f8c024650 -->
  <rule id="637090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1538 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>