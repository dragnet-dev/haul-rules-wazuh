<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5975 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f0690b39-39c7-5b64-b819-ce03d29eedda -->
  <rule id="711051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5975 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>