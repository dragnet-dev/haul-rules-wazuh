<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2983 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: cf7c78d2-9f8f-5ff1-80de-8ef00c14b2a9 -->
  <rule id="724478" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2983 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>