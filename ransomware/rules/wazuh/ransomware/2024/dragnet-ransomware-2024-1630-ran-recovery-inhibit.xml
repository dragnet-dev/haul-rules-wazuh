<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1630 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 9d3d69db-0a7c-5774-b3de-557d1035d152 -->
  <rule id="818169" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1630 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>