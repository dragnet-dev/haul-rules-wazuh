<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2551 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 5de15d22-8b63-5a43-96bf-dd3c0cde2e61 -->
  <rule id="703453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2551 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>