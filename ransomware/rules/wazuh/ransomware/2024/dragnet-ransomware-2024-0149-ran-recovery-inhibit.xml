<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0149 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: f8b1eeea-cf54-52c2-9ff8-2f1c0db29346 -->
  <rule id="300334" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0149 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>