<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3907 — Recovery Inhibition (trisec) | Status: experimental | Sigma ID: 7ea0d1c6-dbd8-5101-bc6a-284e6a0acdec -->
  <rule id="641731" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3907 — Recovery Inhibition (trisec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>