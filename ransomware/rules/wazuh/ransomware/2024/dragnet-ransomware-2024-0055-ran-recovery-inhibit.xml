<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0055 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 5075efd6-1d0f-5a8d-ba1f-5d4b6ddccc19 -->
  <rule id="499439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0055 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>