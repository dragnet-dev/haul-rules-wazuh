<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1069 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3b2be0fc-126d-52c6-bcca-d31581557c9d -->
  <rule id="717420" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1069 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>