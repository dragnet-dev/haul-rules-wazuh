<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3131 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 974446d8-c2f9-58cf-a5bf-cf00786f6c82 -->
  <rule id="391149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3131 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>