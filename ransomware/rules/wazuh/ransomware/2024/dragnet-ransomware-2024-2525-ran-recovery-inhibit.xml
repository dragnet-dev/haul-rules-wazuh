<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2525 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 3256decd-97d9-54d7-a2a2-4305c70e5a20 -->
  <rule id="840140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2525 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>