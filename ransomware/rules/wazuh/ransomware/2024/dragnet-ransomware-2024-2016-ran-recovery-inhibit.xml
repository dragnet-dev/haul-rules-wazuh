<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2016 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 3a33c265-d1dc-5d52-8ea6-50576910b83a -->
  <rule id="434026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2016 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>