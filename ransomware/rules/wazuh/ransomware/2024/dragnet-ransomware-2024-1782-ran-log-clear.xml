<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1782 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 95f649e0-b1ba-505e-8c66-2d6ca0a86ffb -->
  <rule id="735649" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1782 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>