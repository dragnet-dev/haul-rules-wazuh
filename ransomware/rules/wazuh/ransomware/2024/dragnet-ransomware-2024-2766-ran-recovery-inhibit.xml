<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2766 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 271b8254-572a-57c4-8ea5-6d5ca99b7a13 -->
  <rule id="847825" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2766 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>