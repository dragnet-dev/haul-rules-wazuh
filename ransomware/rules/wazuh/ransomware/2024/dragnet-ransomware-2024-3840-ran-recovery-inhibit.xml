<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3840 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: e7e0fb35-e247-5af3-baf2-fe8c675e0c87 -->
  <rule id="757211" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3840 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>