<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0667 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: 90d8a459-e8ff-5408-9d79-f43f11c13cf7 -->
  <rule id="626184" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0667 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>