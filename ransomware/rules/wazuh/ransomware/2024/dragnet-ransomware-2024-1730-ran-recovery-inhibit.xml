<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1730 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 3ec5a9eb-687e-5c72-a229-4497121ed25c -->
  <rule id="807309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1730 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>