<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4589 — Event Log Clearing (qilin) | Status: deprecated | Sigma ID: 52ca89ed-e51d-52e3-b080-7cb6ff2eb0a6 -->
  <rule id="551489" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4589 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>