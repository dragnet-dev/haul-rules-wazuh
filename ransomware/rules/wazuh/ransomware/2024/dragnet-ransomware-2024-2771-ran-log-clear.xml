<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2771 — Event Log Clearing (bluebox) | Status: experimental | Sigma ID: fa207561-fb81-5d4f-bc13-e242b9d578c8 -->
  <rule id="802075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2771 — Event Log Clearing (bluebox)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>