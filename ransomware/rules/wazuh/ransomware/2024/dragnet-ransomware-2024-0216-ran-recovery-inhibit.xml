<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0216 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 27cbc51b-1746-5c80-8dfc-4447123489c7 -->
  <rule id="338525" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0216 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>