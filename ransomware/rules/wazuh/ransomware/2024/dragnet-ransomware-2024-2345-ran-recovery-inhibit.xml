<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2345 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 678687b6-ec0d-56c3-9ff9-2e750c56cb29 -->
  <rule id="159003" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2345 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>