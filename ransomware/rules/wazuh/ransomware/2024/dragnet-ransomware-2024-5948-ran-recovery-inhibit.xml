<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5948 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: e6a327a9-c03e-511d-8ef4-b3a48127d451 -->
  <rule id="646327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5948 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>