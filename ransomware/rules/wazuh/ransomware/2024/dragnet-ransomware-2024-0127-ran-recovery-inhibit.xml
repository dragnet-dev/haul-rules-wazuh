<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0127 — Recovery Inhibition (cloak) | Status: experimental | Sigma ID: 6111279c-4d48-543f-8d26-43bca3d23895 -->
  <rule id="811279" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0127 — Recovery Inhibition (cloak)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>