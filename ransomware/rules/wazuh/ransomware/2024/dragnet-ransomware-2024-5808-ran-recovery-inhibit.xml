<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5808 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 5aac210a-bcde-5427-9300-37ae19c6a441 -->
  <rule id="621221" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5808 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>