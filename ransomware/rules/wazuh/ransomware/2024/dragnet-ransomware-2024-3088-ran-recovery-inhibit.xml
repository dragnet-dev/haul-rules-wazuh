<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3088 — Recovery Inhibition (moneymessage) | Status: experimental | Sigma ID: b5d6e695-4a94-57be-9fe8-c84e620a68bd -->
  <rule id="365906" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3088 — Recovery Inhibition (moneymessage)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>