<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1000 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 46e1ff39-3a7d-5f78-ad90-707d85c57fa8 -->
  <rule id="220511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1000 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
