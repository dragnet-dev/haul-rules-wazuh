<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3997 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 03d0159d-ea49-5d7d-88de-87aa8c3d9da8 -->
  <rule id="862557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3997 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>