<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1736 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 4b9b7878-0e7b-5702-b037-cd02a62095a4 -->
  <rule id="415578" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1736 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>