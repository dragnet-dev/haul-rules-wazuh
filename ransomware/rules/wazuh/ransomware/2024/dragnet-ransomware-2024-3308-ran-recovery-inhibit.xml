<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3308 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: d8fed0af-d91d-515e-92e4-1a3349fac61b -->
  <rule id="393250" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3308 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>