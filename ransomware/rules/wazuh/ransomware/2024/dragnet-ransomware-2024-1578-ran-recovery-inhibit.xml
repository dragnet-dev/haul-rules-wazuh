<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1578 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7e77f345-691d-5dee-a6f0-23411af9b754 -->
  <rule id="328473" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1578 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>