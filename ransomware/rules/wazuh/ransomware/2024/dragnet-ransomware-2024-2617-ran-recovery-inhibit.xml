<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2617 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 5d85a780-a0f9-54e4-b8b7-8cc4e592d89e -->
  <rule id="701707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2617 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>