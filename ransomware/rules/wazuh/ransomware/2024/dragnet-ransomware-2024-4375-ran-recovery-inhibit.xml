<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4375 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: fde1378e-ea1d-5256-b5be-ee53f88eb2c1 -->
  <rule id="562137" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4375 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>