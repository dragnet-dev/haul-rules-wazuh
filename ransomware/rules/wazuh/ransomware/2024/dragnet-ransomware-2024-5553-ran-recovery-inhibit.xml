<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5553 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 920bded3-fae7-5f4a-857f-ccd11d9a8c36 -->
  <rule id="271358" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5553 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>