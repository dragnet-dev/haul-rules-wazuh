<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1014 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: dc71ec1e-8cd9-52c7-a39d-e39d33e03f17 -->
  <rule id="350412" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1014 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>