<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1825 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 3a02cbfb-66bc-5918-b33d-001b1bbf5ebf -->
  <rule id="685515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1825 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>