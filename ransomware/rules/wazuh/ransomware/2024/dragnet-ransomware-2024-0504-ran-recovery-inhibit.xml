<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0504 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: a6d21870-546f-52c4-b744-ee37c0bd7e00 -->
  <rule id="909218" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0504 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>