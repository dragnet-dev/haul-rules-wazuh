<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5561 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 00bf344f-31af-59aa-8853-c6878c7eb25f -->
  <rule id="461519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5561 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>