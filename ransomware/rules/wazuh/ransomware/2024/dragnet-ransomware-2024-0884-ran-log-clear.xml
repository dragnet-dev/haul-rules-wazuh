<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0884 — Event Log Clearing (cloak) | Status: deprecated | Sigma ID: 160d7bf4-3984-5d64-9ae2-6ea91c2189d2 -->
  <rule id="388863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0884 — Event Log Clearing (cloak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>