<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1109 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 373cf713-eb78-5525-bfba-7b17889dcfc5 -->
  <rule id="669571" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1109 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>