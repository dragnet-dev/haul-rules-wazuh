<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0858 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 19593016-2bd9-5731-a754-bf7c80bfd296 -->
  <rule id="259301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0858 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>