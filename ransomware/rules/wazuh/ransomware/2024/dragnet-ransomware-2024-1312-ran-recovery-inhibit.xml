<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1312 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 88f9cfa3-9abd-520a-afe8-d9688cbeabb6 -->
  <rule id="145391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1312 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>