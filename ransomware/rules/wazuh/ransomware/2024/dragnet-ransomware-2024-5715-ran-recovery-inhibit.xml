<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5715 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c7daf6c4-ecc6-5500-838c-6c0548e19fb2 -->
  <rule id="836956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5715 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>