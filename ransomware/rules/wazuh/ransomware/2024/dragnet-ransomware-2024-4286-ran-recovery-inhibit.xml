<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4286 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0d038b22-250d-5557-8efc-a4faa7975555 -->
  <rule id="386192" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4286 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>