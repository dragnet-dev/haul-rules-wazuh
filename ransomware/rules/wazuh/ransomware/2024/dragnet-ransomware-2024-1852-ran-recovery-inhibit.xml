<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1852 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c531caeb-8976-5038-9577-352a0b89b937 -->
  <rule id="608138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1852 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>