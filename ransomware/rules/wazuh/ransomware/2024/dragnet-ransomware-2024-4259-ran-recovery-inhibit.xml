<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4259 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: e310d57c-7560-51f1-a994-a1219761676c -->
  <rule id="589735" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4259 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>