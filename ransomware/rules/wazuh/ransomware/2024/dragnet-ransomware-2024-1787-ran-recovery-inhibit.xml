<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1787 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a7652106-e070-5deb-846a-adbddcbbb23d -->
  <rule id="276521" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1787 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>