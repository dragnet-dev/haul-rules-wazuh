<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0765 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 8277965c-3ce2-5ae9-9f6e-430afecce52d -->
  <rule id="277965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0765 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>