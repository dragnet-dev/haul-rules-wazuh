<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0076 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 59d0efe0-7867-55b1-915e-d79304e010fb -->
  <rule id="750159" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0076 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>