<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2926 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: fbd7b05b-9802-5d98-8696-fe66a59500bc -->
  <rule id="247630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2926 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>