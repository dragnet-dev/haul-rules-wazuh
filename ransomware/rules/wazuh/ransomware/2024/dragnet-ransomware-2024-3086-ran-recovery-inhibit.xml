<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3086 — Recovery Inhibition (moneymessage) | Status: experimental | Sigma ID: d3a020ba-f518-512f-9c86-f14bb7c4363e -->
  <rule id="438020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3086 — Recovery Inhibition (moneymessage)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>