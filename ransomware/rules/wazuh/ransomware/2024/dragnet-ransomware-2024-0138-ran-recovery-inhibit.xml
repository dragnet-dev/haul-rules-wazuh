<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0138 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 5cf3586b-fe44-51b7-8f5d-eff2a70f5d45 -->
  <rule id="687358" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0138 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>