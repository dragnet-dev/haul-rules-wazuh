<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4407 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: b9f9fe10-203e-5103-9fd3-3f9c54cc544b -->
  <rule id="515198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4407 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>