<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5612 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: fcec8a7b-bf20-5876-aacf-e531ee8611fd -->
  <rule id="559818" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5612 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>