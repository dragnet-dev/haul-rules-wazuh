<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2712 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 5b41bbb0-c012-58cb-ba58-b218d60a5fb5 -->
  <rule id="640283" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2712 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>