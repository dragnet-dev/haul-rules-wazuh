<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0183 — Event Log Clearing (lynx) | Status: experimental | Sigma ID: 4b1fe5e8-4ca6-5818-b6a3-175ca76914f9 -->
  <rule id="225105" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0183 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>