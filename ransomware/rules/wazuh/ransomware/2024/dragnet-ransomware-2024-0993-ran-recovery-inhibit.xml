<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0993 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 7771489f-1fe2-5e14-a5b7-dab274b6a36a -->
  <rule id="671489" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0993 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>