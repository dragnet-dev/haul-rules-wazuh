<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1501 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 836c9080-4fb4-5189-a344-9850e45f23fe -->
  <rule id="538890" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1501 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>