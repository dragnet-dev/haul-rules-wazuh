<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3342 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 88a9e513-fab8-572b-b409-89c086166077 -->
  <rule id="570385" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3342 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>