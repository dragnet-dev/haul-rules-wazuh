<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1553 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 15bded06-ee54-50b1-8b4d-36423e628f02 -->
  <rule id="231661" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1553 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>