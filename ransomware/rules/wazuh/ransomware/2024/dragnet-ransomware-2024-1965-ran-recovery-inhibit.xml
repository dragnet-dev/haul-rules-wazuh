<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1965 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 779aecf8-a9b5-504e-b5b0-f5564b6d2f74 -->
  <rule id="593580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1965 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>