<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4325 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 2e6c7907-97c1-5e86-bf87-79c1c7e6d108 -->
  <rule id="368790" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4325 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>