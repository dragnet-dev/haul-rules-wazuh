<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2538 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: b9dda43c-a970-53ae-901c-0fbd4ccb5f7d -->
  <rule id="509704" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2538 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>