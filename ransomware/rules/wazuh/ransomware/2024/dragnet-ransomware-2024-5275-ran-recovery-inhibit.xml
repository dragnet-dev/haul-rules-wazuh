<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5275 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 1a8a3618-58b4-5a37-bc81-7ed71330b897 -->
  <rule id="798361" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5275 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>