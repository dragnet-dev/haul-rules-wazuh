<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3679 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 78a64bfa-8ff1-5d1b-ad1f-e11dcc72c7a9 -->
  <rule id="313835" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3679 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>