<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2144 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4b996eae-52c8-5bef-9c6e-7c1719d243fd -->
  <rule id="415950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2144 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>