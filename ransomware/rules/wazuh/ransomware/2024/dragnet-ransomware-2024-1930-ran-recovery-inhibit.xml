<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1930 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f9d5a8c9-c995-5d43-8063-683988de142e -->
  <rule id="592108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1930 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>