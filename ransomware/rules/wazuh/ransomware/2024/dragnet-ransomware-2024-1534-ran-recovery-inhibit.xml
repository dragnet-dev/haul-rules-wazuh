<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1534 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1502bfb9-4756-565b-8c77-4a75e77769a9 -->
  <rule id="855259" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1534 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>