<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5317 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 8a947a32-877a-5bda-a844-f205e921c53d -->
  <rule id="523162" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5317 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>