<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5411 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0d3805bf-643d-57ec-9fa3-16463cef99db -->
  <rule id="440891" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5411 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>