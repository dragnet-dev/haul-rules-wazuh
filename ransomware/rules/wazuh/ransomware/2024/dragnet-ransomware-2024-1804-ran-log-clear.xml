<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1804 — Event Log Clearing (helldown) | Status: experimental | Sigma ID: 67134fe9-f60e-5e11-8f96-6c779afdde74 -->
  <rule id="274159" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1804 — Event Log Clearing (helldown)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>