<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1487 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 23eb3966-47ed-54fe-8f54-bc91c09cad15 -->
  <rule id="823396" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1487 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>