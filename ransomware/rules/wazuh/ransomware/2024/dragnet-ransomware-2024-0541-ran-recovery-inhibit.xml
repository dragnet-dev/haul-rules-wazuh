<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0541 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 3397b546-de92-5e64-9428-da0a90e7d3e3 -->
  <rule id="136354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0541 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>