<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5502 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: c76dd6ac-3ea7-5f00-8b7b-64e63c3219b8 -->
  <rule id="668776" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5502 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>