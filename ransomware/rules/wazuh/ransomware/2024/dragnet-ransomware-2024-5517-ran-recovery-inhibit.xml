<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5517 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 8d237af0-e34d-5318-852d-1c4f88ea25ad -->
  <rule id="559802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5517 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>