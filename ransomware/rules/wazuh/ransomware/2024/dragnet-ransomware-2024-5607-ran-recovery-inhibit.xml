<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5607 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 539477d5-df88-5492-9b87-a6b9c8efb642 -->
  <rule id="631645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5607 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>