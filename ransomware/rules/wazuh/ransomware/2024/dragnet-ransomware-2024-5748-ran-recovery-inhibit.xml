<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5748 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 838fb2c9-778e-501a-892e-12360b5bcae2 -->
  <rule id="447792" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5748 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>