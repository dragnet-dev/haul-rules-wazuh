<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1107 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3628a1b6-c14a-5f27-8cef-5763c142c926 -->
  <rule id="389307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1107 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>