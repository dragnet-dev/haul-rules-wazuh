<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1567 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 83704f06-f126-59a1-bbd4-03010271e7cc -->
  <rule id="539279" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1567 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>