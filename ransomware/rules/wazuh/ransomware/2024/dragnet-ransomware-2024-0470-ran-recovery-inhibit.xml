<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0470 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: d918ec6c-ec35-5305-8dc2-ea7a7ccde929 -->
  <rule id="963244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0470 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>