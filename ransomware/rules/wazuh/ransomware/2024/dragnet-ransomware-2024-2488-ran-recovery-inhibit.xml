<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2488 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 8e82874c-5d16-54e0-8e12-42093686182a -->
  <rule id="628287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2488 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>