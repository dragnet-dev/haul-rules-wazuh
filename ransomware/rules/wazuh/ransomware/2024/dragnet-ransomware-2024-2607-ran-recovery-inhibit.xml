<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2607 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 4d45d71a-7f01-5e87-b01f-4934e7541f48 -->
  <rule id="439337" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2607 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>