<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2740 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 454141c8-ef06-53ba-89ab-68f47011c1a5 -->
  <rule id="166268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2740 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>