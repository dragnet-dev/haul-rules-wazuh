<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4989 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: a0af7e10-bafe-5413-a837-7d3b413f9add -->
  <rule id="624126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4989 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>