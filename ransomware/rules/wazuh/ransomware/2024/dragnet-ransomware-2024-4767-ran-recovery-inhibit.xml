<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4767 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 1be4a167-f71d-5773-b77d-362d2c245a8b -->
  <rule id="943416" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4767 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>