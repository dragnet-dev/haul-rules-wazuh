<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4765 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 90470766-ef6d-50f2-91ac-f0f5379e1f18 -->
  <rule id="147076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4765 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>