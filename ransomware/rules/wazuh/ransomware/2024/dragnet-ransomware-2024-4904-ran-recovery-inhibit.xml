<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4904 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 462f1ad5-27a2-5490-bb7c-954a22834b2d -->
  <rule id="385146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4904 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>