<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5759 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 8b3f2bb8-ce84-5176-b974-c255a48b5928 -->
  <rule id="968523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5759 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>