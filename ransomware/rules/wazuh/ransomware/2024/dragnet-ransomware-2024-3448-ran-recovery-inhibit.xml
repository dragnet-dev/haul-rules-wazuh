<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3448 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ecf51d71-ca20-5a66-9e90-c563dbca77d1 -->
  <rule id="766429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3448 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>