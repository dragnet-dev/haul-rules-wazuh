<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0134 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 978991d4-8ebd-5e9d-bad5-6ebf4600df9f -->
  <rule id="463869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0134 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>