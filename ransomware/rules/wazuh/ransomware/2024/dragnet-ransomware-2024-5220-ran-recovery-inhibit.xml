<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5220 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: b27e8339-6b0b-5351-af3e-8e3a3a697720 -->
  <rule id="104683" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5220 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>