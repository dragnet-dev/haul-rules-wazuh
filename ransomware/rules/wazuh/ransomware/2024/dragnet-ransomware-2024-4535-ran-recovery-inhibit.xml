<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4535 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 21221d02-d654-5101-b3e7-c8399ca0087b -->
  <rule id="795490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4535 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>