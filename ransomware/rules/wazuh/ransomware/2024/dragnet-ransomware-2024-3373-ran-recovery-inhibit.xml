<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3373 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: a35dfee3-a173-5ca7-85e1-58920dc35a05 -->
  <rule id="742942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3373 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>