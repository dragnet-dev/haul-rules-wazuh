<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0383 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 53cf68eb-7f15-5c46-9221-61562023c49f -->
  <rule id="577568" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0383 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>