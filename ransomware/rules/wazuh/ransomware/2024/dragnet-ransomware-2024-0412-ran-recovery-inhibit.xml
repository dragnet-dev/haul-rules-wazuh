<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0412 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 07646517-6b2c-54eb-b71e-7a35f2d6cf1c -->
  <rule id="546517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0412 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>