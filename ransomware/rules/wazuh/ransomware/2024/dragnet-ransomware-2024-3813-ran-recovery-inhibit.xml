<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3813 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 4c8d70f7-b092-58fe-bad2-81f68ada104b -->
  <rule id="430170" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3813 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>