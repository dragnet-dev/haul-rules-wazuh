<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0280 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: aa00fdfd-9853-5dca-ac74-09e0347d6244 -->
  <rule id="852253" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0280 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>