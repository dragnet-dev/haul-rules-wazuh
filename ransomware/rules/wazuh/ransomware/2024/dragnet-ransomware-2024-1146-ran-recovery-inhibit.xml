<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1146 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: b2154b34-dddd-50b4-93af-6f951281eebd -->
  <rule id="994475" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1146 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>