<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4485 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0bed136b-c3c7-5421-8b9d-1c2173c05eeb -->
  <rule id="453136" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4485 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>