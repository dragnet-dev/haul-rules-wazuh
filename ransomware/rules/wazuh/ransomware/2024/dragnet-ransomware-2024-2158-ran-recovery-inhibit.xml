<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2158 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: edda8c4f-5d22-5793-ae77-55a19b805766 -->
  <rule id="842540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2158 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>