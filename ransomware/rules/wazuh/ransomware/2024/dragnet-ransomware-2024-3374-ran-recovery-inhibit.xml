<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3374 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2980b00a-0beb-59e4-9c25-dc29c5b9ecce -->
  <rule id="369100" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3374 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>