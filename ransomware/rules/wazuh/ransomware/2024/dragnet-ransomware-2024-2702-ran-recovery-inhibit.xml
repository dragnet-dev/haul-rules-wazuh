<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2702 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: bb6ad151-8520-5cd6-b988-7ecadc422409 -->
  <rule id="404291" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2702 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>