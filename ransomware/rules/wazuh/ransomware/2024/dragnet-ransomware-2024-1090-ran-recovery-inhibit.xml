<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1090 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c802f031-bcdb-5d7a-acc8-236ae79f1b04 -->
  <rule id="348470" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1090 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>