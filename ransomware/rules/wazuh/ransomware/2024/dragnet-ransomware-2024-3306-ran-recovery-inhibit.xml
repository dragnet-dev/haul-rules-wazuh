<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3306 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: b14b7736-6599-5d27-afe2-f45f30f48beb -->
  <rule id="983577" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3306 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>