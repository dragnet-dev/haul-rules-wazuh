<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4281 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1f716973-047d-57dd-9b38-5cde2a319654 -->
  <rule id="571697" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4281 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>