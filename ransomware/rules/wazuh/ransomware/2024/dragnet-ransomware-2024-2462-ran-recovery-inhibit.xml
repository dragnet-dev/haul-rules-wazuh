<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2462 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: fa60bf70-92c4-5639-a6af-14b8f291c068 -->
  <rule id="215551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2462 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>