<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0805 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 6965c801-3d62-518b-b5ac-ed442fa9b76c -->
  <rule id="314528" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0805 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>