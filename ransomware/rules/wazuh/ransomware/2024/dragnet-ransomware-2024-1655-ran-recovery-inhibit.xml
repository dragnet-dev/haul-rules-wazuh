<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1655 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 48a876aa-f7f9-5909-8da9-257c8ba5dfd5 -->
  <rule id="862026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1655 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>