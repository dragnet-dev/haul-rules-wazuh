<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4261 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 81dab927-6d39-557b-a0b4-a99a6beb95c2 -->
  <rule id="752759" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4261 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>