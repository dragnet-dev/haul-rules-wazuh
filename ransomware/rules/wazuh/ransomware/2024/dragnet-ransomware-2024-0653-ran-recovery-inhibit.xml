<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0653 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 586e1c8b-b460-50bb-bcf6-39ceec596292 -->
  <rule id="702428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0653 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>