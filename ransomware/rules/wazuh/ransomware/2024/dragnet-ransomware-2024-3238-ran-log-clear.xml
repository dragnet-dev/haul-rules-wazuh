<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3238 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: e0bc0a7a-dc7a-5980-a815-e4b1c72f9e56 -->
  <rule id="464490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3238 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>