<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1961 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 86976e95-028c-51c7-b263-b1fd9fb73bc6 -->
  <rule id="591630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1961 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>