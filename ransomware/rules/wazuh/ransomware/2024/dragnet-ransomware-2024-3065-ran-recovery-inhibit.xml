<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3065 — Recovery Inhibition (play) | Status: experimental | Sigma ID: eee19832-6602-532b-b94a-3bc53bba6622 -->
  <rule id="322198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3065 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>