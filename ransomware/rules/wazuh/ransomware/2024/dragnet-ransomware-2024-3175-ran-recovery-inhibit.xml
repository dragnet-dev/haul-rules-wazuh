<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3175 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: ccc4d549-1e6d-58f9-83c0-24bf4f44e766 -->
  <rule id="842375" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3175 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>