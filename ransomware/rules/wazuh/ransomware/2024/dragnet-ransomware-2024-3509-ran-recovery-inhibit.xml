<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3509 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 08437dac-c1e9-5ce8-81cb-3bc9f27c38c4 -->
  <rule id="460090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3509 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>