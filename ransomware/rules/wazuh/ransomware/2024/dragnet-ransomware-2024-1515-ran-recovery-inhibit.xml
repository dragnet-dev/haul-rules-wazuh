<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1515 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 79a2db92-f35c-5d5d-afe0-97d480d36b09 -->
  <rule id="662171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1515 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>