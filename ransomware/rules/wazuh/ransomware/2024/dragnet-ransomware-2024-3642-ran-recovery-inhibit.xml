<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3642 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: f19c61ad-53df-54eb-ac24-dcbbf551f5d3 -->
  <rule id="731661" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3642 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>