<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2670 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: efc7361c-cafd-5aee-be0d-0ce54ddd9101 -->
  <rule id="336736" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2670 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>