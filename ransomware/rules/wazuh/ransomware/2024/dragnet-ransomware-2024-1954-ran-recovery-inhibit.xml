<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1954 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: c23599d1-1abd-5c61-ad5d-b7ba1efdb504 -->
  <rule id="423599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1954 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>