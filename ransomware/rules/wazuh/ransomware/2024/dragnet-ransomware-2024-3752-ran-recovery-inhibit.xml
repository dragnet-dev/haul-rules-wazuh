<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3752 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 9589cefb-d9fb-57dc-9621-a6a854797db2 -->
  <rule id="754990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3752 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>