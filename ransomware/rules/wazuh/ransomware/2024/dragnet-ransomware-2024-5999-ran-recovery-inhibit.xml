<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5999 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 51daaca3-e594-5e21-9736-a456ba7aed0c -->
  <rule id="798316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5999 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>