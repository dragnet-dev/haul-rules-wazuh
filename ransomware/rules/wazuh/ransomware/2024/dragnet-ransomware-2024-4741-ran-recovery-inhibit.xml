<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4741 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: fe40f9fb-23e7-5d1a-8fd3-2540c2dabcbe -->
  <rule id="570559" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4741 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>