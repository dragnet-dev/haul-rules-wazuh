<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0385 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: b5a14245-1135-5426-be3b-2f43080150ee -->
  <rule id="150142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0385 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>