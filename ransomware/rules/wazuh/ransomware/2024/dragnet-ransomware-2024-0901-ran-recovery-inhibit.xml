<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0901 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: d7eb72c1-4758-565b-a4d7-973040294f74 -->
  <rule id="930772" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0901 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>