<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5926 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9964a0bb-6167-513f-9528-9e8f17ef074a -->
  <rule id="794340" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5926 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>