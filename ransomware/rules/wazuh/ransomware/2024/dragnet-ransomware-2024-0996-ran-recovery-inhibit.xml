<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0996 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 46615113-6762-5a4a-927a-04b75a52a25b -->
  <rule id="261511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0996 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>