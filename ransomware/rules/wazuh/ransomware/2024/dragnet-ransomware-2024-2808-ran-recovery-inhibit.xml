<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2808 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 03a076e0-b1e5-5fc8-be1b-6ced8879cae8 -->
  <rule id="392300" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2808 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>