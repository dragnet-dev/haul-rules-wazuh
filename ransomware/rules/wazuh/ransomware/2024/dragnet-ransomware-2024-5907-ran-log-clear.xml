<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5907 — Event Log Clearing (hunters) | Status: experimental | Sigma ID: 78ce0a95-58de-5c17-8fb8-c4c1ad41bf83 -->
  <rule id="627850" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5907 — Event Log Clearing (hunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>