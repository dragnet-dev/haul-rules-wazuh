<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4571 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: d9995867-4428-5fb7-a6fb-0abd36a59217 -->
  <rule id="599958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4571 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>