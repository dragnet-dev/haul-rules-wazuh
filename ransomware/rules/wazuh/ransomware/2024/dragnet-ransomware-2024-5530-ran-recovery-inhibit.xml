<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5530 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: d4e00a77-3993-520b-bede-f52bf5a6ad83 -->
  <rule id="852810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5530 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>