<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4058 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 684c0acc-c03c-562b-9475-5f8ab4896347 -->
  <rule id="952970" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4058 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>