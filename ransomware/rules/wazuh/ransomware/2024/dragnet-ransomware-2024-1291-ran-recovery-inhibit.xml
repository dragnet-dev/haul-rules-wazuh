<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1291 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2e5f0028-c2ae-5410-aa96-556e38f7b84b -->
  <rule id="355002" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1291 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>