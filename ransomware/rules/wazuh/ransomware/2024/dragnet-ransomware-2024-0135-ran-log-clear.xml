<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0135 — Event Log Clearing (stormous) | Status: deprecated | Sigma ID: 4dbdad6d-c27c-50a8-9a67-de216997f255 -->
  <rule id="694829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0135 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>