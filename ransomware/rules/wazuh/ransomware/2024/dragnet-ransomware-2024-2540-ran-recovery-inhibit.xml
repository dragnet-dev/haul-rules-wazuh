<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2540 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 316a9522-f83d-5c2e-a0ff-096cf6264af6 -->
  <rule id="666952" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2540 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>