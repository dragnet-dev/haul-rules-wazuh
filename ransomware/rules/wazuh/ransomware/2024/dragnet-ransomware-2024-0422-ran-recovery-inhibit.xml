<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0422 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 8f250197-388f-59c9-9825-4b27b8132c2c -->
  <rule id="632501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0422 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>