  <rule id="707142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4649 — Recovery Inhibition (ValenciaLeaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
