<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1609 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 3a5b973e-34e0-57b0-bff2-514c71fdfc19 -->
  <rule id="471973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1609 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>