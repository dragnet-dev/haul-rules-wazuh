<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4825 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: f87d28f1-7e34-5f09-bcfc-4a9e2410748f -->
  <rule id="840528" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4825 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>