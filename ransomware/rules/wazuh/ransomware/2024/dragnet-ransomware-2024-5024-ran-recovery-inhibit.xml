<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5024 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: fd3ac8a0-4a3b-5864-987f-135c54c1aaa4 -->
  <rule id="286208" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5024 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>