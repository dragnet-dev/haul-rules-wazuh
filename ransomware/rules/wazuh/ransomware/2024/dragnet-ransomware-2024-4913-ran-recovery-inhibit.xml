<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4913 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 58f7de65-0366-583f-9c31-d9b4425ab314 -->
  <rule id="716094" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4913 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>