<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5569 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b85ca658-dcd6-53e8-8f68-cd7b15f26d60 -->
  <rule id="435626" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5569 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>