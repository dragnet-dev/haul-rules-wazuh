<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1791 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: cd6145de-c7f4-588c-987f-4d0092ecb451 -->
  <rule id="356145" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1791 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>