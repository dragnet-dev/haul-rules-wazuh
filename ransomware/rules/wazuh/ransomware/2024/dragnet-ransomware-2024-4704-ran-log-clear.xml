<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4704 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 01f1a881-7e0c-539a-b1ba-ed12cf1a2d0d -->
  <rule id="586881" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4704 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>