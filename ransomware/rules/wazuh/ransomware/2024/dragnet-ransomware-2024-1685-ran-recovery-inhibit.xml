<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1685 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 15eaaf1b-54e8-500b-a63d-92eb24f8bd9b -->
  <rule id="243119" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1685 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>