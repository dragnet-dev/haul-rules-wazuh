<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1084 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 82cf3564-54ed-5fef-927d-c694a9c11f7d -->
  <rule id="419935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1084 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>