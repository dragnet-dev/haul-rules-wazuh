<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0345 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0982a68e-30ed-589d-af72-9b773d8f6938 -->
  <rule id="772268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0345 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>