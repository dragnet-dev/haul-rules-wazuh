<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3431 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 35dd4a31-fe77-5715-89a8-ae7596039982 -->
  <rule id="669034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3431 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>