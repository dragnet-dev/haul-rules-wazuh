<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4666 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: dd0e68fc-608b-59f5-a889-54cf9f4b33b1 -->
  <rule id="937468" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4666 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>