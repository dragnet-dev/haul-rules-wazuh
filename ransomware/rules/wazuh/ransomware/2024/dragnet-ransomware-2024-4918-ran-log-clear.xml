<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4918 — Event Log Clearing (snatch) | Status: experimental | Sigma ID: b5ac06f3-2a0e-50c8-ac9a-612ae4b73aa6 -->
  <rule id="361206" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4918 — Event Log Clearing (snatch)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>