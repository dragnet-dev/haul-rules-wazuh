<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1383 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 581e524b-9b1a-5755-a513-6628e84dbbf0 -->
  <rule id="410524" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1383 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>