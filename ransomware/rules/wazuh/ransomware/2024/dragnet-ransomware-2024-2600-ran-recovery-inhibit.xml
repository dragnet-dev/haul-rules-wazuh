<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2600 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: e025ea16-0cdb-5b19-a529-8f28f2ca05a5 -->
  <rule id="990634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2600 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>