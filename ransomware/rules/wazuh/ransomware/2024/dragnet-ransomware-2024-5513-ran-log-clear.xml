<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5513 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 2fba9b1a-8173-5e2a-a341-e8a4c23075e3 -->
  <rule id="255035" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5513 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>