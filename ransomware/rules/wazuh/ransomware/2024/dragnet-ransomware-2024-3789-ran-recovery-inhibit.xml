<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3789 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 3fdfeedc-00bd-55f1-9a70-f08cd9099db8 -->
  <rule id="686094" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3789 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>