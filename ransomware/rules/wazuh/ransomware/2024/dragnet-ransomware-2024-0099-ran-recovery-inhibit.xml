<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0099 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 39715d0b-c5d1-5e3f-ba36-4fac3266fe5b -->
  <rule id="154530" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0099 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>