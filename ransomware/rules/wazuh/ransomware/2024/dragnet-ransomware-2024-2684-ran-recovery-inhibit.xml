<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2684 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b65d849b-8aee-5b64-9cac-ce94c2f843d1 -->
  <rule id="165384" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2684 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>