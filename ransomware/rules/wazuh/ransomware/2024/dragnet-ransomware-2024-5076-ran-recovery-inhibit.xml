<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5076 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: c434ae1b-5649-5491-9f74-2099593b3730 -->
  <rule id="583278" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5076 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>