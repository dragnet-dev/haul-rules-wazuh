<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1058 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a5f1e578-f389-571e-9968-9a4732b1c09a -->
  <rule id="112305" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1058 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>