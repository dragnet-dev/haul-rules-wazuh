<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2915 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8a3e743a-7c01-5dd8-a382-52da7f8849d3 -->
  <rule id="514274" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2915 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>