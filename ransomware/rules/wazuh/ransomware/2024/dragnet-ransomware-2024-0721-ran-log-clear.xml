<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0721 — Event Log Clearing (cloak) | Status: deprecated | Sigma ID: 9fc48e98-43ab-5c2e-a38b-f1d56ab65655 -->
  <rule id="590382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0721 — Event Log Clearing (cloak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>