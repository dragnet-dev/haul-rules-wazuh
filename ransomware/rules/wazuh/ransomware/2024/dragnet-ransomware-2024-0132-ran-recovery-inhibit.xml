<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0132 — Recovery Inhibition (cloak) | Status: experimental | Sigma ID: a3ddcea3-b995-5704-b721-cfd109f25867 -->
  <rule id="606990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0132 — Recovery Inhibition (cloak)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>