<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5896 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 194a026b-ceb0-545f-8bc3-5a156254c36e -->
  <rule id="514026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5896 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>