<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2618 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b0e4a6dd-3793-5c1a-b0b0-ce6f644ed9a6 -->
  <rule id="239146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2618 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
