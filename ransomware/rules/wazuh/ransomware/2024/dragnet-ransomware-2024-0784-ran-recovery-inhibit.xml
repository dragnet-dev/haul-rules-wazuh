<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0784 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: fee13551-9a81-5db3-937e-92f399e69ac1 -->
  <rule id="578135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0784 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>