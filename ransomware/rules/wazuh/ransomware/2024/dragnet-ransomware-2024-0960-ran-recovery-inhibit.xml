<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0960 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: a50abebd-2953-56db-ae21-62ca052493c3 -->
  <rule id="803550" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0960 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>