<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0642 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: d85cbf12-1496-50c6-acad-57eede4fd000 -->
  <rule id="376223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0642 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>