<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3488 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 83530d3c-f0fa-5264-81cc-82d3a43f96f2 -->
  <rule id="536493" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3488 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>