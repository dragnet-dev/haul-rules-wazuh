<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5211 — Recovery Inhibition (qiulong) | Status: experimental | Sigma ID: cab6a74e-3850-55be-aa3c-870f9ee7d7e1 -->
  <rule id="789867" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5211 — Recovery Inhibition (qiulong)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>