<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2925 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d89bd634-1d6e-54d4-a700-8cdfd92e4913 -->
  <rule id="957736" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2925 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>