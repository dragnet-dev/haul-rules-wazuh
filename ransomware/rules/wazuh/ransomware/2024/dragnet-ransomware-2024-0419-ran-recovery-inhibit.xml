<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0419 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: d4cd56e1-0f61-52f5-a08f-b777d6910ab6 -->
  <rule id="850956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0419 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>