<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1709 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7bdcdce8-49aa-5a6b-a983-2a32b0b6e507 -->
  <rule id="117468" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1709 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>