<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2243 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 6abc9d5c-43c3-570b-a6c4-60c38b604ba1 -->
  <rule id="871997" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2243 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>