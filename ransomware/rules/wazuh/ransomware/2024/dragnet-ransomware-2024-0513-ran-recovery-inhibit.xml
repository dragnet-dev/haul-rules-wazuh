<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0513 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: f70df59b-a976-5626-9496-19d0643ef1c5 -->
  <rule id="521435" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0513 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>