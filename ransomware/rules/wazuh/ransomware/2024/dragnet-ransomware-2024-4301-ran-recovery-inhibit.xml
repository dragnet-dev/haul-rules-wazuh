<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4301 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 61a525dd-3a7a-574c-9601-5d1c6069fe39 -->
  <rule id="584413" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4301 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>