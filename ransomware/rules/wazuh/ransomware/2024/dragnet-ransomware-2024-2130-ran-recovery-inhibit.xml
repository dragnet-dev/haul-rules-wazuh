<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2130 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 9d1d4797-6f86-5bfe-94c8-11d290839682 -->
  <rule id="814947" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2130 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>