<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4494 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: b4154c28-4b4c-5b5e-8cf6-c0594559dbad -->
  <rule id="126476" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4494 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>