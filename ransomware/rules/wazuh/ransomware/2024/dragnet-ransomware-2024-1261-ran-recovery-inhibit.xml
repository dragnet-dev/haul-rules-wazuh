<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1261 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 40edadb4-e1e7-5785-b374-45b10a61ad77 -->
  <rule id="982285" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1261 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>