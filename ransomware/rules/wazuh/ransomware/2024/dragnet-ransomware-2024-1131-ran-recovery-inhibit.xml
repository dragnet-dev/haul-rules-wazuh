<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1131 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 8d20cc20-e7d2-5009-be96-2b100786755f -->
  <rule id="114924" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1131 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>