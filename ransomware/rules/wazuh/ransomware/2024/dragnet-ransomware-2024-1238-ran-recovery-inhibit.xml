<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1238 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7a8cc8e7-c66b-5534-ad35-a7af1b4ec53e -->
  <rule id="545728" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1238 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>