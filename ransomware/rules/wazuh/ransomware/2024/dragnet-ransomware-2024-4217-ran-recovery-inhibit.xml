<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4217 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 4a3874a7-e3db-513c-8f6b-e0cf0967ea55 -->
  <rule id="301994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4217 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>