<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3614 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4c818c54-67ca-544b-9bc0-537f1faab1ac -->
  <rule id="429100" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3614 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>