<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1062 — Recovery Inhibition (malekteam) | Status: experimental | Sigma ID: fc200e59-4839-598b-a22b-e203f2eff570 -->
  <rule id="535214" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1062 — Recovery Inhibition (malekteam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>