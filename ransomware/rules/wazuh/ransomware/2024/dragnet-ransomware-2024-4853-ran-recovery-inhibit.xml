<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4853 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 7ba7efe1-066a-5abb-ba12-0cf59d7c3e2d -->
  <rule id="665711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4853 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>