<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2431 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: e3a5de44-9295-5207-b74f-130af7a6b3ce -->
  <rule id="584382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2431 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>