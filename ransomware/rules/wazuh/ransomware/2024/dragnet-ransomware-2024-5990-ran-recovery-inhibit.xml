<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5990 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 560211dd-bd95-59ae-858f-b9eed9a163ae -->
  <rule id="963389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5990 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>