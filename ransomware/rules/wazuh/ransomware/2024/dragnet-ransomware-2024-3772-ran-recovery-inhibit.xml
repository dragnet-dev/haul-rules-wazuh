<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3772 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 65097a9b-58c1-55c8-9e88-a324fca66999 -->
  <rule id="241562" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3772 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>