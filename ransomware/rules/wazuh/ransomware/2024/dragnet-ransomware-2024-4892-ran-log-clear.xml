<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4892 — Event Log Clearing (hunters) | Status: experimental | Sigma ID: 3e6ff61d-7ea4-5e62-bb18-7ff5d360eec2 -->
  <rule id="805116" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4892 — Event Log Clearing (hunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>