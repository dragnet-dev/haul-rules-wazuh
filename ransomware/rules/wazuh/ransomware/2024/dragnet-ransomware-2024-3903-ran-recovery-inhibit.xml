<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3903 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ab36af13-fb21-5b1a-9676-6ae3059016ca -->
  <rule id="886991" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3903 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>