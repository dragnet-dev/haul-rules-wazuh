<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3085 — Recovery Inhibition (moneymessage) | Status: experimental | Sigma ID: 2448a3c6-18fa-5cbd-8797-c6cb7b510653 -->
  <rule id="968540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3085 — Recovery Inhibition (moneymessage)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>