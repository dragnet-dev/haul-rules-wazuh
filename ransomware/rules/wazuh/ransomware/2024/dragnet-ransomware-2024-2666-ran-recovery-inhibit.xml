<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2666 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b5151b54-5807-51a7-ad2b-5dc302469701 -->
  <rule id="142427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2666 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>