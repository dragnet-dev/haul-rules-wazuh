<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1797 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: f673d289-050c-5fd4-ac82-ff05f07c8897 -->
  <rule id="807812" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1797 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>