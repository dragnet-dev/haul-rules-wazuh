<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4808 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2adb9639-b8ac-5e95-996c-f217525d7edf -->
  <rule id="297196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4808 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>