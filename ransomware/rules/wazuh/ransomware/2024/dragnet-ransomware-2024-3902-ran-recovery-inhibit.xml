<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3902 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6c9c0ec8-3103-5a7f-bf1e-8a76beb90b96 -->
  <rule id="189774" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3902 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>