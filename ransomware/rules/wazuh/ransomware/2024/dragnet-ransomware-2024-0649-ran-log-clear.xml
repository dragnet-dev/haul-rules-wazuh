<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0649 — Event Log Clearing (dAn0n) | Status: experimental | Sigma ID: 58dc2ec2-8536-54ca-b9a1-f4a14ff30943 -->
  <rule id="710926" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0649 — Event Log Clearing (dAn0n)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>