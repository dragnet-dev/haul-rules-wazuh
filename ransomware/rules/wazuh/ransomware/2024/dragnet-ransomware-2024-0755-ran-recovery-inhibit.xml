<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0755 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: a3eeb46b-136e-5942-8581-4ef02f31bc2e -->
  <rule id="757074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0755 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>