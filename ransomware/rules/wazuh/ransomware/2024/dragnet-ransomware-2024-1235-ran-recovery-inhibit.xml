<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1235 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 9efb66f9-676b-568d-91d8-8ff20549fbae -->
  <rule id="569966" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1235 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>