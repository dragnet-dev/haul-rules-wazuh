<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2332 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 35935c72-bd35-5f39-ac56-a93670127f27 -->
  <rule id="449727" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2332 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>