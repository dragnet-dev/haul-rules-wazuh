<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0678 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 89dd305d-e628-5b9b-9d16-e694456e8476 -->
  <rule id="600530" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0678 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>