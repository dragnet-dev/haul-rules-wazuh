<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4073 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 992f7dff-60f9-5577-8745-676cf3463d1a -->
  <rule id="842045" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4073 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>