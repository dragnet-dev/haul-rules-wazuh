<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1321 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 55cd0819-d528-5ff4-baeb-6d8d662bd35a -->
  <rule id="628508" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1321 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>