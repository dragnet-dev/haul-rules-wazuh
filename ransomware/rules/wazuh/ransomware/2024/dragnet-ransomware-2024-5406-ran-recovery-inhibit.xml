<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5406 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: e872d857-515b-5bfc-ba10-678a9c2e7276 -->
  <rule id="679658" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5406 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>