<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1663 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 02459b28-bf53-59e0-97e2-3f2ed41e9bbf -->
  <rule id="435528" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1663 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>