<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0293 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 72658d40-81e4-5056-97e5-50da1a63d42b -->
  <rule id="362541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0293 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>