<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3283 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: d3580b42-5cfb-5255-8a03-ecda94e123f2 -->
  <rule id="437291" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3283 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>