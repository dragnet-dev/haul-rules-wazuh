<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4775 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4ec1b062-43ef-51ed-b269-1833ca19055f -->
  <rule id="316270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4775 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>