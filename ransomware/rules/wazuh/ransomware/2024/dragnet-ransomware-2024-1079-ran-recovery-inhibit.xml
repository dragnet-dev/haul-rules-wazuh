<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1079 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a00fb817-cc9e-5d75-ae9e-fdc54487de68 -->
  <rule id="862518" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1079 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>