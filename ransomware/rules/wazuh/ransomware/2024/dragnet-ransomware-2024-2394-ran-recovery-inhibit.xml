<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2394 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 2534245a-8aa7-5954-9411-9188c4340c54 -->
  <rule id="834245" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2394 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>