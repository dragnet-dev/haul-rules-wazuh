<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4450 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 4e4fd18a-a904-52ae-b8a5-b8bfa2e82471 -->
  <rule id="309571" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4450 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>