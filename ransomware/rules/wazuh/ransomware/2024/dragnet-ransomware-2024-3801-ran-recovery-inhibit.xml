<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3801 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: 552de356-dae9-5a2a-9dd8-68923a2b8da1 -->
  <rule id="615343" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3801 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>