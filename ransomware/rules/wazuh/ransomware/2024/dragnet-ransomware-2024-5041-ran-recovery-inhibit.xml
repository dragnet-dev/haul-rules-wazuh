<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5041 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 78050e68-a432-5571-b758-c69f19a9eb5e -->
  <rule id="448814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5041 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>