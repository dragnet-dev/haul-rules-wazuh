<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0328 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f8fca3b3-e3ea-5223-bafd-d4cd18e2bfc8 -->
  <rule id="312103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0328 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>