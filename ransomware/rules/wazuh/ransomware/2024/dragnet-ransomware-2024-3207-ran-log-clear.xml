<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3207 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 4a2f52d3-de6a-5c4a-871a-d4ade040c5c4 -->
  <rule id="388752" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3207 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>