<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4532 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: 7be67cdc-50b9-5e76-ad1c-a3e5be0ee684 -->
  <rule id="572284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4532 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>