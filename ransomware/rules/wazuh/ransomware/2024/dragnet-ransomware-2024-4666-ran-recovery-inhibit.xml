<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4666 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: c698cceb-46f3-5e1f-8b2d-923f2bfc8aa9 -->
  <rule id="650892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4666 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>