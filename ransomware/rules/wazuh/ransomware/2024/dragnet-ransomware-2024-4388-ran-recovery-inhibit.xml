<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4388 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 748822b3-edff-5b6d-98d7-c4faaf69d739 -->
  <rule id="381163" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4388 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>