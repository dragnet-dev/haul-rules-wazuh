<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3948 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e07f7ebb-0fe5-5833-994d-c85c02caf2a6 -->
  <rule id="104446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3948 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>