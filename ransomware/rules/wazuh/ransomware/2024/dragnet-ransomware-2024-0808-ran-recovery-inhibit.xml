<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0808 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: f1ae494b-8485-526d-ba03-46bc357758ce -->
  <rule id="383049" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0808 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
