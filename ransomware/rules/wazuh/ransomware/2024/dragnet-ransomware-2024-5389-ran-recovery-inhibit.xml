<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5389 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8d2970d5-0246-5662-ae11-c3937775ea68 -->
  <rule id="612970" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5389 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>