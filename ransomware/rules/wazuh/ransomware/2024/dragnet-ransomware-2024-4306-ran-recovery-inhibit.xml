<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4306 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 31305bd8-06df-5774-94f7-a90a46ed0d83 -->
  <rule id="914269" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4306 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>