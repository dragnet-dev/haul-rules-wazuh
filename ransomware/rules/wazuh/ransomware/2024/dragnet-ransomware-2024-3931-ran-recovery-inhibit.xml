<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3931 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d507b2e1-7417-56e5-82a8-9db136b69f2c -->
  <rule id="461232" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3931 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>