<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2286 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e4cfcffa-a433-5ce0-a4c4-0d3015a2cabf -->
  <rule id="590383" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2286 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>