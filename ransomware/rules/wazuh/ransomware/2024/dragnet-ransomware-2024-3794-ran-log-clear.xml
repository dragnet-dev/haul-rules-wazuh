<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3794 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 2623cb4e-6d75-5d35-bdf2-a56e32472223 -->
  <rule id="516914" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3794 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>