<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1940 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 2352cdd9-06ae-5ef6-ae81-2d3a278d6a2d -->
  <rule id="737085" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1940 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>