<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5930 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: e8ad2e40-0f5e-5e77-928c-cf4a66c76b1c -->
  <rule id="789806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5930 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>