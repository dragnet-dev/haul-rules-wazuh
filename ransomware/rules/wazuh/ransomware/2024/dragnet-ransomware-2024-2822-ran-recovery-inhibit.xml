<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2822 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 979da6ea-ea67-5bb6-92cc-cb3932103aa0 -->
  <rule id="808426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2822 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>