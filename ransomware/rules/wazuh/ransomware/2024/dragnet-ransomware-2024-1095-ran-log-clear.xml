<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1095 — Event Log Clearing (threeam) | Status: experimental | Sigma ID: c82c9f8b-174d-5a2b-a0ab-bb0f58d3fd0a -->
  <rule id="683999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1095 — Event Log Clearing (threeam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>