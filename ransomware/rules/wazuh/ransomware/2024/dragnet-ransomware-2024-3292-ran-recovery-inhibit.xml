<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3292 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5694b2ed-a069-5e82-8236-3d2bd4e9316f -->
  <rule id="278446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3292 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>