<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0017 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 3960c1ea-09dc-5d4f-a0a1-5ab293841dd8 -->
  <rule id="339550" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0017 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>