<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0059 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: d92fcaf6-8ce5-5524-9b46-6869c9dc57d8 -->
  <rule id="405674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0059 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>