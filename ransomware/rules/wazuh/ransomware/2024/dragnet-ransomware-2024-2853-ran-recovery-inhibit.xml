<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2853 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: fe91b891-6386-5e6d-ae01-0d1fa57a8929 -->
  <rule id="578678" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2853 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>