<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5860 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 7a764486-9318-554a-8dcd-9c40f23febac -->
  <rule id="427644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5860 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>