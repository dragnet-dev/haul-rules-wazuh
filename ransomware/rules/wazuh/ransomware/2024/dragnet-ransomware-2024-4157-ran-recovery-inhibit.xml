<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4157 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: dc2c2a4b-dd8c-50ce-9b8c-fa4baf04ccb4 -->
  <rule id="339082" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4157 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>