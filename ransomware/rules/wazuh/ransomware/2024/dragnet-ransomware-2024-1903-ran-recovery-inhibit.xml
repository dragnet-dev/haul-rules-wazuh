<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1903 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 1455a0fc-5d9c-5c4c-8f58-951d04f09b18 -->
  <rule id="226415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1903 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>