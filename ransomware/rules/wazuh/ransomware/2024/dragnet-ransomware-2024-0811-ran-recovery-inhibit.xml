<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0811 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a963a3f0-7b86-5eb6-be86-7c9c580af178 -->
  <rule id="954183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0811 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>