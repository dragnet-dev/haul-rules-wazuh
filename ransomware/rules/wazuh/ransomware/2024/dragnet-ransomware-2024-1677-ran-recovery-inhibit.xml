<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1677 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 37716349-cc6c-5150-a2fc-0de48fefa2e4 -->
  <rule id="271634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1677 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>