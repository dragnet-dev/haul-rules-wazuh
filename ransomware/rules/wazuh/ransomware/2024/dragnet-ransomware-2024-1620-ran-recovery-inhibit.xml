<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1620 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: f8c85eab-cc51-5af2-9312-9ddd0e9475cc -->
  <rule id="565374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1620 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>