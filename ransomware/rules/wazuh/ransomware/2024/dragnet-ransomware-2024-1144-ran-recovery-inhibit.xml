<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1144 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 17a5822f-9711-5a58-bf0e-b814a55b389b -->
  <rule id="225822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1144 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>