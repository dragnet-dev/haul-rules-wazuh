<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1914 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: a983425c-a68c-5c62-aea4-a8f9ac8578fd -->
  <rule id="298342" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1914 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>