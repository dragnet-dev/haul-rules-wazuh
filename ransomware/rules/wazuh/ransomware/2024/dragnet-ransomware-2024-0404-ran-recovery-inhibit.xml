<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0404 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: c373d32e-af85-5f0e-8348-85a8991b57f7 -->
  <rule id="279813" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0404 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>