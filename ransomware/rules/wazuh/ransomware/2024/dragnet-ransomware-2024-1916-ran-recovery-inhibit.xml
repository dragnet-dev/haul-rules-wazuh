<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1916 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 6692a0de-a768-5467-a2af-f17743f67319 -->
  <rule id="270820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1916 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>