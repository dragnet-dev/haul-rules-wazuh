<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5905 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 17cb1c80-a67b-5b03-8be9-9f3703bfcedb -->
  <rule id="188288" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5905 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>