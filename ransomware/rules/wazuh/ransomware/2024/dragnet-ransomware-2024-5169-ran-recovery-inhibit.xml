<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5169 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 4a391835-7167-53cd-836e-376f6ff54534 -->
  <rule id="339183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5169 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>