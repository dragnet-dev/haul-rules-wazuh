<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5209 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: cdf29608-e951-5cb4-976d-8d9eece0cd6c -->
  <rule id="695296" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5209 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>