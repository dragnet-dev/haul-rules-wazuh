<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1398 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 59c94401-f189-547f-b8c6-19113d0518f2 -->
  <rule id="669440" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1398 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>