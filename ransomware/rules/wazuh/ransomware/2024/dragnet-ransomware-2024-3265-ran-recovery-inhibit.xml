<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3265 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 47d664a0-a1aa-5b09-94cb-a5b31f951857 -->
  <rule id="650634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3265 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>