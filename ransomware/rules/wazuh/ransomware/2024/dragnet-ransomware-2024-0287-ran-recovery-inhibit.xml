<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0287 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: d7db42f1-6d6a-54a2-af6d-0a079c79c632 -->
  <rule id="929142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0287 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>