<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0998 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 9d28879c-cbd3-5d41-980b-31f6bca51a94 -->
  <rule id="772887" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0998 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>