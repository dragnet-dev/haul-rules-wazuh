<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1001 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: f7a1eda9-bd15-57cd-94e1-a662d4f3f4da -->
  <rule id="256813" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1001 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>