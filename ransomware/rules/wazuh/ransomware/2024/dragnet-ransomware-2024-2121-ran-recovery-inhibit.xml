<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2121 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 3f80ba9d-57ad-559b-9eb7-59fa72952f06 -->
  <rule id="833466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2121 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>