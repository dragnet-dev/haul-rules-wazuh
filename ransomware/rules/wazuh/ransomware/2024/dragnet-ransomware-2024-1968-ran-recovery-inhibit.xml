<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1968 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 956ef5b8-ef6e-5cad-8d40-9d55ef1379d0 -->
  <rule id="749755" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1968 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>