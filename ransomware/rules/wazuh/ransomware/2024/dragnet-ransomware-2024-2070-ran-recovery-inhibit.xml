<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2070 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 6acdc537-b149-5f73-88cb-69ab3a7d4968 -->
  <rule id="874685" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2070 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>