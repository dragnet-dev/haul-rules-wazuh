<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5312 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 0af5b5c1-65a3-5c0a-8d84-b8eb507defc3 -->
  <rule id="994652" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5312 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>