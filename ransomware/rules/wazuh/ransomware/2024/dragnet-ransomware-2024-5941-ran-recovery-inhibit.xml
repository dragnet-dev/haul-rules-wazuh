<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5941 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f08d992b-9831-58e1-bc4d-7ca067893e07 -->
  <rule id="714199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5941 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>