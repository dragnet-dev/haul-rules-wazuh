<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4287 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 921f5d12-97fe-5e6b-9561-b18678dc77d8 -->
  <rule id="660253" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4287 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>