<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0168 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: b00e2e2a-fedb-5ad0-b9a2-b50c067e2726 -->
  <rule id="218286" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0168 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>