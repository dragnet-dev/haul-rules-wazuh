<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3624 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: b5e16ccf-37b3-5069-9e93-4b7f656526b7 -->
  <rule id="366668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3624 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>