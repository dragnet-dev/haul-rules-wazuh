<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2312 — Event Log Clearing (killsec) | Status: experimental | Sigma ID: 98f39ff9-ce02-579d-a5aa-9eacb3b15bc6 -->
  <rule id="833439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2312 — Event Log Clearing (killsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>