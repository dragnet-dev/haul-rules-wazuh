<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3518 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7df03b3f-2fbb-5cad-9960-6c17737c6b16 -->
  <rule id="624059" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3518 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>