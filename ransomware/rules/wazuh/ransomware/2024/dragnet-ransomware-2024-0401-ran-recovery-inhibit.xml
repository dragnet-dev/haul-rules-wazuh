<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0401 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 687cb1ab-9328-5598-81f8-031d877fe138 -->
  <rule id="960751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0401 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>