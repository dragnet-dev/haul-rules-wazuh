<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4387 — Recovery Inhibition (ransomcortex) | Status: experimental | Sigma ID: 20349f00-6450-5a8c-96f7-81ad4f2ced43 -->
  <rule id="655990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4387 — Recovery Inhibition (ransomcortex)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>