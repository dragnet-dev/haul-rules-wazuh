<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2478 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 1e391db2-f5b4-5489-bb6a-fdd8201efdf3 -->
  <rule id="680315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2478 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>