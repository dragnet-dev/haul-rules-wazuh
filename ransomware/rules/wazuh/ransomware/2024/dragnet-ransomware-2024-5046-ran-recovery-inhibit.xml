<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5046 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: e3532469-b229-5122-82b7-db190003c194 -->
  <rule id="635324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5046 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>