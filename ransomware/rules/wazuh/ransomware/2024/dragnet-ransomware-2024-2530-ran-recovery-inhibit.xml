<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2530 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b0c48825-54c0-58a7-b123-33f4e5b25147 -->
  <rule id="972488" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2530 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>