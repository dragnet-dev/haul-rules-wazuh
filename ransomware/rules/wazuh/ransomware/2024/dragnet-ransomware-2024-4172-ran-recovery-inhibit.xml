<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4172 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: a96d8496-27a5-53cd-bfae-fc152cfbe46b -->
  <rule id="954984" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4172 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>