<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5027 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 511826cd-56a4-51a7-93cd-30b648fcf8a7 -->
  <rule id="189228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5027 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>