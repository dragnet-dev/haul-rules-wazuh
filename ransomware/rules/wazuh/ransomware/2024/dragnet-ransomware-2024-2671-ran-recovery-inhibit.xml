<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2671 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6c1c5d24-883b-5a48-b8e8-07bb3d04f485 -->
  <rule id="169373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2671 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>