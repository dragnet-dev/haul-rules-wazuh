<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5270 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 88538a8d-2799-5299-af0b-cc6f13b3d213 -->
  <rule id="616618" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5270 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>