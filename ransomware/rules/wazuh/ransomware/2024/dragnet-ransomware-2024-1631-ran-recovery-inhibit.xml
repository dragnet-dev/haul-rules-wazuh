<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1631 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 743ca8c8-cb06-52d6-adce-9bcbf7416202 -->
  <rule id="204108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1631 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>