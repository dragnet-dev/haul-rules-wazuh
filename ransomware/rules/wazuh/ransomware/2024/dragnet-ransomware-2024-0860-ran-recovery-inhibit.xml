<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0860 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 16359008-4d0d-5084-88ff-35ba7f840b78 -->
  <rule id="835900" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0860 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>