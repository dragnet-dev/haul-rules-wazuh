<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1582 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: cd0ac50b-b390-5b69-a688-d1b4edb04530 -->
  <rule id="849725" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1582 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>