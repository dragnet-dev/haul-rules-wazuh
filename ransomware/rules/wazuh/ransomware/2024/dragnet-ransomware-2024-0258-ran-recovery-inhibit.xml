<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0258 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 3f4d4bd3-6966-5fec-9f8f-08711f6604c0 -->
  <rule id="825195" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0258 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>