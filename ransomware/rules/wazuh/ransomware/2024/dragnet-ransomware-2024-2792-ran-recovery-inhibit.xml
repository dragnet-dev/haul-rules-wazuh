<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2792 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7c8e4f76-dd9d-54d9-9a74-3fc70de5709e -->
  <rule id="597199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2792 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>