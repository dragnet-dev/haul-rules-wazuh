<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4821 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: a4d90a5e-81db-5a6d-9fd7-99a89eec7846 -->
  <rule id="984650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4821 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>