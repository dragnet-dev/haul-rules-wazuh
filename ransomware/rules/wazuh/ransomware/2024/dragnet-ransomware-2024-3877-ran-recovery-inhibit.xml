<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3877 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4e4fa13d-6c5e-5c0d-be66-b1a69aee209b -->
  <rule id="309541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3877 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>