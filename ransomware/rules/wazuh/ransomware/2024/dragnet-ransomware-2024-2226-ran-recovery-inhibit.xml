<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2226 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 55647bf4-5571-5dd8-b740-578b132c2849 -->
  <rule id="845823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2226 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>