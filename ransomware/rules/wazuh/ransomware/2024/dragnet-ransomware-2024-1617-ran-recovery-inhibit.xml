<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1617 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 84cc8490-c388-52c2-9529-7a5ec8fd16b9 -->
  <rule id="470884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1617 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>