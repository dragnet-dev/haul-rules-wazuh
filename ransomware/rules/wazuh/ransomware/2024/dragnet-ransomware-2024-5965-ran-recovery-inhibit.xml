<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5965 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ae11ca16-7ddc-5efa-b6f4-2da1f95921ed -->
  <rule id="957418" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5965 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>