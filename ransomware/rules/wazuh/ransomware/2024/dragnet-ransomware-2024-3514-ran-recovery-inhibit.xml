<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3514 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 9c582215-f57a-5ddf-8021-ecbfaf63d1e5 -->
  <rule id="765822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3514 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>