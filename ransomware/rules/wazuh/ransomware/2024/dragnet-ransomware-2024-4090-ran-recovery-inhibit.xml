<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4090 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: cc5b39f2-284a-5149-87ee-8812ee4afd8d -->
  <rule id="673139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4090 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>