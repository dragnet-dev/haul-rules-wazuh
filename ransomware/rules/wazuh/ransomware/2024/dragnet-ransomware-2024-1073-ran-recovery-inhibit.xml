<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1073 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 00253933-b592-5c18-87f0-56544e6816ef -->
  <rule id="562939" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1073 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>