<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1357 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 30d40a48-0c93-5d9b-b8cf-64d2cf22043e -->
  <rule id="794504" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1357 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>