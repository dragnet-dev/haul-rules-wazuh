<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3058 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: d6410b00-b1f3-51b9-bfc5-0afabeb8c584 -->
  <rule id="482571" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3058 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>