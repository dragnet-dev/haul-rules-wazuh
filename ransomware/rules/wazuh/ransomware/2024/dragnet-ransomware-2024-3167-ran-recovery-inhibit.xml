<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3167 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: c2fbbcdd-3995-58a6-b63a-82829353fbdc -->
  <rule id="959836" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3167 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>