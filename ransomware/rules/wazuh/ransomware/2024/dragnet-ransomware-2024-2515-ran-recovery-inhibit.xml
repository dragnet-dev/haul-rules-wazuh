<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2515 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 51f68879-0d3b-523d-9dac-17d2f8387892 -->
  <rule id="316887" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2515 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>