<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5711 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: e07b28a5-2610-5e50-8e31-9f8d58d0b60e -->
  <rule id="552328" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5711 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>