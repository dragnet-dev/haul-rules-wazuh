<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4231 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 463fe3ae-0c09-5f4f-8bf0-4e62e8ef7bda -->
  <rule id="387823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4231 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>