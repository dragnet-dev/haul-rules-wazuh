<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0016 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: d7093e32-b948-5e2d-8282-bfdfa518cf04 -->
  <rule id="493502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0016 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>