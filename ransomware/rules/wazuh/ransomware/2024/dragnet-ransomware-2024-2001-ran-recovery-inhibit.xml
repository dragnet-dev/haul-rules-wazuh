<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2001 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c08564b8-6d5d-5a24-8a9e-f6aae88e4204 -->
  <rule id="408564" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2001 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>