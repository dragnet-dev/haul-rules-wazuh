<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1046 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 33b64e5f-bada-5f9a-90ac-a49e1f717257 -->
  <rule id="634385" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1046 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>