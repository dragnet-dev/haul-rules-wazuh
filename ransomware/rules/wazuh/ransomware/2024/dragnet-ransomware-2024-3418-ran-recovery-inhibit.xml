<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3418 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: ba666cbf-f59c-5fb7-9e2c-23f61583e958 -->
  <rule id="386668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3418 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>