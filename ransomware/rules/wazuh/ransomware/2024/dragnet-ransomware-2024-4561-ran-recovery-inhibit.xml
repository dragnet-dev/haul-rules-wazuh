<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4561 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 373c7283-b4c9-5a99-9a3d-4a9d108b0a6e -->
  <rule id="680728" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4561 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>