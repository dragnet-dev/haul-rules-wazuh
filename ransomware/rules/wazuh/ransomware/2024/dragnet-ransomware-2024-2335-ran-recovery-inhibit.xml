<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2335 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: cad3d889-533b-5664-ba9f-a0a734a7eb16 -->
  <rule id="792618" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2335 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>