<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2476 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0e06dcb1-6c7f-50e2-aefd-fed82175054b -->
  <rule id="462507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2476 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>