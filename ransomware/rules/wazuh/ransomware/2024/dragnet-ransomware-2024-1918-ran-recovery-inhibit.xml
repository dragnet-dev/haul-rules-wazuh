<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1918 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0cc82c39-129d-5756-a47f-9c229e3dfbc4 -->
  <rule id="677243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1918 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>