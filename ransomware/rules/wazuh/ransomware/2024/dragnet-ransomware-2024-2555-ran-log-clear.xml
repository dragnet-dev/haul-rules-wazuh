<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2555 — Event Log Clearing (apt73) | Status: experimental | Sigma ID: d662af18-78d4-51c6-9a9a-cd2893e8d5fd -->
  <rule id="897647" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2555 — Event Log Clearing (apt73)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>