<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2025 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1cc6e716-d19d-5d21-88c0-9f404d14650e -->
  <rule id="271071" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2025 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>