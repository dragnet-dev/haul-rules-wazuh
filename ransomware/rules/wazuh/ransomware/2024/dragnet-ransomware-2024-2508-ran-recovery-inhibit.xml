<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2508 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 20328385-c406-5a11-ba73-7935b19bc349 -->
  <rule id="332838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2508 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>