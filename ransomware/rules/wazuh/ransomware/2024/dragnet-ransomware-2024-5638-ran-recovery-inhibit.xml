<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5638 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 81d313cc-1e6d-53ee-b4a4-3cc76cf2de1e -->
  <rule id="509313" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5638 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>