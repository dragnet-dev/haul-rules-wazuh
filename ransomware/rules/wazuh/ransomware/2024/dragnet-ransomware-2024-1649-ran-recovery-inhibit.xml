<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1649 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 4e48b956-3317-5634-a7b0-a6ab5d8562bf -->
  <rule id="455799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1649 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>