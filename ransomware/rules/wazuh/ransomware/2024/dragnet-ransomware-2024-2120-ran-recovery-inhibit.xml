<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2120 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: d0de37c7-8a80-5be9-a837-66890b1b0f2a -->
  <rule id="750237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2120 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>