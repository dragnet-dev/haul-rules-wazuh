<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1283 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d0a849cb-21f1-5293-81ce-c48f621308ee -->
  <rule id="390849" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1283 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>