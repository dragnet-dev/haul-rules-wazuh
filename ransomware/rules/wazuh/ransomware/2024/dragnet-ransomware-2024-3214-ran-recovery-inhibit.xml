<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3214 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b5e772ff-9d08-5ab4-960e-de476a2511b2 -->
  <rule id="154772" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3214 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>