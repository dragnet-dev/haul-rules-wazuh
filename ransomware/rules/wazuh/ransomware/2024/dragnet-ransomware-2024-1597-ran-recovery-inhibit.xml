<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1597 — Recovery Inhibition (argonauts) | Status: experimental | Sigma ID: c1bce421-209e-52f6-be95-9ab0edf114b4 -->
  <rule id="586384" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1597 — Recovery Inhibition (argonauts)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>