<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0300 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 7d80cf79-ea71-526b-940e-e392593a0d6e -->
  <rule id="620687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0300 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>