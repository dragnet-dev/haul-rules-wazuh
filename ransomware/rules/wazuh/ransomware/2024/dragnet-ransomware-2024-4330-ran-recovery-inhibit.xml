<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4330 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: db30bef6-61e2-505f-a96f-bde9325789ce -->
  <rule id="314270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4330 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>