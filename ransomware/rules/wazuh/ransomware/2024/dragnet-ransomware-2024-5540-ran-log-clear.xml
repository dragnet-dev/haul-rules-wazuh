<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5540 — Event Log Clearing (killsec) | Status: experimental | Sigma ID: afe2d5f4-ef10-5dff-bfa8-a1c9bec0bc83 -->
  <rule id="102855" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5540 — Event Log Clearing (killsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>