<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0119 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c6acd0be-949b-5e7f-b4d1-8e783d373f87 -->
  <rule id="788610" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0119 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>