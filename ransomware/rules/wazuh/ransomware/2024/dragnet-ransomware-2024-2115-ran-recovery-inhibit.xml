<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2115 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 857db532-b5f2-5600-be15-0fc859cd84e4 -->
  <rule id="496115" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2115 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>