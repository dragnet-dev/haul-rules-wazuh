<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2957 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a76ac746-9076-5d8a-b776-daaee2a32d17 -->
  <rule id="156287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2957 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>