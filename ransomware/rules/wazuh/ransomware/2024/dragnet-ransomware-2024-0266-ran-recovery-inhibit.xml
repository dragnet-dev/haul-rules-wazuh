<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0266 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 40e6bfe7-27af-502a-948f-afbd2ab808e5 -->
  <rule id="875967" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0266 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>