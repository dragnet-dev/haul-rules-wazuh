<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0466 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f73d8068-21b6-543d-8a2d-6f9362b5c140 -->
  <rule id="818180" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0466 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>