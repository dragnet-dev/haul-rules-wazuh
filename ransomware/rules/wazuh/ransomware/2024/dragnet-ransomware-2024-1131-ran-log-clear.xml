<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1131 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: 064b6284-7814-5c4d-ad81-d1cab5ff03b2 -->
  <rule id="235628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1131 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>