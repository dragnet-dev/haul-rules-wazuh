<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3172 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7e651dc1-b203-5cb1-8ee5-5119587cff11 -->
  <rule id="326429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3172 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>