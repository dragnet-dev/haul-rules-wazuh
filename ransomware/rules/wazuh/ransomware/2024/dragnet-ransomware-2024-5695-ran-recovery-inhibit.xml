<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5695 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 87fe2718-ea13-58e3-879c-0c250d239bd5 -->
  <rule id="552627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5695 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>