<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0740 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 63043391-3835-535e-8d8e-40947c4e6bab -->
  <rule id="104339" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0740 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>