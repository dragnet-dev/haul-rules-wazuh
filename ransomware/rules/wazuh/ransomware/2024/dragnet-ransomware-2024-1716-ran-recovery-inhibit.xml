<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1716 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4d073c09-97e6-5a14-88b3-3ab3d175fe68 -->
  <rule id="433180" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1716 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>