<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2739 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 51279a55-b0e9-5856-8697-ec58f9381013 -->
  <rule id="204745" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2739 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>