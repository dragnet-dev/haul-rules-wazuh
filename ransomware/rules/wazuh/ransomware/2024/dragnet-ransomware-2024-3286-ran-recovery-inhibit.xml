<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3286 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 0f110896-3967-5084-94a6-dee7fd52a683 -->
  <rule id="711089" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3286 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>