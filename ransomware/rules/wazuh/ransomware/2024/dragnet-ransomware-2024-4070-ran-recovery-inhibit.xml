<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4070 — Recovery Inhibition (insane) | Status: experimental | Sigma ID: 17bc13ac-7ab1-52b0-aaeb-63f13c5f38a9 -->
  <rule id="164218" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4070 — Recovery Inhibition (insane)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>