<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0350 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f5df045a-71ff-5fe2-a3b4-ce240795a914 -->
  <rule id="490304" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0350 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>