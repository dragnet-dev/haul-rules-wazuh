<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2989 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 8aa8b1c2-ce41-5eea-8a5c-8c1c1bd4cb11 -->
  <rule id="950191" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2989 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>