<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1313 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: fd24ca0b-ac6f-5f0f-9d98-8b5f5aa90a65 -->
  <rule id="283146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1313 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>