<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5649 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 5c513379-83a2-519f-933c-4146b2a33edf -->
  <rule id="351337" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5649 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>