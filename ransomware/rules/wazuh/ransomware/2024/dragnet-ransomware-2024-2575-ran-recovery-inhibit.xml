<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2575 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 2fd009d1-1382-5f8b-b32c-70d6288b3e01 -->
  <rule id="640157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2575 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>