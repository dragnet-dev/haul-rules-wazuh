<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1824 — Event Log Clearing (cicada3301) | Status: experimental | Sigma ID: ee01c96a-9f2b-5934-81a1-4c48d57b2a70 -->
  <rule id="308289" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1824 — Event Log Clearing (cicada3301)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>