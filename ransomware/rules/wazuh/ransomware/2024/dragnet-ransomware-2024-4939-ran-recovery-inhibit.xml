<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4939 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 1fb335e0-5da6-5800-90fe-617e86b6f7e3 -->
  <rule id="117374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4939 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>