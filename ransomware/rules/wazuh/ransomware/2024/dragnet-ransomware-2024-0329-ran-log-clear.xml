<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0329 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 79ca9f84-e8d6-512f-9c22-4b9caea42cc5 -->
  <rule id="668319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0329 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>