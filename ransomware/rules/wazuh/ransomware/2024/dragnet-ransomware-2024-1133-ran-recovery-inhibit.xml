<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1133 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a5ecd660-ab96-5282-85ef-8634b60aec71 -->
  <rule id="838696" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1133 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>