<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1115 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 1f8ee88b-d285-507b-a5bf-30983310c604 -->
  <rule id="164688" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1115 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>