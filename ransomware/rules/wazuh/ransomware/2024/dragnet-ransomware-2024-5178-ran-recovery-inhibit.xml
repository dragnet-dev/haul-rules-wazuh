<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5178 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 27182aed-5107-58ac-a8d8-67dcb1c878b8 -->
  <rule id="758766" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5178 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>