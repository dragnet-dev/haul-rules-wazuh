<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5435 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: fc2e56b6-968e-5126-abe3-595112eb0bd9 -->
  <rule id="536656" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5435 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>