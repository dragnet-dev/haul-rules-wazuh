<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5453 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b5693312-3d9a-58e8-b314-b07babbbbae7 -->
  <rule id="356933" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5453 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>