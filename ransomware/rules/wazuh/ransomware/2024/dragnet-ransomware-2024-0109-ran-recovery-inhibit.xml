<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0109 — Recovery Inhibition (ElDorado) | Status: experimental | Sigma ID: a255be6c-2fde-54ca-b2f5-ba7ea5005591 -->
  <rule id="925470" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0109 — Recovery Inhibition (ElDorado)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>