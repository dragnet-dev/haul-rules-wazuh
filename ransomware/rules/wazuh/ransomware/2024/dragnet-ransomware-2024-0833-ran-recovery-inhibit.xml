<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0833 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6ced3be2-afe6-5f75-a849-77d9c3e17b98 -->
  <rule id="961659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0833 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>