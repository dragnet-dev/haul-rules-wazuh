<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5822 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 79037bb5-3f72-5609-8183-1357c622185f -->
  <rule id="464603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5822 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>