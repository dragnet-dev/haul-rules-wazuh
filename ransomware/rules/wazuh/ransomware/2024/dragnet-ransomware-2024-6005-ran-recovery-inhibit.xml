<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6005 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7062c055-f1f3-54e9-a1b6-c40d7a004030 -->
  <rule id="330040" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6005 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>