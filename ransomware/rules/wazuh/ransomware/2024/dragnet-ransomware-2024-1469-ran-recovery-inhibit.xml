<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1469 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 1311eb25-6d6b-548a-bbca-f04dc28233f9 -->
  <rule id="758512" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1469 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>