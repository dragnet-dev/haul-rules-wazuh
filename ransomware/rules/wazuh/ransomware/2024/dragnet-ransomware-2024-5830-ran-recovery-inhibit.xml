<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5830 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 0f9bf564-95b1-5bc0-b6be-ace977b3a0ee -->
  <rule id="589556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5830 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>