<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3453 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: b75d659b-c5f1-5e6f-aedb-e6af57032215 -->
  <rule id="181365" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3453 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>