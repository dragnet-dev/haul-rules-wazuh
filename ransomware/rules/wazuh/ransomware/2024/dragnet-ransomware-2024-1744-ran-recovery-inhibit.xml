<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1744 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f8f8b4f6-7df4-51cd-bb97-bba54c1defdd -->
  <rule id="570194" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1744 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>