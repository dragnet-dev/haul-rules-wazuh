<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1573 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0db639db-a75a-533c-90b0-65d9d33e3d15 -->
  <rule id="914237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1573 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>