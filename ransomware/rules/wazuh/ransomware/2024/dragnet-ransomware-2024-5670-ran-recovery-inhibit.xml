<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5670 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: fa7911f4-3c54-5bef-b37d-5ac8c9aa08c8 -->
  <rule id="807911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5670 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>