<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5177 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 8e8c7bd7-265c-5702-934f-299b3e30ba2e -->
  <rule id="157723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5177 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>