<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5549 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: c6517c16-c869-5e79-9036-89b542538323 -->
  <rule id="324284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5549 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
