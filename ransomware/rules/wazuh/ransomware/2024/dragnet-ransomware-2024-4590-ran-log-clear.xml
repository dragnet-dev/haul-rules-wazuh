<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4590 — Event Log Clearing (spacebears) | Status: experimental | Sigma ID: 7c4f605c-c4f8-5b95-a4cc-5fc6d67ff0f4 -->
  <rule id="291960" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4590 — Event Log Clearing (spacebears)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>