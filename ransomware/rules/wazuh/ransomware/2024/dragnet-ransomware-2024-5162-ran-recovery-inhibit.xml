<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5162 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: de20711d-55db-5dd1-ba88-e5812a6de923 -->
  <rule id="522071" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5162 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>