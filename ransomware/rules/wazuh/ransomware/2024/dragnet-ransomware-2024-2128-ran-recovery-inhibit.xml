<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2128 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 40c1f515-035e-54ac-9225-0cfb7b86a8d2 -->
  <rule id="243515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2128 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>