<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5271 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: cb8a2a39-a077-55f0-8bf2-f41d8ec3e2d5 -->
  <rule id="818922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5271 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>