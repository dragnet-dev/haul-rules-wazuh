<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1264 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 1cf21bfd-6d3f-574e-bc1c-892f0c6635c6 -->
  <rule id="258367" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1264 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>