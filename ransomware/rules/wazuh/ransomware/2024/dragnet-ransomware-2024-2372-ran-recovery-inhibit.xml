<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2372 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: fd777593-5468-5250-a765-06299a5b6724 -->
  <rule id="837775" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2372 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>