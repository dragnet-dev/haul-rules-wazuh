<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0518 — Event Log Clearing (handala) | Status: experimental | Sigma ID: 587847ce-ff2e-5935-b983-c9db8911071c -->
  <rule id="505564" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0518 — Event Log Clearing (handala)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>