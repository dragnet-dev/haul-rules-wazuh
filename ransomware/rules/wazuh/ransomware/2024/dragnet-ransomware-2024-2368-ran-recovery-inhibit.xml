<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2368 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: c23c6508-59bd-5a81-aca6-2a1850807b11 -->
  <rule id="258065" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2368 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>