<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3082 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5da3b9cb-4a9f-5d6d-89cc-2993e0ce6343 -->
  <rule id="697399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3082 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>