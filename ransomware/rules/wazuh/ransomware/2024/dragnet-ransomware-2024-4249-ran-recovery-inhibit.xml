<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4249 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: d13ada02-4421-5157-996d-4353de92867a -->
  <rule id="980826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4249 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>