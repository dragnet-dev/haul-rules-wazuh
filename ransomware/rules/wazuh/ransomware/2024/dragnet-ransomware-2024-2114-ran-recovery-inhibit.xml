<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2114 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 562e82e7-1388-5173-bc53-e40178ada05d -->
  <rule id="110926" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2114 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>