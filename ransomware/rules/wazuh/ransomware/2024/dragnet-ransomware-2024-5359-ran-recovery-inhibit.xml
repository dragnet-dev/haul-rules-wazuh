<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5359 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f9902b07-65ff-5924-a4a9-e5cdd12855bb -->
  <rule id="858443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5359 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>