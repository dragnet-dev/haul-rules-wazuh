<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2008 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c6e46008-8390-5ec4-b3ae-d3479d3acf85 -->
  <rule id="330460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2008 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>