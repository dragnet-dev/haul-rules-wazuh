<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4496 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 9526e846-bc54-5fa6-b222-1e218164930c -->
  <rule id="724308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4496 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>