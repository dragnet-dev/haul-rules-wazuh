<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5631 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: b2172c88-ebdb-5e9c-ba66-92e53894dea2 -->
  <rule id="994764" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5631 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>