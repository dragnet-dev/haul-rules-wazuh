<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4084 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: a07d8f63-5b22-5c36-b58d-0fc66eb971bf -->
  <rule id="880143" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4084 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>