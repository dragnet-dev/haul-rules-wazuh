<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5167 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 74d6d0e2-663d-5b5f-a032-392a26f35dd9 -->
  <rule id="216290" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5167 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>