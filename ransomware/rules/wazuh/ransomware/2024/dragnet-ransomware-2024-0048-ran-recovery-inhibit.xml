<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0048 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 613309b4-b31c-57a9-83d3-531ec388cc33 -->
  <rule id="912955" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0048 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>