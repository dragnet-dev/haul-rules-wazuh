<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4433 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: df7a6712-9285-51fd-a004-4a16f14e1e83 -->
  <rule id="980267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4433 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>