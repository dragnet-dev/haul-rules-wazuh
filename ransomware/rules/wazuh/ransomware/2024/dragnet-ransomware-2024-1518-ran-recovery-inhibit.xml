<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1518 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: 59f9b044-9f5e-5ed6-b851-bc2166fae484 -->
  <rule id="735950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1518 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>