<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0951 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 562eec56-0676-53d5-b86b-bb759d1b2978 -->
  <rule id="605772" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0951 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>