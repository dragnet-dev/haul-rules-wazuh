<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4830 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: cee71556-30a9-5b84-b3b8-d9dfc5f1d263 -->
  <rule id="710715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4830 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>