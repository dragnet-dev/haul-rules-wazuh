<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4983 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 523181c3-5306-5f02-8a7d-0d1e1ccf315f -->
  <rule id="370908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4983 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>