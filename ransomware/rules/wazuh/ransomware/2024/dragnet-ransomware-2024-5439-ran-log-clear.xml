<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5439 — Event Log Clearing (monti) | Status: experimental | Sigma ID: cbe2e517-c050-558c-b1b8-f9542d2390ad -->
  <rule id="819665" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5439 — Event Log Clearing (monti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>