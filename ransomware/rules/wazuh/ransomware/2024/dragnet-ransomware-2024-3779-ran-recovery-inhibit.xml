<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3779 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 59e6dad7-e01d-5a81-bcae-0307250ce224 -->
  <rule id="754234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3779 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>