<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0535 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7cab03c9-8e7c-5c2a-91b0-c41848731dee -->
  <rule id="591503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0535 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>