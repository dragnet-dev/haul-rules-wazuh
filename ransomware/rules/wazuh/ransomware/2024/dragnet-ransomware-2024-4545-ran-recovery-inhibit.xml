<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4545 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: a02fb4b7-f195-550c-bf02-5d74828db944 -->
  <rule id="867634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4545 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>