<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0308 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: faba1921-6073-58ca-a3a8-64735fa5c004 -->
  <rule id="218619" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0308 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>