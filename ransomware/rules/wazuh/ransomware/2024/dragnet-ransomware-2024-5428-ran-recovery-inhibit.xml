<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5428 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 910814f7-b089-5c44-b04c-d5d32c19803c -->
  <rule id="273039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5428 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>