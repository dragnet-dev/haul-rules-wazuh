<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1382 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: dbe4f751-5445-5053-a047-d2851b35a843 -->
  <rule id="329597" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1382 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>