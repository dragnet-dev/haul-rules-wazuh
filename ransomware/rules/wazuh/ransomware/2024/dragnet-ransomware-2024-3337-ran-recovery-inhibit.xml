<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3337 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: f1ad0b70-1b10-5012-9ead-fb184e140a62 -->
  <rule id="912651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3337 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>