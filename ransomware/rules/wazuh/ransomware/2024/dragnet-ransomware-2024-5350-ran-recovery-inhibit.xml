<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5350 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: a3e83098-f5df-503f-84f4-35343d816691 -->
  <rule id="862830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5350 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>