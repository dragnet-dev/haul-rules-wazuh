<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2308 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e8577deb-dc89-59f0-a334-c41de74d9703 -->
  <rule id="677245" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2308 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>