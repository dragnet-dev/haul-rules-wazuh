<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4392 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: eb4fb26e-8120-5acf-b75b-21148f3dfad0 -->
  <rule id="728752" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4392 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>