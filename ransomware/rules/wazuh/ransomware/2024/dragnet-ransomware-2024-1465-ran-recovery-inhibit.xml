<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1465 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5f62d80e-0e56-582f-8de3-22131afc8137 -->
  <rule id="730058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1465 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>