<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1151 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4d8df2da-47a1-5e85-94c3-a7e04278b031 -->
  <rule id="293912" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1151 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>