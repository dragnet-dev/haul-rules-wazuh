<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5721 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: fb9f2e47-473b-5088-9250-cd65b64d9cda -->
  <rule id="251086" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5721 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>