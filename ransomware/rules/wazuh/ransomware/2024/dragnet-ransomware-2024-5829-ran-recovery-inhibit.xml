<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5829 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 26436dfa-bad5-5423-8dce-f8753383381f -->
  <rule id="567839" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5829 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>