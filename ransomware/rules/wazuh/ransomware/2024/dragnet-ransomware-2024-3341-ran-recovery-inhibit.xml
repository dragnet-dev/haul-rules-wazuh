<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3341 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: fe152442-5c18-5194-b0bc-54fdf30b0766 -->
  <rule id="841524" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3341 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>