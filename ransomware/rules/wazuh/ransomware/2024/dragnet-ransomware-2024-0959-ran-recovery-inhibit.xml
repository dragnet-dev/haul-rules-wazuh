<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0959 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 5db5cafc-cdcf-5a24-a7a2-c006a1fade07 -->
  <rule id="338922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0959 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>