<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0277 — Event Log Clearing (alphalocker) | Status: experimental | Sigma ID: 20bfc518-0c36-58ed-90bc-0ec64bf4ec5b -->
  <rule id="498851" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0277 — Event Log Clearing (alphalocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>