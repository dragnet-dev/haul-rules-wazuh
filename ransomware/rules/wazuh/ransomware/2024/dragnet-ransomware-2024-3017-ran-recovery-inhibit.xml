<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3017 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 7e3cccbd-8c0f-50bf-95f0-420ab3621c8a -->
  <rule id="776524" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3017 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>