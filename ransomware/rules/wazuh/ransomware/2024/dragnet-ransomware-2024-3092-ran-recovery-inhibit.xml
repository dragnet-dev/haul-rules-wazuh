<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3092 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7395bc3d-10c8-5b9a-b462-4574bd21b840 -->
  <rule id="193308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3092 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>