<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2910 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 214a56af-79f9-5adc-9835-80e3fd06e914 -->
  <rule id="195306" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2910 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>