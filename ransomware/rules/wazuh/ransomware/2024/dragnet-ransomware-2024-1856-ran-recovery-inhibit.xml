<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1856 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 2d14b488-f7ca-5073-a540-180e807b8ea5 -->
  <rule id="123548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1856 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>