<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3230 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: 5a667753-5787-5385-9b7b-bcf66567a5a1 -->
  <rule id="166775" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3230 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>