<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2709 — Recovery Inhibition (werewolves) | Status: experimental | Sigma ID: 1e1083db-d564-5cc3-8898-52e33fad661d -->
  <rule id="417341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2709 — Recovery Inhibition (werewolves)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>