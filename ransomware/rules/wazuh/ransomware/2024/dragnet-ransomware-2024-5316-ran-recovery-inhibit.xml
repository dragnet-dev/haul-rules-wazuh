<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5316 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d272332f-4b8c-54ed-b238-9efe11718124 -->
  <rule id="527233" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5316 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>