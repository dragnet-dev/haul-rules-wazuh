<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3968 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7977fb87-41bb-505b-aeb5-135e205e0f93 -->
  <rule id="342363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3968 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>