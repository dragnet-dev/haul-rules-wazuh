<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2816 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d8dd644b-ebf9-550f-8957-6894435d3402 -->
  <rule id="954964" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2816 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>