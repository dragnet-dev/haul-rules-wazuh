<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4380 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: c4f72b19-f98e-505a-a4b1-9217c777aee7 -->
  <rule id="599563" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4380 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>