<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5165 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 50549c32-0c5c-5812-8f35-9233af6db14f -->
  <rule id="987963" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5165 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>