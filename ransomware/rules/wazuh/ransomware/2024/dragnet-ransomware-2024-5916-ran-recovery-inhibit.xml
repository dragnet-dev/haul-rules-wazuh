<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5916 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5f48e9ae-654a-5514-a780-e7550f8122b9 -->
  <rule id="727829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5916 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>