<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5725 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6917eb85-9ae7-5ff4-96cc-fde8e766c1f3 -->
  <rule id="970987" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5725 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>