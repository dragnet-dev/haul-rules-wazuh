<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4356 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 35223458-0f01-5bc7-8611-8479ca07c00e -->
  <rule id="922345" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4356 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>