<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0312 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 0946a8db-9c74-5fca-a9f3-06007727dd81 -->
  <rule id="723501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0312 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>