<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5608 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: a491a4fa-da7a-5460-bc67-8b1a5d755af9 -->
  <rule id="878664" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5608 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>