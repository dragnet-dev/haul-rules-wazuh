<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5972 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: f009df7c-6a7d-5029-9b96-f26021a1e6f3 -->
  <rule id="342527" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5972 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>