<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0253 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: e2a59575-32d7-5ff1-8c7f-164ee08edd2e -->
  <rule id="582595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0253 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>