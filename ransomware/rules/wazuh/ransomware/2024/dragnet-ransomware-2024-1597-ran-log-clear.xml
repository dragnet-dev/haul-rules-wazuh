<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1597 — Event Log Clearing (argonauts) | Status: experimental | Sigma ID: 071efc43-af4d-5bb9-95aa-a8afd76c1cd8 -->
  <rule id="346524" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1597 — Event Log Clearing (argonauts)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>