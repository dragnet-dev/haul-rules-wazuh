<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5967 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 02a2699c-429f-51bf-a662-09fdde09d16c -->
  <rule id="563196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5967 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>