<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0450 — Recovery Inhibition (ElDorado) | Status: experimental | Sigma ID: 99522889-018c-5bf3-99df-3aee0fc8beea -->
  <rule id="152288" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0450 — Recovery Inhibition (ElDorado)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>