<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1067 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 7cb1c6e5-ee37-54cc-a7eb-8b263bd4aa2d -->
  <rule id="592286" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1067 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>