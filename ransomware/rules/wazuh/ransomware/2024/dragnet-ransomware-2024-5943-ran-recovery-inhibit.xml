<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5943 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 2f976e6e-381d-5d02-b857-3dd4323cedf9 -->
  <rule id="576306" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5943 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>