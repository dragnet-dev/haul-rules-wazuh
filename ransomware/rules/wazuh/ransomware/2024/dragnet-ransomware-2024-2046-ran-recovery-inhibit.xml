<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2046 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 0ffd3aa8-0bf8-50d5-9992-10c2ee31be07 -->
  <rule id="679018" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2046 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>