<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0089 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: 5aa62f2a-75aa-57e2-8110-7b989ecdf9be -->
  <rule id="621007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0089 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>