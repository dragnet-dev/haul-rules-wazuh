<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1068 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: b02a627e-8187-503e-b775-0801b4287b58 -->
  <rule id="964262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1068 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>