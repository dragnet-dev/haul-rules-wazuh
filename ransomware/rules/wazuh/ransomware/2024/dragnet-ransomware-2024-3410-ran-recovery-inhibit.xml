<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3410 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5d9e5678-9cb1-5b11-83b7-344710cedd90 -->
  <rule id="703856" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3410 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>