<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0791 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 47bedee2-30aa-5feb-bd43-9af2e80ae172 -->
  <rule id="529054" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0791 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>