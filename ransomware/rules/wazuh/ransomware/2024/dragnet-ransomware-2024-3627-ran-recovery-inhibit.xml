<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3627 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c181b6a4-c4f0-551c-b406-dd952aae4442 -->
  <rule id="249076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3627 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>