<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1943 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 64da5521-7810-5104-8fb2-169771672946 -->
  <rule id="860255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1943 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>