<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0823 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: c7921157-efd1-5636-a33f-4f692e26f388 -->
  <rule id="479211" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0823 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>