<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0341 — Recovery Inhibition (play) | Status: experimental | Sigma ID: fb6d1e36-68e1-5ec1-9c4a-fb9e5bfda3c3 -->
  <rule id="243070" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0341 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>