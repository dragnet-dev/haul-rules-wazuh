<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4030 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e649e11f-8e25-5a43-a253-2aa4bc710863 -->
  <rule id="643981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4030 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>