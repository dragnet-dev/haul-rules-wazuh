<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2409 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: 097e731a-b56d-519c-b5e8-03416bd5a0d4 -->
  <rule id="766731" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2409 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>