<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0594 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7cad0588-528d-5e13-8b15-6cb166442dde -->
  <rule id="591705" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0594 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>