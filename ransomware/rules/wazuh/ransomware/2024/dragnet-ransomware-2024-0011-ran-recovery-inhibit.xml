<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0011 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 3189f001-ef79-533d-9455-e061f5b861a7 -->
  <rule id="703900" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0011 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>