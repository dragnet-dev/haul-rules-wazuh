<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2344 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: d62d26b6-8b40-536f-bfb4-bbdbedff04ad -->
  <rule id="480526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2344 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>