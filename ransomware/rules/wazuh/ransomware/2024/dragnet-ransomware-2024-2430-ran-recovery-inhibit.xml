<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2430 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 152bb7fa-f97a-5cf6-ae16-56793c390f2e -->
  <rule id="955967" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2430 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>