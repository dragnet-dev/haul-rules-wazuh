<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1430 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 78d75137-8084-5c55-9e8f-df8b0dc577fd -->
  <rule id="461751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1430 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>