<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4854 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: ed69b9da-b66a-5307-81bc-d53a479b9d0f -->
  <rule id="303159" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4854 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>