<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3657 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 3c210dd5-7cb4-52e0-8cc0-291b4c3880dc -->
  <rule id="213981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3657 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>