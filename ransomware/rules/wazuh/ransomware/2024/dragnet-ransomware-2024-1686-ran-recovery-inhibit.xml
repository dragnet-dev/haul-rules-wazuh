<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1686 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 6ee76ec2-9403-5fa6-b7df-d4d665df9cfc -->
  <rule id="239630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1686 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>