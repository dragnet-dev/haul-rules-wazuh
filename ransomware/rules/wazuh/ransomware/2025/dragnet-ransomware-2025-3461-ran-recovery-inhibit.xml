<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3461 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 468cdd1c-494a-5cb6-8d8e-b7e01ccb1019 -->
  <rule id="220221" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3461 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>