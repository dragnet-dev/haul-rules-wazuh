<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7244 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 084a31e5-e7f9-54a4-9a41-e27ae6038146 -->
  <rule id="466910" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7244 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>