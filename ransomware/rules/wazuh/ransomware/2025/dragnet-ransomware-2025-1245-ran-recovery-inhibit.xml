<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1245 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: bde786dd-2892-57f5-8a6a-a7227aaff947 -->
  <rule id="438786" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1245 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>