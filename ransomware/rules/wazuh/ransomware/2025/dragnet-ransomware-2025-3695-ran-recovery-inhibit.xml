<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3695 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 11705129-3f0c-5881-b226-e788f18719dc -->
  <rule id="370512" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3695 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>