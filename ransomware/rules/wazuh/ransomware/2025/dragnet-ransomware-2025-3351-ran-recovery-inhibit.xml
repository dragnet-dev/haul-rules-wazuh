<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3351 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 35b49573-5f13-59d1-a490-927fdd6d1fa7 -->
  <rule id="414957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3351 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>