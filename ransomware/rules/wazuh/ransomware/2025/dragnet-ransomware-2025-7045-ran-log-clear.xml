<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7045 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: e6507f73-17eb-55f9-bb4e-e0dd25cd9552 -->
  <rule id="644127" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7045 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>