<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5580 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 8840fe57-d51f-592d-ab46-d1ea1ebb94aa -->
  <rule id="563294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5580 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>