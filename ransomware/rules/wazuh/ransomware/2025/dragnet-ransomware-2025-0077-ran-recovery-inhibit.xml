<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0077 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 968c23e8-f75e-53a7-acd1-91dc696710a5 -->
  <rule id="750023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0077 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>