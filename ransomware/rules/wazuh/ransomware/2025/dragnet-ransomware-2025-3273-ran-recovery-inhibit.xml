<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3273 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 4f7b8bb2-215b-5047-8398-65bfdea00303 -->
  <rule id="342219" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3273 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>