<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1518 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: c15679a4-ca93-5e76-a761-d718d13a6b05 -->
  <rule id="415679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1518 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>