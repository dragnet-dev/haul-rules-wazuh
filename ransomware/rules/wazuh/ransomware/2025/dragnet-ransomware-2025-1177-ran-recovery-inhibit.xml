<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1177 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: c5e1f8fd-2acc-5d9d-b6f2-17a5bdd64114 -->
  <rule id="622718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1177 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>