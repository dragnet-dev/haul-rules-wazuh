<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6251 — Recovery Inhibition (ralord) | Status: experimental | Sigma ID: f456f7b2-4446-5067-8dde-b87e0d5e458e -->
  <rule id="773117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6251 — Recovery Inhibition (ralord)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>