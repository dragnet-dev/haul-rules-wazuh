<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3064 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 9482a448-c775-594d-8b08-b2beead2f4ea -->
  <rule id="717224" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3064 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>