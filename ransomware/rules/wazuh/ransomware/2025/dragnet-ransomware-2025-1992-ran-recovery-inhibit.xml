<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1992 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 6971307f-e8f1-5283-b5f6-c450c5d2f40b -->
  <rule id="771307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1992 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>