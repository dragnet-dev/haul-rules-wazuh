<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0465 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 33e3ef42-0f4c-5e5e-8651-5ccf47e6c5e9 -->
  <rule id="588527" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0465 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>