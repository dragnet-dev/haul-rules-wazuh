<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4832 — Recovery Inhibition (warlock) | Status: experimental | Sigma ID: 904a1f52-8a78-553b-bf49-15a57681d525 -->
  <rule id="615871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4832 — Recovery Inhibition (warlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>