<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0701 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: d9e9796f-3ad9-5a27-9a4a-00387a2e0db9 -->
  <rule id="538979" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0701 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>