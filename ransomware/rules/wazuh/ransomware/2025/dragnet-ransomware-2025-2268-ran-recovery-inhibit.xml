<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2268 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: d7cca6dd-3a7a-5d2c-bbbe-b74b30b5968a -->
  <rule id="344266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2268 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>