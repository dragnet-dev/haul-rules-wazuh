<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4818 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 35c0e48e-33d3-50ae-8a35-ffc4fcd296df -->
  <rule id="253448" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4818 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>