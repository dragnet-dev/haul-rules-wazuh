<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7159 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 5296c076-0a79-5a7e-9d78-2866c44d9c69 -->
  <rule id="474807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7159 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>