<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4574 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 972c8711-d1b8-5f4c-86b4-f31788165034 -->
  <rule id="756487" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4574 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>