<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6151 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: c9769db9-e0c4-5f29-8723-3b4a3e471cbf -->
  <rule id="376317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6151 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>