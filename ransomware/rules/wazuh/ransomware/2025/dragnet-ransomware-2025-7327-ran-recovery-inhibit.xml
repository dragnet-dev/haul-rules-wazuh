<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7327 — Recovery Inhibition (qilin) | Status: test | Sigma ID: f80da5d5-14e9-5fa8-9142-6be57551e7db -->
  <rule id="546985" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7327 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>