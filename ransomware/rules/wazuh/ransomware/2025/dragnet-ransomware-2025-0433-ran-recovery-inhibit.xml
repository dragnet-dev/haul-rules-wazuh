<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0433 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 357f8809-2f29-5d4b-af98-3ac67d069d50 -->
  <rule id="427880" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0433 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>