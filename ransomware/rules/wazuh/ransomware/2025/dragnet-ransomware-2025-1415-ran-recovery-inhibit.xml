<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1415 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 974ec662-c84f-5963-8455-b42701f7dc05 -->
  <rule id="795806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1415 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>