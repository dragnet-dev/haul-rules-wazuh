<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3550 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: e89da0ec-849d-5577-8fab-7a562778fa77 -->
  <rule id="314020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3550 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>