<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6348 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 4447d496-6796-562c-ae5b-6a5ed6635b25 -->
  <rule id="916549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6348 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>