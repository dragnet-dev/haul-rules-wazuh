<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0661 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 60b94007-bae7-5a2c-9e8e-a2f25f4cbdf1 -->
  <rule id="819400" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0661 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>