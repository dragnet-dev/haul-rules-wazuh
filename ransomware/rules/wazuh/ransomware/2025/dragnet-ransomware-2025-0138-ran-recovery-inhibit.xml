<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0138 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: aa8776a7-ca2b-5195-ab03-0e997a4a73a3 -->
  <rule id="908776" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0138 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>