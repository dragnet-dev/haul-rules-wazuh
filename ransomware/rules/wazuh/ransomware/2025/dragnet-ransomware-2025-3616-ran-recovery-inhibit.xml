<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3616 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 14e66a5a-1a04-5c4d-b407-f0a08b198953 -->
  <rule id="318665" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3616 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>