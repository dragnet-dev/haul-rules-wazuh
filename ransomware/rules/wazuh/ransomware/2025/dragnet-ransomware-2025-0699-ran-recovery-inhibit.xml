<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0699 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 562f0ad9-197d-5cf6-8908-63033acacd0d -->
  <rule id="641130" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0699 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
