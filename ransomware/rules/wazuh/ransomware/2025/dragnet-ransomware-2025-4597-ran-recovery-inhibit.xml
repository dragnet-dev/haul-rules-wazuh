<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4597 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: 3ff5354f-35a4-5716-ae18-ca52b87dcf5a -->
  <rule id="223535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4597 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>