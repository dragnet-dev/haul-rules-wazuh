<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0050 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: fe5523fa-0791-5476-b704-240a476b7f0d -->
  <rule id="845523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0050 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>