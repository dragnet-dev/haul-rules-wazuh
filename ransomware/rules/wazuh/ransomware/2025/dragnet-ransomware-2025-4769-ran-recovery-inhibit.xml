<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4769 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: d0e2ba28-85ca-53e2-921c-57c2f8cca473 -->
  <rule id="961338" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4769 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>