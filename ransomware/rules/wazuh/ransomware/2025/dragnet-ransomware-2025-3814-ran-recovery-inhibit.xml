<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3814 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 75de055b-aaee-583b-ac77-773756697d7f -->
  <rule id="242205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3814 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>