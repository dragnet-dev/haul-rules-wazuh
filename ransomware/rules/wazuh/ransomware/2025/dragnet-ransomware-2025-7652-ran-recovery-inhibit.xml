<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7652 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 626fcbe2-dbcd-5dd2-a74d-8156beb3c3c4 -->
  <rule id="868139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7652 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>