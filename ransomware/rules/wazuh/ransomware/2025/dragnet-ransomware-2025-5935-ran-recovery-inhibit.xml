<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5935 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 556b7e6f-37d8-5835-a5ca-4f3715500290 -->
  <rule id="625246" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5935 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>