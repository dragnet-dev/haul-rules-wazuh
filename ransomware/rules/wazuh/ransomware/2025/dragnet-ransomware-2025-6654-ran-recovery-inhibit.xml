<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6654 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 44b81054-1bb3-5e16-9458-fd9b6592b0d7 -->
  <rule id="958105" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6654 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>