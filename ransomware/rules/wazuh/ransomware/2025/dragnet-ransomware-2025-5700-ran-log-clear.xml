<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5700 — Event Log Clearing (devman) | Status: experimental | Sigma ID: 3ec5a2ee-4314-5dbf-a4db-b6a8134d1c99 -->
  <rule id="807302" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5700 — Event Log Clearing (devman)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>