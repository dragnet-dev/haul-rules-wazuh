<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2384 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d90a62d8-b579-5f75-9be8-e3e4a5014419 -->
  <rule id="525062" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2384 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>