<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6979 — Recovery Inhibition (securotrop) | Status: experimental | Sigma ID: 15084b6d-7579-577b-b73b-207ab2f82a41 -->
  <rule id="713556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6979 — Recovery Inhibition (securotrop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>