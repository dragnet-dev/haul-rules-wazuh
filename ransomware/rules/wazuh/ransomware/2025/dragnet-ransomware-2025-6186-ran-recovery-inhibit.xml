<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6186 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a7042f5c-c5c0-516f-9888-927f19f6a7dc -->
  <rule id="912687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6186 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>