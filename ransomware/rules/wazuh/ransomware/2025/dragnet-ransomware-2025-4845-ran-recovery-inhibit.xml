<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4845 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 0a639470-378c-5723-8023-50869c434420 -->
  <rule id="263947" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4845 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>