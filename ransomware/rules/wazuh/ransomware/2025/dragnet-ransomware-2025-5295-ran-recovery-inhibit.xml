<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5295 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: f4f86983-13cf-50e5-95e4-03a68822b08b -->
  <rule id="779869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5295 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>