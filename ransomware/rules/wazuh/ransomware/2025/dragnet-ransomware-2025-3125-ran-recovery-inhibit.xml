<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3125 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: e57ea16b-e9cb-5927-9f2e-6b36d2caadb6 -->
  <rule id="232261" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3125 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>