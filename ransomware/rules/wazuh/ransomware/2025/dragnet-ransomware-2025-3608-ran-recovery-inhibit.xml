<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3608 — Recovery Inhibition (warlock) | Status: deprecated | Sigma ID: 5f851ef8-eba1-5df1-878c-75b0925cfa64 -->
  <rule id="733630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3608 — Recovery Inhibition (warlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>