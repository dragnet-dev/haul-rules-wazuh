<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0191 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ed8b7fdd-27d8-5a3b-8ae1-b391559eb240 -->
  <rule id="789567" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0191 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>