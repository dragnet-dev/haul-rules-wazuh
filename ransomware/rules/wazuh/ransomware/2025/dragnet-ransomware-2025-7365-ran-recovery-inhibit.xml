<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7365 — Recovery Inhibition (weyhro) | Status: experimental | Sigma ID: 1aadd108-4964-59e5-bb75-7b7b3ad3ccc0 -->
  <rule id="292771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7365 — Recovery Inhibition (weyhro)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>