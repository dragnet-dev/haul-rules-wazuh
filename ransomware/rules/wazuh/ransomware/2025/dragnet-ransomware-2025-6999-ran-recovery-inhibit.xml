<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6999 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: b7f9af10-94d0-5049-a712-88a561efad83 -->
  <rule id="433199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6999 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>