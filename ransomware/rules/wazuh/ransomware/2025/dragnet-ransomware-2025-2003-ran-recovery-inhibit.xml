<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2003 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d26af3a2-dde7-506b-b137-f2328d6d26c2 -->
  <rule id="796313" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2003 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>