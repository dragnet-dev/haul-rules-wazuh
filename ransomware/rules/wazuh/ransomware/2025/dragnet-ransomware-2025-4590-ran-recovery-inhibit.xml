<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4590 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 651d1f1b-458b-5207-89a2-a7f88ef148ce -->
  <rule id="868671" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4590 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>