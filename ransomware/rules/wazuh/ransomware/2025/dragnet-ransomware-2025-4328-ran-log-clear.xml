<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4328 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 6a3ff0b6-2eac-5fae-95a3-b0c9b15e8b5d -->
  <rule id="123830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4328 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>