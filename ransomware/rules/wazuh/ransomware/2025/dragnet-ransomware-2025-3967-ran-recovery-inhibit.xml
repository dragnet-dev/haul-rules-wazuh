<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3967 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: ef23e377-f29a-50e1-978d-370458d0a459 -->
  <rule id="327823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3967 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>