<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2919 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: b52ab8ce-0364-5909-9e45-a72a8512cf78 -->
  <rule id="350838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2919 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>