<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1882 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: e94e66de-dbaa-5e3f-9102-fc5245004b4f -->
  <rule id="691866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1882 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>