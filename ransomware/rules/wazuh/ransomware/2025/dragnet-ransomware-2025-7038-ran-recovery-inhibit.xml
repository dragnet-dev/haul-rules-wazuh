<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7038 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: b4299432-df1c-58ee-a839-cff76723ce01 -->
  <rule id="342994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7038 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>