<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0002 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 819fad84-874d-51cb-9ac1-257796ad2039 -->
  <rule id="758637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0002 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>