<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3262 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 7f5ece53-f1ab-5ae8-8324-f2fb973c5b0e -->
  <rule id="826190" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3262 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>