<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6314 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 5daef6f2-660d-5130-9c40-b4299e164383 -->
  <rule id="337276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6314 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>