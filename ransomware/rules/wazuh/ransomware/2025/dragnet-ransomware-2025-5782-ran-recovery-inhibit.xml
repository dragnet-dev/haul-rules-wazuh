<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5782 — Recovery Inhibition (devman) | Status: deprecated | Sigma ID: e3e83358-c43b-594c-a14b-28583b82022f -->
  <rule id="602833" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5782 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>