<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4123 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: e4ae1aa6-1d30-543f-8645-0987b8aa5554 -->
  <rule id="626106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4123 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>