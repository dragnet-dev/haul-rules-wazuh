<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3149 — Event Log Clearing (coinbasecartel) | Status: experimental | Sigma ID: af47944e-4f59-5f5b-9ad3-ecea1a7865b7 -->
  <rule id="954794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3149 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>