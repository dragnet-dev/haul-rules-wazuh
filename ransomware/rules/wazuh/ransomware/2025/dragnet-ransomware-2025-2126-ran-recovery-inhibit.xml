<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2126 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f917a7f0-ba37-53cf-8933-93e5eed34484 -->
  <rule id="846827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2126 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>