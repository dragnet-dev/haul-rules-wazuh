<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6146 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 94812097-0cb9-5a93-a805-94f4fad23459 -->
  <rule id="581209" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6146 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>