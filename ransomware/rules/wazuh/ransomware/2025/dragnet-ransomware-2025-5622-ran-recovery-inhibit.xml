<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5622 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b2889689-6d63-5e3c-9ed8-fb850b594564 -->
  <rule id="328896" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5622 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>