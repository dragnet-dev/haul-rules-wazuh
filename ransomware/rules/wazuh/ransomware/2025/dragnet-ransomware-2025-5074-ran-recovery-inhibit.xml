<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5074 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 11c8e022-6232-5963-8db4-23b356a87d1e -->
  <rule id="422202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5074 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>