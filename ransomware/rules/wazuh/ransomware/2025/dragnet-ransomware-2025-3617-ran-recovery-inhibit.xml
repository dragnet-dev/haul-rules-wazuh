<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3617 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 99af8a63-9a81-59cd-8440-8944cd5042c0 -->
  <rule id="583178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3617 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>