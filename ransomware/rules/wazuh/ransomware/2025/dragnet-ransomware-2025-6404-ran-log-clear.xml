<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6404 — Event Log Clearing (lynx) | Status: experimental | Sigma ID: d13ae88b-6528-5ecf-8e79-7bfa12f1c9f8 -->
  <rule id="763028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6404 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>