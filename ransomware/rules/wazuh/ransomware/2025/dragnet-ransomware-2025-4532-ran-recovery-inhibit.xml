<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4532 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: ba2e814c-a598-56bb-a7d5-0255dc2d7694 -->
  <rule id="380681" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4532 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>