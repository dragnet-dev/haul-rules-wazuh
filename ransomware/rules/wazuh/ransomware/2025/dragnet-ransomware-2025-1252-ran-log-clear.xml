<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1252 — Event Log Clearing (kawa4096) | Status: deprecated | Sigma ID: f00e0f1f-d268-5e50-a814-6bb0cf82f680 -->
  <rule id="342255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1252 — Event Log Clearing (kawa4096)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>