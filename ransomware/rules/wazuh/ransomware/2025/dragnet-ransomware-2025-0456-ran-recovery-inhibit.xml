<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0456 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: c49d958e-b9f4-51af-9fbd-7d18232c2a48 -->
  <rule id="299795" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0456 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>