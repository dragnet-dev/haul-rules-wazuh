<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5642 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 71559f35-529f-5a3e-9233-8f16a81b87aa -->
  <rule id="344959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5642 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>