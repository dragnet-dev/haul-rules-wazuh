<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2896 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: 891dd4e9-5e28-524c-bde7-054efc043629 -->
  <rule id="583174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2896 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>