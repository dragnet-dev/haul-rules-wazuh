<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5909 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 343f5b04-2172-531a-aaa6-320c5b7441a4 -->
  <rule id="805710" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5909 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>