<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0731 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 93b84fce-576b-5234-9e3e-337373eec0b1 -->
  <rule id="699759" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0731 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>