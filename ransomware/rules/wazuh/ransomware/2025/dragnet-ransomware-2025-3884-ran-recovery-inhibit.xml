<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3884 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 7c2c1981-c2ad-5754-9130-733dedf58164 -->
  <rule id="288419" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3884 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>