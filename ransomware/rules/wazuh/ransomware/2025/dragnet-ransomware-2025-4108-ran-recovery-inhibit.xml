<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4108 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 39b82ade-49be-5108-80d6-ea84134a133c -->
  <rule id="217322" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4108 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>