<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4051 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d974ecaf-de1e-548a-a7d7-fe61cc0b96d3 -->
  <rule id="977580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4051 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>