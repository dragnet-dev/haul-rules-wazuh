<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4796 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f0db3e3f-1e89-5d77-b6a0-383086d06dad -->
  <rule id="879102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4796 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
