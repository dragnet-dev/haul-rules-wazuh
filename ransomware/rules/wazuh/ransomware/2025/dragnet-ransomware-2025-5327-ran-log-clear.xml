<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5327 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 04d0c8b6-3a57-5b11-bb61-4b3b3bca4470 -->
  <rule id="273259" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5327 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>