<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3127 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: 4b97a755-78f1-505d-a8d1-ec7a759716ca -->
  <rule id="415627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3127 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>