<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6953 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: aaaebe51-23d4-5dcd-8d5d-4dde8657bfd0 -->
  <rule id="485854" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6953 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>