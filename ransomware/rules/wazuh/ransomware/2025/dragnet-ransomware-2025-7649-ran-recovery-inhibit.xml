<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7649 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 6e037fcf-d76e-59fb-b83f-12bd89245110 -->
  <rule id="960607" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7649 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>