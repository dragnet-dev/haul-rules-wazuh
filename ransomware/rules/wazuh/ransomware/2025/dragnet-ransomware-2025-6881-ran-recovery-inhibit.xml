<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6881 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 35596996-a535-561d-89bb-6396a4fe3007 -->
  <rule id="959699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6881 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>