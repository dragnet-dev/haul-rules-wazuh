<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4995 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 69e76b22-ba64-5c44-accd-32fe36e4a002 -->
  <rule id="990027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4995 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>