<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6405 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 3a01b3f3-f1a9-5f0f-970a-061b01c7387b -->
  <rule id="552383" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6405 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>