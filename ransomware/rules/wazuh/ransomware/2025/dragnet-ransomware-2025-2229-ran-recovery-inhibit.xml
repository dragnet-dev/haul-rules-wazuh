<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2229 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 2bc20a94-1059-5b3e-9977-e1ff192d42cb -->
  <rule id="320330" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2229 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>