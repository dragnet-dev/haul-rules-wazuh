<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4555 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 907ea989-551e-5860-894e-9757d7ce4d67 -->
  <rule id="624269" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4555 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>