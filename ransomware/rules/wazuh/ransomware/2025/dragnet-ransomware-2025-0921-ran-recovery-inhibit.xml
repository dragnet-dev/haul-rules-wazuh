<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0921 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 80f144b7-618e-5fd0-acff-09e787f2da39 -->
  <rule id="495144" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0921 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>