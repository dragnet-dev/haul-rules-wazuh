<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4871 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 302eeac9-c7aa-53f6-ac72-30f514a88a3b -->
  <rule id="440810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4871 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>