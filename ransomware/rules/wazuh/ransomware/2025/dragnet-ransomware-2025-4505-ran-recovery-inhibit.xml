<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4505 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: b5d4a671-1393-54be-bedc-304340c1b273 -->
  <rule id="365546" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4505 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>