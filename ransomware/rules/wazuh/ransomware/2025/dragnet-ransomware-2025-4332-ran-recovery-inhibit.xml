<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4332 — Recovery Inhibition (crazyhunter) | Status: experimental | Sigma ID: 964af573-6245-55c0-a375-93eab6f58295 -->
  <rule id="769595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4332 — Recovery Inhibition (crazyhunter)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>