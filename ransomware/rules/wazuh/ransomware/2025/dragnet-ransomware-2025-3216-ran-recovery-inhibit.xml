<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3216 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 61910a47-415e-5a30-8df7-8cf319dbcd2d -->
  <rule id="105704" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3216 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>