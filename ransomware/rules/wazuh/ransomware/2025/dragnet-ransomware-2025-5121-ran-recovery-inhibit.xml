<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5121 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 5586d050-c63d-5be4-85e5-73c6ec362b18 -->
  <rule id="938905" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5121 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>