<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1968 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: 91c996cd-08a5-5394-b6fb-6f5c51eb89e6 -->
  <rule id="668996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1968 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>