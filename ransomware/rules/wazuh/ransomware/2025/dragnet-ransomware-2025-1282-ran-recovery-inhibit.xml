<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1282 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 80e3965f-cd56-5042-853e-238f1ba79b8d -->
  <rule id="494396" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1282 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>