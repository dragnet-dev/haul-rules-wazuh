<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7060 — Event Log Clearing (beast) | Status: experimental | Sigma ID: 7724a969-15bf-5287-b585-4a8b28793ac6 -->
  <rule id="435949" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7060 — Event Log Clearing (beast)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>