<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6567 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 6f5eebc9-50ee-5298-8711-e351e9dbb8a8 -->
  <rule id="170859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6567 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>