<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0284 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 8ecfdd11-ca40-5423-9b9e-72fb995d28c9 -->
  <rule id="459325" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0284 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>