<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2311 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: d66d22a0-91ed-5da7-8dbc-23552d21890d -->
  <rule id="486922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2311 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>