<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2121 — Recovery Inhibition (hellcat) | Status: deprecated | Sigma ID: 594994f4-5c9e-525a-9499-a60c9882566d -->
  <rule id="619919" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2121 — Recovery Inhibition (hellcat)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>