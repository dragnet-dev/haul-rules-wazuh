<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5011 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 64dd532e-4a98-5096-b621-2239a839abb8 -->
  <rule id="860553" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5011 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>