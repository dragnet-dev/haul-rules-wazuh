<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6824 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: ff0f454e-54bd-51f2-9526-5ed925179e35 -->
  <rule id="581545" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6824 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>