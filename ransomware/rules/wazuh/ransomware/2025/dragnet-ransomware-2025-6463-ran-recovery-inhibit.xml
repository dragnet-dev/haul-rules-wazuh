<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6463 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2b589efb-4cb2-54c0-acfd-5d1ff5cc4d28 -->
  <rule id="459023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6463 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>