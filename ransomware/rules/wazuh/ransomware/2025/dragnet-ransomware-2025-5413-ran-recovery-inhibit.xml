<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5413 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 52468dbe-607c-5736-a57f-2135f84c7c03 -->
  <rule id="932027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5413 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>