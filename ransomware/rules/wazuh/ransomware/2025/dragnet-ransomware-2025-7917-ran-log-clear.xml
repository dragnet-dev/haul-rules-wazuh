<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7917 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: ce758ee8-a5f1-5ab7-b7c2-0d71bfbe5b78 -->
  <rule id="708142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7917 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>