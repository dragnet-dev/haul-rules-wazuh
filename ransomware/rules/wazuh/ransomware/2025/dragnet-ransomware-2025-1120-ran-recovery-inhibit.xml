<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1120 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 95ea772e-5895-5ad3-8b52-8f87773fe439 -->
  <rule id="755477" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1120 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>