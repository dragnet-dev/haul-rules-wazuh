<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3933 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 39ab4541-bbd7-5e23-adad-4f516c9ed514 -->
  <rule id="215545" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3933 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>