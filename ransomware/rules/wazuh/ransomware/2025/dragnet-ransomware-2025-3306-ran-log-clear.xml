<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3306 — Event Log Clearing (babuk2) | Status: experimental | Sigma ID: 327ecdde-e17f-5be2-9ba4-ed2e1e50aa27 -->
  <rule id="543181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3306 — Event Log Clearing (babuk2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>