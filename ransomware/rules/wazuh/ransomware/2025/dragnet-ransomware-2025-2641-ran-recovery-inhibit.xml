<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2641 — Recovery Inhibition (minteye) | Status: deprecated | Sigma ID: 5aa2a237-4c54-57a1-aa34-101933a99cfe -->
  <rule id="620422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2641 — Recovery Inhibition (minteye)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>