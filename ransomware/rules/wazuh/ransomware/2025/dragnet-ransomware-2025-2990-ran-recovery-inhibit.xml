<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2990 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 02b78d7c-c987-5e1a-bb54-63ff377da2f5 -->
  <rule id="509884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2990 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>