<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3591 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 5898c588-6530-5ea1-b4ce-7cb08ed6d794 -->
  <rule id="538058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3591 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>