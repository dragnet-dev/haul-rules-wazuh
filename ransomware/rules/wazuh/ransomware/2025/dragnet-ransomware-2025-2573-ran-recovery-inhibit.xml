<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2573 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: acc81b8c-433f-5c72-81a1-211b9f03a897 -->
  <rule id="923707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2573 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>