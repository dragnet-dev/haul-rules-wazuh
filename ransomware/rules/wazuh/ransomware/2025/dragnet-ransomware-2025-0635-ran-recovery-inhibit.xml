<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0635 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 263df685-1c1e-58fa-adac-eb4722fc640c -->
  <rule id="555168" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0635 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>