<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7600 — Event Log Clearing (chaos) | Status: experimental | Sigma ID: 2cfbbb98-4cf6-514f-b8dc-04b3f7fe9362 -->
  <rule id="348027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7600 — Event Log Clearing (chaos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>