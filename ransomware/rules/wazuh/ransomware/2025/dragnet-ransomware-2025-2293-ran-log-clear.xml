<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2293 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: 750af9f6-42bc-5a90-8af9-19b6467f9faa -->
  <rule id="221759" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2293 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>