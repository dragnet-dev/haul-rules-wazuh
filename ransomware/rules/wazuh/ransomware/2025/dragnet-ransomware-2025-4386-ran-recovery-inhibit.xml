<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4386 — Recovery Inhibition (everest) | Status: test | Sigma ID: b10a66d7-11b4-5750-820b-a38c126f6a9a -->
  <rule id="977066" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4386 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>