<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0302 — Recovery Inhibition (qilin) | Status: test | Sigma ID: d74fbf53-c3e0-52d6-990b-8400eae79664 -->
  <rule id="331935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0302 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
