<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5675 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 98d9c2ed-aa47-59e7-994c-fbfb48f059bb -->
  <rule id="831162" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5675 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>