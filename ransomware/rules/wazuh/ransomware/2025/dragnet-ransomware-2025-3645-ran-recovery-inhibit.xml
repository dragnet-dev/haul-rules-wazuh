<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3645 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: e2240ac7-ad68-5691-8cdc-b4f3398f4c57 -->
  <rule id="575850" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3645 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>