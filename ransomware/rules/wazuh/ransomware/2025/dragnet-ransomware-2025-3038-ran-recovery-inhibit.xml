<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3038 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: d9c51b18-50f1-5ad8-914f-fb5a3b79c9d1 -->
  <rule id="978427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3038 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
