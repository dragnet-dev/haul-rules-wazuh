<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1970 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 8dadfbea-c502-5cd4-884e-704a025d9358 -->
  <rule id="385115" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1970 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>