<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2558 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ad6d20e1-21c8-5b55-9947-6cf6126f3cc2 -->
  <rule id="178920" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2558 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>