<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6257 — Recovery Inhibition (weyhro) | Status: experimental | Sigma ID: 25964c9e-3b3e-5568-9abb-20ea662a15db -->
  <rule id="654369" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6257 — Recovery Inhibition (weyhro)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>