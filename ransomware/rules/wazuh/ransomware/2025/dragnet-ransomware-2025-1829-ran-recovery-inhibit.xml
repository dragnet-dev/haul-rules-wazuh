<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1829 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 163d62d5-cbf6-5d84-889c-eb33a4a63250 -->
  <rule id="694605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1829 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>