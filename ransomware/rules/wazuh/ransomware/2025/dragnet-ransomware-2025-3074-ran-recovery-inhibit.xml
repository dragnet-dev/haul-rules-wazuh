<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3074 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 7251ea71-4d94-5eca-a63b-77bd4134371c -->
  <rule id="156490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3074 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>