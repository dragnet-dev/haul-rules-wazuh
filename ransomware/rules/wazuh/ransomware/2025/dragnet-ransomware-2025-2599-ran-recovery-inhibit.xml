<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2599 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 9c538815-b358-5a46-b94c-6400633001da -->
  <rule id="765388" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2599 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>