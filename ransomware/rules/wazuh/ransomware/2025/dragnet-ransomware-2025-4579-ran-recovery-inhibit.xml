<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4579 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: ae322358-e9c2-505c-a00e-f50f8545f523 -->
  <rule id="943223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4579 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>