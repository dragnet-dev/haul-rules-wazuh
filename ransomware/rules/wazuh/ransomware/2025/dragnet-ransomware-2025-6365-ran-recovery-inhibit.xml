<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6365 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 28c14628-0cff-57d5-9d6a-99e450aefe04 -->
  <rule id="201462" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6365 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>