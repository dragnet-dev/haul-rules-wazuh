<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4418 — Event Log Clearing (BrainCipher) | Status: experimental | Sigma ID: 0759dc33-2c18-5352-9d0a-4ac592f0cf32 -->
  <rule id="245243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4418 — Event Log Clearing (BrainCipher)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>