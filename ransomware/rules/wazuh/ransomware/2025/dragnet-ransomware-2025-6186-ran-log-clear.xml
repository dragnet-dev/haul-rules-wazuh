<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6186 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 96a79a6d-765a-5653-9d94-9cd1994e0bd1 -->
  <rule id="774874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6186 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>