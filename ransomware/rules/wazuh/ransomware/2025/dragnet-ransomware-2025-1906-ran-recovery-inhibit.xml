<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1906 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 02a116c3-5fa9-52f2-90f8-1fac9f93d002 -->
  <rule id="538683" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1906 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>