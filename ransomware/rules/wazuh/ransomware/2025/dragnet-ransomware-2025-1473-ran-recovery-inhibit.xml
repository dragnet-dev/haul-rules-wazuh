<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1473 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7b8aedac-1922-5b15-98e3-83ed95254c3b -->
  <rule id="673645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1473 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>