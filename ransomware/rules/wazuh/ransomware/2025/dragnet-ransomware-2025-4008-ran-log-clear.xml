<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4008 — Event Log Clearing (payoutsking) | Status: experimental | Sigma ID: d1440fb7-7109-523d-9453-68baa3c4a642 -->
  <rule id="403055" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4008 — Event Log Clearing (payoutsking)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>