<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4124 — Recovery Inhibition (medusa) | Status: test | Sigma ID: 4930d596-f54e-58cf-8bcb-877f571ec682 -->
  <rule id="789359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4124 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>