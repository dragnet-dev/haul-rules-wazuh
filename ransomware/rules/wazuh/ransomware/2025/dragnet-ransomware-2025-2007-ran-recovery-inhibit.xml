<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2007 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: a5cb418e-b2f5-5419-b9f0-60ffbe3291cb -->
  <rule id="108341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2007 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>