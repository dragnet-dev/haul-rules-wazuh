<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3735 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 7271a12e-d209-58eb-bf01-e737159321b0 -->
  <rule id="363461" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3735 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>