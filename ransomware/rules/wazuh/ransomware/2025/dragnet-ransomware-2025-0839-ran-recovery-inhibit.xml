<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0839 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 5af7af3d-362b-5ce9-8f80-9176cd30e4ca -->
  <rule id="226767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0839 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>