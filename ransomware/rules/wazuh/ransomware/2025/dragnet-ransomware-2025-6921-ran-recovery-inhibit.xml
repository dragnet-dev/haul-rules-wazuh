<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6921 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6765d11f-9c6d-5b40-91a7-eae7c6fdd519 -->
  <rule id="282531" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6921 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>