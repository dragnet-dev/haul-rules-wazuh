<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6061 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ad103bcb-0465-526d-9b2d-414d8676e096 -->
  <rule id="169659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6061 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>