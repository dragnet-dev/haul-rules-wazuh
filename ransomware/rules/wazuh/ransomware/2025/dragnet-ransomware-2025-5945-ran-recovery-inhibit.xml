<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5945 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 75560125-2179-5559-9b0a-9508afc89dc5 -->
  <rule id="456012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5945 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>