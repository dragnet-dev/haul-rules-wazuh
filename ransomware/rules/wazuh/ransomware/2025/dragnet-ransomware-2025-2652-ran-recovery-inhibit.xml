<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2652 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: b6ed6964-2a8c-5892-93ce-b2f2b6e10788 -->
  <rule id="393369" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2652 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>