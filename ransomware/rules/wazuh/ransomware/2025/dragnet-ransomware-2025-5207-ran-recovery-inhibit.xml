<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5207 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 94b61c0b-092e-50b6-b2e6-7f82adb05f5e -->
  <rule id="724988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5207 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>