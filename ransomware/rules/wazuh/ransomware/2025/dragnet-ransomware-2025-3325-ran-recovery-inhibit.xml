<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3325 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 359ef816-4ff0-5668-ad18-2384bef379f8 -->
  <rule id="314381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3325 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>