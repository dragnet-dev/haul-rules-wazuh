<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7754 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1057c86e-888d-5cc2-a9d7-eff354aed24c -->
  <rule id="892486" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7754 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>