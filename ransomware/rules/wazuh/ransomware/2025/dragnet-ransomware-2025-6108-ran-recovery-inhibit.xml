<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6108 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 73d852fc-025a-5c15-8634-6382ef504e7e -->
  <rule id="381852" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6108 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>