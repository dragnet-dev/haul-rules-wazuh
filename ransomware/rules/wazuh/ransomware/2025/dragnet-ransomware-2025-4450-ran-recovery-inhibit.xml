<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4450 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: c2e66fef-7b49-59cd-aaec-440989c2fe40 -->
  <rule id="546671" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4450 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>