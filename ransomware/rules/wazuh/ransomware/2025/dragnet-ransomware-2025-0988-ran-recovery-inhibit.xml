<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0988 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: e82adb48-14f0-5957-85ac-6d55f0c317a9 -->
  <rule id="773051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0988 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>