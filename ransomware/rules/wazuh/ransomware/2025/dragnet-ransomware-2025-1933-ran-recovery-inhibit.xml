<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1933 — Recovery Inhibition (IMNCrew) | Status: experimental | Sigma ID: d6b9950a-e542-57ba-a262-a6afac444853 -->
  <rule id="487995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1933 — Recovery Inhibition (IMNCrew)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>