<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7193 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 33366a59-de09-5304-b6c8-4f1bbe2d3613 -->
  <rule id="938665" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7193 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>