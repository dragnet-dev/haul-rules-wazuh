<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4604 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 52fb9d9d-9329-5ae8-ba37-9ed6f8afcb89 -->
  <rule id="470237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4604 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>