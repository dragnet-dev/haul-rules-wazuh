<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3459 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 0ffcf778-1be9-596b-b007-09766aa26beb -->
  <rule id="348777" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3459 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>