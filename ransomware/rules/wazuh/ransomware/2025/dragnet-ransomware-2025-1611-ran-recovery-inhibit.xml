<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1611 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 9de5dc98-81de-5443-894e-c5ed8248e1e8 -->
  <rule id="268060" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1611 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>