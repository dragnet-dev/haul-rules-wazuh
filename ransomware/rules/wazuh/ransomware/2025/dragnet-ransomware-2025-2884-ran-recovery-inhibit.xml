<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2884 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: aadc0a1f-cd62-542c-a6ec-44eb1f58d7de -->
  <rule id="798410" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2884 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>