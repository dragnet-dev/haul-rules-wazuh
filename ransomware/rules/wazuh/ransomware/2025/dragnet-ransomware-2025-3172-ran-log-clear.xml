<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3172 — Event Log Clearing (nova) | Status: test | Sigma ID: ee891741-2870-5782-be62-805e88e57b95 -->
  <rule id="688917" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3172 — Event Log Clearing (nova)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>