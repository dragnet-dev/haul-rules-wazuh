<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0748 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 5059c5d8-e7a5-57e3-9b8f-44c5167c91ea -->
  <rule id="453053" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0748 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>