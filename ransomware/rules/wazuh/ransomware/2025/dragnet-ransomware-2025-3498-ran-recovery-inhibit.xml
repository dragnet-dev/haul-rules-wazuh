<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3498 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 03a381ac-112e-516c-800b-12e1de2eebc3 -->
  <rule id="645708" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3498 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>