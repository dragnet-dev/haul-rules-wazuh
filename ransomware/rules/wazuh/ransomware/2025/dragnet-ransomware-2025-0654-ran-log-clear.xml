<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0654 — Event Log Clearing (blacklock) | Status: experimental | Sigma ID: 85cdb87b-5cf2-5c91-abdd-99fc1cf5bd63 -->
  <rule id="914518" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0654 — Event Log Clearing (blacklock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>