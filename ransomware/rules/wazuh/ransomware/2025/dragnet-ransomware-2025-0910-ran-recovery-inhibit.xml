<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0910 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 926a95b2-9df4-565a-9cb4-7b29026318c8 -->
  <rule id="682695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0910 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>