<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7562 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 9fb1b6c4-3e5e-5a6c-a848-82802010e4dd -->
  <rule id="588276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7562 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>