<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6988 — Event Log Clearing (spacebears) | Status: experimental | Sigma ID: b82307ca-44eb-5b49-be57-9fd313785170 -->
  <rule id="382307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6988 — Event Log Clearing (spacebears)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>