<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0031 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 21e9dd41-cf6e-5352-b835-c7f69cc76247 -->
  <rule id="985254" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0031 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>