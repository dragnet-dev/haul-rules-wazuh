<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2439 — Recovery Inhibition (thegentlemen) | Status: experimental | Sigma ID: b4a54ad8-8f12-52cf-bbe4-bc1a656fb287 -->
  <rule id="335274" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2439 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
