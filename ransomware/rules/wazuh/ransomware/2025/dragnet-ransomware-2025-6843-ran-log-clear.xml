<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6843 — Event Log Clearing (desolator) | Status: experimental | Sigma ID: 2641e16e-7c0d-5db1-835b-00f4d3845523 -->
  <rule id="727016" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6843 — Event Log Clearing (desolator)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>