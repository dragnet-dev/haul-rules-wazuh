<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5359 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2a7bf52a-8706-51ec-9cee-294cfca23d00 -->
  <rule id="295035" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5359 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>