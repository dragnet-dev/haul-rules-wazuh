<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6716 — Recovery Inhibition (obscura) | Status: experimental | Sigma ID: 0123bb06-8bb0-5c6c-ad60-051e0e1f56aa -->
  <rule id="567506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6716 — Recovery Inhibition (obscura)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>