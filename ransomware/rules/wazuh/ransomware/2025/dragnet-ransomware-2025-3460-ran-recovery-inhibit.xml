<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3460 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 40948161-d049-57d4-b6c8-029b60adad39 -->
  <rule id="594816" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3460 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>