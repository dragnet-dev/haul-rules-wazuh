<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5775 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 24fbe1a1-eb5d-5393-ac55-3ed64d87c7dc -->
  <rule id="223341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5775 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>