<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2227 — Event Log Clearing (direwolf) | Status: experimental | Sigma ID: d0bd053c-19b6-5a36-b1f7-fc3ff46b85b7 -->
  <rule id="746905" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2227 — Event Log Clearing (direwolf)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>