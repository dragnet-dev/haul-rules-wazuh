<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5797 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 74eea9a3-5779-5b90-8301-8938ea9dc839 -->
  <rule id="469229" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5797 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
