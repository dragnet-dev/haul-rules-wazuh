<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7626 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 60f472bd-d560-5309-98c3-f99f3e4f1537 -->
  <rule id="407563" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7626 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>