<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3599 — Event Log Clearing (linkc) | Status: experimental | Sigma ID: f3b33821-a7e9-5982-af0d-7b374216c6a3 -->
  <rule id="759338" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3599 — Event Log Clearing (linkc)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>