<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6185 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: a689bfae-18ce-5875-bdfd-9b595d6cca24 -->
  <rule id="136575" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6185 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>