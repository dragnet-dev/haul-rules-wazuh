<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0475 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 7c6ab1cd-5b8e-5cce-a73d-723e4f872407 -->
  <rule id="591471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0475 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>