<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4639 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 71541816-d1bc-51fd-a40f-af3feb2a42cf -->
  <rule id="954181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4639 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>