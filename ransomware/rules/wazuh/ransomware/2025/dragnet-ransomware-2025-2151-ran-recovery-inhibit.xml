<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2151 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 22a2db72-fc2b-55dc-b396-3c380bbc1e10 -->
  <rule id="374517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2151 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>