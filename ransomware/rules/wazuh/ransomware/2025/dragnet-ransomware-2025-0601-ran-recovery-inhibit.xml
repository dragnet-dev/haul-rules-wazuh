<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0601 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 376e529d-1392-58c6-b92c-1416cf1d92bc -->
  <rule id="730529" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0601 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>