<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2281 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 06c658a7-6067-542a-affb-a89ac714db19 -->
  <rule id="938538" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2281 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>