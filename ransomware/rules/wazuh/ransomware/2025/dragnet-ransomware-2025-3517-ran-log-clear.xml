<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3517 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 0ecaa18b-b4a7-58d8-bfdd-cfd6c9301c88 -->
  <rule id="758618" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3517 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>