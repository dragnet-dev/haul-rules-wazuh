<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1779 — Event Log Clearing (bqtlock) | Status: experimental | Sigma ID: e2e8ebf6-1d2a-5e98-a30c-579f2fcb0017 -->
  <rule id="554443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1779 — Event Log Clearing (bqtlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>