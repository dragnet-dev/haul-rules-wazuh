<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0083 — Event Log Clearing (ransomhouse) | Status: test | Sigma ID: 060bc6c6-b4c4-541a-bd73-ed56e9ce17e4 -->
  <rule id="787788" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0083 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>