<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2585 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 763f7f0e-13ae-5284-b285-a6b9e59c3c28 -->
  <rule id="255807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2585 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>