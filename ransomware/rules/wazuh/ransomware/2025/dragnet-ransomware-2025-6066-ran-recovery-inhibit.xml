<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6066 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 1da5199b-7aec-54ca-8fdf-8451b160eb6f -->
  <rule id="345199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6066 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>