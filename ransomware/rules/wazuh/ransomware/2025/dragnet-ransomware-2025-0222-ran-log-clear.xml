<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0222 — Event Log Clearing (clop) | Status: deprecated | Sigma ID: 0645bd7a-df23-57c0-9a7d-d0f0c4e3728f -->
  <rule id="853097" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0222 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>