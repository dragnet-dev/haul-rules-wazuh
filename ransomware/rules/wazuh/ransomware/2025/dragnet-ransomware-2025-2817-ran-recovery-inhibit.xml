<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2817 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f41bafa4-96c9-5efb-ab20-d8a4611900e8 -->
  <rule id="114927" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2817 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>