<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4146 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: cbf634eb-2f15-5091-a3ec-60f26987a93d -->
  <rule id="663634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4146 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>