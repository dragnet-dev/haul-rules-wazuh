<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5434 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: a984f7bb-fe02-552d-8181-c27e270bfce6 -->
  <rule id="957597" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5434 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>