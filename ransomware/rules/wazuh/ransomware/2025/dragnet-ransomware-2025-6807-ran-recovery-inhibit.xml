<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6807 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0de52dbc-4470-5236-9251-64b18f3af002 -->
  <rule id="396731" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6807 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
