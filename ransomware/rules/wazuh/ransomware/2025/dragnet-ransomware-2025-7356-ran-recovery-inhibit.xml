<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7356 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 760b2cb2-c81d-5bbb-9d19-424c8b315713 -->
  <rule id="247404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7356 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>