<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6939 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 31e658e2-6dd4-5ca5-aaa7-c2df1d42ad69 -->
  <rule id="170542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6939 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>