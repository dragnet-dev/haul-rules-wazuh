<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3792 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: a350c582-6828-5e52-a51f-955a1824db6a -->
  <rule id="856125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3792 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>