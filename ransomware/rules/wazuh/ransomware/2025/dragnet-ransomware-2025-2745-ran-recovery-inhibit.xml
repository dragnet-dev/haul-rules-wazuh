<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2745 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 2610b545-1b0e-5ce1-99f8-c75337c175fe -->
  <rule id="677154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2745 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>