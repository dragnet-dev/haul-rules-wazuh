<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7523 — Event Log Clearing (crypto24) | Status: deprecated | Sigma ID: 2a9d092b-f5cb-565b-9f5a-79dd1642d04d -->
  <rule id="677092" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7523 — Event Log Clearing (crypto24)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>