<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3427 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: a29f81ba-c683-5cc5-ba0a-9ba537f252dc -->
  <rule id="847981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3427 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>