  <rule id="879422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4354 — Recovery Inhibition (payoutsking)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
