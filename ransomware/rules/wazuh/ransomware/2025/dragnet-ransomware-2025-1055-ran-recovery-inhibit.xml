<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1055 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f296232b-c2ab-56b8-b391-dc3a6a113cac -->
  <rule id="729623" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1055 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>