<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2607 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 85f9e55a-5bc6-5e90-9ece-5e5510360e1a -->
  <rule id="501585" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2607 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>