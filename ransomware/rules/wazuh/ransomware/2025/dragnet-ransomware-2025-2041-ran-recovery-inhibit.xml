<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2041 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: c74cccb1-9192-5ff1-9c10-15dc828550b5 -->
  <rule id="821580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2041 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>