<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3917 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 968efcc2-cefe-5af7-a46b-d855d15970ff -->
  <rule id="468764" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3917 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>