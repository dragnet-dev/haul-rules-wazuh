<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4467 — Recovery Inhibition (crazyhunter) | Status: experimental | Sigma ID: 59f57f71-aede-5948-a508-56d6a541e15f -->
  <rule id="735327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4467 — Recovery Inhibition (crazyhunter)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>