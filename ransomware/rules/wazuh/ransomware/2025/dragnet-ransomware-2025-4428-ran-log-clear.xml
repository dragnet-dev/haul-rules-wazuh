<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4428 — Event Log Clearing (lynx) | Status: experimental | Sigma ID: 68c9f1c2-eb2f-53cc-b8a8-604cf3b36c60 -->
  <rule id="961591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4428 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>