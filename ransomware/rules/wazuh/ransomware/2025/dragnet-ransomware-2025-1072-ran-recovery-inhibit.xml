<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1072 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 21c4fb90-d957-5b1a-834f-cee9589869f0 -->
  <rule id="921559" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1072 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>