<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1351 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 559cd835-12e8-52c6-b6f5-f0c7db897090 -->
  <rule id="633098" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1351 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>