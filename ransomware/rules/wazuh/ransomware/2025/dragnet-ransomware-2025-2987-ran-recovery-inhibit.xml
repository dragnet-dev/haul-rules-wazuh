<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2987 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5108be9f-4c6e-5bf2-a485-363cbd6cca4e -->
  <rule id="507838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2987 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>