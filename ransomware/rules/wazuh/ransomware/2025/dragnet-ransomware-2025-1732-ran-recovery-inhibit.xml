<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1732 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: dd61a25c-6105-5d96-8be5-f0d7b55fa320 -->
  <rule id="945862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1732 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>