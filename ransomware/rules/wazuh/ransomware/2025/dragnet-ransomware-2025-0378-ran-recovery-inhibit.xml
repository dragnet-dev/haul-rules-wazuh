<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0378 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 3cc7cb7c-c8d1-525f-a950-484cc126626b -->
  <rule id="790315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0378 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>