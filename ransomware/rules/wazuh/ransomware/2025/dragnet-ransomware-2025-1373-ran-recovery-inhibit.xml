<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1373 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b0039194-29c9-5ec1-bb87-75a841920755 -->
  <rule id="300391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1373 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>