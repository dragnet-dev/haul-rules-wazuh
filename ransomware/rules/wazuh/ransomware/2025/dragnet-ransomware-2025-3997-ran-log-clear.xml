<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3997 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 84c76c26-6b6d-5f1c-842f-b34bfceb5a3e -->
  <rule id="470828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3997 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>