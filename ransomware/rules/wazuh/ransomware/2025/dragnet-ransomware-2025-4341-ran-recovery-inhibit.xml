<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4341 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: d6ab9deb-5367-53da-804d-a1e795d679ec -->
  <rule id="298077" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4341 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>