<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3903 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 83efca4d-2779-5c67-91d6-186cd273ed93 -->
  <rule id="200874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3903 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>