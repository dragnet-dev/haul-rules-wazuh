<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1172 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 1a86e040-d7a6-5233-b8e9-838ae1d1e21b -->
  <rule id="799004" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1172 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>