<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0781 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 415f473a-f816-5b71-a992-dd912123c888 -->
  <rule id="455473" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0781 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>