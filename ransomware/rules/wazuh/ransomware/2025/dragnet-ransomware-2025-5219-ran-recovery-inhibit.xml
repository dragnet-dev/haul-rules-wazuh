<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5219 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 4aee7053-91af-5108-8ae0-8de65883b5ee -->
  <rule id="218270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5219 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>