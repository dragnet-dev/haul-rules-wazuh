<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7865 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a739e1c8-c625-5f31-90d8-7468d206cf76 -->
  <rule id="918381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7865 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>