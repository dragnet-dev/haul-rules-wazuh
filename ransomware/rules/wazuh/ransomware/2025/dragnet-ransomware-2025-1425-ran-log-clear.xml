<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1425 — Event Log Clearing (gunra) | Status: experimental | Sigma ID: 41932232-2967-5091-8b36-608e415112c2 -->
  <rule id="693223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1425 — Event Log Clearing (gunra)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>