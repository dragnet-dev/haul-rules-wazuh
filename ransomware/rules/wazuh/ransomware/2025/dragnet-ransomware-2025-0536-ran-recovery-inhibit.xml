<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0536 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 2b42b4b3-dcba-517d-b378-2b44b5d2e07c -->
  <rule id="417355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0536 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>