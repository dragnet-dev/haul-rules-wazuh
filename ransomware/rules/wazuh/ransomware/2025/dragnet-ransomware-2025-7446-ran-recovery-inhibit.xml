<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7446 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: c92eef6d-6b38-525f-ac20-83e6746e2ae7 -->
  <rule id="895855" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7446 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>