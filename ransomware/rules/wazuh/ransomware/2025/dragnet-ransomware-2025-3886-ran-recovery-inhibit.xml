<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3886 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 0dba7d39-b5c1-5be3-a356-13d3c99284f4 -->
  <rule id="323653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3886 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>