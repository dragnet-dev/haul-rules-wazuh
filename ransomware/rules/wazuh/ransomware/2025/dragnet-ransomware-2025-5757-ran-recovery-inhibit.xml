<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5757 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 1c4869de-8cdf-5eca-81b5-ecd235e481bb -->
  <rule id="157917" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5757 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>