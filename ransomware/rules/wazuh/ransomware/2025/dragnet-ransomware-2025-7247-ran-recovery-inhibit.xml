<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7247 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: fb9f3625-b9ea-5a73-8bd6-6d04a4268ef5 -->
  <rule id="531936" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7247 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>