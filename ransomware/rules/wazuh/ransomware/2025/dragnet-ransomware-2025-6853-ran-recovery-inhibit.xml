<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6853 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 77df1c95-4446-5b10-8e7d-7519b53ad4c0 -->
  <rule id="589628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6853 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>