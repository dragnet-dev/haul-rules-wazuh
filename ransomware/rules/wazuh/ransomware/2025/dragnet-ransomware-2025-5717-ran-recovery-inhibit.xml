<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5717 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: daa1c133-a13c-586b-8d53-f7052ea9f389 -->
  <rule id="297081" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5717 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>