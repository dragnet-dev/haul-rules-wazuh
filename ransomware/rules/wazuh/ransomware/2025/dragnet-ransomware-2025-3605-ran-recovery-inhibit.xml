<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3605 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: b50b5851-2ae5-55e1-b4d1-6d8149253c86 -->
  <rule id="141158" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3605 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>