<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7322 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1c0c77bb-b06b-5241-bb14-48c78031ef55 -->
  <rule id="988443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7322 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>