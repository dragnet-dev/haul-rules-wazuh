<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4849 — Recovery Inhibition (insomnia) | Status: experimental | Sigma ID: ee3d2389-d6b5-504e-85a1-6b529297fe6c -->
  <rule id="314123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4849 — Recovery Inhibition (insomnia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>