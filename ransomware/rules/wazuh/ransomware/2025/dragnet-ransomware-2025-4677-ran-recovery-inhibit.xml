<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4677 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 00169437-2186-5d0d-8073-41281a71ea2d -->
  <rule id="894372" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4677 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>