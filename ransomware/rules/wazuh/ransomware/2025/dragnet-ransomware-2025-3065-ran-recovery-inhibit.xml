<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3065 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 63c48125-24a6-589b-b4e0-c972668f20e1 -->
  <rule id="220481" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3065 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>