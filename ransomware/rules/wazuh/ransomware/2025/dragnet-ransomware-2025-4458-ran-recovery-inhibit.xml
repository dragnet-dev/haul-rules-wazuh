<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4458 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: 8f50ca2c-87f7-5826-a4fb-9aa7bdb11014 -->
  <rule id="173802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4458 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>