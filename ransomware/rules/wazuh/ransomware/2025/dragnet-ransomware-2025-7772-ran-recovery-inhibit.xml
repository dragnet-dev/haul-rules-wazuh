<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7772 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 8b51125b-2f18-5123-93a1-2b236066d667 -->
  <rule id="595112" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7772 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>