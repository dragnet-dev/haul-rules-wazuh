<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2827 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 44c54034-3984-51e4-92f9-47b5c6a7b728 -->
  <rule id="965403" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2827 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>