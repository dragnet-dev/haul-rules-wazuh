<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7765 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: ec3f6a15-33c8-54dd-82b4-9fb99a9aa7b2 -->
  <rule id="751786" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7765 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>