<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5088 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 1c072523-ba49-5812-b906-6e00c8213c6d -->
  <rule id="207252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5088 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>