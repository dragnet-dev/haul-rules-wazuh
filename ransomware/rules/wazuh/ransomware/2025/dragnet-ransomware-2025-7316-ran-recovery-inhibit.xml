<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7316 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 4896a90f-3dea-56f1-a921-f7b1768a7c9d -->
  <rule id="734690" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7316 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>