<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2251 — Recovery Inhibition (RunSomeWares) | Status: experimental | Sigma ID: 7c5f9654-2dc5-56ca-a809-a9c450e451aa -->
  <rule id="293596" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2251 — Recovery Inhibition (RunSomeWares)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>