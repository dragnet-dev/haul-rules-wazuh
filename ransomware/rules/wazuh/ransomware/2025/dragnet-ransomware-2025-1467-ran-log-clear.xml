<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1467 — Event Log Clearing (lockbit5) | Status: experimental | Sigma ID: 1c26ab8c-e566-5e07-98e4-3633a0e06c29 -->
  <rule id="136278" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1467 — Event Log Clearing (lockbit5)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>