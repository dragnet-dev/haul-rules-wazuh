<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4577 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 9b0c48c9-c8d2-55f7-ba3d-8aaef7f630dc -->
  <rule id="781248" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4577 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>