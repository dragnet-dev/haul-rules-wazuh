<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5007 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e24665b5-a978-5208-8278-90242c15f62f -->
  <rule id="624665" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5007 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>