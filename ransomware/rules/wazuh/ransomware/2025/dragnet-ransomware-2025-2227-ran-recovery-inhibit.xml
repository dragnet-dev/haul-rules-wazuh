<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2227 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 1d468f79-8e8f-5afa-babb-e47d5665e261 -->
  <rule id="315037" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2227 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>