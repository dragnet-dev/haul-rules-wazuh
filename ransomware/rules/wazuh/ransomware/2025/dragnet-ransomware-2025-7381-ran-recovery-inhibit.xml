<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7381 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 23a07c06-c19a-54b4-8bc9-d9c65d16129a -->
  <rule id="749240" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7381 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>