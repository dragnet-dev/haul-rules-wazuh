<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0379 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: a61ddff2-e000-5a27-a6fb-4c431347a4e9 -->
  <rule id="849407" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0379 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>