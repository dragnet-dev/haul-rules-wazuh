<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1329 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 53fe025d-e8e7-5d42-870f-e47f4d2ff532 -->
  <rule id="582202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1329 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>