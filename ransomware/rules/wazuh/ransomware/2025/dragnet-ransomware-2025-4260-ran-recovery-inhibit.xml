<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4260 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 47b97389-4e76-5e31-b07c-5b7823fd7853 -->
  <rule id="539738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4260 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>