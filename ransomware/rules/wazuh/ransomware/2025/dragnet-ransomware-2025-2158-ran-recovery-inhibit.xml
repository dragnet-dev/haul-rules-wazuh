<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2158 — Recovery Inhibition (obscura) | Status: experimental | Sigma ID: a897ae4c-1582-5c02-81d5-c44e4fe2428b -->
  <rule id="189806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2158 — Recovery Inhibition (obscura)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>