<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0337 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 37cad9bf-a535-571e-97d2-81d32bb8fd1b -->
  <rule id="747979" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0337 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>