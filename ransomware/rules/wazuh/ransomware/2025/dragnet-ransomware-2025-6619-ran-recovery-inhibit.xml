<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6619 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: c174ba36-e1cd-5c6c-afec-935c4cba6afa -->
  <rule id="516730" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6619 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>