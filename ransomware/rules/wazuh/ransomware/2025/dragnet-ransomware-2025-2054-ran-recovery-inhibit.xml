<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2054 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: ea7ef80d-ba0c-5396-9fdc-39576fed286a -->
  <rule id="710718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2054 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>