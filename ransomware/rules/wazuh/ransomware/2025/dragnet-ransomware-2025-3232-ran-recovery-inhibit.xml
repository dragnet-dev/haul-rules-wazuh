<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3232 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 30fdfba2-f5e4-5027-85aa-7cadfac48115 -->
  <rule id="331099" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3232 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>