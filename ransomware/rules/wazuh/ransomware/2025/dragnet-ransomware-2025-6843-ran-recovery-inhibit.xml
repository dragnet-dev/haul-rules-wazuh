<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6843 — Recovery Inhibition (desolator) | Status: experimental | Sigma ID: d439654d-f472-5055-8b9b-fb02467deb8e -->
  <rule id="543965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6843 — Recovery Inhibition (desolator)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>