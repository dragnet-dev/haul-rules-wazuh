<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0626 — Event Log Clearing (coinbasecartel) | Status: experimental | Sigma ID: 76d5bfa1-e2a8-5f4f-95bb-99280bd0644c -->
  <rule id="547711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0626 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>