<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3976 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 5ae845de-10c1-523a-8570-1c6caeb307fa -->
  <rule id="654845" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3976 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>