<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0672 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 80b2ca47-1c82-5997-8c7b-b69e0fceebb1 -->
  <rule id="705674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0672 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>