<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6695 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 40387471-2e1b-5f91-a9e6-3020388a876b -->
  <rule id="538747" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6695 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>