<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2891 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 764269c7-a602-5d84-b3ea-d8dc54fcb145 -->
  <rule id="628316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2891 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>