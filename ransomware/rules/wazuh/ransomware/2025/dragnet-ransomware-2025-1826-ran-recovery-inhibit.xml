<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1826 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 6eb08f92-69e7-59b2-8729-08962f4554cb -->
  <rule id="233743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1826 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>