<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1030 — Recovery Inhibition (cephalus) | Status: experimental | Sigma ID: ffe1a1b8-db1c-5f51-82c6-536fb339d30a -->
  <rule id="350661" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1030 — Recovery Inhibition (cephalus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>