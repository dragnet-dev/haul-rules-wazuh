<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7630 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f0157b0f-6a11-5ef0-acc6-148044e89b4d -->
  <rule id="702523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7630 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>