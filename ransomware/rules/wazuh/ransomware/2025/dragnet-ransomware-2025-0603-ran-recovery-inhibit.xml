<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0603 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 96b58997-4d02-562d-b6eb-79fb661515c8 -->
  <rule id="747589" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0603 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>