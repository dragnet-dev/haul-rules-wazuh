<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7881 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0dad7a5e-e8bd-58d3-884b-a39a9e880e58 -->
  <rule id="302825" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7881 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>