<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2669 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 70c42970-5bf4-5bb3-886f-20859fd5e2ab -->
  <rule id="332429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2669 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>