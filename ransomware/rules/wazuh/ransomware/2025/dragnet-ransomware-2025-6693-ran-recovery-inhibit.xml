<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6693 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 3b8608b0-aa3d-500a-8fea-1daf98a23342 -->
  <rule id="677739" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6693 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>