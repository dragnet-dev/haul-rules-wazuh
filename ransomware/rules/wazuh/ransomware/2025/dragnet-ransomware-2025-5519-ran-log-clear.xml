<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5519 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 3ffba091-eb9d-5484-8c2a-ade544a02ce7 -->
  <rule id="920740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5519 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>