<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2895 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 5e14472e-7136-5c05-8caa-4e6229c15ab1 -->
  <rule id="514472" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2895 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>