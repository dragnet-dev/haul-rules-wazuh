<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0477 — Recovery Inhibition (qilin) | Status: test | Sigma ID: c80a8cd7-91e2-555c-bd80-f6001ba85e0d -->
  <rule id="678540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0477 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>