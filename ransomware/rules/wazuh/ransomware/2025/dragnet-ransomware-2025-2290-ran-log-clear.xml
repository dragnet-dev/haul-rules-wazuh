<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2290 — Event Log Clearing (funksec) | Status: experimental | Sigma ID: b26bcf20-786e-5df3-9a0a-d9e3e7b7aee1 -->
  <rule id="215119" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2290 — Event Log Clearing (funksec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>