<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7868 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 7c4a7593-05dd-53dd-9a28-641c09ec7efe -->
  <rule id="291475" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7868 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>