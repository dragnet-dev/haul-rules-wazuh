<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3044 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: e58a8ad3-2902-5133-9f07-b1ed8992e001 -->
  <rule id="234218" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3044 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>