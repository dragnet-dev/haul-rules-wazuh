<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7088 — Event Log Clearing (chaos) | Status: experimental | Sigma ID: 2d83f1cb-ab91-55e5-91f5-2a70d9e8cce6 -->
  <rule id="134908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7088 — Event Log Clearing (chaos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>