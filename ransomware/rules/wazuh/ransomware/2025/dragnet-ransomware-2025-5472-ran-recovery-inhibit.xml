<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5472 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c3d15e8f-e11e-548e-a36e-a8481a527399 -->
  <rule id="569854" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5472 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>