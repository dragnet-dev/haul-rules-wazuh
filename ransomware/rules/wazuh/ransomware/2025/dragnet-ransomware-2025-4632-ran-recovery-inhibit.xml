<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4632 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4d3d20b3-b464-5a7e-99a7-0fdfe303d99d -->
  <rule id="438120" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4632 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>