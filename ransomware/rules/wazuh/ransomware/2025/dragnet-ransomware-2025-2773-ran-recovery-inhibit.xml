<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2773 — Recovery Inhibition (cephalus) | Status: experimental | Sigma ID: 0c6fe81b-67cd-5943-a17c-aef78ef627b4 -->
  <rule id="651081" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2773 — Recovery Inhibition (cephalus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>