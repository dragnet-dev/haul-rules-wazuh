<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4653 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 489e1bc0-5773-5dcf-9099-6ef7b9cd08e7 -->
  <rule id="454107" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4653 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>