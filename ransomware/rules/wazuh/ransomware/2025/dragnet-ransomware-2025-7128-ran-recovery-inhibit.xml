<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7128 — Recovery Inhibition (direwolf) | Status: test | Sigma ID: 937c1906-a1ed-593a-ac12-d9727393d95f -->
  <rule id="700419" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7128 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>