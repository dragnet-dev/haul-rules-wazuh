<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5874 — Event Log Clearing (silent) | Status: experimental | Sigma ID: 0ad23495-d12d-555f-9e9d-52f76e32f005 -->
  <rule id="932349" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5874 — Event Log Clearing (silent)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>