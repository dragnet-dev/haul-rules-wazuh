<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2322 — Recovery Inhibition (ralord) | Status: experimental | Sigma ID: 126f2141-fd17-5779-8776-4b616a4cb633 -->
  <rule id="331214" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2322 — Recovery Inhibition (ralord)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>