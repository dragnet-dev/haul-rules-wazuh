<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0595 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7a73de0b-a00f-5ebb-a327-ab765fc01272 -->
  <rule id="542110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0595 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>