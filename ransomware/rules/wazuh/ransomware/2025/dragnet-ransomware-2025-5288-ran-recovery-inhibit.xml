<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5288 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 630cbf1d-1805-5745-ba4e-2756bc654c2c -->
  <rule id="883743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5288 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>