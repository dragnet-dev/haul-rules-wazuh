<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4241 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: d3482da4-ae95-55ab-89c7-f2f3873b6471 -->
  <rule id="435725" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4241 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>