<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0192 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 7732518d-dd7e-590b-813b-369185564d95 -->
  <rule id="632518" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0192 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>