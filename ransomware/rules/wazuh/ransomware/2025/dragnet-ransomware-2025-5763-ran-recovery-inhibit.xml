<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5763 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: bdac0afc-d2ad-5d19-9ca5-6ce4bd54ecf6 -->
  <rule id="668970" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5763 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>