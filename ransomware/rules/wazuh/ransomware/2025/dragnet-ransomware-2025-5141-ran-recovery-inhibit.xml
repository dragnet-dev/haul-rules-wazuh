<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5141 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 2f599e16-e154-54c9-b0b0-9c212ed28be2 -->
  <rule id="515981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5141 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
