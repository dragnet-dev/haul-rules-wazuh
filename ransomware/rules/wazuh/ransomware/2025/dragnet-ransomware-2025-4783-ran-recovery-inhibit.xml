<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4783 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: e9d6f2b8-4fed-5e42-a306-97f3ff2d8ae3 -->
  <rule id="336312" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4783 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>