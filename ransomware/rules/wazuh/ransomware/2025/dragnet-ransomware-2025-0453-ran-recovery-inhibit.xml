<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0453 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f2cd8597-461e-5e4f-bb8b-51f3d051bc49 -->
  <rule id="411785" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0453 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>