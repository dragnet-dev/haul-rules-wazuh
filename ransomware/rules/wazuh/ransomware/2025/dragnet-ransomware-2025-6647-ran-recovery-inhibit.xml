<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6647 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: ec52a27c-897b-5e36-91f0-3f51050bd5a0 -->
  <rule id="284422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6647 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>