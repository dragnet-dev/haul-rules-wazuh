<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6699 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: fb526f60-05b1-56e2-aba6-0c89e663d3ae -->
  <rule id="524431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6699 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>