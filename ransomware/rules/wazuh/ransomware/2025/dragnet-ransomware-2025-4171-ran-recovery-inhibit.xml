<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4171 — Recovery Inhibition (play) | Status: experimental | Sigma ID: caf9ce66-5fd6-5969-8181-0b9f855fda0c -->
  <rule id="314830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4171 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>