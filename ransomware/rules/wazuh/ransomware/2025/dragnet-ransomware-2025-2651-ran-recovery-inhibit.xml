<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2651 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 02ac6e1d-d774-559e-a0ac-7316c33dfc2f -->
  <rule id="295501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2651 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>