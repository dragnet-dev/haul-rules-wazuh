<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0925 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 87218936-a5eb-5564-a879-0a59e38d2d1d -->
  <rule id="721893" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0925 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>