<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6038 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1bd19e8c-ce14-5e2f-9a79-d642a9259da2 -->
  <rule id="923188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6038 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>