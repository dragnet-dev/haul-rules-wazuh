<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7891 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 698e294e-3b08-5abe-bb3f-22f70dedbdc8 -->
  <rule id="318229" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7891 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>