<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0514 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: dd9e6beb-9ca2-5cbd-9a59-803d8ba6f483 -->
  <rule id="382987" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0514 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>