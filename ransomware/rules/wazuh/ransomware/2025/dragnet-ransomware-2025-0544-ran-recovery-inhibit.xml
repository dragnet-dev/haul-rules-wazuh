<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0544 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c58ac5c8-ff6b-581f-b843-97e50aa001e3 -->
  <rule id="622205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0544 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>