<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5733 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 448f2b71-075d-55b7-b9f1-325f24ea5c99 -->
  <rule id="349323" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5733 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>