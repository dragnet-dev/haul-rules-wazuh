<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3182 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3265db56-0f59-5931-86d3-3b40787ab648 -->
  <rule id="360595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3182 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>