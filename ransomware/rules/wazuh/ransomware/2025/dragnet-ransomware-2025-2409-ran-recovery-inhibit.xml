<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2409 — Recovery Inhibition (thegentlemen) | Status: experimental | Sigma ID: 12fc9e44-af7b-55df-b204-ea9a98377683 -->
  <rule id="919984" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2409 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
