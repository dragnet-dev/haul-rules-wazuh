<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6830 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b57c2361-56db-5889-ab63-140f19b492b1 -->
  <rule id="152423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6830 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>