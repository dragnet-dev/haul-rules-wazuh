<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1353 — Recovery Inhibition (obscura) | Status: experimental | Sigma ID: be18d8a0-88a5-5e87-98c3-417a3205e9d5 -->
  <rule id="443018" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1353 — Recovery Inhibition (obscura)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>