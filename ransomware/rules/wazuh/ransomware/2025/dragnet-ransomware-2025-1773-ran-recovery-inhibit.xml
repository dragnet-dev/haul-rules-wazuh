<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1773 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 256f2ffd-d2e0-55bc-9a8a-6e3d76c41076 -->
  <rule id="724927" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1773 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>