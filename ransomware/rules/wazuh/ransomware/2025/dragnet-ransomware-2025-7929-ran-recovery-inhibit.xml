<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7929 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 18b15a04-305d-5565-9cf5-c95102800d6d -->
  <rule id="386500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7929 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>