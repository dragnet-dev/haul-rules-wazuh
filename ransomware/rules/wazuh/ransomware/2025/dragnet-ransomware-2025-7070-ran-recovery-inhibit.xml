<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7070 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 7c1581bf-ec1b-58cb-b54a-f502c24b869c -->
  <rule id="441581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7070 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
