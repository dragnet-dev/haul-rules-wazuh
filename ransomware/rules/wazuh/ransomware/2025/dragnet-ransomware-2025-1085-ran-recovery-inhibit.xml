<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1085 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 1fa05fd2-062e-58f0-b948-ab7a58b2af25 -->
  <rule id="455133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1085 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>