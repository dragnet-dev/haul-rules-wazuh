<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6557 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 426780e3-4329-5f8c-94a8-f7b867622bc5 -->
  <rule id="628494" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6557 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>