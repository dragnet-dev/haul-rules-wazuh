<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1286 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 49565afc-7d1c-5a39-b468-866e3de83344 -->
  <rule id="188815" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1286 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>