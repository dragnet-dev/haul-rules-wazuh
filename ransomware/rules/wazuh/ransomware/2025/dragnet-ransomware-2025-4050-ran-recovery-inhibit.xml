<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4050 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 7c63d60c-7a9c-5d17-899f-4b7e6b6fda39 -->
  <rule id="294216" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4050 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>