<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4139 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7d7c2c54-b9c1-5fc2-be72-f2edc9eeaec9 -->
  <rule id="619884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4139 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>