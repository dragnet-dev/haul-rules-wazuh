<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6380 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 7f9a15a0-61aa-5898-bb81-dabd4c9c6749 -->
  <rule id="347415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6380 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>