<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1421 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: a96becb7-ca04-54bc-94d0-3a2d0e988470 -->
  <rule id="992268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1421 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>