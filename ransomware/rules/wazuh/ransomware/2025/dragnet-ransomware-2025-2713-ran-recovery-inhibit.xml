<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2713 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f2ae383f-5ddd-58e9-b01a-f9f41e70fe20 -->
  <rule id="408638" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2713 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>