<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4828 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 93ffc944-4ff5-58af-9cc7-25ae466bab0f -->
  <rule id="350209" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4828 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>