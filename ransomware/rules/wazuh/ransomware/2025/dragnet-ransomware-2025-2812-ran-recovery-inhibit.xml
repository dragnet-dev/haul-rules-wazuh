<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2812 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 4ac15c8d-b766-531b-b8b2-9be319d4a6dc -->
  <rule id="213852" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2812 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>