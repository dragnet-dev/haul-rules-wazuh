<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0814 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 120963fc-d05d-584b-8223-df5c139d0cb3 -->
  <rule id="235423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0814 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>