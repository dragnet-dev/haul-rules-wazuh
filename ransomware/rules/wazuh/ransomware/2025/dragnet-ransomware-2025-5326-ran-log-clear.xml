<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5326 — Event Log Clearing (obscura) | Status: experimental | Sigma ID: f5e0e2a3-7a29-50dd-9f7f-5a0908cd45e5 -->
  <rule id="490542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5326 — Event Log Clearing (obscura)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>