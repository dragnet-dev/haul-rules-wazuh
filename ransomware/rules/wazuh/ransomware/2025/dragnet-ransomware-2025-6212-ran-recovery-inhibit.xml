<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6212 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 261021b5-43fc-5dc6-a8d1-77cd4206fbd9 -->
  <rule id="676347" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6212 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>