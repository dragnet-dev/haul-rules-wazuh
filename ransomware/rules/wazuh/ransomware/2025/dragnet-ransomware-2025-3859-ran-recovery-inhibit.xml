<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3859 — Recovery Inhibition (interlock) | Status: test | Sigma ID: 1f9c32ec-f8f2-5281-9579-d64bdd42f79c -->
  <rule id="186126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3859 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>