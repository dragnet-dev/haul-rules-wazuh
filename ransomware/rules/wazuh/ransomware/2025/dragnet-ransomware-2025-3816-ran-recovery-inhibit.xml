<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3816 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5fb9d8d1-1002-5d1e-8cac-90b3abc46bb7 -->
  <rule id="751178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3816 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>