<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4704 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7034ddbe-eb11-5c55-9151-297ba51bc76b -->
  <rule id="100925" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4704 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>