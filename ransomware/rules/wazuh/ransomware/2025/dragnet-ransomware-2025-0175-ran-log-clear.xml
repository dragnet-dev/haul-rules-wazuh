<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0175 — Event Log Clearing (brotherhood) | Status: deprecated | Sigma ID: 19adab6f-0f12-5985-8399-1703f97d909f -->
  <rule id="489643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0175 — Event Log Clearing (brotherhood)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>