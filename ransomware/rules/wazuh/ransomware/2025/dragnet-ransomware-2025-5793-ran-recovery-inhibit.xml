<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5793 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 431d7a0b-cb8b-5e5f-8f2c-e7b9aae32d37 -->
  <rule id="305562" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5793 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
