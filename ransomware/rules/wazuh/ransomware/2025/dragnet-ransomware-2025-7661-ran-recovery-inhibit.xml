<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7661 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 1b1657a6-6ea9-5ffb-952d-6f8e0574d7d6 -->
  <rule id="846522" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7661 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>