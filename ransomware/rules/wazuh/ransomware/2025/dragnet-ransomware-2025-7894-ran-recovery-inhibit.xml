<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7894 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 8f672425-9e5e-5939-ade3-96f5cc8456fb -->
  <rule id="636724" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7894 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>