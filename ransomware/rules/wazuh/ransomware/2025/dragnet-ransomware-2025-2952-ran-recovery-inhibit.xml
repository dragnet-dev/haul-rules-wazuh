<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2952 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 65bcbfb6-36c2-5db5-ac1d-f5af14a9f0fa -->
  <rule id="808159" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2952 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>