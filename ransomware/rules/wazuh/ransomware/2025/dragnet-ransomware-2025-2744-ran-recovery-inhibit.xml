<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2744 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e8f45e0d-5a2d-5077-baf3-c7f359df9a82 -->
  <rule id="313534" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2744 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>