<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5205 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 8d2a0569-4df3-5cdf-9e39-f7160642092e -->
  <rule id="560205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5205 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>