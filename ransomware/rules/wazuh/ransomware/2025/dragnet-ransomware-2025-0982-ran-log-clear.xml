<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0982 — Event Log Clearing (genesis) | Status: experimental | Sigma ID: 9a08e9cf-6fb0-540c-9ad1-ef9c16d104b0 -->
  <rule id="765429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0982 — Event Log Clearing (genesis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>