<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6776 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: d0404f51-cb00-5310-bfef-9b331a7edd46 -->
  <rule id="386479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6776 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>