<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2225 — Recovery Inhibition (weyhro) | Status: experimental | Sigma ID: 235ee0c8-24b0-5223-b628-0168e32b87be -->
  <rule id="763692" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2225 — Recovery Inhibition (weyhro)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>