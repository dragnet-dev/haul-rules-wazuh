<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0029 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: cb033c5a-b39e-51c1-bd72-25e8d9ec3fbe -->
  <rule id="648540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0029 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>