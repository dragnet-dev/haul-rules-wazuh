<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5986 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: f5cc296f-883e-533f-8ce5-8f0ed8d24df3 -->
  <rule id="488429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5986 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>