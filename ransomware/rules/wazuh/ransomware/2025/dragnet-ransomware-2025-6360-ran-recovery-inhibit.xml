<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6360 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: a970f431-4209-5ce6-a4c9-37cd31532c72 -->
  <rule id="955354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6360 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>