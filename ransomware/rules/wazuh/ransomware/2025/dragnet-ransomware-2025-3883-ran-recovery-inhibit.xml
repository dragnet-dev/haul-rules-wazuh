<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3883 — Recovery Inhibition (devman) | Status: deprecated | Sigma ID: e42e49ef-3cee-5795-b978-aa111a7c5fbe -->
  <rule id="608649" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3883 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>