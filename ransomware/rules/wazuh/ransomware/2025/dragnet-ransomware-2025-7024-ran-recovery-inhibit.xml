<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7024 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 832fe0ea-d556-5005-9ff8-ed6b49a7d500 -->
  <rule id="432460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7024 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>