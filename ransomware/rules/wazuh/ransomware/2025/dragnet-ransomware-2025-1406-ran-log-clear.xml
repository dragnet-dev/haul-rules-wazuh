<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1406 — Event Log Clearing (kawa4096) | Status: deprecated | Sigma ID: bc991ec4-026b-50f2-bf95-b4b05d930328 -->
  <rule id="423870" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1406 — Event Log Clearing (kawa4096)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>