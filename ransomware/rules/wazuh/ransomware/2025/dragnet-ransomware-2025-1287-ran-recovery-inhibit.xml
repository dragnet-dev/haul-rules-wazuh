<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1287 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: fb3d7bc7-718e-570e-b988-6e6751cdfd88 -->
  <rule id="235483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1287 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>