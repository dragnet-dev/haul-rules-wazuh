<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2155 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 18261fc2-51ce-59bf-abc4-24a1c3d312ef -->
  <rule id="275068" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2155 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>