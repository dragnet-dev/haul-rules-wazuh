<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7241 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 31f356e0-014c-5e33-83b0-faff7dec30d9 -->
  <rule id="181710" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7241 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>