<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2114 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8cb7bb52-5061-53d3-b314-4133b895f486 -->
  <rule id="464539" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2114 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>