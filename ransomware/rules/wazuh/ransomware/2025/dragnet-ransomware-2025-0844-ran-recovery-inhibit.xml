<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0844 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0a82ba08-9904-51d8-af21-ef2610abce2d -->
  <rule id="171780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0844 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>