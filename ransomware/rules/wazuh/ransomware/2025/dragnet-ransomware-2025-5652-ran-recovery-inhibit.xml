<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5652 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 467b52d6-0eca-5fba-9d3c-565031e0d5ca -->
  <rule id="373645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5652 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>