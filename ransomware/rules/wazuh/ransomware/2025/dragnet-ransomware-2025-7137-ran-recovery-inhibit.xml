<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7137 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: ccbcacdc-ecff-59f7-86d6-9fe412db7efe -->
  <rule id="917644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7137 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>