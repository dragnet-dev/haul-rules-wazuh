<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3186 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: dcbca9c6-3ad4-5251-a714-74587d61aaf9 -->
  <rule id="141389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3186 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>