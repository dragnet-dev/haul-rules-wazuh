<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4925 — Recovery Inhibition (IMNCrew) | Status: experimental | Sigma ID: f4157db7-830a-5b7b-a403-bb3736b4de29 -->
  <rule id="766525" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4925 — Recovery Inhibition (IMNCrew)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>