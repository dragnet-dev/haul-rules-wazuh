<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6982 — Event Log Clearing (securotrop) | Status: experimental | Sigma ID: 93b3ba2b-4f0f-5f68-a407-83ca8fbcff8b -->
  <rule id="338394" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6982 — Event Log Clearing (securotrop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>