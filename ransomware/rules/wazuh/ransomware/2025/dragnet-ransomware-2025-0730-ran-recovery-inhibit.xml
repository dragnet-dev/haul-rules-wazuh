<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0730 — Recovery Inhibition (ralord) | Status: experimental | Sigma ID: 2b8bd8f8-4cbc-5ec4-8180-371f620127f7 -->
  <rule id="323178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0730 — Recovery Inhibition (ralord)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>