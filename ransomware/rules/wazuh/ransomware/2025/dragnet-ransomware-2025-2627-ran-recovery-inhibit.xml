<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2627 — Recovery Inhibition (qilin) | Status: test | Sigma ID: a90e3fd4-7022-5af9-80fd-ad9676d787e4 -->
  <rule id="192703" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2627 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>