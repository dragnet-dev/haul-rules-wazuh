<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5544 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a5ea5a30-4537-5e59-9148-8e6916accdfe -->
  <rule id="838330" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5544 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>