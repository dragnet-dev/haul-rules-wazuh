<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6420 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6036e977-182c-53f9-bcfa-1bf03b599aba -->
  <rule id="759097" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6420 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>