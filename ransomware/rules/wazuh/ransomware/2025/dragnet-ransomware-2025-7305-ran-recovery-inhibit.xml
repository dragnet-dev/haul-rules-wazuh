<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7305 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3a7f3a14-61fd-5d34-a69d-cb3875e24edd -->
  <rule id="705178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7305 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>