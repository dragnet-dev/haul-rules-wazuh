<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5828 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 294f4393-46f7-598d-8e20-374207272a7a -->
  <rule id="319439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5828 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>