<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1242 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: edabf956-f192-52af-bd00-633dc960d62f -->
  <rule id="835039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1242 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>