<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7825 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 72b924fd-b065-5f21-9955-575591ce1b18 -->
  <rule id="363924" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7825 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>