<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7345 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 58fa2056-a981-5c0a-bc91-34631f15e513 -->
  <rule id="709820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7345 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>