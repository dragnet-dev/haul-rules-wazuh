<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6091 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 0271a7d1-3cf6-501a-976a-d47bd1e0e2d3 -->
  <rule id="754851" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6091 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>