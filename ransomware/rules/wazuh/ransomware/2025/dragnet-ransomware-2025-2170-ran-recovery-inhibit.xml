<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2170 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: ab4d6d70-5665-5669-822e-2bb84b36e34b -->
  <rule id="890029" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2170 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>