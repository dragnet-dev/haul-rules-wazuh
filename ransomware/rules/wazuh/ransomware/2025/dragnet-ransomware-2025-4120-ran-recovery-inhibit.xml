<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4120 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 30a7b13d-e8ec-5514-bd5f-602104ba09a2 -->
  <rule id="752313" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4120 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>