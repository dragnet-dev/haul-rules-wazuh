<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2062 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 558a9d44-db80-5a79-8710-d4ad778e9076 -->
  <rule id="630237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2062 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>