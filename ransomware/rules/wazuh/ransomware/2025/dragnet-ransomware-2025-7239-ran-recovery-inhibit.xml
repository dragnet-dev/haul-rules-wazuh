<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7239 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 731d479d-6bb5-5be5-862d-89b8daa0850e -->
  <rule id="370947" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7239 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>