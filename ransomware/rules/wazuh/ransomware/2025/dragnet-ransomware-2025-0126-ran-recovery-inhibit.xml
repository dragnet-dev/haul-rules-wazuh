<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0126 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: adc2eb9b-a060-54c0-906e-f56af12a3971 -->
  <rule id="917547" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0126 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>