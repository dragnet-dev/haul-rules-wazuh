<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2347 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 7c38f054-a856-5837-aca7-481067775856 -->
  <rule id="290230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2347 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>