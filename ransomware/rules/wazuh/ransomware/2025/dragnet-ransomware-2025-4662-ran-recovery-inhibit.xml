<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4662 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: c2347b73-645c-5e9b-9670-b23fd63a1ce2 -->
  <rule id="257563" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4662 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>