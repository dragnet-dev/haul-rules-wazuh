<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4655 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 3dace89b-013b-5794-8ade-082afb79e52e -->
  <rule id="826228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4655 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>