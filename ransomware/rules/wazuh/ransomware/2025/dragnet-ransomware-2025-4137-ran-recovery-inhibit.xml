<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4137 — Recovery Inhibition (qilin) | Status: test | Sigma ID: fd2a543e-de75-5f11-83ba-568fe73c3abb -->
  <rule id="552254" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4137 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>