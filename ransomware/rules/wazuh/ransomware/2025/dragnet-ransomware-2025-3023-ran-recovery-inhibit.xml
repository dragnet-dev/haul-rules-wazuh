<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3023 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f49f7060-581b-5d71-ba57-1d3d61bef139 -->
  <rule id="779970" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3023 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>