<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5439 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 227cf090-43a7-53d8-991e-2634a2f0154e -->
  <rule id="531909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5439 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>