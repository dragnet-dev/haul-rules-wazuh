<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6188 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 0844f5c6-d2c7-5459-a8c6-52d88898ee24 -->
  <rule id="463132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6188 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>