<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4192 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: 9439ef6e-d114-56cb-a7fe-297c2d28f22b -->
  <rule id="716623" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4192 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>