<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1248 — Recovery Inhibition (morpheus) | Status: deprecated | Sigma ID: dbf0ccb2-657c-51a5-9885-63c624618886 -->
  <rule id="108844" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1248 — Recovery Inhibition (morpheus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>