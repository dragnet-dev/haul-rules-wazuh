<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7507 — Event Log Clearing (funksec) | Status: experimental | Sigma ID: 11f9e1ce-7144-5cbb-88a8-73d4bdd398e4 -->
  <rule id="514908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7507 — Event Log Clearing (funksec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>