<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4158 — Event Log Clearing (radar) | Status: deprecated | Sigma ID: 2c2abe1c-4d83-5432-9481-a4ab70174856 -->
  <rule id="113182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4158 — Event Log Clearing (radar)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>