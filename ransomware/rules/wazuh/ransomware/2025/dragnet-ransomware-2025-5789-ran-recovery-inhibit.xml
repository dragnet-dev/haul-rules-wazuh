<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5789 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 760d2aaa-43ec-51e8-a70b-1734b44cf1ad -->
  <rule id="247722" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5789 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>