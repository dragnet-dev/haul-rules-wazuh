<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7268 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 56166593-28bd-5170-89d1-ca7e124a2442 -->
  <rule id="316659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7268 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>