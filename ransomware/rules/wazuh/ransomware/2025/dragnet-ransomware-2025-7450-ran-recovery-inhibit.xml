<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7450 — Recovery Inhibition (ralord) | Status: experimental | Sigma ID: 0341a9ea-8fd5-5bbd-b41b-de327868fbc0 -->
  <rule id="595498" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7450 — Recovery Inhibition (ralord)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>