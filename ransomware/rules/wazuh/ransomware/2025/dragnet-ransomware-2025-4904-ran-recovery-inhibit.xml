<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4904 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ab029a31-19a8-5bc2-9cd2-ef66d2b57160 -->
  <rule id="136474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4904 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>