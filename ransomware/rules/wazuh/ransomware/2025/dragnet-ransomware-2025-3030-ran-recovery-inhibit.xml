<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3030 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 17d4de2a-8fe6-5b27-9653-7430f4d675c6 -->
  <rule id="208462" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3030 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>