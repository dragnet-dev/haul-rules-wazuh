<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2327 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 30e5c9dd-0cf0-5527-9ffd-1d3f1df9799e -->
  <rule id="161277" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2327 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>