<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4088 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 26ce4ec0-c6bd-57fe-ba46-d37ed56e01b6 -->
  <rule id="297998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4088 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>