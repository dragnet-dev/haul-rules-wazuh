<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7573 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: cc556d93-7412-54a4-bded-585b75b4ed06 -->
  <rule id="672909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7573 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>