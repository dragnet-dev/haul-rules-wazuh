<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4548 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 17ec2048-b40b-59f9-82cc-d120f38689f1 -->
  <rule id="188204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4548 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>