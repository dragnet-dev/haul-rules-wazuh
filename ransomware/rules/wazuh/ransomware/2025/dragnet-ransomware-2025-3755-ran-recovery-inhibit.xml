<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3755 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 192a25cd-b96e-5af4-81cf-c02dbd328335 -->
  <rule id="531612" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3755 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>