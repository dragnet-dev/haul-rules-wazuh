<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3368 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: bfdf3ea4-d2cd-5516-8987-c951448f8166 -->
  <rule id="759102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3368 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>