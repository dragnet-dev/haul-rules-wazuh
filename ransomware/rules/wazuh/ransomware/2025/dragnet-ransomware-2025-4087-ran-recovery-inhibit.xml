<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4087 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 2316ff21-fecb-5673-8103-5bb95e1df01d -->
  <rule id="631512" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4087 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>