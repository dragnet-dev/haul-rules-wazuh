<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3803 — Event Log Clearing (blacknevas) | Status: experimental | Sigma ID: 6bfd7a2b-84b3-5db3-b05f-af1312a53ada -->
  <rule id="923322" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3803 — Event Log Clearing (blacknevas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>