<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5084 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 166780bc-6c28-5f4d-8fb0-34be4c39d1e9 -->
  <rule id="968491" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5084 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>