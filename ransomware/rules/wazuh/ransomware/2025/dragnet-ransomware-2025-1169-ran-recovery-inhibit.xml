<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1169 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 38c11a1f-392d-523c-a6c1-af2ddb014cfb -->
  <rule id="121861" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1169 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>