<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0491 — Recovery Inhibition (kraken) | Status: experimental | Sigma ID: 35e0383a-a216-5e0b-a8ea-5e5691764e9b -->
  <rule id="440383" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0491 — Recovery Inhibition (kraken)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>