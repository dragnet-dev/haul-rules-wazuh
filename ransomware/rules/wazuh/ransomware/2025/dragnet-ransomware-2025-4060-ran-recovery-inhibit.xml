<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4060 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 0f6ef820-98b0-5554-8dcd-4d256485095b -->
  <rule id="517582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4060 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>