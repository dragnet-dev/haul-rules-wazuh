<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3662 — Event Log Clearing (termite) | Status: experimental | Sigma ID: 751bdbe8-11c6-532c-8417-f1760c4cc4bf -->
  <rule id="479131" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3662 — Event Log Clearing (termite)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>