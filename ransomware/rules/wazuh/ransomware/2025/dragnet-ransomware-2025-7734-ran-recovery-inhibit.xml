<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7734 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 8b0b7b21-71fe-5d9c-9db2-ed9ae77d158b -->
  <rule id="960283" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7734 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>