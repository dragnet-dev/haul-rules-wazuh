<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6160 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 28845176-4d7f-5ccc-b0e8-98c72a4e0933 -->
  <rule id="284517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6160 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>