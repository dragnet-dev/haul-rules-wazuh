<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1586 — Recovery Inhibition (IMNCrew) | Status: experimental | Sigma ID: bb69610f-c4ed-5838-969b-2ec1c25e7e51 -->
  <rule id="176961" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1586 — Recovery Inhibition (IMNCrew)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>