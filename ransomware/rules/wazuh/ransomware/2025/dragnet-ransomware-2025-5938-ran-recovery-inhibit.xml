<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5938 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: d61ab7af-922d-5118-a981-76b024840307 -->
  <rule id="885877" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5938 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>