<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6897 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 9978b5d1-38ae-5543-91e8-1a133b985ac5 -->
  <rule id="796595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6897 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>