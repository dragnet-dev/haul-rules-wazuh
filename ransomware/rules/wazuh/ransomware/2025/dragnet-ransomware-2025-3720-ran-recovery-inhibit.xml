<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3720 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 14d42881-bd27-5f47-a7da-a95c7c17092a -->
  <rule id="674288" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3720 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>