<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2128 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: b7a677f0-a882-5a8b-8733-774f58a836c6 -->
  <rule id="182677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2128 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>