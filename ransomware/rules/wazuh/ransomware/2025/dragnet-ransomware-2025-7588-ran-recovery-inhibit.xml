<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7588 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 35599b10-1519-5028-9cd7-87265f70a052 -->
  <rule id="395951" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7588 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>