<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7560 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: 4de2e9a4-c8be-5812-9015-355265d8795e -->
  <rule id="294069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7560 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>