<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4071 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7dc2608c-de42-5f80-973a-77aa29c79725 -->
  <rule id="312260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4071 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>