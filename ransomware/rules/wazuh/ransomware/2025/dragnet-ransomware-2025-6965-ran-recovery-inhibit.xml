<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6965 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 44a76d27-3b2d-53c1-94da-99a5dadc80d8 -->
  <rule id="343629" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6965 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>