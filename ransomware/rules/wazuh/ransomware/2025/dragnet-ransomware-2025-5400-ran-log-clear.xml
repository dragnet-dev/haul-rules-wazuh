<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5400 — Event Log Clearing (lunalock) | Status: experimental | Sigma ID: 96c6dcd8-d58e-55cf-a85c-4c434ca84c23 -->
  <rule id="464636" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5400 — Event Log Clearing (lunalock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>