<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0756 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: 7a6d08ca-9292-5f5f-b5ef-0a84d6b53b31 -->
  <rule id="262908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0756 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>