<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6284 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 6161ae18-000b-5462-92a8-86246574a505 -->
  <rule id="777390" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6284 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>