<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1295 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 24696561-5e69-5206-8299-acbacbe917d6 -->
  <rule id="769656" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1295 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>