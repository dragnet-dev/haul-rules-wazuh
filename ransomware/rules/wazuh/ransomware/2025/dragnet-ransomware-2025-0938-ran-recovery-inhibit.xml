<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0938 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ae6311c9-43b9-5c13-bd8c-20311aed5ee7 -->
  <rule id="946311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0938 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>