<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0368 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 9734a07c-470b-5180-ac08-fd58e3b2cec9 -->
  <rule id="757540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0368 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>