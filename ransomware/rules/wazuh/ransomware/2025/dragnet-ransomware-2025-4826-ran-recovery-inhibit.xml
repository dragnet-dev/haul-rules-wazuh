<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4826 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d2495309-ed37-5949-aee3-64c9945761ba -->
  <rule id="524953" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4826 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>