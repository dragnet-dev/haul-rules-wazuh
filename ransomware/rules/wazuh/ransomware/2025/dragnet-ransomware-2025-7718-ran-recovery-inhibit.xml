<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7718 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 69664821-68e6-570f-b8f1-7775bd2359d5 -->
  <rule id="766482" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7718 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>