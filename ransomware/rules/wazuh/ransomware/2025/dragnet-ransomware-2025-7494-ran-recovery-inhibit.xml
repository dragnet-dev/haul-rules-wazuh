<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7494 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ac2e67ce-8854-58fe-8af8-d3f974df02a7 -->
  <rule id="156667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7494 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>