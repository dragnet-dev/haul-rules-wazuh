<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6968 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 3fcccf3c-caa3-5c4a-8cd7-62816ee05c29 -->
  <rule id="681199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6968 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>