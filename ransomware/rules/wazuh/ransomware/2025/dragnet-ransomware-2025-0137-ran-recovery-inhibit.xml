<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0137 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 67d4342a-7c0c-5666-a0e1-a2cbe0f324ce -->
  <rule id="285434" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0137 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>