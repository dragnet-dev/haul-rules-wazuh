<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7715 — Event Log Clearing (teamxxx) | Status: experimental | Sigma ID: 4366aecd-1110-50f6-89aa-560559d41388 -->
  <rule id="317870" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7715 — Event Log Clearing (teamxxx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>