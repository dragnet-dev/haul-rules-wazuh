<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2774 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 8d599f93-1f5d-5353-9504-bacebd6e081c -->
  <rule id="565599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2774 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>