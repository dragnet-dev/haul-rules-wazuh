<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4265 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 1bce8054-2512-5724-9e75-95b293a0a8c0 -->
  <rule id="918805" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4265 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>