<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0133 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 2c11f22b-6506-5737-a23d-03ee73cd1879 -->
  <rule id="859122" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0133 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>