<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1726 — Recovery Inhibition (weyhro) | Status: experimental | Sigma ID: ca946c0a-2347-5edb-b6e1-b1a7811f24a2 -->
  <rule id="647148" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1726 — Recovery Inhibition (weyhro)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>