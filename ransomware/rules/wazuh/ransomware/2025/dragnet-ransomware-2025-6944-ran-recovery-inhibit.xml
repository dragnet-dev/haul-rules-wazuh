<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6944 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: fa6cf268-29d7-5789-a711-6285ead334a9 -->
  <rule id="217432" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6944 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>