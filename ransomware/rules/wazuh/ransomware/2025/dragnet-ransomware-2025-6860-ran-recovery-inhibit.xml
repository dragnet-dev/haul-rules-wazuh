<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6860 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: d58934d1-e6bb-5550-9beb-3d1b6dc80184 -->
  <rule id="558934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6860 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>