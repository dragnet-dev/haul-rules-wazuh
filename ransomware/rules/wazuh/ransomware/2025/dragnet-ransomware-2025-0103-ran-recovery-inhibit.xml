<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0103 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: d26e9f8e-c221-51b7-a48f-aaa9fe2ea732 -->
  <rule id="796959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0103 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>