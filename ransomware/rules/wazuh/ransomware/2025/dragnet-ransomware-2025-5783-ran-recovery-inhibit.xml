<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5783 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 993bc131-24ef-5fad-be51-8c37b38655e6 -->
  <rule id="843961" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5783 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>