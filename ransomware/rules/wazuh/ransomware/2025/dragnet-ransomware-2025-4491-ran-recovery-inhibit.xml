<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4491 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 5df4c778-3eed-58f5-b485-2b9879363abc -->
  <rule id="705567" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4491 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>