<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7690 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: 79395727-c443-568e-b000-2d32cd40f185 -->
  <rule id="839572" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7690 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>