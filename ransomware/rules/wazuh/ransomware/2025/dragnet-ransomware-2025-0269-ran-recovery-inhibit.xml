<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0269 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f981f7c4-1c8a-54f4-86f0-4e8a8c5e97f1 -->
  <rule id="857117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0269 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>