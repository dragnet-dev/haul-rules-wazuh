<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4081 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 7076e7e3-36a1-59e1-80ae-8bcecb059971 -->
  <rule id="332307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4081 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>