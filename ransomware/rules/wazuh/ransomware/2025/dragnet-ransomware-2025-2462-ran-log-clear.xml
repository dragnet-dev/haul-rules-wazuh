<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2462 — Event Log Clearing (thegentlemen) | Status: test | Sigma ID: 1a7de166-9ca9-5674-a1c8-eb99a9961c9f -->
  <rule id="657416" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2462 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>