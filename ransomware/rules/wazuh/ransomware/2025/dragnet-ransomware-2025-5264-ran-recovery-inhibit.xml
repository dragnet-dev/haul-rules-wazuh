<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5264 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: deff7e28-e67c-5729-8d9a-16f479557104 -->
  <rule id="234046" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5264 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>