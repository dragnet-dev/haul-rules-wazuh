<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2251 — Event Log Clearing (RunSomeWares) | Status: experimental | Sigma ID: 82be1af2-3924-57a9-9978-eba87e41dc37 -->
  <rule id="789146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2251 — Event Log Clearing (RunSomeWares)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>