<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3739 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 3b601d9e-4908-5b96-8e0b-e4e328194898 -->
  <rule id="636299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3739 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>