<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5018 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 62360c2b-677e-5c4e-8d3f-ebc2288e2973 -->
  <rule id="177722" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5018 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>