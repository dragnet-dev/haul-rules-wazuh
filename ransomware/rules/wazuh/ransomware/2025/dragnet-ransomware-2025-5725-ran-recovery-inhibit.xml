<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5725 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: b463076c-e203-5e60-be57-74c1e5afe32c -->
  <rule id="346307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5725 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>