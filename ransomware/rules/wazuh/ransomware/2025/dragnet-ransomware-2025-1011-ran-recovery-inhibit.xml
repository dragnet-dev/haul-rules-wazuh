<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1011 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 411f2d37-bd4f-5ac3-8ea0-9ca1ecbf9401 -->
  <rule id="254605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1011 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>