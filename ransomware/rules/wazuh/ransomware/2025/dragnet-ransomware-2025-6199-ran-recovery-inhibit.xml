<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6199 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: d9ba2799-cb43-5904-9d89-6a1f1d3034e9 -->
  <rule id="977027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6199 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>