<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2131 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: 19e3fa41-baea-588a-ad71-af1d24efc72d -->
  <rule id="150984" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2131 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>