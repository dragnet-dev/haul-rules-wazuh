<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2274 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 1cdfc213-82b1-5e58-b8e7-fca5d26af2e4 -->
  <rule id="382682" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2274 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>