<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4204 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: bfd9836e-3bf7-5574-8c0d-1d3e0d1d4d73 -->
  <rule id="469983" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4204 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>