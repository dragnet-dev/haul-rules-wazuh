<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3401 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 39c153b2-cb95-546b-8e52-5f1fe98108a2 -->
  <rule id="378459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3401 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>