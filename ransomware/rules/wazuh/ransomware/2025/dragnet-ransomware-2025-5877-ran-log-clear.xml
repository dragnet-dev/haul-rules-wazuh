<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5877 — Event Log Clearing (silent) | Status: experimental | Sigma ID: 2dc4f6d8-71d9-5cf1-8b6d-a275c573a548 -->
  <rule id="371996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5877 — Event Log Clearing (silent)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>