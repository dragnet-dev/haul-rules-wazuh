<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3466 — Event Log Clearing (nightspire) | Status: experimental | Sigma ID: 6266fe3c-1bb3-5b47-83dd-361939c0b5f3 -->
  <rule id="804350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3466 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>