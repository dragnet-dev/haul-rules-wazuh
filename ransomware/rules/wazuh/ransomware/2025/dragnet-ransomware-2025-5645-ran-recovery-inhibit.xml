<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5645 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 85074023-524e-549e-96a5-a84aeb68d17c -->
  <rule id="507402" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5645 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>