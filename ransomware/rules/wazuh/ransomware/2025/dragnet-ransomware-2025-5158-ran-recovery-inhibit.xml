<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5158 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ff8b583f-ad04-5763-b1a4-5c22a1dc76a4 -->
  <rule id="593958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5158 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>