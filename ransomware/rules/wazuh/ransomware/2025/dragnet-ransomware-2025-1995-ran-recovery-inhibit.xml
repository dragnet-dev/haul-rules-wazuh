<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1995 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 11179f57-169d-5737-84f0-ed4ceb5e8f83 -->
  <rule id="988795" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1995 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>