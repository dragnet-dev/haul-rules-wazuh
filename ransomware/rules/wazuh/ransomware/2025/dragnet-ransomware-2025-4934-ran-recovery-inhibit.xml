<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4934 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 97458af5-b6e8-5398-acb6-eac138cc34ef -->
  <rule id="759338" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4934 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>