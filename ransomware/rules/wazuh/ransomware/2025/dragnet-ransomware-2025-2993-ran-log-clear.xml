<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2993 — Event Log Clearing (chaos) | Status: experimental | Sigma ID: 325cddfc-e87c-5f68-9ab9-babb10e8acd3 -->
  <rule id="534493" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2993 — Event Log Clearing (chaos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>