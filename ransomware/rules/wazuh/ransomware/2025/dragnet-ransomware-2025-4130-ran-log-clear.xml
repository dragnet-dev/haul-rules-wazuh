<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4130 — Event Log Clearing (alphalocker) | Status: experimental | Sigma ID: 1d1edd2c-3b21-53a8-a07e-815b76e3d535 -->
  <rule id="395741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4130 — Event Log Clearing (alphalocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>