<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1004 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: f5b743cc-fa32-5c99-b8ca-dbd5d398a0d2 -->
  <rule id="791743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1004 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>