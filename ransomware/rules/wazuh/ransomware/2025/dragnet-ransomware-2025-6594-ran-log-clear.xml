<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6594 — Event Log Clearing (cicada3301) | Status: experimental | Sigma ID: daf6dd5c-0de5-5f0d-9ce3-f4dcc2a9ea99 -->
  <rule id="969437" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6594 — Event Log Clearing (cicada3301)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>