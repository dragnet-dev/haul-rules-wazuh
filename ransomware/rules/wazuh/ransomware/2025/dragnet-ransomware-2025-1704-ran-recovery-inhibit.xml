<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1704 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b5080cab-35a7-5227-b24f-feb4496841f0 -->
  <rule id="141292" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1704 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>