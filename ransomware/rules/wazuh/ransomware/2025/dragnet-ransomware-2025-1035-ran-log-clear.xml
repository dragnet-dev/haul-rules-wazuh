<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1035 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 69ba5930-8e9c-5588-a40b-1a9f7ab04f88 -->
  <rule id="985059" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1035 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>