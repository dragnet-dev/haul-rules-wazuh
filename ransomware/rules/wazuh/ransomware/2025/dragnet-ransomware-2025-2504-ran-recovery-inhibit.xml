<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2504 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 356246ed-4691-59e7-8d48-c7378fa9af1d -->
  <rule id="399950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2504 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>