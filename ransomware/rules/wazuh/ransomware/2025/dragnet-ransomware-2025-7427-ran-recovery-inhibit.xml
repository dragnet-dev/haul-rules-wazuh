<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7427 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ec7dbee0-ad22-5697-a603-2e2c1f34b7b1 -->
  <rule id="798750" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7427 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>