<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2036 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: b8fde8a0-c01b-5d9e-9a6b-e1cd219ea489 -->
  <rule id="473908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2036 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>