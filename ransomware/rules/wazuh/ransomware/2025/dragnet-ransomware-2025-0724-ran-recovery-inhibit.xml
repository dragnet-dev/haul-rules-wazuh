<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0724 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: ceb1b4f4-4744-5893-9fb6-d3d5fe27da40 -->
  <rule id="891474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0724 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>