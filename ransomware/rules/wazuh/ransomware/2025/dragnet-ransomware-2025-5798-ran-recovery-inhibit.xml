<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5798 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 3bc87174-a8a5-5350-9196-deeaeed2f45a -->
  <rule id="668717" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5798 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>