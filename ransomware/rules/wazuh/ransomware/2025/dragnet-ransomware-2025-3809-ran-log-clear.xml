<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3809 — Event Log Clearing (datacarry) | Status: deprecated | Sigma ID: 37a0bdd2-203f-5603-b3ef-95ad27c7adbc -->
  <rule id="741309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3809 — Event Log Clearing (datacarry)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>