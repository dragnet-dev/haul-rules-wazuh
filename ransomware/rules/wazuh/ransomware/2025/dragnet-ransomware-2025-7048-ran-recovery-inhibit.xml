<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7048 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ee6e3254-6638-57a4-8b31-a35961d571b1 -->
  <rule id="319032" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7048 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>