<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1559 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: aef11864-234a-5819-b705-6614ab8c3c01 -->
  <rule id="199118" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1559 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>