<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7770 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: d01d8bd1-9896-5893-a4b6-55251569cc8d -->
  <rule id="732779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7770 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>