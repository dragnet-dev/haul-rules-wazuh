<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1910 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 3ff9e86f-f380-59bd-aaf5-efc9e69ccfd5 -->
  <rule id="838388" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1910 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>