<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4991 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 8bfdf409-5f4a-5748-b978-7a987c7d9401 -->
  <rule id="434074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4991 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>