<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5709 — Recovery Inhibition (lynx) | Status: test | Sigma ID: f68e36d1-e990-55b2-98fd-82e82358365a -->
  <rule id="810236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5709 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
