<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2691 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: c6c2f419-d798-544e-811c-bc41f96ddfba -->
  <rule id="645274" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2691 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>