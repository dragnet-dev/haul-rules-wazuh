<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4243 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6f8e1a5b-5427-5944-9949-cc661ffd43ee -->
  <rule id="264346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4243 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>