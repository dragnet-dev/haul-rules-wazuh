<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2049 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ba141548-ddd1-5b50-abe2-59a47968aac5 -->
  <rule id="161415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2049 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>