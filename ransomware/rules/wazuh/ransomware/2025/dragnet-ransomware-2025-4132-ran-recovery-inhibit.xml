<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4132 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2b3c300f-2309-5e03-9fd0-574e3b606cfd -->
  <rule id="740300" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4132 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>