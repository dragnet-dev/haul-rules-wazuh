<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4508 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: eb08b5bc-8f8d-52ee-8940-6a06fa3b0cc4 -->
  <rule id="261395" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4508 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>