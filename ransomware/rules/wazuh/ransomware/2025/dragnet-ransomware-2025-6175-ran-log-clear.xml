<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6175 — Event Log Clearing (worldleaks) | Status: experimental | Sigma ID: 55b9df1c-e5fb-5059-92dc-aa0f751fa011 -->
  <rule id="583487" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6175 — Event Log Clearing (worldleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>