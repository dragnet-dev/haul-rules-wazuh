<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3203 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 14b693b5-a619-506b-9cfb-e41db343ce51 -->
  <rule id="271099" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3203 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>