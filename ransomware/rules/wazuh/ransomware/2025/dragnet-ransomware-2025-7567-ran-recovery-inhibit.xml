<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7567 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 9700ddaa-f2e4-5d46-a5ed-ab40a4111587 -->
  <rule id="783421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7567 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>