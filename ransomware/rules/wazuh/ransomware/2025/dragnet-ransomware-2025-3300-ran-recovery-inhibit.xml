<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3300 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 80d946d9-24ca-5979-bab8-ddcc6dfee85e -->
  <rule id="493946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3300 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>