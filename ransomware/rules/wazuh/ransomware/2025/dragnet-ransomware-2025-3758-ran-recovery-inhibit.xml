<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3758 — Recovery Inhibition (weyhro) | Status: experimental | Sigma ID: ad611e68-18d1-536b-87a6-e4d0539fee12 -->
  <rule id="177790" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3758 — Recovery Inhibition (weyhro)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>