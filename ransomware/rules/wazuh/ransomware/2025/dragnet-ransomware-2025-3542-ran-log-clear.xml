<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3542 — Event Log Clearing (kairos) | Status: experimental | Sigma ID: e6b2c0f6-6f1e-59a7-a4c1-c7d86e874960 -->
  <rule id="255640" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3542 — Event Log Clearing (kairos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>