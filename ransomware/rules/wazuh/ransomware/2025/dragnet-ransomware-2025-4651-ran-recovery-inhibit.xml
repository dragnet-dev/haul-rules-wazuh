<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4651 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 4cb96601-21fc-51e6-ad4e-8d785da82ec0 -->
  <rule id="427966" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4651 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>