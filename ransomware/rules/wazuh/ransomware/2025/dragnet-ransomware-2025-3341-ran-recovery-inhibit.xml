<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3341 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: 2a8ecb91-f14b-5272-8559-c17f0f87241b -->
  <rule id="956875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3341 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>