<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4948 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: a9740bda-3efa-5598-8860-02c0a5f11f89 -->
  <rule id="955851" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4948 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>