<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6318 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 18408ac3-7847-54bd-9781-079d92cf09f8 -->
  <rule id="312620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6318 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>