<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6636 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: a2ea5514-0ece-5826-9191-1f5503283757 -->
  <rule id="934655" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6636 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>