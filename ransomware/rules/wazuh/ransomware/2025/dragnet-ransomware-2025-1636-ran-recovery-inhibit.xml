<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1636 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a09f09f2-804e-5da1-8bdd-efa8b2cc795c -->
  <rule id="815909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1636 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>