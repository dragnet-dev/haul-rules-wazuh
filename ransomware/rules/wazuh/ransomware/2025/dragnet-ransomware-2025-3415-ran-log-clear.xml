<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3415 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: 0787d3d6-0f5a-5fbb-8e7a-3343e728b8f0 -->
  <rule id="316861" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3415 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>