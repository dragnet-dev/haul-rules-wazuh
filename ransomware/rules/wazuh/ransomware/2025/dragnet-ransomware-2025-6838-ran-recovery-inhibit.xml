<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6838 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 8a41493b-1dd2-52ea-884b-2fecacba92aa -->
  <rule id="584149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6838 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>