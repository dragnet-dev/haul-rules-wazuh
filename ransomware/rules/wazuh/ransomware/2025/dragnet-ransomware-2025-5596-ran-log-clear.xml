<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5596 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: ec9bbdf8-8ca8-5bf3-8593-d7df4c9a4545 -->
  <rule id="806429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5596 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>