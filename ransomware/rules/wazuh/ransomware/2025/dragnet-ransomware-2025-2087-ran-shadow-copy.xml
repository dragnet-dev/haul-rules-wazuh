<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2087 — Shadow Copy Deletion (RunSomeWares) | Status: experimental | Sigma ID: a8cfc05a-86ba-5ea0-8543-3a192acb4a9b -->
  <rule id="956920" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2087 — Shadow Copy Deletion (RunSomeWares)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>