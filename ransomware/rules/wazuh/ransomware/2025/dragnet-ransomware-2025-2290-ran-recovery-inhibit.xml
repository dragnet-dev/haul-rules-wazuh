  <rule id="447889" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2290 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
