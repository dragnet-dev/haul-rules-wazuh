<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5772 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: c75a89f7-fb50-50a5-b302-3a3b52cf2e06 -->
  <rule id="341089" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5772 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>