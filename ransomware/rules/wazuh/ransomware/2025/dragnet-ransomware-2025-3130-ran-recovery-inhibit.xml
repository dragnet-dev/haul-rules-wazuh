<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3130 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 170e4a23-d4b4-50c8-a706-f04189af230a -->
  <rule id="875142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3130 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>