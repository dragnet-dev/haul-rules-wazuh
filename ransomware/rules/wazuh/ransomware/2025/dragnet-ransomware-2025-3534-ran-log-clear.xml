<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3534 — Event Log Clearing (monti) | Status: experimental | Sigma ID: 5b69b0a1-bbf6-5dbc-b0ac-9edb90c8925a -->
  <rule id="667150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3534 — Event Log Clearing (monti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>