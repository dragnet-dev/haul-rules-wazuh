<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0291 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: e01073d1-42e3-5d89-ac30-3c82cb1d1b4f -->
  <rule id="601073" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0291 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>