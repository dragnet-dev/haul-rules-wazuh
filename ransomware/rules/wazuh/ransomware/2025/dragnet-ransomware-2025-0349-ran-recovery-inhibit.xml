<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0349 — Recovery Inhibition (crazyhunter) | Status: experimental | Sigma ID: a789bc5f-d0ed-5b52-809d-e457cdf93558 -->
  <rule id="162172" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0349 — Recovery Inhibition (crazyhunter)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>