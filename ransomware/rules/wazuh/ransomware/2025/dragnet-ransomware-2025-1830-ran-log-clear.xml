<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1830 — Event Log Clearing (play) | Status: experimental | Sigma ID: 3ee0bbce-1ca8-53c0-9d2e-d431ea70fe6e -->
  <rule id="875547" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1830 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>