<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7338 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 612cfb72-064d-5077-981c-c7eaaec69f5a -->
  <rule id="810075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7338 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>