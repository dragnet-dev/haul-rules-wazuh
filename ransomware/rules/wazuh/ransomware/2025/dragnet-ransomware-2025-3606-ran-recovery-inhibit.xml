<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3606 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 7821a625-2969-51a1-87fa-5f53b600f610 -->
  <rule id="451466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3606 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>