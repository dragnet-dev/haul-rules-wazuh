<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3968 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: fd65ddbd-d81b-54f0-afdc-b969323a5397 -->
  <rule id="293661" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3968 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>