<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3759 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: e5646990-58cf-50ab-80f2-1af2ff8f6b47 -->
  <rule id="656469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3759 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>