<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7695 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 58f7fdfc-7b40-5574-bb55-7ac7c2ea26bf -->
  <rule id="716125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7695 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>