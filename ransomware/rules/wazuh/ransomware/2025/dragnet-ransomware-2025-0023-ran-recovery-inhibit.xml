<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0023 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: 96ab369f-c05b-54c0-bb75-6519a5966263 -->
  <rule id="774736" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0023 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
