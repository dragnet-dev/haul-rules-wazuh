<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2551 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 914a1a85-e89c-584b-89d8-c937ef364e51 -->
  <rule id="641466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2551 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>