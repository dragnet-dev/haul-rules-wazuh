<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6882 — Event Log Clearing (dragonforce) | Status: experimental | Sigma ID: 7f5c4bc7-d2c8-5612-87ae-9b4d22e76504 -->
  <rule id="665995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6882 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>