<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4200 — Recovery Inhibition (nightspire) | Status: experimental | Sigma ID: 195fceb6-d625-584e-8a95-8475b23275f7 -->
  <rule id="344267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4200 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>