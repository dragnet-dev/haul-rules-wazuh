<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3343 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: b1227b46-f698-545b-b7f6-f6128ea3c873 -->
  <rule id="979643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3343 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>