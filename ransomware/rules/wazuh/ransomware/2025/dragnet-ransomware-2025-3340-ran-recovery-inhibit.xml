<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3340 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: 74f6f8c9-dfac-532e-b3f4-284d408e1db7 -->
  <rule id="219518" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3340 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>