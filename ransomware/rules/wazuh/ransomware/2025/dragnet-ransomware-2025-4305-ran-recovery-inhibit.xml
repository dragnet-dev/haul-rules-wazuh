<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4305 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: 6282120f-3a52-50a8-ae06-768e051b1bc9 -->
  <rule id="982120" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4305 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
