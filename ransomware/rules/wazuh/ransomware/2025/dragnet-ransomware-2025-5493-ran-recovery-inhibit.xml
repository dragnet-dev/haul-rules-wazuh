<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5493 — Recovery Inhibition (devman) | Status: test | Sigma ID: 459b01d1-665b-5850-ba00-b36e416faf4e -->
  <rule id="168029" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5493 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>