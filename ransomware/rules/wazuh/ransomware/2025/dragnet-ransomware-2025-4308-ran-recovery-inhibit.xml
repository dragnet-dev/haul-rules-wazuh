<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4308 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: cf113774-e2af-5285-bec1-c360ce88d26c -->
  <rule id="371137" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4308 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>