<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5436 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: c38ab2b6-6507-5fde-a4b8-8f1ebcd4c987 -->
  <rule id="570992" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5436 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>