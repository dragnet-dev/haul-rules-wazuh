<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5402 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 85f2ceb2-6d9d-53a0-b84e-4e48c493d8d4 -->
  <rule id="920718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5402 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>