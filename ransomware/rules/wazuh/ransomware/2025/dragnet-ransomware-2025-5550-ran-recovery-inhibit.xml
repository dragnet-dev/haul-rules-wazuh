<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5550 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: b93d85d8-31cd-58d7-b36f-fde22e6a3931 -->
  <rule id="210185" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5550 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>