<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7710 — Recovery Inhibition (ralord) | Status: experimental | Sigma ID: a6305cf9-035e-543b-8a4b-0b853a7a5263 -->
  <rule id="900892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7710 — Recovery Inhibition (ralord)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>