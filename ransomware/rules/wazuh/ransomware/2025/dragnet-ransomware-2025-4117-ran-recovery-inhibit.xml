<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4117 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ce18c280-fd35-571e-b1b1-db1eb9ee43a0 -->
  <rule id="699002" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4117 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>