<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7018 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 536ae291-22f7-5e2c-97b3-cb812caab46f -->
  <rule id="573902" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7018 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>