<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4148 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 972bd46a-bd35-5c97-bb2a-94cdd86ff8d8 -->
  <rule id="790214" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4148 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>