<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2582 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0591eee1-0aae-5527-b331-bdc44593175f -->
  <rule id="724558" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2582 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>