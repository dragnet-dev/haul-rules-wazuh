<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0448 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 27a71a1b-001b-57e3-bbc2-68e4c26f0947 -->
  <rule id="883461" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0448 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>