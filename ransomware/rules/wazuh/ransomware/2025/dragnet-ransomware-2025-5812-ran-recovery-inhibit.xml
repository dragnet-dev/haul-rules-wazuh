<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5812 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 5ab1efdd-5fac-5ec8-aeae-90f12196dbdf -->
  <rule id="215055" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5812 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>