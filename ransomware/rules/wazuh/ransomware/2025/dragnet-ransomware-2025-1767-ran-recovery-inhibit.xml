<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1767 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 4a64fb4b-897e-5662-bc37-aa7f83422a09 -->
  <rule id="211035" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1767 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>