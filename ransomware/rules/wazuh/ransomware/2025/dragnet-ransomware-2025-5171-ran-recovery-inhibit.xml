<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5171 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 4205fdd1-9f83-55cc-8717-5a0fb03e48b2 -->
  <rule id="276733" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5171 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>