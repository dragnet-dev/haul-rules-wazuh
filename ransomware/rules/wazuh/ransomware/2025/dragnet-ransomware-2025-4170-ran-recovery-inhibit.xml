<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4170 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 25cff542-7a13-5899-b7bc-7f5a941f13c7 -->
  <rule id="257275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4170 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>