<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3287 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: cbee992e-2ae4-5e14-88b7-61172a1e314c -->
  <rule id="820699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3287 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>