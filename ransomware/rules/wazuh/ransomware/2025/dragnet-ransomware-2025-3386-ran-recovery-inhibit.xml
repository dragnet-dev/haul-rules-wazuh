<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3386 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 2f8b7fe5-3ae2-5571-865c-e38ad39c168e -->
  <rule id="425567" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3386 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>