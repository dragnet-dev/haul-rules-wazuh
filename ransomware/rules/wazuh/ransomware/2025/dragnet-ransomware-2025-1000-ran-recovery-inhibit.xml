<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1000 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 97f81541-52ac-551a-a118-21af38c51c8e -->
  <rule id="767815" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1000 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>