<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4812 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 4da777cd-7dd0-52b0-a793-5abfcd9279a7 -->
  <rule id="442777" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4812 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>