<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7203 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: b6fdfcd6-a0ed-56b5-8967-c3b6c7753998 -->
  <rule id="567196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7203 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>