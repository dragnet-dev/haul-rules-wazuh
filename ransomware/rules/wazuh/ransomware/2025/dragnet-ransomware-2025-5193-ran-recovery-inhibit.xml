<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5193 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 9f7c6998-9e79-5ca7-9f20-e4d4627debf1 -->
  <rule id="856469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5193 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>