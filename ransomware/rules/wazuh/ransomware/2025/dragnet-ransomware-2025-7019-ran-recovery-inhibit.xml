<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7019 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: 35bc97bb-4044-5e02-a729-8cbba96376ac -->
  <rule id="338363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7019 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>