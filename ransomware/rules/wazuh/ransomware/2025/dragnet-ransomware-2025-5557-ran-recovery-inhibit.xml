<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5557 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 24dc0c08-bfb3-535e-9f3a-bc7f69f4ff12 -->
  <rule id="218252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5557 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>