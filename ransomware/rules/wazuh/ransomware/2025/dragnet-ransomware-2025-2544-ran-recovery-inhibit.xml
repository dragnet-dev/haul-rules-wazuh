<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2544 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 02efa1cd-f445-5bab-89ba-76f1b7bafdc8 -->
  <rule id="224188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2544 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>