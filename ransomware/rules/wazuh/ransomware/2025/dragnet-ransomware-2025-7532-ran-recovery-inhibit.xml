<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7532 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c7ff21ca-5073-5e29-bf7e-9ab253afa94f -->
  <rule id="676721" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7532 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>