<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0033 — Event Log Clearing (dragonforce) | Status: experimental | Sigma ID: 8df160e4-60ab-5915-b0dd-5a0d1d4efe0b -->
  <rule id="571160" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0033 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>