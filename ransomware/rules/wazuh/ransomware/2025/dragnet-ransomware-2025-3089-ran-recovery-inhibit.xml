<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3089 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: d265ace6-109d-5604-866a-8c2b0be96076 -->
  <rule id="796012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3089 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>