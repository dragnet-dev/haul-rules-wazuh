<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2947 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 5abe4f4e-d8fd-5a41-a5d9-71de9a1a8c43 -->
  <rule id="216879" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2947 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>