<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3249 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 97f50dd6-6e89-5d6c-8257-284eac7564cc -->
  <rule id="808013" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3249 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>