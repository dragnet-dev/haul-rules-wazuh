<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7877 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4fd25a53-f0af-5bb4-841b-b1764a8d2bdd -->
  <rule id="343610" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7877 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>