<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0437 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 60d0ff44-6cd0-5f26-9852-9526371463fc -->
  <rule id="791135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0437 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>