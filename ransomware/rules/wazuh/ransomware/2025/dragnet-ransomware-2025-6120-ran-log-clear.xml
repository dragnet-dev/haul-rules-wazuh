<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6120 — Event Log Clearing (interlock) | Status: experimental | Sigma ID: 4e6ecc4f-06c8-5dbd-9b9f-c930ca66a68d -->
  <rule id="623244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6120 — Event Log Clearing (interlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>