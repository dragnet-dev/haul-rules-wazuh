<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3450 — Event Log Clearing (lockbit5) | Status: test | Sigma ID: ea8456b1-c8d9-5ab0-b71e-921d8b9dd7ce -->
  <rule id="648456" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3450 — Event Log Clearing (lockbit5)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>