<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7150 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: d5cc35e9-6e10-5785-89d5-278ec55be9a4 -->
  <rule id="876435" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7150 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>