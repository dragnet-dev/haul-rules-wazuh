<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0250 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 74164049-09e1-5b01-a3de-90fa92466098 -->
  <rule id="316404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0250 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>