<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2325 — Event Log Clearing (safepay) | Status: test | Sigma ID: 2f40df9b-8a09-5b51-8c1b-e297586a7f2f -->
  <rule id="413663" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2325 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>