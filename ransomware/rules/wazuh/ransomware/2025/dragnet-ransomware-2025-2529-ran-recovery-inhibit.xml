<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2529 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 104bca72-94f3-55f8-845c-266c00132c3d -->
  <rule id="790027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2529 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>