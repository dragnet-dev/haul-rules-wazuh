<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3509 — Event Log Clearing (warlock) | Status: deprecated | Sigma ID: dfb5c21a-8cbf-5bcd-a72f-ca27ddee79d3 -->
  <rule id="427322" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3509 — Event Log Clearing (warlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>