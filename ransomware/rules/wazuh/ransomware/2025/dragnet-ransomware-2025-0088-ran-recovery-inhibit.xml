<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0088 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 89d6a048-e3cb-5fc6-9dd5-76e01d0d74f8 -->
  <rule id="600260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0088 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>