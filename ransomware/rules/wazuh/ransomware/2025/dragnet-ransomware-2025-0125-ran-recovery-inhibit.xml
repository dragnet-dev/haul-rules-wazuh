<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0125 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: a83a0140-9e16-563d-a283-94206a8668a4 -->
  <rule id="933801" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0125 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>