<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0091 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 67b2bf3b-dd47-5846-bf0c-e31b64491f15 -->
  <rule id="173183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0091 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>