<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6030 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 9ea726b3-f033-5b84-9989-152435947c4a -->
  <rule id="838726" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6030 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>