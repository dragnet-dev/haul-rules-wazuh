<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4317 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: a462a13c-bb20-5bf4-9ea1-56d05261e63b -->
  <rule id="874021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4317 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>