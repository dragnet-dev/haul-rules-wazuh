<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4687 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: b41228c7-85db-5b9c-9ebf-b631225ac942 -->
  <rule id="341228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4687 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>