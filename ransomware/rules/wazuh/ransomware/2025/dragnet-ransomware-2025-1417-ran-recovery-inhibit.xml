<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1417 — Recovery Inhibition (play) | Status: experimental | Sigma ID: be731a7d-79dd-56bf-99b2-7001d56e9f28 -->
  <rule id="451706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1417 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>