<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7813 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 274321a4-b33d-5123-8983-d7c354220e0e -->
  <rule id="889146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7813 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>