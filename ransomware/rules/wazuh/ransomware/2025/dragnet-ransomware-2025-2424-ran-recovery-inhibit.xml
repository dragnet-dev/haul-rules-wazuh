<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2424 — Recovery Inhibition (thegentlemen) | Status: experimental | Sigma ID: 47ec209c-ec67-5303-92a7-87b2560feeb7 -->
  <rule id="426820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2424 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>