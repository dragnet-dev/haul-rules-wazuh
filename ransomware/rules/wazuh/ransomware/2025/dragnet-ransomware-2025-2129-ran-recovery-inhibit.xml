<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2129 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 5918075c-8834-5858-8591-881baa6b3e7b -->
  <rule id="618075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2129 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>