<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0797 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 08b8652e-34d1-5874-a283-2fa30540777d -->
  <rule id="598652" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0797 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>