<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0365 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b434c460-c206-5434-9907-701ebb39eb73 -->
  <rule id="129564" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0365 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>