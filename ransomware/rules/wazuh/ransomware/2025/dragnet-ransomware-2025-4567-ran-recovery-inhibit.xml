<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4567 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 56ba6fbe-9a04-5222-95cd-85c3226468d0 -->
  <rule id="623631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4567 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>