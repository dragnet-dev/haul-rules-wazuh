<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7863 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: aa35e63a-c2db-5985-b0ca-ffe3fb6f8c2b -->
  <rule id="125746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7863 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>