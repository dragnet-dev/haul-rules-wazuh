<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2031 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3fa19208-15ca-57f6-b14b-4da0dd5a2857 -->
  <rule id="218192" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2031 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>