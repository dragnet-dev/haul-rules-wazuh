<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1904 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 319a82aa-7a1b-5d16-85c1-50f5b85ff58d -->
  <rule id="183722" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1904 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>