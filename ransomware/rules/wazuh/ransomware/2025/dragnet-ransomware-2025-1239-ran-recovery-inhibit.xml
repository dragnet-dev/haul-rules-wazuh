<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1239 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 2746edcb-9513-5fbd-98ff-664a26e078e1 -->
  <rule id="551420" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1239 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>