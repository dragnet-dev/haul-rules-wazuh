<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0385 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 77f7a4c6-1370-51de-8f05-f2bb99650d04 -->
  <rule id="296424" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0385 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>