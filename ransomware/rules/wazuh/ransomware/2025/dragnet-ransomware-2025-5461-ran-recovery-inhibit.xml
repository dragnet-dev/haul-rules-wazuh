<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5461 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 4929ba5f-b6f9-577c-a1da-21d93ec203a5 -->
  <rule id="462010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5461 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>