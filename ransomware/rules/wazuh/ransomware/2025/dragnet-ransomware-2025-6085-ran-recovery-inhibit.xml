<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6085 — Recovery Inhibition (crazyhunter) | Status: experimental | Sigma ID: a4f42fd2-d03b-514e-8f79-fa095a125fc1 -->
  <rule id="987087" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6085 — Recovery Inhibition (crazyhunter)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>