<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4714 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: ae9e1f7d-7d41-58f2-bf74-09ff1d2a0d3e -->
  <rule id="979711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4714 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>