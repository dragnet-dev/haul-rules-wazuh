<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2709 — Recovery Inhibition (handala) | Status: test | Sigma ID: 29a08372-2e8c-5347-851b-d882ae42f6dc -->
  <rule id="340837" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2709 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>