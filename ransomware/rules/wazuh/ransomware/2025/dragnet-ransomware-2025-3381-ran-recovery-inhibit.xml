<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3381 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 75297067-6170-576b-8cc3-cb5a81f3d0be -->
  <rule id="429706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3381 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>