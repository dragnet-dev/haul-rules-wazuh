<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2397 — Recovery Inhibition (thegentlemen) | Status: experimental | Sigma ID: 10487d81-f1a6-5533-ab84-edf1ed9063fb -->
  <rule id="878058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2397 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>