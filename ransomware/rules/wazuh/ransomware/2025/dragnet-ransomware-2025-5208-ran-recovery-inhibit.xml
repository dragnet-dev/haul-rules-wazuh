<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5208 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 24044dbf-5c69-5fbd-bf14-c05ee9221fca -->
  <rule id="855483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5208 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>