<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0310 — Event Log Clearing (payoutsking) | Status: experimental | Sigma ID: 2cc8a9fd-f27a-5ad3-94aa-6482aaba02cd -->
  <rule id="346989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0310 — Event Log Clearing (payoutsking)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>