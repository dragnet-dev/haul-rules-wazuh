<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1302 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: 7fc3933e-23a4-59aa-8900-b43127510d01 -->
  <rule id="344393" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1302 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>