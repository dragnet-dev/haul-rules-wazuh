<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4652 — Event Log Clearing (sinobi) | Status: test | Sigma ID: d13d6d02-f6a7-513b-9dcf-1f63a6cba275 -->
  <rule id="763469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4652 — Event Log Clearing (sinobi)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>