<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4247 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: a6d35b5a-b0da-5b4b-b4f2-24a6243c66d7 -->
  <rule id="134971" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4247 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>