<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4538 — Recovery Inhibition (radiant) | Status: experimental | Sigma ID: f301629f-44bf-5bfa-bd38-863f7dd62184 -->
  <rule id="730162" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4538 — Recovery Inhibition (radiant)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>