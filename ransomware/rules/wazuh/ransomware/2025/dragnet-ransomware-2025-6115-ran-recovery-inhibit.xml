<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6115 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 01efc136-573e-53da-9b3e-673ef07d87c1 -->
  <rule id="832136" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6115 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>