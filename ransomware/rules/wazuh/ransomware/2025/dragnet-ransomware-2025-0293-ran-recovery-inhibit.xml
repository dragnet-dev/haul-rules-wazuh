<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0293 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b42b2edf-57c6-5425-bbd4-25e72a02525e -->
  <rule id="325326" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0293 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>