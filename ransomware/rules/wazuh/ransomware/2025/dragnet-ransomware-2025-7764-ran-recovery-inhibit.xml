<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7764 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 89e726d1-d946-565f-8b19-5557ee9bbe4d -->
  <rule id="638726" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7764 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>