<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1378 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8e60da55-7324-5277-8bb9-175a5973d028 -->
  <rule id="150778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1378 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>