<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3548 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: dd91c5a1-57d2-57f6-8864-c08350b34ed0 -->
  <rule id="950685" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3548 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>