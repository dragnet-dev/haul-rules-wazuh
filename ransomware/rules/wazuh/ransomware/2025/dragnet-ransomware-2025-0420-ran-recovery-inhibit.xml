<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0420 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 685c5c9a-f063-5e53-9454-5efb7a0de9df -->
  <rule id="955612" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0420 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>