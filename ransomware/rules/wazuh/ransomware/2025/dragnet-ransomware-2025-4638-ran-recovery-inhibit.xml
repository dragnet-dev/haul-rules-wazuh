<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4638 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 3507eaa7-57ec-57bf-a034-ec1af80f2a10 -->
  <rule id="968426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4638 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>