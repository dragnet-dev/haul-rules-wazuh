<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6211 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 78013547-b50d-52ac-bc68-e0488132a5b6 -->
  <rule id="701354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6211 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>