<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2383 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: d5f31d57-f2a4-5f3e-8d02-aab8a1de3e6b -->
  <rule id="880509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2383 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>