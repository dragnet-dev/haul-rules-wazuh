<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5102 — Recovery Inhibition (trinity) | Status: experimental | Sigma ID: ed8e7ae5-3e9e-55af-8087-189217751d9f -->
  <rule id="790042" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5102 — Recovery Inhibition (trinity)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>