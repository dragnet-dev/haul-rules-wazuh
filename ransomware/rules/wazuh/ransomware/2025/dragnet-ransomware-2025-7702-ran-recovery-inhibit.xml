<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7702 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4a48aa36-a53a-5c51-a384-ea9239cd8625 -->
  <rule id="206858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7702 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>