<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2683 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e5731038-95de-5c7f-8d04-e6cdabccff41 -->
  <rule id="657310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2683 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>