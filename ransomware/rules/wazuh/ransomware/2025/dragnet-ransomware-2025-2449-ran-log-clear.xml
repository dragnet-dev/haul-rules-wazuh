<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2449 — Event Log Clearing (thegentlemen) | Status: test | Sigma ID: 9b40c398-5fe6-52aa-8947-1a2bedcce68c -->
  <rule id="786523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2449 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>