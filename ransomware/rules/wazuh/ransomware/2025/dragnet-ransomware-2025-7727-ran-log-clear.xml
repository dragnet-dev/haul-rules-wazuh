<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7727 — Event Log Clearing (clop) | Status: deprecated | Sigma ID: 86ea2fd1-8d88-5cbc-aff9-d2d2520389c1 -->
  <rule id="960047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7727 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>