<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3163 — Event Log Clearing (satanlockv2) | Status: experimental | Sigma ID: 48d91c3e-087a-5dac-adfa-34aac7d324d7 -->
  <rule id="451068" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3163 — Event Log Clearing (satanlockv2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>