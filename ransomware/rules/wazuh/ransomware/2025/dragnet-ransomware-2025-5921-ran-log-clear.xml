<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5921 — Event Log Clearing (benzona) | Status: deprecated | Sigma ID: 422d2b23-3107-50b9-98b4-ab3113355a9b -->
  <rule id="282443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5921 — Event Log Clearing (benzona)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>