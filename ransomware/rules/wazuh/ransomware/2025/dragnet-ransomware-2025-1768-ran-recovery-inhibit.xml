<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1768 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: d893a700-c646-57cc-9f40-079e5fefedfc -->
  <rule id="522987" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1768 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>