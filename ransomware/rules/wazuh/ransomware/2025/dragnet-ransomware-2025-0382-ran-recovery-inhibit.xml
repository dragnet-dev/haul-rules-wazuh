<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0382 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 98685a3f-458b-5f16-af66-20aadfd05f1c -->
  <rule id="778970" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0382 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>