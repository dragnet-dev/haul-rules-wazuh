<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6426 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 7c8a02b5-6b89-5638-bc97-181ee06a11da -->
  <rule id="297802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6426 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>