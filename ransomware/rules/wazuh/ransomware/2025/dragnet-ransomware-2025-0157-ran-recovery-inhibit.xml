<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0157 — Recovery Inhibition (insomnia) | Status: experimental | Sigma ID: 178fd7b6-1d67-5f5b-9310-756b33691479 -->
  <rule id="231483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0157 — Recovery Inhibition (insomnia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>