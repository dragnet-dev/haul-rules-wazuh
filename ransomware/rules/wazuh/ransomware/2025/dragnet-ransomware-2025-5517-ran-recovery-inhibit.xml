<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5517 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c2cf76dd-9bb3-5105-9289-967d14b414b4 -->
  <rule id="543976" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5517 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>