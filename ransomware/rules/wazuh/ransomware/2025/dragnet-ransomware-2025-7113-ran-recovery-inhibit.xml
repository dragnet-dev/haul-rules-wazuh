<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7113 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0ecf735b-df13-5992-a6f3-a03e91078135 -->
  <rule id="291735" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7113 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>