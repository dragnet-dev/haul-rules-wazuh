<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0893 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: a73f32ca-6494-5007-ab81-ebf7a13266cf -->
  <rule id="918332" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0893 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>