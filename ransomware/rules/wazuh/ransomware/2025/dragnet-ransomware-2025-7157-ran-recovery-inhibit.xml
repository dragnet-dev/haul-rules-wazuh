<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7157 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 764c3549-eb82-58ad-ba5a-8ac56ed67513 -->
  <rule id="423635" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7157 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>