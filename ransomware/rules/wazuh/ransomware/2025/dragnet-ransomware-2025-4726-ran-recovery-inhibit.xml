<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4726 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ec826c5e-d409-5407-9751-8cd0b2d4cf6a -->
  <rule id="289228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4726 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>