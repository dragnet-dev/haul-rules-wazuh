<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6976 — Recovery Inhibition (securotrop) | Status: experimental | Sigma ID: 452d3c13-f0ed-5843-9085-4ee3806ff2e4 -->
  <rule id="359260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6976 — Recovery Inhibition (securotrop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>