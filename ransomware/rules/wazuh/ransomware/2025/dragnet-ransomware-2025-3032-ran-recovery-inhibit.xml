<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3032 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b8e20e63-c2c7-5d4b-a6bb-3bcfbb95ed25 -->
  <rule id="443534" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3032 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>