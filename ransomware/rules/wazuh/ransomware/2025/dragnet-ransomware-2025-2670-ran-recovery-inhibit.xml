<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2670 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 5374f2a8-0d4a-5311-815f-400c3ecf986e -->
  <rule id="359882" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2670 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>