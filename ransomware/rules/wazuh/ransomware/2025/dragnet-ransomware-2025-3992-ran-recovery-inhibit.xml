<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3992 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b105ec96-0efd-5af3-ba97-7c19f2ab5714 -->
  <rule id="243116" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3992 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>