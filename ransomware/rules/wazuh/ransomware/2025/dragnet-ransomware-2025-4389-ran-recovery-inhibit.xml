<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4389 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 7c647176-5f31-5d95-99f3-4aa76ebae97d -->
  <rule id="446471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4389 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>