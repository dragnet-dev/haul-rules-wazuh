<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5592 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ed4e8f4d-f666-598f-a3e5-e0b64d42ce47 -->
  <rule id="779823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5592 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>