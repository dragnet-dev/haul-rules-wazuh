<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6714 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: ce2d83e9-4b27-5136-90cb-4df6cbc63b06 -->
  <rule id="700583" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6714 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>