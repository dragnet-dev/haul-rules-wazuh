<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5781 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: d5b1ae50-7a6e-5517-84dd-c73f50645142 -->
  <rule id="258190" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5781 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>