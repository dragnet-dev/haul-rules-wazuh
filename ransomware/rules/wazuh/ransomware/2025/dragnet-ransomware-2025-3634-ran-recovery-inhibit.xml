<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3634 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 5e3ad4b9-deee-533a-b83f-d1f6c989e386 -->
  <rule id="715814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3634 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>