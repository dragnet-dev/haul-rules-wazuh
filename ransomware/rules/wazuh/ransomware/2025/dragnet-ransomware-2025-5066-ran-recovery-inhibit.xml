<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5066 — Recovery Inhibition (killsec) | Status: deprecated | Sigma ID: fec5a2eb-b74e-51a7-92de-b7027354ea69 -->
  <rule id="322502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5066 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>