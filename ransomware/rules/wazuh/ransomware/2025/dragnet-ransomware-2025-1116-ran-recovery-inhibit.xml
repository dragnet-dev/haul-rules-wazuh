<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1116 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: ae3fa17c-03d4-5df0-81ec-9c839668295e -->
  <rule id="964581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1116 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>