<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5633 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 0ab51ade-a0c7-57fd-a7a5-e97c7356eaa0 -->
  <rule id="890829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5633 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>