<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3418 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: de959277-774f-546e-9f97-955772bce853 -->
  <rule id="529592" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3418 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>