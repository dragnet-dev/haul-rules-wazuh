<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3660 — Event Log Clearing (cloak) | Status: deprecated | Sigma ID: 8df53dd9-73bc-53b5-b2f4-4b4b11f88613 -->
  <rule id="134461" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3660 — Event Log Clearing (cloak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>