<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5045 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: cebf6bc7-24a9-5647-8cd3-7f440ed1c4d1 -->
  <rule id="468427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5045 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>