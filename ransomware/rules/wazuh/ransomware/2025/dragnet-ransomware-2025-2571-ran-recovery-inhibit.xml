<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2571 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: b93413ad-4aef-54a9-a422-a531d2e6c48a -->
  <rule id="393413" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2571 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>