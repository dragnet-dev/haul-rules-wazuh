<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1018 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a580c959-b2c6-544d-9773-b7aa63247e67 -->
  <rule id="892929" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1018 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>