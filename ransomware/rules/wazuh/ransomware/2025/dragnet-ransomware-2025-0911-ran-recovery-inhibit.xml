<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0911 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: b2e7e902-7001-570c-9966-136b84d18e08 -->
  <rule id="290869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0911 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>