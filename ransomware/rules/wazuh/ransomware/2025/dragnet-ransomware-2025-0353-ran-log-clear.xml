<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0353 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: a32b5061-c7b0-5d5f-87be-f120fcb8e7da -->
  <rule id="852350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0353 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>