<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1098 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 974f23ab-ec8d-5392-b604-32b5f4c4b286 -->
  <rule id="759923" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1098 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>