<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3619 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 3c93f429-d1d3-5fe6-8d63-ec6248b8593e -->
  <rule id="850342" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3619 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>