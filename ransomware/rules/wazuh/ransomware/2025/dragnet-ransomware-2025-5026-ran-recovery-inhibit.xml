<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5026 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3bc0eb46-fc06-5afb-85fd-70f822b79d28 -->
  <rule id="747595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5026 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>