<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3115 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 7fa70647-1523-5886-8314-2adc7829d0a9 -->
  <rule id="342706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3115 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>