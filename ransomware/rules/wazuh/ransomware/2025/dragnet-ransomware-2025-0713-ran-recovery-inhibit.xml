<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0713 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 39882e29-0d80-564c-b808-15c45b59406e -->
  <rule id="181262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0713 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>