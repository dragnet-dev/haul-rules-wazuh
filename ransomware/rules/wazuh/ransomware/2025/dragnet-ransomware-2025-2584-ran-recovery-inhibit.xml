<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2584 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 4aa2baf7-a9ef-5b27-bb1d-7c1c5d99f079 -->
  <rule id="457338" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2584 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>