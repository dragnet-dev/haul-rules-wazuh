<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3551 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 48088e4b-cf11-54e2-8426-a651a1c5ae06 -->
  <rule id="594224" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3551 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>