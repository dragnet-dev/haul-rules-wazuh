<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4822 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c02efbb6-a117-5267-8a31-cea113758935 -->
  <rule id="527227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4822 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>