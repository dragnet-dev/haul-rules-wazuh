<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2073 — Event Log Clearing (safepay) | Status: experimental | Sigma ID: fb7c01d5-dbe0-5db0-8a4f-b2315a48bd9c -->
  <rule id="528401" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2073 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>