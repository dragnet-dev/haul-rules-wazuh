<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3000 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 2b4ba6b2-98ca-5654-bb60-6c28421ac8ce -->
  <rule id="312906" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3000 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>