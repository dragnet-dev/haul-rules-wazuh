<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0428 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 62dd35ac-d450-5ca8-84c7-3e7ee1e9c661 -->
  <rule id="809335" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0428 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>