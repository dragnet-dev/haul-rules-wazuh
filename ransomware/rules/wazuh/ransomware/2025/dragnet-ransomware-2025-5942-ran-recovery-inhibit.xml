<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5942 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: dee5b882-3523-5452-9810-be35647f531f -->
  <rule id="406518" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5942 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>