<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3800 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: fa58b5ef-75a7-5bf2-8ed3-3786b5e4ffb1 -->
  <rule id="509395" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3800 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>