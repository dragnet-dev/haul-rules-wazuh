<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7155 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: d83079a1-9e77-5e75-be21-118ddf8e7501 -->
  <rule id="583079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7155 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>