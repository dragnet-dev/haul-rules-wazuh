<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7092 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 8fa97e4f-9ffc-515f-88b1-fc577399d590 -->
  <rule id="178366" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7092 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>