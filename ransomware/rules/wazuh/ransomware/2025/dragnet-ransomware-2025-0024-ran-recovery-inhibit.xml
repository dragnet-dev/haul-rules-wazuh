<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0024 — Recovery Inhibition (gunra) | Status: experimental | Sigma ID: d4934c3b-3ba1-538b-bc96-f164fd78432c -->
  <rule id="458956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0024 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>