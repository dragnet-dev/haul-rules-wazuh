<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2778 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 193ef50f-98ed-54c3-8685-faa7e149e8ac -->
  <rule id="564750" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2778 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>