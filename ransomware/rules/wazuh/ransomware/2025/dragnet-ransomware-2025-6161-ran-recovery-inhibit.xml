<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6161 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 8d4ccacd-1465-5fd8-8c95-fde9389fae0f -->
  <rule id="495018" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6161 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>