<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3272 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: a1ea0225-294f-52d3-922b-cad680241474 -->
  <rule id="909002" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3272 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>