  <rule id="117005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6327 — Recovery Inhibition (genesis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
