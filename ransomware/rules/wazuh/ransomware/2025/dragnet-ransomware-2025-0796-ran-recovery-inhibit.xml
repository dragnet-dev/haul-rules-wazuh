<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0796 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a540fddc-b38c-5aca-b8b9-63f8ab13796c -->
  <rule id="998493" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0796 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>