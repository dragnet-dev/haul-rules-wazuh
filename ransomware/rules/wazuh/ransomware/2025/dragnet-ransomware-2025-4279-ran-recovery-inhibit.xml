<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4279 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 64a03885-286f-5a65-9291-96e1109b833f -->
  <rule id="234038" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4279 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>