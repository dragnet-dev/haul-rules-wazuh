<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7566 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: fac8edb3-ecf0-546f-86b3-e637b8860708 -->
  <rule id="473005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7566 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>