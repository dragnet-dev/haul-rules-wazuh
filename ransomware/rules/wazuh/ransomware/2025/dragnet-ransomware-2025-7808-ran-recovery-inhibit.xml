<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7808 — Recovery Inhibition (insomnia) | Status: test | Sigma ID: 952e3990-5672-5eba-8de5-5e931d9916ee -->
  <rule id="724639" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7808 — Recovery Inhibition (insomnia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>