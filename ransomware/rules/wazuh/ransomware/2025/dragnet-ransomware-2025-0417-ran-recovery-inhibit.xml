<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0417 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: 2373f4e2-f203-5e60-b1c7-1ddbc53f2458 -->
  <rule id="777358" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0417 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>