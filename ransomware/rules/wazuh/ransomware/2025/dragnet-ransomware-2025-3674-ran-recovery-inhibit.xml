<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3674 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: e03dd5b5-33c3-5727-81f4-56e8b30e4e91 -->
  <rule id="993895" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3674 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>