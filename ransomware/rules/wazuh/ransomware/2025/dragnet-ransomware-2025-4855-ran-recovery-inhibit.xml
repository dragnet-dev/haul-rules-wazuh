<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4855 — Recovery Inhibition (IMNCrew) | Status: experimental | Sigma ID: b1666cc0-2739-5155-8b38-747ab27a9b4a -->
  <rule id="986668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4855 — Recovery Inhibition (IMNCrew)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>