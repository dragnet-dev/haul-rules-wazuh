<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5563 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: d1249448-19a1-56b4-8e70-3df37cf83d5e -->
  <rule id="512494" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5563 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>