<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4419 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1a2bf06f-5da3-506e-bc79-6a0cdf4b2ed2 -->
  <rule id="526306" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4419 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>