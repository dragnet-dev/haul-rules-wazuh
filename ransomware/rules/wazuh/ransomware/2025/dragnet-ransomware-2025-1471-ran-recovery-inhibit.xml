<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1471 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 8b03d0a0-d533-531f-bca8-85ad24e63e17 -->
  <rule id="524610" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1471 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>