<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7719 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: b30a1cb9-c9d6-5009-9660-32c6cf1277ea -->
  <rule id="294428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7719 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>