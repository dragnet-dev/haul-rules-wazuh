<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3201 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: a469d21c-7b74-57e8-b02f-64741e82665d -->
  <rule id="875172" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3201 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>