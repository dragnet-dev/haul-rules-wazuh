<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2856 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: da05d854-01a2-5675-afb1-1a781aefa2c9 -->
  <rule id="888938" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2856 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>