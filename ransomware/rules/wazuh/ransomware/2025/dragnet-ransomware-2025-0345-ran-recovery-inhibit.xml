<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0345 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 7612cf1c-6f43-50af-8029-9cbcc5732795 -->
  <rule id="248879" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0345 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>