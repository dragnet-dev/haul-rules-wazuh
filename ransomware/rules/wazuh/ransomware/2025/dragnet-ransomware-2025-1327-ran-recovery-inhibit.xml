<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1327 — Recovery Inhibition (coinbasecartel) | Status: experimental | Sigma ID: 310572f6-fc80-55ad-8267-b398cf72d064 -->
  <rule id="569167" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1327 — Recovery Inhibition (coinbasecartel)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
