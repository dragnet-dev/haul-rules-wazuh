<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1778 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f1f6ddbd-b624-54bf-8a20-a7c68df57b80 -->
  <rule id="925117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1778 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>