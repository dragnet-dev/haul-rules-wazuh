<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4274 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: d2cef48c-e8af-512a-ac44-1b337a93e00d -->
  <rule id="139834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4274 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>