<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2076 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 9a0ff940-6627-528b-8923-344309e317b2 -->
  <rule id="444959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2076 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>