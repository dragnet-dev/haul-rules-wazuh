<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3128 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2fca7154-4641-523a-b8a3-3dbe6218e9a2 -->
  <rule id="423471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3128 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>