<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2417 — Shadow Copy Deletion (thegentlemen) | Status: experimental | Sigma ID: 230a7c5d-c302-56a0-9d4d-0349abfd6ea0 -->
  <rule id="605245" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2417 — Shadow Copy Deletion (thegentlemen)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>