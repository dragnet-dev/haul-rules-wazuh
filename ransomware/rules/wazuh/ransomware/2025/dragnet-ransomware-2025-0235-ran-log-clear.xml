<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0235 — Event Log Clearing (warlock) | Status: deprecated | Sigma ID: 4a4a2925-0bcb-58c5-a48a-73e8b46b3af8 -->
  <rule id="391429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0235 — Event Log Clearing (warlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>