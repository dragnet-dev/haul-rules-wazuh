<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1253 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 67eddc74-9c64-505e-b698-9307a5b0e11c -->
  <rule id="951804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1253 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>