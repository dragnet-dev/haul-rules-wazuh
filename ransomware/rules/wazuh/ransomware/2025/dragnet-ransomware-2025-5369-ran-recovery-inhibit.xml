<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5369 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 529aeb8c-4255-5511-a379-f57523387401 -->
  <rule id="469579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5369 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>