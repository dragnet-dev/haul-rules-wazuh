<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2108 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: eb50b649-6cbb-5177-b3b2-dd2772232776 -->
  <rule id="268116" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2108 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>