<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5257 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 454c5027-3c09-5793-93e9-9989c6327f5b -->
  <rule id="176502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5257 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>