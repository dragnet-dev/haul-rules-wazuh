<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0738 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e8d888fe-fb47-52f8-a331-2ed06fa2cd4a -->
  <rule id="681888" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0738 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>