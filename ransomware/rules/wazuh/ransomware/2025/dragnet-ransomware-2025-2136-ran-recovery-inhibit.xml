<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2136 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: cb1f5212-c21a-5726-ba49-8d5d79243fa0 -->
  <rule id="651152" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2136 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>