<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3274 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 9d7c6476-05b1-50a5-860e-c007e1a69a50 -->
  <rule id="824464" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3274 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>