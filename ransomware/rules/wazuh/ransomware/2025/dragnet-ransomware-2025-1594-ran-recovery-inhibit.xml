<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1594 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: fe68e736-f161-5f0f-8764-d81a86533765 -->
  <rule id="575027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1594 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>