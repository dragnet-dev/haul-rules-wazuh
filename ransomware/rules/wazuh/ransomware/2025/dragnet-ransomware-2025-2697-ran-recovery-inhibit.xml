<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2697 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: f8ca1583-aca3-5702-9204-ae0d82f8e03c -->
  <rule id="565015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2697 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>