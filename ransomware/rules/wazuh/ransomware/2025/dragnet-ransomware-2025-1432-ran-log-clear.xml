<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1432 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: 5bc9f58f-aa5e-5b1c-8633-9f3d4bb84881 -->
  <rule id="650395" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1432 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>