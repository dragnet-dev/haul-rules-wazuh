<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1176 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 27ef8db1-0f50-53b4-b7fa-6b7994b6aac3 -->
  <rule id="344301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1176 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>