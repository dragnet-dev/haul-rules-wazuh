<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1335 — Event Log Clearing (obscura) | Status: experimental | Sigma ID: 9d322916-3bd6-5238-9dcb-c37c00648092 -->
  <rule id="773229" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1335 — Event Log Clearing (obscura)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>