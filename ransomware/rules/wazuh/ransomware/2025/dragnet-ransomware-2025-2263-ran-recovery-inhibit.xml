<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2263 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 16d54458-4d7b-50b6-a5f8-0609f4e45a9e -->
  <rule id="995445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2263 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>