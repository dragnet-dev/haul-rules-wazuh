<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6495 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 8b14b937-2bf4-58b3-b6a2-8cefc1f465a3 -->
  <rule id="526359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6495 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>