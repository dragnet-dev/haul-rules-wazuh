<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4169 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 16039610-ab97-5f4a-afcd-9ffa446dc325 -->
  <rule id="803961" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4169 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>