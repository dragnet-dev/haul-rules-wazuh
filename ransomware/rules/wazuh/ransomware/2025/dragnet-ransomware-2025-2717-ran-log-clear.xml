<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2717 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 212e5ec4-b8a5-5d3d-adcb-17f305411bcf -->
  <rule id="720876" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2717 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>