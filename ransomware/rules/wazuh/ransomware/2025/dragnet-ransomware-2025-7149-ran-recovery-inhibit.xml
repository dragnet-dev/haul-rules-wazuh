<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7149 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 758b7042-d881-5501-91b9-602f298071f7 -->
  <rule id="413970" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7149 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>