<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1257 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: c78771d4-dd47-592d-996b-c063e3e657a3 -->
  <rule id="478771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1257 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>