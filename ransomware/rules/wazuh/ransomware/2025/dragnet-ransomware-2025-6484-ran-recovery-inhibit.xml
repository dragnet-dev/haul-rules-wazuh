<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6484 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 46d6f09f-0ef3-5560-b864-24420aa69481 -->
  <rule id="399510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6484 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>