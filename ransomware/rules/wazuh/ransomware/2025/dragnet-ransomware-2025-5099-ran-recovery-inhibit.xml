<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5099 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 16147ae7-0e75-5e1b-9de7-adef35e3391a -->
  <rule id="633806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5099 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>