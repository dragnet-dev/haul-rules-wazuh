<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4198 — Recovery Inhibition (nova) | Status: test | Sigma ID: b5b01211-10eb-51ca-9bb1-a5b1f969f8b4 -->
  <rule id="151012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4198 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>