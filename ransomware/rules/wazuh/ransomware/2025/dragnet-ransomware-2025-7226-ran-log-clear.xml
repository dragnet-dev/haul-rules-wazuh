<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7226 — Event Log Clearing (crypto24) | Status: deprecated | Sigma ID: c7ef8366-9b96-5b56-b821-f92c17055502 -->
  <rule id="675183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7226 — Event Log Clearing (crypto24)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>