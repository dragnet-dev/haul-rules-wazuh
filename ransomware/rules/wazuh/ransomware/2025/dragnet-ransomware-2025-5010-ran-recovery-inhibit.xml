<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5010 — Recovery Inhibition (clop) | Status: deprecated | Sigma ID: 2dc0182d-22ff-525d-98f8-fe46eb8fae45 -->
  <rule id="220182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5010 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>