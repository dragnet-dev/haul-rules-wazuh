<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2358 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 28f1c326-6589-529d-96d3-6d112972215c -->
  <rule id="310832" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2358 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>