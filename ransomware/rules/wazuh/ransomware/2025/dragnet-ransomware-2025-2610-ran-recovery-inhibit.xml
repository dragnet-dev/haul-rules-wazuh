<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2610 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b0586880-7ab6-5326-a838-1325e68dcd40 -->
  <rule id="305868" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2610 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>