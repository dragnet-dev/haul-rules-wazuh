<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5298 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e377561e-73ce-5428-b731-bf07772a2565 -->
  <rule id="637756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5298 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>