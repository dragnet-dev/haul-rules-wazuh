<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5617 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: dfb1f8b5-d5b8-5751-884c-55b246795390 -->
  <rule id="426718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5617 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>