<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3217 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ef9aa3ef-1bb1-521e-b152-f3a6ced3e09e -->
  <rule id="843143" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3217 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>