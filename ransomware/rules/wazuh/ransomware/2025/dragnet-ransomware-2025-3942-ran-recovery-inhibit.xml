<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3942 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: aabd9698-8984-54ec-a084-7d712da70548 -->
  <rule id="870996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3942 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>