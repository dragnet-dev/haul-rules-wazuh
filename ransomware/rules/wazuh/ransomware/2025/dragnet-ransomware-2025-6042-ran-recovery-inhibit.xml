<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6042 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: b3bd9b5f-0890-5971-bfb6-9327f09f9e17 -->
  <rule id="258875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6042 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>