<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2032 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 31fa7756-680f-5c98-8433-3dde8e078eb0 -->
  <rule id="186775" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2032 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>