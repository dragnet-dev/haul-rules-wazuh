<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7395 — Event Log Clearing (embargo) | Status: experimental | Sigma ID: cb1b6dbe-b71b-5aa2-9279-9970a3cf2d22 -->
  <rule id="801229" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7395 — Event Log Clearing (embargo)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>