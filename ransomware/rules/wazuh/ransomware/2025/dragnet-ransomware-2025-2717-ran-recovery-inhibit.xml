<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2717 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7bcb13a8-1f13-57e5-9012-4ce994d5649f -->
  <rule id="569113" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2717 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>