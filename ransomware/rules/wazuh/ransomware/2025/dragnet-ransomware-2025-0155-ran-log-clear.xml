<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0155 — Event Log Clearing (metaencryptor) | Status: experimental | Sigma ID: e863573b-20d5-516f-a7ef-2d9dd498d126 -->
  <rule id="686357" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0155 — Event Log Clearing (metaencryptor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>