<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0206 — Recovery Inhibition (global) | Status: experimental | Sigma ID: 8f00ab46-e7e3-54a2-b808-d57743f11a68 -->
  <rule id="160971" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0206 — Recovery Inhibition (global)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>