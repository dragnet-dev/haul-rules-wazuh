<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5636 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 5b2a1133-57cc-5a81-8163-0454be48d98e -->
  <rule id="660211" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5636 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>