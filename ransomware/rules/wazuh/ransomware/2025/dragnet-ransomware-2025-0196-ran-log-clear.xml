<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0196 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 2652a7c6-a5f9-507f-9800-1d42dd6c82b8 -->
  <rule id="590844" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0196 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>