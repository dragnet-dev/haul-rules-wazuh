<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0432 — Event Log Clearing (clop) | Status: experimental | Sigma ID: b7f604b2-3bc3-57c4-9d4d-0b5fa2ac9aed -->
  <rule id="187604" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0432 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>