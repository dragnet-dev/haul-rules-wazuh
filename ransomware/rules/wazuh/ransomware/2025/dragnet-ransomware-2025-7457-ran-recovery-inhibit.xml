<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7457 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 3b2f3b93-5766-5acc-8c0b-f519a67596f0 -->
  <rule id="717979" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7457 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>