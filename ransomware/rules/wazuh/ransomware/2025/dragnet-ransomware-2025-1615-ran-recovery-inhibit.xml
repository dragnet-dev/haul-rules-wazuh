<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1615 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 3b44a712-d362-521e-838c-b5a93605b1ff -->
  <rule id="611471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1615 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>