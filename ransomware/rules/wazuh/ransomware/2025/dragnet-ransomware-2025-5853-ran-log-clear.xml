<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5853 — Event Log Clearing (gunra) | Status: experimental | Sigma ID: 847fa8f5-e3bd-5b96-a1a1-58c34bf5ebc4 -->
  <rule id="470828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5853 — Event Log Clearing (gunra)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>