<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2740 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b2c49193-4c8d-5e7b-9561-518c57c24a17 -->
  <rule id="104491" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2740 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>