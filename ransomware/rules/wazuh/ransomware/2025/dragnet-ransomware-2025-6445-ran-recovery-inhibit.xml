<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6445 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 816f57c8-d897-57f8-9adf-8e3448e73d4d -->
  <rule id="507157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6445 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>