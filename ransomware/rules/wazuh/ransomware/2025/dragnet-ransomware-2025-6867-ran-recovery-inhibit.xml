<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6867 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 4c21a9b3-eb7f-58cd-bdde-ca3e209d7e8c -->
  <rule id="419469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6867 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>