<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3314 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: a587e022-0584-5588-901d-8b0f47b52d1f -->
  <rule id="894060" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3314 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>