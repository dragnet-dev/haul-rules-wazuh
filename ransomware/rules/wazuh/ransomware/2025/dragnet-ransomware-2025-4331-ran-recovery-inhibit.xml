<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4331 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 0cb54edf-820f-5dff-998e-b933107f1115 -->
  <rule id="810861" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4331 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>