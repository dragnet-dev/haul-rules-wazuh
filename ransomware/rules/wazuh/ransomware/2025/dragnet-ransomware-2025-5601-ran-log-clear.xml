<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5601 — Event Log Clearing (cephalus) | Status: deprecated | Sigma ID: e624f5dd-b180-50a3-90ea-5ebc47ab0ad0 -->
  <rule id="639995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5601 — Event Log Clearing (cephalus)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>