<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6747 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 12689e1a-867f-5603-8607-1e025b416e22 -->
  <rule id="330381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6747 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>