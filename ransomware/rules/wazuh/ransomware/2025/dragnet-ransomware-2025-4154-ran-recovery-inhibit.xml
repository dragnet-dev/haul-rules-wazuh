<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4154 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 281611a6-dff8-5066-830e-a7d9fa492c07 -->
  <rule id="105786" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4154 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>