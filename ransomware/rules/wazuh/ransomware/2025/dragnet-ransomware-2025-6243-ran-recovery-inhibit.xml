<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6243 — Recovery Inhibition (play) | Status: experimental | Sigma ID: fecfd293-303c-56c7-80a3-fd5b67a299aa -->
  <rule id="243709" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6243 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>