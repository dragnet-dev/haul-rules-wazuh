<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6851 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: ef0ad595-4342-59b4-867f-98351f6334de -->
  <rule id="820135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6851 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>