<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7374 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: adbfefff-6d99-593e-bf92-c0ffd0e12e70 -->
  <rule id="686863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7374 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>