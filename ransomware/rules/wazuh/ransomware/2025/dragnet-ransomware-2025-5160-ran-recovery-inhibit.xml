<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5160 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: f40e1e69-4ef9-572b-8be0-1f6a5f5f300a -->
  <rule id="444670" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5160 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>