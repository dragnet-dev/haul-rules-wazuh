<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1083 — Event Log Clearing (spacebears) | Status: experimental | Sigma ID: 7c1f49a5-7c91-54df-a9b7-b76e3fe88dee -->
  <rule id="287149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1083 — Event Log Clearing (spacebears)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>