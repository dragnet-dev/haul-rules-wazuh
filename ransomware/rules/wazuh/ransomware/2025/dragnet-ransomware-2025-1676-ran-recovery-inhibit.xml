<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1676 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8133fb5a-088a-571e-a33c-8ef1d53b3c08 -->
  <rule id="382299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1676 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>