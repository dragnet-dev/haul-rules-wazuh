<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6684 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 37b38da4-40dc-550b-be32-d6e81cecb6d1 -->
  <rule id="246746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6684 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>