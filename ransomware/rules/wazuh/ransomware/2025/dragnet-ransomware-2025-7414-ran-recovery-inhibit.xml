<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7414 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 9eade15f-132e-5f78-986c-e23da849e751 -->
  <rule id="299501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7414 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>