<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3963 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: eed72194-1572-5f04-b823-2ba58477ed8f -->
  <rule id="321721" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3963 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>