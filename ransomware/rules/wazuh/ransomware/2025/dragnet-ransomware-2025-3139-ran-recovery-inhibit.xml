<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3139 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4f343346-f5a6-5b15-95fe-099aed99b444 -->
  <rule id="834334" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3139 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>