<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1150 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 511179c2-378d-5962-8b8e-a5568fe94b57 -->
  <rule id="178876" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1150 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>