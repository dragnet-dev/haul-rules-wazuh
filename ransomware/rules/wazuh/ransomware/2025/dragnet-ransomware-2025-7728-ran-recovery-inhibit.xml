<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7728 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: d61d79e7-c5b3-5c52-b4c8-33e857a546a2 -->
  <rule id="478979" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7728 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>