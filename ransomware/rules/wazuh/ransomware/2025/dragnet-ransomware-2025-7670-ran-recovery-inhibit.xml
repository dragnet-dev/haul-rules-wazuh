<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7670 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 2ef4fdd3-8537-596c-897c-e56a20b735cf -->
  <rule id="223837" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7670 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>