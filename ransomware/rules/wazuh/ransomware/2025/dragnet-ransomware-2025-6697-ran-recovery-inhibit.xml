<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6697 — Recovery Inhibition (tridentlocker) | Status: experimental | Sigma ID: 0007e85f-23d3-53f9-b17e-9cd5a5cec5e5 -->
  <rule id="329752" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6697 — Recovery Inhibition (tridentlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>