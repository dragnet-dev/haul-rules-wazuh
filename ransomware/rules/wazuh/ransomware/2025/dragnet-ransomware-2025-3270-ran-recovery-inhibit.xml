<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3270 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 61e4dd21-3999-57b8-a43d-3ef4c18ca912 -->
  <rule id="835645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3270 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>