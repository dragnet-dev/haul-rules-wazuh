<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7557 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: b1d7d772-02f9-5851-9ed9-9a89b957d86d -->
  <rule id="263657" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7557 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>