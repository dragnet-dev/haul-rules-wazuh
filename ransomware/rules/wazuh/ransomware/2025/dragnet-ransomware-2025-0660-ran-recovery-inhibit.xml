<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0660 — Recovery Inhibition (handala) | Status: test | Sigma ID: 83c4001e-59a5-5f4d-ad2a-8de586b90685 -->
  <rule id="540400" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0660 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>