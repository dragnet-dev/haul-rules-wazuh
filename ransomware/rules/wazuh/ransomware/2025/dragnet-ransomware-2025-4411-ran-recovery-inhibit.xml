<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4411 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 0001c0e1-f264-5fe0-98b6-87f714230b66 -->
  <rule id="990712" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4411 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>