<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5061 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 9d006a87-76e9-51a4-a14b-bf1ac8550ce0 -->
  <rule id="812106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5061 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>