<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5225 — Recovery Inhibition (reynolds) | Status: experimental | Sigma ID: 64c63137-66b4-5b05-92dc-faaed2b4a943 -->
  <rule id="236631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5225 — Recovery Inhibition (reynolds)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>