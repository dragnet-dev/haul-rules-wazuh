<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0142 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 83b08044-bd54-57ce-a175-9dc1bbda09e7 -->
  <rule id="539080" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0142 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>