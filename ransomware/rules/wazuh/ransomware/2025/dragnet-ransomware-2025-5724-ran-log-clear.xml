<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5724 — Event Log Clearing (babuk2) | Status: experimental | Sigma ID: dccc9275-f8ca-5bad-bb53-e9b0c88f0c1a -->
  <rule id="352492" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5724 — Event Log Clearing (babuk2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>