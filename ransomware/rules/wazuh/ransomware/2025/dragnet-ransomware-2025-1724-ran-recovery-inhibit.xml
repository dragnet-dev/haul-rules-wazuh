<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1724 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: 53f127bc-baba-555c-9e64-dbd2f7437ccc -->
  <rule id="410043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1724 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>