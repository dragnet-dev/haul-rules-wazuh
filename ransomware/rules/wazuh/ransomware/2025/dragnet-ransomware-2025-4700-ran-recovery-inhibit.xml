<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4700 — Recovery Inhibition (play) | Status: experimental | Sigma ID: bfd9b131-8854-5cd7-94da-51b2ab03798e -->
  <rule id="511951" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4700 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
