<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3999 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 9b3a4a9a-4e3e-547e-999f-f7f885b969b1 -->
  <rule id="477354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3999 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>