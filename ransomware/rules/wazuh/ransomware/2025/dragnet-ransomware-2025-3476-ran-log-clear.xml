<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3476 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 3a3a58ea-1302-5b68-98f6-6a7fcf4fdad7 -->
  <rule id="641742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3476 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>