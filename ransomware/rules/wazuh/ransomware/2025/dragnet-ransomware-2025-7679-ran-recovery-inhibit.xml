<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7679 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: d5acafc8-4a2d-59ef-b6a4-a88b8555bdd3 -->
  <rule id="891567" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7679 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>