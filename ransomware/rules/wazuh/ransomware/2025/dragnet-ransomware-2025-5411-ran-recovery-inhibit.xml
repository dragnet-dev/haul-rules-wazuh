<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5411 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: f149ae24-7c9c-5933-8118-4bcd666d7d05 -->
  <rule id="378318" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5411 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>