<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1961 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 549e182e-2c04-50b5-9453-f86b0f28b827 -->
  <rule id="798182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1961 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>