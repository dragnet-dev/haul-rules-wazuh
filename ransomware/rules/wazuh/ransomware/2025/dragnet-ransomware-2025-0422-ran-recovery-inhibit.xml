<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0422 — Recovery Inhibition (qilin) | Status: test | Sigma ID: afa1ce3d-3fd8-51f1-82c2-802f44b83f9d -->
  <rule id="994062" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0422 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>