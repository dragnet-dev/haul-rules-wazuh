<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1167 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: dc57e20c-262f-5252-83d0-5bf129b023a8 -->
  <rule id="929262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1167 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>