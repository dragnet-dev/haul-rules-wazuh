<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7719 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: f9e6d09f-dd35-5e05-87d6-491eb263f799 -->
  <rule id="593890" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7719 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>