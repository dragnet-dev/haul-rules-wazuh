<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5262 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 8d335673-e2fa-51d1-a89a-92006df3fac5 -->
  <rule id="613356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5262 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>