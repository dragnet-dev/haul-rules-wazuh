<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6606 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 4d965610-4ec1-59d8-9973-75f94a06d35e -->
  <rule id="696561" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6606 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>