<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5858 — Event Log Clearing (tengu) | Status: test | Sigma ID: 87216bd8-876d-5403-b8d7-f119d2df1c73 -->
  <rule id="595467" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5858 — Event Log Clearing (tengu)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>