<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6149 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: 034b6f0e-d54d-5d16-a49f-76ba0cc1b7ff -->
  <rule id="825774" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6149 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
