<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6282 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 71b54bb3-d46c-55b8-8137-794e59ea0a7a -->
  <rule id="136075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6282 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>