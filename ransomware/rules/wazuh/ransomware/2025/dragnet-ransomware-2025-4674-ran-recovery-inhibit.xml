<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4674 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: bc1c2ad7-bf64-5348-9f5a-e0a2beb73563 -->
  <rule id="417322" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4674 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>