<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7187 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 2b8631c2-8b61-5609-b0e5-6c33b2c12b48 -->
  <rule id="818108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7187 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>