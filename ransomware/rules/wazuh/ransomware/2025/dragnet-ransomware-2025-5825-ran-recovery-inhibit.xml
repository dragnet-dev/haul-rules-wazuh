<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5825 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 49525bf4-e549-515b-9147-48b86a2f0cfb -->
  <rule id="178591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5825 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>