<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5404 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 469043d2-7e91-5de1-9eff-baf81602f08c -->
  <rule id="404701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5404 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>