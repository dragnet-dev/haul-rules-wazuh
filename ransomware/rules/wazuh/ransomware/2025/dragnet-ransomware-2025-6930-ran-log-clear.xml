<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6930 — Event Log Clearing (kraken) | Status: experimental | Sigma ID: c0500152-854a-59c1-ab1f-36984cbf07ac -->
  <rule id="405001" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6930 — Event Log Clearing (kraken)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>