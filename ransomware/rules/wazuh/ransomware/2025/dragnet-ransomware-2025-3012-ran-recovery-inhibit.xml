<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3012 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 34faa8cd-b309-5b98-b7f5-0dc36f79ec40 -->
  <rule id="632748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3012 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>