<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4777 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ca1871c6-bd96-5597-bddc-e296e461f33c -->
  <rule id="321871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4777 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>