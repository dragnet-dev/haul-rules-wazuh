<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5912 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 157bb204-2cdb-537f-bb7e-85966a3e869c -->
  <rule id="537920" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5912 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>