<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4321 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 56962e91-490a-5b7f-95ae-e73357da704f -->
  <rule id="214069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4321 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>