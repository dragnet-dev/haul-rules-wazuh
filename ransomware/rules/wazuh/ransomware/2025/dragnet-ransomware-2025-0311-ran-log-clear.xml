<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0311 — Event Log Clearing (dragonforce) | Status: experimental | Sigma ID: 02e13fa6-0c3f-555c-a8a4-d04fb0770a59 -->
  <rule id="381178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0311 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>