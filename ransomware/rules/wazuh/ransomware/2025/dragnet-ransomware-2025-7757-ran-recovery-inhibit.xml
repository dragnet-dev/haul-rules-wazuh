<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7757 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 41d76916-3d81-5b80-9090-54625e532d02 -->
  <rule id="497691" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7757 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>