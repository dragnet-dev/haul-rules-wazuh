<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3224 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 05505cc7-5035-58cf-b0fc-a9904a261045 -->
  <rule id="609484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3224 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>