<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1854 — Event Log Clearing (safepay) | Status: experimental | Sigma ID: 800efdf7-d16c-5dc2-a6a3-3dbdaf0d2269 -->
  <rule id="680637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1854 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>