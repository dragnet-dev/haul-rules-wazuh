<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1479 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: ecaa9b51-0270-5462-888e-ddc636bd6f69 -->
  <rule id="793915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1479 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>