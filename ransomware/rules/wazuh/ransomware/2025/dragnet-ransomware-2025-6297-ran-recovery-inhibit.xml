<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6297 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3ec0e8d6-b85a-5676-8f90-b2a16b7d60b0 -->
  <rule id="806548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6297 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>