<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7601 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 030f1816-d67d-53bc-95c4-ad43f2cc9cfd -->
  <rule id="551816" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7601 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>