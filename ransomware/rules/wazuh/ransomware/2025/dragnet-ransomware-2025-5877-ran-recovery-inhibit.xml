<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5877 — Recovery Inhibition (silent) | Status: experimental | Sigma ID: f51646dc-7037-53d4-a4d7-bf5f270b2e8d -->
  <rule id="751646" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5877 — Recovery Inhibition (silent)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>