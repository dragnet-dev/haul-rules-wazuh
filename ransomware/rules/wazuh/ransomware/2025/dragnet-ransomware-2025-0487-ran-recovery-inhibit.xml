<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0487 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a9f1a112-0029-5e53-9358-ec01fb8f0c46 -->
  <rule id="214661" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0487 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>