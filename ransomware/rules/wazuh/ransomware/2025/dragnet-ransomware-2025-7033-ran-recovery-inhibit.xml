<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7033 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 549c05e4-a82a-57d1-9e3d-4f3709ed06ba -->
  <rule id="673694" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7033 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>