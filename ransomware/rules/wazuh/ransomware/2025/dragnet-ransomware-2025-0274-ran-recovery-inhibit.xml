<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0274 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 0a037107-e059-552c-8cb3-5221bfe827ef -->
  <rule id="203710" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0274 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>