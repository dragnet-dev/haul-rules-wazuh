<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5848 — Recovery Inhibition (gunra) | Status: experimental | Sigma ID: ce66cd63-f873-5c57-9850-92dd889ded3d -->
  <rule id="890701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5848 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>