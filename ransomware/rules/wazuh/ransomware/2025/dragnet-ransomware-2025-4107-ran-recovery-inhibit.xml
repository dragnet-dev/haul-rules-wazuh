<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4107 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e669519f-d3cf-59c6-868c-745008b57dda -->
  <rule id="666951" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4107 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>