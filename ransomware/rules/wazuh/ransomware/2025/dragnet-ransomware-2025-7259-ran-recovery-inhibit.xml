<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7259 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 5aab9d75-5baf-590d-b6df-ef9d7ff379a5 -->
  <rule id="213917" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7259 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>