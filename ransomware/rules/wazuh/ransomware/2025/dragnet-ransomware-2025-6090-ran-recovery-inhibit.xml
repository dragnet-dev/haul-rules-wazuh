<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6090 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 71dec3ce-e154-5e59-b9f2-f33b0197ce69 -->
  <rule id="343803" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6090 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>