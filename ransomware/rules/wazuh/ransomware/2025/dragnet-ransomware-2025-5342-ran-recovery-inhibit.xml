<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5342 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: bcdf2560-db2b-54db-bfc7-4580e925af68 -->
  <rule id="435125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5342 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>