<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7616 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9bfbc129-8f6f-5f78-a2f1-85150c6d6fff -->
  <rule id="189081" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7616 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>