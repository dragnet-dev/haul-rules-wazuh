<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3519 — Event Log Clearing (hellcat) | Status: deprecated | Sigma ID: f73d8148-1099-5f37-b67c-5d19a7653699 -->
  <rule id="818181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3519 — Event Log Clearing (hellcat)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>