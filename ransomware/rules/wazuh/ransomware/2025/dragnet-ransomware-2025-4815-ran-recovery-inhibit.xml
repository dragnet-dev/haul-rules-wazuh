<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4815 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: fb081edd-609e-5b6b-a8c3-04454eb54a29 -->
  <rule id="517310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4815 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>