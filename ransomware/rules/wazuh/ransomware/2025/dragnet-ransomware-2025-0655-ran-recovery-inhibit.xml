<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0655 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: de64e1eb-f9b8-5ba5-8521-3a08d3111c33 -->
  <rule id="962381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0655 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>