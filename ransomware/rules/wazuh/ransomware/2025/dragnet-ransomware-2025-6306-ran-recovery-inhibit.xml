<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6306 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e501d1d1-40f2-515b-95d9-f4c502d545a8 -->
  <rule id="620291" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6306 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>