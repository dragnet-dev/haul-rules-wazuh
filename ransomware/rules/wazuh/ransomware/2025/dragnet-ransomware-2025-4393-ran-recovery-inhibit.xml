<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4393 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: c918c81b-c6fb-559f-b268-6ccd9fda9ef6 -->
  <rule id="367008" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4393 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>