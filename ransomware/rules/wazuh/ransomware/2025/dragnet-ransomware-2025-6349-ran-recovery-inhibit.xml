<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6349 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 24c8940a-46f4-5adb-9a77-c346d6f63526 -->
  <rule id="468940" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6349 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>