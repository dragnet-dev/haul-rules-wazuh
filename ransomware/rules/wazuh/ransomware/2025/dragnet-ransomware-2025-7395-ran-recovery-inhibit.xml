<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7395 — Recovery Inhibition (embargo) | Status: experimental | Sigma ID: 87785631-aa83-58a4-885b-c469180fcbc0 -->
  <rule id="778563" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7395 — Recovery Inhibition (embargo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
