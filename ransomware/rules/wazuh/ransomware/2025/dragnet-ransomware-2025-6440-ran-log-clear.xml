<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6440 — Event Log Clearing (devman) | Status: deprecated | Sigma ID: a5fb63d0-7966-51b9-95bb-2eb58b5f9f9d -->
  <rule id="113163" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6440 — Event Log Clearing (devman)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>