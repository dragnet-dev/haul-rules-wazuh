<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6866 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 5ccdbaab-dda6-5695-a96e-d402dcbe3a49 -->
  <rule id="781978" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6866 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>