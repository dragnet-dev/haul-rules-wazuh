<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4880 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d7c6bd45-db95-5f7f-b9d7-b7c1386b59dd -->
  <rule id="343965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4880 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>