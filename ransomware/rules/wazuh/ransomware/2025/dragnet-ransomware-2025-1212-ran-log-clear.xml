<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1212 — Event Log Clearing (radiant) | Status: deprecated | Sigma ID: cbf0b2ec-043e-516f-90e5-ed06d49fdbd3 -->
  <rule id="820912" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1212 — Event Log Clearing (radiant)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>