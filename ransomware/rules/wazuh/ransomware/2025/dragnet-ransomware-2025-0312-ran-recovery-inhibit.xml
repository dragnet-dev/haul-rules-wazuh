<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0312 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 1f569b78-1edc-59cd-a75d-23c1621ee7d8 -->
  <rule id="651157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0312 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>