<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5408 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: c3012392-2e85-564f-9da4-9091e25aa8b3 -->
  <rule id="430123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5408 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>