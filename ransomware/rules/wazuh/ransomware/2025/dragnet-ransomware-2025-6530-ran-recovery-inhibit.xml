<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6530 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 67bd456d-17ab-53f1-8294-6b52b0765023 -->
  <rule id="934145" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6530 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>