<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4122 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 924d71a5-a176-5e3d-b9c1-20cd747cfc5a -->
  <rule id="679771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4122 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>