<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5654 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 97d90408-0d09-50db-b04b-a501f660be66 -->
  <rule id="765904" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5654 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>