<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3956 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: 2ad258db-507a-5267-8863-59324bf57f13 -->
  <rule id="264141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3956 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>