<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7526 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: ed31f594-6e90-5fc4-8be8-eb03d5b3f465 -->
  <rule id="297115" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7526 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>