<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4377 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 08e0ac1b-17e9-5eb2-8cc5-f26a667791b5 -->
  <rule id="136921" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4377 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>