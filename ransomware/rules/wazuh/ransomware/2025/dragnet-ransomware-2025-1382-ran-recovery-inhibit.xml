<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1382 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: f1d4fe08-e347-5908-b6c8-1a6087a75f37 -->
  <rule id="919518" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1382 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>