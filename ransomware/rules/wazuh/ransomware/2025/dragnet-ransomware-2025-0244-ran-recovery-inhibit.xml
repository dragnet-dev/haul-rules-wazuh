<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0244 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 47fc8446-64b9-5792-9d49-c7dca51c55a8 -->
  <rule id="428484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0244 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>