<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5155 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2a6da244-3dbe-5b7f-89b9-e9e57959afcf -->
  <rule id="292742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5155 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>