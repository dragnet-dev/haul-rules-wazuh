<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6937 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: 96cac7a9-4793-54c1-a660-b7c51eb283e0 -->
  <rule id="464607" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6937 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>