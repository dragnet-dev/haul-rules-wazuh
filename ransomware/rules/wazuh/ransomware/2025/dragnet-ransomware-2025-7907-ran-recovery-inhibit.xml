<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7907 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: e8af3db4-9deb-5dc9-9459-41829c66bdd2 -->
  <rule id="790141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7907 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>