<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5750 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: da541cb1-a7c5-5e30-9045-d7caf7581a0f -->
  <rule id="896668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5750 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>