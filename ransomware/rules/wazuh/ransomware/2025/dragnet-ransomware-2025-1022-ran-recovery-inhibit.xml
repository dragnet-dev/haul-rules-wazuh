<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1022 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: c5197855-3df6-557c-a825-8b9d781ff7cc -->
  <rule id="451978" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1022 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>