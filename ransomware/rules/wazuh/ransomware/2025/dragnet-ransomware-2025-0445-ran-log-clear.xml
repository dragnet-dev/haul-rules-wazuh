<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0445 — Event Log Clearing (qilin) | Status: test | Sigma ID: f7524398-102b-5981-8982-d4aac05d712c -->
  <rule id="775243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0445 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>