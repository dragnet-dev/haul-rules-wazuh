<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0673 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d2c15348-fd7a-560a-87cf-7711c3530e63 -->
  <rule id="424153" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0673 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>