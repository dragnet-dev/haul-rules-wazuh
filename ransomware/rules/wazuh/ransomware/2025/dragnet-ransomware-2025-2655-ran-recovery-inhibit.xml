<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2655 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 5c60999b-844a-59d9-b129-52c0989ae797 -->
  <rule id="360999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2655 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>