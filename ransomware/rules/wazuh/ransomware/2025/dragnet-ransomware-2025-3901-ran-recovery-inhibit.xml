<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3901 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: dcb4fb75-51cc-5f0e-bb30-a6dbebdf0d2a -->
  <rule id="140635" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3901 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>