<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7512 — Event Log Clearing (blackshrantac) | Status: experimental | Sigma ID: c9d45c89-d645-509d-93b4-b9e0cdc8f04d -->
  <rule id="723932" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7512 — Event Log Clearing (blackshrantac)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>