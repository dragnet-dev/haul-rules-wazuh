<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3372 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 2203e57b-c846-5f8e-b75f-8aa8ab4c808c -->
  <rule id="926257" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3372 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>