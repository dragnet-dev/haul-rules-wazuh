<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1457 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 25316ec6-ed6c-5c89-b64b-9fc6ad43af13 -->
  <rule id="281132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1457 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>