<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1410 — Recovery Inhibition (weyhro) | Status: experimental | Sigma ID: f55bb8bf-b0d3-55ff-b85e-7a9812897b5d -->
  <rule id="482678" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1410 — Recovery Inhibition (weyhro)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>