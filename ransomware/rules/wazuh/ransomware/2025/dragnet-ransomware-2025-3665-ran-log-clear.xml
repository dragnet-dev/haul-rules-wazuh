<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3665 — Event Log Clearing (nasirsecurity) | Status: experimental | Sigma ID: f239e87b-0dd5-5d70-87b9-56a0775c73b9 -->
  <rule id="738388" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3665 — Event Log Clearing (nasirsecurity)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>