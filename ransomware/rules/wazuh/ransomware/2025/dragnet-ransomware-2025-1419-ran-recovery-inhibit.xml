<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1419 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 4347af8c-fe4e-5b20-8c03-57f0c6302158 -->
  <rule id="313007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1419 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>