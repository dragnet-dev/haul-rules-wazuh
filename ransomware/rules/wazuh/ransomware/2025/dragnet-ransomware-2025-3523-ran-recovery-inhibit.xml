<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3523 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 193c732c-d869-5739-9c73-b7eade741b9b -->
  <rule id="500732" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3523 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>