<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1413 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: a4f9e4ce-a48f-5c25-9c6e-a4c3bd8be986 -->
  <rule id="987984" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1413 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>