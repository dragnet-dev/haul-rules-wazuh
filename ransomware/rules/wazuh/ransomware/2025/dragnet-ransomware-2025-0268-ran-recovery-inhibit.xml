<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0268 — Recovery Inhibition (bert) | Status: experimental | Sigma ID: bd94e0d8-0ebc-591b-bf12-220105144cfd -->
  <rule id="439180" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0268 — Recovery Inhibition (bert)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>