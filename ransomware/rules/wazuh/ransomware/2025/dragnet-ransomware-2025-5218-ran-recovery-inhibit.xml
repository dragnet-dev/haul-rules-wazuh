<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5218 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 0715bffd-7b91-5190-9686-081891119ac8 -->
  <rule id="331711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5218 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>