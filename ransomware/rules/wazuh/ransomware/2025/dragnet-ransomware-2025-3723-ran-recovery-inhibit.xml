<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3723 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 08aaa1c8-1e2c-546f-98f2-b83de31963ef -->
  <rule id="379708" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3723 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>