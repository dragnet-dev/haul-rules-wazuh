<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7488 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2b2cb977-e18c-5ec7-8f77-f5d6a696bdea -->
  <rule id="307959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7488 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>