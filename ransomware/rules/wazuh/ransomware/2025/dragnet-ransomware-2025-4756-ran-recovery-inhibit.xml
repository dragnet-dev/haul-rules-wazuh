<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4756 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3a50240c-44e0-504a-a893-08fb6778b1be -->
  <rule id="550240" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4756 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>