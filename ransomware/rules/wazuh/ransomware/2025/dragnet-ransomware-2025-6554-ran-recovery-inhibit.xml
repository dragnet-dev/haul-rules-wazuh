<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6554 — Recovery Inhibition (hellcat) | Status: deprecated | Sigma ID: 7773dc2d-4cf6-5cb2-a9f0-119affdabbed -->
  <rule id="290108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6554 — Recovery Inhibition (hellcat)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>