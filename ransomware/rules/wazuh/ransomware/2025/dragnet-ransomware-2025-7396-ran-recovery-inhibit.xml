<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7396 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: d736044a-14ba-5cdd-8776-21ec712e0112 -->
  <rule id="573604" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7396 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>