<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6449 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: f46c7eae-dc06-5e1b-a444-add7fbdbad0a -->
  <rule id="459806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6449 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>