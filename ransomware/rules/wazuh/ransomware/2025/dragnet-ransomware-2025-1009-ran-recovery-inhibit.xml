<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1009 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: d4c0e2b0-d735-562f-ace4-5754a591db21 -->
  <rule id="849742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1009 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>