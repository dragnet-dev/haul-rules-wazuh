<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5613 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6f5b041e-766e-5871-9cac-5c91cf491e82 -->
  <rule id="985104" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5613 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>