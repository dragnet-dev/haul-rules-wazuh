<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0718 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: edaee40f-7f87-5c24-bf30-c1019b923504 -->
  <rule id="835504" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0718 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>