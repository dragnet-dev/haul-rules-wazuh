<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2587 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: b01a7721-f3e1-53a8-8cc3-cb4ab91ddad8 -->
  <rule id="962677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2587 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>