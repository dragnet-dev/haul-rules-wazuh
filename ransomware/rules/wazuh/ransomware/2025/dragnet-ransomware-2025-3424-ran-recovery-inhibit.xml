<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3424 — Recovery Inhibition (play) | Status: experimental | Sigma ID: dcdf1370-6daf-5414-9f2c-8fa2e6c02539 -->
  <rule id="354313" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3424 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>