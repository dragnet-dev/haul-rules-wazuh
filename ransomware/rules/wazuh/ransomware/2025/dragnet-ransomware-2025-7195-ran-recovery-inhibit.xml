<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7195 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 48130ad1-7e4a-5d6e-b6df-e28f88ddc4fc -->
  <rule id="721453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7195 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>