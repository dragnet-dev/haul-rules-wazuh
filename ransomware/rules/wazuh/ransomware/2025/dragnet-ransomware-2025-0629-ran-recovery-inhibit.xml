<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0629 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 9e7dc416-13a3-503e-b963-6e19ab0ccbad -->
  <rule id="564924" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0629 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>