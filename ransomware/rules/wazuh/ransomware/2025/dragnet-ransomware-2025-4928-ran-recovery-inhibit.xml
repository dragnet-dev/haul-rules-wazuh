<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4928 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 8b681a4d-5c8f-554a-8796-b0821730ca70 -->
  <rule id="534906" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4928 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>