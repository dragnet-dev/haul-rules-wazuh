<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1761 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 2b32f1cb-e0e0-52b7-858b-7b38a7922974 -->
  <rule id="392348" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1761 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>