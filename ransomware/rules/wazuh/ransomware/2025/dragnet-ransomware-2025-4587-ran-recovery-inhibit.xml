<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4587 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: b98f6060-1892-576b-9e7a-21918c068d3f -->
  <rule id="218360" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4587 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>