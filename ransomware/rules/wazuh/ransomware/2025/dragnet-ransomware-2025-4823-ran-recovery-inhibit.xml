<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4823 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 8d0156b3-8d93-5601-a9ca-add6af63af2f -->
  <rule id="610156" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4823 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>