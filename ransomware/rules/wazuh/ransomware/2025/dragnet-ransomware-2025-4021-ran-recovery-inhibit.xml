<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4021 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: f2bc7c9b-cb01-5d3b-be5b-1ede4794ed1c -->
  <rule id="956124" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4021 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>