<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1221 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: a2d4e678-785e-5e17-b2ad-60950ca4b4e4 -->
  <rule id="932786" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1221 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>