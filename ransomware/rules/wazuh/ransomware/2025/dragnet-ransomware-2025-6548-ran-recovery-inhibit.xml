<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6548 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: fa6d55fd-171b-59a1-a92f-056d191d22c4 -->
  <rule id="510955" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6548 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>