<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1752 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: a0fc2036-6065-5d35-83e7-1a61ae7e16e6 -->
  <rule id="885220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1752 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>