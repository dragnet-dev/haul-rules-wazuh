<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6395 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 01c8f20d-7cf9-5693-a496-82c3dfae4b54 -->
  <rule id="297133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6395 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>