<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6980 — Recovery Inhibition (securotrop) | Status: experimental | Sigma ID: 9039052e-e293-504f-920b-e15f270a72b3 -->
  <rule id="139052" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6980 — Recovery Inhibition (securotrop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>