<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3935 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1a6451fb-3187-54f9-9b04-426bc6925e1e -->
  <rule id="763231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3935 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>