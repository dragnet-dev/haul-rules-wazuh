<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5872 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 98ff9f5e-199a-5a92-93ae-117cb49a3949 -->
  <rule id="555039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5872 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>