<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3516 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 10ebbeda-a0ca-52d9-8943-408834daf1a3 -->
  <rule id="751373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3516 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>