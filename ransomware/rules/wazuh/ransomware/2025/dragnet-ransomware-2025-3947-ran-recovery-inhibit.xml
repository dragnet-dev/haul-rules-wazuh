<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3947 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 1cd17496-80d0-50a4-9e3b-4b0ebbb45882 -->
  <rule id="211749" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3947 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>