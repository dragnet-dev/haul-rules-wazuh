<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2342 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6746f795-2c53-5e5f-9fc1-8aafa17b5c4a -->
  <rule id="279517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2342 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>