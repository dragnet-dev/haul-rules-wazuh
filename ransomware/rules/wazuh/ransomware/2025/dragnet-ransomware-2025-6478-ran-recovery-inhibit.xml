<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6478 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 66e924c9-817a-5341-a1c2-ab1ea036ac71 -->
  <rule id="270924" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6478 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>