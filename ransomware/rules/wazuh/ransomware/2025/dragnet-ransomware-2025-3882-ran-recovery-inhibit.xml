<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3882 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2ed25674-4be0-5ed6-911c-7778914cf125 -->
  <rule id="392567" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3882 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>