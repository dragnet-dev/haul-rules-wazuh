<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7081 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 86841c72-47ad-5064-ae34-41458521ea18 -->
  <rule id="589468" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7081 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>