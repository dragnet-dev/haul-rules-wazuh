<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3250 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 01c4419c-6819-5f40-83d2-b44cde616b23 -->
  <rule id="150716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3250 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>