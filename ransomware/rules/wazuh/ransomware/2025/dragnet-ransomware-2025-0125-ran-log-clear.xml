<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0125 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 1d2f979f-44cb-56f9-985f-e7fa7b7cdac3 -->
  <rule id="287979" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0125 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>