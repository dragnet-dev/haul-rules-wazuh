<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2272 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a990a24c-4ae4-5ef4-9359-a9131f5a4302 -->
  <rule id="958502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2272 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>