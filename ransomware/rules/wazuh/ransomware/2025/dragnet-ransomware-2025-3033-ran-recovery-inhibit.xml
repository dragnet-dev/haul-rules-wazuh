<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3033 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 3387eb52-e508-57c6-a560-bad328376f32 -->
  <rule id="673075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3033 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>