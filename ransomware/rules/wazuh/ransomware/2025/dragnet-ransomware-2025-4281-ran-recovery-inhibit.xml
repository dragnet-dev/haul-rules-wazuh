<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4281 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: ba7a0d4c-1ae5-5c89-bc12-461b49f3bd16 -->
  <rule id="381133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4281 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>