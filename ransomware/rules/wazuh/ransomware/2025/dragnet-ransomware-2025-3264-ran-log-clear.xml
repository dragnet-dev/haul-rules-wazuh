<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3264 — Event Log Clearing (teamxxx) | Status: experimental | Sigma ID: e7c6b4d5-77fb-5b1c-8a1b-d722121a9775 -->
  <rule id="283474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3264 — Event Log Clearing (teamxxx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>