<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1430 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 0254e5f6-33b5-52c5-a2bd-7a7d4f8ddbcb -->
  <rule id="325756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1430 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>