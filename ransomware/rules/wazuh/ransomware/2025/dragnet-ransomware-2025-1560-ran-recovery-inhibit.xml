<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1560 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: ad260a4e-5962-5374-b631-883b9970de8b -->
  <rule id="172170" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1560 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>