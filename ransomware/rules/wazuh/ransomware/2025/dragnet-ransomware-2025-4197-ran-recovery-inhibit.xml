<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4197 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: e19fdb95-5aca-5526-8c31-c3076f07e96e -->
  <rule id="516283" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4197 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>