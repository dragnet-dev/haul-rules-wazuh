<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0173 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: b1e4013a-6a80-5a7b-bd25-6aa8403237a1 -->
  <rule id="990401" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0173 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>