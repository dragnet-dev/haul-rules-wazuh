<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4959 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: a9a9b442-68a5-59cd-a6fb-426728796df6 -->
  <rule id="207954" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4959 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>