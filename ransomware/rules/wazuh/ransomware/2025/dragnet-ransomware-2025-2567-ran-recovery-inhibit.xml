<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2567 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c0e998f3-ef7d-51ca-a4bf-b637d8fef7dd -->
  <rule id="234998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2567 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>