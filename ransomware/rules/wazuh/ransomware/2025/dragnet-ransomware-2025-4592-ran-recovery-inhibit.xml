<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4592 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 62978c3a-43ec-5983-aaab-f29c3bcf16c3 -->
  <rule id="207660" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4592 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>