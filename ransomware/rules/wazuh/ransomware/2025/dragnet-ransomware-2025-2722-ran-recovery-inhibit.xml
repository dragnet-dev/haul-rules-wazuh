<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2722 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: ff3e91b2-cb57-58d5-9b37-211a18e35a03 -->
  <rule id="586291" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2722 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>