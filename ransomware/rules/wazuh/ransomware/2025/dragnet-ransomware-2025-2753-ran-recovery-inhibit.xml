<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2753 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: da8088a7-0970-5489-988b-8ca22b4bf33b -->
  <rule id="488088" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2753 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>