<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1054 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 1c29a815-9f32-5ca4-a15a-0635a8c1f1c1 -->
  <rule id="127481" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1054 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>