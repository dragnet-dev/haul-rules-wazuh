<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2877 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: dff1d64c-acf5-5b1b-8d5a-75efe49f7a43 -->
  <rule id="433096" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2877 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>