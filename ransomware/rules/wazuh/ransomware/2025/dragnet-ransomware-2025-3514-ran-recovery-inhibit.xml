<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3514 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e32ca919-cbd3-5732-9fd5-a0a2e7d58bfd -->
  <rule id="167949" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3514 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>