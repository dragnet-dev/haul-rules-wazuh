<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3985 — Event Log Clearing (kraken) | Status: experimental | Sigma ID: b4f408b4-6b2d-5f53-8fc3-25adde9284b7 -->
  <rule id="139408" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3985 — Event Log Clearing (kraken)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>