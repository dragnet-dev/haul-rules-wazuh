<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6027 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 401b56c3-d28d-5360-837b-860982e11e6c -->
  <rule id="484108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6027 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>