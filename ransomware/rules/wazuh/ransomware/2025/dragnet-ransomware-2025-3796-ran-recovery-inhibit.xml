<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3796 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5aae9971-317f-58c6-97ad-39aa35d04ee2 -->
  <rule id="621499" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3796 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>