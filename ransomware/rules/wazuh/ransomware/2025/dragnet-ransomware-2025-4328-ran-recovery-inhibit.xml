<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4328 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: eda34a9d-06ba-5501-a0a4-e40783db34fa -->
  <rule id="783754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4328 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>