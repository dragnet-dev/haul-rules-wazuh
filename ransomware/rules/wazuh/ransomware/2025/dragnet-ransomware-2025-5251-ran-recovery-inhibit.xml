<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5251 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 1fdc3a05-f2ba-507b-9ac6-dc6db30331d7 -->
  <rule id="505018" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5251 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>