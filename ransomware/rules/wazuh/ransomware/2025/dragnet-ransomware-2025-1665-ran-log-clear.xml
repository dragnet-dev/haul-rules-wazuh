<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1665 — Event Log Clearing (kryptos) | Status: deprecated | Sigma ID: 052e4c72-4d27-59fa-a75f-b63195366363 -->
  <rule id="554367" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1665 — Event Log Clearing (kryptos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>