<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2103 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: d2bad5ac-c379-552f-986c-3ffbc5271913 -->
  <rule id="136615" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2103 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>