<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1137 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 9a1c061b-7c3e-5265-9933-52909d986904 -->
  <rule id="766806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1137 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>