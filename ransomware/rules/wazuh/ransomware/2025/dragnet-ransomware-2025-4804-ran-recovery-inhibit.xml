<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4804 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 9e0f9f1f-c735-568b-b237-9479bfdd34f2 -->
  <rule id="547359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4804 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>