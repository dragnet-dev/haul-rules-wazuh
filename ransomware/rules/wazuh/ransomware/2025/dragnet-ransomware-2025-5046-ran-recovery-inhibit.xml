<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5046 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: dd6440dd-7a64-5a55-8a59-23a6f7fc792d -->
  <rule id="516440" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5046 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>