<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0242 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 94202348-66fa-553a-9af4-a99013fd5bb0 -->
  <rule id="520234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0242 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>