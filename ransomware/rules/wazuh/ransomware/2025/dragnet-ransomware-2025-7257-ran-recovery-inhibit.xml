<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7257 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: 35a498f4-ee3e-5ddc-8a03-99cb073515ed -->
  <rule id="227983" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7257 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>