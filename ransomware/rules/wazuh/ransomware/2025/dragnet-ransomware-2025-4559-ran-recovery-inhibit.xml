<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4559 — Recovery Inhibition (skira) | Status: experimental | Sigma ID: 7d055c27-9b0b-5bf7-b073-4746c4c24cd1 -->
  <rule id="300892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4559 — Recovery Inhibition (skira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>