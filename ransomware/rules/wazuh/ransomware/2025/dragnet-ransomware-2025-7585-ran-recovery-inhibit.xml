<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7585 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 645ce800-d249-54f3-99fe-7fe4cf9c5e59 -->
  <rule id="853268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7585 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>