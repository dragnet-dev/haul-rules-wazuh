<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4133 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 9efc090e-8d18-5dae-902c-57b77e15c4c1 -->
  <rule id="570009" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4133 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>