<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3321 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 9f63dd50-db30-5b0f-9399-d62146c21d06 -->
  <rule id="586749" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3321 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>