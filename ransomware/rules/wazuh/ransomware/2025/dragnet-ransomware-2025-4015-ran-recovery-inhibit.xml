<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4015 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 6a3acae8-99fc-5daf-97a6-ada57df10e58 -->
  <rule id="856810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4015 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
