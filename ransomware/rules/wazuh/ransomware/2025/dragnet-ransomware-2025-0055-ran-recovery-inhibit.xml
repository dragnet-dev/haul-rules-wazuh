<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0055 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 17e7ddc2-9bcc-517a-a07d-aa20fe6fa3ab -->
  <rule id="146780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0055 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>