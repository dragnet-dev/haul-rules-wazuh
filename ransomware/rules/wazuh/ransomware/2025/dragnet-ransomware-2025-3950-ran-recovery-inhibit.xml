<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3950 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 3bcc9bdb-a41d-5719-843b-4f3bd8ab1f33 -->
  <rule id="749435" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3950 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>