<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4445 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 5e8d4220-3cf5-5f73-91d5-1268978bd6e6 -->
  <rule id="718142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4445 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>