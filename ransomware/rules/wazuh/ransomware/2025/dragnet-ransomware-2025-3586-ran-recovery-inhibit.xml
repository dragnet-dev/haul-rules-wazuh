<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3586 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 77523c20-0a05-5490-8bfe-02fbb2272c8a -->
  <rule id="440380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3586 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>