<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6234 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: d85767ad-c6f0-5b4d-b0a3-4eee4782161d -->
  <rule id="585767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6234 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>