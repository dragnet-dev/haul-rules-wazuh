<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1474 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6578291e-c2e4-5ac1-95a6-f36349beba6d -->
  <rule id="378291" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1474 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>