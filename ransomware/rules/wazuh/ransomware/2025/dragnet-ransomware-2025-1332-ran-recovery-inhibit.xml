<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1332 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: c559c44e-0f57-5a06-a095-949c01ebd45b -->
  <rule id="309564" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1332 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>