<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4091 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: b8934387-8004-541f-be0c-44db220f34d5 -->
  <rule id="389343" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4091 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>