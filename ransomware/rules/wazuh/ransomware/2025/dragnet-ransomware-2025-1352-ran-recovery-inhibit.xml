<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1352 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: f94c431a-3a56-5e64-8baa-32df9be3b15f -->
  <rule id="851643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1352 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>