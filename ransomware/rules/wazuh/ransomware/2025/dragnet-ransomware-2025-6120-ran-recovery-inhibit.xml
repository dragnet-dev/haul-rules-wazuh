<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6120 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 0d0db610-09f4-57d5-a9be-3a27d29ebeef -->
  <rule id="749961" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6120 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>