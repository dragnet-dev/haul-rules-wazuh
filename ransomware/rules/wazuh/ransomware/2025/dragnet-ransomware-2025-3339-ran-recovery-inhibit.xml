<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3339 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: c9015039-a610-5f85-9c23-cc4a98c6077f -->
  <rule id="490150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3339 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>