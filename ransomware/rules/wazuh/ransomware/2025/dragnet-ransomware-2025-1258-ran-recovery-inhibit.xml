<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1258 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 49958cdd-9347-54f6-a0d8-1e9d508e60c8 -->
  <rule id="289453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1258 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>