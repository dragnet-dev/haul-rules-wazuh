<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0803 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ec6d63cd-5362-5f4d-b540-6bbb558d4b39 -->
  <rule id="286963" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0803 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>