<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5377 — Recovery Inhibition (trinity) | Status: experimental | Sigma ID: fd408c51-014d-52fa-974d-9fb469f9d1d9 -->
  <rule id="554540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5377 — Recovery Inhibition (trinity)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>