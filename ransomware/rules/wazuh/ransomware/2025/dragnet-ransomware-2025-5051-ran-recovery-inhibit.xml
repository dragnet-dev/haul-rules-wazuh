<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5051 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 59a14b7d-1b8a-51f7-ae60-9c97a94e85ad -->
  <rule id="726635" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5051 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>