<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5854 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e8700fbd-7fdf-53a7-86cf-15ef2959ee77 -->
  <rule id="679215" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5854 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>