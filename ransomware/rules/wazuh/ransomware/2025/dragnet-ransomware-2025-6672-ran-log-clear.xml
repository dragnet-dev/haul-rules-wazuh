<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6672 — Event Log Clearing (babuk2) | Status: experimental | Sigma ID: 5989965b-40e1-5a7e-9fa6-6fe4c3edabfa -->
  <rule id="689965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6672 — Event Log Clearing (babuk2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>