<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2285 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: cef8b91a-eff2-500e-98e2-121114ff6c08 -->
  <rule id="898999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2285 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>