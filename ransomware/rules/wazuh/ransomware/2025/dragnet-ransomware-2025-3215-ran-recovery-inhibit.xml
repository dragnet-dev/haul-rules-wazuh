<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3215 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: f42496f2-ade2-5f46-938c-49142f6fee55 -->
  <rule id="742496" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3215 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>