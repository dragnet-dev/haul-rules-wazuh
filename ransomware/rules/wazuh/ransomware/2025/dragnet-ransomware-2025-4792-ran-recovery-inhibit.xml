<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4792 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 7eef2b22-7e76-5f38-bf9b-00df0c2eb0e2 -->
  <rule id="799243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4792 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
