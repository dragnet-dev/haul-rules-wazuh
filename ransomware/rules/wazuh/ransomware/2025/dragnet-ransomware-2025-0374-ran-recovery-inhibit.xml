<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0374 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 9dea3549-abc1-5651-a0ce-e36a7726f075 -->
  <rule id="542635" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0374 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>