<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3479 — Recovery Inhibition (warlock) | Status: experimental | Sigma ID: 6b4eabe6-10ae-5bb8-8187-ff291a0f19db -->
  <rule id="902859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3479 — Recovery Inhibition (warlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>