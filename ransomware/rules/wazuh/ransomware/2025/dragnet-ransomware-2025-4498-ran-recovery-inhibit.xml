<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4498 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: e196fdec-e99b-59f9-bdf5-ceccb9b79f25 -->
  <rule id="134429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4498 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>