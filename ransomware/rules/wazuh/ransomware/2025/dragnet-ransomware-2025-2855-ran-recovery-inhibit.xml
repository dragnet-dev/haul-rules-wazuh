<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2855 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: 3101b6eb-2730-5b1e-bfcb-49b1c5527c91 -->
  <rule id="840430" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2855 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>