<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6321 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: b6d46feb-d181-55b9-a381-9067af5f0b9a -->
  <rule id="391151" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6321 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>