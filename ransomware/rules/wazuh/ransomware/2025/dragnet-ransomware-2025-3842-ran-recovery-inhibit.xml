<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3842 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 38d78071-7007-517b-a661-7d186f283fec -->
  <rule id="917807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3842 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>