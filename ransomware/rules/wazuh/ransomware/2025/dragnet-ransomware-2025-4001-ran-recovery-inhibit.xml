<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4001 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c7b2dba4-d534-51ea-b20a-65d96a0007d2 -->
  <rule id="830811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4001 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>