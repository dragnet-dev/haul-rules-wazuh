<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7485 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 65ee672e-3fb9-5c7a-b399-2d471cfd75ba -->
  <rule id="887867" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7485 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>