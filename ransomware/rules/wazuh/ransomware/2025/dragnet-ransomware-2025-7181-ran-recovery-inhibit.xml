<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7181 — Recovery Inhibition (kraken) | Status: experimental | Sigma ID: e3b05bc3-5783-5d18-af5b-291677af6e09 -->
  <rule id="178491" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7181 — Recovery Inhibition (kraken)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>