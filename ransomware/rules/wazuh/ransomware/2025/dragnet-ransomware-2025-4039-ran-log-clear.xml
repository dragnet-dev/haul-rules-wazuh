<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4039 — Event Log Clearing (ralord) | Status: experimental | Sigma ID: 68029ba0-b971-5a05-84dd-7d56e80a818a -->
  <rule id="288475" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4039 — Event Log Clearing (ralord)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>