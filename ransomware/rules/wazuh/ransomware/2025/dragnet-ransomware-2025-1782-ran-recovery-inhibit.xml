<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1782 — Recovery Inhibition (bqtlock) | Status: experimental | Sigma ID: 75f1ef96-d973-556c-85ba-bf81bf3477ca -->
  <rule id="510895" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1782 — Recovery Inhibition (bqtlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>