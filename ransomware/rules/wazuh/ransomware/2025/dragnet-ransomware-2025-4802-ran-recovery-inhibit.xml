<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4802 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: f2301881-65cc-5a01-9561-f09589618de2 -->
  <rule id="723018" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4802 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>