<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2271 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 10e7ce7e-e516-5d6b-bb1f-244890f9c2a5 -->
  <rule id="974387" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2271 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>