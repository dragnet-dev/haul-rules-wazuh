<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6969 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 5d72d972-7c89-5f03-a24a-64e5b5ff949f -->
  <rule id="699659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6969 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>