<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2791 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: 20ccc42a-7651-5ed7-9bab-312d0583bbb9 -->
  <rule id="519642" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2791 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>