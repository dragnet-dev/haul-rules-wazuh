<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2881 — Recovery Inhibition (payoutsking) | Status: experimental | Sigma ID: 4c74ee65-2a79-569d-be0e-c264d18f95eb -->
  <rule id="264782" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2881 — Recovery Inhibition (payoutsking)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>