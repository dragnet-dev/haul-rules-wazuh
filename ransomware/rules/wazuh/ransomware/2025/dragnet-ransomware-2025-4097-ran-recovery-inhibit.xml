<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4097 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e4b1828c-4f27-5fb9-96d3-fe66cb597b35 -->
  <rule id="615182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4097 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>