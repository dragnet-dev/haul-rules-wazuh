<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1492 — Recovery Inhibition (skira) | Status: experimental | Sigma ID: 3cac9a2f-df19-5c72-ba92-8ca71731224f -->
  <rule id="785274" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1492 — Recovery Inhibition (skira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>