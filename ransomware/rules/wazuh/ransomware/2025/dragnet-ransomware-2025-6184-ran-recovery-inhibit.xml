<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6184 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 21faf443-8d63-55a8-8334-9722f9d4a67d -->
  <rule id="103144" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6184 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>