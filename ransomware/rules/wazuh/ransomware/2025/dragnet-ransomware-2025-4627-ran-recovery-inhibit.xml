<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4627 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 1014a941-fdf8-5791-a128-72cdd1b2363e -->
  <rule id="823494" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4627 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>