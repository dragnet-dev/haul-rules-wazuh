<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2965 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 5e76f7cb-bf16-5f94-a38e-fe533e2bf946 -->
  <rule id="716317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2965 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>