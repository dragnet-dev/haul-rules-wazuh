<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7419 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: f4e7af33-918b-5f90-afbe-4838efee165e -->
  <rule id="145647" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7419 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>