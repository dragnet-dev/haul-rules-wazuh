<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3081 — Recovery Inhibition (play) | Status: experimental | Sigma ID: eb840930-440f-5ae0-9da8-d0194eef5b62 -->
  <rule id="658409" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3081 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>