<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4045 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 045f8b6a-8651-5f0b-b716-a875c359d859 -->
  <rule id="377396" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4045 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>