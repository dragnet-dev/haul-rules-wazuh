<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7391 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: d1ecb666-619f-5365-acb6-9f5612fa1964 -->
  <rule id="103636" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7391 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>