<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3845 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 4b45cfd8-23cd-541e-8753-ccd0489d595b -->
  <rule id="231727" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3845 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>