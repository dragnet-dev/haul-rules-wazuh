<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6783 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 5e0ddd8e-b09c-57a1-bb7d-a06548aaf19d -->
  <rule id="353789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6783 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>