<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4475 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 2f8c376d-2b07-5a08-92c0-39ec8ebb8bc9 -->
  <rule id="560376" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4475 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>