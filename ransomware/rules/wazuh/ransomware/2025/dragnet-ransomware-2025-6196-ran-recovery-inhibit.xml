<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6196 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 380e88d4-a31f-5de2-bb50-1e79d6ee6ae2 -->
  <rule id="851821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6196 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>