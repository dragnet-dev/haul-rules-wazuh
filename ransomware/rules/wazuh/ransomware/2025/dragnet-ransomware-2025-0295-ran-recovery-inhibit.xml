<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0295 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 7576e105-4c7b-5385-a152-2c20134d8f28 -->
  <rule id="412301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0295 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>