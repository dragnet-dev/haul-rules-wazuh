<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3995 — Event Log Clearing (kraken) | Status: experimental | Sigma ID: 2419fcad-13d5-5ec8-9b6b-03ed820ebe5e -->
  <rule id="112266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3995 — Event Log Clearing (kraken)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>