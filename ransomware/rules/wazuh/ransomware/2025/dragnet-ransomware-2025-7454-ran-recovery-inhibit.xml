<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7454 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e18c7c90-ad84-5edb-8de8-d74b80492ca7 -->
  <rule id="132124" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7454 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>