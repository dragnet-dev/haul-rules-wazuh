<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3808 — Event Log Clearing (weyhro) | Status: experimental | Sigma ID: 2528a68d-62e2-5dd7-bee6-9883566008a2 -->
  <rule id="545868" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3808 — Event Log Clearing (weyhro)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>