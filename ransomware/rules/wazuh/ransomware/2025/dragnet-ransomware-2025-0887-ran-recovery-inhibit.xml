<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0887 — Recovery Inhibition (interlock) | Status: test | Sigma ID: 71b8b4a8-e3e4-54e0-8352-e7191ea2246c -->
  <rule id="136594" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0887 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>