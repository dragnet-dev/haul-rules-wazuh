<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7762 — Event Log Clearing (minteye) | Status: deprecated | Sigma ID: 2970c599-b6b4-549d-bca5-cf62f8c35d5e -->
  <rule id="353259" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7762 — Event Log Clearing (minteye)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>