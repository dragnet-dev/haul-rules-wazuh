<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2492 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4f26958f-0209-5d82-b853-12af4031a07a -->
  <rule id="826958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2492 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>