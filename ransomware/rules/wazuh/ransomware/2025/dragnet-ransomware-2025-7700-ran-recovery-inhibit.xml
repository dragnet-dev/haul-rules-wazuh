<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7700 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 5938b109-ea79-5fb2-b936-23ca9b8b6802 -->
  <rule id="601910" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7700 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>