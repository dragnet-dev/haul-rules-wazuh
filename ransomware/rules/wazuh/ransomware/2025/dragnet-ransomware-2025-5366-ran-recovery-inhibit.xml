<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5366 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 37316cde-c978-5087-96d1-f7e72da002df -->
  <rule id="653101" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5366 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>