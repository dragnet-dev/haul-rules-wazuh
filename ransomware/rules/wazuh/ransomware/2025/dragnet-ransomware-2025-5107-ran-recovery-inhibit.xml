<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5107 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: fd70fa8f-6bf3-580a-864f-5b3d43993bd9 -->
  <rule id="294970" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5107 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>