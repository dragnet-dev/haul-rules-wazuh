<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6524 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: bb194645-af61-5809-9e55-0a2ac2b378d1 -->
  <rule id="171946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6524 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>