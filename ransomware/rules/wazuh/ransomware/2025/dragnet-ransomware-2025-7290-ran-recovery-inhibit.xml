<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7290 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 185931d1-7cff-5932-bd57-733565b90f09 -->
  <rule id="374909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7290 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>