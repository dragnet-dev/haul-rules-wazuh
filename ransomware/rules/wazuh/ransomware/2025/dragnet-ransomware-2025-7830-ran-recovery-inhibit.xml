<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7830 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 1238ae15-bc45-5e1e-aaf9-f7bf3a1acefc -->
  <rule id="571021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7830 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>