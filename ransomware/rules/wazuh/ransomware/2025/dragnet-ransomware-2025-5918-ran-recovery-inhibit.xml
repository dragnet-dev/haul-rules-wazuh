<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5918 — Recovery Inhibition (tridentlocker) | Status: experimental | Sigma ID: 9cbfe624-1e35-52f7-b9af-6782f0825598 -->
  <rule id="220466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5918 — Recovery Inhibition (tridentlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>