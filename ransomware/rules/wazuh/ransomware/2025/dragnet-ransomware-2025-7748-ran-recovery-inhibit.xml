<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7748 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4cd540df-1754-592d-8356-28c557e546ef -->
  <rule id="429540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7748 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>