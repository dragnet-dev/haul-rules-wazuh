<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2578 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: fd3288d7-e168-54cd-ab17-492c6bf4202e -->
  <rule id="833288" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2578 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>