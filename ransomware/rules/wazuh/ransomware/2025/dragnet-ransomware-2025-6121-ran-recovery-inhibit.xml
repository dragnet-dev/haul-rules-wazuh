<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6121 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 209e46d7-6dad-5ef2-8326-82d5fc5e1a88 -->
  <rule id="973549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6121 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>