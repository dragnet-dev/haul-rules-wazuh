<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0172 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: e113730a-ecb8-5ed0-9a4b-337bb11bf6b2 -->
  <rule id="611373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0172 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>