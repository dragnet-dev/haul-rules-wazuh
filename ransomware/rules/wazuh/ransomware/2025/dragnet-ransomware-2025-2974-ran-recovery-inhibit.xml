<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2974 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 67492b35-46d4-51fb-97a7-0c00abce3588 -->
  <rule id="279883" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2974 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>