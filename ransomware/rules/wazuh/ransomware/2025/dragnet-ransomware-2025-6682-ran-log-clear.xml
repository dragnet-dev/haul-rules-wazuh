<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6682 — Event Log Clearing (devman) | Status: experimental | Sigma ID: 0e7a6552-1e43-58d6-8a75-2e1b655e1cf8 -->
  <rule id="662655" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6682 — Event Log Clearing (devman)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>