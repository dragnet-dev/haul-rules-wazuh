<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1226 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 4e2f8f7b-dff3-5442-94e6-f0a743c65909 -->
  <rule id="304463" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1226 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>