<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6446 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: cf883db6-0399-51d2-9966-c99c65ce4129 -->
  <rule id="726141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6446 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>