<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3922 — Event Log Clearing (safepay) | Status: test | Sigma ID: 4fa21aa5-4bee-50a4-bfe2-16c60c2fdbe7 -->
  <rule id="338746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3922 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>