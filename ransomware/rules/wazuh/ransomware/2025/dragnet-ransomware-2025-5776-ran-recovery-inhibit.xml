<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5776 — Recovery Inhibition (obscura) | Status: experimental | Sigma ID: dfcb2587-fb91-5220-b34a-628fa9aaf3bb -->
  <rule id="429125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5776 — Recovery Inhibition (obscura)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>