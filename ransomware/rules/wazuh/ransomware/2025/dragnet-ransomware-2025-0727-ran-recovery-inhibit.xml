<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0727 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 9c4bda8b-9025-5e18-8769-61f9ea7194c7 -->
  <rule id="209178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0727 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>