<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3592 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 479a54ef-bc5c-55db-89c9-254498be5622 -->
  <rule id="679278" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3592 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
