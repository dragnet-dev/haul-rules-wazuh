<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4648 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 47c83978-5dc5-52af-b955-e606c5648b32 -->
  <rule id="548397" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4648 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>