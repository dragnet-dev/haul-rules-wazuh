<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6818 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 8af60c23-bad1-58c7-a127-2464fc13e7c2 -->
  <rule id="957772" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6818 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>