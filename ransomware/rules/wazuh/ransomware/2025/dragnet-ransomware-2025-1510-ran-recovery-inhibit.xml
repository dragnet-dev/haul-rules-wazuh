<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1510 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 572ddca8-4185-5bf0-9739-6a9300ed2724 -->
  <rule id="646460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1510 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>