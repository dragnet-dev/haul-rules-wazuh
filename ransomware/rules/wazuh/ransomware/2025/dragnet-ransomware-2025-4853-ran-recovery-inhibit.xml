<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4853 — Recovery Inhibition (IMNCrew) | Status: experimental | Sigma ID: 79f4c547-9d72-5a9c-af7a-8c40954b5c7f -->
  <rule id="347165" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4853 — Recovery Inhibition (IMNCrew)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>