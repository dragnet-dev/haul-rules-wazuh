<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7540 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: 02def249-59d1-50ba-94e8-1a90045e1a3b -->
  <rule id="375924" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7540 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>