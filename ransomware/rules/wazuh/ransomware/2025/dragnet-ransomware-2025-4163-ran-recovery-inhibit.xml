<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4163 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: e5c0bf30-91ed-5c1f-a18a-4b7a725ceac3 -->
  <rule id="670111" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4163 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>