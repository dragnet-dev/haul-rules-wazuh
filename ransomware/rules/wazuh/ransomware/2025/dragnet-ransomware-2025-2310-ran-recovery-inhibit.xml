<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2310 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: d61c8b4d-7a89-53eb-8908-eda427a0772e -->
  <rule id="886219" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2310 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>