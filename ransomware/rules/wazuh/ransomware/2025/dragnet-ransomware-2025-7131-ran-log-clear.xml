<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7131 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 245ea6d6-6f90-5a6f-9855-b19d4b3147bf -->
  <rule id="272749" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7131 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>