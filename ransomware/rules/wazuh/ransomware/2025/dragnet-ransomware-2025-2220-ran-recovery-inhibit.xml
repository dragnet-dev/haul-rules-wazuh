<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2220 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 89781949-e92d-5f1a-8305-9fcd2a7d9ad2 -->
  <rule id="978194" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2220 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>