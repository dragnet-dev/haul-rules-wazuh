<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1953 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6c65ebe8-b85d-5c3b-8549-47cf7162aa2d -->
  <rule id="181675" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1953 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>