<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7177 — Event Log Clearing (warlock) | Status: experimental | Sigma ID: 7e0f9a33-a1c5-5d1c-8f6a-38a3bc5bb74c -->
  <rule id="628154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7177 — Event Log Clearing (warlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>