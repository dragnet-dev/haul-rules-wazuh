<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2037 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 3fe00dea-8bce-59ed-9178-e32fa7fa3021 -->
  <rule id="835213" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2037 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>