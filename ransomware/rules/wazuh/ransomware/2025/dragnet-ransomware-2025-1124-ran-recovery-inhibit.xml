<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1124 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: 31f5b05e-6462-5c02-b466-075091db57bc -->
  <rule id="185105" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1124 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>