<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7809 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3952c9f4-6489-5b6a-b06a-b1fe7dacd66e -->
  <rule id="319199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7809 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>