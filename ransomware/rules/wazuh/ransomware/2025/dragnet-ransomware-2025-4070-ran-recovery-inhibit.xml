<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4070 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 73bbe253-b2b2-5828-9e02-a6f35666b94c -->
  <rule id="420142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4070 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>