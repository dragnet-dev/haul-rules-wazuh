<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2241 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 4b7c85c4-71e9-5992-b7bc-f5d7c0ee8482 -->
  <rule id="412485" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2241 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>