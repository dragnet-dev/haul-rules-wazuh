<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2080 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 8783a47d-e57d-5cc7-a5d4-3bfd4f37e3b7 -->
  <rule id="605384" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2080 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>