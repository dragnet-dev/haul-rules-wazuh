<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7580 — Event Log Clearing (GDLockerSec) | Status: experimental | Sigma ID: da14de01-d747-5de1-bda3-402fd3b92205 -->
  <rule id="284606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7580 — Event Log Clearing (GDLockerSec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>