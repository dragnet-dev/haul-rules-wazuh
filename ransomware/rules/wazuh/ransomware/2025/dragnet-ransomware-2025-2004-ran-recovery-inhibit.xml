<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2004 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 53b93bec-597e-5af0-9872-7516fb0845c5 -->
  <rule id="575899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2004 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>