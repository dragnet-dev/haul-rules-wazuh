<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5008 — Event Log Clearing (VanHelsing) | Status: experimental | Sigma ID: 75b174de-ac0a-5110-95cf-1e8c75ce72ed -->
  <rule id="411174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5008 — Event Log Clearing (VanHelsing)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>