<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0290 — Event Log Clearing (apos) | Status: experimental | Sigma ID: 1cb81352-b8d1-5a43-bd37-7f7a7ef51438 -->
  <rule id="198135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0290 — Event Log Clearing (apos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>