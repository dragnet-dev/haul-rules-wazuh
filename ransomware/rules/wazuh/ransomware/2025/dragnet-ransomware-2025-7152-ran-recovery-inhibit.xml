<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7152 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 2488189e-519c-5a5b-bbc4-098c4df2d818 -->
  <rule id="788189" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7152 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>