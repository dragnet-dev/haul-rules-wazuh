<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6180 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: fdab6a52-a3d6-561b-bd57-1bb86aba4651 -->
  <rule id="590346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6180 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>