<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0111 — Event Log Clearing (dragonforce) | Status: experimental | Sigma ID: a48c3c35-6db8-5723-b317-e0eeb69cc4c2 -->
  <rule id="984860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0111 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>