<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3022 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: 4226971b-ed5e-5ba5-976f-bf81b477e2c5 -->
  <rule id="726971" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3022 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>