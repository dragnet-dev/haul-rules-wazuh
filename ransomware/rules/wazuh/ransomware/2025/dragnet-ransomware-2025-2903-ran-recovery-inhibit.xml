<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2903 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 3d24701e-58c9-5015-9e5b-d8c4b3491b20 -->
  <rule id="824701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2903 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>