<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5694 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: e289c328-af8a-5fe9-a13d-55c28ead7fda -->
  <rule id="586363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5694 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>