<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3662 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: e76d10e7-875e-5299-9575-b6b220b7adf0 -->
  <rule id="662910" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3662 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>