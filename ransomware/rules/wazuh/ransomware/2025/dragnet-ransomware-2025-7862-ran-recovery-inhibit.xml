<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7862 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 16fd599a-7ad6-5bb4-91c7-0d54dc35c5ba -->
  <rule id="849599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7862 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>