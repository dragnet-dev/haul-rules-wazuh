<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3093 — Event Log Clearing (insomnia) | Status: experimental | Sigma ID: 0d593b01-f9c8-599e-a779-274600a8ddd1 -->
  <rule id="474990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3093 — Event Log Clearing (insomnia)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>