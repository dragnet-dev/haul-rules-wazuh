<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2187 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: e72dea9c-c611-5baa-8f7c-e7caccc5aef3 -->
  <rule id="732874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2187 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>