<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0229 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 80e20e7e-f916-5310-9bd9-1e63bdda7d28 -->
  <rule id="370734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0229 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>