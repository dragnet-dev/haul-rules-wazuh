<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3327 — Event Log Clearing (lynx) | Status: experimental | Sigma ID: c34e8fe6-05f6-52b5-8ba8-6bf9d0598f4c -->
  <rule id="561423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3327 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>