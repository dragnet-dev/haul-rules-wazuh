<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5807 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 767508df-6c0b-5fe6-bd8d-2accd46845f2 -->
  <rule id="680141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5807 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>