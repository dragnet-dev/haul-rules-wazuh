<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1895 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 634d0497-2722-5324-925a-60fb9f3bdbcb -->
  <rule id="215704" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1895 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>