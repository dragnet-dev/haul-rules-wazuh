<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1158 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 1cf5a45f-dbc8-5443-9ab1-c7f21c270838 -->
  <rule id="317045" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1158 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>