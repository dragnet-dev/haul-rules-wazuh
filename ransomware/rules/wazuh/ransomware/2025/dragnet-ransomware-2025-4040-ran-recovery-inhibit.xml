<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4040 — Recovery Inhibition (qilin) | Status: test | Sigma ID: adfdb75a-23f5-5e9d-b4de-b91bf33079f4 -->
  <rule id="926677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4040 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>