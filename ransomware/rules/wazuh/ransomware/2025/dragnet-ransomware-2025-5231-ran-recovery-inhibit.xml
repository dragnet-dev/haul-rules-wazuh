<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5231 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: e19e08d6-fdf2-5e9b-abf9-e1ac4bdf3870 -->
  <rule id="571808" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5231 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>