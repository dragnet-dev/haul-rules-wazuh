<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4732 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 0ffa22b0-9014-5ba8-82e2-0bd3b542f760 -->
  <rule id="344363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4732 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>