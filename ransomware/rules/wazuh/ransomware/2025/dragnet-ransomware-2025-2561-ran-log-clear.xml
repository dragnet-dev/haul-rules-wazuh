<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2561 — Event Log Clearing (warlock) | Status: deprecated | Sigma ID: d5cbb7fd-6d8b-575e-8c4c-b321b47d4aa2 -->
  <rule id="262197" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2561 — Event Log Clearing (warlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>