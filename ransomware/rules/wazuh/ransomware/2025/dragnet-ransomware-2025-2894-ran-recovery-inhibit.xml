<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2894 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c7d8e815-e655-5b8c-926f-d01988bff219 -->
  <rule id="673428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2894 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>