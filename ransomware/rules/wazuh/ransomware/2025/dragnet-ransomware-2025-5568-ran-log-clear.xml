<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5568 — Event Log Clearing (sinobi) | Status: experimental | Sigma ID: 28d3d31a-8bcd-5981-b956-3a300f1d9e22 -->
  <rule id="282131" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5568 — Event Log Clearing (sinobi)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>