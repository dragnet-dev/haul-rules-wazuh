<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1807 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8d6e1e08-e2c0-51b6-be88-a206bd78666b -->
  <rule id="127230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1807 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>