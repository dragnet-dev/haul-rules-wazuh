<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7297 — Event Log Clearing (embargo) | Status: experimental | Sigma ID: 8b97b25a-bfb2-5b21-938b-51e0d5e7e3f2 -->
  <rule id="539632" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7297 — Event Log Clearing (embargo)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>