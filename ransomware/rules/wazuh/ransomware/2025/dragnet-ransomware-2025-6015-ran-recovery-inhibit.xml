<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6015 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: eb09cb89-c150-5051-bf39-10feaa96bf48 -->
  <rule id="718507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6015 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>