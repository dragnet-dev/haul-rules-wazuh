<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7588 — Event Log Clearing (lynx) | Status: experimental | Sigma ID: dfb937d6-8d9d-51fe-95f0-b1d5ccc7a06e -->
  <rule id="979937" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7588 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>