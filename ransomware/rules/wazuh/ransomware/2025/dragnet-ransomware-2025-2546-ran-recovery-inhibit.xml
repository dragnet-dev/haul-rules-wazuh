<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2546 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 225ff4b7-84e4-5d56-a343-d8d2ffbea37d -->
  <rule id="356875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2546 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>