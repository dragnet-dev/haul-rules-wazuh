<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2799 — Recovery Inhibition (crazyhunter) | Status: experimental | Sigma ID: 82a01e34-d000-55d5-8500-cb94b2dbdc9e -->
  <rule id="415230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2799 — Recovery Inhibition (crazyhunter)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>