<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2915 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: d6ada7de-ce52-5862-ab4f-4671dfd9c554 -->
  <rule id="298347" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2915 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>