<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7730 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: b351a56d-7064-5bf7-8d8c-e15940f09898 -->
  <rule id="116265" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7730 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>