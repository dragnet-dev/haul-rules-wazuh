<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2201 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 33327749-9db8-50b4-aa1c-649b2097cf10 -->
  <rule id="732774" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2201 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>