<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7217 — Recovery Inhibition (everest) | Status: test | Sigma ID: 779e3df9-ccf7-58e6-81ce-360d26995b59 -->
  <rule id="296541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7217 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>