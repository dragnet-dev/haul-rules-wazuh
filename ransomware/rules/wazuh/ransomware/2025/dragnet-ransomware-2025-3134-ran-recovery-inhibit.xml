<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3134 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 392335be-6d4f-52c1-9a81-0c3563b31e58 -->
  <rule id="977371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3134 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
