<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2579 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 4294bb6d-8850-5a4b-9eb4-f77423b31754 -->
  <rule id="299451" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2579 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>