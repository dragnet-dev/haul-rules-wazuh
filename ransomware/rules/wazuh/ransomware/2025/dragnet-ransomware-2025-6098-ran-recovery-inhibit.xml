<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6098 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 5cd35b27-a846-5517-8d29-4006e7241e87 -->
  <rule id="676571" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6098 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>