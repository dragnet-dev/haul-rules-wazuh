<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6841 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: e7ab081d-83a2-565e-a8d0-a4f7b783847c -->
  <rule id="280308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6841 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>