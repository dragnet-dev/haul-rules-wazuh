<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1058 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: cf9a1f8b-3a58-5051-b1b9-e4b6ed621d7d -->
  <rule id="923871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1058 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>