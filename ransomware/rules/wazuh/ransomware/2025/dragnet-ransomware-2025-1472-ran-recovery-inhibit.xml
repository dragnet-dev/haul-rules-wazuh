<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1472 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 1bacf2e7-221c-50ef-a319-504ec426cb62 -->
  <rule id="333592" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1472 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>