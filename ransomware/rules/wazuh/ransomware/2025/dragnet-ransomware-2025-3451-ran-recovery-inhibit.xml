<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3451 — Recovery Inhibition (incransom) | Status: test | Sigma ID: 8c2e2bda-c5fe-5304-ae00-d4464564121b -->
  <rule id="991403" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3451 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
