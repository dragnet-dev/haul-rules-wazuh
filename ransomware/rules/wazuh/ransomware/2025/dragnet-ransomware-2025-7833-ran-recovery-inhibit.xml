<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7833 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: deec8afa-3935-506f-b7b6-955597f0c0a6 -->
  <rule id="231018" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7833 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>