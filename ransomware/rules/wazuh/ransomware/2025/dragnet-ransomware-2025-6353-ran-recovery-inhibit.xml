<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6353 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 836575e8-33ac-5de1-a426-3a9db908e826 -->
  <rule id="885214" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6353 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>