<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2393 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: d80085bd-4a42-5602-860f-c8fd316440fc -->
  <rule id="580085" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2393 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>