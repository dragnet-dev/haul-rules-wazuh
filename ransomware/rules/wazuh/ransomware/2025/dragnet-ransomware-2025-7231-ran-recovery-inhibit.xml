<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7231 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f55dc40e-6b5e-51ba-81cf-b331fc3ac5a3 -->
  <rule id="483004" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7231 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>