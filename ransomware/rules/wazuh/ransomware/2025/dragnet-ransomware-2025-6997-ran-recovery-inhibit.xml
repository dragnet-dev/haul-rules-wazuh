<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6997 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 35136a28-6d08-5d15-b1e6-e540b8b70a21 -->
  <rule id="321862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6997 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>