<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7791 — Event Log Clearing (warlock) | Status: deprecated | Sigma ID: 6fb7cbf3-7a58-5dd8-8332-80a6e0e3de93 -->
  <rule id="176715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7791 — Event Log Clearing (warlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>