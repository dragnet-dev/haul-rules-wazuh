<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1163 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e1e80a78-0b0a-5ac1-bc83-933cac7647cf -->
  <rule id="133290" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1163 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>