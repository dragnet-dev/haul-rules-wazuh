<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7451 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 99fa7fe0-8776-5659-af78-d9b8b5bed355 -->
  <rule id="595167" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7451 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>