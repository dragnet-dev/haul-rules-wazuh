<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6178 — Recovery Inhibition (killsec) | Status: deprecated | Sigma ID: 3cee10b6-a206-57dc-9555-24a7fea89a2b -->
  <rule id="759810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6178 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>