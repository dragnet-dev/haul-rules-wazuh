<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4621 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: bf4247c0-0391-53d2-8606-3a0dc5b345c5 -->
  <rule id="214247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4621 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>