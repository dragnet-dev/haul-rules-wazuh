<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7897 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 283d01fe-bb3f-5a17-a42e-77ea917c4b1e -->
  <rule id="165631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7897 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>