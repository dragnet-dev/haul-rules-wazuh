<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6737 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 902e9f62-9f3c-5323-bb69-165c34b3735f -->
  <rule id="611519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6737 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>