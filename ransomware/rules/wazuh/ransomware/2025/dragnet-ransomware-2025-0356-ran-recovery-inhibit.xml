<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0356 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: b2dfb57d-0078-5b6f-8541-f9341c2e8fd5 -->
  <rule id="223315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0356 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>