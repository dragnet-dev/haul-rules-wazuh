<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3805 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a6fbd00f-638d-509f-b418-160a6de84237 -->
  <rule id="882050" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3805 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>