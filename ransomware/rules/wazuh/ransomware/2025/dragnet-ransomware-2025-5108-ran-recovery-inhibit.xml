<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5108 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: cdfb3f07-9768-53a0-a8c3-c574e35afdb1 -->
  <rule id="437023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5108 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>