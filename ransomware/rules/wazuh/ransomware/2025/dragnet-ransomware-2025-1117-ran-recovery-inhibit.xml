<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1117 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c1f27395-1291-5306-bda2-a09252dae7cf -->
  <rule id="251273" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1117 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>