<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4096 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: ebfca24b-9eeb-5649-9028-e62abc996a81 -->
  <rule id="766022" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4096 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>