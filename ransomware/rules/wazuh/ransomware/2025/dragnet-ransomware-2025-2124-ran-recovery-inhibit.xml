<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2124 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 8d0dccfe-a530-5ed0-92d6-987083d61823 -->
  <rule id="478892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2124 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>