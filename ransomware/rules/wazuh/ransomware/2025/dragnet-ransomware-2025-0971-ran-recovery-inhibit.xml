<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0971 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9783c7f1-6956-54fc-aa2d-570174dcb2f2 -->
  <rule id="765407" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0971 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>