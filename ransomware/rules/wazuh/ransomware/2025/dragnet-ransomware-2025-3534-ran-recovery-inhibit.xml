<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3534 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: c1a69c8b-18f0-5c2b-8f59-eacb2490aa3d -->
  <rule id="514716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3534 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>