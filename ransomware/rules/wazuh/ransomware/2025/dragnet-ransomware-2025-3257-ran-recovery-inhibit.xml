<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3257 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 970f2916-3975-50f8-b207-f4381011e690 -->
  <rule id="753529" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3257 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>