<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5159 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 4483c415-06a8-5e92-862c-5f91bd9bb3a0 -->
  <rule id="974041" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5159 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>