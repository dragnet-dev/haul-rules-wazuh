<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4827 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 7344d456-20a9-5a02-a49a-540f166f399b -->
  <rule id="375174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4827 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>