<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0501 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e9f28821-c3b1-5d25-b945-e1c55632978b -->
  <rule id="699288" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0501 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>