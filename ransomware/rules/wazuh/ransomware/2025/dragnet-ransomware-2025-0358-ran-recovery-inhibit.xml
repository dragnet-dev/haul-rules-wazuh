<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0358 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f6121aca-7d99-52c9-aaf9-b53befd249af -->
  <rule id="797946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0358 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>