<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1856 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 053f3a95-dc9d-5662-b551-3e37733c5259 -->
  <rule id="581389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1856 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>