<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6719 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 4e6d2cc3-bdbc-5bcf-8fb1-15a76a962936 -->
  <rule id="314284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6719 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>