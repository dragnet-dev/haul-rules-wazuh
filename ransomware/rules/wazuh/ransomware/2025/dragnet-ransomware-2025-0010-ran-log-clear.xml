<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0010 — Event Log Clearing (interlock) | Status: experimental | Sigma ID: e4c7523c-a82a-5a2f-8cea-72697c5952f6 -->
  <rule id="616752" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0010 — Event Log Clearing (interlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>