<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7724 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 7e0aaf09-ee37-57e0-b3bf-9654c3aecac0 -->
  <rule id="763695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7724 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>