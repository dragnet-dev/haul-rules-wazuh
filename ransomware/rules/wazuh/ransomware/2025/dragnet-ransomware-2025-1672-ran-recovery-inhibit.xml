<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1672 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: dde505a4-597c-55cc-90b2-a9244e19f789 -->
  <rule id="950505" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1672 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>