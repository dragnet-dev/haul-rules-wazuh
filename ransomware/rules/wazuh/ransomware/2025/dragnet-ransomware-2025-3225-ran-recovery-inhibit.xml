<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3225 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 62861f88-2066-5a17-984e-7f91081c3193 -->
  <rule id="205791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3225 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>