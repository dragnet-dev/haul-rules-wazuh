<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6558 — Recovery Inhibition (interlock) | Status: test | Sigma ID: 2ee8c504-80be-54d7-9871-10a194698496 -->
  <rule id="401405" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6558 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>