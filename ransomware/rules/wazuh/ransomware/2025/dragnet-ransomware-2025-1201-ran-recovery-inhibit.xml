<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1201 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f25afa4c-706d-516b-a565-34e7bd7499e5 -->
  <rule id="949210" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1201 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>