<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1188 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 8da3835a-5b3f-5fa9-b2c7-e848a5339b70 -->
  <rule id="566383" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1188 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>