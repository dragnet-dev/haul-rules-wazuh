<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7906 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 6dba5d6c-d54c-5644-b167-c69c26694965 -->
  <rule id="994493" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7906 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>