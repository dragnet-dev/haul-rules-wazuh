<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7876 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 0ddecdf4-0e23-56b7-b440-e2a5ea3bd8de -->
  <rule id="244095" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7876 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>