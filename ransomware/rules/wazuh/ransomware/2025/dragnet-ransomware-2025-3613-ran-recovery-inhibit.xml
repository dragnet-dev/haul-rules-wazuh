<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3613 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 5a746d70-7d80-599b-8177-52b1660b4733 -->
  <rule id="651949" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3613 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>