<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3733 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 4f144262-aa2c-5064-880e-357ff0d845fc -->
  <rule id="814426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3733 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>