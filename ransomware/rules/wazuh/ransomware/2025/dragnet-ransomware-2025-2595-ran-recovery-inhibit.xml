<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2595 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 356fdd0c-5fd8-534f-bbf8-9701f8100558 -->
  <rule id="662237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2595 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>