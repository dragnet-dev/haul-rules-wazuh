<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5648 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 5d3d64d1-1a4c-5fe2-8a46-3e80ba532af4 -->
  <rule id="694164" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5648 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>