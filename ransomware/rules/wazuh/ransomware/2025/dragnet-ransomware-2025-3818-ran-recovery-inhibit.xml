<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3818 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 3c39ff78-da81-542e-8b5d-2494623543bc -->
  <rule id="746239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3818 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>