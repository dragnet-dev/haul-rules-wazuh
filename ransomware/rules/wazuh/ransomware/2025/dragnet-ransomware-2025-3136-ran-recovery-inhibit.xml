<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3136 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 49f5f85b-6071-595b-8fcd-34e190f62841 -->
  <rule id="479358" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3136 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>