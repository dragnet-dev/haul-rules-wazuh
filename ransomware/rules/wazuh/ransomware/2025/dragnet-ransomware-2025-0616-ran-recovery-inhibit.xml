<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0616 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: cf35455c-cd46-53d2-8d30-66ef8b11a880 -->
  <rule id="373545" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0616 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>