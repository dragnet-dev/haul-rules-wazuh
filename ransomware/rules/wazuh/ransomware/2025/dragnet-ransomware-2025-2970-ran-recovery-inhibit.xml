<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2970 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: 2f3749bb-88f5-5271-beb1-8ccebb585a94 -->
  <rule id="479995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2970 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>