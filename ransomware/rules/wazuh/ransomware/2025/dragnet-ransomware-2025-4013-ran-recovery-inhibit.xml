<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4013 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 513bc63c-f51a-58a9-b9d6-3deb2012257f -->
  <rule id="515166" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4013 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>