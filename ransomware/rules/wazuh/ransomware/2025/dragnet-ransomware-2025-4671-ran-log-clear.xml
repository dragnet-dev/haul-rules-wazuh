<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4671 — Event Log Clearing (flocker) | Status: experimental | Sigma ID: 4f99354d-c235-56d6-b160-c38090e54e4d -->
  <rule id="899354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4671 — Event Log Clearing (flocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>