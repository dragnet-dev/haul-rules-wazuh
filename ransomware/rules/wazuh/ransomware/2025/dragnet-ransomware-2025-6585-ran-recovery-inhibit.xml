<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6585 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b285b396-ea18-500d-8f0e-6895d12fe276 -->
  <rule id="105713" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6585 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>