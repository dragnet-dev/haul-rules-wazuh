<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1291 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c5c22db6-6ed4-5f51-a58a-cdef93659600 -->
  <rule id="619565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1291 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>