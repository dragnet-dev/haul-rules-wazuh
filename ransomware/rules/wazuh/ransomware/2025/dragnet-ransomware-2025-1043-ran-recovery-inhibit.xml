<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1043 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 0a8836db-a6c3-5917-99e3-5010df193d80 -->
  <rule id="941389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1043 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>