<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7819 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: ebfe555b-97f1-5d61-b4e6-a3991e57d532 -->
  <rule id="741455" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7819 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>