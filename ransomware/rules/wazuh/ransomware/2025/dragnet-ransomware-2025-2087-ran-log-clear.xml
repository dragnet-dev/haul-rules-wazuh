<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2087 — Event Log Clearing (RunSomeWares) | Status: experimental | Sigma ID: 2e83ee11-0337-503e-ae5a-84d28c6a048b -->
  <rule id="399086" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2087 — Event Log Clearing (RunSomeWares)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>