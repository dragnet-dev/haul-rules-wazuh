<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1039 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 4046dc5b-7e24-56e7-83fb-18469b8c2bd0 -->
  <rule id="235996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1039 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>