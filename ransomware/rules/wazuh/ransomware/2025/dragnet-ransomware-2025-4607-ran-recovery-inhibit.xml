<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4607 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 8b89e189-2a2e-558f-a558-d1bff562fac2 -->
  <rule id="538381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4607 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>