<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4063 — Event Log Clearing (dragonforce) | Status: experimental | Sigma ID: f5a1de06-61b7-5a5e-b6f7-994d75ad6d53 -->
  <rule id="174878" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4063 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>