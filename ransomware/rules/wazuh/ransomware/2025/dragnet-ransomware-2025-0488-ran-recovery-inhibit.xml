<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0488 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 2db5b058-bceb-5c22-a966-3e17f4cebc13 -->
  <rule id="370510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0488 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>