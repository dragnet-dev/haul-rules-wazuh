<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1715 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: a55c86cf-4099-5d82-b002-35248ff017e6 -->
  <rule id="889286" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1715 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>