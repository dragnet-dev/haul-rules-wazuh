<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4209 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 27f33dd7-675a-5923-b813-4e839f5d525a -->
  <rule id="751869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4209 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>