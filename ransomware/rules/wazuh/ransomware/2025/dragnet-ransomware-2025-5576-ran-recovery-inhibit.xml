<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5576 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 52e9a833-3213-5f03-bbad-8ad3d8443457 -->
  <rule id="555148" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5576 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>