<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3326 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 576d4bc8-5884-5fb2-8cfd-e3a6cbec5262 -->
  <rule id="676715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3326 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>