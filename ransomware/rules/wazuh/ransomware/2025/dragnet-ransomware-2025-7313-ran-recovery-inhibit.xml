<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7313 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 302ec70b-7b0e-55bc-8e58-379f5e2d28c1 -->
  <rule id="654870" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7313 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>