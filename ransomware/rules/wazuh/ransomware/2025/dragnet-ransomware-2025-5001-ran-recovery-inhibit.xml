<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5001 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: fee54ef3-a676-5eb4-9bc0-1ffedaa9d817 -->
  <rule id="325678" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5001 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>