<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1361 — Event Log Clearing (hellcat) | Status: deprecated | Sigma ID: 43235f28-16a0-5d7e-ae00-447176589b24 -->
  <rule id="717752" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1361 — Event Log Clearing (hellcat)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>