<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1313 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2034800e-96e8-5898-b5ec-be770f89da58 -->
  <rule id="334800" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1313 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>