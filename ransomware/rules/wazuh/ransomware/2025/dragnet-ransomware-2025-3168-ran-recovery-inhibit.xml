<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3168 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 0854d66d-be9f-5f21-afb8-53c1c2469388 -->
  <rule id="567766" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3168 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>