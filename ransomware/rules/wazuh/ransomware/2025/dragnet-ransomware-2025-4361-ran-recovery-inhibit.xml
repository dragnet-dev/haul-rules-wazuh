<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4361 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: f150510e-4feb-5102-915e-0a0dffbcd377 -->
  <rule id="715051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4361 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>