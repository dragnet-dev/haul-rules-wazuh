<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4444 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 3cb8e0e9-3bed-59dd-8275-25b81efb655a -->
  <rule id="755020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4444 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>