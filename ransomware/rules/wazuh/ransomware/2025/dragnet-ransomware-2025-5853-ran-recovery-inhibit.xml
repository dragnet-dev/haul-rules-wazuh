<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5853 — Recovery Inhibition (gunra) | Status: experimental | Sigma ID: b9605b79-b925-5916-a9d0-ccfa3ce768f9 -->
  <rule id="213691" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5853 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>