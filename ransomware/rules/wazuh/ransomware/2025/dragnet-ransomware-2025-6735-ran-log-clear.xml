<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6735 — Event Log Clearing (cloak) | Status: deprecated | Sigma ID: 2e6cfa65-491c-50cd-93e1-832a5b7bc8e4 -->
  <rule id="212058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6735 — Event Log Clearing (cloak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>