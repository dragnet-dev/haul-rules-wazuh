<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1053 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 954d01ed-403b-58d8-bc20-6e27537a4705 -->
  <rule id="727701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1053 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>