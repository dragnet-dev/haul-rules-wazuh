<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0690 — Recovery Inhibition (weyhro) | Status: experimental | Sigma ID: 4ff82638-ef31-5742-9962-c392119e80dc -->
  <rule id="479826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0690 — Recovery Inhibition (weyhro)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>