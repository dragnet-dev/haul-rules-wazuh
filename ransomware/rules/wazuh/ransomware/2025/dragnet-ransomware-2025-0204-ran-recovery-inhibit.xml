<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0204 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: fb3dcc7d-4f5f-5725-b21c-804d15291fa8 -->
  <rule id="496780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0204 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>