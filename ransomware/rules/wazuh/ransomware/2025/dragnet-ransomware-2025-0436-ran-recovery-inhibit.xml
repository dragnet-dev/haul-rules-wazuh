<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0436 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 410b00f2-66fa-5c23-9c27-aa39442fa2aa -->
  <rule id="713615" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0436 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>