<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3975 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: f362c6da-5dd7-5dd8-a0dd-3949d45146a6 -->
  <rule id="758046" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3975 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>