<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1960 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 70d9c329-679a-55c3-bb91-f48af4cd0761 -->
  <rule id="114363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1960 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>