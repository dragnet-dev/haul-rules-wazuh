<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3921 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: e2d7e821-7367-5797-9b42-a3ce4c1ac810 -->
  <rule id="157268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3921 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>