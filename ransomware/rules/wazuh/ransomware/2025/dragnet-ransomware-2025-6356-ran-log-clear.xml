<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6356 — Event Log Clearing (pear) | Status: experimental | Sigma ID: 646a4b86-290f-59b1-93b3-92fcf73ba3c3 -->
  <rule id="855435" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6356 — Event Log Clearing (pear)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>