<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6761 — Recovery Inhibition (ralord) | Status: experimental | Sigma ID: 95d4caed-611a-5495-bd3d-7c3e1d4837b2 -->
  <rule id="425706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6761 — Recovery Inhibition (ralord)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>