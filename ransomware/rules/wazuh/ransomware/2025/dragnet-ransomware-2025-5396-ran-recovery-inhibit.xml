<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5396 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 8df30ea0-d84b-556c-966a-84973bb17052 -->
  <rule id="134094" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5396 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>