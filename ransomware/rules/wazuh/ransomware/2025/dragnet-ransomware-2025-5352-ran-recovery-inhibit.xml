<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5352 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: a02930d9-ad21-5010-9820-89ad349c2f95 -->
  <rule id="202930" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5352 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>