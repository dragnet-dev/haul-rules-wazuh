<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1014 — Recovery Inhibition (osiris) | Status: deprecated | Sigma ID: 32d356c5-41ab-5847-a87c-ffbefa174490 -->
  <rule id="405708" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1014 — Recovery Inhibition (osiris)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
