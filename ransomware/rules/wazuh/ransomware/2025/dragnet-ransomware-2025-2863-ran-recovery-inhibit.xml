<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2863 — Recovery Inhibition (GDLockerSec) | Status: experimental | Sigma ID: a9d47f13-6193-55fc-87bd-51bbeec9b6e7 -->
  <rule id="211967" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2863 — Recovery Inhibition (GDLockerSec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>