<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2371 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 984f1241-015b-5e1c-96c9-0fc128905ab8 -->
  <rule id="775912" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2371 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>