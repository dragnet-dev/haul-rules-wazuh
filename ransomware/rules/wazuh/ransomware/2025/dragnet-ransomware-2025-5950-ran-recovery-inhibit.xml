<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5950 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 16a38197-10a7-5c91-879b-6fbe1aa4bc19 -->
  <rule id="963819" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5950 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>