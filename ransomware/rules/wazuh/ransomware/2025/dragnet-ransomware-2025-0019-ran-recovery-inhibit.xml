<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0019 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6b9ac1c7-0927-5c39-8cd1-8aa53e1e3bef -->
  <rule id="163961" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0019 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>