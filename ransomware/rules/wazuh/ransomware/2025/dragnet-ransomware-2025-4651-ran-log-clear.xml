<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4651 — Event Log Clearing (stormous) | Status: deprecated | Sigma ID: 41b79e2e-e66b-59e3-8b8a-cd5e8f31ff69 -->
  <rule id="268478" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4651 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>