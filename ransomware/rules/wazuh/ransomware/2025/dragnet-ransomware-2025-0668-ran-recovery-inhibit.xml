<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0668 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 0d7781eb-4740-55a3-ba8d-d20e213ea023 -->
  <rule id="504510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0668 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>