<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7697 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: add64556-eb23-5b84-89ad-973ed9254544 -->
  <rule id="181645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7697 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>