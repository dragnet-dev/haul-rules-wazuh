<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3574 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 18baa832-df7f-5d48-9246-4aad6a70be9d -->
  <rule id="571483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3574 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>