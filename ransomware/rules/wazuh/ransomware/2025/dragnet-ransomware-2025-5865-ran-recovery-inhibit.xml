<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5865 — Recovery Inhibition (play) | Status: experimental | Sigma ID: bdf9fe6b-276d-5870-9e4e-6683f753ef52 -->
  <rule id="682398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5865 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>