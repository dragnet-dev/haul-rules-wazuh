<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0525 — Event Log Clearing (global) | Status: deprecated | Sigma ID: 2d96cd14-bd84-5c5e-8fb3-d2a413f9ad1e -->
  <rule id="376781" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0525 — Event Log Clearing (global)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>