<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0594 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: ee8fcc97-d584-5c99-8062-948bfaa1f959 -->
  <rule id="885292" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0594 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>