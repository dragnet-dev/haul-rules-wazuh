<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5198 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 2c1e2d68-6740-5020-b41a-f144d305c46e -->
  <rule id="331245" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5198 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>