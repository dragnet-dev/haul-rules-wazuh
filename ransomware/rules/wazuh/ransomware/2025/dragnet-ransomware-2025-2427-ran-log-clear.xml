<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2427 — Event Log Clearing (thegentlemen) | Status: experimental | Sigma ID: 23b9d669-4d6a-5e19-81ae-ae5fe6e5b38b -->
  <rule id="779766" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2427 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>