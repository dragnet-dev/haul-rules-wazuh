<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7078 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 4154bc3f-a6ef-5c06-a3ab-2e0fb3fd6f81 -->
  <rule id="263612" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7078 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>