<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0746 — Recovery Inhibition (tridentlocker) | Status: experimental | Sigma ID: e5646d67-dd7f-5cf1-9d6b-256702abce2f -->
  <rule id="630349" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0746 — Recovery Inhibition (tridentlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>