<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0041 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a8ccf3a3-a162-55cf-96a6-fd53290847d0 -->
  <rule id="956473" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0041 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>