<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7922 — Recovery Inhibition (ransomhouse) | Status: test | Sigma ID: 667582a8-3e99-5272-8742-7fcd24757174 -->
  <rule id="881322" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7922 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>