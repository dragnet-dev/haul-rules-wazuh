<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6262 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1e27c05a-3839-5698-b061-c9ab5773b9f5 -->
  <rule id="444405" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6262 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>