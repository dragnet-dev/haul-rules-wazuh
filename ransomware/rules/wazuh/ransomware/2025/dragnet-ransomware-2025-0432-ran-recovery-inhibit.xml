<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0432 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: c1bd3b8e-2b98-5886-92d7-f6e68bc9aab9 -->
  <rule id="586459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0432 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>