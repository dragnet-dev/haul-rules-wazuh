<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2425 — Recovery Inhibition (thegentlemen) | Status: experimental | Sigma ID: 520dec41-89cd-5124-8ce8-382259b03a02 -->
  <rule id="433484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2425 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>