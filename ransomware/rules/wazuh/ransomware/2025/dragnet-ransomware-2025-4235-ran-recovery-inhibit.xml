<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4235 — Recovery Inhibition (obscura) | Status: experimental | Sigma ID: 56d38929-5055-594c-9b9d-e70f7d34cc9b -->
  <rule id="193892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4235 — Recovery Inhibition (obscura)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>