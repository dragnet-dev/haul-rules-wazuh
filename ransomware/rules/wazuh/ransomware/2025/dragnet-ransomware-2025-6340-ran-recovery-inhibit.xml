<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6340 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: f102f8d9-9142-5685-885d-da4f7c7be455 -->
  <rule id="716478" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6340 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>