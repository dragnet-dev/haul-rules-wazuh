<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7890 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 58a25732-06a5-5746-9a1a-fd7c56912f05 -->
  <rule id="482573" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7890 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>