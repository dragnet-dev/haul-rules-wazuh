<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3650 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 484d72bc-6332-5678-9f20-d7a4b6949020 -->
  <rule id="812363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3650 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>