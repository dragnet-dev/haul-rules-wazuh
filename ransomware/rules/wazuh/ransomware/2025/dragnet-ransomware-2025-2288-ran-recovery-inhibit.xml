<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2288 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 099645fd-dcc1-5ffc-9f73-efa2a920e56f -->
  <rule id="794335" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2288 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>