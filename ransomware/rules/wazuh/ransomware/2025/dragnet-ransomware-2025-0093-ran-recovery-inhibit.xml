<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0093 — Recovery Inhibition (play) | Status: experimental | Sigma ID: dae7bf78-3659-5e3d-bc62-53f039c2190f -->
  <rule id="967103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0093 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>