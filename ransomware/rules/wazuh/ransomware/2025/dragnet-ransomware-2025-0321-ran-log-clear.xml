<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0321 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: cc4baafa-5e98-5e4b-ab00-3b9713dd0f2b -->
  <rule id="375210" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0321 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>