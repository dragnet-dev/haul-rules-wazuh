<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5890 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 26357818-9235-5c49-b5e9-a0dacb87195f -->
  <rule id="935781" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5890 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>