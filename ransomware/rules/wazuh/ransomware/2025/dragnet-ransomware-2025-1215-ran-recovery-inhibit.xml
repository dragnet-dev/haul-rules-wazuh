<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1215 — Recovery Inhibition (yurei) | Status: experimental | Sigma ID: e6b17247-c5da-524f-b0a9-b63026de4281 -->
  <rule id="647172" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1215 — Recovery Inhibition (yurei)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>