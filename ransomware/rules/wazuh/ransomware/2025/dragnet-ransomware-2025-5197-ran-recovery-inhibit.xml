<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5197 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 54d07fcc-0586-58db-a402-29ccaa628296 -->
  <rule id="603327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5197 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>