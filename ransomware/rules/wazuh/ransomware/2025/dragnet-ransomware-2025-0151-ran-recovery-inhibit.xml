<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0151 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d4dee297-e8f6-5a64-b647-4b27d8bbade0 -->
  <rule id="224302" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0151 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>