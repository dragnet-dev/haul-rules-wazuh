<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4309 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 4127690f-a850-5930-a00e-1adb27fe7e0a -->
  <rule id="627690" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4309 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>