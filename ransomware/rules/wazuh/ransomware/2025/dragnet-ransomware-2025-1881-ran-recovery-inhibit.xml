<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1881 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 015162ee-a3da-5f5e-8871-ad1d710babaa -->
  <rule id="381710" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1881 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>