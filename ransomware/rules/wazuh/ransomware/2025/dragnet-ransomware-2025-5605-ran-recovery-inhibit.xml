<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5605 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 671e3fbe-9206-53a2-bd5d-2916935ec80b -->
  <rule id="920063" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5605 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>