<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2279 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 2fa062fe-2e24-5bac-8c8f-9d95aaf11cdf -->
  <rule id="593007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2279 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>