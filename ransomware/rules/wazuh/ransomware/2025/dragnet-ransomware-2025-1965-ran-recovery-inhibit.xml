<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1965 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 03cc3cd7-9551-5012-b363-2ee4d7a8639a -->
  <rule id="789293" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1965 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>