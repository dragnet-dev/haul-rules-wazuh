<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6780 — Event Log Clearing (d4rk4rmy) | Status: deprecated | Sigma ID: 52d1ebfd-bc68-5b8e-8af4-9f213b664c4b -->
  <rule id="463691" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6780 — Event Log Clearing (d4rk4rmy)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>