<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5972 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: c58c073a-6912-5d8a-b441-b0f9774048ad -->
  <rule id="314007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5972 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>