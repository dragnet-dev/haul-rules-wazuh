<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4660 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: b21e234b-c43a-5630-9912-045a45961451 -->
  <rule id="995023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4660 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>