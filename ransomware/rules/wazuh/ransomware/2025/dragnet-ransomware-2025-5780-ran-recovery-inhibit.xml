<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5780 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 395e7c3b-df1d-5546-b60a-41a38d9e4a83 -->
  <rule id="213564" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5780 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>