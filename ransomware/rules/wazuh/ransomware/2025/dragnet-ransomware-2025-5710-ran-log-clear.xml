<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5710 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 29afb0a7-654f-5fe5-aa1c-a2422bc623a7 -->
  <rule id="415950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5710 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>