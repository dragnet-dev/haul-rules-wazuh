<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3866 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7b6247af-5c1f-52ba-9f5c-f0adffcb6910 -->
  <rule id="436247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3866 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>