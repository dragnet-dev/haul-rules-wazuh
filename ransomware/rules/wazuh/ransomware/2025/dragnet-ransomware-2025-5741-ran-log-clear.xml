<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5741 — Event Log Clearing (direwolf) | Status: experimental | Sigma ID: 65acaaaa-c97e-528b-b4c4-be5c57c5aab8 -->
  <rule id="804042" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5741 — Event Log Clearing (direwolf)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>