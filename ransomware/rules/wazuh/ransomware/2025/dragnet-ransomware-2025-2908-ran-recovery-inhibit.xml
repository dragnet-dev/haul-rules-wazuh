<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2908 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 8241db30-afe7-5482-ac88-3cd64dbda942 -->
  <rule id="409915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2908 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>