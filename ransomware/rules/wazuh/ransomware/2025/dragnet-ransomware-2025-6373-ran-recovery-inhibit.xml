<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6373 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 47aa9328-2478-5b6a-8913-c08b974f25f6 -->
  <rule id="420293" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6373 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>