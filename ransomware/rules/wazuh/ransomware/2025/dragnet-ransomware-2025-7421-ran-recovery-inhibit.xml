<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7421 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 1d53f98a-ac23-5425-acbf-580cc7eba2a5 -->
  <rule id="326398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7421 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>