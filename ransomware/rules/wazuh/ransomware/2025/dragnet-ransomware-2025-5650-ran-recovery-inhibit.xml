<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5650 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: e6fe51b1-5c73-51ba-9b9a-fdba440988a3 -->
  <rule id="263051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5650 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>