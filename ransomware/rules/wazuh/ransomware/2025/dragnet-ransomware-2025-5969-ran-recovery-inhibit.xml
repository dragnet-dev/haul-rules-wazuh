<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5969 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: f45be597-ab76-5d4c-b5ff-277468e432a4 -->
  <rule id="457105" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5969 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>