<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5642 — Event Log Clearing (flocker) | Status: experimental | Sigma ID: 6bff40f6-1ff3-59fb-a39b-8e6a0a1b1d03 -->
  <rule id="164740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5642 — Event Log Clearing (flocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>