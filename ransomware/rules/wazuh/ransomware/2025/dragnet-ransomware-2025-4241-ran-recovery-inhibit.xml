<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4241 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 575866ce-63ef-584c-b125-d46acaf3c13e -->
  <rule id="313868" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4241 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>