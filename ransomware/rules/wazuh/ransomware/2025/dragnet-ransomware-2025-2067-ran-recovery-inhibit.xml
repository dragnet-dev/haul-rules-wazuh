<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2067 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: 01bc694d-b65f-51c2-8615-1457bd318663 -->
  <rule id="915117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2067 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>