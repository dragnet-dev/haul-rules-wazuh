<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3353 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: f19827a4-62de-52e3-aa5d-e8f3ec0bb7f3 -->
  <rule id="719827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3353 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>