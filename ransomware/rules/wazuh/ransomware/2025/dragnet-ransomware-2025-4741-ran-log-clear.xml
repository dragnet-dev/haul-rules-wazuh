<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4741 — Event Log Clearing (radiant) | Status: deprecated | Sigma ID: b1aa025f-23e5-520e-a3fd-7ec4d9d8a0cd -->
  <rule id="258602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4741 — Event Log Clearing (radiant)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>