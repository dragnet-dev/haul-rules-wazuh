<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5080 — Event Log Clearing (rhysida) | Status: experimental | Sigma ID: 9e8da9b3-3222-5ae5-9dbb-9c57cc4b5d4d -->
  <rule id="567469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5080 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>