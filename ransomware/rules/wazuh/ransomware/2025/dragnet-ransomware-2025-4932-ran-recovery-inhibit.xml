<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4932 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4f07d773-7c23-53de-bc44-846e70432b86 -->
  <rule id="465257" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4932 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>