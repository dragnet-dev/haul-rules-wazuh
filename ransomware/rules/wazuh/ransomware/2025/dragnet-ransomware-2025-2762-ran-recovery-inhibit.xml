<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2762 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: fa2f065e-14ce-5fbe-bc7f-a7ae6e6664a8 -->
  <rule id="504706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2762 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>