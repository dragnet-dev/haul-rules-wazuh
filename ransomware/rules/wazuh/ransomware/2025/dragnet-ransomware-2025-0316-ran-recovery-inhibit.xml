<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0316 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: f05fa9dc-e996-5c31-b6a8-7c01a2100342 -->
  <rule id="355309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0316 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>