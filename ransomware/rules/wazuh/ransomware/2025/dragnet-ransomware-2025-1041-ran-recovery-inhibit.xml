<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1041 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 38faa4a5-f5d6-5e07-9b8b-428bc77d6b46 -->
  <rule id="796584" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1041 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>