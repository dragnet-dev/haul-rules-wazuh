<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0171 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 400123f8-c0e7-523b-bee9-168ba9fe68a5 -->
  <rule id="201983" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0171 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>