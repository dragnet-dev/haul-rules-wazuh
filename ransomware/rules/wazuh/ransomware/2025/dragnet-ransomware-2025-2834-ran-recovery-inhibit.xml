<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2834 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: b0a241b6-560e-582b-9c4f-c3b56a503925 -->
  <rule id="970241" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2834 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>