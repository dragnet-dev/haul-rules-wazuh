<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3298 — Recovery Inhibition (embargo) | Status: experimental | Sigma ID: 446ce881-3b1e-5288-b81c-550a999a0ac3 -->
  <rule id="343828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3298 — Recovery Inhibition (embargo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>