<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0974 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: bdcf87f7-185e-519c-b5e2-4b93f17cd241 -->
  <rule id="459187" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0974 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>