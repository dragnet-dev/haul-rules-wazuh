<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1786 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 4b551e90-bfeb-5462-a565-32b3e4d5fba0 -->
  <rule id="408830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1786 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>