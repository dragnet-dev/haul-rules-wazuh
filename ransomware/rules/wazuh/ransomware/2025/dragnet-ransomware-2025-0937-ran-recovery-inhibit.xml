<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0937 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: f101108b-9665-5332-aed9-6a2aa52f92b7 -->
  <rule id="710110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0937 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>