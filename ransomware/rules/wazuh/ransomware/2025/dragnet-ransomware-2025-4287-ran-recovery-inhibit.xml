<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4287 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 301f2156-402d-54e2-9eb8-c8d9887fbcb5 -->
  <rule id="431215" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4287 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>