<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6745 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 31e949db-9fec-5f59-8030-a2611aea64fa -->
  <rule id="175197" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6745 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>