<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0513 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: 2dc0f8e2-8b2f-5d50-98b3-dde67f9f35c9 -->
  <rule id="371358" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0513 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>