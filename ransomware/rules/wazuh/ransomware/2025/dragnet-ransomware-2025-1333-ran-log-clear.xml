<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1333 — Event Log Clearing (blackshrantac) | Status: test | Sigma ID: a8732683-ce84-5b81-8313-62516020e650 -->
  <rule id="287326" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1333 — Event Log Clearing (blackshrantac)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>