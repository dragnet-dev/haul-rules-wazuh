<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6170 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7e84f8f0-d8bb-5e73-b534-a504334b349c -->
  <rule id="329598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6170 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>