<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1390 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d954cf3c-590d-5bac-aca7-9378ecdf7917 -->
  <rule id="972431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1390 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>