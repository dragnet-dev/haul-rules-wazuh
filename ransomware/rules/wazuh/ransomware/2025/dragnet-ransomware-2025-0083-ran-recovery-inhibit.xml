<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0083 — Recovery Inhibition (ransomhouse) | Status: test | Sigma ID: 9cb71206-1dd5-5c09-b682-7f08bd6af5ae -->
  <rule id="807712" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0083 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>