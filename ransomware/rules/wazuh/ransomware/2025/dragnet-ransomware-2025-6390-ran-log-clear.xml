<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6390 — Event Log Clearing (fog) | Status: experimental | Sigma ID: dcb6033b-ca1b-552a-879d-70e6168ee0c9 -->
  <rule id="931603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6390 — Event Log Clearing (fog)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>