<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5805 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 20ef6aed-b53f-576f-b0b7-4fd4f8425dd1 -->
  <rule id="320750" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5805 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>