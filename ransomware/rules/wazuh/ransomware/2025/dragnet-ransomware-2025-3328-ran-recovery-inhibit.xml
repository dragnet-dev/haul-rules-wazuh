<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3328 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: afc7540c-c71f-5ee6-8e2e-5f64e261e305 -->
  <rule id="212754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3328 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>