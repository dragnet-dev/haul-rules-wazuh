<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4670 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 05e70299-3b70-5778-a0f9-b41bc382fd6e -->
  <rule id="570299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4670 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>