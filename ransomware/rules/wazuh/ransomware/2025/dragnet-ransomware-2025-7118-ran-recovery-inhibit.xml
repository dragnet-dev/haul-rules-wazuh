<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7118 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 2168dc19-133f-5d5f-a283-f2c1d2993752 -->
  <rule id="252281" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7118 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>