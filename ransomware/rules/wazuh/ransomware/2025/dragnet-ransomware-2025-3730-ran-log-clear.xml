<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3730 — Event Log Clearing (clop) | Status: deprecated | Sigma ID: e1afe2f8-bdc8-520c-be78-af0b9c3ef5e4 -->
  <rule id="503502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3730 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>