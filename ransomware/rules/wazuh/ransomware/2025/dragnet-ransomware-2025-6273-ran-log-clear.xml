<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6273 — Event Log Clearing (BrainCipher) | Status: experimental | Sigma ID: 237a013d-90c4-5fd4-b9d9-14ff95f9a8ed -->
  <rule id="302013" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6273 — Event Log Clearing (BrainCipher)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>