<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4749 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: f2bda95c-8fae-59ae-aa33-ddd26b2546bb -->
  <rule id="956269" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4749 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>