<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5013 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: c0d98260-43b8-5429-a5ec-1fe908882284 -->
  <rule id="233982" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5013 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>