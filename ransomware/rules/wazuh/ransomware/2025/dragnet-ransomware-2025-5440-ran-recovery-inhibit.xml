<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5440 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2e7f889e-6296-5457-9d5a-646647ec3e67 -->
  <rule id="387889" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5440 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>