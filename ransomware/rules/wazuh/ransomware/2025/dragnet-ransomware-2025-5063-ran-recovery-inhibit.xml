<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5063 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: e5f66f5c-028f-5e74-a168-fa5b6766c77c -->
  <rule id="237071" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5063 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>