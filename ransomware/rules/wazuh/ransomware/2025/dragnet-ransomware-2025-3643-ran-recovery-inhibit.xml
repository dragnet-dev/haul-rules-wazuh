<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3643 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 5f5c1a77-fe53-5661-bfbe-4b2a6e32afb1 -->
  <rule id="746746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3643 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>