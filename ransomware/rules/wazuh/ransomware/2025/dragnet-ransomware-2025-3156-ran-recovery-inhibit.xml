<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3156 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: c70d2178-367d-5dd1-84e1-c53edf8624f1 -->
  <rule id="333321" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3156 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>