<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3246 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 9a2cd3e4-825c-5de6-92a0-40636d6635f6 -->
  <rule id="449573" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3246 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>