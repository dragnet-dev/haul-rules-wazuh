<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4210 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 1dc432a8-9780-5d90-97e7-ed16ae9fbdba -->
  <rule id="522922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4210 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>