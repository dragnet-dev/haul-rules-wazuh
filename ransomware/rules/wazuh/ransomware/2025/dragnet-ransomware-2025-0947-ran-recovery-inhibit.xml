<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0947 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: ecadbd46-79d5-5215-bd0a-3e0fb61325aa -->
  <rule id="310973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0947 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>