<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2742 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 82659f5f-0b58-5780-abf3-9914bee8e0ad -->
  <rule id="522559" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2742 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>