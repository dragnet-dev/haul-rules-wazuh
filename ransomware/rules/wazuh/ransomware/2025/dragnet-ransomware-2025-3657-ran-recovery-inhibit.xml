<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3657 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: fd39f925-d045-525e-b931-fec9311ae4cf -->
  <rule id="554399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3657 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>