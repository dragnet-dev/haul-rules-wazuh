<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1700 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0384a6db-541b-5e87-96b6-40f84d6ea5b1 -->
  <rule id="555995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1700 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>