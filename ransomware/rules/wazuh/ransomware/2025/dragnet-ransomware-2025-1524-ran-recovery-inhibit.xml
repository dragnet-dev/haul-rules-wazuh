<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1524 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 48a4fe88-d51d-542b-ae57-8e403b863f41 -->
  <rule id="292958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1524 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>