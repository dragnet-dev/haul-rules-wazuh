<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4556 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: a586e9c0-f8b5-568e-ad22-cb60bcfdf7bc -->
  <rule id="893909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4556 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>