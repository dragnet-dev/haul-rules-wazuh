<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0154 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 42c53ad7-b400-593c-a0fc-a79bb031bb68 -->
  <rule id="295258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0154 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>