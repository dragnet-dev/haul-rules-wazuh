<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1305 — Recovery Inhibition (qilin) | Status: test | Sigma ID: ddebd2cb-84fe-5607-9135-19714ebb45f2 -->
  <rule id="189892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1305 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>