<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5453 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 292e7892-52af-584b-a02a-f9e26faa8383 -->
  <rule id="286789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5453 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>