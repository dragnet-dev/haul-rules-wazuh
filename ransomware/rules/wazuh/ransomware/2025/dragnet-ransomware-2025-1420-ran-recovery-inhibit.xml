<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1420 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 67270995-baf4-5751-ba28-682b8de97598 -->
  <rule id="527099" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1420 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>