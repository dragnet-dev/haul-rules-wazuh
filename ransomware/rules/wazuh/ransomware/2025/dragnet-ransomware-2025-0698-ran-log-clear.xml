<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0698 — Event Log Clearing (play) | Status: experimental | Sigma ID: 2cd3d7b9-d1c4-5f5d-a1a5-5f904accc223 -->
  <rule id="347817" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0698 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>