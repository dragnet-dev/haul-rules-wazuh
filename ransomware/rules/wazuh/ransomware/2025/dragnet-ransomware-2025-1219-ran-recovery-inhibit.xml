<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1219 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6ba2498d-b317-57c0-a6ca-34a030c1134b -->
  <rule id="922249" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1219 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>