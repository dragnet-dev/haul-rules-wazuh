<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1262 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 44ed9c76-e44d-5e29-a45e-191f2def01e1 -->
  <rule id="140316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1262 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>