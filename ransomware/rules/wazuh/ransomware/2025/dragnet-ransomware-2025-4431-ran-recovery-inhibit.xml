<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4431 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: ebbe0568-3021-5cbc-b5da-4e903767f830 -->
  <rule id="735005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4431 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>