<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2047 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 845b002c-b810-53ff-bcf8-a03dcf632a24 -->
  <rule id="553100" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2047 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>