<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1580 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 08ad9d2c-3ce2-5b48-b607-6a5b8e296882 -->
  <rule id="955172" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1580 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>