<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4501 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: a17c3eea-db8c-5c0b-9fc9-081a5f317ec0 -->
  <rule id="905502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4501 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>