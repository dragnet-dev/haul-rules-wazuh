<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0802 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: af901b43-e190-5345-97e7-b959684b0017 -->
  <rule id="214427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0802 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>