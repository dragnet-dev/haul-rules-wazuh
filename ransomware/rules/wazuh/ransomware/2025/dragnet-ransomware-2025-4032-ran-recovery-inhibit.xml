<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4032 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 448351eb-c323-5bae-94e7-77e0bb85159b -->
  <rule id="973630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4032 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>