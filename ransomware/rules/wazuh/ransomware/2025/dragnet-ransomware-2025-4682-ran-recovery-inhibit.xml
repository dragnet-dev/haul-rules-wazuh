<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4682 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 91a3885a-8fa3-53a4-a582-7794d81d90c7 -->
  <rule id="666388" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4682 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>