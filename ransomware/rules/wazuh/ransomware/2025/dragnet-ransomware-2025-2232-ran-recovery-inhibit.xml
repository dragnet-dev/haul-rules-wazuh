<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2232 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: bbccb5c3-d4a0-5031-9339-fcf5f0a8e58d -->
  <rule id="592275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2232 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>