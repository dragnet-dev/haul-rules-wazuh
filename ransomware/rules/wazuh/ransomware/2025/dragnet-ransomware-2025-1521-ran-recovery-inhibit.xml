<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1521 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 3c3082db-9d69-5741-b512-ac978ccf1b8a -->
  <rule id="749325" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1521 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>