<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7196 — Event Log Clearing (desolator) | Status: experimental | Sigma ID: cab9e6fc-a79c-5969-92ff-c74aa481f6ec -->
  <rule id="790386" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7196 — Event Log Clearing (desolator)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>