<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4899 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 57cec665-61ca-5ca7-8233-6e3760ab38fc -->
  <rule id="667806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4899 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>