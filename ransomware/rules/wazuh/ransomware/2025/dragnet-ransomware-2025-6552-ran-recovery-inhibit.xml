<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6552 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 45efa0da-c08a-5cd1-9927-8c41e061bc83 -->
  <rule id="181540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6552 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>