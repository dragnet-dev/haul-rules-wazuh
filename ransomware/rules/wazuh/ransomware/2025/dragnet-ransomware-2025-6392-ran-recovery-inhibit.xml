<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6392 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 8f2cff3f-ed30-5d77-870c-a03b61712336 -->
  <rule id="568799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6392 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>