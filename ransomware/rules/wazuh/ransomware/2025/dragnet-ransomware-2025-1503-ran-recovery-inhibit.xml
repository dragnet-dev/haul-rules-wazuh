<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1503 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c05265d5-287c-59bd-bc3a-e796c2e16275 -->
  <rule id="405265" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1503 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>