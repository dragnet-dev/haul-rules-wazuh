<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1536 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 992e6760-773c-585c-9c5d-748e5d468c4a -->
  <rule id="788667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1536 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>