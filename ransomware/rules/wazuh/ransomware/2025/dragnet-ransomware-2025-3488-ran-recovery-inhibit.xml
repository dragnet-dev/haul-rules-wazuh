<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3488 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 385bdcb5-0ce9-5d72-9f5f-b612296212c1 -->
  <rule id="779996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3488 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>