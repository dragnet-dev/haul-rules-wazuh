<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0381 — Event Log Clearing (worldleaks) | Status: experimental | Sigma ID: 50498545-20c8-5af3-9991-8ec934693049 -->
  <rule id="649854" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0381 — Event Log Clearing (worldleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>