<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3483 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 88ce7a76-9014-5411-918f-eb0e1413c142 -->
  <rule id="137562" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3483 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>