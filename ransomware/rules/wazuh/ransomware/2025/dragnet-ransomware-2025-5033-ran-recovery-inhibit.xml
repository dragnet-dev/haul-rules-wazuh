<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5033 — Recovery Inhibition (trinity) | Status: experimental | Sigma ID: d973a785-bb1b-5d55-b1d8-f6852b5b47e5 -->
  <rule id="535787" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5033 — Recovery Inhibition (trinity)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
