<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5527 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: b8a12541-327d-5f35-a27a-0e2bc41691cd -->
  <rule id="198125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5527 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>