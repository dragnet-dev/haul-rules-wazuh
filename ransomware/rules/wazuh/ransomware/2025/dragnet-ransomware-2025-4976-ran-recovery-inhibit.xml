<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4976 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: c0b0ccdf-806d-5ec6-8bb7-3955bf206689 -->
  <rule id="543564" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4976 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>