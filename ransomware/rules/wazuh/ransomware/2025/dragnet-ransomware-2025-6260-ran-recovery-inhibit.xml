<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6260 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: b34bf6e4-cc54-5144-9b01-424be0222ec9 -->
  <rule id="304956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6260 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>