<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1762 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 3fa458eb-dc48-5f13-9743-9b44d1673db3 -->
  <rule id="218458" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1762 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>