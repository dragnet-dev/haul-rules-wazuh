<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0042 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: e9581cb3-1710-5008-94c4-05184a7c09fb -->
  <rule id="693308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0042 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>