<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7610 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 993d3bb8-bce9-5f74-bd97-85ecda2ed0d8 -->
  <rule id="844219" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7610 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>