<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2509 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 30615883-42a6-5c7f-a603-bc9dcd854b96 -->
  <rule id="461588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2509 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>