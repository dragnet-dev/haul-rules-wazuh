<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3425 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 68ecc94e-4dc8-5a08-84b3-8b47c829847c -->
  <rule id="223169" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3425 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>