<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3684 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3748bc23-de9f-557c-8095-90b18a0038ae -->
  <rule id="696762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3684 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>