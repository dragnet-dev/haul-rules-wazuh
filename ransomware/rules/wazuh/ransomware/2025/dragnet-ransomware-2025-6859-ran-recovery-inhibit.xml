<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6859 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: b09858a4-c272-5729-a3e3-59fb3e140278 -->
  <rule id="309858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6859 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>