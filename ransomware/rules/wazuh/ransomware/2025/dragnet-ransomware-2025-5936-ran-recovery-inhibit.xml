<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5936 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4bc7b75a-bb75-54c1-b5fc-71cad03c6144 -->
  <rule id="240437" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5936 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>