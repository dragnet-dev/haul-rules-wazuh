<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0983 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: a7255002-5f09-51e9-ad0f-88512d45f46d -->
  <rule id="272550" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0983 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>