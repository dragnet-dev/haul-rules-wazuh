<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6878 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 46d9543f-e749-5963-b1aa-593966a3ccd2 -->
  <rule id="399543" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6878 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>