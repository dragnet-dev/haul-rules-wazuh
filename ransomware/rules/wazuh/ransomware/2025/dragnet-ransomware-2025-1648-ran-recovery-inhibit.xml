<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1648 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 2dc05f7a-9471-5b0d-9863-b306fd05e9d8 -->
  <rule id="371295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1648 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>