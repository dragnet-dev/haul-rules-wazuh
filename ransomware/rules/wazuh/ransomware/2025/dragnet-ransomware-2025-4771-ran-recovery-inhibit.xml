<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4771 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f40ff3fd-a64f-55ae-b1ee-46c097a1eeb2 -->
  <rule id="444953" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4771 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>