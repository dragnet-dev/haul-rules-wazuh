<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2837 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 0ce37490-744c-55ef-aa86-1249392b3658 -->
  <rule id="363749" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2837 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>