<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1045 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 9cd3095d-228e-5d4b-bbe3-90242f07f867 -->
  <rule id="809309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1045 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>