<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4275 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: 8bc26ed7-4209-5b0e-8f62-804925f1a0ab -->
  <rule id="978030" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4275 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>