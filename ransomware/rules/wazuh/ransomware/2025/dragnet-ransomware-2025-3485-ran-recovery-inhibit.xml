<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3485 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 95c0c359-2b6d-570c-9e4e-490d11b44631 -->
  <rule id="751323" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3485 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>