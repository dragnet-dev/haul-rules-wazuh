<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2386 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: ea4c406f-b193-5a23-95e9-45ab10124f7e -->
  <rule id="251640" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2386 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>