<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4649 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: 0980d742-047b-506f-86ab-a371675ce55c -->
  <rule id="769374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4649 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>