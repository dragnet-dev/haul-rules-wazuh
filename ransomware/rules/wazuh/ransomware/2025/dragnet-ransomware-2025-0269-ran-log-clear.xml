<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0269 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 68dc5fd7-a759-5c48-81c1-6f0de3e46ab3 -->
  <rule id="220575" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0269 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>