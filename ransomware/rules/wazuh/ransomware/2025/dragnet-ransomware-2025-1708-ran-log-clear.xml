<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1708 — Event Log Clearing (yurei) | Status: experimental | Sigma ID: f45124f3-17e4-5db3-b475-467fdc265218 -->
  <rule id="745124" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1708 — Event Log Clearing (yurei)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>