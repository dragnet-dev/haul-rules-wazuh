<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1216 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 5b7f1557-de93-584b-8376-b851a4619322 -->
  <rule id="668715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1216 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>