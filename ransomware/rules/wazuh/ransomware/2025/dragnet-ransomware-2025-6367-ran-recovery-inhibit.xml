<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6367 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: c4c687d9-190a-50ca-9b0c-6752064f7627 -->
  <rule id="296687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6367 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>