<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3237 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c2ec50a4-721d-50f7-a12f-d5afd0f14284 -->
  <rule id="546850" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3237 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>