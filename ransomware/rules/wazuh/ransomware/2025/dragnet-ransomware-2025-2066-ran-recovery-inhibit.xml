<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2066 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: cea3de36-a54c-5aa3-98f0-132e80ac4c31 -->
  <rule id="464350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2066 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>