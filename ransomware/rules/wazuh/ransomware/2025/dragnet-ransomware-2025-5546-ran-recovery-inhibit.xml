<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5546 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ca0423aa-a699-5d2b-8c0f-88343b14ca02 -->
  <rule id="320423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5546 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>