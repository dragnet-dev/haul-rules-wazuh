<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4664 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: e74dfabb-6bfa-58b1-aca1-d1aa9837fa4e -->
  <rule id="741082" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4664 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>