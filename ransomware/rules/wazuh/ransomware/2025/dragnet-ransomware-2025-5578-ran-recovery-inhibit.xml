<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5578 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 3e3ad551-50d4-536d-8f46-c7ffd08236b7 -->
  <rule id="796615" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5578 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>