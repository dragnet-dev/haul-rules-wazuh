<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4186 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: 39b71252-6650-5bac-836d-219912400a3f -->
  <rule id="157125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4186 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>