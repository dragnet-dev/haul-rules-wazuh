<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7612 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 0721228e-a206-52cb-a982-e9cc0d7fc194 -->
  <rule id="839662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7612 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>