<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7030 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 157bba20-9b45-57c3-af03-df051da2f3c4 -->
  <rule id="260742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7030 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>