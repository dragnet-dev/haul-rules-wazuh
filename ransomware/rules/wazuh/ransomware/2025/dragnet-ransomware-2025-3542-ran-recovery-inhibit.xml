<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3542 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 23bc2287-5fb2-5c8f-ad90-434f2f98671a -->
  <rule id="776228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3542 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>