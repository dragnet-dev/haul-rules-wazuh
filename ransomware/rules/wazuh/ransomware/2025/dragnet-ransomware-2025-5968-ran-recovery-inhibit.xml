<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5968 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 00da9859-a408-52ba-8d40-3cc058146dda -->
  <rule id="489859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5968 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>