<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3301 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ef6759f1-e8d5-5a7b-9117-6ca05a58137c -->
  <rule id="696759" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3301 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>