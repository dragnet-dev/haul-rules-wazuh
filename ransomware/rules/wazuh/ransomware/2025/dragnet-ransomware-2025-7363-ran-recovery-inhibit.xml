<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7363 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b798e2be-baa5-51f9-8e55-18530a9f89b3 -->
  <rule id="187822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7363 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>