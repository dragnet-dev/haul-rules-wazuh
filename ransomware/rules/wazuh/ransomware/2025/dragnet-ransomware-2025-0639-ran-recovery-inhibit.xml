<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0639 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: fba409fa-7273-5e96-8bbf-fe88c560b9bb -->
  <rule id="526409" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0639 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>