<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1575 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: c6878c87-f3c2-5211-9b13-44a2fde9de89 -->
  <rule id="330060" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1575 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>