<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5421 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 718663ce-5cb4-54b7-b1fe-d9ca723aa5a5 -->
  <rule id="798620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5421 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>