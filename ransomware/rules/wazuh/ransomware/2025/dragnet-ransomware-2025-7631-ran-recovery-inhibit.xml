<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7631 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: ec79c278-f5dc-51b4-805a-fa5c69f9ce02 -->
  <rule id="288762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7631 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>