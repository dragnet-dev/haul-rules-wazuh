<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3073 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4c7262ae-0274-515d-9b2a-9cea68248e0e -->
  <rule id="676202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3073 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>