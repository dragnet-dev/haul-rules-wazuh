<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4764 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 97868060-3217-5a2e-b416-018138c785f2 -->
  <rule id="886806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4764 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>