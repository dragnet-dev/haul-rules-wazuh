<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4748 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: a4aeabaa-ebe1-5d81-be83-289d0d60dd95 -->
  <rule id="660459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4748 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>