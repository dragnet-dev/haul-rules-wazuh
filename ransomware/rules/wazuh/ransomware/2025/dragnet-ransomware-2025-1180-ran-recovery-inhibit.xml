<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1180 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 7a248aa1-f58e-5453-b18b-083d59e432c3 -->
  <rule id="255978" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1180 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>