<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1834 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: e988b160-c2db-51a0-854e-b3b354da319c -->
  <rule id="698191" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1834 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>