<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3362 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f83cbf2e-597e-5ce6-ac34-cd5db76554ee -->
  <rule id="287231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3362 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>