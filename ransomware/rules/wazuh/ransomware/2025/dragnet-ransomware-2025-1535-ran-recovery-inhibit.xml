<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1535 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 4fbe2ea2-0e10-5280-be65-ac8c19d238a8 -->
  <rule id="666286" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1535 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>