<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3536 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 39b6ac2e-4f17-554f-a08d-09d5e39d14b1 -->
  <rule id="827308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3536 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>