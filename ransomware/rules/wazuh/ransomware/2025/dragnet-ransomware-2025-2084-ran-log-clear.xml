<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2084 — Event Log Clearing (shinyhunters) | Status: deprecated | Sigma ID: 972d6c29-f4fd-571b-a7a6-d910d2f39ba4 -->
  <rule id="790508" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2084 — Event Log Clearing (shinyhunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>