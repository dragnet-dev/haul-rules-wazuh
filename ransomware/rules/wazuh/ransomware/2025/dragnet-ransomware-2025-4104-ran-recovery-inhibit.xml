<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4104 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 842abd45-2812-5b67-8a06-2a02b7adcc3d -->
  <rule id="851581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4104 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>