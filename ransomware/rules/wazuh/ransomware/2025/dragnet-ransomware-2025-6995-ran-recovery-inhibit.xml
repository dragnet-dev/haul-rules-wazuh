<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6995 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c9ab76d3-94f4-5260-a69a-3e21fc82e147 -->
  <rule id="719576" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6995 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>