<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2270 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 78ae3435-7559-5962-9703-2c698b8c44a0 -->
  <rule id="314234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2270 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>