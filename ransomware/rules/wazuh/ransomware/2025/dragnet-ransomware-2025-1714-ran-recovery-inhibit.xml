<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1714 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 49a2e9e5-5ad2-5d34-9f50-61844e465c43 -->
  <rule id="470869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1714 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>