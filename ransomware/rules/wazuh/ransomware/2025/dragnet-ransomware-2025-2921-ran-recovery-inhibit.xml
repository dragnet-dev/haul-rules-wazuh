<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2921 — Recovery Inhibition (lynx) | Status: test | Sigma ID: 3e92351f-53ff-599d-a46c-f394077b1c76 -->
  <rule id="992351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2921 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>