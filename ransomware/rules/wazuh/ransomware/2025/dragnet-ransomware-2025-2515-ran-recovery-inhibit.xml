<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2515 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 43e8df2f-b984-5fc7-83de-bfd04970b04a -->
  <rule id="999391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2515 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>