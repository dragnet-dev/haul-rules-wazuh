<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6163 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: df746363-5aba-5ce7-aa29-9db251318cc9 -->
  <rule id="537463" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6163 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>