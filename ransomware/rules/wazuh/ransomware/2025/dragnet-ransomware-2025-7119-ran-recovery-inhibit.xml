<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7119 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 991607c0-6248-5d7a-85e9-882d41b54ed8 -->
  <rule id="665724" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7119 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>