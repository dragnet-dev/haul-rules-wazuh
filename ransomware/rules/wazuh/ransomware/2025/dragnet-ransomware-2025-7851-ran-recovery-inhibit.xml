<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7851 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: da86089e-3a7c-554b-9080-87b9887819ea -->
  <rule id="488608" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7851 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>