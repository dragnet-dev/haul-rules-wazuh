<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7845 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 45b3f909-6095-5112-b08e-9669398f25df -->
  <rule id="370239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7845 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>