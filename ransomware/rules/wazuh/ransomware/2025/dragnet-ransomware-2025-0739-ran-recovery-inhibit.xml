<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0739 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: 616d8e7e-13fc-5e2a-ad31-358b488fad68 -->
  <rule id="779182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0739 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>