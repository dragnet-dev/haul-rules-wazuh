<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3569 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8231b16a-083c-5f05-9989-f5809ec88b4d -->
  <rule id="517071" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3569 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>