<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3828 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d2f25eb9-7658-551e-bc02-126c4806ab7c -->
  <rule id="803614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3828 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>