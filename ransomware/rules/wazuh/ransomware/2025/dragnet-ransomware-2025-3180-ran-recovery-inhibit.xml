<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3180 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: ac0221a3-15a8-501c-b732-0b2651c2299d -->
  <rule id="920221" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3180 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>