<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0866 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: ba377785-d2da-586d-a714-94c8b5018e5a -->
  <rule id="163777" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0866 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>