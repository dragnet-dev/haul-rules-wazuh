<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6504 — Event Log Clearing (hunters) | Status: experimental | Sigma ID: 2414c5c2-6629-5a4e-bb01-1c30dbf3ea16 -->
  <rule id="881852" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6504 — Event Log Clearing (hunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>