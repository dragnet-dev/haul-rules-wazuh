<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6578 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: d16c467f-f32c-5d01-820d-79adda06e562 -->
  <rule id="406846" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6578 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>