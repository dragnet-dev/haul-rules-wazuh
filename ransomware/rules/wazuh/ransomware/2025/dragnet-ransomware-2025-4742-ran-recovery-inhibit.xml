<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4742 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: cdc99871-b6f6-58fe-9259-9812e038f27d -->
  <rule id="692998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4742 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>