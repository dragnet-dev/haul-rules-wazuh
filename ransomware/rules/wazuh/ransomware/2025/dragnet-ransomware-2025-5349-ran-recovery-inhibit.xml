<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5349 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 3f99d85d-55cf-5ae3-9471-83a28eeccaac -->
  <rule id="223978" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5349 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>