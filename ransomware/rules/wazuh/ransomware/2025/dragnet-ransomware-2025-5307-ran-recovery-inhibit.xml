<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5307 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a63664da-e6d5-501d-a49c-1a1e3c32c30f -->
  <rule id="263664" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5307 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>