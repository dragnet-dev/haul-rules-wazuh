<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7219 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5047f4b3-7858-518f-86bf-c14c6de21418 -->
  <rule id="422795" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7219 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>