<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7069 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: a31e9576-ff17-55c2-be0e-f2baac87d958 -->
  <rule id="851095" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7069 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>