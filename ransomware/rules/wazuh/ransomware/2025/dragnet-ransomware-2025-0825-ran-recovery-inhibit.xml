<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0825 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: dd0323c4-6d6b-57d4-82ac-2dcb872412d2 -->
  <rule id="510323" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0825 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>