<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4585 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 98615c8c-5d9b-5cb6-b353-78ebcbe687ee -->
  <rule id="777852" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4585 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>