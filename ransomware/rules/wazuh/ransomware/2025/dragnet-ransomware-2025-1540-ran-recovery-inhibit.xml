<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1540 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: cc8162e1-4dbe-599b-aa6d-5884eaf76e06 -->
  <rule id="348162" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1540 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>