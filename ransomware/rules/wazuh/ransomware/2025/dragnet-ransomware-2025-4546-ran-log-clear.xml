<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4546 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 9f8b8aa1-0e37-59fa-a1d9-900cacb75c9a -->
  <rule id="592778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4546 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>