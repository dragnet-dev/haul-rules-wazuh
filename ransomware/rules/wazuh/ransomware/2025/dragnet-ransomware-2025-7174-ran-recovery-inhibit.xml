<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7174 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: 852576b5-872f-5bbc-a10c-adb1ebc41c1f -->
  <rule id="241227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7174 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>