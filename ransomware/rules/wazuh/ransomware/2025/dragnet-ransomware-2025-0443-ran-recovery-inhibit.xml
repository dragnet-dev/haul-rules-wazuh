<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0443 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 21dc6c97-4cd1-5244-8be8-0a62966414d8 -->
  <rule id="954689" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0443 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>