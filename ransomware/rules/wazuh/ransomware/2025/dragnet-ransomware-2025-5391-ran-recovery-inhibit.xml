<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5391 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: d39f1b86-da31-59ab-86fc-ae8a239d2ac4 -->
  <rule id="830267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5391 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>