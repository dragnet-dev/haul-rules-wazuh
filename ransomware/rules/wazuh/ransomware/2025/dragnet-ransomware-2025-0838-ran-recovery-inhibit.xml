<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0838 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 3fe1e568-4f91-5e81-9087-22083733159e -->
  <rule id="835505" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0838 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>