<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1698 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 8eb0b0d9-1e7a-52a4-b53f-845772580f45 -->
  <rule id="152910" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1698 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>