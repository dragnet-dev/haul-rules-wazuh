<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4014 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 03e0819a-6521-5471-81fc-648995b347d4 -->
  <rule id="133114" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4014 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>