<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6018 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c94b6fce-b1d8-5665-b06c-35053723fce6 -->
  <rule id="714511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6018 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>