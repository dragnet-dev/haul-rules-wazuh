<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5234 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 118905aa-3859-5448-82c3-6c14f7853cb6 -->
  <rule id="202490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5234 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>