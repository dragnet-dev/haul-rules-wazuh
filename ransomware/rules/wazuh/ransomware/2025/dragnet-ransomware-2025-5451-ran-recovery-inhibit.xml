<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5451 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: a893896e-6bf2-5dd6-af8c-b4d937fc91f5 -->
  <rule id="289389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5451 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>