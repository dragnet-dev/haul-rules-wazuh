<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3994 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: f468fa40-d8f1-569b-8719-37d1cffbe6c9 -->
  <rule id="460058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3994 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>