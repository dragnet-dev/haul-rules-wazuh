<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5723 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 3854cfb3-3758-583e-b681-a3b305a077f3 -->
  <rule id="589307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5723 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>