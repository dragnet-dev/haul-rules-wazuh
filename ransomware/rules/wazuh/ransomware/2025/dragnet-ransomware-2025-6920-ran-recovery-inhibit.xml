<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6920 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8f2ff52b-d51a-5b2e-8997-4e196cd2aaa5 -->
  <rule id="168475" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6920 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>