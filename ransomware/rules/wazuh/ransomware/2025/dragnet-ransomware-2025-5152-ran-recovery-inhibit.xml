<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5152 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: fe9b95f6-c1ab-5feb-a3e1-22616ba74105 -->
  <rule id="579595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5152 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>