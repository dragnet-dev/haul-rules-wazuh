<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6955 — Event Log Clearing (blacknevas) | Status: experimental | Sigma ID: 02dfc676-2a23-5722-a368-9079163b100b -->
  <rule id="377267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6955 — Event Log Clearing (blacknevas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>