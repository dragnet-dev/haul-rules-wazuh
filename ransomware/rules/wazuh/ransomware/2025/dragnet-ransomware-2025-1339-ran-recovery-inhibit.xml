<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1339 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 1584173f-b7ef-5a38-84f8-6ee3334f7e7d -->
  <rule id="784173" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1339 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>