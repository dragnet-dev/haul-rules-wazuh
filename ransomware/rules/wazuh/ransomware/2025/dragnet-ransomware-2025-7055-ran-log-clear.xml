<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7055 — Event Log Clearing (d4rk4rmy) | Status: experimental | Sigma ID: ff598c0d-5d41-5668-bb3a-e34651d8fcc2 -->
  <rule id="589580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7055 — Event Log Clearing (d4rk4rmy)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>