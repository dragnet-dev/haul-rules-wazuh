<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4608 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 4c44873f-08c5-5f94-b141-86129a88f7a1 -->
  <rule id="544873" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4608 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>