<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3016 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: b3eecb5b-7e72-5f1a-b799-eb3fbbc57a5c -->
  <rule id="366699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3016 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>