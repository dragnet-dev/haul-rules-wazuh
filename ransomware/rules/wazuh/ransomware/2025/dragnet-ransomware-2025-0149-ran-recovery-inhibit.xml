<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0149 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: 9237cedf-a58f-53fc-af60-8ee5a4640069 -->
  <rule id="664878" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0149 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>