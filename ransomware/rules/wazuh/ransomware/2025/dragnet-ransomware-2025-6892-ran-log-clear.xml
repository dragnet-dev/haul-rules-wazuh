<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6892 — Event Log Clearing (babuk2) | Status: experimental | Sigma ID: a67f0bb3-a894-5c7c-9e68-cc8b3eee0406 -->
  <rule id="133931" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6892 — Event Log Clearing (babuk2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>