<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1498 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: b50af105-8d1e-58dd-8a55-75c8a5826a2c -->
  <rule id="345751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1498 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>