<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1935 — Recovery Inhibition (ralord) | Status: experimental | Sigma ID: c017cc95-d7c6-5b98-a01d-f96ba8ba74cd -->
  <rule id="476556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1935 — Recovery Inhibition (ralord)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>