<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5146 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 52b0656d-7b0f-5ae8-af28-89338515a6c8 -->
  <rule id="430656" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5146 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>