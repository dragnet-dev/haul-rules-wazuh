<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1643 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 97b586fe-9c95-5005-ab7b-bf827c289eb7 -->
  <rule id="763586" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1643 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>