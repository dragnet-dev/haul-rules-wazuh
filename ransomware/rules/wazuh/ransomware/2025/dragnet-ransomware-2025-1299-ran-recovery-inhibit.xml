<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1299 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 7888d2b5-c188-57d8-af87-bccea719f170 -->
  <rule id="462212" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1299 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>