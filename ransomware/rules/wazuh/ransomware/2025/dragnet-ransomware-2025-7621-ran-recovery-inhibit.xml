<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7621 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 3e7c2325-8c7f-5034-bc6f-48910ec60a5a -->
  <rule id="204423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7621 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>