<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7100 — Event Log Clearing (clop) | Status: deprecated | Sigma ID: ca35fc2c-529e-5f45-8aee-3e2c0acd5d74 -->
  <rule id="780412" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7100 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>