<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3210 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7b450c01-a02c-502f-adfb-bc06ae4afa2e -->
  <rule id="275212" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3210 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>