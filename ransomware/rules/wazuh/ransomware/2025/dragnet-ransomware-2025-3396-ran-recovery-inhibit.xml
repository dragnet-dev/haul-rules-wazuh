<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3396 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: e7dc07d9-82d0-5a36-9389-fb70913a89d5 -->
  <rule id="285207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3396 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>