<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6276 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 3d53d3a1-b7bb-5c8f-8b97-cbd0a11222b7 -->
  <rule id="553818" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6276 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
