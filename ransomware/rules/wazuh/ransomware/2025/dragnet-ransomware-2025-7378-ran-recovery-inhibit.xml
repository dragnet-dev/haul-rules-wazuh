<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7378 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 9ef3f27c-b19f-5b1d-bdf5-5bb6439ca92c -->
  <rule id="569432" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7378 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>