<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7121 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 97f49b54-da3e-5e3a-ac4e-947c72a1e295 -->
  <rule id="807995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7121 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>