<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0353 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: 9687e778-de60-5a7d-aec2-ad710dcd955e -->
  <rule id="750067" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0353 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>