<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0622 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 9e489e26-4523-53b2-8b93-4bd60f4c5077 -->
  <rule id="835838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0622 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>