<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2366 — Recovery Inhibition (incransom) | Status: test | Sigma ID: da965ca5-debb-511b-83d6-103ce768e020 -->
  <rule id="903452" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2366 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
