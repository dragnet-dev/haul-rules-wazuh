<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1076 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 54f58a6a-dd0b-589a-b108-6cde477a04d0 -->
  <rule id="607338" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1076 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>