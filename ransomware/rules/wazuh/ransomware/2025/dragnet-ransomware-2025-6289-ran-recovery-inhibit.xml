<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6289 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 98f79a75-1ff4-5818-ba3b-dc283474ec5c -->
  <rule id="834074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6289 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>