<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6213 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4038d3e1-182c-54cf-b69e-2a565bb93b3e -->
  <rule id="539422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6213 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>