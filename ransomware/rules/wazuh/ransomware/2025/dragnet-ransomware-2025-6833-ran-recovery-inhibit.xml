<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6833 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: facd7eff-94c0-5510-9226-352997591cd4 -->
  <rule id="472926" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6833 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>