<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2135 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d537c55f-45df-53d9-aa15-2f0311f98ae1 -->
  <rule id="466045" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2135 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>