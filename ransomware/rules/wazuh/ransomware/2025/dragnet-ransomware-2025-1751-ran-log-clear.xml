<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1751 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: ce7b8d69-80b2-5f79-a3f3-cbe4cad237bf -->
  <rule id="893421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1751 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>