<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7831 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: bc6e4fcb-e7d0-51bb-ab4e-3cfaed550ef8 -->
  <rule id="430479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7831 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>