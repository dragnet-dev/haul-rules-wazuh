<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2854 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 6a06d1d0-4ab2-5113-b74c-0f2761416ed6 -->
  <rule id="897091" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2854 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>