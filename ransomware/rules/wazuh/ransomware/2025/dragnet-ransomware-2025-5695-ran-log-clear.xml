<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5695 — Event Log Clearing (blacklock) | Status: experimental | Sigma ID: e8e06fe5-65cf-5e01-b8ec-8741c5b2df02 -->
  <rule id="311311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5695 — Event Log Clearing (blacklock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>