<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4293 — Event Log Clearing (kawa4096) | Status: experimental | Sigma ID: d141cb92-e4cf-5cbc-9bf2-e379791dcb3c -->
  <rule id="764299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4293 — Event Log Clearing (kawa4096)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>