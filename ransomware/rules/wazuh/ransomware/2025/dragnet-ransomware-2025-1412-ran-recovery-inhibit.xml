<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1412 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 631cb3d4-e615-5d44-bae3-41649ddcfc9d -->
  <rule id="817393" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1412 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>