<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4080 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 8a6b8f6c-f0a6-5465-940f-426f7449f305 -->
  <rule id="950063" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4080 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>