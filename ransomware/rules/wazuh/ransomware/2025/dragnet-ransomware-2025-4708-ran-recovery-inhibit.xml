<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4708 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 87d8d159-4c4c-5a61-b8be-5d9d65b24556 -->
  <rule id="549411" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4708 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>