  <rule id="548367" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5095 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
