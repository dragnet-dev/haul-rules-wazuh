<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1846 — Event Log Clearing (brotherhood) | Status: experimental | Sigma ID: 83390928-63fa-53b0-a2b0-0603123f7af2 -->
  <rule id="339092" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1846 — Event Log Clearing (brotherhood)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>