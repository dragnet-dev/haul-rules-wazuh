<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7200 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c5f3ba93-4fcb-5984-a5f5-78028a03947c -->
  <rule id="759354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7200 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>