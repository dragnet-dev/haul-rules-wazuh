<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5264 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 3bf7d30a-8e1f-55b5-9ebe-4ef35a8ef6f6 -->
  <rule id="735653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5264 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>