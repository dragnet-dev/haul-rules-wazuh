<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4630 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1ff8e267-45c2-5e2e-b219-e2e6abcad63e -->
  <rule id="190226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4630 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>