<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5842 — Recovery Inhibition (gunra) | Status: experimental | Sigma ID: 00aed36f-5d9d-5d9b-9c87-9d24dcbebe38 -->
  <rule id="975791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5842 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>