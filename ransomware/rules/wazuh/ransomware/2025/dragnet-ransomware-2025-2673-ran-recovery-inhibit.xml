<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2673 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: ff9e5177-d50c-5dba-94cc-8f3ecc88d8ab -->
  <rule id="595851" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2673 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>