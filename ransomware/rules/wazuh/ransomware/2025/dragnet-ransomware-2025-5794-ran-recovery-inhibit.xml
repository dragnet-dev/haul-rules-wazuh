<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5794 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 0bbcf744-7409-596f-87d6-f04cb1cd695e -->
  <rule id="407974" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5794 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>