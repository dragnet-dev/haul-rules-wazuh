<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6100 — Event Log Clearing (rhysida) | Status: experimental | Sigma ID: c5b824bf-6bdc-5f23-bd72-3e60d2f90d49 -->
  <rule id="311824" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6100 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>