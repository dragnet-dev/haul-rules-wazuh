<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7079 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: b9dd4cc7-cd13-56b4-91c5-5c368d0ccc85 -->
  <rule id="509676" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7079 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>