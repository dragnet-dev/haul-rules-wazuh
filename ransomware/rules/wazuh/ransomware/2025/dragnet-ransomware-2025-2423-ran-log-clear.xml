<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2423 — Event Log Clearing (thegentlemen) | Status: experimental | Sigma ID: 0cdc4836-7de7-5086-8e4f-bc5cd79afe43 -->
  <rule id="692483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2423 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>