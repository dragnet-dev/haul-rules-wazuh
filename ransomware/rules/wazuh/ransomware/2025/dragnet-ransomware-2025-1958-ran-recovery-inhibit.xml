<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1958 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 0c495eef-77c1-5b95-92d8-0997fbebd699 -->
  <rule id="598958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1958 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>