<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7563 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: b75203dd-b7a2-5ab2-acbd-4535a51995b5 -->
  <rule id="375203" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7563 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>