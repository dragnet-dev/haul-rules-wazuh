<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5693 — Event Log Clearing (play) | Status: experimental | Sigma ID: 8f80783c-d3e4-5d1c-be6e-eeb4d09d0d98 -->
  <rule id="638078" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5693 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>