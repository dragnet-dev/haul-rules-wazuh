<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0898 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 4e673a31-70ac-50aa-9468-39d2968e222c -->
  <rule id="458778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0898 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>