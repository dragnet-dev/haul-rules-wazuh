<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1991 — Event Log Clearing (lynx) | Status: experimental | Sigma ID: 5060c4aa-3ecd-58a7-9bb0-7bcff44635f7 -->
  <rule id="455594" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1991 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>