<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1573 — Recovery Inhibition (VanHelsing) | Status: experimental | Sigma ID: da0d2420-ff1b-528e-a96b-fada74946a82 -->
  <rule id="889324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1573 — Recovery Inhibition (VanHelsing)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>