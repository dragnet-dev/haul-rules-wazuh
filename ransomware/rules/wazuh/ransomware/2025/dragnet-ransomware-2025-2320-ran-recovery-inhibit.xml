<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2320 — Recovery Inhibition (obscura) | Status: experimental | Sigma ID: 23d95240-11f9-5857-bf98-ed3c829ae3fb -->
  <rule id="319524" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2320 — Recovery Inhibition (obscura)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>