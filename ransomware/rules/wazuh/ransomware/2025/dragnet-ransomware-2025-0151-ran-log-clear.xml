<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0151 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 5c8b65b5-88ca-5cc2-82a0-b50e5f564ad9 -->
  <rule id="685965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0151 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>