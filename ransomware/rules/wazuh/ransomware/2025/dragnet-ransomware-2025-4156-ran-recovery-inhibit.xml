<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4156 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 5298a97d-d0f5-5077-8d84-acdfe680d0fe -->
  <rule id="477897" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4156 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>