<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5585 — Recovery Inhibition (J) | Status: experimental | Sigma ID: e16db9ec-a959-5e5f-8706-80fb69e9c2b1 -->
  <rule id="127159" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5585 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>