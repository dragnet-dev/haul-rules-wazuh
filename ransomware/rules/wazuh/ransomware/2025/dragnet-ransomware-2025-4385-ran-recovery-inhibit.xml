<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4385 — Recovery Inhibition (everest) | Status: test | Sigma ID: e13a425e-4891-572b-a5f8-2327966c3100 -->
  <rule id="561842" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4385 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>