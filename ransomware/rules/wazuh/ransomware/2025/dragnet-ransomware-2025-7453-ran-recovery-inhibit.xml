<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7453 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 855e1fc6-e1b2-52d8-9a99-139aed97bb0a -->
  <rule id="491071" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7453 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>