<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3525 — Event Log Clearing (cloak) | Status: deprecated | Sigma ID: b0e4db2d-de4a-572f-948e-1d06e8a418e7 -->
  <rule id="142683" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3525 — Event Log Clearing (cloak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>