<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0721 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 43be2287-323c-5d40-90fe-e017f7bd6fa3 -->
  <rule id="319822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0721 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>