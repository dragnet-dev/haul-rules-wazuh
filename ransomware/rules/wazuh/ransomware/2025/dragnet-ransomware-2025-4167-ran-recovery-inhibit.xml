<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4167 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: fd7334bb-f081-5769-a719-a9f2902fabc6 -->
  <rule id="837334" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4167 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>