<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2618 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 91f9c11a-133a-5519-a9b6-ab9465dd0fe6 -->
  <rule id="655161" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2618 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>