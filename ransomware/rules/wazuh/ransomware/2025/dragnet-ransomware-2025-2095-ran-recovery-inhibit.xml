<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2095 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 61aeaf2f-a95a-58e6-92e4-eadf28458393 -->
  <rule id="542415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2095 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>