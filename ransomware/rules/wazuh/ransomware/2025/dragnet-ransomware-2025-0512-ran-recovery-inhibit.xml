<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0512 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 5e037579-a230-576b-8157-d0eccdde62df -->
  <rule id="503757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0512 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>