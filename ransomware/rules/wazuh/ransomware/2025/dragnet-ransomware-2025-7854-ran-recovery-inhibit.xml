<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7854 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 0d088e6a-7653-56a0-8906-364965b132a3 -->
  <rule id="394226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7854 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>