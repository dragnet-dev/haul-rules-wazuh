<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7144 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f0a0e41f-ff3b-57aa-b45b-53b10a5c08ea -->
  <rule id="356144" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7144 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>