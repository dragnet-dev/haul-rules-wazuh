<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6559 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: ab356832-b361-5a54-94fe-006e013d713b -->
  <rule id="913568" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6559 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>