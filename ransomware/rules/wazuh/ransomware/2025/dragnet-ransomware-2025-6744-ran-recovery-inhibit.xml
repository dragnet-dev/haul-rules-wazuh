<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6744 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 4c4a055a-a20a-5451-afe1-a840b914628a -->
  <rule id="423405" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6744 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>