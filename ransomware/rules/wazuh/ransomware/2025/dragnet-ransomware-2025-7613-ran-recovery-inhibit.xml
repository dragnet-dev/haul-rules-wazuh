<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7613 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: c1da47f2-cf68-5de0-a1ba-9d2ac5ea7cc1 -->
  <rule id="519447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7613 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>