<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3394 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e31014d2-98cf-528c-89fc-32e2f8ed2824 -->
  <rule id="631014" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3394 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>