<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2576 — Event Log Clearing (arcusmedia) | Status: experimental | Sigma ID: 48b9ec67-501d-53eb-a747-cfbd4ac6a231 -->
  <rule id="296780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2576 — Event Log Clearing (arcusmedia)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>