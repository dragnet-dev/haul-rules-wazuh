<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2574 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 26cbed01-4d72-54a6-b8ce-8b315e2049cf -->
  <rule id="956141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2574 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>