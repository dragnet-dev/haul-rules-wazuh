<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3954 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: f869d213-a9fb-585c-9f9d-c0848246c12b -->
  <rule id="839172" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3954 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>