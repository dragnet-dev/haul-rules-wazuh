<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0654 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 510e6206-00a7-5a05-a25d-9c4079737591 -->
  <rule id="174620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0654 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>