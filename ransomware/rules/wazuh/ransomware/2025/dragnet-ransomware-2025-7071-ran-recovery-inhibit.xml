<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7071 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: d11fd28d-880d-5eeb-a9df-e72906c4e0ac -->
  <rule id="758692" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7071 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>