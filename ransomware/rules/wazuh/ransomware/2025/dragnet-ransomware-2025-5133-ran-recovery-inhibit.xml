<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5133 — Recovery Inhibition (J) | Status: experimental | Sigma ID: c59fb5bc-ccb4-502b-ba79-d8692eb06f13 -->
  <rule id="625555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5133 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>