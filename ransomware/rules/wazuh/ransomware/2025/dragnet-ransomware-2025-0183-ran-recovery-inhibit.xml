<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0183 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 66f45c64-035f-559b-a10a-79cef894d9b6 -->
  <rule id="914332" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0183 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>