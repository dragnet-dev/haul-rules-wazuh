<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1140 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 22872eaf-bf78-533f-89a6-82609d33fc35 -->
  <rule id="555466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1140 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>