<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0710 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7b15b5b3-01bf-517f-a1f0-f5268eca3f6a -->
  <rule id="270515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0710 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>