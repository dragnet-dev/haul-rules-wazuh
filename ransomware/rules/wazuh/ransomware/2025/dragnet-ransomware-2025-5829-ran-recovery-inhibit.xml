<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5829 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: b68da3f5-72b9-5fbb-9094-533163483925 -->
  <rule id="392263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5829 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>