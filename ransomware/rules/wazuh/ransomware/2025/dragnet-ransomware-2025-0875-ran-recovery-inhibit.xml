<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0875 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: c28897df-4cf5-5e3c-9b30-556c2019cc85 -->
  <rule id="428897" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0875 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>