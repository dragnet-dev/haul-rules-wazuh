<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1758 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: a0bf6784-f640-5608-8792-01e5cfd65df9 -->
  <rule id="879167" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1758 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>