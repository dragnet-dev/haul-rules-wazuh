<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2805 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 38664040-5a92-59c3-8458-667995ba9c05 -->
  <rule id="366404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2805 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>