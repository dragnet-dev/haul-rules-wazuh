<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4854 — Recovery Inhibition (IMNCrew) | Status: experimental | Sigma ID: ce9659d7-e413-5e86-b674-068221416cdd -->
  <rule id="369659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4854 — Recovery Inhibition (IMNCrew)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>