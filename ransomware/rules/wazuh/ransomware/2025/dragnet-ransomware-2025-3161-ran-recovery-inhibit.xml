<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3161 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 97801357-5b15-56d6-a01a-fa1354537e5e -->
  <rule id="880135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3161 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>