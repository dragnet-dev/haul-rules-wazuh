<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2583 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f98e203c-e373-5b29-8a56-5089dbb1bd89 -->
  <rule id="858220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2583 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>