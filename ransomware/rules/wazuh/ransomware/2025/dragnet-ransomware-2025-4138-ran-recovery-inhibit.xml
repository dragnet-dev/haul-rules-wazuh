<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4138 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 7af6b6a5-8be6-5c9b-9c97-0431740a983a -->
  <rule id="548276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4138 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>