<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0625 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 64960e8b-1d52-5ab8-8901-b555268a4c67 -->
  <rule id="239374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0625 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>