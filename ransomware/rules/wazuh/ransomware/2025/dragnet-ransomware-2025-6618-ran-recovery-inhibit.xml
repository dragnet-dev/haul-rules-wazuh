<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6618 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 734c2721-1b6d-5a49-a6b9-1d043efc90ff -->
  <rule id="375627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6618 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>