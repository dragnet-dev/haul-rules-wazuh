<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1040 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c7dd31c1-df4e-525c-99d5-323118eb3f27 -->
  <rule id="673331" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1040 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>