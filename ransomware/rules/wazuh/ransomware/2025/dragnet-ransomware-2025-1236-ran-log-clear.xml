<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1236 — Event Log Clearing (AiLock) | Status: deprecated | Sigma ID: 7bc4da2f-3d5b-5a22-b6f1-69f6e510ec0e -->
  <rule id="670042" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1236 — Event Log Clearing (AiLock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>