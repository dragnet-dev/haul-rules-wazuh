<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3537 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 130fd5ed-ee1e-594a-ab4d-087cb90b9c2b -->
  <rule id="965374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3537 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>