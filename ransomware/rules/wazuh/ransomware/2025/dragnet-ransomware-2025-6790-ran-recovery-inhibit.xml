<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6790 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 2146bf78-fa2d-5142-8d42-01fac43dc5f8 -->
  <rule id="195677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6790 — Recovery Inhibition (safepay)</description>
