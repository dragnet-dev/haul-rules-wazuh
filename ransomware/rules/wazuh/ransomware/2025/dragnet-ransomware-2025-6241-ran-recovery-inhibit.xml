<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6241 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b1c0e6a0-671a-58c1-8f8a-99e75afa369c -->
  <rule id="260946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6241 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>