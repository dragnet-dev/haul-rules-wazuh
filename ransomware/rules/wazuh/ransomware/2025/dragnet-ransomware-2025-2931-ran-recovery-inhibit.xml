<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2931 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c134063d-289f-5fde-9340-e0f475f3577c -->
  <rule id="413406" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2931 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>