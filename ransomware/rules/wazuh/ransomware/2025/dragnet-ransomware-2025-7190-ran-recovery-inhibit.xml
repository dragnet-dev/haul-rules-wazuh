<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7190 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e0f911ed-5356-5dde-a684-1eef762748e5 -->
  <rule id="555911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7190 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>