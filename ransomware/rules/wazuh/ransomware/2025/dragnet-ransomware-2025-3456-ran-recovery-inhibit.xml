<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3456 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 989d723d-0253-5026-ae8e-2a5d77452fae -->
  <rule id="783772" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3456 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>