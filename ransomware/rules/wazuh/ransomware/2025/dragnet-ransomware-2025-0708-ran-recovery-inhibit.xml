<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0708 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: debce5dc-315b-5724-8fba-90712bb4de3d -->
  <rule id="223345" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0708 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>