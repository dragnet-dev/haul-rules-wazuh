<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6942 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: c6cbbbbc-adba-59ae-89d3-d68b9d9348e1 -->
  <rule id="309691" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6942 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
