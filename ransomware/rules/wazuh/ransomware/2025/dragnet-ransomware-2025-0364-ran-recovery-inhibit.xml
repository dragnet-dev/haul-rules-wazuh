<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0364 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 60b3bd50-bbce-5d80-8969-eac94fd59b6c -->
  <rule id="786717" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0364 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
