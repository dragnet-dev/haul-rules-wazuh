<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4002 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: e948584d-4024-5e75-89f3-84a6ffb07a16 -->
  <rule id="694858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4002 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>