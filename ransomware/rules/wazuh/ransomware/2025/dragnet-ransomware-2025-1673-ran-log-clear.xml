<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1673 — Event Log Clearing (global) | Status: deprecated | Sigma ID: 93af1a53-82d9-5fc1-8742-9bae6a17baae -->
  <rule id="337306" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1673 — Event Log Clearing (global)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>