<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3482 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: db6275f0-ec72-58b5-ac5f-245d3610ed02 -->
  <rule id="496275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3482 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>