<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1651 — Event Log Clearing (IMNCrew) | Status: experimental | Sigma ID: c0fb3138-3f0f-5846-bddb-271edfc77428 -->
  <rule id="497131" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1651 — Event Log Clearing (IMNCrew)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>