<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6799 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: a1a4ee42-a5f4-5271-a693-97cdfb145d80 -->
  <rule id="663822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6799 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>