<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1249 — Recovery Inhibition (kraken) | Status: experimental | Sigma ID: c4b4414c-78dd-50a9-9522-98fd4ae0fc01 -->
  <rule id="295441" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1249 — Recovery Inhibition (kraken)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>