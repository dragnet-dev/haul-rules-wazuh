<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4718 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 49f026e6-ad74-5c4a-a334-660e3b866cca -->
  <rule id="284430" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4718 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>