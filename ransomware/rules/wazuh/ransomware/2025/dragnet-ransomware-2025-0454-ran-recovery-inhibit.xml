<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0454 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 4f26ce82-c2e5-5704-8fbf-1caa0cb0c6c2 -->
  <rule id="329262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0454 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>