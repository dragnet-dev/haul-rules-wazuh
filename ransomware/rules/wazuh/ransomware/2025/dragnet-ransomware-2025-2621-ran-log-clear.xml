<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2621 — Event Log Clearing (clop) | Status: deprecated | Sigma ID: 4ac50e1f-a2bd-5d2f-af13-899a2e5e27c9 -->
  <rule id="214414" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2621 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>