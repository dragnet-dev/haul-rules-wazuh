<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2534 — Recovery Inhibition (insomnia) | Status: experimental | Sigma ID: 84cb29f6-8ea8-5170-b558-d32d4976d969 -->
  <rule id="470729" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2534 — Recovery Inhibition (insomnia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>