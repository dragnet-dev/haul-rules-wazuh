<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6101 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 57694063-412b-5074-9868-8787ddc40f9d -->
  <rule id="469406" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6101 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>