<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1528 — Event Log Clearing (handala) | Status: experimental | Sigma ID: 4ef55f8a-8d4d-5a82-9075-9433b4a37ec2 -->
  <rule id="321695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1528 — Event Log Clearing (handala)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>