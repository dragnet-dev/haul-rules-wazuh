<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5682 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 0ab2ff68-b406-5814-9d7c-368ff0cd73d6 -->
  <rule id="885276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5682 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>