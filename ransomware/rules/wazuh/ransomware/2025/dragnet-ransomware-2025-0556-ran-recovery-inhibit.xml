<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0556 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: d84b45d4-27af-5e82-b14e-1504fa598553 -->
  <rule id="515545" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0556 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>