<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0990 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 1f88985b-7232-5d8f-aada-000f3fb6e819 -->
  <rule id="588985" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0990 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>