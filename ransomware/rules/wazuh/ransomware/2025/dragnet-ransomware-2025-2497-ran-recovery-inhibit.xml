<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2497 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 3df232af-20a6-533f-bf73-7eb6e1ce0638 -->
  <rule id="659722" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2497 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>