<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6446 — Event Log Clearing (kairos) | Status: experimental | Sigma ID: ee8f817f-57ef-5b26-9de1-147dcb659c72 -->
  <rule id="322381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6446 — Event Log Clearing (kairos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>