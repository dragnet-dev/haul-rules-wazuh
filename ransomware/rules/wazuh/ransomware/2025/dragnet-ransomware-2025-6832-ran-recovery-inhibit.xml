<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6832 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 89aed55d-a0c0-5497-ade6-4fa914fb5111 -->
  <rule id="173415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6832 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>