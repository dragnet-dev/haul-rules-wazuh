<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4024 — Event Log Clearing (cephalus) | Status: deprecated | Sigma ID: d9dfeda6-02d1-5070-9618-5e595d5681d7 -->
  <rule id="266829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4024 — Event Log Clearing (cephalus)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>