<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4812 — Event Log Clearing (everest) | Status: experimental | Sigma ID: 7085e910-3e02-53d7-a4b2-a2e9bf41e7d7 -->
  <rule id="333749" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4812 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>