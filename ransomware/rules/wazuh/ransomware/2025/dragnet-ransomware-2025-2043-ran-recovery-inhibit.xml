<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2043 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 4fd50cf2-5c59-5b30-a593-b1b3c77bf636 -->
  <rule id="344012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2043 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>