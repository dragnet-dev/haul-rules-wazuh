<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1825 — Event Log Clearing (babuk2) | Status: experimental | Sigma ID: 2b876753-3ea2-5266-97e6-fe8cb2c5d7bd -->
  <rule id="887675" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1825 — Event Log Clearing (babuk2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>