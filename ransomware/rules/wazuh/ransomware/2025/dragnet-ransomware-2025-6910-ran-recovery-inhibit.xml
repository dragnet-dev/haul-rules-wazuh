<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6910 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 2501c4b4-d295-54b2-99bb-e86d136c2c01 -->
  <rule id="204555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6910 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>