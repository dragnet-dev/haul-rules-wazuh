<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0407 — Recovery Inhibition (obscura) | Status: experimental | Sigma ID: ab49e251-2ed7-567c-9707-76f280760490 -->
  <rule id="143982" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0407 — Recovery Inhibition (obscura)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>