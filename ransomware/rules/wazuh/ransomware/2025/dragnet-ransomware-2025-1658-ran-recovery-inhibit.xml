<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1658 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 7d9910fb-63c9-528b-9087-ece758a64ee7 -->
  <rule id="459910" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1658 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>