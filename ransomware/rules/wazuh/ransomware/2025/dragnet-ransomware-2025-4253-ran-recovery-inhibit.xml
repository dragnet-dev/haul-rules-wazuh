<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4253 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: 8eff3d62-d762-5e98-b381-1baf7f3cdce2 -->
  <rule id="557181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4253 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>