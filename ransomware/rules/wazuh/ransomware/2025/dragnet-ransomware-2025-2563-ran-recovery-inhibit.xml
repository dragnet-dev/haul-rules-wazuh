<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2563 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 50b58669-5ff3-5ce3-ad3c-a79ff9b0551c -->
  <rule id="115866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2563 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>