<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3873 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 5d03cc7e-cb9d-54fc-8a9c-f9d7ee2ae3b6 -->
  <rule id="681772" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3873 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>