<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6816 — Recovery Inhibition (incransom) | Status: test | Sigma ID: a63e56af-9ef4-57c6-8117-b49964a85256 -->
  <rule id="902256" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6816 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>