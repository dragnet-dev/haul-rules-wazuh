<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0355 — Recovery Inhibition (apos) | Status: experimental | Sigma ID: 348d394b-bbb8-528d-baae-56ca89f975e6 -->
  <rule id="281394" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0355 — Recovery Inhibition (apos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>