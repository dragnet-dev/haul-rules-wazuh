<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6702 — Recovery Inhibition (arkana) | Status: experimental | Sigma ID: e4007919-7f16-5468-b5d3-00f884d7ed23 -->
  <rule id="640079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6702 — Recovery Inhibition (arkana)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>