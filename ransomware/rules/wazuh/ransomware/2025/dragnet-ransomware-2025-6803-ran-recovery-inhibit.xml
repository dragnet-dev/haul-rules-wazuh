<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6803 — Recovery Inhibition (qilin) | Status: test | Sigma ID: e8306c6a-80ef-5e6e-a49a-fb80dedc1e02 -->
  <rule id="672908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6803 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>