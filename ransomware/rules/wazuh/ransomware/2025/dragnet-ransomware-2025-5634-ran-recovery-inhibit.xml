<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5634 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 06a4bee5-ec29-5146-b624-206b96e77507 -->
  <rule id="861198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5634 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>