<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0656 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 9742bb66-e0eb-5902-b0d7-0ccb67706e58 -->
  <rule id="794139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0656 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>