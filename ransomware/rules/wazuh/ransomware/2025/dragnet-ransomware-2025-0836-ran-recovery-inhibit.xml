<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0836 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: d2129496-f33e-546b-a5ed-2e808cddf328 -->
  <rule id="521294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0836 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>