<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3003 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 30468dbd-9409-5086-ba27-4b8d676af13e -->
  <rule id="700027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3003 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>