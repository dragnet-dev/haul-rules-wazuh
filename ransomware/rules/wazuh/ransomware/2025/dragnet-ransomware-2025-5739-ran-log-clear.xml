<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5739 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 02d44fb4-6c9c-5206-8c40-1c3532f8f3e1 -->
  <rule id="363515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5739 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>