<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7041 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: dd956c49-7069-55d0-8e4a-12a48e948c73 -->
  <rule id="951308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7041 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>