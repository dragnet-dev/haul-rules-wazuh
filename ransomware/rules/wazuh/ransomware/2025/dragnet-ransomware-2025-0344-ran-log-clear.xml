<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0344 — Event Log Clearing (kawa4096) | Status: deprecated | Sigma ID: cd90695e-583a-54e6-942d-d24eed4c0ed9 -->
  <rule id="359069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0344 — Event Log Clearing (kawa4096)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>