<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7090 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 16d5720b-3b3f-549e-a633-e339d34e6363 -->
  <rule id="995720" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7090 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
