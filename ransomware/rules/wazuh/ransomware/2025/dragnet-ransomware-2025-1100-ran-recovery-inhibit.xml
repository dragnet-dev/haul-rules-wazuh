<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1100 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: fc2e44ad-4b2b-57fa-899a-6a9af3235592 -->
  <rule id="536644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1100 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>