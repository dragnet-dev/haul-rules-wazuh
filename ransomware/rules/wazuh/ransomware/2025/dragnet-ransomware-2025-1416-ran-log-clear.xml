<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1416 — Event Log Clearing (genesis) | Status: experimental | Sigma ID: 4012ed63-188c-51d2-8221-cf6ea9a3360b -->
  <rule id="227309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1416 — Event Log Clearing (genesis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>