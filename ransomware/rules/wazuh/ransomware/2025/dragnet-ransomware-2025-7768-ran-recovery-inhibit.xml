<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7768 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 831b5ff4-1f00-5d0d-9bac-1a2326b3fa81 -->
  <rule id="429215" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7768 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>