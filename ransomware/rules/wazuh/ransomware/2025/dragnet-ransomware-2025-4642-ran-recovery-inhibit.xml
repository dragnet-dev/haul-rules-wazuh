<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4642 — Recovery Inhibition (RunSomeWares) | Status: experimental | Sigma ID: 03649015-d9e2-56be-bcb7-8721f5d77b2a -->
  <rule id="149015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4642 — Recovery Inhibition (RunSomeWares)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>