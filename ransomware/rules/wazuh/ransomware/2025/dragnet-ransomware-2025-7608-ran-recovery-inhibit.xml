<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7608 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 78c4cd98-8b42-5741-a91b-870f741c4eec -->
  <rule id="626829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7608 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>