<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2418 — Recovery Inhibition (thegentlemen) | Status: experimental | Sigma ID: de89ea76-4613-542d-bef3-4d80f72727c1 -->
  <rule id="406218" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2418 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>