<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2298 — Event Log Clearing (everest) | Status: experimental | Sigma ID: a8ba9cf2-54cc-550a-bd0f-c8545f4c78a5 -->
  <rule id="953596" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2298 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>