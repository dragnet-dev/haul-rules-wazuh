<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4788 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 319f6562-f4eb-50b7-bb69-0cf0e5552f29 -->
  <rule id="719656" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4788 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>