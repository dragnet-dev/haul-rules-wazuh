<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4514 — Event Log Clearing (cicada3301) | Status: experimental | Sigma ID: a8cd9189-f3d9-5ecc-881e-1978c20423d4 -->
  <rule id="185391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4514 — Event Log Clearing (cicada3301)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>