<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6922 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: ee7ebfd1-6d34-51b4-93ef-1ceab0d9c001 -->
  <rule id="880927" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6922 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>