<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2498 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2625895b-cfd4-57dd-935b-93b461024809 -->
  <rule id="925895" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2498 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>