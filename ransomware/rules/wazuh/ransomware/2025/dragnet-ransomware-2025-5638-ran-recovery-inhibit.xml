<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5638 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: ce20367d-855f-556c-9266-7f3dce3ea848 -->
  <rule id="362036" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5638 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>