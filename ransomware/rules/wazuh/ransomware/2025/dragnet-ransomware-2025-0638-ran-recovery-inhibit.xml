<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0638 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: d895e72f-5683-5402-b818-8dacc95eb1c3 -->
  <rule id="523347" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0638 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>