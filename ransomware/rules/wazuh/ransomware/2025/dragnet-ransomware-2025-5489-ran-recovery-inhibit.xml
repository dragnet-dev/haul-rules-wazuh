<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5489 — Recovery Inhibition (devman) | Status: test | Sigma ID: 3c925607-97dc-5d5c-9a35-c901aa5eaae4 -->
  <rule id="792560" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5489 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
