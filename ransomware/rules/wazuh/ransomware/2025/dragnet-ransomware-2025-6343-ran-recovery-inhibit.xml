<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6343 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 586a555b-6178-5d82-b6c4-23c1e69d0148 -->
  <rule id="486555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6343 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>