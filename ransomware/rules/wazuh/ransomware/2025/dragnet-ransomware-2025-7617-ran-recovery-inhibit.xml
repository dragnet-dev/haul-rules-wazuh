<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7617 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 8dfdb63c-e53c-55f5-8e7c-ea424468af3e -->
  <rule id="515956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7617 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>