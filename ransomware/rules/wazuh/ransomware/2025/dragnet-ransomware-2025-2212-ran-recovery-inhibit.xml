<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2212 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 307b8a5d-58bd-584a-adb8-3eb5e18cf05e -->
  <rule id="778185" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2212 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>