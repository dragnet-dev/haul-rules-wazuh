<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5659 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 71fa3c36-8c1c-5414-9579-1f3ba7dbf5e6 -->
  <rule id="348220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5659 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>