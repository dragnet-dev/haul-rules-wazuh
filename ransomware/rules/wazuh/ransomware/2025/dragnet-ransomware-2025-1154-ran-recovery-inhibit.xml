<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1154 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: c1f555b1-4d76-57ec-a8e9-671f8c95429a -->
  <rule id="251555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1154 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>