<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5883 — Event Log Clearing (warlock) | Status: deprecated | Sigma ID: 9d5f81f1-2449-5ebb-906c-03fb6607d4fd -->
  <rule id="821581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5883 — Event Log Clearing (warlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>