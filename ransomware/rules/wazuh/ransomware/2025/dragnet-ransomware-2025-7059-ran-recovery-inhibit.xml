<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7059 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 54d320b4-d35e-5d4d-87e0-d5411b0590b6 -->
  <rule id="637131" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7059 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>