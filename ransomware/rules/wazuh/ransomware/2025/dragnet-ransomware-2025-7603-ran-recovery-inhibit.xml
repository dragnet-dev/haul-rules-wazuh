<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7603 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: c7f5a088-08ce-5421-ba61-5d926362e94b -->
  <rule id="676100" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7603 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>