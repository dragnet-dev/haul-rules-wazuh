<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5540 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: a8f591c6-fac7-5f15-8c27-d62641a21ee0 -->
  <rule id="943591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5540 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>