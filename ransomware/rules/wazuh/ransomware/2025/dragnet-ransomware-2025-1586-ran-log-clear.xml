<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1586 — Event Log Clearing (IMNCrew) | Status: experimental | Sigma ID: 46a2c9ed-8166-57ea-b2cc-453d2b7ad506 -->
  <rule id="394049" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1586 — Event Log Clearing (IMNCrew)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>