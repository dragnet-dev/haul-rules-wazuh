<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7469 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: fc7e0326-29ae-5256-b44e-7bc4d735aa90 -->
  <rule id="544603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7469 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>