<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1077 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 53f83011-550e-5975-be88-c6a34207da8c -->
  <rule id="638301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1077 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>