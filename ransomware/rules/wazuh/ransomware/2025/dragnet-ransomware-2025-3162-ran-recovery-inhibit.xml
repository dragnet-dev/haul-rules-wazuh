<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3162 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: a3715148-5935-5d0a-9204-5de8cf39f878 -->
  <rule id="237151" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3162 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>