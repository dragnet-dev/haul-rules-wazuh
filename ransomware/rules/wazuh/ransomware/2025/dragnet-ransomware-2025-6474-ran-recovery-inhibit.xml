<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6474 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: edac849d-0729-5606-9542-8a766d47b3e6 -->
  <rule id="784484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6474 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>