<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5106 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: dbcbe336-e38f-54e8-9d6b-3592f4b20d30 -->
  <rule id="102863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5106 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>