<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2730 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: cc3d66ef-0be9-5621-a752-3cae3e003a55 -->
  <rule id="670166" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2730 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>