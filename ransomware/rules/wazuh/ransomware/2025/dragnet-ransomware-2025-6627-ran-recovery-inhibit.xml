<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6627 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: 69d04c9e-abe4-5a6d-a906-2451ae8c08a8 -->
  <rule id="987276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6627 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>