<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1955 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 830d4e3a-3475-5e1e-b563-f176e4670f71 -->
  <rule id="426958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1955 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>