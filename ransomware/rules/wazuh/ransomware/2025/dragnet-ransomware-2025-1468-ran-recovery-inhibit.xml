<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1468 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 7cec307a-5589-5098-8dca-93bd2e697398 -->
  <rule id="598030" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1468 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>