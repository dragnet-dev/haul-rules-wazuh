<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5802 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0ff21239-c8fa-5d2a-98b2-48bda9945084 -->
  <rule id="852123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5802 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>