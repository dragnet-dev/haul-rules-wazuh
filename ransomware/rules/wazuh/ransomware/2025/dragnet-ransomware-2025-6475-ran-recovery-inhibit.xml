<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6475 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4d4473be-4934-525a-b26b-97e98ad2564c -->
  <rule id="791579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6475 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>