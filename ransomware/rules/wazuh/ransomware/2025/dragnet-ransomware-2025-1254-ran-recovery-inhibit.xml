<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1254 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: 29e60b35-9d5b-5cd8-b006-5eff7ad26101 -->
  <rule id="557713" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1254 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>