<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6361 — Event Log Clearing (alphalocker) | Status: experimental | Sigma ID: 6ad1b561-252d-5bb2-93a6-87d50be859c1 -->
  <rule id="134675" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6361 — Event Log Clearing (alphalocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>