<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2682 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 4ce15d7c-45e0-5f7b-b371-75db6c54d28f -->
  <rule id="268253" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2682 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>