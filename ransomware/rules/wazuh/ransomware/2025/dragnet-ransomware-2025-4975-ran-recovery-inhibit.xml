<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4975 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 07a0932a-fda0-5cd7-b4a2-54142d6d2472 -->
  <rule id="420932" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4975 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
