<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5615 — Recovery Inhibition (payoutsking) | Status: experimental | Sigma ID: 532d94fb-f4c0-5062-9e91-be15643655a4 -->
  <rule id="241519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5615 — Recovery Inhibition (payoutsking)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>