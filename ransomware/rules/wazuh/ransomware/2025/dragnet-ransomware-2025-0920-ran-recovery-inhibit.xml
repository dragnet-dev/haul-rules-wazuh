<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0920 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 2580aec5-4c4d-57e4-a166-a6aa63a2bce3 -->
  <rule id="770476" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0920 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>