<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0687 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 706359ce-9f3f-58d0-86e2-e348ad032720 -->
  <rule id="601756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0687 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>