<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4449 — Recovery Inhibition (kawa4096) | Status: experimental | Sigma ID: bb701438-71b6-5381-89bc-8170c137e73a -->
  <rule id="177014" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4449 — Recovery Inhibition (kawa4096)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>