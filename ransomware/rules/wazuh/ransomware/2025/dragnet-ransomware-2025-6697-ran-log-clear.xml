<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6697 — Event Log Clearing (tridentlocker) | Status: experimental | Sigma ID: 2c515a67-6da0-52ca-aeef-5d3703b03ef8 -->
  <rule id="922506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6697 — Event Log Clearing (tridentlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>