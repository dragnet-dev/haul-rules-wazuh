<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4739 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e782254a-36e1-5fe6-a5f5-88f803cbe312 -->
  <rule id="678225" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4739 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>