<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0538 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 5b18c321-0b43-5924-834d-7afe39e635c0 -->
  <rule id="659003" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0538 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>