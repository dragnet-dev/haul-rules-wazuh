<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1042 — Event Log Clearing (payoutsking) | Status: deprecated | Sigma ID: 1ecca028-d4e5-576b-a355-40842d1fcbe8 -->
  <rule id="461540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1042 — Event Log Clearing (payoutsking)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>