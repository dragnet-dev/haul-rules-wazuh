<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5705 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 78f932a3-b000-5b20-adf7-c59d0cbe6adc -->
  <rule id="463932" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5705 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>