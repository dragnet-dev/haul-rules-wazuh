<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4979 — Recovery Inhibition (kraken) | Status: experimental | Sigma ID: 1d1c3b5c-c22d-5093-93bd-22e655d14f95 -->
  <rule id="369395" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4979 — Recovery Inhibition (kraken)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>