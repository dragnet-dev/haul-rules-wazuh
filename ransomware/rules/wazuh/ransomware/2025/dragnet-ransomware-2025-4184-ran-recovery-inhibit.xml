<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4184 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2aa29560-111a-5c29-89df-471ef8d5194a -->
  <rule id="622956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4184 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>