<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4782 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: faee667a-0405-5f81-a0d6-c975a345bc79 -->
  <rule id="223866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4782 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>