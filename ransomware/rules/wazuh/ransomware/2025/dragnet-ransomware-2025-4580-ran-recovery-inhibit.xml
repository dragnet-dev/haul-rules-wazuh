<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4580 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 971d805b-7ffa-54f7-9659-5581ced515ba -->
  <rule id="754980" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4580 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>