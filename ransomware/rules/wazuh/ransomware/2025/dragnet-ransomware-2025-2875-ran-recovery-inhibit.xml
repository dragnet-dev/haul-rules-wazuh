<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2875 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 5f698b8e-cbbf-53e7-a310-481e19a3f1cb -->
  <rule id="731179" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2875 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>