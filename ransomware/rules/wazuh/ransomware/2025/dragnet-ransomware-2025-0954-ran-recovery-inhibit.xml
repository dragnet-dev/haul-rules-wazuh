<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0954 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4f33ef33-c7e0-5d16-960b-622d07bda6bd -->
  <rule id="331087" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0954 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>