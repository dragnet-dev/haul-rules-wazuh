<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7736 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 15295109-014a-5b6d-b13c-50ef24562986 -->
  <rule id="729510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7736 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>