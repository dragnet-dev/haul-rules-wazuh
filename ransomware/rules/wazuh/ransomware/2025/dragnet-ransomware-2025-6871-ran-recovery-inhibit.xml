<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6871 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 0162e599-160b-5f10-b451-7c64a34cf970 -->
  <rule id="906599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6871 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>