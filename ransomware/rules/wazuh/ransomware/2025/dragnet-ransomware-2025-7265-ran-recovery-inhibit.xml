<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7265 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: acc63a80-510e-5450-89c4-0ce324efd9b9 -->
  <rule id="923418" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7265 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>