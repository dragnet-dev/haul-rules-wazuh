<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1534 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 5fd3716c-1c43-5224-8c62-8ea90376d105 -->
  <rule id="733371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1534 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>