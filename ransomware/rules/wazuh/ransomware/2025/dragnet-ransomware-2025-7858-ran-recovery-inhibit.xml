<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7858 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 06cc7539-3f78-52a5-a384-52c779b98519 -->
  <rule id="940753" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7858 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>