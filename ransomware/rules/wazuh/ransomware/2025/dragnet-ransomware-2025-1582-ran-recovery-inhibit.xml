<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1582 — Recovery Inhibition (medusa) | Status: test | Sigma ID: b1d9c21a-4ebf-5ca6-b507-8b5fb3231817 -->
  <rule id="263962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1582 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>