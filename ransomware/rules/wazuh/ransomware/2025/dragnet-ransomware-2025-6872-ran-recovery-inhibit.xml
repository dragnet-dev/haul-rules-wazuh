<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6872 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 083f31fa-0bbb-56bd-b120-c66fd8f50614 -->
  <rule id="449311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6872 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>