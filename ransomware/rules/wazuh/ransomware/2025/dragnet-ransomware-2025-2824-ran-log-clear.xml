<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2824 — Event Log Clearing (J) | Status: experimental | Sigma ID: 9db3c281-ed89-541b-9c36-d9b5c60c2831 -->
  <rule id="537402" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2824 — Event Log Clearing (J)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>