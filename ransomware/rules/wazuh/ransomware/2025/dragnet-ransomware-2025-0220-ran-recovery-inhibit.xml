<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0220 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 3986e4df-2712-5254-b824-6877af1ac8be -->
  <rule id="406477" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0220 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>