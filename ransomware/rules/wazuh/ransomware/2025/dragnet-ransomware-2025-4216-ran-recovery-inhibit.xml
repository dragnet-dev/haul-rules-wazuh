<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4216 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 44ef91f9-9790-531a-9134-c63cc68cd5e1 -->
  <rule id="350391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4216 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>