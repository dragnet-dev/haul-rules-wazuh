<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0707 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 986d9645-ca60-5ebd-a18a-b469ff9a5ad3 -->
  <rule id="778996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0707 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>