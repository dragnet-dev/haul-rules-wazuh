<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2638 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 015966b7-b6a8-51af-ab42-9f07c2bdbe68 -->
  <rule id="854677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2638 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>