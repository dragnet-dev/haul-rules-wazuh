<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3076 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 5ed34d24-3312-5577-805d-a0a9b067e173 -->
  <rule id="727757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3076 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>