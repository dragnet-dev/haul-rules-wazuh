<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6828 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 6f674dac-1e83-5bfa-bc7f-d53252e9bd6d -->
  <rule id="986797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6828 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
