<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7678 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b362574f-4893-5130-9792-4b0b00a4c5ea -->
  <rule id="336257" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7678 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
