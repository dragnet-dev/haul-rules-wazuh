<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7258 — Event Log Clearing (direwolf) | Status: test | Sigma ID: 79beada5-690c-5d86-b411-94137bd7da35 -->
  <rule id="826157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7258 — Event Log Clearing (direwolf)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>