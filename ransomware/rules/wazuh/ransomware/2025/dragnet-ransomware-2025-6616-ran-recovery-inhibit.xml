<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6616 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 552012fc-d95e-5ae3-90c7-57365864915e -->
  <rule id="832207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6616 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>