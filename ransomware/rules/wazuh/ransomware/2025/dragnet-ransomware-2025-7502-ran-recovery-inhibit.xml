<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7502 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 02effe4f-9b03-51d3-a6e0-4df7ff62e7a9 -->
  <rule id="225104" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7502 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>