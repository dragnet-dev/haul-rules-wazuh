<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4018 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: aea3b862-b3c6-59d4-bab5-ad9dee5e3f54 -->
  <rule id="970998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4018 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>