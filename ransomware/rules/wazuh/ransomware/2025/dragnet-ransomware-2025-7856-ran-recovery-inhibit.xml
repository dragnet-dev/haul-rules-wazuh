<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7856 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: f81b13ce-33b5-5060-ad39-4233223ae310 -->
  <rule id="830713" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7856 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>