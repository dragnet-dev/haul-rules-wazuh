<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0413 — Event Log Clearing (sinobi) | Status: experimental | Sigma ID: 6578dc00-ab42-529c-a3c1-bed89f63a940 -->
  <rule id="884188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0413 — Event Log Clearing (sinobi)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>