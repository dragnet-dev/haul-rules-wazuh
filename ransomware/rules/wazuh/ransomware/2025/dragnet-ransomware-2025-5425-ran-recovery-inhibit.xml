<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5425 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 7bcd1b0e-6186-58c7-bab8-454a2e2cb073 -->
  <rule id="670907" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5425 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>