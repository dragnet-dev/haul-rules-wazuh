<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2783 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b93dec87-d692-57c3-ba4d-4f4ea2475e8c -->
  <rule id="490092" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2783 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>