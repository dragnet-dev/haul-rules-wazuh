<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2872 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: 906d9417-d8f7-5bc0-81bd-d4bf9b997671 -->
  <rule id="650994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2872 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>