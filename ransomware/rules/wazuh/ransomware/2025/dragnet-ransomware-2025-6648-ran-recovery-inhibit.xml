<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6648 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d0cc0832-c851-5ea3-a7ca-1c5f12598321 -->
  <rule id="748408" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6648 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>