<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5814 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 76ef3d0b-e167-5e95-93da-1b738a32ffbf -->
  <rule id="551261" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5814 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>