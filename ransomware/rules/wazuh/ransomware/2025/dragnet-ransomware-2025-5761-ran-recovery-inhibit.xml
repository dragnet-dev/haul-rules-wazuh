<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5761 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 30c721f9-cff2-55a3-b88f-b16342791746 -->
  <rule id="783551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5761 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>