<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2557 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7abddbc8-88e4-53fa-9306-4de018855241 -->
  <rule id="943995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2557 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>