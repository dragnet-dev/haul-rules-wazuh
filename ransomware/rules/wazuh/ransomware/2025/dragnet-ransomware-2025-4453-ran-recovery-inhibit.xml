<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4453 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: b19eb78f-cde8-5805-8974-2b74f60112a8 -->
  <rule id="266997" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4453 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>