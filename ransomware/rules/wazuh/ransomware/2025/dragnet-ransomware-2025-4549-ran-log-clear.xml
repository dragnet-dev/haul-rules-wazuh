<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4549 — Event Log Clearing (clop) | Status: deprecated | Sigma ID: cbf3969c-c27b-59a5-a9b6-cd5e75e2b6e1 -->
  <rule id="663396" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4549 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>