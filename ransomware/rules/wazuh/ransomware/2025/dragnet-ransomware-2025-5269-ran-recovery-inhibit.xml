<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5269 — Recovery Inhibition (play) | Status: experimental | Sigma ID: edba6f86-389f-5460-8efb-f161dd6dba74 -->
  <rule id="837391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5269 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>