<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4161 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: fd6d54fb-66b0-5768-8935-37cdc516cb17 -->
  <rule id="558954" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4161 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>