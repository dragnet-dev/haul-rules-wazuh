<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1387 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 20e1f7ce-7fe1-5212-ae42-74e84838cdf9 -->
  <rule id="555484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1387 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>