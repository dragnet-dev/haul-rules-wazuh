<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1467 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: 3730451d-abc5-5d9f-bfe3-eb29de415e43 -->
  <rule id="230451" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1467 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>