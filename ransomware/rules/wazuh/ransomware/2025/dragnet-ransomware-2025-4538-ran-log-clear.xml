<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4538 — Event Log Clearing (radiant) | Status: experimental | Sigma ID: 3731e75e-9981-5016-bff3-e132e8910ec1 -->
  <rule id="671075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4538 — Event Log Clearing (radiant)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>