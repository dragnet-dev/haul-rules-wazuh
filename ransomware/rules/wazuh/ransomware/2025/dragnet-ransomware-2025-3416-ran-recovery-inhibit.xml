<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3416 — Recovery Inhibition (play) | Status: experimental | Sigma ID: efe7e216-0f22-5e5f-b09f-d5b630c0bebd -->
  <rule id="842062" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3416 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>