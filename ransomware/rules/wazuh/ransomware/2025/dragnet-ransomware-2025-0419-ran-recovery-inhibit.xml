<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0419 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 0b0be688-af38-5945-a149-2f3cd540671d -->
  <rule id="235068" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0419 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>