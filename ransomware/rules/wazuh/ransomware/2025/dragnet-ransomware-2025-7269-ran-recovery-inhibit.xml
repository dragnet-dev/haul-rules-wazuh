<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7269 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: d8761507-3f30-5fac-a226-84878b44637f -->
  <rule id="587615" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7269 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>