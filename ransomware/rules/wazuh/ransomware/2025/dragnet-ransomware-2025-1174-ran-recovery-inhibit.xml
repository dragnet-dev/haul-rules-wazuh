<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1174 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: b9d134f7-1ce0-58ff-b625-cd31db8597a7 -->
  <rule id="217134" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1174 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>