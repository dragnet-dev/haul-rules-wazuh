<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0449 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 14ecbde3-8227-5b54-851e-4fe19fbddb11 -->
  <rule id="449758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0449 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>