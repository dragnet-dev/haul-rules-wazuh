<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4713 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 788ba014-d026-518b-ab95-217b8432d918 -->
  <rule id="319140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4713 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>