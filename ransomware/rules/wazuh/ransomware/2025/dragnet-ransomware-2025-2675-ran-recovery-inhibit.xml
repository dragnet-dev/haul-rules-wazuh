<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2675 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e649be13-cad5-5045-b5b7-609c7fe73494 -->
  <rule id="250334" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2675 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>