<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7466 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 230a446d-ce11-55d3-9c42-d859cadf69fe -->
  <rule id="190446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7466 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>