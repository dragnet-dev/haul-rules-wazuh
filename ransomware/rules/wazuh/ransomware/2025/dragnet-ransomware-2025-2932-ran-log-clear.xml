<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2932 — Event Log Clearing (coinbasecartel) | Status: experimental | Sigma ID: 8b8fda76-163f-5429-9c1a-ef73626e4d75 -->
  <rule id="430266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2932 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>