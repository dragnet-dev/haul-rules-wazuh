<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7555 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 1a0f3fea-fd1e-5bf8-95a3-fa0e3d6407ee -->
  <rule id="889022" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7555 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>