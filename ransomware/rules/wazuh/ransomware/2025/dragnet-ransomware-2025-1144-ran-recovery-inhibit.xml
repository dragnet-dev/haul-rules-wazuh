<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1144 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3832a8d8-5c95-5717-813d-07e70441c682 -->
  <rule id="911661" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1144 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>