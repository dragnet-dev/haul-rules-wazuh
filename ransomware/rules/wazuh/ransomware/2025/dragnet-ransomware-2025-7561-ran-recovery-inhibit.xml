<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7561 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 0eca2679-1fc7-53c3-bb55-e7c0cbf705f8 -->
  <rule id="286267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7561 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>