<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3311 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 9741061b-82dc-5273-a5e2-b29f68f58121 -->
  <rule id="841061" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3311 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>