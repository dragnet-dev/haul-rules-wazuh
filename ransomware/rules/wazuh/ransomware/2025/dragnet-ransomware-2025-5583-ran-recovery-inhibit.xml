<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5583 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f6eb2f5e-865d-56af-bd90-21670b2fd8e1 -->
  <rule id="227407" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5583 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>