<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3722 — Event Log Clearing (lynx) | Status: experimental | Sigma ID: 1ec3c5c9-43ba-5b5f-b23b-e5de28f793ec -->
  <rule id="104892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3722 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>