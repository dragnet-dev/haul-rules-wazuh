<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7188 — Recovery Inhibition (securotrop) | Status: experimental | Sigma ID: 3f680ee2-c924-5c1f-a24d-339292e46ec1 -->
  <rule id="218894" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7188 — Recovery Inhibition (securotrop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>