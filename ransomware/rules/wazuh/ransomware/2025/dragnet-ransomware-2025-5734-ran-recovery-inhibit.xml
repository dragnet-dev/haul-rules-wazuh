<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5734 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 413227de-aed0-5601-b757-be7469439153 -->
  <rule id="411645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5734 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>