<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0709 — Event Log Clearing (hellcat) | Status: deprecated | Sigma ID: a88c7f13-32e9-50d3-a9d4-2e7417d8bff8 -->
  <rule id="187327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0709 — Event Log Clearing (hellcat)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>