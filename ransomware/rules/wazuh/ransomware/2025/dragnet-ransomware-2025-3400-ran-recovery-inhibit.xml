<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3400 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 6805c385-978e-5d04-873c-acc5f9ce5990 -->
  <rule id="288923" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3400 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>