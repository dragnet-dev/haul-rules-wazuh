<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3371 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 74d6ae13-6fde-55a5-994f-584945466575 -->
  <rule id="466030" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3371 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>