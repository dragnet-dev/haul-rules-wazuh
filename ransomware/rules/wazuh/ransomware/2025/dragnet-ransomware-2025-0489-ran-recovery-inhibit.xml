<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0489 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 27844e29-0841-5bd4-b5df-f0ceb017277c -->
  <rule id="955182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0489 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>