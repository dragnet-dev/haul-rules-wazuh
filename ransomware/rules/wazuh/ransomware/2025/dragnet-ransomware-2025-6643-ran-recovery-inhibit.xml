<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6643 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 13a9c46c-dbea-5697-9d78-0915744353f5 -->
  <rule id="903646" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6643 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>