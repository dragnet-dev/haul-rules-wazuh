<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3137 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 939b2133-688e-53f1-bd76-c9a156444977 -->
  <rule id="703521" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3137 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>