<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2591 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: add759d1-5280-56b3-a378-c13a4ca88398 -->
  <rule id="181759" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2591 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>