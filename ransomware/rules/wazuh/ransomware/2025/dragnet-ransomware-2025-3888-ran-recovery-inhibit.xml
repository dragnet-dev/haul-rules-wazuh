<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3888 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 6e1dd638-7f3a-58b5-991a-34a758de0147 -->
  <rule id="220776" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3888 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>