<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6334 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 5c063e88-ead4-5d24-a4d6-f1d26e8133d1 -->
  <rule id="673022" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6334 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>