<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3047 — Recovery Inhibition (minteye) | Status: deprecated | Sigma ID: bb7ea24b-760d-5466-8535-d23bf5bc2134 -->
  <rule id="407462" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3047 — Recovery Inhibition (minteye)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
