<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0877 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 206368da-2d30-5d55-a814-149485f98e82 -->
  <rule id="701901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0877 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>