<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7691 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 92d53b28-d61d-5475-91aa-15497850e58f -->
  <rule id="676859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7691 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>