<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4362 — Event Log Clearing (kawa4096) | Status: deprecated | Sigma ID: 57d575cb-dcd0-51b7-85a5-797b34c0499b -->
  <rule id="509212" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4362 — Event Log Clearing (kawa4096)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>