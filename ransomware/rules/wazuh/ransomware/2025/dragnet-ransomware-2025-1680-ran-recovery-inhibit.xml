<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1680 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a7abda21-78ed-56ca-a46f-b8153b378b35 -->
  <rule id="856346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1680 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>