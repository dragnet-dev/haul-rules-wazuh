<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0115 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: fa75546a-0b5c-5b57-9a67-9dec59afeb07 -->
  <rule id="807554" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0115 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>