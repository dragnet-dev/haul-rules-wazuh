<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2956 — Recovery Inhibition (embargo) | Status: experimental | Sigma ID: f8fc7c5f-c187-529f-8b98-2f744c346030 -->
  <rule id="312124" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2956 — Recovery Inhibition (embargo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
