<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0403 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: efc37195-fe41-5cf3-9598-222c0177f059 -->
  <rule id="336371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0403 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>