<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1814 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 7ff134d3-5e6c-564f-892d-139aa30bf0c5 -->
  <rule id="347134" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1814 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>