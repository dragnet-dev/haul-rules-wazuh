<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3628 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: f3e0e187-2af1-5da9-abd3-ecb1794d394d -->
  <rule id="439341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3628 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>