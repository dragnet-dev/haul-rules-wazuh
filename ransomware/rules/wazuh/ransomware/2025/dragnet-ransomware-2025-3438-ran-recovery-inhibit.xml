<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3438 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: fc3614ff-da4c-526a-baab-52cde6d2c9cd -->
  <rule id="823614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3438 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>