<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7832 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 539a01eb-1fa3-553c-8bf7-8f0bbaaf211d -->
  <rule id="414430" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7832 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>