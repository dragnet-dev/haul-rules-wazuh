<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5803 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 37de0a9d-c18a-52b2-aa9a-97a1f42c6e2e -->
  <rule id="751050" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5803 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>