<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0570 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 82d7fcea-e560-5d88-9dca-3038c945c926 -->
  <rule id="794044" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0570 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>