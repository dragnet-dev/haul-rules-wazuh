<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2714 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: daa39bbe-1e44-5cc7-9e58-b2c5eca7caf5 -->
  <rule id="297435" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2714 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>