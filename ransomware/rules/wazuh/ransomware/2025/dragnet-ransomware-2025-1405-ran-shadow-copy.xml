<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1405 — Shadow Copy Deletion (SilentRansomGroup) | Status: deprecated | Sigma ID: 4cb62b20-5d4c-52f8-a7b9-04a84bda4496 -->
  <rule id="264203" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1405 — Shadow Copy Deletion (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>