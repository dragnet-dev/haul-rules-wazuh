<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0020 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 19a9132b-f88d-550f-abc5-7d793047fd71 -->
  <rule id="549132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0020 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>