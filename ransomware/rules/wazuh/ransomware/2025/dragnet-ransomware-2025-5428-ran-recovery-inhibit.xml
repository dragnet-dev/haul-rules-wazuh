<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5428 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 0451bdd1-1d04-5131-8f7c-358443245893 -->
  <rule id="150333" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5428 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>