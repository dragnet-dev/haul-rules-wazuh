<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1360 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: a877816e-6c41-538f-8c8a-b8c86a8984b2 -->
  <rule id="287781" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1360 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>