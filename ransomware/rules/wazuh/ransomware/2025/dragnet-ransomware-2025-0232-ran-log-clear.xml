<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0232 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: ab83e35f-56f7-5fa6-a15d-f2c9598778b4 -->
  <rule id="149423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0232 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>