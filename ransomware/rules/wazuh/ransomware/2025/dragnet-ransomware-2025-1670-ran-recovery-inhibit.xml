<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1670 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 01bbb1d1-2ca3-5fc9-a8b5-6259e2b65079 -->
  <rule id="335869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1670 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>