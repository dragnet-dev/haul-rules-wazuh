<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0402 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: cafc299c-12e7-58a9-bce9-4fafe3be61d5 -->
  <rule id="796429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0402 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>