<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2993 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: b049ac4f-16d6-591d-b4e1-201c1755c114 -->
  <rule id="228716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2993 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>