<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3870 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: eb345770-f9c5-5036-aee3-85d4199799b9 -->
  <rule id="653457" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3870 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>