<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5698 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 1e0d68a0-3204-5423-a514-2d015e439ec8 -->
  <rule id="601898" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5698 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>