<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5758 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 3889bb82-5fb0-5819-9eda-da38629d5fb6 -->
  <rule id="157718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5758 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>