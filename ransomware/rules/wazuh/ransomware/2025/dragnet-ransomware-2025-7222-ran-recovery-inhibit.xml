<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7222 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 133a75a0-9256-5a86-8adb-6d0936401d1d -->
  <rule id="822010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7222 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>