<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4843 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 731c51aa-a924-5835-a04c-1c99b055ca5d -->
  <rule id="370851" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4843 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>