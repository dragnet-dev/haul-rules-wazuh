<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2728 — Recovery Inhibition (lunalock) | Status: experimental | Sigma ID: 2f75ed9d-7208-58ba-82d7-84a02c168694 -->
  <rule id="422637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2728 — Recovery Inhibition (lunalock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>