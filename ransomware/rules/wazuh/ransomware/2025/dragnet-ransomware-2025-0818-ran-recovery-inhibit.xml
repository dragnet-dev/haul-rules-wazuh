<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0818 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 09669ba8-d27d-5d68-a338-bb82bf5ebec0 -->
  <rule id="775450" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0818 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>