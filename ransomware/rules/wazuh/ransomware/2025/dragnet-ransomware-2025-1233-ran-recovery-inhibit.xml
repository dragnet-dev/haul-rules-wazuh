<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1233 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 6a9fbb66-72e6-54f5-87ec-4145258d1c50 -->
  <rule id="882651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1233 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>