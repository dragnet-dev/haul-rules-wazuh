<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7623 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: fd80b484-c9b9-56a5-9672-cf62b463ba8e -->
  <rule id="560914" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7623 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>