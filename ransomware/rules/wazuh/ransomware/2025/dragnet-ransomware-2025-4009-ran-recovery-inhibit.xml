<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4009 — Recovery Inhibition (qilin) | Status: test | Sigma ID: aee616b3-6da7-52d2-8d76-d841491e0358 -->
  <rule id="198616" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4009 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>