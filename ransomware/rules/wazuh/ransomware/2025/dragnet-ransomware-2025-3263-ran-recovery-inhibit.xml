<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3263 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 43d8d13e-6a14-59ef-a7a7-285268552666 -->
  <rule id="323011" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3263 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>