<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3085 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: a8ad8813-cef1-53a5-aa12-c6c6e0ef362a -->
  <rule id="182188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3085 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>