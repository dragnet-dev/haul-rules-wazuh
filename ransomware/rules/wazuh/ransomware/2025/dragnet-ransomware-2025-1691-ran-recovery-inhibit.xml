<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1691 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 165f2c27-0698-5136-ae2c-6b671de0d331 -->
  <rule id="748442" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1691 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>