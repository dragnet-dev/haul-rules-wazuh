<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1374 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 383d33bb-941d-5e16-ae1b-34318d37f611 -->
  <rule id="926139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1374 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>