<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0232 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e074a1f2-1dcb-564c-9e5d-ead30d2ee6e5 -->
  <rule id="551941" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0232 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>