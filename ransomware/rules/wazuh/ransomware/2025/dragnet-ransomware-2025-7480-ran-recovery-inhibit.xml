<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7480 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1efc777a-9fb7-5eda-b0dc-6de5aa9615d8 -->
  <rule id="832777" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7480 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>