<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7908 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: 84ed427e-cf61-5932-b9be-9d727424c111 -->
  <rule id="474142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7908 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>