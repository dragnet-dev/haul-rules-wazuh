<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4647 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 800280d8-0ca3-5cc8-82d4-64596f1376eb -->
  <rule id="304493" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4647 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>