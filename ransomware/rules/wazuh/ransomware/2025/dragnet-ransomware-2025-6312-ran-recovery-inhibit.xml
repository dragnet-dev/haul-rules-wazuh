<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6312 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 5bba0d4c-5fe6-5505-9f41-9b80601edfe5 -->
  <rule id="257133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6312 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>