<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1410 — Event Log Clearing (weyhro) | Status: experimental | Sigma ID: 146cadae-46e1-5ae0-9b8d-39c1c887903c -->
  <rule id="720186" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1410 — Event Log Clearing (weyhro)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>