<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1766 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: c0a4cee4-0705-572b-a9c5-2966c246f4fc -->
  <rule id="542030" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1766 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>