<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3471 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 96aad6a7-6c11-5d25-8367-905f928a27f8 -->
  <rule id="459496" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3471 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>