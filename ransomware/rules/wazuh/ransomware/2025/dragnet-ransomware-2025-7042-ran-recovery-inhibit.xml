<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7042 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: e297673b-1643-5e5a-aa4a-958e1471ec1b -->
  <rule id="629767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7042 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>