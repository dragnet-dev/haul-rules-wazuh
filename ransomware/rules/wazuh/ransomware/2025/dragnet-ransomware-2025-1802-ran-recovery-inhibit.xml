<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1802 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 9684a167-3b83-5c75-add2-d9894a997fee -->
  <rule id="749541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1802 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
