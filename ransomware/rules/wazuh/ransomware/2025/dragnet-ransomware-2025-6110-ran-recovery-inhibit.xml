<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6110 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6c0c26a7-cd79-50d1-bf1c-629820649d0c -->
  <rule id="929226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6110 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>