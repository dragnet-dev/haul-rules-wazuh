<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3458 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 61e6eb94-d04c-5c6a-8f84-9dcf3d8e23fd -->
  <rule id="836171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3458 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>