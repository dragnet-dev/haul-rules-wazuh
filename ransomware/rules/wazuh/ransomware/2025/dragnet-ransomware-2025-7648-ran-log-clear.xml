<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7648 — Event Log Clearing (qilin) | Status: test | Sigma ID: 6a9c5394-8d2e-5bd3-8c10-1b88d5d89e29 -->
  <rule id="911653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7648 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>