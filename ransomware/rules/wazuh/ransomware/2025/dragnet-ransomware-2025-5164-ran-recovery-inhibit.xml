<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5164 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: db11fe78-b499-5fb7-8628-94fb06940ffd -->
  <rule id="309470" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5164 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>