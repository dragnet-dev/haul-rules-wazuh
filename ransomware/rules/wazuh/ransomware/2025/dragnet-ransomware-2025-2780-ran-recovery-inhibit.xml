<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2780 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: e980c606-fa87-5d6f-a6bf-5883da269595 -->
  <rule id="696926" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2780 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>