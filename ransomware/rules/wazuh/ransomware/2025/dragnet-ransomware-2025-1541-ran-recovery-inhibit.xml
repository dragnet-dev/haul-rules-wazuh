<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1541 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: cafa4646-910b-507c-b867-4c20f3410c0d -->
  <rule id="796246" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1541 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>