<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6283 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: b9d4ee56-5a6a-514e-a308-7811ed1608c4 -->
  <rule id="508782" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6283 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>