<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0650 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: c813f8da-f7a5-51bc-a65d-a1390ed0a459 -->
  <rule id="350238" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0650 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>