<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4762 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 425e2ccd-ae55-51e2-91b3-914b1fdee1fc -->
  <rule id="290284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4762 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>