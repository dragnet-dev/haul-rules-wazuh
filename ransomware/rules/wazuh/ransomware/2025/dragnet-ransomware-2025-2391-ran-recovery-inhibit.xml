<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2391 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 9b6da8b3-7857-528f-912f-636ff48e0271 -->
  <rule id="485548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2391 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
