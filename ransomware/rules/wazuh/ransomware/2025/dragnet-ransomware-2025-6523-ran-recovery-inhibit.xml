<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6523 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d0b4c7a3-679b-5ae8-a462-8eb41f15df29 -->
  <rule id="746367" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6523 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>