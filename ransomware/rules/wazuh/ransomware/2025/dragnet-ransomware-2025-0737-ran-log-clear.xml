<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0737 — Event Log Clearing (cephalus) | Status: deprecated | Sigma ID: 37df7ce1-c30a-5ef2-ad35-afbf9064ccf3 -->
  <rule id="751324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0737 — Event Log Clearing (cephalus)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>