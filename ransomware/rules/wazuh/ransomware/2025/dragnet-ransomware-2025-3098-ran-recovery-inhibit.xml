<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3098 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 086b33b5-472a-5b87-ad24-67dfc3452254 -->
  <rule id="519739" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3098 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>