<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3904 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: ff6ebef6-79b4-5478-b0c6-72127644f6da -->
  <rule id="673150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3904 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>