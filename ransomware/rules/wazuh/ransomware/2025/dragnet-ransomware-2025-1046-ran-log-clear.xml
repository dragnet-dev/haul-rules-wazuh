<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1046 — Event Log Clearing (anubis) | Status: experimental | Sigma ID: 1b39d53d-6ca4-563b-8b0d-e6a18e46a32f -->
  <rule id="883753" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1046 — Event Log Clearing (anubis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>