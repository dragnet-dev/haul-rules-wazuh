<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6957 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 866b874d-122c-5788-8606-d1873a094047 -->
  <rule id="586787" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6957 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>