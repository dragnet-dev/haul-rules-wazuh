<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4564 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: e9eee909-4301-5d57-b993-cc4222f004c6 -->
  <rule id="841269" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4564 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>