<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5535 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: cb030e1d-166f-5c10-84be-4d6ec1b44766 -->
  <rule id="648494" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5535 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>