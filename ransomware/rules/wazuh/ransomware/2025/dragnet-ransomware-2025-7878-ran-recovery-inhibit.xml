<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7878 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a58fcd51-35e6-500f-9fc1-23d26c69a20e -->
  <rule id="837613" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7878 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>