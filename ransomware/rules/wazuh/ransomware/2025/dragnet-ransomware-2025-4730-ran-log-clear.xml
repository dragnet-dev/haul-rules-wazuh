<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4730 — Event Log Clearing (bravox) | Status: test | Sigma ID: 3e679507-cd76-5345-ba75-4f4aa13bb3b7 -->
  <rule id="967950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4730 — Event Log Clearing (bravox)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>