<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7015 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 44129947-5c2d-5b32-ac68-9bbb0c56258e -->
  <rule id="912994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7015 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>