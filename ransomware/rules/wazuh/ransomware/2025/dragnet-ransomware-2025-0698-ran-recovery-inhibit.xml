<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0698 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 84b70d0c-d7ab-594e-a9ad-366e3c697da0 -->
  <rule id="469133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0698 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>