<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4011 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: b923deea-5743-5ac5-a5a8-7ae8cb495c92 -->
  <rule id="452510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4011 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>