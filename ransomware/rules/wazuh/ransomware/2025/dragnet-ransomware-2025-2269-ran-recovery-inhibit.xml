<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2269 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 8e184e77-f502-52e0-a986-911eb973c482 -->
  <rule id="574958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2269 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>