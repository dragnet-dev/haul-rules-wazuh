<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0251 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: e13c8d20-741a-58a2-a131-e0158c39610e -->
  <rule id="119341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0251 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>