<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7344 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 79a71254-7c67-5171-8e45-64edc4fd1bc3 -->
  <rule id="474712" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7344 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>