<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6154 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: 51ce7661-4ba1-5798-b262-733813af3e9d -->
  <rule id="526276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6154 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>