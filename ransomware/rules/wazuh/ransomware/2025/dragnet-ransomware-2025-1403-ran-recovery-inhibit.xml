<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1403 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 83d5fb7d-2cb0-5506-b905-e630ba27fa37 -->
  <rule id="834491" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1403 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>