<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4131 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ae1da01d-471d-5b98-a758-4f8167bb8962 -->
  <rule id="959140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4131 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>