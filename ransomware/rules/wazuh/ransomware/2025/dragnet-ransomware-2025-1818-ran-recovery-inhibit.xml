<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1818 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: e1e412e5-824c-5eff-af73-ee42e9bfb625 -->
  <rule id="570412" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1818 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>