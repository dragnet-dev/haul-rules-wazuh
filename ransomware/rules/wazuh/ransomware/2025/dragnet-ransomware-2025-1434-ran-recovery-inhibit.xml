<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1434 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 36ee900e-61eb-5ac6-9643-14310db943d6 -->
  <rule id="554900" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1434 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>