<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4394 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ae1d609a-3a59-5c44-8618-3a21150129d5 -->
  <rule id="186960" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4394 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>