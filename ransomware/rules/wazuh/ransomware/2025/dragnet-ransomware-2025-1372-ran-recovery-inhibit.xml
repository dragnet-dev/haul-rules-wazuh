<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1372 — Recovery Inhibition (cephalus) | Status: experimental | Sigma ID: 083125b9-d844-5909-8059-37e2979e04f0 -->
  <rule id="530011" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1372 — Recovery Inhibition (cephalus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>