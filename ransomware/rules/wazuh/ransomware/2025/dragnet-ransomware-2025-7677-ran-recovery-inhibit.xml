<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7677 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 280725bc-b985-58f5-87f4-d273f06ef499 -->
  <rule id="991611" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7677 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>