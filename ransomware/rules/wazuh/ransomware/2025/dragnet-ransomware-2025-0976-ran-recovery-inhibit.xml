<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0976 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: 1c533ec1-41c0-5c17-b6bc-fd70511644be -->
  <rule id="204684" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0976 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>