<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7672 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 297bc4ea-74ac-519c-b464-b2e35ac3da95 -->
  <rule id="595278" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7672 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>