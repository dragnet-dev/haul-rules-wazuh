<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1010 — Event Log Clearing (lynx) | Status: experimental | Sigma ID: 84d1e6f2-f73c-526d-92d1-56b5f9fdb9bc -->
  <rule id="471506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1010 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>