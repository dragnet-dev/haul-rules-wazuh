<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0371 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 92fd8073-670b-5606-90e0-3c784851f130 -->
  <rule id="680580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0371 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>