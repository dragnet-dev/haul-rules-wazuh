<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4583 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6a88ff96-33f2-56d2-af80-0be72482aea2 -->
  <rule id="136383" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4583 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>