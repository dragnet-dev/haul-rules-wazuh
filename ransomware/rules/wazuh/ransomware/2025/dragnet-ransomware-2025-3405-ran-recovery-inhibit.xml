<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3405 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: c49d722a-321a-51c7-af0a-83d9c08e2d1f -->
  <rule id="299772" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3405 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>