<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3636 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 25f3665c-f5b5-500f-b5a7-0472151f6f7e -->
  <rule id="653665" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3636 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>