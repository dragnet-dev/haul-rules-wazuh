<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6791 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: e5bdcba9-a54d-5e5e-b36b-ff8059c29fe9 -->
  <rule id="651307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6791 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>