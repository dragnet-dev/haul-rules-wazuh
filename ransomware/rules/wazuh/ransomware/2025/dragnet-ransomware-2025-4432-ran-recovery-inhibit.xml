<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4432 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 79d6b303-d51c-5381-b01e-e6e6c51956e4 -->
  <rule id="344273" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4432 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>