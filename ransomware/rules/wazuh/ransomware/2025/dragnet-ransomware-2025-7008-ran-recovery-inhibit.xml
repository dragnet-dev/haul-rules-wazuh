<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7008 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 65a26be1-89cb-5acf-8fab-55a186757782 -->
  <rule id="880427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7008 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>