<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4479 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ccdbef70-1d43-5553-91fc-e3b543c23328 -->
  <rule id="925647" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4479 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>