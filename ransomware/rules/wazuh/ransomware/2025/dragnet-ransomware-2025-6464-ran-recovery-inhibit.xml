<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6464 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: be8d3d1c-4f94-5e49-b6e1-e140f3352493 -->
  <rule id="486621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6464 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>