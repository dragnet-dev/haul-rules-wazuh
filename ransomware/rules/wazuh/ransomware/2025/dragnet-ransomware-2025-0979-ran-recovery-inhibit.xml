<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0979 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 76cf1616-c787-53ec-9652-229273f0889f -->
  <rule id="266316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0979 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>