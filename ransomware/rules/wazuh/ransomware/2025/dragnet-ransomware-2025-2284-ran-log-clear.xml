<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2284 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 4a7b15f4-6bf3-573c-8ec1-468a87145c5a -->
  <rule id="396315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2284 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>