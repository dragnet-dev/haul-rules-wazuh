<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0913 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: db0d6dac-6213-5c98-a8e1-bc75dcad2645 -->
  <rule id="308589" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0913 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
