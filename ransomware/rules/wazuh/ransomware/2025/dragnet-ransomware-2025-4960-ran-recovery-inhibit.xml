<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4960 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7486d06b-db7a-5d76-a260-6b13d4309c43 -->
  <rule id="397890" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4960 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>