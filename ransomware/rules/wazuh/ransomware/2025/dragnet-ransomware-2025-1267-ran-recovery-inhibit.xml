<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1267 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 70ce9879-6c1f-5a94-bb00-a03ac5cbe7ec -->
  <rule id="112698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1267 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>