<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3786 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1d6a8aa0-f9f5-51b4-a15b-b283fce3a985 -->
  <rule id="551978" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3786 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>