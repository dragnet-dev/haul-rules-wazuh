<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3181 — Event Log Clearing (bert) | Status: experimental | Sigma ID: 4fbb7edc-1f07-5a5e-9a61-12530f9c31fb -->
  <rule id="665886" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3181 — Event Log Clearing (bert)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>