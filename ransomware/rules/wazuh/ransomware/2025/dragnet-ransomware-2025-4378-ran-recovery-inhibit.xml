<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4378 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 285b5287-acb7-5130-9bec-34b93f0345a3 -->
  <rule id="171528" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4378 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>