<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4127 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: 07d041e0-8203-5da1-8bc7-7a6c9967bd85 -->
  <rule id="300670" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4127 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>