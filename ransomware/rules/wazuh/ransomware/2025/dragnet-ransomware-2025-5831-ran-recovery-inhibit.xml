<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5831 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 35246c20-87d4-5c20-b95b-511deb57e01c -->
  <rule id="339482" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5831 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>