<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6143 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: eede26b5-b017-5e76-9023-350226b2fce2 -->
  <rule id="815026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6143 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>