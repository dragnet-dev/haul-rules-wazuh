<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3256 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: bd5d8380-9673-5558-bfaa-a1f94a0afbd1 -->
  <rule id="433383" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3256 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>