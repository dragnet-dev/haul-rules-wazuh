<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1210 — Recovery Inhibition (devman) | Status: test | Sigma ID: 8b407d5d-4c16-5706-8dc2-9a48c957fca3 -->
  <rule id="530525" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1210 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>