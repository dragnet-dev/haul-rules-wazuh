<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6140 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: b189da1e-8283-5b2b-a664-9bd44384b5f9 -->
  <rule id="264602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6140 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>