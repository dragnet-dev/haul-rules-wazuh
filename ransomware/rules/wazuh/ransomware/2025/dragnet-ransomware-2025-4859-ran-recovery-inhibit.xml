<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4859 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: 6652b98b-b37b-577e-bdcf-db782f1e062e -->
  <rule id="264439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4859 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>