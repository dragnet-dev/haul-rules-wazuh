<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0247 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: e0bdb46e-524a-5c23-87bb-788ef63b5b91 -->
  <rule id="464754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0247 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>