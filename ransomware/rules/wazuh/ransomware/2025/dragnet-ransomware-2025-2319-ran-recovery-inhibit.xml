<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2319 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 9e60d971-8d70-5da3-80bd-b303452828fa -->
  <rule id="837739" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2319 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>