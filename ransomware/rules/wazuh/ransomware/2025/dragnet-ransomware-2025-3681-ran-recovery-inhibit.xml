<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3681 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 50dd1b05-5c9f-5617-84c8-8d9554608782 -->
  <rule id="383387" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3681 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>