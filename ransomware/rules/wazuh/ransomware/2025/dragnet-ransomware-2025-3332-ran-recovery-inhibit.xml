<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3332 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 8450c50a-0a9e-5ea8-93ba-2406d1f0aa48 -->
  <rule id="552125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3332 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>