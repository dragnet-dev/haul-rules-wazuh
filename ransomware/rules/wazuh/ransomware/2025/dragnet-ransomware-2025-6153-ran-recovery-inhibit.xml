<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6153 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: c2c97ab8-1c75-5340-81a2-dc7e1d57adc0 -->
  <rule id="543962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6153 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>