<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5784 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 75e5338e-27aa-5db8-bdad-0f5e9ab41008 -->
  <rule id="414533" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5784 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>