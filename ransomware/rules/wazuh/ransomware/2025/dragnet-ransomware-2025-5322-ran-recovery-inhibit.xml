<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5322 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 2db753b0-dec4-52e4-a94d-f373620f7ee3 -->
  <rule id="108059" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5322 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>