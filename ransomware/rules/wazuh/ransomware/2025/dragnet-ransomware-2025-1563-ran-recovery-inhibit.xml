<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1563 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: b705630f-9bbd-59a6-99b0-4203234d3983 -->
  <rule id="370563" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1563 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>