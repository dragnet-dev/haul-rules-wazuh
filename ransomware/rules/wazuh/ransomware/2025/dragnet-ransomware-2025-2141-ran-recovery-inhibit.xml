<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2141 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 81d416ed-fbe3-5a23-a29f-0b1d5a15716e -->
  <rule id="509416" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2141 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>