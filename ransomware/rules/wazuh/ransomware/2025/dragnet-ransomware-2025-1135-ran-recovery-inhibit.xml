<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1135 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 7b7065a7-078b-5ebe-86f8-f44cf131e940 -->
  <rule id="437065" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1135 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>