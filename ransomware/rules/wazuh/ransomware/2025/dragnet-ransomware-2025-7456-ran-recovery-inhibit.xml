<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7456 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 680ef35c-0050-56f7-a821-093e82cd70fd -->
  <rule id="943193" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7456 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>