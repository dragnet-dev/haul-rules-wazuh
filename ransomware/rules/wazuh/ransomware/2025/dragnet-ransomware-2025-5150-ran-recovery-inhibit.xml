<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5150 — Recovery Inhibition (genesis) | Status: experimental | Sigma ID: 19feadb1-4f31-50b2-b9a2-d459f317ca7d -->
  <rule id="510381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5150 — Recovery Inhibition (genesis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>