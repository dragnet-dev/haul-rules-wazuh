<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3063 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 4045c871-18c9-50f8-aa34-c1d4ef10302d -->
  <rule id="273287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3063 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>