<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2646 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 4fde73e4-bff5-5d12-9d4c-ed1a5c35a21e -->
  <rule id="344673" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2646 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>