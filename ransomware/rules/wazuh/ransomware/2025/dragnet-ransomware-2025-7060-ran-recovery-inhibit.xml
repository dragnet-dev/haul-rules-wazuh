<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7060 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 1577f04e-80c1-5a69-a207-0550f64a1180 -->
  <rule id="824704" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7060 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>