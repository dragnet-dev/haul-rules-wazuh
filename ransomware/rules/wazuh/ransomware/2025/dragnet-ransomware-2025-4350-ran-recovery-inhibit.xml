<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4350 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0063d74c-6482-5bd9-a803-ae967ad969dd -->
  <rule id="834796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4350 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>