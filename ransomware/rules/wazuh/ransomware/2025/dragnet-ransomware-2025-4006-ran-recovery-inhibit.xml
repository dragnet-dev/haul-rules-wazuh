<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4006 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: feed45e7-f518-5174-9706-04901493b870 -->
  <rule id="326145" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4006 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>