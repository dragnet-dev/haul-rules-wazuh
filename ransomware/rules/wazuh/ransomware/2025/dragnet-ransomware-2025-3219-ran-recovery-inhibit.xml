<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3219 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c124839f-6951-59a4-ad15-1b3f5b6bc241 -->
  <rule id="412483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3219 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>