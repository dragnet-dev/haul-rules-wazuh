<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5944 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: 37289260-167c-5693-b116-be531e1581b0 -->
  <rule id="228926" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5944 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>