<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6596 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: e7fc7eb3-e2a8-5cda-9d9d-b316b4ea29a8 -->
  <rule id="761566" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6596 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>