<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0643 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 543c3941-835c-5d58-a702-9c070664836f -->
  <rule id="700394" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0643 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
