<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7151 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6ff250a6-83a2-5527-ae42-050cda0e3756 -->
  <rule id="991250" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7151 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>