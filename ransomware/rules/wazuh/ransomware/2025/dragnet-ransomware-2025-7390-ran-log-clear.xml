<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7390 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 2f0fafdb-8074-5a8c-adb6-e59696cce503 -->
  <rule id="229135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7390 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>