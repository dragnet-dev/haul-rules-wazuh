<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6288 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 7e61a7e4-d3a2-58d3-98e2-fc289d8e23d3 -->
  <rule id="325867" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6288 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>