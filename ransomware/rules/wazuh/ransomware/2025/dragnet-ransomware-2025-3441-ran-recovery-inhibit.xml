<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3441 — Recovery Inhibition (incransom) | Status: test | Sigma ID: 89227846-65da-533a-871f-f1907a903f2b -->
  <rule id="922784" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3441 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>