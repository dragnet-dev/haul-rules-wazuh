<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1982 — Event Log Clearing (dragonforce) | Status: test | Sigma ID: 8c0f48b9-2fb0-5b33-9a80-299e3ce69a7e -->
  <rule id="541548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1982 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>