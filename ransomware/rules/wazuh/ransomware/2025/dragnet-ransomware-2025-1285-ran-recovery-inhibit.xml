<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1285 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 1608d784-796a-5ff8-8f9a-09f15d5181ad -->
  <rule id="874178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1285 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>