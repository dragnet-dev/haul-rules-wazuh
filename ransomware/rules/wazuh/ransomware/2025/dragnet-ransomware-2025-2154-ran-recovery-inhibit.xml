<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2154 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0dc59efe-198b-5846-b0aa-2af2c0fb9861 -->
  <rule id="347343" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2154 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>