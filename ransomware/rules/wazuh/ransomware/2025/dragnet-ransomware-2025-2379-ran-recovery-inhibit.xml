<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2379 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 82e22a11-799a-5817-9df9-4eb8b264899b -->
  <rule id="421962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2379 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>