<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0035 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 0b9c373c-cb13-5413-ba63-337272d1a38f -->
  <rule id="216373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0035 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>