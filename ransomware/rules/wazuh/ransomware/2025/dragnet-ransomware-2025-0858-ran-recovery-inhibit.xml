<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0858 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: c74e3202-bda2-5a08-85f1-66b33ba9c207 -->
  <rule id="339832" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0858 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>