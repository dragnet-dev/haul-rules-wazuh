<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1050 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: 88f380d3-580e-51d5-83d9-8c1bf51fa673 -->
  <rule id="623380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1050 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>