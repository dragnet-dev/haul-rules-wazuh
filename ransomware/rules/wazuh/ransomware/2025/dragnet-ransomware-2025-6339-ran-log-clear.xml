<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6339 — Event Log Clearing (ALP-001) | Status: experimental | Sigma ID: 8179f21a-341b-5246-a60b-714671ff88ce -->
  <rule id="508792" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6339 — Event Log Clearing (ALP-001)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>