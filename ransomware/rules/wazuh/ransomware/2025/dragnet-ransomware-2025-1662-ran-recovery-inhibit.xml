<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1662 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 585b802f-febd-56e8-8241-8b4381d4f9a4 -->
  <rule id="471802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1662 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>