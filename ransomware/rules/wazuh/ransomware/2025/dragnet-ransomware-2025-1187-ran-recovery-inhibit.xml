<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1187 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: a7aea59e-1e5c-5848-861d-3f11f36db201 -->
  <rule id="910665" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1187 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>