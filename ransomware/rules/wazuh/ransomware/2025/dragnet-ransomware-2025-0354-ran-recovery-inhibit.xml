<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0354 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 572cf858-09ae-589b-b5c5-8c3f34165941 -->
  <rule id="666398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0354 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>