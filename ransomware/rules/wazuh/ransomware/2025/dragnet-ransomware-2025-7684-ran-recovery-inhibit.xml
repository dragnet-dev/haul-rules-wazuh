<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7684 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 04113472-07a7-5328-9125-adbd412e9d0a -->
  <rule id="613472" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7684 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>