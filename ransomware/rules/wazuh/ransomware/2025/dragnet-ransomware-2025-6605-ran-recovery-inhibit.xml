<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6605 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: aeba698b-c5b3-5e37-926c-2d96221c3a47 -->
  <rule id="973069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6605 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>