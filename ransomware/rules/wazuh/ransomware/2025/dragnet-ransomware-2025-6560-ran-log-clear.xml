<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6560 — Event Log Clearing (dragonforce) | Status: experimental | Sigma ID: 4f1ef47a-b9a3-5592-9c90-2c2b00d6045a -->
  <rule id="327354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6560 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>