<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6126 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ca3fb2fc-069d-52e7-9c55-e9ac052b1f2d -->
  <rule id="781392" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6126 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>