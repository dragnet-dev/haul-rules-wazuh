<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1060 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 3101a5eb-5bdd-552f-a50e-c85afc854602 -->
  <rule id="840254" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1060 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>