<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5803 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d83e87f7-f301-5d44-90b2-02e3934b235a -->
  <rule id="514287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5803 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>