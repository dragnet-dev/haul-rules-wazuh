<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7111 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: c85d8f29-fc73-5e6e-8b05-454eefcc6f0a -->
  <rule id="691823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7111 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>