<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1354 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 72c20835-92f1-573d-8e46-1f6765e74148 -->
  <rule id="364208" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1354 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>