<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0471 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: 773dc0cf-efde-587e-a9bd-78499588d1b8 -->
  <rule id="281080" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0471 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>