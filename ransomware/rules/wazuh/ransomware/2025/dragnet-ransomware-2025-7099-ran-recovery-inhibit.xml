<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7099 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d47606a3-78db-566b-8bbd-bc487df329a6 -->
  <rule id="547606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7099 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>