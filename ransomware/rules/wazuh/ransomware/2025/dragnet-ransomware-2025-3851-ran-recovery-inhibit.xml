<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3851 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: a212a5af-dcca-5b46-b141-864d0f815f30 -->
  <rule id="834025" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3851 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>