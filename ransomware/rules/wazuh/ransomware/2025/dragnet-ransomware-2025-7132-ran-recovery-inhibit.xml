  <rule id="190998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7132 — Recovery Inhibition (cicada3301)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
