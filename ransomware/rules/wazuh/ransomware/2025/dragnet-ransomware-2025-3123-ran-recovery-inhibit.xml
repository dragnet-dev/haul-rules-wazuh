<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3123 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 58ab8e07-f56e-53de-85b2-ea04d8e9c049 -->
  <rule id="703182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3123 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>