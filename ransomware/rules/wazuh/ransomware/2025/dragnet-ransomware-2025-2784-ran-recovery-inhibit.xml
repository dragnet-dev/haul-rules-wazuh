<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2784 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: 60c43fe5-fc3e-5865-a1fe-40560f50523e -->
  <rule id="755903" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2784 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>