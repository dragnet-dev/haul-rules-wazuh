<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4238 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0f5bc4f1-def8-5c79-9306-d4ce8db09ad7 -->
  <rule id="178959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4238 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>