<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0503 — Recovery Inhibition (hellcat) | Status: deprecated | Sigma ID: 802e62ff-464c-57c6-91d9-52cfc07805ab -->
  <rule id="484662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0503 — Recovery Inhibition (hellcat)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>