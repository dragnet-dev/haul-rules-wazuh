<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3204 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 4f10b52d-9076-5dd6-89a9-c1b6b066babf -->
  <rule id="465715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3204 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>