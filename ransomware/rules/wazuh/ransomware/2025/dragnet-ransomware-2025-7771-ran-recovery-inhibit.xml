<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7771 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: d604eff4-41fb-5e3d-8bd3-03880fc22abc -->
  <rule id="882863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7771 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>