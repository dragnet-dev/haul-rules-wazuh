<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1626 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 3d24ac6c-5863-5eb3-a58a-cae04354e424 -->
  <rule id="767916" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1626 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>