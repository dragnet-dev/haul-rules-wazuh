<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4924 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 22b9b71c-9003-51ef-97e3-f69efccb1e46 -->
  <rule id="523571" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4924 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>