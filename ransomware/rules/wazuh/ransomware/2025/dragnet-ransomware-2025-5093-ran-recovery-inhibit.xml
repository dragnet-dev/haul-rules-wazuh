<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5093 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 09fdec81-0c1f-54a0-a996-ef1bfdbc45d8 -->
  <rule id="348288" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5093 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
