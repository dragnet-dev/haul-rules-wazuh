<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5569 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 135267c8-26c8-54b5-90fe-d95d80e4cb25 -->
  <rule id="464284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5569 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>