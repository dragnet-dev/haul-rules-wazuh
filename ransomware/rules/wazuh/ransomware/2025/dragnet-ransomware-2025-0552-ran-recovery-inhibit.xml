<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0552 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: a589fdd2-ef5a-559e-a784-2c6952296c13 -->
  <rule id="111037" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0552 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>