<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5025 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 35fcf251-7d8c-5476-b7f3-8ce5346ef7a8 -->
  <rule id="674072" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5025 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>