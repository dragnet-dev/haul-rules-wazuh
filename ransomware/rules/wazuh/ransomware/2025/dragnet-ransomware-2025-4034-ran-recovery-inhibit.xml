<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4034 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 35289b15-7b3e-50b5-ac72-45ca76405bd4 -->
  <rule id="346351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4034 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>