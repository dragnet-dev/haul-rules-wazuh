<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6159 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 0a022a55-e8ff-59cd-a00d-8cc158520cc4 -->
  <rule id="803625" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6159 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>