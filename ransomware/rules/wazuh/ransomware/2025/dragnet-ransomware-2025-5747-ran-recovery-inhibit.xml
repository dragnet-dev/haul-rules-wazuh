<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5747 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9f2f848d-85b6-5403-86d9-82f1fbd3215a -->
  <rule id="848784" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5747 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>