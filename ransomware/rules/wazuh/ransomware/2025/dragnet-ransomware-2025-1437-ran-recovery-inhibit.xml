<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1437 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: c42e5485-e111-52e4-bfbd-df84d896b5a3 -->
  <rule id="288654" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1437 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>