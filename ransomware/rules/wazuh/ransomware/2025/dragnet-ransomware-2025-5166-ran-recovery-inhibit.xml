<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5166 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 6bdb7a91-76fc-5c97-a86b-ea12eb6069f8 -->
  <rule id="917882" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5166 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>