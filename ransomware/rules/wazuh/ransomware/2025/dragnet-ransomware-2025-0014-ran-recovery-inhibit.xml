<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0014 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 10f0e62f-e165-5f89-870e-a9b72d32aab4 -->
  <rule id="201462" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0014 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>