<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3061 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 38a8b8be-b18e-5578-9a14-044f72cfcf77 -->
  <rule id="643179" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3061 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>