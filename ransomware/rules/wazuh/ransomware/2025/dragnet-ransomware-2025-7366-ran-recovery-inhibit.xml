<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7366 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 4fd25494-18ee-50ad-a3c3-45c3a95f1b70 -->
  <rule id="477254" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7366 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>