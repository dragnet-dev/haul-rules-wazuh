<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5317 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f20e53ed-d756-561c-a881-8c604e7b5284 -->
  <rule id="733453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5317 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>