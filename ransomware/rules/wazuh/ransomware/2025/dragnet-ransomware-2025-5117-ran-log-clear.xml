<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5117 — Event Log Clearing (coinbasecartel) | Status: experimental | Sigma ID: 3c1263fe-2aba-53cb-b423-d045f8e0b470 -->
  <rule id="720223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5117 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>