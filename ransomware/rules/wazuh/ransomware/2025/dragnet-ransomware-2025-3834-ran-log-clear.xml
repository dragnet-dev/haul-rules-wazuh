<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3834 — Event Log Clearing (qilin) | Status: test | Sigma ID: 9f37bdd3-b2fc-50a3-bf1f-d3fcf91d6c06 -->
  <rule id="580061" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3834 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>