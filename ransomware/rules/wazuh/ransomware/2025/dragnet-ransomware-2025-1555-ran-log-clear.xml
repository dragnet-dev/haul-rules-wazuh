<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1555 — Event Log Clearing (safepay) | Status: experimental | Sigma ID: 96c7c0bc-dd08-5394-a820-8c23958bf265 -->
  <rule id="778040" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1555 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>