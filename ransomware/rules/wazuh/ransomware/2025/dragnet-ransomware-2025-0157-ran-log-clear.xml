<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0157 — Event Log Clearing (insomnia) | Status: experimental | Sigma ID: 91779cb2-b4c6-577b-a326-48c95f612c1d -->
  <rule id="668476" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0157 — Event Log Clearing (insomnia)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>