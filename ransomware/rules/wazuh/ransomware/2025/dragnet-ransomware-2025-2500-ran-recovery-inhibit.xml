<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2500 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 6fc35455-7531-5447-93b4-4b162d6441ee -->
  <rule id="988354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2500 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>