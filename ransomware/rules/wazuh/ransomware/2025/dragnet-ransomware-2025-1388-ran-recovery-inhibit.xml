<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1388 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ca10d998-a05e-5007-9dca-64b815b80778 -->
  <rule id="633739" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1388 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>