<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2459 — Event Log Clearing (thegentlemen) | Status: experimental | Sigma ID: 70b3801d-d8a5-5a0a-a0c4-ccc4416b9e93 -->
  <rule id="331380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2459 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>