<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6990 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 695416bb-ba6e-504d-8003-1fdb663f8915 -->
  <rule id="426667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6990 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>