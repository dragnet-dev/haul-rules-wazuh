<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7745 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 4ee28743-f73f-5045-9e1b-8fb916389cdc -->
  <rule id="462287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7745 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>