<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3928 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 5c4f01b3-3c4b-585f-8ce1-676ba5e7d878 -->
  <rule id="679901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3928 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>