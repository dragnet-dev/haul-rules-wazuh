<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6787 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 3900d914-c096-507d-b84a-f87268df03c2 -->
  <rule id="941391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6787 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>