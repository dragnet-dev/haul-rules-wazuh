<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7639 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 81b7d79e-f5b0-5da5-8c05-50d4910b3b55 -->
  <rule id="392457" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7639 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>