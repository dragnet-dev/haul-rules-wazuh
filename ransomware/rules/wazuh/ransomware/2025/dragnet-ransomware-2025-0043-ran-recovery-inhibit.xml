<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0043 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: cdd14683-90fd-5de5-a742-356381bbd16c -->
  <rule id="693146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0043 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>