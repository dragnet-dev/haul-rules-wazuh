<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0906 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 69e8b6b4-bffb-50d7-827a-83138c2433e7 -->
  <rule id="990196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0906 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>