<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6341 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 65ccd558-211c-52c5-8286-fd60324947cb -->
  <rule id="995175" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6341 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>