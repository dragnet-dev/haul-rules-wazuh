<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4418 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: bfe8fd78-fbe2-56d2-a09c-2ac7d53603d6 -->
  <rule id="761501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4418 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>