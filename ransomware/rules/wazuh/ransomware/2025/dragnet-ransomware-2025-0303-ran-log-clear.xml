<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0303 — Event Log Clearing (funksec) | Status: experimental | Sigma ID: 9b2d41f9-5153-5db1-ac34-1b7b1532dbc0 -->
  <rule id="784541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0303 — Event Log Clearing (funksec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>