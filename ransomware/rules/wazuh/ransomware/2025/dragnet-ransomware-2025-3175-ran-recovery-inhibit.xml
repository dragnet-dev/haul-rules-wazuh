<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3175 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: c1ecac22-dc69-529d-8bb5-e6d7dc4f3db1 -->
  <rule id="890444" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3175 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>