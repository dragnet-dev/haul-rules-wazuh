<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6754 — Recovery Inhibition (kraken) | Status: experimental | Sigma ID: 319dab32-e173-5ac4-b30c-573778c7a4fc -->
  <rule id="510123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6754 — Recovery Inhibition (kraken)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>