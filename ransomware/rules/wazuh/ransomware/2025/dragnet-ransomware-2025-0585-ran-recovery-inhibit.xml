<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0585 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 2a5f59e2-28e0-5a5b-8d12-e7c617fb96e5 -->
  <rule id="204958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0585 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>