<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4761 — Event Log Clearing (hellcat) | Status: deprecated | Sigma ID: 5ee07144-e32b-5e2c-9451-5f9cc2755b6b -->
  <rule id="718071" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4761 — Event Log Clearing (hellcat)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>