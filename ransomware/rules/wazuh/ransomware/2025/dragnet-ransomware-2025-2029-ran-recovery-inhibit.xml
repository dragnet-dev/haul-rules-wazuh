<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2029 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: f4cc4324-f9a5-5cab-b636-8431f974c099 -->
  <rule id="462843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2029 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>