<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4468 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 286c198a-41b0-573e-a635-88ee32a42af3 -->
  <rule id="188198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4468 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>