<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7285 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: be3d955a-c36a-58a4-ac9a-4f1cba7a6e01 -->
  <rule id="446195" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7285 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>