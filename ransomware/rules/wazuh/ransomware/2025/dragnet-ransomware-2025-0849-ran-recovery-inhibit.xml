<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0849 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 513d365a-4b95-506c-af82-5164ae598c78 -->
  <rule id="221365" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0849 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>