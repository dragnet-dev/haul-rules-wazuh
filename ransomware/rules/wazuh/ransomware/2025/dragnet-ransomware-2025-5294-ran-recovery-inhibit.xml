<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5294 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: 951e13a6-a68a-5366-b731-2f82a0028384 -->
  <rule id="723013" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5294 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>