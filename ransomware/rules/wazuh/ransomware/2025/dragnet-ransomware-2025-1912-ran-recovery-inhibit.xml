<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1912 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: e9d5decb-784a-553b-9d35-3495144700b9 -->
  <rule id="837822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1912 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>