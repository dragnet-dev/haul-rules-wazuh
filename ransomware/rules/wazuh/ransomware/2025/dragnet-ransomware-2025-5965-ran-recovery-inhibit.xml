<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5965 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 70dafd24-1c4e-5792-b5fc-db2b29208be1 -->
  <rule id="243581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5965 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>