<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7189 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: c9cee5ec-5379-58b5-852e-1d5884c39d7e -->
  <rule id="916945" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7189 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>