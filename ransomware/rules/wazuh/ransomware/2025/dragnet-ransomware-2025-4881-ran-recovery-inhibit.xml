<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4881 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: c2c8477a-caf9-501e-9062-b3b1bafe6460 -->
  <rule id="264847" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4881 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>