  <rule id="303482" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4989 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
