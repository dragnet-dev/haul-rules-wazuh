<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1734 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 459467b3-bb07-5012-850a-50344a47abcb -->
  <rule id="251483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1734 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>