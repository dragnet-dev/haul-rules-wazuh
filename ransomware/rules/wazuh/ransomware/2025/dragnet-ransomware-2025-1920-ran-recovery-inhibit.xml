<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1920 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0a9cb005-cd82-5744-8764-0dfe2c8c29b4 -->
  <rule id="210700" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1920 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>