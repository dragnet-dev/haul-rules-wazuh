<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3176 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 03653f2d-dfdb-530a-bf46-c86811d42a1e -->
  <rule id="454125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3176 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>