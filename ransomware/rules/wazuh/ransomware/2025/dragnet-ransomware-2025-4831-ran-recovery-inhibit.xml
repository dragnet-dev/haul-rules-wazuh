<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4831 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 8cafb3c0-c81e-5359-b398-e1b353f3b2e9 -->
  <rule id="462513" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4831 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>