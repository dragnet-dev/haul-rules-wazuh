<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4415 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 9c53301b-1aee-5d7f-95f6-84d5b741299a -->
  <rule id="765330" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4415 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>