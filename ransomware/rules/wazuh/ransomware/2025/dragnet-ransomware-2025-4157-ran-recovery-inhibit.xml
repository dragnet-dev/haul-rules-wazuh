<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4157 — Recovery Inhibition (kraken) | Status: experimental | Sigma ID: 77b9dd0e-74dd-593f-84fc-ab8efdbfe24a -->
  <rule id="584605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4157 — Recovery Inhibition (kraken)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>