<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2917 — Event Log Clearing (nitrogen) | Status: test | Sigma ID: 06169cbc-95ec-5754-a1ec-dd5a226d692a -->
  <rule id="779467" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2917 — Event Log Clearing (nitrogen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>