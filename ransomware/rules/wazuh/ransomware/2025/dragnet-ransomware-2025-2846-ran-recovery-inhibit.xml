<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2846 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7defc80d-6474-5d62-aa1d-edc3313f7d9e -->
  <rule id="758368" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2846 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>