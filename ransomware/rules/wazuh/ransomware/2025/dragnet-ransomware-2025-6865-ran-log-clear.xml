<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6865 — Event Log Clearing (bravox) | Status: experimental | Sigma ID: 65cae992-336b-52eb-83ec-b32848e30a47 -->
  <rule id="994869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6865 — Event Log Clearing (bravox)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>