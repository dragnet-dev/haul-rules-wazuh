<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0048 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: bef9cc71-02ac-530c-bc77-e4ba12747a42 -->
  <rule id="723308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0048 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>