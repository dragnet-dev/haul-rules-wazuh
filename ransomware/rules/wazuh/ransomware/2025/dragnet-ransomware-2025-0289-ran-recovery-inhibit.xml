<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0289 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: c8d04300-d24c-5fb5-ab4f-d79da78d4d18 -->
  <rule id="361043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0289 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>