<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2434 — Recovery Inhibition (thegentlemen) | Status: experimental | Sigma ID: 91170715-9c36-52d3-82ac-c06c27b103a5 -->
  <rule id="217071" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2434 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>