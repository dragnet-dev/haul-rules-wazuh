<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3985 — Recovery Inhibition (kraken) | Status: experimental | Sigma ID: eff267d5-196b-5fdb-a482-b1c9d1bb1575 -->
  <rule id="339267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3985 — Recovery Inhibition (kraken)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>