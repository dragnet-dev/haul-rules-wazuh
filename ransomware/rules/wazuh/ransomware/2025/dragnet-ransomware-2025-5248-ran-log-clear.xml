<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5248 — Event Log Clearing (ralord) | Status: experimental | Sigma ID: bfd8c4b9-ba39-5d19-bc14-ed6cb0acbf9c -->
  <rule id="511804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5248 — Event Log Clearing (ralord)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>