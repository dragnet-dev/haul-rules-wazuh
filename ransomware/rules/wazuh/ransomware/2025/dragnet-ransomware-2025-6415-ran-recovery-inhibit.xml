<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6415 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: c628acd2-1c0a-5c3a-92f2-5c82e595744f -->
  <rule id="632940" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6415 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>