<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5276 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a117c3b8-26c1-5df9-a290-dcad8bb0b2d3 -->
  <rule id="818843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5276 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>