<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5190 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6307ee10-84f1-5e72-bc40-4b69acfe0d42 -->
  <rule id="814830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5190 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>