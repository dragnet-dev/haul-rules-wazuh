<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4045 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 80f4399c-e7a5-544f-90d7-00ff489f7cf6 -->
  <rule id="495439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4045 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>