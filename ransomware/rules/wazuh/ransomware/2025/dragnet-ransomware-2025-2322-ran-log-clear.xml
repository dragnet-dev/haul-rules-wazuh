<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2322 — Event Log Clearing (ralord) | Status: experimental | Sigma ID: 01e98b2b-f7ae-5f49-98e2-f2b73258f675 -->
  <rule id="832683" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2322 — Event Log Clearing (ralord)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>