<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6197 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 46309f8e-30ba-55b6-9a66-f34028359f35 -->
  <rule id="309598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6197 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>