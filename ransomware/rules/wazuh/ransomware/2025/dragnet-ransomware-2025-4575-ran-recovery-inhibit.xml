<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4575 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 73cfea89-e815-5923-9ef7-f2872445298d -->
  <rule id="437354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4575 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>