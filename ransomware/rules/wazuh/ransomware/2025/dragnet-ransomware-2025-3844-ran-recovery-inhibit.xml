<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3844 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: f312bdee-65ab-5313-b8b3-b353eef264dc -->
  <rule id="420061" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3844 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>