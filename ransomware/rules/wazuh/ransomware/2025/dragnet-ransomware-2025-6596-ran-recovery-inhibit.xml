<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6596 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4347e9db-2b53-5cf5-9ad1-66bfd3643227 -->
  <rule id="430717" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6596 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>