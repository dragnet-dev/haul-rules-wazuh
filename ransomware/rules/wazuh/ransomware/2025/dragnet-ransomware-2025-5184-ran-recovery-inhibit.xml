<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5184 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 87ea1641-6524-5640-9633-b345363f3887 -->
  <rule id="550616" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5184 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>