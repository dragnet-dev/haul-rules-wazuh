<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7243 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: b89b8e59-468b-582f-903b-88728b1eacfb -->
  <rule id="445742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7243 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>