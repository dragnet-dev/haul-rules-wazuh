<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6836 — Event Log Clearing (safepay) | Status: experimental | Sigma ID: 309b01e9-7b19-5bde-a6d9-df7ecb1ec7e8 -->
  <rule id="828030" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6836 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>