<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4990 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 7a728f3a-47f9-51f4-88f2-37237160fc23 -->
  <rule id="263663" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4990 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
