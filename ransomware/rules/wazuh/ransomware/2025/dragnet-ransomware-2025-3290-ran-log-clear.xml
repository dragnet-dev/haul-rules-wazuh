<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3290 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 612640c7-2e1f-5e11-ae01-f1b75da8c2e0 -->
  <rule id="902252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3290 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>