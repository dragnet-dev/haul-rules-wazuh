<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2012 — Recovery Inhibition (qilin) | Status: test | Sigma ID: c7772873-393d-5ddb-9799-bf10e5141178 -->
  <rule id="477728" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2012 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>