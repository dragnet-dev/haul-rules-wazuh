<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1552 — Event Log Clearing (clop) | Status: deprecated | Sigma ID: 4d25cb95-bc1e-5b54-b400-f0b3eefac3c0 -->
  <rule id="277803" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1552 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>