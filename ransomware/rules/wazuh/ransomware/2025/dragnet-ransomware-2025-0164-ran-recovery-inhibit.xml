<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0164 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3d7d07d6-4791-5608-8dc7-58856f1ac3a6 -->
  <rule id="616125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0164 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>