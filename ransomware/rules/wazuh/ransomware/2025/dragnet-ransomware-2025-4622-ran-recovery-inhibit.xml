<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4622 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 8e9a8e5e-7ab2-5d2f-8753-27f28c025ebc -->
  <rule id="159982" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4622 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>