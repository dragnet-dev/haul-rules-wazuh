<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5003 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 9dc9960c-dd39-58e5-b1e3-5415167ee314 -->
  <rule id="824996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5003 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>