<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0328 — Event Log Clearing (kazu) | Status: deprecated | Sigma ID: 8251ad24-383f-5f9b-9897-36220184ea18 -->
  <rule id="412429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0328 — Event Log Clearing (kazu)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>