<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1061 — Recovery Inhibition (J) | Status: experimental | Sigma ID: e07b2886-fe53-5963-a108-4381fa985fef -->
  <rule id="552328" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1061 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>