<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5648 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 736a7ef2-9a6d-5d5c-96bf-29926e477198 -->
  <rule id="185886" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5648 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>