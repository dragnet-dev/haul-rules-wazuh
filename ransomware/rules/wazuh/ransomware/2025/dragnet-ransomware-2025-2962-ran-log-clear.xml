<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2962 — Event Log Clearing (sinobi) | Status: experimental | Sigma ID: 33bf9f20-44e4-5832-9e47-4fbd6e4a6306 -->
  <rule id="582399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2962 — Event Log Clearing (sinobi)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>