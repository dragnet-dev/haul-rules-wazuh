<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1702 — Recovery Inhibition (medusa) | Status: test | Sigma ID: 324f26ed-920c-5e87-9d52-f2d9d7d7951e -->
  <rule id="318830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1702 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>