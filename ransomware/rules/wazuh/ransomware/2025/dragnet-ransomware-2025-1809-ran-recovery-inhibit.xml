<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1809 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 828eb5ec-cae6-58fe-941d-7aff6aa239a0 -->
  <rule id="422035" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1809 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>