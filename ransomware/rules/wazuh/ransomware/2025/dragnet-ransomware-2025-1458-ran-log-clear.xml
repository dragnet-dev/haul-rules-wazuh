<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1458 — Event Log Clearing (kryptos) | Status: deprecated | Sigma ID: d133a476-985a-5c76-bd09-ad4837de3e33 -->
  <rule id="401384" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1458 — Event Log Clearing (kryptos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>