<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6433 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 6181017e-f83c-5eaa-8b9c-ac6234c6ca67 -->
  <rule id="881017" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6433 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>