<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6325 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 70056866-85a2-5e96-a592-e1c8c65f822f -->
  <rule id="805686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6325 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>