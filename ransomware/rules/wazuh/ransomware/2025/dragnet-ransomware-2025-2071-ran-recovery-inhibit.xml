<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2071 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 09563384-5796-5e4c-8d6e-3d8c97f1f3ac -->
  <rule id="663384" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2071 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>