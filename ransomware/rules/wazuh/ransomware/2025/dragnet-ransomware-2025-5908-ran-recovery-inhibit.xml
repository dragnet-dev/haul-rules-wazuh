<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5908 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: a194555a-252d-599b-805e-3df91041eaff -->
  <rule id="219455" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5908 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>