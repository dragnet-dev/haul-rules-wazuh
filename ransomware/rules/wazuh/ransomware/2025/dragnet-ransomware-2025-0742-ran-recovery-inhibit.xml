<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0742 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d068ea51-9d09-596d-8337-1600aec168dd -->
  <rule id="745642" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0742 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>