<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1897 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: a8f9e962-11c2-5a36-9880-664105d18767 -->
  <rule id="190389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1897 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>