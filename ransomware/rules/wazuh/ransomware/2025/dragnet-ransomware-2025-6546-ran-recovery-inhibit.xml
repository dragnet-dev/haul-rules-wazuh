<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6546 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 6dd2fcf6-1390-51ee-9864-8f8c2d092f31 -->
  <rule id="998684" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6546 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>