<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0863 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: b886443d-b6c3-5577-99ac-fedf2d02e562 -->
  <rule id="388644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0863 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>