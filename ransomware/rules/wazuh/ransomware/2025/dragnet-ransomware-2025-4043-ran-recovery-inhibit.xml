<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4043 — Recovery Inhibition (radiant) | Status: experimental | Sigma ID: cf6f8538-1a04-59e3-98bf-656105c7b43e -->
  <rule id="723185" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4043 — Recovery Inhibition (radiant)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>