<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3267 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d1cbafae-7078-5abd-95db-ea69ca4b33de -->
  <rule id="637359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3267 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>