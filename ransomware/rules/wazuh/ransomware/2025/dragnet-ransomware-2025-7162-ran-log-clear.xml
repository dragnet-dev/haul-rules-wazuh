<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7162 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: f7ff6fbd-2b89-5c4b-ab56-4643dcef3f76 -->
  <rule id="271631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7162 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>