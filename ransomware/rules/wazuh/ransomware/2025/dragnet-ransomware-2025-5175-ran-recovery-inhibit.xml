<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5175 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 9c237176-2aef-5481-a4bb-ffb2e8c78902 -->
  <rule id="762371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5175 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>