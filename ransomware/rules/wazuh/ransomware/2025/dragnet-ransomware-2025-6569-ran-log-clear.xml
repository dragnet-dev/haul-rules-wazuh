<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6569 — Event Log Clearing (rhysida) | Status: experimental | Sigma ID: ed3b0dfc-0f76-5b4c-9667-609b4a1c5bd0 -->
  <rule id="776653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6569 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>