<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0931 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 84583383-b6a4-56f4-9bb2-83dbb9fcdd84 -->
  <rule id="458338" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0931 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>