<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5966 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: abd9f366-3346-50d4-89b9-8a0138db00aa -->
  <rule id="899993" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5966 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>