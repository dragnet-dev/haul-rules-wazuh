<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7924 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 0f844766-a7dd-5897-8a0c-195982c84371 -->
  <rule id="784476" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7924 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>