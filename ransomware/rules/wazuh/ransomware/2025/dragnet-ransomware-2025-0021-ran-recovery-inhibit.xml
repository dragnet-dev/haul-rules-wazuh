<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0021 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 237d6655-850d-5cd5-9716-3715a4e20dc8 -->
  <rule id="305665" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0021 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>