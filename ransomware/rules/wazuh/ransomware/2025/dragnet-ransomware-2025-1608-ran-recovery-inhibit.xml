<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1608 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: e5a4a470-f83e-5707-831f-d44c5d7431eb -->
  <rule id="228744" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1608 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>