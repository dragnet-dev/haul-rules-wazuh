<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0285 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 092bcd4f-313d-5303-84b7-0525370570ca -->
  <rule id="298534" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0285 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>