<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3034 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 4807d6f0-754e-5dc4-a344-663f826da9c4 -->
  <rule id="708111" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3034 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>