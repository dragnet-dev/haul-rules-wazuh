<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4965 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a9650825-cfe2-5807-8a69-3213cb97a031 -->
  <rule id="296508" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4965 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>