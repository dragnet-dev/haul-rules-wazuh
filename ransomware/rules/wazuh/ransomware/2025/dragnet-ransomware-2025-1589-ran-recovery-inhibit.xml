<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1589 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 9789b2fe-0372-5dec-993a-fa9b98ca30a3 -->
  <rule id="766352" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1589 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>