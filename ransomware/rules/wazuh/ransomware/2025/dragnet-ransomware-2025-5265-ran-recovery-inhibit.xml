<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5265 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 0927dd62-bd58-5072-a79f-9e9162e8e6a8 -->
  <rule id="675336" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5265 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>