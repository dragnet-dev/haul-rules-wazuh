<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5595 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: e18b7fef-1920-5e47-bfe4-f9dc46872bf3 -->
  <rule id="131967" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5595 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>