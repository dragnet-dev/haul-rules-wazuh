<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5554 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: bc24c3c1-f3af-58f8-bc1f-b62c3024f2d2 -->
  <rule id="411963" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5554 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>