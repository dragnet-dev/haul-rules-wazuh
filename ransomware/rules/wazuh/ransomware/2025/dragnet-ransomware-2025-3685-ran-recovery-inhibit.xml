<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3685 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 52479124-fc2b-5a9f-b89b-1734176bfbc2 -->
  <rule id="847912" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3685 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>