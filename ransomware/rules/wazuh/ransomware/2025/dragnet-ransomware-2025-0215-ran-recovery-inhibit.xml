<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0215 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 9776695b-4a24-5b31-b330-9fbb973816c0 -->
  <rule id="876695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0215 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>