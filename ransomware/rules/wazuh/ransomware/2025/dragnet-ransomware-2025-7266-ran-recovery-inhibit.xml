<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7266 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2951ca86-f3b0-5bfa-a6d0-06fb295ce205 -->
  <rule id="456588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7266 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>