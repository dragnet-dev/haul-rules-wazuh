<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0087 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: a2da298c-5d89-5859-8e20-ce1d80ea738d -->
  <rule id="933029" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0087 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>