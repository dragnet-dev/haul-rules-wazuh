<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1243 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 6792b2a9-b1c2-51ea-8d2e-bf1ad5be8904 -->
  <rule id="286832" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1243 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>