<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4968 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e8ff157c-6255-5465-84ea-11eb2b87c087 -->
  <rule id="314315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4968 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>