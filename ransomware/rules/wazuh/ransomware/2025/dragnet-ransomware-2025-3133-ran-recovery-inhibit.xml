<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3133 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 3fb7dd5d-7643-5e1a-9ef9-fbb3c72ab374 -->
  <rule id="910653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3133 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>