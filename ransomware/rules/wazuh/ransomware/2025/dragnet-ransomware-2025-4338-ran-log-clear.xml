<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4338 — Event Log Clearing (genesis) | Status: test | Sigma ID: 93096aa6-fc82-5637-8e9a-0f9735812c18 -->
  <rule id="689546" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4338 — Event Log Clearing (genesis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>