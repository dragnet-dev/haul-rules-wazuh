<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1237 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 5971f040-aa39-53b6-af3c-f2bfdbcb0073 -->
  <rule id="655104" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1237 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>