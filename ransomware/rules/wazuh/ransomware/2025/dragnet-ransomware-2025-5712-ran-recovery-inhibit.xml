<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5712 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 160b9d43-8e03-59a3-9081-a582c4023165 -->
  <rule id="615174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5712 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>