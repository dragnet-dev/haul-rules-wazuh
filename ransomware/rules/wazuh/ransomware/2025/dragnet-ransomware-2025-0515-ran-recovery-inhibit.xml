<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0515 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 659f0347-3519-5845-b804-b9354db3bbe5 -->
  <rule id="255903" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0515 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>