<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4057 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: c22aa5a7-dc75-5b87-996d-90cca641e1f9 -->
  <rule id="530025" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4057 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>