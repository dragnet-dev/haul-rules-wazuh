<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7281 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: bb2d016b-b35c-513b-9bce-43486a11abab -->
  <rule id="396501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7281 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>