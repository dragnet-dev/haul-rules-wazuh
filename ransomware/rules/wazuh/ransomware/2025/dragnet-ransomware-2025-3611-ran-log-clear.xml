<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3611 — Event Log Clearing (bert) | Status: experimental | Sigma ID: 22e84139-b266-55ee-a559-96047b60ad7d -->
  <rule id="168413" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3611 — Event Log Clearing (bert)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>