<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4738 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 9e0237f3-b09a-5d43-97fa-b703548955ae -->
  <rule id="780237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4738 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>