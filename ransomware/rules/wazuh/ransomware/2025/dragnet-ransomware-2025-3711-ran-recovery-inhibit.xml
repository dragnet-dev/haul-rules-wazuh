<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3711 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: a8d37731-285a-5c80-91cf-ac553ae1f30d -->
  <rule id="941377" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3711 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>