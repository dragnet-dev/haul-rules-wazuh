<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5846 — Event Log Clearing (gunra) | Status: experimental | Sigma ID: 46168dee-71f8-5811-9229-d6dfb376561c -->
  <rule id="219230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5846 — Event Log Clearing (gunra)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>