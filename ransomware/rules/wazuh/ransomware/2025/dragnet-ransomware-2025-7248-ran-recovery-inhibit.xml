<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7248 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 6ee01b80-9344-5e5b-8959-815f0f4d8716 -->
  <rule id="238427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7248 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>