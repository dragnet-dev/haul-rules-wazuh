<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6164 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ffbb672c-248f-58ff-aa83-a1e87d66a6a9 -->
  <rule id="346767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6164 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>