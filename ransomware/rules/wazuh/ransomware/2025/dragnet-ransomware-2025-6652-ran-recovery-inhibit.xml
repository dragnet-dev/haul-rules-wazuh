<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6652 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: f50d0a52-8477-58c5-81de-760cffe67734 -->
  <rule id="470090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6652 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>