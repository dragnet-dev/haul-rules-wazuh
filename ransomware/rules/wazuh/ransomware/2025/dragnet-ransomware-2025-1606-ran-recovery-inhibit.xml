<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1606 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 039f43bf-04c5-5195-9314-1de857799349 -->
  <rule id="223099" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1606 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>