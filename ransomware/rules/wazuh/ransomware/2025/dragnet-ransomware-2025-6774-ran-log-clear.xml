<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6774 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: 27c4a56e-c0a9-5ac4-a01c-6d0b86c8fe04 -->
  <rule id="911456" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6774 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>