<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6384 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ba080550-e810-5a6e-8609-1284b6a209f8 -->
  <rule id="160805" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6384 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>