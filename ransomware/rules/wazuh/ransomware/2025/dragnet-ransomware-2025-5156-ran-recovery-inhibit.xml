<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5156 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 59d38996-8f77-5c5d-b3f1-22a5e092f9f6 -->
  <rule id="673899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5156 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>