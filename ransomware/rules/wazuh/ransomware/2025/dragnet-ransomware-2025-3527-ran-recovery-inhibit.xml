<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3527 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: d353068d-b761-5f80-b77c-3d2ce4fca1f6 -->
  <rule id="535306" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3527 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>