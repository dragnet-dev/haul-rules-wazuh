<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1781 — Event Log Clearing (bqtlock) | Status: experimental | Sigma ID: 777a1846-6593-5dbe-9d19-a85f76f1c78b -->
  <rule id="444218" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1781 — Event Log Clearing (bqtlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>