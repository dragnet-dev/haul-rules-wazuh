<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7330 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 2f7fc049-333b-51c3-913c-beb412276aa6 -->
  <rule id="423640" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7330 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>