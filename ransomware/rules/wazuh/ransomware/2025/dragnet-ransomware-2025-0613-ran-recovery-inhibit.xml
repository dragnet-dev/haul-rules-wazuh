<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0613 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: e3da0cf0-799c-52b1-99cf-6a970d2840dd -->
  <rule id="592172" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0613 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>