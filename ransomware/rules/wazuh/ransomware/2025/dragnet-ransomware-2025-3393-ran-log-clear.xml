<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3393 — Event Log Clearing (clop) | Status: deprecated | Sigma ID: 6acd569c-831f-5e0c-8d7b-76c68f7acda8 -->
  <rule id="134156" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3393 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>