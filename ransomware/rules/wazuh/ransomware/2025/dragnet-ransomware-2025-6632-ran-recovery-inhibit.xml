<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6632 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 8d5913ee-de6d-56a7-9853-45aee90379ca -->
  <rule id="615913" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6632 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>