<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5438 — Recovery Inhibition (tridentlocker) | Status: experimental | Sigma ID: 37fe1cd7-3d9e-5bc4-abe3-61a09075f55f -->
  <rule id="756188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5438 — Recovery Inhibition (tridentlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>