<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5223 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8f5ede1b-964a-52c3-a810-7eb9d11bbcef -->
  <rule id="581566" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5223 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>