<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3880 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: dae23f6b-6df6-5c3e-bda9-4767f969dc85 -->
  <rule id="303583" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3880 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>