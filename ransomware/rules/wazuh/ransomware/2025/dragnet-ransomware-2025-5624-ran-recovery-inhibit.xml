<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5624 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 82f7216d-83b8-5417-a637-1af357e9fc9b -->
  <rule id="527721" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5624 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>