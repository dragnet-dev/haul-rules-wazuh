<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1930 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 4b3504fa-0e4f-5907-8129-583c0d577439 -->
  <rule id="456079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1930 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>