<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4452 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d5d2924b-c2c6-5a18-8537-61f4c5762fc5 -->
  <rule id="473292" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4452 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>