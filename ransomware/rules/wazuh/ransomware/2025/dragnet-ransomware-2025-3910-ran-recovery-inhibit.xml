<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3910 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: c645c4ae-ee3c-5bd2-9f27-bb3dbf040663 -->
  <rule id="323324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3910 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>