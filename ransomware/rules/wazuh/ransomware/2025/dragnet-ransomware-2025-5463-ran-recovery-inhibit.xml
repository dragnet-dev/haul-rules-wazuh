<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5463 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 1a87ff53-7ab6-59e4-96e5-13a0c392c1d6 -->
  <rule id="681275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5463 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>