<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2235 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 7058a154-22d2-5fbc-baee-37188d692cc2 -->
  <rule id="329381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2235 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>