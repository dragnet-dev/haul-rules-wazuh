<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4366 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 5f1c15ff-5a0d-5be5-8553-564eb0e7cf73 -->
  <rule id="722815" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4366 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>