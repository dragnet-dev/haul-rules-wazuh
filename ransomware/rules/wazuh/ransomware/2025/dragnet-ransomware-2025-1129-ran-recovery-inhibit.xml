<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1129 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 406f2cd3-166d-587f-84d1-221b5a6e53b5 -->
  <rule id="241804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1129 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>