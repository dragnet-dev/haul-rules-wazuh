<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7867 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: b51fe02b-52eb-5f06-b054-f4b7b607aefb -->
  <rule id="349100" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7867 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>