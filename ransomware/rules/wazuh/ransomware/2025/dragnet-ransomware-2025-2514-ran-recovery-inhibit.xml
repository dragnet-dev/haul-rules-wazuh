<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2514 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 5ff0871a-2827-5c68-9506-e26dd7a2aaa7 -->
  <rule id="735087" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2514 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>