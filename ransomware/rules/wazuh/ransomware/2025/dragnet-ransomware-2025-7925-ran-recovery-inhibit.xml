<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7925 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 66342440-85bf-5684-9edb-392b5f8cc696 -->
  <rule id="434244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7925 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>