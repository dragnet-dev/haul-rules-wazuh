<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0970 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 63b351e3-9caf-573b-9a44-381a19e9ff36 -->
  <rule id="219351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0970 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>