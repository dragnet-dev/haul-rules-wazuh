<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4078 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 3097e2b5-117d-5f61-8432-bda4ffafc270 -->
  <rule id="830603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4078 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>