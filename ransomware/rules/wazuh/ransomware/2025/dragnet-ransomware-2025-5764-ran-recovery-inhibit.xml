<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5764 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0ef7d568-9b26-5c49-b274-86feb84119a2 -->
  <rule id="336556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5764 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>