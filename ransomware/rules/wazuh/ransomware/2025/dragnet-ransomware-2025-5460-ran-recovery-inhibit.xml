<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5460 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 37c9da42-17f9-5167-b66f-48b1a55ae3ce -->
  <rule id="748762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5460 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>