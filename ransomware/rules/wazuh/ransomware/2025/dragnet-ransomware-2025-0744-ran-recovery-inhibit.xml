<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0744 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d6ccbc32-3167-5dc9-84fd-3c8326b7c8a6 -->
  <rule id="965308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0744 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>