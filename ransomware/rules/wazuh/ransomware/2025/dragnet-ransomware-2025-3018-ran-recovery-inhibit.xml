<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3018 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: bd7d047c-768a-5054-9de0-efef418bc243 -->
  <rule id="436504" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3018 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>