<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0073 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: b03b3118-ae76-5ef0-9d86-2e71058db34f -->
  <rule id="965931" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0073 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>