<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7801 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 2dd79ce4-2471-56ba-9151-629e8d1c7621 -->
  <rule id="374076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7801 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>