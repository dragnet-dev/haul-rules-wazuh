<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7834 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 9478212f-9aaf-5cd0-ae46-ab19189f54d9 -->
  <rule id="578212" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7834 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>