<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0187 — Recovery Inhibition (crazyhunter) | Status: experimental | Sigma ID: 4f46561b-b307-5700-a8b9-a2a5e4669f2e -->
  <rule id="846561" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0187 — Recovery Inhibition (crazyhunter)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>