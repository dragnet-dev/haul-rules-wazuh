<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4733 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c783d514-05ba-5e65-932c-05cedade9fef -->
  <rule id="345415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4733 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>