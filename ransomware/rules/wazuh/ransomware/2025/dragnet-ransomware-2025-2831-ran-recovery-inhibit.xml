<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2831 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: a69d4760-2997-51d1-a06a-7d4358b807b3 -->
  <rule id="911747" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2831 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>