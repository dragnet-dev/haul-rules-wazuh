<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0892 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4c2b08ab-8c77-55be-86a7-eaaa3106418e -->
  <rule id="420308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0892 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>