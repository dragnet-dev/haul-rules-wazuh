<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5248 — Recovery Inhibition (ralord) | Status: experimental | Sigma ID: 5b929c9e-e082-5969-8967-ae6769bb1f65 -->
  <rule id="670876" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5248 — Recovery Inhibition (ralord)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>