<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2291 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 25b313df-bbe6-502e-ae01-c78649bde917 -->
  <rule id="381021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2291 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>