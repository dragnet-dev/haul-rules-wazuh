<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4637 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: eeeb722b-cfbf-5252-ae6f-152f0d845b4c -->
  <rule id="816372" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4637 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>