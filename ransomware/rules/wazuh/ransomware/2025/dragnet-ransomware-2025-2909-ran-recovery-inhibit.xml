<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2909 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: 9e93da90-6bbc-51bb-b144-74ee5127f842 -->
  <rule id="568826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2909 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
