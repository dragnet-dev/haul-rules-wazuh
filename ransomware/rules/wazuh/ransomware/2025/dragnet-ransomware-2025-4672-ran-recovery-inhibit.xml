<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4672 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 76b76dff-1c35-5a09-bc3a-ba56a1333e77 -->
  <rule id="264429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4672 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>