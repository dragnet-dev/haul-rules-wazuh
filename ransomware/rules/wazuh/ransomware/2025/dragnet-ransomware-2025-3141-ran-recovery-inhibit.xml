<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3141 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: 7ea30173-9f30-5e39-b3f5-cdcfcbb462ce -->
  <rule id="326301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3141 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>