<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6538 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 7ea95056-0346-5b20-8003-350df54b6994 -->
  <rule id="326950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6538 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>