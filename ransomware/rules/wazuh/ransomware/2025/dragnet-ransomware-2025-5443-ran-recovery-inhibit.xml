<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5443 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 0753a7f9-54e6-504c-a97f-a6d9a483e9fd -->
  <rule id="229407" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5443 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>