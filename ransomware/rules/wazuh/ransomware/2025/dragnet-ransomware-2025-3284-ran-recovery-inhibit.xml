<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3284 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 51673ae5-3d53-526f-8894-7d636d857a73 -->
  <rule id="728462" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3284 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>