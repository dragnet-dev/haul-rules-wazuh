<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0652 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 29d4c840-e8c0-5ee2-b755-661874c41de4 -->
  <rule id="539684" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0652 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>