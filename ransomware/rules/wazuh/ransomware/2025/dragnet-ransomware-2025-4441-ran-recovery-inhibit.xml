<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4441 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9b5de076-1395-5269-9158-4300ba102aa4 -->
  <rule id="483020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4441 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>