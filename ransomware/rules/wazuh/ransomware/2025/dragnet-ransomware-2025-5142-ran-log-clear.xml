<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5142 — Event Log Clearing (embargo) | Status: experimental | Sigma ID: 40c14f95-9b51-58f5-8a1e-8c02f033545d -->
  <rule id="243439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5142 — Event Log Clearing (embargo)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>