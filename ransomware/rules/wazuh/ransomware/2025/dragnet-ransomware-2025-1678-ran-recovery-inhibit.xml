<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1678 — Recovery Inhibition (kraken) | Status: experimental | Sigma ID: fd8cbc42-770a-5bcd-b83f-3c40a4f80c59 -->
  <rule id="598908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1678 — Recovery Inhibition (kraken)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>