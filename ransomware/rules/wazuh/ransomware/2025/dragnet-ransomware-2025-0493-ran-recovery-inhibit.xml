<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0493 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 67260f42-1785-5b39-b054-c94fcbc6cb42 -->
  <rule id="276175" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0493 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>