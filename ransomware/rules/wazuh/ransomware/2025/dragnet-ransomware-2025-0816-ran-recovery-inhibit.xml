<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0816 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: 54e2fb46-3ea9-5d1e-aeb5-ed7272843449 -->
  <rule id="548443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0816 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>