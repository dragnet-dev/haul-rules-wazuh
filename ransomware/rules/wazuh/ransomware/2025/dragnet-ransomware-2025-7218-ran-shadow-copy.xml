<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7218 — Shadow Copy Deletion (qilin) | Status: experimental | Sigma ID: 25f730d5-76d1-5260-a0b5-f473e093b819 -->
  <rule id="451693" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7218 — Shadow Copy Deletion (qilin)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>