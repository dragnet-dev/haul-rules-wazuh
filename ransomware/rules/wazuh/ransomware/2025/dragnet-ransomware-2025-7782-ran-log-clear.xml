<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7782 — Event Log Clearing (d4rk4rmy) | Status: experimental | Sigma ID: 111d90e3-c2b0-5c6a-beb9-a5f767ce39e3 -->
  <rule id="263854" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7782 — Event Log Clearing (d4rk4rmy)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>