<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5737 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: a087f022-346d-517d-bd6d-fd2ee93902aa -->
  <rule id="814070" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5737 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>