<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3754 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 72031f3c-ad8c-536e-8d42-c832e5518bbe -->
  <rule id="352511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3754 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>