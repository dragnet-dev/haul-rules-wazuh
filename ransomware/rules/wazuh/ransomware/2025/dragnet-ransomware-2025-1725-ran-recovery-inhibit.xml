<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1725 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 67446039-e5e7-58a4-b05a-e5cc59e43025 -->
  <rule id="544603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1725 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>