<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5632 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 598a3942-a839-525c-934e-0a1e553d2892 -->
  <rule id="678394" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5632 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>