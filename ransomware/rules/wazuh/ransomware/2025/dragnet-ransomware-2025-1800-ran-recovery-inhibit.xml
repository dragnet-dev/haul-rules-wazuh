<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1800 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 6b7cc86c-dac7-54cf-8667-d939387b648a -->
  <rule id="159168" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1800 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>