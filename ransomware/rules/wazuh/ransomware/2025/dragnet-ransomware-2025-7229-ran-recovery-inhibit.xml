<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7229 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ba1b432a-cdcc-5201-9b6f-7d5825da0960 -->
  <rule id="378743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7229 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>