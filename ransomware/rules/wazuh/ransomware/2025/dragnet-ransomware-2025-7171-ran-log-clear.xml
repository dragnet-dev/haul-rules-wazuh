<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7171 — Event Log Clearing (kairos) | Status: deprecated | Sigma ID: c3ca4522-fe67-5ece-91be-dee6ddfd5a6a -->
  <rule id="569045" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7171 — Event Log Clearing (kairos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>