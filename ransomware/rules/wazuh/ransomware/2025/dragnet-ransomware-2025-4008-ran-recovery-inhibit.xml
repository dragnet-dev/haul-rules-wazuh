<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4008 — Recovery Inhibition (payoutsking) | Status: experimental | Sigma ID: c5f80da2-82c5-5723-8668-b1ff5e75c4c3 -->
  <rule id="625293" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4008 — Recovery Inhibition (payoutsking)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>