<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7270 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: aad9a3e4-f3f2-5512-865a-7bb384d77a6a -->
  <rule id="874343" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7270 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>