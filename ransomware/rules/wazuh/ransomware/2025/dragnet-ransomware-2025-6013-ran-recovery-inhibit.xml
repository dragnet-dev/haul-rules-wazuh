<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6013 — Recovery Inhibition (d4rk4rmy) | Status: experimental | Sigma ID: 7e8f4577-af8f-5cea-b7ea-e1a9e5ba46e6 -->
  <rule id="330345" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6013 — Recovery Inhibition (d4rk4rmy)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>