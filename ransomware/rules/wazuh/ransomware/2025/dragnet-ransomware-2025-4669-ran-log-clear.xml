<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4669 — Event Log Clearing (lockbit5) | Status: experimental | Sigma ID: c0b65df1-3f33-5fc5-8eb6-cb999b145bd8 -->
  <rule id="490653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4669 — Event Log Clearing (lockbit5)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>