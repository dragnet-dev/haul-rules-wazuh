<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1610 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 328dc7f3-d1ac-5886-85b3-b3171744e0f5 -->
  <rule id="970207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1610 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>