<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5115 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 2af6eaf9-ef0e-5ebe-ae89-3cbc093a7912 -->
  <rule id="960490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5115 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>