<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6591 — Event Log Clearing (cicada3301) | Status: experimental | Sigma ID: ef839ae9-0bb3-516f-bb56-58c8db29dd7b -->
  <rule id="337434" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6591 — Event Log Clearing (cicada3301)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>