<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7055 — Recovery Inhibition (d4rk4rmy) | Status: experimental | Sigma ID: bfa1dc17-e38d-53ed-b317-d4019a10b7a5 -->
  <rule id="749436" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7055 — Recovery Inhibition (d4rk4rmy)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>