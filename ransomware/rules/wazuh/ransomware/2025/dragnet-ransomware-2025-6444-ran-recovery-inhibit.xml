<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6444 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: bded8703-7d87-5622-98f5-41c9ea951eb6 -->
  <rule id="462187" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6444 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>