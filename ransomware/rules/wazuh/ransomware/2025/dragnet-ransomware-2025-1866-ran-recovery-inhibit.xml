<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1866 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 313f2027-e86b-54bd-b1f9-bc5534b5e50b -->
  <rule id="623202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1866 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>