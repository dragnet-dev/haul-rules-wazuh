<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2300 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: cb7b39d7-2e52-552c-9439-d573753cb17e -->
  <rule id="660339" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2300 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>