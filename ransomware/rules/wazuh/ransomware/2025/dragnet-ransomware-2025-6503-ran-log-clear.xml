<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6503 — Event Log Clearing (clop) | Status: deprecated | Sigma ID: 42cc8cfc-88ca-5eb7-a28d-f140b48ec4ed -->
  <rule id="953100" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6503 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>