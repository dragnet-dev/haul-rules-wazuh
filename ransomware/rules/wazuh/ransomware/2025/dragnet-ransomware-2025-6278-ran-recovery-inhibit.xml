<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6278 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 4cce2200-22cf-5c61-a4fb-7d6d1e555d2b -->
  <rule id="266222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6278 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>