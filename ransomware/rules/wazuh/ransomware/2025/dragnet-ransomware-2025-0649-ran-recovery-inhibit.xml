<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0649 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 275ab476-8fb3-5412-9738-b10b66f4a435 -->
  <rule id="857147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0649 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>