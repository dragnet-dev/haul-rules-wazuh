<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5609 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 169bbae8-fb8d-5fdc-9fc9-1710bd65eff3 -->
  <rule id="423630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5609 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>