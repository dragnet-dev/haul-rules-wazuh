<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0271 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 0b0e9631-5158-5a83-a168-85292e014c00 -->
  <rule id="974963" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0271 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>