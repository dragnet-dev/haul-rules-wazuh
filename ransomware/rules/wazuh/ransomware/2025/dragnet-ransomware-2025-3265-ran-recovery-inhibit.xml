<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3265 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 3ab8f63d-3586-5185-974a-148d5e14373d -->
  <rule id="703836" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3265 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>