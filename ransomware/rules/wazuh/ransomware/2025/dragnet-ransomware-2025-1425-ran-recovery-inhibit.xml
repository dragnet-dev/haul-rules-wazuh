<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1425 — Recovery Inhibition (gunra) | Status: experimental | Sigma ID: 59e68232-2401-57b6-b154-e298b903ff59 -->
  <rule id="686823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1425 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>