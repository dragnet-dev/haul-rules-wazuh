<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7050 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: fa81a5fb-9af5-5abf-84ad-466591cdcdff -->
  <rule id="513065" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7050 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>