<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7885 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: d2a8cef0-7f62-567c-aee6-51775166cdc9 -->
  <rule id="134574" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7885 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>