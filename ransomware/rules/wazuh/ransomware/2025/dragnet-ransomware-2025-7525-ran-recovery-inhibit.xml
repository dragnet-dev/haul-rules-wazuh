<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7525 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 64689a0c-7329-5d68-80a0-d13024c1eabd -->
  <rule id="235034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7525 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>