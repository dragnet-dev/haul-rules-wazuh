<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2298 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 852e74a1-b4e7-5196-8530-f648339625f4 -->
  <rule id="564674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2298 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>