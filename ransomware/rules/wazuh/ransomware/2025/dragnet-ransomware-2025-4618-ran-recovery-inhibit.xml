<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4618 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: ad9ce1a7-27d0-55b4-aae6-3c72cbe6f58e -->
  <rule id="953901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4618 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>