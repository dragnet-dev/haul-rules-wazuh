<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3449 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f48ef570-ef7f-5995-a1de-196141628660 -->
  <rule id="465275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3449 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>