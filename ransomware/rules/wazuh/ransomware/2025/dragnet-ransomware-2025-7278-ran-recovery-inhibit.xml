<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7278 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: d8499317-118f-5a0a-9866-31a143f3bc93 -->
  <rule id="584993" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7278 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>