<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1400 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 3c7c07cc-639a-5044-aa09-c79d4f8f59a6 -->
  <rule id="358524" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1400 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>