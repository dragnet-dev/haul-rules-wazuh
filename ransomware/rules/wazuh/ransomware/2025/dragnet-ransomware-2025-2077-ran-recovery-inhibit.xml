<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2077 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: cc68f2a2-4d33-564b-9378-c821c897c851 -->
  <rule id="675032" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2077 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>