<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3801 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 76f2a36f-7dd6-50ba-81f9-1ff3b0059130 -->
  <rule id="270023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3801 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>