<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4340 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 23cd3a23-dc40-52d5-a566-8dff870fe79d -->
  <rule id="849382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4340 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>