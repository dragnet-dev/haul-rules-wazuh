<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5277 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4dd8941a-18c0-593e-b6ce-16442000b357 -->
  <rule id="445894" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5277 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
