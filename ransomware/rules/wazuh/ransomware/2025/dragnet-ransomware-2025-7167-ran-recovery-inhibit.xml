<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7167 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 36a51192-b474-5d5c-977b-8f800e9d257c -->
  <rule id="565119" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7167 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>