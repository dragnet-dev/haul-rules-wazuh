<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5662 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: ef73f1bb-b9d5-5d17-9b04-1ab7f3274715 -->
  <rule id="335831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5662 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>