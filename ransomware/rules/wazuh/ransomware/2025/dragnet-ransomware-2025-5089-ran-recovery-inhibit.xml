<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5089 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 960812cc-e7b6-5121-ad7c-1869e71a663a -->
  <rule id="173004" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5089 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>