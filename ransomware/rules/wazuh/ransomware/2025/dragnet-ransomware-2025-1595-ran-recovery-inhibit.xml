<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1595 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: aa76f90c-7afd-5826-acca-e454d8b83d62 -->
  <rule id="132319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1595 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>