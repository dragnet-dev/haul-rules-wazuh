<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0541 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: 5bf839f7-5932-5848-985f-66b5ec5146d5 -->
  <rule id="671839" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0541 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>