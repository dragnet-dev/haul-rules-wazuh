<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7111 — Event Log Clearing (flocker) | Status: experimental | Sigma ID: 08f31d5f-9525-5c33-a604-b60f273fc9e5 -->
  <rule id="593095" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7111 — Event Log Clearing (flocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>