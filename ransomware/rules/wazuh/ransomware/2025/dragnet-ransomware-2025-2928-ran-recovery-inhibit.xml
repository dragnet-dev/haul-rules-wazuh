<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2928 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 941f7b00-f525-5604-8e2c-b1a1c68395b6 -->
  <rule id="711483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2928 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>