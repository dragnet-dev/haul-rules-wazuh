<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0361 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 89a137a9-f6da-5a35-aa21-6e48840d7bc7 -->
  <rule id="634137" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0361 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>