<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2848 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 6eb68802-726e-5ebd-b704-de82ff559611 -->
  <rule id="971688" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2848 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>