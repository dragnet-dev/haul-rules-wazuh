<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2207 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: d44829e4-1ed8-5b52-80c0-6ac131252c39 -->
  <rule id="544829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2207 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>