<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3504 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 3bf176ab-17b1-5a23-a498-21237ee0ba4f -->
  <rule id="146826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3504 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>