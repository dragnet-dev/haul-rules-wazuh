<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0947 — Event Log Clearing (pear) | Status: experimental | Sigma ID: 0f3e654a-ed6f-50bf-ae0c-61e6596a3c25 -->
  <rule id="762654" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0947 — Event Log Clearing (pear)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>