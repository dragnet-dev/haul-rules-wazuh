<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5348 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: e933c216-d7bc-596e-b799-505b2bd254df -->
  <rule id="689402" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5348 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>