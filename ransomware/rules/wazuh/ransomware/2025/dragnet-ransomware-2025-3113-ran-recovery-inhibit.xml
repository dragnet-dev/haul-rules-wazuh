<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3113 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 4db34dfc-f6f5-55b4-92e2-da1a25f67ff5 -->
  <rule id="289357" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3113 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>