<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6687 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: b3a99677-9e3e-51af-8cec-373ea45f6dd5 -->
  <rule id="118996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6687 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>