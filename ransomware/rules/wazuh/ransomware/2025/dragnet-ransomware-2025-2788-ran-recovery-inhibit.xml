<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2788 — Recovery Inhibition (blackshrantac) | Status: experimental | Sigma ID: e59fe3ea-3697-54d5-ae6d-4d492ffb87e4 -->
  <rule id="237583" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2788 — Recovery Inhibition (blackshrantac)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>