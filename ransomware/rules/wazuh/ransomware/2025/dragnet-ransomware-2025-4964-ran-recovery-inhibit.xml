<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4964 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1345fbd1-451c-5c87-8851-ed15b822f722 -->
  <rule id="213149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4964 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>