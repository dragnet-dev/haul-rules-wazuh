<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5125 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 757408b3-94c7-56fe-af0b-41c7808f5145 -->
  <rule id="518539" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5125 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>