<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2852 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 6ee0ec4a-dd34-5709-bc80-6ad28bd5e19a -->
  <rule id="141676" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2852 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>