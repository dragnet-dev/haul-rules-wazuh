<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6913 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 75219f15-84d1-527d-97b0-8d3e24596006 -->
  <rule id="403519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6913 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>