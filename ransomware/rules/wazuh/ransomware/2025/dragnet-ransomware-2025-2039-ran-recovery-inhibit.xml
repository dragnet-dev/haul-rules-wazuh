<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2039 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b0266383-aa8e-5a94-9c94-d120c7fa1ee3 -->
  <rule id="302663" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2039 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>