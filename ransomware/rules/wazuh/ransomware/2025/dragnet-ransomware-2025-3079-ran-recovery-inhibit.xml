<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3079 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0c932802-1bd5-5018-a0e9-1d4270a197c8 -->
  <rule id="493280" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3079 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>