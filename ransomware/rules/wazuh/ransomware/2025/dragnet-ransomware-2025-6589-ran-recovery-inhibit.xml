<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6589 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 5453fa9c-7dff-5ad3-8c53-1abe2c430fd6 -->
  <rule id="596218" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6589 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>