<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5173 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 4c049d1e-f824-566d-9cac-8ce7b917d2b0 -->
  <rule id="416797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5173 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>