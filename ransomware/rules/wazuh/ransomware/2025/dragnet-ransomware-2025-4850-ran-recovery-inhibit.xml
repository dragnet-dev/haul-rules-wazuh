<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4850 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0e3c0387-dcbb-54f6-b6a2-55ec789a9de9 -->
  <rule id="600038" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4850 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>