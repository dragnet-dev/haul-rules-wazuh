<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7659 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: cd2e6d0a-5ba3-58d1-a3c3-b12245407fe7 -->
  <rule id="855469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7659 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>