<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2068 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 177f94b3-deba-5923-b535-81621096d280 -->
  <rule id="156715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2068 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>