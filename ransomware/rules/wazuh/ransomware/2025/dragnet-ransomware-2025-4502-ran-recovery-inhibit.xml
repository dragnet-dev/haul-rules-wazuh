<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4502 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: a99c2a61-f07c-52b6-b0d2-72de9415efbf -->
  <rule id="215402" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4502 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>