<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7197 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 40264cdf-9ba3-509d-8573-b63959647acd -->
  <rule id="507789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7197 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>