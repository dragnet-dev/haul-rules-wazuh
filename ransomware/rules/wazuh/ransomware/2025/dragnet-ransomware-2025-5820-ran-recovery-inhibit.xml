<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5820 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 870d395d-ea67-5980-9ad4-dc0ad16c51a9 -->
  <rule id="593339" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5820 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>