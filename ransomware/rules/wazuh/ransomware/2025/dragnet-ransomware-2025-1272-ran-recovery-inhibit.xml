<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1272 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: a4d3b78e-9cd0-5406-ae17-94dd41cf6bb5 -->
  <rule id="983797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1272 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>