<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6970 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: ef434138-3f53-59b1-8853-bc032b003862 -->
  <rule id="694341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6970 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>