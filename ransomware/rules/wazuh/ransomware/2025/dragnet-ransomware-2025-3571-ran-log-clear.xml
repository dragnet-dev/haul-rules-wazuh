<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3571 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 82c21aaf-82fd-5b8d-ba86-7ade34361d9b -->
  <rule id="418746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3571 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>