<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2853 — Event Log Clearing (spacebears) | Status: experimental | Sigma ID: f7746a7b-ccca-57cd-a318-d1dd1d241def -->
  <rule id="823946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2853 — Event Log Clearing (spacebears)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>