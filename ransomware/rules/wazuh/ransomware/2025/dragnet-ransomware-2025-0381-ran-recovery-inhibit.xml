<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0381 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 39e8c445-fe4e-5074-a4ac-2078f7b98fd5 -->
  <rule id="222204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0381 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>