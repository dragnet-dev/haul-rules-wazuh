<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6328 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 131928e4-ee47-5469-95c8-1aa428b76693 -->
  <rule id="410862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6328 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>