<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3465 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 837b241b-7149-5a78-b3be-cc440ac90c3e -->
  <rule id="540324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3465 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>