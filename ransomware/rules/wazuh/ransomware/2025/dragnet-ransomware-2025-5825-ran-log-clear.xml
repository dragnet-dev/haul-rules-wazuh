<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5825 — Event Log Clearing (cactus) | Status: experimental | Sigma ID: 3d688a6f-84cf-5aca-8ae1-52b1cb8ab642 -->
  <rule id="970186" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5825 — Event Log Clearing (cactus)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>