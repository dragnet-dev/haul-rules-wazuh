<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3377 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 37aae35d-5005-516e-96c7-a50ec8ea05bb -->
  <rule id="742863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3377 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>