<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5752 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 772b8eb7-ab52-58d3-afcd-804f8a2ff30f -->
  <rule id="278222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5752 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>