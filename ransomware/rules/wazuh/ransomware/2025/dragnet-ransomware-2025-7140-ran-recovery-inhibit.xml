<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7140 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 6a09d07e-3b25-5793-97a6-0f7bbe27056c -->
  <rule id="897570" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7140 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>