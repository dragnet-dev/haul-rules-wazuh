<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4312 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0d9a2dc0-26a8-5b67-b5c5-f9ee3ae78aea -->
  <rule id="419772" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4312 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>