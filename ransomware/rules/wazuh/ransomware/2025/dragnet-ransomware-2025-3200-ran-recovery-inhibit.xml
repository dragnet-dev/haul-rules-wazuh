<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3200 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 44918c17-7bf7-5ec7-8780-e67b0be8ac63 -->
  <rule id="987001" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3200 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>