<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2968 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: fcc35d78-983d-5a6c-8f94-1d88b0b20f36 -->
  <rule id="270973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2968 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>