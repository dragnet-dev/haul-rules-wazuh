<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3455 — Event Log Clearing (GDLockerSec) | Status: experimental | Sigma ID: 75177ee3-a403-5382-9ee5-1702e3d90485 -->
  <rule id="402846" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3455 — Event Log Clearing (GDLockerSec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>