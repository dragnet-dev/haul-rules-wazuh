<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0778 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: b2661302-41fe-52bd-a21a-675d8e116dae -->
  <rule id="326613" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0778 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>