<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3664 — Recovery Inhibition (d4rk4rmy) | Status: experimental | Sigma ID: ac3a16e4-fe27-5755-8621-c5e19faa9399 -->
  <rule id="157816" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3664 — Recovery Inhibition (d4rk4rmy)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>