<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5801 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d0fe0f92-8773-55de-a6e4-68b770eb771d -->
  <rule id="965455" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5801 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>