<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6389 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: e25b9819-5e1a-5e2c-878f-6244d443e7bc -->
  <rule id="581198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6389 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>