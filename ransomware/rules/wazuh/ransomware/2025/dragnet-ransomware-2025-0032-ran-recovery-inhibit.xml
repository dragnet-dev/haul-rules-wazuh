<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0032 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 1439fb34-0567-520d-aaa0-1114f1566032 -->
  <rule id="186353" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0032 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>