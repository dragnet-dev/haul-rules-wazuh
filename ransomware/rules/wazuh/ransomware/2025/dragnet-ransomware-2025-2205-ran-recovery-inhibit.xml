<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2205 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: f9dc147f-3b19-5710-bdd2-ffbd3e40b5d8 -->
  <rule id="592414" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2205 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>