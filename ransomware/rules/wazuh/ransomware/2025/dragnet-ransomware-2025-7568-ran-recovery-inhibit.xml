<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7568 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 97e23cec-4ccf-514c-afc2-2d6d1da81129 -->
  <rule id="805980" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7568 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>