<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7162 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: b3c864b3-bdcd-5077-b8d3-b6f5461513cb -->
  <rule id="120864" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7162 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>