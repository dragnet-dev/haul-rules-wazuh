<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5900 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: ba7aca84-5396-5201-883e-1a7379b4365b -->
  <rule id="549994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5900 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>