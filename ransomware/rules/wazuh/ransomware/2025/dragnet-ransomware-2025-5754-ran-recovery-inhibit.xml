<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5754 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: dd413532-d973-5838-9b02-979b154dcfdf -->
  <rule id="514135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5754 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>