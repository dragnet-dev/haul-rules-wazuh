<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5998 — Recovery Inhibition (desolator) | Status: experimental | Sigma ID: a7320717-5f06-5ac0-bcee-d3716c5fe4d2 -->
  <rule id="273207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5998 — Recovery Inhibition (desolator)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>