<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6510 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 384ccd9a-c787-598b-b8e4-e473447900e5 -->
  <rule id="776141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6510 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>