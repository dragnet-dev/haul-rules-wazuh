<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6879 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: a51d10a7-ccfe-5eff-a865-870eee099094 -->
  <rule id="882910" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6879 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>