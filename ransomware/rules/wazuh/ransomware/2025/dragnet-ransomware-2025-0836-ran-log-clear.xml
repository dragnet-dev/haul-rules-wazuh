<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0836 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: eba3b9ea-dee5-5f4b-8679-6b5d353cd0b1 -->
  <rule id="732599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0836 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>