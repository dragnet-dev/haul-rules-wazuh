<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4252 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5f4b1529-ed28-5ccc-bdde-2ec98fc71578 -->
  <rule id="727515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4252 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>