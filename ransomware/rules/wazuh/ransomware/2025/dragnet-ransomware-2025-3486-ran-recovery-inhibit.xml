<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3486 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 78af07f4-889b-50f8-993c-306c76bf3388 -->
  <rule id="314307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3486 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>