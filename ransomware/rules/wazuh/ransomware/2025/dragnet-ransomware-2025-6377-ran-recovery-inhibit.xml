<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6377 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 070cb4ad-b791-56b1-93c3-a2b59256ec2f -->
  <rule id="299754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6377 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>