<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5696 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: b1344800-6eea-55a0-84eb-357a7e0debff -->
  <rule id="313448" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5696 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>