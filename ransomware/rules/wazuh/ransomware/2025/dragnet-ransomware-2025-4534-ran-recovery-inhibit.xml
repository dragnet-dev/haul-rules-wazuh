<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4534 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 97f05a7c-e236-5284-b17f-16510f3bd2c1 -->
  <rule id="807290" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4534 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>