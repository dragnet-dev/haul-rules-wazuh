<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4215 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: abd345a7-32a4-577f-a05a-bab745e4fa92 -->
  <rule id="149345" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4215 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>