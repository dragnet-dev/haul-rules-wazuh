<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4663 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 083fe22d-0715-5503-8d3d-45d12705497f -->
  <rule id="450222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4663 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>