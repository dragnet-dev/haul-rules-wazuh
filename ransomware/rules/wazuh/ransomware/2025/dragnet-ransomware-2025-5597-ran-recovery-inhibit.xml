<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5597 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 56ac8625-d442-5baa-902b-4cc1a1bc5c5c -->
  <rule id="650886" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5597 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>