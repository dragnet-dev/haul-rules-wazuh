<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0545 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f2bd06d1-2a95-58ca-8477-3962358201f0 -->
  <rule id="410106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0545 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>