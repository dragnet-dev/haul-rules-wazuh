<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3912 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 67e2fa56-3f55-5197-b3d3-8ed5b824165c -->
  <rule id="180922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3912 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>