<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0330 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: a233767f-e477-5696-a36e-18fcf9090f4e -->
  <rule id="223376" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0330 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>