<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1148 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: e512d489-7ed4-5378-b525-06fe3dc4b9b7 -->
  <rule id="622054" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1148 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>