<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5203 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 48afb54c-0142-5914-a1a3-8f629029583d -->
  <rule id="294195" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5203 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>