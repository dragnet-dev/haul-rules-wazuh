<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6675 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 668f0fa6-12eb-5c40-80e4-9cbdc2276679 -->
  <rule id="912495" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6675 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>