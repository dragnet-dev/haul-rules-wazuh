<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1886 — Recovery Inhibition (radar) | Status: experimental | Sigma ID: 79efaea0-e374-57b8-acdd-61884d131ca9 -->
  <rule id="838702" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1886 — Recovery Inhibition (radar)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>