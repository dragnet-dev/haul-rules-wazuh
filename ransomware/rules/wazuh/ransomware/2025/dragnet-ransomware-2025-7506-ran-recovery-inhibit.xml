<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7506 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0992423b-7e30-593b-aa58-c970ad99ac4c -->
  <rule id="678779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7506 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>