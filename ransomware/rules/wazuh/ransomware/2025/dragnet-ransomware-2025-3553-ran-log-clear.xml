<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3553 — Event Log Clearing (lockbit5) | Status: experimental | Sigma ID: 81a4a6cd-6d74-5946-a4b6-7a7e3434e3bc -->
  <rule id="390346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3553 — Event Log Clearing (lockbit5)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>