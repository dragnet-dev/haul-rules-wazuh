<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4754 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 05360ef2-96b1-5fbc-b332-dc4cf7b67f4f -->
  <rule id="572399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4754 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>