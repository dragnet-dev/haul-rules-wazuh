<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6837 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 7ec64730-7ac3-57e1-a380-d03258a71307 -->
  <rule id="328647" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6837 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>