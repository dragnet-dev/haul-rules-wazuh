<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6683 — Event Log Clearing (obscura) | Status: deprecated | Sigma ID: 8ad01ddd-b847-57f4-a2a6-6f624cccf9a2 -->
  <rule id="953629" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6683 — Event Log Clearing (obscura)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>