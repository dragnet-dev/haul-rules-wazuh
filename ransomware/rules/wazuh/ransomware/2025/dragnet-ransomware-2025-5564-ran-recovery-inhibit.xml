<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5564 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a7f61122-facf-5696-9da2-0c1563f56199 -->
  <rule id="927611" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5564 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>