<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0562 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 0b2e2ff5-47f5-503f-827a-566b9dded7f5 -->
  <rule id="224127" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0562 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>