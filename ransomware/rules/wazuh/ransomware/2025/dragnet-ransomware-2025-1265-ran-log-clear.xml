<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1265 — Event Log Clearing (payoutsking) | Status: experimental | Sigma ID: 4a1d049f-5355-53a8-9669-b84ebfdc406f -->
  <rule id="386904" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1265 — Event Log Clearing (payoutsking)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>