<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4789 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: e9b479fe-e14f-598e-8ace-8da3619a1a92 -->
  <rule id="695479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4789 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>