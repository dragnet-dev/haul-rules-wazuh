<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7535 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8fc84308-47d9-5a8a-84e1-37892b9675d3 -->
  <rule id="600843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7535 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>