<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7254 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7e980f43-e507-54e5-92c8-2c6e3a25ad55 -->
  <rule id="331695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7254 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>