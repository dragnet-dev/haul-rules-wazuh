<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3445 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: f5509180-3ac0-562f-9005-5648482e048d -->
  <rule id="755091" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3445 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>