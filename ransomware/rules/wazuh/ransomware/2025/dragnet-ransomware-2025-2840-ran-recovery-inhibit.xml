<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2840 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1bf67236-75b6-5bb2-8e4f-49b8a7d03022 -->
  <rule id="976723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2840 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>