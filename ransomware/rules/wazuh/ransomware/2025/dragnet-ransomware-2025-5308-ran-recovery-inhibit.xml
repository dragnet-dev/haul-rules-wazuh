<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5308 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: b9f9859f-1429-5dac-a2a4-d0342f10da20 -->
  <rule id="219985" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5308 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>