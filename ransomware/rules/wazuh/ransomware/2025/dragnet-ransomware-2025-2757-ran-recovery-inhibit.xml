<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2757 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 96b04ff1-b8e6-5bc3-b112-03bfe3cce32f -->
  <rule id="775279" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2757 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>