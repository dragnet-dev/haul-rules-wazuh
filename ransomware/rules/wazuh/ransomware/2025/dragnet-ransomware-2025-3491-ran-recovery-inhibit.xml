<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3491 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: aa46d13f-4a18-504f-b144-d42560ec4018 -->
  <rule id="127491" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3491 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>