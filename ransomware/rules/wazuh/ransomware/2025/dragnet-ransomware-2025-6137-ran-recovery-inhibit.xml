<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6137 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 448f46db-27f9-597c-a6ae-87aa1b7ed40a -->
  <rule id="793549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6137 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>