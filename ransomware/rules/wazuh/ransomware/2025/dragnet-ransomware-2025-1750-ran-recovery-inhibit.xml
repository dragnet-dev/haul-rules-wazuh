<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1750 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 31efd27c-9b6e-5a43-a1aa-2fed4665766d -->
  <rule id="508132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1750 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>