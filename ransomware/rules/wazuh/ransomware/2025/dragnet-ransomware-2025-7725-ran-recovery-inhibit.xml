<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7725 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: dd6539a0-4203-5464-b744-354a05ee4e67 -->
  <rule id="516539" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7725 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>