<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0170 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 7770d508-e71c-54f5-89d3-7c682279d6f6 -->
  <rule id="443335" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0170 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>