<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0108 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 5ab298b2-ad07-5cba-8f19-36aece9bf637 -->
  <rule id="651298" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0108 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>