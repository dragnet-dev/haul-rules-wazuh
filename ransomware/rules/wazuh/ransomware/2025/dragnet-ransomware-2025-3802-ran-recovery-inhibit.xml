<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3802 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3883d0f3-6cd4-5db1-be89-bb101bcc5a97 -->
  <rule id="142575" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3802 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>