<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1984 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 1dab5ef5-550a-5a9b-9d30-521f5f233298 -->
  <rule id="415294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1984 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>