<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6182 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 4c3e29d0-60c6-514f-9976-ca799c55230f -->
  <rule id="422229" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6182 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>