<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2034 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 30cbe2b8-588e-5494-9fa4-67c62b6dd9fd -->
  <rule id="461422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2034 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>