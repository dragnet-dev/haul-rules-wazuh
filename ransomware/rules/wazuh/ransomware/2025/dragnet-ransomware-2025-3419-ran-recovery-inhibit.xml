<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3419 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8ecac7bd-27f1-5b45-9067-f862aa1f9ea1 -->
  <rule id="548767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3419 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>