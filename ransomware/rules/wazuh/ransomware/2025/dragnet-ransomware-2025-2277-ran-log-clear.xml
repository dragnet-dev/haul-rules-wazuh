<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2277 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: 92bd2d56-d63d-5f7e-b9ee-3bea9a340e49 -->
  <rule id="298605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2277 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>