<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3865 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 583a0df1-ebc7-5449-86f3-1d429b40c632 -->
  <rule id="694093" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3865 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>