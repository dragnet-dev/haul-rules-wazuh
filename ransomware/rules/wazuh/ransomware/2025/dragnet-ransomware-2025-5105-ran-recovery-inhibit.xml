<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5105 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b6490e36-69cc-56f1-a6bd-b1643ee6d4a5 -->
  <rule id="163854" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5105 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>