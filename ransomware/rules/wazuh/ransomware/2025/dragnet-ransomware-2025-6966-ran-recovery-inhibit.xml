<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6966 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: b9dce1a6-bc34-55fd-9095-450b1d0929fc -->
  <rule id="509581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6966 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>