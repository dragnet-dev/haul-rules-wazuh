<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0267 — Event Log Clearing (lynx) | Status: experimental | Sigma ID: 29f29a07-d72c-5a03-8ddb-5e10ee06f7d4 -->
  <rule id="568740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0267 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>