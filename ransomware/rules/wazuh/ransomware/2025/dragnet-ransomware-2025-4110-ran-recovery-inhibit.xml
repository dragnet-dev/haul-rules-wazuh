<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4110 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 698181d7-febf-5dbe-bef9-d4c41b93250b -->
  <rule id="470909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4110 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>