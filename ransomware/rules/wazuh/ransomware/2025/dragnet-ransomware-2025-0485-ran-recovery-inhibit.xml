<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0485 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: 6ead4c71-379e-5f6a-a579-2943df8402dc -->
  <rule id="133356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0485 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>