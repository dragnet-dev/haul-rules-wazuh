<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1847 — Recovery Inhibition (brotherhood) | Status: experimental | Sigma ID: d38bc993-d7b3-5ee7-b06c-209e63f79b42 -->
  <rule id="827169" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1847 — Recovery Inhibition (brotherhood)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
