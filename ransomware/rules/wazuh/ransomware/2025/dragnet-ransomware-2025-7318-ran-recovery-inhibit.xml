<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7318 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1851114b-2b97-5d76-ad68-d7a8fd8d87c9 -->
  <rule id="151114" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7318 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>