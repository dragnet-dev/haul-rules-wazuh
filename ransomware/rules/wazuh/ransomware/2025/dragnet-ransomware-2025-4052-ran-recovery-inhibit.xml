<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4052 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 95421a0f-4d7e-529a-8b56-df2e35fcc4de -->
  <rule id="726746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4052 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>