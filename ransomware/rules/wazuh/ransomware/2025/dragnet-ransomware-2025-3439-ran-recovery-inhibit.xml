<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3439 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6c379136-9336-518d-8bdd-dbd5caaf5055 -->
  <rule id="283791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3439 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>