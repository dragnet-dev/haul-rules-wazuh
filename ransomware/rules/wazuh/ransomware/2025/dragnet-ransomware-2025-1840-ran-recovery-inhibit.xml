<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1840 — Recovery Inhibition (gunra) | Status: experimental | Sigma ID: d946d3be-0fc5-56c7-9f01-2d4bc183fe27 -->
  <rule id="531493" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1840 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>