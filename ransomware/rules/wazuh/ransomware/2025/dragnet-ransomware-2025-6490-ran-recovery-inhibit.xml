<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6490 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 1b5680bc-3d01-50af-ba69-9e581212a877 -->
  <rule id="910891" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6490 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>