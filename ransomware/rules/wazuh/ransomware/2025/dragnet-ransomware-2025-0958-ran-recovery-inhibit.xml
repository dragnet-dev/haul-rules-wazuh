<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0958 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 91835619-7ce4-56a0-9726-3b0da3c37165 -->
  <rule id="283561" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0958 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>