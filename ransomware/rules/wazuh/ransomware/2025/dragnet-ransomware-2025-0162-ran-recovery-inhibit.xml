<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0162 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 2562ff24-bb59-5389-8bcb-27a63c72344b -->
  <rule id="361272" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0162 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>