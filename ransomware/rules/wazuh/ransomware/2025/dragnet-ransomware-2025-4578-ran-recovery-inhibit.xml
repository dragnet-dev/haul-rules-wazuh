<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4578 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 5038c4e4-b684-5740-b746-5f9bdf1c28b9 -->
  <rule id="399278" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4578 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>