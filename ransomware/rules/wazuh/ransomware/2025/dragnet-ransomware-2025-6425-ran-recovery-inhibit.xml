<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6425 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7f81848b-1e07-5ec5-81dc-7bb91d572883 -->
  <rule id="478184" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6425 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>