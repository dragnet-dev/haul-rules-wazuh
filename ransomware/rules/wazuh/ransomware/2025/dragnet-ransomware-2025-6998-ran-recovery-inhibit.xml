<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6998 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7c784ed0-b056-5833-a0c5-d114b7eac188 -->
  <rule id="296558" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6998 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>