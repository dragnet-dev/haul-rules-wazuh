<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6891 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: a1e98086-c737-5582-8003-415df33b65f1 -->
  <rule id="830980" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6891 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>