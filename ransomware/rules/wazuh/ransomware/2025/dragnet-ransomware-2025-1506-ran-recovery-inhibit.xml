<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1506 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: cc8d841a-71a2-5417-b822-a74a0358eb10 -->
  <rule id="678184" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1506 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>