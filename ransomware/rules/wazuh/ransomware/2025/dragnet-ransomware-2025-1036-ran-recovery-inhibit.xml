<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1036 — Recovery Inhibition (ralord) | Status: experimental | Sigma ID: b0307084-f74e-5a37-b72a-2626acde9d87 -->
  <rule id="303070" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1036 — Recovery Inhibition (ralord)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>