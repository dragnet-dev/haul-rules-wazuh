<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7551 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: a65cca30-ab73-5447-a694-f69f82106c3e -->
  <rule id="865514" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7551 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>