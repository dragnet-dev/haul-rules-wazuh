<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4318 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: b8d7130a-7b14-5397-bbaf-fda2e056da25 -->
  <rule id="201713" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4318 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>