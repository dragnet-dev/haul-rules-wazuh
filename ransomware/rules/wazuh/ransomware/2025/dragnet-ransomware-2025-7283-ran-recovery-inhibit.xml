<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7283 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 02b9050d-2628-550f-87bc-593b8b7a24b5 -->
  <rule id="824813" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7283 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>