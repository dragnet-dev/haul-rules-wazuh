<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3655 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 5ce5a59f-b01f-5bd0-ab5b-bf8f6424c45f -->
  <rule id="678505" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3655 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>