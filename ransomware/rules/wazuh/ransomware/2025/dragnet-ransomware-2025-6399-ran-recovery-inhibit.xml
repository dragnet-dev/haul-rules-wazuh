<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6399 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 1cbca46b-74a9-5baf-97d8-020a06d046d6 -->
  <rule id="377064" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6399 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
