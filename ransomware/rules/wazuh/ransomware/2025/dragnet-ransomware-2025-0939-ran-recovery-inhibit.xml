<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0939 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 332ec143-6b49-52e2-8266-fb3c161c4c8e -->
  <rule id="522814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0939 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>