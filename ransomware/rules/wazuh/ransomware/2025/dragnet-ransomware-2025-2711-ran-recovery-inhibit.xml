<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2711 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3dc4cc01-d7a3-50c8-a5ff-7bf72e2fdb00 -->
  <rule id="830508" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2711 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>