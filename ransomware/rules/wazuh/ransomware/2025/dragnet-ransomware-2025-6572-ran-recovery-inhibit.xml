<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6572 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 417622bc-c0fb-5b15-894f-2631524e0b80 -->
  <rule id="481963" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6572 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>