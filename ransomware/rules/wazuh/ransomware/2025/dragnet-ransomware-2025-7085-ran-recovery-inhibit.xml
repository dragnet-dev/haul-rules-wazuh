<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7085 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 85898422-941f-53ca-965f-88d38532b5d7 -->
  <rule id="589842" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7085 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>