<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7666 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: dcc9dc69-82a2-550c-9a3f-012ec8e0ee5d -->
  <rule id="144444" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7666 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>