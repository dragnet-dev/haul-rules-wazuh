<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7104 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: b4d91762-cd34-58a1-a101-ff0d7f9a3ca3 -->
  <rule id="137917" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7104 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>