<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3271 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 53609259-e5cf-5d55-88ca-ef40addc724d -->
  <rule id="960925" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3271 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>