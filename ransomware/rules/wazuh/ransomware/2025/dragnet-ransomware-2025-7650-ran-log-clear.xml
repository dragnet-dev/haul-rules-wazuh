<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7650 — Event Log Clearing (tengu) | Status: experimental | Sigma ID: 41b330ce-9e29-52f8-9a8c-f6e7de7c8e12 -->
  <rule id="877292" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7650 — Event Log Clearing (tengu)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>