<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7530 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: e9ba1f9a-5dcc-56ad-95ef-59817fd9ee35 -->
  <rule id="832831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7530 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>