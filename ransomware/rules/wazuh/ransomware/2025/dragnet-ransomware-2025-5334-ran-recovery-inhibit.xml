<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5334 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 8883bc38-5920-5334-83bc-a4ea7489653a -->
  <rule id="574236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5334 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>