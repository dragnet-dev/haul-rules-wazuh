<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0869 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: 7b7d1bd7-183b-5ed9-9205-78fcfe0074e4 -->
  <rule id="568827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0869 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>