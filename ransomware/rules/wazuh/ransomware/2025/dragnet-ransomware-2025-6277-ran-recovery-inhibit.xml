<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6277 — Recovery Inhibition (securotrop) | Status: experimental | Sigma ID: 250b5a65-5ba3-52f7-8b98-f6ea3e4d8f3f -->
  <rule id="218506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6277 — Recovery Inhibition (securotrop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>