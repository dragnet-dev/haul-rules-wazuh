<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4613 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 7e657c74-0abe-58a8-8522-811050126926 -->
  <rule id="326524" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4613 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>