<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0609 — Recovery Inhibition (apos) | Status: experimental | Sigma ID: 706a6b6b-8c7a-529e-986d-70a16efccc74 -->
  <rule id="109067" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0609 — Recovery Inhibition (apos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>