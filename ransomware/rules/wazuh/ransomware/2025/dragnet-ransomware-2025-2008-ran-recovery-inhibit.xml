<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2008 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: b6521b89-540f-5ed2-adbe-dfa79998ffcb -->
  <rule id="164347" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2008 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>