<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6537 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 89756f8d-1775-5078-aa2e-4f81d7b439a8 -->
  <rule id="636111" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6537 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>