<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7410 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 28d826a8-5ded-519f-b106-5cdfbf9f4469 -->
  <rule id="289226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7410 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>