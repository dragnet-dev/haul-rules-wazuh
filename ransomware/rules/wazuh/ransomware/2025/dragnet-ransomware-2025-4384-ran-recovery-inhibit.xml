<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4384 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 94f6152f-e8a6-5ecc-8d3c-9d725f678df3 -->
  <rule id="719615" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4384 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>