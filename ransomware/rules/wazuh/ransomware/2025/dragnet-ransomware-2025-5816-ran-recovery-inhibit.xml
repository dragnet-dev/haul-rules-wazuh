<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5816 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 5dee6067-428d-5d7a-a93e-fb07e2b72448 -->
  <rule id="704660" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5816 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>