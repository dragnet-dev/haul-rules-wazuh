<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4921 — Recovery Inhibition (kraken) | Status: experimental | Sigma ID: bf2d91ff-3b8f-5f0b-b929-e60ec029741a -->
  <rule id="460591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4921 — Recovery Inhibition (kraken)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>