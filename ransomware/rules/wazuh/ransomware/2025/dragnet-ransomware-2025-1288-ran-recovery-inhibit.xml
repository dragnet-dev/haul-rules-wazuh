<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1288 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 692518b6-50db-51d6-a76d-c14ef38dfea1 -->
  <rule id="380299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1288 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>