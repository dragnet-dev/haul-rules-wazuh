<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7107 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3eb4116a-0b69-5e59-8721-4d2bfdd3b374 -->
  <rule id="203411" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7107 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>