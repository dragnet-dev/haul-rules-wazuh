<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3527 — Event Log Clearing (lockbit5) | Status: experimental | Sigma ID: 9b501b21-78d1-5473-9d48-20a4fc7d57f7 -->
  <rule id="788027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3527 — Event Log Clearing (lockbit5)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>