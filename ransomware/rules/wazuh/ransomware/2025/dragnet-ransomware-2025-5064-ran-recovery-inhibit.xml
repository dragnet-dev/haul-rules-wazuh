<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5064 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e5057390-1228-56b0-ad87-4d04b1eedb8b -->
  <rule id="650573" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5064 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>