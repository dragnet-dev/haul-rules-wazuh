<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0131 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d69f497c-1a03-59b6-b390-ad5e16bfe433 -->
  <rule id="491949" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0131 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>