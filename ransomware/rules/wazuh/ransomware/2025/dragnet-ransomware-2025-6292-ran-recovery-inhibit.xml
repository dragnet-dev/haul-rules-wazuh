<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6292 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: aa202bbd-26c4-531f-89e7-e464bfef034e -->
  <rule id="123243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6292 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>