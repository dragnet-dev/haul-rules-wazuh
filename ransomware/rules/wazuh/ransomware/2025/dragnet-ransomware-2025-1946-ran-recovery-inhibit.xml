<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1946 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: 1191e852-c7b4-563d-8b86-077a7d581154 -->
  <rule id="207085" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1946 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
