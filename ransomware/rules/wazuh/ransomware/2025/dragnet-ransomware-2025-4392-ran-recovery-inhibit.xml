<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4392 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 428c00b0-a2e1-5a62-abf0-87ea1a291c42 -->
  <rule id="276011" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4392 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>