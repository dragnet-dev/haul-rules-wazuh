<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0464 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0843a87e-c344-5ce5-8415-6584c4b0a426 -->
  <rule id="549887" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0464 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>