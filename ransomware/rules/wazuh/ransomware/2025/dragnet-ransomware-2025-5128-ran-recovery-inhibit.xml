<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5128 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 8743c7af-e9f3-51f3-8715-1cd19ff9db67 -->
  <rule id="599007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5128 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>