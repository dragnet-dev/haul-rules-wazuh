<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4609 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: b1f46905-c5ed-51a1-9ad7-a0a9a03bf59f -->
  <rule id="991469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4609 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>