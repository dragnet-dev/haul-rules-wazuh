<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7274 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 28b26e07-3ac4-5192-a3af-b1a45cedbc72 -->
  <rule id="248300" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7274 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>