<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5988 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 8b65c3c9-3c7b-556e-b9a9-0f62a1319765 -->
  <rule id="534523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5988 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>