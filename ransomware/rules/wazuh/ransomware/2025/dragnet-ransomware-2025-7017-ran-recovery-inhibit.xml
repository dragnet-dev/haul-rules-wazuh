<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7017 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 8978d3f0-5655-521d-a459-33ebeb7d8cee -->
  <rule id="636613" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7017 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>