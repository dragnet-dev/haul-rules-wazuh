<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4059 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: c8b1f6e0-7ff7-5734-8ff8-f000e461bbeb -->
  <rule id="694716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4059 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>