<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0267 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 8ab2cd20-3c63-5fed-8622-bd07c63dc672 -->
  <rule id="381357" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0267 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>