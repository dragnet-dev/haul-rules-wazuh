<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3475 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: ea7b53a6-6e41-5062-9e4c-755d06e12680 -->
  <rule id="256353" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3475 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>