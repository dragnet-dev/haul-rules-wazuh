<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0260 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a75ec700-1731-567d-8d08-ffbfa2b55d2a -->
  <rule id="154367" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0260 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>