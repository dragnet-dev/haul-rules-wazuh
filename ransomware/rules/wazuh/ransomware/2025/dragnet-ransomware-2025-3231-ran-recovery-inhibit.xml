<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3231 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 63c39715-507e-573f-96fa-011ea2909ce5 -->
  <rule id="220397" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3231 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>