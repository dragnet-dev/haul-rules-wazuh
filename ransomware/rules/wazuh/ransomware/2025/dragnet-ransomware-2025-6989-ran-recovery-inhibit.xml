<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6989 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 24d0002b-eea2-57e9-8be0-9a608267bb37 -->
  <rule id="470002" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6989 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>