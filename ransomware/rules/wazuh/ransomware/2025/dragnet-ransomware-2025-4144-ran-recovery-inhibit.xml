<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4144 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f88a5c13-d3cf-559f-a31f-3ec036066fd9 -->
  <rule id="566972" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4144 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>