<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3691 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 1b94ff92-a6d1-5c05-acf1-c370ab3bf980 -->
  <rule id="955199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3691 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>