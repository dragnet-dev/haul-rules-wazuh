<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5305 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 73f93f0c-8ee8-5697-9c80-844dac3ebf85 -->
  <rule id="194303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5305 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>