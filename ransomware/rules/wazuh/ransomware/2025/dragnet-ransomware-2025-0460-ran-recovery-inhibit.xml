<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0460 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 386c885e-df1c-5a81-92ec-804457daa6d3 -->
  <rule id="888885" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0460 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>