<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7411 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b62b27f0-2780-5245-a0b8-e883d9a9e377 -->
  <rule id="160327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7411 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>