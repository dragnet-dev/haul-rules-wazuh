<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6390 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 2fb6f8c5-3bae-51d7-9963-ad3e76985d4e -->
  <rule id="421918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6390 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>