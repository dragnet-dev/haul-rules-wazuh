<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7604 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 5464137a-c4d9-51b5-9b9f-acb3806c1d31 -->
  <rule id="164137" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7604 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>