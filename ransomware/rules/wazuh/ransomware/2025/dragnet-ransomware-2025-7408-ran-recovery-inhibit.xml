<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7408 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 2f3e4a6c-05a3-5d95-ad1e-a4ca22c7719f -->
  <rule id="413194" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7408 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>