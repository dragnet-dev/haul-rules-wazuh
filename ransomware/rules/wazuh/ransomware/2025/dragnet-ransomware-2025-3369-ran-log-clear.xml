<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3369 — Event Log Clearing (fog) | Status: experimental | Sigma ID: 77413b7b-e4a0-5a38-be5d-d9d27f0ef1b8 -->
  <rule id="438619" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3369 — Event Log Clearing (fog)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>