<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1690 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: bd5d8a5a-6552-5728-9ac3-60977b6b2d5f -->
  <rule id="453418" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1690 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>