<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2001 — Recovery Inhibition (VanHelsing) | Status: experimental | Sigma ID: 105a286c-4d4f-5c24-840c-7b84c1cc4625 -->
  <rule id="890286" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2001 — Recovery Inhibition (VanHelsing)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>