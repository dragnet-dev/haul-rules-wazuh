<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5078 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 0248980e-59ca-5ab7-82f2-4af7b443d36c -->
  <rule id="483694" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5078 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>