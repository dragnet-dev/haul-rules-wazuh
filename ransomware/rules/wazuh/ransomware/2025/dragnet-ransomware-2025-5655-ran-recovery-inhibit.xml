<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5655 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: e65c2a17-185c-519c-a15b-c0a63a5d0ced -->
  <rule id="252362" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5655 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>