<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7543 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 00e6698f-b2ca-5307-8fcf-2e5fc388c131 -->
  <rule id="647183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7543 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>