<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3352 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4b639c78-d761-53e2-9089-325fd46d0d53 -->
  <rule id="410236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3352 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>