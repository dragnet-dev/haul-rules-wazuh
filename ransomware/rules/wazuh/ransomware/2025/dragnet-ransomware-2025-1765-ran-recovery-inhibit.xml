<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1765 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 51f48642-c8c6-5fc6-873e-1951b3c389b4 -->
  <rule id="314864" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1765 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>