<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3803 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: b0197252-9541-5105-838a-f6e627e80156 -->
  <rule id="301972" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3803 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>