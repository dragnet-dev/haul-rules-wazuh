<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2959 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 34731465-88ad-5fb8-8ed1-7412a6cdb541 -->
  <rule id="873146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2959 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>