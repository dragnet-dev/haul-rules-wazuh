<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1733 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: fa98a3ac-d696-5086-90e3-3b50d7a81b6a -->
  <rule id="515783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1733 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>