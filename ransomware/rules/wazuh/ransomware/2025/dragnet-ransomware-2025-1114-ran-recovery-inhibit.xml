<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1114 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: d436dc06-c71f-5523-b187-0f6f0a108ad4 -->
  <rule id="839836" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1114 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>