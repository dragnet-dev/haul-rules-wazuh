<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6034 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 170945c0-960f-519f-8a19-2170adde87ea -->
  <rule id="135132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6034 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>