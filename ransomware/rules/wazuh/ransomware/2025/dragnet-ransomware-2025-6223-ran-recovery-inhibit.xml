<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6223 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 276ef499-9e76-53c8-9c3a-013db2489b01 -->
  <rule id="889549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6223 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>