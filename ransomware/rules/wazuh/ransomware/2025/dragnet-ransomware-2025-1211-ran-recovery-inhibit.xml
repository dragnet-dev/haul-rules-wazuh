<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1211 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6fe321f2-6da0-5e7a-9075-98d1fae54904 -->
  <rule id="990321" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1211 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>