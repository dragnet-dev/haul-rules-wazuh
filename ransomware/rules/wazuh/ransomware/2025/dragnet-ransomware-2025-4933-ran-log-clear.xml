<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4933 — Event Log Clearing (datacarry) | Status: deprecated | Sigma ID: acda62c4-5e71-5b0d-a29b-d19eda3303eb -->
  <rule id="925062" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4933 — Event Log Clearing (datacarry)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>