<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1091 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7fb62c05-464a-50d2-9fae-5037cad7c791 -->
  <rule id="669804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1091 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>