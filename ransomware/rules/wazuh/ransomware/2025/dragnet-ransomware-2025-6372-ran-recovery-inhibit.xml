<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6372 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 26d4bdc1-b2c8-519a-b4e7-f244d4409522 -->
  <rule id="299453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6372 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>