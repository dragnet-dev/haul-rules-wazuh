<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1770 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: a48577c2-0498-56c9-b002-84b93124e962 -->
  <rule id="248577" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1770 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>