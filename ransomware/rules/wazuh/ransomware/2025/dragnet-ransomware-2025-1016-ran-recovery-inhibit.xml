<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1016 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: c1fefbe5-73cb-5c7e-9088-033765762fd5 -->
  <rule id="895131" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1016 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>