<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5459 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: f3f373f3-1a54-534a-bc6e-2732599d1fe6 -->
  <rule id="763373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5459 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>