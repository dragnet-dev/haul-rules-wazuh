<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5325 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 189bb570-6365-5627-883d-e4bd88740241 -->
  <rule id="457157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5325 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>