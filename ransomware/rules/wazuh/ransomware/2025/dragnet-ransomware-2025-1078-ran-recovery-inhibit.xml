<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1078 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: d594315e-c83a-5452-841d-2a2c38ff598d -->
  <rule id="559431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1078 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>