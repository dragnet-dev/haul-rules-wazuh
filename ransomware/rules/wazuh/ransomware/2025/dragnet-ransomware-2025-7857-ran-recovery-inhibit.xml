<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7857 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6df18efc-3189-54c8-bc40-60ec51998702 -->
  <rule id="214702" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7857 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>