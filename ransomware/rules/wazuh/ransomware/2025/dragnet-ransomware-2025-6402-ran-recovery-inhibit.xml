<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6402 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 43321251-d9c2-50bf-9de1-7488785322fb -->
  <rule id="832125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6402 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>