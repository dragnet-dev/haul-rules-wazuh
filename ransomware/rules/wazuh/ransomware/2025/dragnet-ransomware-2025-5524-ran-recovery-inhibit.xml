<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5524 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6af804a6-92cb-55cd-88a3-a8e9fdfbb5c5 -->
  <rule id="911804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5524 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>