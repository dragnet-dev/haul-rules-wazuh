<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2927 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 66be90a9-eb78-56bb-b010-145f817866f1 -->
  <rule id="908690" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2927 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>