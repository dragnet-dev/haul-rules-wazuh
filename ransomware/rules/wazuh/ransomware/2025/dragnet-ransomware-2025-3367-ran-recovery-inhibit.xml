<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3367 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 2d50730c-b6cc-5c78-9157-3ac224d58682 -->
  <rule id="150730" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3367 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>