<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1868 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 42e8cc35-c52a-5b15-ac8e-77e430a970a5 -->
  <rule id="958412" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1868 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>