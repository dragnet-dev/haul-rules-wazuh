<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0324 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7fa9a432-d346-5219-8662-b396be2bee1e -->
  <rule id="668744" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0324 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>