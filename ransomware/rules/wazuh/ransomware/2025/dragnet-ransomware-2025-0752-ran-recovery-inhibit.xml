<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0752 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 090437c7-2c0c-5ae4-9436-0451f13f33dc -->
  <rule id="647004" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0752 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>