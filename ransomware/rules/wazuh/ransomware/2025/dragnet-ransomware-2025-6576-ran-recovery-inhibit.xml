<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6576 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 66ca584a-0020-5062-96f7-4fe0324abdd6 -->
  <rule id="909858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6576 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>