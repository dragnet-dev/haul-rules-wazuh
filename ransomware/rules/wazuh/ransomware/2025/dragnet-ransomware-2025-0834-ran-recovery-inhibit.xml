<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0834 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 5a4f3569-02fe-5d83-9f5a-e1fc24c76998 -->
  <rule id="647935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0834 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>