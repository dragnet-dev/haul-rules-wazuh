<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6880 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 59d058de-bb0b-5ba2-a79a-4a8d932ffa3f -->
  <rule id="112941" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6880 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>