<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3354 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 54cd5cac-15d8-5f97-9396-2e88cdbd6ce4 -->
  <rule id="544732" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3354 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>