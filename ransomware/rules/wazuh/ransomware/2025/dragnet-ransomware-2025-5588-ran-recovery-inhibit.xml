<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5588 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 22151ee6-0858-53e1-b8dc-c8502512d885 -->
  <rule id="370894" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5588 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>