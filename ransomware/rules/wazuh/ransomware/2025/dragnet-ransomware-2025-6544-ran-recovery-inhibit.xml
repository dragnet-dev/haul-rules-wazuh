<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6544 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 9c5dc63c-9607-5cd2-b7a5-420d7e6bc2eb -->
  <rule id="508606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6544 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>