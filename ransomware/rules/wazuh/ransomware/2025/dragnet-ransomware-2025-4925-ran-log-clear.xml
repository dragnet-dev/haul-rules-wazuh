<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4925 — Event Log Clearing (IMNCrew) | Status: experimental | Sigma ID: 70c18204-3096-5426-9d31-140d330bbd11 -->
  <rule id="332182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4925 — Event Log Clearing (IMNCrew)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>