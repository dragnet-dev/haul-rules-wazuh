<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0292 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 38be3747-d8bd-5e33-9fe5-375d18f4e591 -->
  <rule id="118374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0292 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>