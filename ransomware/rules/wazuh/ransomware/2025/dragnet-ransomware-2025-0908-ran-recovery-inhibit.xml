<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0908 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 8cf95efc-7c9d-52e2-89f9-818f19411ee8 -->
  <rule id="109534" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0908 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>