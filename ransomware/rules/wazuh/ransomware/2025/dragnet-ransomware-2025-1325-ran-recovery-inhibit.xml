<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1325 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: c662cde6-da94-516d-aeb0-b5142ff6379f -->
  <rule id="641677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1325 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>