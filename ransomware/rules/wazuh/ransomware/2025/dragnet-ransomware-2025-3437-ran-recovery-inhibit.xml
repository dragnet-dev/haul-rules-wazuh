<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3437 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3623a907-8806-58d8-bccf-c393cdb911fc -->
  <rule id="497890" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3437 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>