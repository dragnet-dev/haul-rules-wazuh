<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0121 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: 046ae7f0-9501-575a-bee4-94d49082062e -->
  <rule id="212127" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0121 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>