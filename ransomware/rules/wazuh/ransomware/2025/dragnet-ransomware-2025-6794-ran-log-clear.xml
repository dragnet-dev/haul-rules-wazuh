<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6794 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: cff8018f-5e2c-5e55-9b0c-b3c66a5bb9cf -->
  <rule id="727801" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6794 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>