<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5731 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 0889e075-353b-599e-bb08-031b371c8d0a -->
  <rule id="623807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5731 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>