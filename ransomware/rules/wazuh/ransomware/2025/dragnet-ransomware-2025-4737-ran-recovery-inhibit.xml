<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4737 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 9241e184-4c79-5047-a89c-e41e58a240d6 -->
  <rule id="678701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4737 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>