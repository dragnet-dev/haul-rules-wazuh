<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6547 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2a1f4225-812c-59fd-9e42-fe5fa64688ac -->
  <rule id="551422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6547 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>