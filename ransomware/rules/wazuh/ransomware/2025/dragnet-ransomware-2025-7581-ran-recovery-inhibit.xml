<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7581 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: af2ea063-94bb-58b2-ae97-b80b5039c81f -->
  <rule id="987460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7581 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>