<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4879 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: f81d022d-8181-5d91-84a9-9f91b3701f6a -->
  <rule id="830902" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4879 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>