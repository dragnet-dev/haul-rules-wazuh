<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2734 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: a3ec15c2-1c9d-560e-957a-a16d320c0fa6 -->
  <rule id="960415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2734 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>