<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7163 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a1f87006-d664-5742-b8bd-0b3a68367689 -->
  <rule id="831870" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7163 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>