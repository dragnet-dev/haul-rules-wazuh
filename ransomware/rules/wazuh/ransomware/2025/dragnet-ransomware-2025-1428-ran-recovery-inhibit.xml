<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1428 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 9dd2a204-6c43-5d68-b2a9-c7dfb1a2502d -->
  <rule id="540422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1428 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>