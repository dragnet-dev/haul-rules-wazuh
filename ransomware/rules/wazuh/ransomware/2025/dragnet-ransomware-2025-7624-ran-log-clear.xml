<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7624 — Event Log Clearing (weyhro) | Status: experimental | Sigma ID: bcd72ea6-4557-53b8-bfcf-30869b390865 -->
  <rule id="434766" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7624 — Event Log Clearing (weyhro)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>