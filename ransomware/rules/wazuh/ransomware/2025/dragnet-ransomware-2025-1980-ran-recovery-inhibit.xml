<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1980 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 76c274c3-c1c7-5c85-bdc9-87958c938d6b -->
  <rule id="428274" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1980 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>