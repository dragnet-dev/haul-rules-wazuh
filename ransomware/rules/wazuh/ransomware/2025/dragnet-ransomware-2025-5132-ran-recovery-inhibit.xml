<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5132 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 53fb4544-791d-556d-bf21-41890541ad37 -->
  <rule id="581945" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5132 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>