<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5021 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 5082639c-fafd-5ba8-9ce1-c55ed0ead51e -->
  <rule id="682639" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5021 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>