<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7486 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 611c0b42-d6ab-58ff-b112-12d665242e0d -->
  <rule id="766091" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7486 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>