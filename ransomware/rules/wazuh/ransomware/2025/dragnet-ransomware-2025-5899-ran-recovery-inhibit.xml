<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5899 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6d125f23-2c35-51de-8283-f77859959cba -->
  <rule id="946015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5899 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>