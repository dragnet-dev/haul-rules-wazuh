<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3991 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7b19220d-d855-5b87-bd9d-c9e8e1444d26 -->
  <rule id="431922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3991 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>