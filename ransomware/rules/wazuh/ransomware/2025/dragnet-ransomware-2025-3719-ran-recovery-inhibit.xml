<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3719 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: fefe4465-9115-55d1-b7ef-7cdf7537a0dd -->
  <rule id="327844" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3719 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>