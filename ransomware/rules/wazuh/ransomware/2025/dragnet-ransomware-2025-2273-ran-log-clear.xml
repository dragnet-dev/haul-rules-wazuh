<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2273 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 659e21b7-53b4-531b-8f1a-667e6bcdbb3e -->
  <rule id="255821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2273 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>