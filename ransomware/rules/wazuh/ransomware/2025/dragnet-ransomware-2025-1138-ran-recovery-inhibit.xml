<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1138 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: d47ee0f7-8a9e-5c94-9948-8516c088899b -->
  <rule id="850700" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1138 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>