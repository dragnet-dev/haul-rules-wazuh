<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5908 — Event Log Clearing (direwolf) | Status: experimental | Sigma ID: 3724e343-e516-5586-8f1c-66110b75a9c8 -->
  <rule id="659834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5908 — Event Log Clearing (direwolf)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>