<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3549 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5796e3eb-b238-53b1-842e-b455afbe0221 -->
  <rule id="540062" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3549 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>