  <rule id="218668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5701 — Recovery Inhibition (morpheus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
