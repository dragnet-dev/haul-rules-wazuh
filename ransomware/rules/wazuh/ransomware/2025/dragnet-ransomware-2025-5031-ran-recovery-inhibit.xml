<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5031 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 6749cd06-5a15-5627-aa78-f1e211ba3830 -->
  <rule id="927949" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5031 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>