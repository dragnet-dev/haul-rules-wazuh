<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6173 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: 63959ef8-fbb8-5ddb-be3c-5b4f6fe537ca -->
  <rule id="223358" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6173 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>