<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6870 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e3f59522-8386-530f-8876-92fe7d1f20f9 -->
  <rule id="603595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6870 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>