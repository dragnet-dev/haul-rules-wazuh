<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0862 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1611139a-7fca-5bc8-8299-45232edd633e -->
  <rule id="811139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0862 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>