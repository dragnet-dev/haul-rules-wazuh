<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1186 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d9cc2b61-073d-5194-bb72-0f5b86199b8f -->
  <rule id="426123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1186 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>