<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1969 — Event Log Clearing (direwolf) | Status: experimental | Sigma ID: efdcd933-71cd-55b1-a7d8-5c848ae23796 -->
  <rule id="924779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1969 — Event Log Clearing (direwolf)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>