<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4111 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: d5f6d710-1f60-59ce-8197-41a99204897e -->
  <rule id="881097" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4111 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>