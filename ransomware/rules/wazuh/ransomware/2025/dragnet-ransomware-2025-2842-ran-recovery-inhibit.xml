<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2842 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 039d7641-fee5-532d-85b0-5124861d02dc -->
  <rule id="177641" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2842 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>