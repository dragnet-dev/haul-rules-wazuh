<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6136 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8a0b92c8-f0d0-5d3b-85cc-383746c4dd0f -->
  <rule id="509192" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6136 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>