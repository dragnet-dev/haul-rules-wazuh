<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3497 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 08baf808-954f-53e6-98c9-dba90648f052 -->
  <rule id="975980" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3497 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>