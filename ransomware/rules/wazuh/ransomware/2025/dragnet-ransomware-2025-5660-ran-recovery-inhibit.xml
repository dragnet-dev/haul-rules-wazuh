<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5660 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0fef0e80-832f-529b-aebd-891dffd13df6 -->
  <rule id="326548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5660 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>