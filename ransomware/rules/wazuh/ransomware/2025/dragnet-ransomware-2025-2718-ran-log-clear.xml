<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2718 — Event Log Clearing (walocker) | Status: experimental | Sigma ID: b6e252fe-ad79-5eaa-8e38-fe6b4b8cc556 -->
  <rule id="170252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2718 — Event Log Clearing (walocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>