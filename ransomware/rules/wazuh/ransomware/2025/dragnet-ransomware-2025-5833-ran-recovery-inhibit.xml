<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5833 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: e8a54723-0d39-5eef-a351-1095f57de888 -->
  <rule id="678547" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5833 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>