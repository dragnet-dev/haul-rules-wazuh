<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6251 — Event Log Clearing (ralord) | Status: experimental | Sigma ID: 3ceeb726-d396-54bb-8ef4-65875b5ef959 -->
  <rule id="795797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6251 — Event Log Clearing (ralord)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>