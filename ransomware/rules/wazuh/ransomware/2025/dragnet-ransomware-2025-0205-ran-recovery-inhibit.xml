<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0205 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 7012c76b-cf4a-5b96-92cf-d5e6512cf571 -->
  <rule id="322047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0205 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>