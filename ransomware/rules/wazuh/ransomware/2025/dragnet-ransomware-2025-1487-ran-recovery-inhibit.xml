<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1487 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 7eac919e-75da-5c70-96b4-f032bbcae69b -->
  <rule id="642891" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1487 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>