<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0584 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8625e751-37f0-5b86-a9dd-5a752ffc6e2b -->
  <rule id="580147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0584 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>