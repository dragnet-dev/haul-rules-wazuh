<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6330 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: df8b3dd8-d800-5081-a9f7-ceca6a7bf7e2 -->
  <rule id="431101" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6330 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>