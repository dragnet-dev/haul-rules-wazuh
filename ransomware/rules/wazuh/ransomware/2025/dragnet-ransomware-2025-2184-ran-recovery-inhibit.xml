<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2184 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 071d6548-c54b-5894-baf2-4b3934cdbbf6 -->
  <rule id="349654" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2184 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>