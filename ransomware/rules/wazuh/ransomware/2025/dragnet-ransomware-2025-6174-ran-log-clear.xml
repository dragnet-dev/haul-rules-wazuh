<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6174 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: 42845b88-c37f-5ff6-847c-7c5b0648e64f -->
  <rule id="655318" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6174 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>