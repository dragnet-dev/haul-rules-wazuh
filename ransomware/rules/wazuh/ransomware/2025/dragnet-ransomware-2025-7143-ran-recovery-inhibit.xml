<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7143 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 778b106e-528b-5471-88ec-585400862676 -->
  <rule id="445910" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7143 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>