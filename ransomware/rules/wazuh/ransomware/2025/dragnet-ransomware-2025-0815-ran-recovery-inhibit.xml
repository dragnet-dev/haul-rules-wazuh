<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0815 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 265b4b83-7a44-5edc-b543-e804b91948ef -->
  <rule id="602358" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0815 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>