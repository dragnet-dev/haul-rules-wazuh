<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3160 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 3068c5b8-e9f5-59dc-9b04-fd14fdc5ffa5 -->
  <rule id="756091" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3160 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>