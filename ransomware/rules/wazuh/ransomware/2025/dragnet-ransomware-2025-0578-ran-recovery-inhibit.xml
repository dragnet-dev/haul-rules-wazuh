<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0578 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c84c4981-1aa3-504a-899b-79e4236e8407 -->
  <rule id="355649" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0578 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>