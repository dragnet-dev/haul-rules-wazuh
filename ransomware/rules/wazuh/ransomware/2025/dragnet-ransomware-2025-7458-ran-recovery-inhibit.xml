<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7458 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f7bccbc2-d71c-5fdf-9256-c89f42ec2efd -->
  <rule id="537483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7458 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>