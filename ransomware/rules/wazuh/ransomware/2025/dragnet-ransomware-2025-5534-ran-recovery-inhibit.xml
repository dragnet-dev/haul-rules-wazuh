<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5534 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 4225a497-a9e9-57dc-9888-7cd590e85b7f -->
  <rule id="561049" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5534 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>