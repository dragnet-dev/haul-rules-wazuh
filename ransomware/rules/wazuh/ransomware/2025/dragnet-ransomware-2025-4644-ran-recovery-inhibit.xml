<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4644 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9afcca50-c367-54e4-8a5f-16b2723bd7a4 -->
  <rule id="357258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4644 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>