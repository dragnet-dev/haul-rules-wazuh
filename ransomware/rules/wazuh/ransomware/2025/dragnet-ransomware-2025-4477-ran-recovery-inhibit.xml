<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4477 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 666f2903-28ce-530b-b4be-23383a1f33e6 -->
  <rule id="267129" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4477 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>