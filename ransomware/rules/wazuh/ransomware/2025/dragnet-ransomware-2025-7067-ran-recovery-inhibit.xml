<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7067 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 9cf3804f-85b0-5623-929a-2049421e6961 -->
  <rule id="811380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7067 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>