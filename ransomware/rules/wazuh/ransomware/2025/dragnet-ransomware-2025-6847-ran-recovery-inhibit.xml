<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6847 — Recovery Inhibition (global) | Status: experimental | Sigma ID: 5511547f-2aa3-58aa-94c1-4992346a4530 -->
  <rule id="211547" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6847 — Recovery Inhibition (global)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>