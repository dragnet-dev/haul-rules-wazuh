<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7565 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: cdfd3d85-2b65-5fd7-8a52-e6ad43eb220b -->
  <rule id="437341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7565 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>