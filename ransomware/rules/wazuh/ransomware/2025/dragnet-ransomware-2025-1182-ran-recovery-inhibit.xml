<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1182 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 4493b1f6-9e4a-56cf-babc-c0566ce8e119 -->
  <rule id="803871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1182 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>