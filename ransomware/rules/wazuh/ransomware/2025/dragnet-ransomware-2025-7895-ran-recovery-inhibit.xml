<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7895 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: c9748141-41fb-5263-9cae-12f7b461e543 -->
  <rule id="497481" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7895 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>