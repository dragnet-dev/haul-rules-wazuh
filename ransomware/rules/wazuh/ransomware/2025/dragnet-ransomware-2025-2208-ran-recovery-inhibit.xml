<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2208 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 9a8e4d0a-b562-55ad-b5ba-834d1995245c -->
  <rule id="465197" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2208 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>