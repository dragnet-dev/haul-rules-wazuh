<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2766 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: a0af747e-834d-54f7-ab0a-39476062f457 -->
  <rule id="877574" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2766 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>