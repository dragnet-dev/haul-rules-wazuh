<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6549 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 7833ba89-867a-54de-9275-b036a463cb20 -->
  <rule id="305434" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6549 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>