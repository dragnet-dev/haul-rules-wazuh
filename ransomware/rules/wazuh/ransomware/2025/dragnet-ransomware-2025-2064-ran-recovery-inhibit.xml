<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2064 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 4526acf4-7613-5850-8522-a5fcbfb3ab7c -->
  <rule id="358828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2064 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>