<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5577 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 749c8ba7-d975-5561-bae9-660d132fffd2 -->
  <rule id="219499" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5577 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>