<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7110 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 7a04bd9c-0566-59a6-b4a0-d1d1a81c1008 -->
  <rule id="524413" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7110 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>