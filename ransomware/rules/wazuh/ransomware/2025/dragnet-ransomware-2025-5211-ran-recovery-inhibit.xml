<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5211 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: adb0c759-6000-565a-becf-5bb59be83e0a -->
  <rule id="946527" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5211 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>