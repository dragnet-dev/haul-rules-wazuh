<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0690 — Event Log Clearing (weyhro) | Status: experimental | Sigma ID: ed48b73b-65b9-5a45-8fe5-e7857645820a -->
  <rule id="299797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0690 — Event Log Clearing (weyhro)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>