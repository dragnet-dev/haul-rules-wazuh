<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6922 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: fa6b7da6-0392-5a85-b22b-437d3fddff46 -->
  <rule id="217245" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6922 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>