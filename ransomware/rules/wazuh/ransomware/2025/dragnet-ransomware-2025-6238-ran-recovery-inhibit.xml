<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6238 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 87627196-9350-5782-8190-345630e2c348 -->
  <rule id="762719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6238 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>