<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4553 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 1edc5c45-1c37-5fad-9f2b-44f1dceeebe7 -->
  <rule id="464092" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4553 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>