<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2725 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 505983ac-b728-5649-848e-cb0a40b27406 -->
  <rule id="995738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2725 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>