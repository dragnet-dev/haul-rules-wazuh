<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0653 — Recovery Inhibition (ralord) | Status: experimental | Sigma ID: acb1c261-101c-564f-a361-c69fa3a360f6 -->
  <rule id="921082" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0653 — Recovery Inhibition (ralord)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>