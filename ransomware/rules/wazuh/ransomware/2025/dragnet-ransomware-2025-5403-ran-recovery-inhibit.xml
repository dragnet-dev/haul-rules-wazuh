<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5403 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 0b84647c-ba09-543e-a11a-50da9c3e55b0 -->
  <rule id="384647" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5403 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>