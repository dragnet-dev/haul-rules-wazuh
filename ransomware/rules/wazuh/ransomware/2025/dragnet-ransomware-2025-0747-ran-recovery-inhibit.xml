<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0747 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: 81406868-9041-5fbb-aaf4-e5b8da69b729 -->
  <rule id="140686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0747 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>