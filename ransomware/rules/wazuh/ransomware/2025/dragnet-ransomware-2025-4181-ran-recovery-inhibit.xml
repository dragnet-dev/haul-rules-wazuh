<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4181 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 7f0e539d-1cfb-58e7-af72-60d0853cdfc9 -->
  <rule id="333453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4181 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>