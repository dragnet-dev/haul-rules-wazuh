<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4731 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: c1a747f2-3fa9-56c2-add3-74f3413a7d29 -->
  <rule id="246747" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4731 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>