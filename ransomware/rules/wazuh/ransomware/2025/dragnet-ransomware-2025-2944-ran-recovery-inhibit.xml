<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2944 — Recovery Inhibition (qilin) | Status: test | Sigma ID: cd0529c5-2b6b-533a-8917-4a22b31b540c -->
  <rule id="350529" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2944 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>