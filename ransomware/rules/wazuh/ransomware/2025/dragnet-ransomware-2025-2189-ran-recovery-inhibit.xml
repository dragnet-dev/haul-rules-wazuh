<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2189 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 724846dd-6cb4-57be-ba23-79af65927e70 -->
  <rule id="897549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2189 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>