<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1913 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 6c195665-b58a-578b-83ab-b2368deb7bdd -->
  <rule id="281956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1913 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>