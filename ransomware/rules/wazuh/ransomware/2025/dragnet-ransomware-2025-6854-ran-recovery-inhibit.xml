<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6854 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 72fcf88a-5aa0-5289-90b0-6e4bc8aa3a93 -->
  <rule id="389598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6854 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>