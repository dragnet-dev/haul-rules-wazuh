<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5620 — Recovery Inhibition (anubis) | Status: test | Sigma ID: a1564c54-e870-5a9e-a21b-64933485238c -->
  <rule id="825036" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5620 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>