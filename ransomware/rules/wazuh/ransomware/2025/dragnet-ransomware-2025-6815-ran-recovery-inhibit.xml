<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6815 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: ebc3c2fc-f523-5d29-96f3-122cb5015958 -->
  <rule id="735802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6815 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>