<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4710 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 7969d18b-962d-5fdc-a69b-189a247e5afa -->
  <rule id="475171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4710 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>