<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5426 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: fd3aecf8-6aca-53ae-a3ca-2c78fff66420 -->
  <rule id="577964" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5426 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>