<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4106 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ab5e510c-98c5-52a3-8126-58c10f29036f -->
  <rule id="145451" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4106 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>