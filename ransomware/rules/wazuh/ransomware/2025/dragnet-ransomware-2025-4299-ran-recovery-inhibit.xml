<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4299 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f81134e8-fdcd-53aa-9755-f813f1c4c5da -->
  <rule id="781134" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4299 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>