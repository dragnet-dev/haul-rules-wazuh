<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4003 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 5e4ec8c4-57d9-5a1b-a254-ca723653d497 -->
  <rule id="719008" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4003 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>