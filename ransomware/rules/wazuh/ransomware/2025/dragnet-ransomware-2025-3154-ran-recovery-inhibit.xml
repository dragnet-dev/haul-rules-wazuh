<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3154 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: a323b695-e50a-5941-867a-a716e479f608 -->
  <rule id="851796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3154 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>