<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0535 — Recovery Inhibition (interlock) | Status: test | Sigma ID: d5854652-d501-5ee9-a185-a0c5546fa8e9 -->
  <rule id="558546" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0535 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
