<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6917 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: ee9104e8-0369-5ad6-a76e-b186de753bc4 -->
  <rule id="689104" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6917 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>