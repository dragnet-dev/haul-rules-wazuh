<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5365 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: f722f441-3f60-5c97-95a2-a91f97ed2f2f -->
  <rule id="815674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5365 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>