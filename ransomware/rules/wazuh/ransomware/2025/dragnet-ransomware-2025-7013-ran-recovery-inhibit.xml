<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7013 — Recovery Inhibition (securotrop) | Status: experimental | Sigma ID: 1fb54018-b61f-5c83-9ffa-12dfb6f6d68a -->
  <rule id="675401" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7013 — Recovery Inhibition (securotrop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>