<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3253 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: e583da5e-e7e9-58dc-9a56-c9f45ccd5a9a -->
  <rule id="233466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3253 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>