<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1370 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: bce85951-faaa-5f21-9b4d-312062d5cacb -->
  <rule id="422859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1370 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>