<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5975 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7be520cc-bbc7-56eb-955c-69730032fb9e -->
  <rule id="282520" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5975 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>