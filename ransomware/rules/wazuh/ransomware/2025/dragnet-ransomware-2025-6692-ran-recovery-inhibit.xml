<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6692 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: a74ec01c-3e52-5751-97fc-1b5c838b7404 -->
  <rule id="151800" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6692 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>