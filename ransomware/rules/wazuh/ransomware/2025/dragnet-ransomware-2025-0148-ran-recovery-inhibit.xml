<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0148 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2f2b4d3e-690a-5467-bf41-511055a9f38e -->
  <rule id="410157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0148 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>