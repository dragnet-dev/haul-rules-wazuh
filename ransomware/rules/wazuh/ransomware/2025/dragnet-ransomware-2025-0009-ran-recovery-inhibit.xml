<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0009 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 9591cb12-f6a2-5550-b9f5-4222e8106e03 -->
  <rule id="755499" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0009 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>