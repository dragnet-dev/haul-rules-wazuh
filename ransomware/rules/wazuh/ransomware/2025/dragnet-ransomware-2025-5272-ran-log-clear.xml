<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5272 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: 5f1e34b9-16e8-5ad0-a88a-a1ffc26d0d46 -->
  <rule id="723034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5272 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>