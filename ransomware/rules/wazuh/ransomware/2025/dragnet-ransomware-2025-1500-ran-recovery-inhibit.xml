<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1500 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2900513f-f93e-5fad-8ade-d550943128be -->
  <rule id="300513" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1500 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>