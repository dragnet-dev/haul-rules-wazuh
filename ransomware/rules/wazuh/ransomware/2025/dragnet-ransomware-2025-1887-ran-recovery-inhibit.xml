<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1887 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: f2d82c84-5aa4-55a4-b28b-6bc02350f0cb -->
  <rule id="413324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1887 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>