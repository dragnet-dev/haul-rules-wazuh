<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7660 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: d05ec10c-f84b-5cdc-b7ee-023d232cbc28 -->
  <rule id="743161" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7660 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>