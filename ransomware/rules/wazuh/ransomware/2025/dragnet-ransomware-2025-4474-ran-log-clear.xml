<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4474 — Event Log Clearing (fog) | Status: deprecated | Sigma ID: 81cd2e5a-2425-58f3-bc77-45dc1cd99b61 -->
  <rule id="750606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4474 — Event Log Clearing (fog)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>