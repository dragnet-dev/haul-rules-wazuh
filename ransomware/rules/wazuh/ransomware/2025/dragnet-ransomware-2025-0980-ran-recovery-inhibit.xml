<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0980 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: db01a08e-7c22-5744-a3a5-72fbdb40b5b2 -->
  <rule id="904260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0980 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>