<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6331 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 829e4f82-71e3-5c08-89af-66ed1f531deb -->
  <rule id="424559" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6331 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>