<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2253 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: 57a4fa12-96ba-5007-bea7-c1ac30366cb8 -->
  <rule id="661594" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2253 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>