<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7498 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 5d593d90-f08b-5f50-9f75-9c05035248e5 -->
  <rule id="697501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7498 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>