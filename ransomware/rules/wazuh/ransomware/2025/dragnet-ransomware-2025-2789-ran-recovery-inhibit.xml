<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2789 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 5bcce3fc-1933-5a2a-9c98-9b6e27b62291 -->
  <rule id="260143" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2789 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>