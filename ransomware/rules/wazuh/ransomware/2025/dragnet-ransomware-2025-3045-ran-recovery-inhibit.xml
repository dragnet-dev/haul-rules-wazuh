<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3045 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 4b5aaebe-24c8-5d69-9ccf-183e225c27e1 -->
  <rule id="495214" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3045 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>