<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1865 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: c942aeb3-bbed-5563-8508-96a978535c57 -->
  <rule id="713326" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1865 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>