<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4339 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 485e63bf-45fb-5b95-ae8c-f50300f6d557 -->
  <rule id="839419" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4339 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>