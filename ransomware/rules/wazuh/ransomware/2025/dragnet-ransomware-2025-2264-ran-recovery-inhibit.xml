<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2264 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c6b389e3-8e16-5712-8ead-d6776282be2c -->
  <rule id="327389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2264 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>