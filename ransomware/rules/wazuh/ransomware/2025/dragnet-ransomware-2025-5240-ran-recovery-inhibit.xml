<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5240 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 9cd1abae-e9e6-564d-a78e-f6c906992337 -->
  <rule id="223467" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5240 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>