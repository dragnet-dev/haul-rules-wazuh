<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3269 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 3ff71fb3-8af8-5d6e-bb67-853e79e4c772 -->
  <rule id="837951" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3269 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>