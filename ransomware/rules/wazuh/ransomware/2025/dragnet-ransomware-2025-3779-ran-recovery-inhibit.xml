<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3779 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 984861f0-c6da-56a7-be38-7d8c103ce9be -->
  <rule id="557791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3779 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>