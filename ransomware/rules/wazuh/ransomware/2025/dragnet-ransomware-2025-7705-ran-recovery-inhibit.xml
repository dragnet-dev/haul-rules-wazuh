<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7705 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 080c5726-7cab-54de-b6bb-e08a30f3e648 -->
  <rule id="492572" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7705 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>