<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0809 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 1c2105a6-1942-5de2-9a4d-68be8d30a373 -->
  <rule id="113690" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0809 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>