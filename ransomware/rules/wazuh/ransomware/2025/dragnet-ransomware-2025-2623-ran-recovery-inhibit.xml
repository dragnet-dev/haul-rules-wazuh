<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2623 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 83bcafaf-e537-5127-a269-7d1816d91870 -->
  <rule id="187791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2623 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>