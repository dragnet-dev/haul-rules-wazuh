<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5083 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: b1d915e6-d646-5c61-8364-1c4f80307625 -->
  <rule id="989915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5083 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>