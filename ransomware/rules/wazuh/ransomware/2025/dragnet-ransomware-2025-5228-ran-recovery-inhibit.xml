<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5228 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 1605b23c-e742-5be6-be31-7a7f19e4a9d1 -->
  <rule id="869123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5228 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>