<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6036 — Shadow Copy Deletion (interlock) | Status: test | Sigma ID: 4682ce4c-a66f-5d1c-866b-ae44ef7ce46a -->
  <rule id="398798" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6036 — Shadow Copy Deletion (interlock)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>