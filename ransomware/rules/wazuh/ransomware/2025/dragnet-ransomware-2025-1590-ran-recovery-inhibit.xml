<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1590 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 41972c4d-7a3a-5c14-a001-558e552a322c -->
  <rule id="515644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1590 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>