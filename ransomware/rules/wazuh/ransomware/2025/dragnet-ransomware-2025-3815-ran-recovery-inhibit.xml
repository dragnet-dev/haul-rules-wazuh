<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3815 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 8eef94d8-c715-575c-b186-91271c803d82 -->
  <rule id="159194" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3815 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>