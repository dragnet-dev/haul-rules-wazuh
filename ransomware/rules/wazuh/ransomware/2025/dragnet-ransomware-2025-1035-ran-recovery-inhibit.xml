<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1035 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ce156cfb-5041-5bb5-81f5-56c318ddacf5 -->
  <rule id="698508" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1035 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>