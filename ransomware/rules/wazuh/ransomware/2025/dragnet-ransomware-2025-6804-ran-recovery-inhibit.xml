<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6804 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d4e6de06-3201-5098-9f09-dbabfa1ec3e8 -->
  <rule id="226238" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6804 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>