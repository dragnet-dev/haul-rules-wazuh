<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0597 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2b012bc0-4ab9-55a1-803e-1145e15dedea -->
  <rule id="311260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0597 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>