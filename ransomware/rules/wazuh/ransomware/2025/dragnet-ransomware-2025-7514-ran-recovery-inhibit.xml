<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7514 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 112bc5a4-4637-553a-95de-39aabbb0f45e -->
  <rule id="217690" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7514 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>