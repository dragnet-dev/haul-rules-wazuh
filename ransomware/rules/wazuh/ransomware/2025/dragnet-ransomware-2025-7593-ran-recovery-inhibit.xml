<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7593 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: d854424a-23f3-5229-b0a9-8a94ea155e8b -->
  <rule id="585442" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7593 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>