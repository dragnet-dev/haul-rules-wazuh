<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4542 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 407453a9-cd5d-594e-8343-9b0cc4d1d579 -->
  <rule id="319258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4542 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>