<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0413 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 00a3d884-f100-5e23-a3e4-e87567dfd71b -->
  <rule id="861884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0413 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>