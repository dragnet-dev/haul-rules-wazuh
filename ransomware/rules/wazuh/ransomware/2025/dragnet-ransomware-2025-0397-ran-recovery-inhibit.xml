<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0397 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 5535267d-221e-5d80-b1e2-e8e023d708fd -->
  <rule id="235267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0397 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>