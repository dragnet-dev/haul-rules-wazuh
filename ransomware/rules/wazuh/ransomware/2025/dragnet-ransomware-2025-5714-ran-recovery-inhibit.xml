<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5714 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 6d8b7542-0303-5659-95cc-94037d365894 -->
  <rule id="957975" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5714 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>