<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0472 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 6f924302-733c-5d00-aa03-d029b94b2286 -->
  <rule id="319243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0472 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>