<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3561 — Recovery Inhibition (interlock) | Status: test | Sigma ID: 3f9274bd-4d25-5118-b40b-ef9e9b8f4faa -->
  <rule id="428395" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3561 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>