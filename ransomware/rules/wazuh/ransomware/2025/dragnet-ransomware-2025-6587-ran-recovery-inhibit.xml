<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6587 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d22a12bf-4f57-5b5c-b3c5-22562c746eae -->
  <rule id="416212" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6587 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>