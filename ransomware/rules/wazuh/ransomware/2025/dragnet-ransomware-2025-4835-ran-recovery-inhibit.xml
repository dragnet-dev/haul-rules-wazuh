<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4835 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 91031671-c752-5f3b-9bc2-4c59b324577a -->
  <rule id="203167" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4835 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>