<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0226 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 38fd9ac5-a671-5a62-9628-e0c5065ac24e -->
  <rule id="797114" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0226 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>