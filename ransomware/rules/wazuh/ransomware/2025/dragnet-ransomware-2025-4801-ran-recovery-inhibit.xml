<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4801 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 025fd5cc-b9e0-559f-ac64-844bcf175826 -->
  <rule id="264572" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4801 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>