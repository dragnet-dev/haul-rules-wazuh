<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2537 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: 2de17379-c924-568c-b13f-ef15b54c40f8 -->
  <rule id="241737" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2537 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>