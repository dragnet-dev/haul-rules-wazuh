<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3194 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: a7b78fdd-373e-50e0-b418-8d1054054ef5 -->
  <rule id="158063" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3194 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>