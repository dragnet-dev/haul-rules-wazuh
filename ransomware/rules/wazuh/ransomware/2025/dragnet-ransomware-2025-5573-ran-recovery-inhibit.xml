<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5573 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8eb98461-2594-5644-a273-9df9ee046a12 -->
  <rule id="583984" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5573 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>