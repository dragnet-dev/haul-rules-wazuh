<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0537 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f239b71a-4aee-5e80-a49a-fa14f9825b4f -->
  <rule id="738357" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0537 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>