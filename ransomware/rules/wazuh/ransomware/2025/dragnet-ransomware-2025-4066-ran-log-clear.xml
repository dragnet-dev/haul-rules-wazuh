<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4066 — Event Log Clearing (radar) | Status: deprecated | Sigma ID: 46f9ef59-a4f3-515d-be9f-b2db7ef1d0e9 -->
  <rule id="225103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4066 — Event Log Clearing (radar)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>