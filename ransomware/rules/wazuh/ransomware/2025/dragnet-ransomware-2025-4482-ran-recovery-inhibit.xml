<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4482 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: 6d426b25-c268-5235-b887-2037706e981b -->
  <rule id="950827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4482 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>