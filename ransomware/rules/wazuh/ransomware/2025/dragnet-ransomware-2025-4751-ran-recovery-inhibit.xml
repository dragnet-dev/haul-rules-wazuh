<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4751 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 441ac6bc-060c-5da8-8a28-9c58fb315eb3 -->
  <rule id="330686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4751 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>