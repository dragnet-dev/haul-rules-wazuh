<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6194 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 2d4b49ce-eec4-5c8f-921f-6af83c579c6d -->
  <rule id="940796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6194 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>