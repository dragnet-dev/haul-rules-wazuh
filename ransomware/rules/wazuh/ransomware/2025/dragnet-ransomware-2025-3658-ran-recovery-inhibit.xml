<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3658 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0a4ed541-500a-5d64-a4c3-26e173a39f33 -->
  <rule id="986154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3658 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>