<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2046 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 56741bcc-3d80-5769-8176-6afcf4a3fc0c -->
  <rule id="225884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2046 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>