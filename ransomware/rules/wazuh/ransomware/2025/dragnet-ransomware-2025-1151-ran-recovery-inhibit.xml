<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1151 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 855378ac-67b1-5919-b32b-f569ab37c38d -->
  <rule id="286058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1151 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>