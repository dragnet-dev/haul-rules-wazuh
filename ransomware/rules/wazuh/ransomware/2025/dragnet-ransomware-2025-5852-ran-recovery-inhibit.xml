<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5852 — Recovery Inhibition (gunra) | Status: experimental | Sigma ID: 9a63580e-ce7b-5aa6-a1f1-df041c5d4da5 -->
  <rule id="746358" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5852 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>