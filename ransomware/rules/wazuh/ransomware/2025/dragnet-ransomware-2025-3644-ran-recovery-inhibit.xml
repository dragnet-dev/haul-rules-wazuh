<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3644 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3be91338-04f3-5908-b7b5-7e88a66aafbd -->
  <rule id="689133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3644 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>