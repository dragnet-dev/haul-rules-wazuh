<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7161 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: b012c8a4-5fc1-5208-a0e5-56ababf39b6f -->
  <rule id="962048" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7161 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>