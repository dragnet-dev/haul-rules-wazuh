<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6991 — Event Log Clearing (shinyhunters) | Status: experimental | Sigma ID: 2193aa3c-fd15-54eb-8109-1fb02dca24c3 -->
  <rule id="315783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6991 — Event Log Clearing (shinyhunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>