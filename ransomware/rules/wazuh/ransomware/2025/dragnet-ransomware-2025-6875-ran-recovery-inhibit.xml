<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6875 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b6c4f140-ac2c-5d63-87c1-26874892c60d -->
  <rule id="389591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6875 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>