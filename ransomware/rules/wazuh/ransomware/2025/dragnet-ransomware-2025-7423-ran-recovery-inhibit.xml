<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7423 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 57b6f40e-5e0f-52ad-b1d0-19f42bfa8914 -->
  <rule id="677914" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7423 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>