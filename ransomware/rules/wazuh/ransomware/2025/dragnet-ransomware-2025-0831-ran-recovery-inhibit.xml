<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0831 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d8b8d28f-596e-5e50-8fce-df25528eac3c -->
  <rule id="951812" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0831 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>