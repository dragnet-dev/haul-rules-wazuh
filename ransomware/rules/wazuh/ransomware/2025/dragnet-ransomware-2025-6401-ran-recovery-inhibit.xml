<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6401 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: c1c06616-d165-536d-bcff-3b44365db44a -->
  <rule id="248066" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6401 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>