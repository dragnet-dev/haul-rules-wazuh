<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2997 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: f9f85b61-7441-50ad-a73c-b7ea6b99ea7b -->
  <rule id="595771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2997 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>