<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4267 — Event Log Clearing (direwolf) | Status: experimental | Sigma ID: faaf4fc5-4eb5-52f1-8da5-d6a6b87c0efd -->
  <rule id="468079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4267 — Event Log Clearing (direwolf)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>