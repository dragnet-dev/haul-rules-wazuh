<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6499 — Recovery Inhibition (play) | Status: experimental | Sigma ID: dd98452b-63e6-5745-b940-24f18e95387a -->
  <rule id="519845" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6499 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>