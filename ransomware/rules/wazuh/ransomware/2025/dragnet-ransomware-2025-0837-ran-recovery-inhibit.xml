<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0837 — Recovery Inhibition (J) | Status: experimental | Sigma ID: 2ecb4925-2641-536f-863a-5428ca4d702d -->
  <rule id="397949" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0837 — Recovery Inhibition (J)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>