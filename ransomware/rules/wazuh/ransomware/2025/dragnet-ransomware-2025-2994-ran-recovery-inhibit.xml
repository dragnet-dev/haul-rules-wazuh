<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2994 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 2ac0d751-ed9e-5699-9c98-0ba65bb3a13d -->
  <rule id="294537" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2994 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>