<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2919 — Event Log Clearing (lynx) | Status: experimental | Sigma ID: 74e9ec1f-bf29-5a63-9a00-3b53ca9de5ff -->
  <rule id="469420" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2919 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>