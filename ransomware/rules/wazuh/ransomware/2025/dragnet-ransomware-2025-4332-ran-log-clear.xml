<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4332 — Event Log Clearing (crazyhunter) | Status: experimental | Sigma ID: 7247cb37-ad75-5afd-82f4-faafb1adf296 -->
  <rule id="155435" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4332 — Event Log Clearing (crazyhunter)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>