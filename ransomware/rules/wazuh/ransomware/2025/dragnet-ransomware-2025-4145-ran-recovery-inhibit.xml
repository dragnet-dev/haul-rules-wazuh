<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4145 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f277bdc5-dd92-5012-87ab-48c275128750 -->
  <rule id="411101" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4145 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>