<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4688 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: a870abad-7418-5e93-a246-1f8898439ab0 -->
  <rule id="182891" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4688 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>