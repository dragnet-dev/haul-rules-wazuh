<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3436 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: c7346965-84ab-558a-9824-47537810d843 -->
  <rule id="473469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3436 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>