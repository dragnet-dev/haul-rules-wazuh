<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0089 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: c885eee4-ad97-51ad-a125-9185aa908d1a -->
  <rule id="698798" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0089 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>