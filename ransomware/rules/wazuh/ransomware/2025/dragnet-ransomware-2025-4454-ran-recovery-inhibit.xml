<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4454 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: e7bd0c6b-a121-51e6-b1c5-972ac7c5d2b4 -->
  <rule id="751372" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4454 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>