  <rule id="553382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2087 — Recovery Inhibition (RunSomeWares)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
