<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4586 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 53b6d5a5-29f9-5969-a6ab-a13d666fd1f4 -->
  <rule id="575495" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4586 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>