<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5674 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d394878e-6060-5899-95c4-d728c6933bf0 -->
  <rule id="539487" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5674 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>