<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2734 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 4b2153fb-040d-571c-86db-e238569f4061 -->
  <rule id="434463" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2734 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>