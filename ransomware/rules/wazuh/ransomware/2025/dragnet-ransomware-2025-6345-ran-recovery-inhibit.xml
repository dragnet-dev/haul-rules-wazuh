<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6345 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: ffbdfcb0-4360-555d-9985-302fd2f1255e -->
  <rule id="247519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6345 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>