<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0636 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 6cbcc390-e3f9-574e-8205-846a198d09f6 -->
  <rule id="953883" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0636 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>