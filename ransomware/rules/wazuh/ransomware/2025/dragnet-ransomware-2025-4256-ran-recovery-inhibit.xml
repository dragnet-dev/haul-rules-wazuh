<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4256 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: ed8aa587-4cc3-579a-b2aa-de197f540eac -->
  <rule id="789385" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4256 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>