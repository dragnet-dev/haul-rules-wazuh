<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5584 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 23797ee1-8765-5661-a855-953bcc5f8ecf -->
  <rule id="792270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5584 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>