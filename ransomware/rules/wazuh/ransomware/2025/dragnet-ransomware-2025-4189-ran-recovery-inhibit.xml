<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4189 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 62fe366f-a687-54d2-9dd0-ea06983f497c -->
  <rule id="812636" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4189 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>