<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6145 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3c01976f-8269-57e7-b046-35e98dae83ae -->
  <rule id="701976" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6145 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>