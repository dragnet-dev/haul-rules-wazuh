<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0479 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 2c41cea6-8bf9-5484-a53a-ee5346b9519d -->
  <rule id="337102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0479 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>