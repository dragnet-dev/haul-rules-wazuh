<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0427 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 4f1f8ff2-5fc3-5245-b480-ad01f157d42f -->
  <rule id="327503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0427 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>