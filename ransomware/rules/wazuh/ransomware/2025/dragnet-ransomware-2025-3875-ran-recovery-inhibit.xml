<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3875 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 5be8848e-af35-5464-a745-7d876b3f9013 -->
  <rule id="670884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3875 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>