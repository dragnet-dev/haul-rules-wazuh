<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3989 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 5558c347-9d55-5540-a50e-71a7c1422c5a -->
  <rule id="894034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3989 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>