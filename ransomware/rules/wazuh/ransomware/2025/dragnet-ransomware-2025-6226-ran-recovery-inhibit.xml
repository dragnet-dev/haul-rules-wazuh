<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6226 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 214a7b73-0c7c-5095-ba51-2fb9c438c7e4 -->
  <rule id="195637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6226 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>