<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2769 — Event Log Clearing (GDLockerSec) | Status: experimental | Sigma ID: 4912ac8a-1173-55ef-902b-79404cec0990 -->
  <rule id="457644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2769 — Event Log Clearing (GDLockerSec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>