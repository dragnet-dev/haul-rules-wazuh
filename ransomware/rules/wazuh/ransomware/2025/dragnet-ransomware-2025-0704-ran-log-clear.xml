<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0704 — Event Log Clearing (clop) | Status: deprecated | Sigma ID: 1e5df5d1-f357-5aa3-a39b-171fb95a7fe1 -->
  <rule id="928573" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0704 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>