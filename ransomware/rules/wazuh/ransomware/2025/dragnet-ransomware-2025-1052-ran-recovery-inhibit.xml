<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1052 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ddfc6d5a-3783-5741-b5fa-160a92c94429 -->
  <rule id="192589" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1052 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>