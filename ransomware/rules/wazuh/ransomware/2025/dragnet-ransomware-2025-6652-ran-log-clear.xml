<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6652 — Event Log Clearing (blackshrantac) | Status: experimental | Sigma ID: 9b6b007a-fbb1-5c76-ae78-15dbfbcc7252 -->
  <rule id="790700" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6652 — Event Log Clearing (blackshrantac)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>