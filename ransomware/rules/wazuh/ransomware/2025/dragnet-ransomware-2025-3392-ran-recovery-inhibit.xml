<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3392 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 300a4a32-f3b8-51f2-a502-289df249de67 -->
  <rule id="596743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3392 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>