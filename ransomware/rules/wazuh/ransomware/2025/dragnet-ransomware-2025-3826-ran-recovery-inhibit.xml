<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3826 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 29c0966c-ee59-533e-a818-9b9d8cb256e4 -->
  <rule id="360966" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3826 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>