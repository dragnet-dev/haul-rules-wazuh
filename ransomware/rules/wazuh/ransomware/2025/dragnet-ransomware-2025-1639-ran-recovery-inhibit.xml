<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1639 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3674a87c-7db5-545b-ba65-86d8f4532c16 -->
  <rule id="579487" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1639 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>