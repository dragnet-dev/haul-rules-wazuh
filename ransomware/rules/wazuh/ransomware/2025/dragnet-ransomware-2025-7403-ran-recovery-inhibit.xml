<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7403 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: a93dcf5e-69aa-5fef-8600-22ded614d1b1 -->
  <rule id="980463" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7403 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>