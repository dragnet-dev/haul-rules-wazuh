<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1503 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 9f0ef235-ea0a-5971-99f9-01758cbca3a1 -->
  <rule id="572792" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1503 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>