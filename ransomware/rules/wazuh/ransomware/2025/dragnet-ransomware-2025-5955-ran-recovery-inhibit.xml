<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5955 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: f60c0f0c-e8dc-5b1e-be63-9d5f4ca06be1 -->
  <rule id="495535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5955 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>