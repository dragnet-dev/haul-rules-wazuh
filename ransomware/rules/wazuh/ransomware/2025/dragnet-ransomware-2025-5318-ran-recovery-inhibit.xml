<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5318 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: df5eaf2c-0b03-5a56-b016-18d70071ae57 -->
  <rule id="258319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5318 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>