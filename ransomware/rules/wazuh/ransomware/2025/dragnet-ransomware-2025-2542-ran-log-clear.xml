<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2542 — Event Log Clearing (ms13089) | Status: test | Sigma ID: 1f556dc5-7aaf-5b1f-94ab-1a8e2f8d8897 -->
  <rule id="978556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2542 — Event Log Clearing (ms13089)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>