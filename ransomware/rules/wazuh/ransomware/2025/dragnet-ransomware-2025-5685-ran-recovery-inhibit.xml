<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5685 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: b49fdc48-cefc-5fa8-9bc4-9d7f1da3f9c2 -->
  <rule id="310364" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5685 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>