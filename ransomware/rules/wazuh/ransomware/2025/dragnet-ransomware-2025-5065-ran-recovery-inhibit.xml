<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5065 — Recovery Inhibition (qilin) | Status: test | Sigma ID: a24f4eda-5a87-535c-b684-8ca019388384 -->
  <rule id="923918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5065 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>