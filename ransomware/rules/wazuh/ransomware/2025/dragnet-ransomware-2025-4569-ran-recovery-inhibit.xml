<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4569 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 09fae26f-7d8a-59db-9e07-fcfde200112b -->
  <rule id="587826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4569 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>