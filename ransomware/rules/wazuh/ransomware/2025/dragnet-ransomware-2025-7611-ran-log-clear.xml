<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7611 — Event Log Clearing (global) | Status: deprecated | Sigma ID: f4e3f4b3-d3d1-532d-b2e4-8574a73fe5d8 -->
  <rule id="465434" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7611 — Event Log Clearing (global)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>