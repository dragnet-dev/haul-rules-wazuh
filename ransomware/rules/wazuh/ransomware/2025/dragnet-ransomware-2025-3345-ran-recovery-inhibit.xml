<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3345 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 7c49eaf0-c3c2-5853-a8a3-a0a28938e237 -->
  <rule id="587178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3345 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>