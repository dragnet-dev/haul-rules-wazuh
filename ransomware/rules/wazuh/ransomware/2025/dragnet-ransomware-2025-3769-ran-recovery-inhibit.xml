<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3769 — Recovery Inhibition (pear) | Status: experimental | Sigma ID: b937d218-6a38-5a55-b0ce-1a870fc8818c -->
  <rule id="210052" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3769 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>