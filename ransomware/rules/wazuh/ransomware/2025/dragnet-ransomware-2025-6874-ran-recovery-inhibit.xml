<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6874 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: ce1da055-fa2a-5b0e-b334-92410ad17fe2 -->
  <rule id="878340" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6874 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>