<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3700 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6ce03cbc-e92e-5087-ac75-2ea4a521c5c7 -->
  <rule id="187260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3700 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>