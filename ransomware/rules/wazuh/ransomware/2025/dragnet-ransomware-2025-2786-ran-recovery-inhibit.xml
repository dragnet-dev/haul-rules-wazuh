<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2786 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ccef5d35-d816-5c35-86c0-1b2235355f2c -->
  <rule id="394173" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2786 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>