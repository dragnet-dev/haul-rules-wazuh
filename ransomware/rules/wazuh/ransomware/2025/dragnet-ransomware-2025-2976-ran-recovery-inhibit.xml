<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2976 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: e7d43e87-9c65-5cbc-94d2-3de7daa332cc -->
  <rule id="284702" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2976 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>