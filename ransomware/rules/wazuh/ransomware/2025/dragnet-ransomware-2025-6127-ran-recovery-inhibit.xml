<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6127 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 37ad3925-8882-52ae-b438-3af2552a72f6 -->
  <rule id="745392" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6127 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>