<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6167 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 33b1b419-ea54-5fb4-9deb-54f7b26ee3ea -->
  <rule id="626741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6167 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>