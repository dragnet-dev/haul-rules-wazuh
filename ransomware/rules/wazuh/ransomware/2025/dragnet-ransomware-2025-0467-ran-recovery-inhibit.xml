<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0467 — Recovery Inhibition (obscura) | Status: experimental | Sigma ID: d0ab79b7-cd6e-507b-894a-be6b4fc96965 -->
  <rule id="745179" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0467 — Recovery Inhibition (obscura)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>