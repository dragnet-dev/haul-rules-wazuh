<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6011 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 39249296-3c5d-58ee-8668-648b41fe9764 -->
  <rule id="424929" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6011 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>