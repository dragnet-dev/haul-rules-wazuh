<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7803 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 01bfa643-74be-5589-b5c5-75d429106cb9 -->
  <rule id="962643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7803 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>