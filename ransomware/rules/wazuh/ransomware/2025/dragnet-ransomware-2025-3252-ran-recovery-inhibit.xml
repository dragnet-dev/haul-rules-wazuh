<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3252 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: deb1a087-18f0-5455-bf02-0f252d348c09 -->
  <rule id="401060" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3252 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>