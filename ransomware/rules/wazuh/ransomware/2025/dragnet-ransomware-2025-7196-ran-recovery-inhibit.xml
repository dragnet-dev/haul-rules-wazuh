<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7196 — Recovery Inhibition (desolator) | Status: experimental | Sigma ID: 59285484-36d9-528c-b63e-91cd8caf8979 -->
  <rule id="628548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7196 — Recovery Inhibition (desolator)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>