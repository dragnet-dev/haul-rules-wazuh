<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4865 — Recovery Inhibition (insomnia) | Status: experimental | Sigma ID: 73cec4d3-0a86-5654-a239-f0c2077711fa -->
  <rule id="423164" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4865 — Recovery Inhibition (insomnia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>