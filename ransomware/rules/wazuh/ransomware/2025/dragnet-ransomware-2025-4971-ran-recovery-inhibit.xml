<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4971 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 80f5be24-d149-5897-9eba-a1789a3dd410 -->
  <rule id="716670" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4971 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>