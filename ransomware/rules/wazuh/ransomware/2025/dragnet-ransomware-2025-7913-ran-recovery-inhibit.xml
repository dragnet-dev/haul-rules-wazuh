<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7913 — Recovery Inhibition (kazu) | Status: experimental | Sigma ID: 64097d37-b03d-5b63-a41e-020e697a8332 -->
  <rule id="225565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7913 — Recovery Inhibition (kazu)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>