<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3601 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: c7379cee-7a2f-5833-b45e-08f8494d0240 -->
  <rule id="338076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3601 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>