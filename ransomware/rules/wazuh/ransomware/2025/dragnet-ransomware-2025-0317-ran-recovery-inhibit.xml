<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0317 — Recovery Inhibition (lynx) | Status: test | Sigma ID: 7ec7efdc-2362-5983-9543-963abce4361f -->
  <rule id="793711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0317 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>