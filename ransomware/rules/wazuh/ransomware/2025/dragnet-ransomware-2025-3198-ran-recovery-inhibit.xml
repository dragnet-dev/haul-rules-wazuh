<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3198 — Recovery Inhibition (arkana) | Status: experimental | Sigma ID: f41e0761-558d-5dec-af87-c012f6c9f938 -->
  <rule id="767007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3198 — Recovery Inhibition (arkana)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>