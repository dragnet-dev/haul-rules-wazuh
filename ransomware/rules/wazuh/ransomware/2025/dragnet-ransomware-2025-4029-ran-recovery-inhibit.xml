<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4029 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 558188ce-612e-5a38-9013-9f328cec3f3b -->
  <rule id="931020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4029 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>