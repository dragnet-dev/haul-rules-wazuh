<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6765 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ef6cab55-4d55-5394-b003-70b7dd30b8b3 -->
  <rule id="917259" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6765 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>