<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4603 — Event Log Clearing (ciphbit) | Status: deprecated | Sigma ID: 540f489e-22f3-55a8-8bd6-36aa01c6f8cd -->
  <rule id="655489" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4603 — Event Log Clearing (ciphbit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>