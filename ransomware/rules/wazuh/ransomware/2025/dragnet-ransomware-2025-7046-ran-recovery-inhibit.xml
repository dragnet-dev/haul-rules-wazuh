<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7046 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: aa853cf3-d141-57f6-aad1-e5f293a56856 -->
  <rule id="133660" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7046 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>