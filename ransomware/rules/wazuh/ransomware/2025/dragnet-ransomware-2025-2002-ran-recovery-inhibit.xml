<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2002 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: e1543906-1fc6-582f-8c6a-826d34b0c713 -->
  <rule id="615439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2002 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>