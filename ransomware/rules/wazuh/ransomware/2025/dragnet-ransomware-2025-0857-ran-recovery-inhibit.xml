<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0857 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: a743600f-b9e6-5cb8-9a3c-89794af5d692 -->
  <rule id="274360" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0857 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>