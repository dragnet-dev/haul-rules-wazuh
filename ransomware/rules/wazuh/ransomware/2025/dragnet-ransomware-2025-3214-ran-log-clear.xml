<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3214 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 57a1a22a-52c7-5acb-a51c-ec3d8598c3e7 -->
  <rule id="675462" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3214 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>