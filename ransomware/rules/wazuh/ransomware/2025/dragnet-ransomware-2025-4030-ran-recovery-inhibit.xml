<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4030 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d44fe4bc-0d74-52b2-b803-2bd937ae4a48 -->
  <rule id="843184" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4030 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
