<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1591 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 899be121-3d4a-5d05-9fa0-b59c5e8e3bb9 -->
  <rule id="603341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1591 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>