<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1982 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: 037c6aa4-2c8b-5b63-9472-1826c19de818 -->
  <rule id="747946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1982 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
