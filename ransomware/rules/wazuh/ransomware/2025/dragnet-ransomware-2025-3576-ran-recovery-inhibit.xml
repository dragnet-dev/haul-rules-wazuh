<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3576 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 3dd7c93b-9106-589d-a5b9-5e3a459b7813 -->
  <rule id="783649" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3576 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>