<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6848 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b83ded4b-187f-5826-942c-ea8a5cf6f98b -->
  <rule id="449133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6848 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>