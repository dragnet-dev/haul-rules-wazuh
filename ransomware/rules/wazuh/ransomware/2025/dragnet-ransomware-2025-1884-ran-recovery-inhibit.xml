<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1884 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 30e41843-75b1-5d6d-87c4-2dc287be04f2 -->
  <rule id="544184" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1884 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>