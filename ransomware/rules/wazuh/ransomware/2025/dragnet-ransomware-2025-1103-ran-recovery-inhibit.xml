<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1103 — Recovery Inhibition (qilin) | Status: test | Sigma ID: c6b329a7-8664-5782-a6b7-f196d6d37a48 -->
  <rule id="327329" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1103 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>