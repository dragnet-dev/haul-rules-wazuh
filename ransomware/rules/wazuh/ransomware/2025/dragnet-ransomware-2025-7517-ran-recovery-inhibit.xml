<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7517 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 83c70f68-85c4-50a7-a5bc-a49c465c42b8 -->
  <rule id="445135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7517 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>