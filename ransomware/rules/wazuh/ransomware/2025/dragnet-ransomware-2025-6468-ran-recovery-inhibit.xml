<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6468 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: ee18478b-290b-5b88-8703-1931194b0472 -->
  <rule id="681847" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6468 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>