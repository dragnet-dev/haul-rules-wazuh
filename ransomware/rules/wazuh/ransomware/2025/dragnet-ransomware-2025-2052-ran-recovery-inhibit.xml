<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2052 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: f4a6ebd2-c199-5fe2-8501-f513ccf2b5be -->
  <rule id="135211" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2052 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>