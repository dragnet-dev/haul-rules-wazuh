<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1061 — Event Log Clearing (J) | Status: experimental | Sigma ID: 550d2e09-8d48-55c0-b971-1d72155c9e3f -->
  <rule id="610126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1061 — Event Log Clearing (J)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>