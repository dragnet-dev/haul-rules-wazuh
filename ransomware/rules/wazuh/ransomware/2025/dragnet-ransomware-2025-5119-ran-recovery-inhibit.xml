<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5119 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: ac3b2def-ee3c-5ec2-9216-6617d3ddb96b -->
  <rule id="912685" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5119 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>