<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3598 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 26bf8d57-79d4-52ad-ab66-ec4467c36714 -->
  <rule id="295661" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3598 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>