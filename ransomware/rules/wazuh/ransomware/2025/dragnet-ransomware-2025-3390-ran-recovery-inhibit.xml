<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3390 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: b05c8216-9342-5c84-ad46-0373cc829932 -->
  <rule id="969282" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3390 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>