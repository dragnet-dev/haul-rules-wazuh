<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1861 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 9c58be00-13aa-5015-8058-4cbc65e62a01 -->
  <rule id="508638" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1861 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>