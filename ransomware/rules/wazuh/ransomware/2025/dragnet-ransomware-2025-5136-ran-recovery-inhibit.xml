<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5136 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 4ad84c14-802f-5a2c-aa2d-116f021f58cb -->
  <rule id="216556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5136 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>