<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5477 — Event Log Clearing (crypto24) | Status: deprecated | Sigma ID: f3eaff55-5c28-581a-b0f4-39ca55c961f5 -->
  <rule id="287167" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5477 — Event Log Clearing (crypto24)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>