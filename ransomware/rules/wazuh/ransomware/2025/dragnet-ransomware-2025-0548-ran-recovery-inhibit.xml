<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0548 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: aed8c4bd-73fc-5959-abaf-137e5102688f -->
  <rule id="976604" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0548 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>