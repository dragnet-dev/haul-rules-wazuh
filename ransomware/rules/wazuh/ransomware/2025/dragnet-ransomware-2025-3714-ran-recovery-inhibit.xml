<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3714 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 931a55a4-ee76-511b-9411-67d414f2c15d -->
  <rule id="690655" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3714 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>