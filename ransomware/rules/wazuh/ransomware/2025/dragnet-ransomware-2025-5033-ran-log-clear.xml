<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5033 — Event Log Clearing (trinity) | Status: experimental | Sigma ID: e0efa488-8986-5325-ac2a-8ca3c85fd2ca -->
  <rule id="472744" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5033 — Event Log Clearing (trinity)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>