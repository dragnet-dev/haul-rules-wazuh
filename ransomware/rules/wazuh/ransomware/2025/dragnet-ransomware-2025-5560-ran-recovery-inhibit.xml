<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5560 — Recovery Inhibition (dunghill) | Status: experimental | Sigma ID: 99171fd3-3c02-5be8-aac5-aa5c7696a5c8 -->
  <rule id="786751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5560 — Recovery Inhibition (dunghill)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>