<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4083 — Recovery Inhibition (qilin) | Status: test | Sigma ID: db60f4ac-bec8-58fe-89c5-2b5c863453f3 -->
  <rule id="913754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4083 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>