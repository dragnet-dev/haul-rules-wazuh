<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4153 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 9033b17b-252d-532c-b518-20cd516a66c6 -->
  <rule id="645391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4153 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>