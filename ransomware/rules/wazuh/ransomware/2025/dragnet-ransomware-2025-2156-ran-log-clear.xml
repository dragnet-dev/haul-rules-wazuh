<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2156 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: a8c8c0d4-f78d-5395-b0a4-fbe78fc2471b -->
  <rule id="185400" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2156 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>