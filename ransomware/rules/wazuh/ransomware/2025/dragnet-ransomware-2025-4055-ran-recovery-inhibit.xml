<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4055 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 05efb252-9550-5cbf-a5bf-37c6f9cad5da -->
  <rule id="731525" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4055 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>