<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0180 — Recovery Inhibition (direwolf) | Status: experimental | Sigma ID: 11a73090-587c-5830-bf25-22ebc57ffef1 -->
  <rule id="167309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0180 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>