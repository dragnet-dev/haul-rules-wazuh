<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5177 — Event Log Clearing (daixin) | Status: deprecated | Sigma ID: d6d4ad12-6684-5363-8dbb-6804dd2b491f -->
  <rule id="305037" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5177 — Event Log Clearing (daixin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>