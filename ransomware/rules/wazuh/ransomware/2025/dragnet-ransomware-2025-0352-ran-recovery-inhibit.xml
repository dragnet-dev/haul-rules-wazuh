<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0352 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 39e9acd2-f663-5da1-9133-a369888497a5 -->
  <rule id="835756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0352 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>