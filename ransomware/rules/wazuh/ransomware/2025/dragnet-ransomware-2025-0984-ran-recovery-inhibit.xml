<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0984 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 581a0ad9-fcc0-520a-8a97-9a7672a04e8c -->
  <rule id="688970" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0984 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>