<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7326 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 9f3a9e32-1b93-5cf2-81ab-2eaf69d1c85a -->
  <rule id="579838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7326 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>