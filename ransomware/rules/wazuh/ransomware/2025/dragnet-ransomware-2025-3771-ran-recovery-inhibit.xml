<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3771 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 0ae92bc5-592e-56bc-9075-56b964171219 -->
  <rule id="978140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3771 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>