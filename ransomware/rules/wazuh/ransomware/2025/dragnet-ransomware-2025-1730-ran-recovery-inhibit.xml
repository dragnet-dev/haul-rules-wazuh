<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1730 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: d5874361-ecaa-58d5-ace3-3ff3c1f9723a -->
  <rule id="558743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1730 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>