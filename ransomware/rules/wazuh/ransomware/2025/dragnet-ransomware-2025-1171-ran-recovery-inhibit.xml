<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1171 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c4ed7a5c-a65b-5550-bc08-9bee63589841 -->
  <rule id="717082" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1171 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>