<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0682 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a5cae29e-d89f-5a5b-ae81-2923457701ae -->
  <rule id="833262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0682 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>