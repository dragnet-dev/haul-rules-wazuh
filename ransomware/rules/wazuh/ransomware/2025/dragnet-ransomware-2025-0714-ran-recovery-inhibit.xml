<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0714 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2174b789-4886-5f15-aa97-0f1e83f31487 -->
  <rule id="879578" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0714 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>