<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7398 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 2739b9ba-c407-54de-9ed2-4556af9f0200 -->
  <rule id="813755" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7398 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>