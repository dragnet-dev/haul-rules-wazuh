<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3895 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 50d65e2f-93e9-58fe-b846-4baddb459b13 -->
  <rule id="501854" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3895 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>