<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6376 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: de435060-3b69-539a-891f-0c11f60c1c70 -->
  <rule id="524350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6376 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>