<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7898 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: acf34bbc-90e8-538e-8734-09d1deae9d42 -->
  <rule id="927755" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7898 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>