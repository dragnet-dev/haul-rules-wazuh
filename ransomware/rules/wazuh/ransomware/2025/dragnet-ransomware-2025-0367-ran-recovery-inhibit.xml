<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0367 — Recovery Inhibition (nova) | Status: experimental | Sigma ID: 36b5c869-daa1-5a4e-819b-4c782e023784 -->
  <rule id="501286" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0367 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>