<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4258 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6d236e58-4083-5421-89f1-896fd71d7677 -->
  <rule id="947790" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4258 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>