<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0916 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 912dbec7-28d3-59bc-a809-ac7cd2f658d5 -->
  <rule id="239070" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0916 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>