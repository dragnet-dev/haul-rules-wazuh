<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6883 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: 36b586c7-fec4-51fc-bd22-117780e19276 -->
  <rule id="501388" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6883 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>