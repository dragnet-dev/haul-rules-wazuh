<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1402 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 296ab652-9589-5abd-94b9-e6e553c30c80 -->
  <rule id="494765" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1402 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>