<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1945 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 33a77104-1e5b-50a6-b0b3-f66331109474 -->
  <rule id="987710" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1945 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>