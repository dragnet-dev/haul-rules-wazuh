<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1579 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 1950937f-713b-5899-937d-16077e0d898d -->
  <rule id="250937" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1579 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>