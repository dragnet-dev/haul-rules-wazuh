<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5541 — Event Log Clearing (clop) | Status: experimental | Sigma ID: ba51f7b9-9a57-5d24-aa5a-7e6b0ee673a8 -->
  <rule id="384317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5541 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>