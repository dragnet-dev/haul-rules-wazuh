<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5625 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: e606aa72-d586-53f2-b79d-336ce5f76289 -->
  <rule id="239306" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5625 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>