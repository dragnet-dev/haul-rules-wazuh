<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7471 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: fd5c22bb-805e-58fe-968a-4f4f598161d1 -->
  <rule id="557222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7471 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>