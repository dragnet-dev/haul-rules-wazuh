<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6052 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 4d7679dc-1c66-5bea-bded-200bd909db78 -->
  <rule id="842877" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6052 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>