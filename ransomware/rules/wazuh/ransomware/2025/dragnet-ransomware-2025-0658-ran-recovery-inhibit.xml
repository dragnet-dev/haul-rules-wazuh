<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0658 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ceac5eb5-76d4-5246-83ac-2222c8291616 -->
  <rule id="465374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0658 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>