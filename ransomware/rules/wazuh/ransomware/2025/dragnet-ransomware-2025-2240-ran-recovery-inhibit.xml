<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2240 — Recovery Inhibition (chaos) | Status: experimental | Sigma ID: 3d4b9c2d-7ca3-520e-895a-3b1e74a71ef1 -->
  <rule id="773756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2240 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>