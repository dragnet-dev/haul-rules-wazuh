<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4481 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 58376eca-378f-5bf4-9b4b-508b1c9ffcf6 -->
  <rule id="644492" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4481 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>