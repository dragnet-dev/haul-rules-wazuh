<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4017 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ee533de7-e70f-5317-b804-76069579afdc -->
  <rule id="316541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4017 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>