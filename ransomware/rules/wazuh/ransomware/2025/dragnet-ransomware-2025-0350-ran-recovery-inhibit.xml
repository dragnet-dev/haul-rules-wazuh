<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0350 — Recovery Inhibition (skira) | Status: experimental | Sigma ID: 810cf36c-61c1-5ac4-813f-aa78ea9b72c2 -->
  <rule id="375673" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0350 — Recovery Inhibition (skira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>