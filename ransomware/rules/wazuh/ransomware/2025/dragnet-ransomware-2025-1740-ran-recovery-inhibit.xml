<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1740 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: 495434ea-6095-5729-9e20-6fa6adcd21d3 -->
  <rule id="826958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1740 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>