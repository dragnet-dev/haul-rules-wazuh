<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4218 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 2fc35355-6cd2-55b2-b3e2-2c0de049bee2 -->
  <rule id="543535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4218 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>