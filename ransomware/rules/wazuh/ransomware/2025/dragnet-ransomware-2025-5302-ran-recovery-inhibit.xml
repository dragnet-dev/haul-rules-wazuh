<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5302 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: bf5c7b8c-a510-5d71-b6f5-3b47dc9598d8 -->
  <rule id="504443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5302 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>