<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1651 — Recovery Inhibition (IMNCrew) | Status: experimental | Sigma ID: 16846e7f-3dee-5f97-8a87-cb66129aa95b -->
  <rule id="995507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1651 — Recovery Inhibition (IMNCrew)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>