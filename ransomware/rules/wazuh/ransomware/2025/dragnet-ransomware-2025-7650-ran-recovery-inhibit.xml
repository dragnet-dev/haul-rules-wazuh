<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7650 — Recovery Inhibition (tengu) | Status: experimental | Sigma ID: 60951e33-2ad9-530e-ad9a-6221f9b950c6 -->
  <rule id="852303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7650 — Recovery Inhibition (tengu)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>