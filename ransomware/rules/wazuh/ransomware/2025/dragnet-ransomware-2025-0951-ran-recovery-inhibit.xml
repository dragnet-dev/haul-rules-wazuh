<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0951 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 83d500f2-5c67-533c-930d-ddf0c6315598 -->
  <rule id="541500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0951 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>