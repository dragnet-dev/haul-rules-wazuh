<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1469 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f805c961-fad7-576e-a5c3-8cd2cc46759e -->
  <rule id="828929" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1469 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>