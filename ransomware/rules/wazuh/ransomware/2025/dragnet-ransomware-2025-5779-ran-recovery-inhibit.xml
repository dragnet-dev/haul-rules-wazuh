<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5779 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: ec7a0f3d-9784-5f69-b608-0f6f5c02fe16 -->
  <rule id="761135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5779 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>