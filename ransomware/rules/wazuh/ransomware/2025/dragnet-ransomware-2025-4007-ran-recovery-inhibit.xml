<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4007 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: cff6f48e-e990-5afd-903d-9af84dedaa90 -->
  <rule id="924314" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4007 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>