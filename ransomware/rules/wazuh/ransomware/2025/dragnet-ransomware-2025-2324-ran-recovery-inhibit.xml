<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2324 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 1a1c756a-8272-5969-8195-9f257e079cbc -->
  <rule id="688756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2324 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>