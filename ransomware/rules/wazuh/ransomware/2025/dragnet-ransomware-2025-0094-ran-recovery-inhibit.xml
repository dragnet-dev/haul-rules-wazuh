<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0094 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: d4e06257-6b5e-50f2-9fd9-0346892d25a4 -->
  <rule id="458062" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0094 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>