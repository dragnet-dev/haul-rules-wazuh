<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2124 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 7ba448ab-0cc8-5ada-9945-1d937788a7a9 -->
  <rule id="278448" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2124 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>