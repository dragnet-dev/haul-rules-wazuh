<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4372 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 352e9772-b0c9-537a-9a50-0bc77b6f0077 -->
  <rule id="346977" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4372 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
