<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6457 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 5d658fa0-bb44-56c2-9275-5db544de94d3 -->
  <rule id="698543" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6457 — Recovery Inhibition (sinobi)</description>
