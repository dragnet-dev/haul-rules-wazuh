<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6672 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 04fe9e37-75f9-53aa-83d3-c45d80fca093 -->
  <rule id="346383" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6672 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>