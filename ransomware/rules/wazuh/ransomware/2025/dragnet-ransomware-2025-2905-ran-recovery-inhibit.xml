<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2905 — Recovery Inhibition (sinobi) | Status: experimental | Sigma ID: 67d2cf8b-9219-5f64-ab6a-039754be8c87 -->
  <rule id="178319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2905 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>