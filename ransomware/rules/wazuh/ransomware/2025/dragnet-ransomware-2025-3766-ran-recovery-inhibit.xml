<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3766 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 62ad6e30-5c9f-57c9-9095-4515d9275d35 -->
  <rule id="867310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3766 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>