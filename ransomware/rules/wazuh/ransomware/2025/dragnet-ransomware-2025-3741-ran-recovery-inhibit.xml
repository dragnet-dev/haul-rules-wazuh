<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3741 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0b115d12-6e1e-5cab-bd8a-74de5fb7c1fe -->
  <rule id="978531" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3741 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>