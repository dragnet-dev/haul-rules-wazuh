<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0169 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2a209cbd-cdb8-5594-861c-151686673d48 -->
  <rule id="105707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0169 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>