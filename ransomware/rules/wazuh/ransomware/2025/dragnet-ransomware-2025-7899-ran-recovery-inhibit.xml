<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7899 — Recovery Inhibition (anubis) | Status: experimental | Sigma ID: 61d18bde-77b5-56ad-9d52-00793df96367 -->
  <rule id="782699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7899 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>