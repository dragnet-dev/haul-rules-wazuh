<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5971 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: ed4f3987-20d4-579d-9b59-74faf6c3d349 -->
  <rule id="299939" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5971 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>