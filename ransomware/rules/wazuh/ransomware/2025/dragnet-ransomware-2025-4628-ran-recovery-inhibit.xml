<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4628 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: abead203-a290-5c89-8114-37e53ee2d166 -->
  <rule id="841732" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4628 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>