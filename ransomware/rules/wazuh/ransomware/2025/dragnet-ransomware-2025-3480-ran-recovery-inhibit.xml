<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3480 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 1cfde66d-c850-5778-876c-575c1a8528c3 -->
  <rule id="387506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3480 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>