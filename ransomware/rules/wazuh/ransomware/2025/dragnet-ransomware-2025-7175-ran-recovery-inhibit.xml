<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7175 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ffe7d880-da46-5d40-9e96-418ddf2e7716 -->
  <rule id="351658" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7175 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>