<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6165 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 2e66362b-bd08-5f4f-a3a8-a7262c0cca56 -->
  <rule id="266362" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6165 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>