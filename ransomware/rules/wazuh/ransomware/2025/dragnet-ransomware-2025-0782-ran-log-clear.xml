<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0782 — Event Log Clearing (bert) | Status: experimental | Sigma ID: e91a2896-de22-53b4-975a-1cf9f477329d -->
  <rule id="686628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0782 — Event Log Clearing (bert)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>