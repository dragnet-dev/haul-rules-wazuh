<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2228 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: a9232208-7ab4-54e2-961a-6b3bcdf71a78 -->
  <rule id="292322" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2228 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>