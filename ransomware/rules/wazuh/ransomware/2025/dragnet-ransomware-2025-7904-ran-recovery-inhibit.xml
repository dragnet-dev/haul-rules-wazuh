<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7904 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 98b0faa8-b29f-5c58-ad27-b2425e47bae6 -->
  <rule id="542490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7904 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>