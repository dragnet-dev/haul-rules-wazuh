<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7334 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: a88d89e8-b683-51d1-b097-e01950388467 -->
  <rule id="942189" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7334 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
