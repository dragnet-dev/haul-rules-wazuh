<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3798 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 67543100-cb2a-54a1-9ed9-7132b47643f7 -->
  <rule id="554310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3798 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>