<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5915 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 9f4d7601-2122-5620-8dae-61b6a461ebde -->
  <rule id="851776" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5915 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>