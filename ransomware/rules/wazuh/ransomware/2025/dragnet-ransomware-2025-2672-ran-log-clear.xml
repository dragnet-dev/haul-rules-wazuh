<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2672 — Event Log Clearing (IMNCrew) | Status: experimental | Sigma ID: d103861c-5082-5740-a818-30b620801895 -->
  <rule id="510386" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2672 — Event Log Clearing (IMNCrew)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>