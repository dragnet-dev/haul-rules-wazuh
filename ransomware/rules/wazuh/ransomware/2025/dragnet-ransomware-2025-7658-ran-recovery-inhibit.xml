<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7658 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c8bc5b2c-948a-5b14-8480-bb6e7ee98e67 -->
  <rule id="873051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7658 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>