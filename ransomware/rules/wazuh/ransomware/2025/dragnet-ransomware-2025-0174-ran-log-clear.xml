<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0174 — Event Log Clearing (lynx) | Status: experimental | Sigma ID: f1bc5d2b-d4b0-56a4-9f4d-d721efeabf69 -->
  <rule id="915133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0174 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>