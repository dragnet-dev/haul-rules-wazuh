<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3489 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: f9b416ca-05ee-586b-a698-4ce97fa5b5f4 -->
  <rule id="855416" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3489 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>