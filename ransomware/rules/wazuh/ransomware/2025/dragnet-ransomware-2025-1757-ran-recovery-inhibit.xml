<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1757 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 0db9bab6-771b-5dad-adaa-4c332c5b8cb0 -->
  <rule id="110091" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1757 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>