<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7392 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 98474153-a073-58d4-8346-3a90d6ff2dc9 -->
  <rule id="947415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7392 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>