<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7461 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 19ffbbe8-9316-5a76-ab8d-b072f2e1c53d -->
  <rule id="510651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7461 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>