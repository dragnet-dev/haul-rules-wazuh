<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1652 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: c9a64177-c599-50f4-a6ae-a990870d0f9a -->
  <rule id="374641" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1652 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>