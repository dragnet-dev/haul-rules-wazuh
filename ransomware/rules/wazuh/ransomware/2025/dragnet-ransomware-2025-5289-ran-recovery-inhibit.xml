<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5289 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 03ede51e-ef28-5b7e-80e0-6524a377ecab -->
  <rule id="809451" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5289 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>