<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6099 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: fb471f25-bf13-55de-9800-7dbabe3837bc -->
  <rule id="523551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6099 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>