<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5631 — Recovery Inhibition (worldleaks) | Status: experimental | Sigma ID: c1ea0621-cbcf-5555-892d-6d510e6b592e -->
  <rule id="521006" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5631 — Recovery Inhibition (worldleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>