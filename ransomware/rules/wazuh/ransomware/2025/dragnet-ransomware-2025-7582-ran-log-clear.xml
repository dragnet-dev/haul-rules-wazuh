<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7582 — Event Log Clearing (kawa4096) | Status: deprecated | Sigma ID: 74d047ac-c5e6-506a-ab27-d6841d3d011d -->
  <rule id="397047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7582 — Event Log Clearing (kawa4096)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>