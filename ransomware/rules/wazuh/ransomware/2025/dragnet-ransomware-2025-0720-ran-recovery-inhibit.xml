<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0720 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 97bd51cf-80d4-568e-9518-80a36d2ac343 -->
  <rule id="802151" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0720 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>