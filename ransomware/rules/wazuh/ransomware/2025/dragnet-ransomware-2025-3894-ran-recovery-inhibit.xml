<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3894 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 55ccb449-fd1b-5137-b584-0a1f29d0995b -->
  <rule id="585554" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3894 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>