<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5769 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: ff410776-c954-5ca3-9464-438e5608f4e3 -->
  <rule id="854107" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5769 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>