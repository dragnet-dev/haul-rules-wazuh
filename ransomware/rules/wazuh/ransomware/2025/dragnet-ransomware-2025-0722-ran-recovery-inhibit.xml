<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0722 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 096c5029-90dc-54d5-8116-72c2a725d254 -->
  <rule id="748502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0722 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>