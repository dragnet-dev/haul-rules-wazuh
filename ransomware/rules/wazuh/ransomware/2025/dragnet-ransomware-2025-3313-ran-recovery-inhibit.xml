<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3313 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: abfff877-1784-516d-8ddf-8a73f38b76a0 -->
  <rule id="845118" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3313 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>