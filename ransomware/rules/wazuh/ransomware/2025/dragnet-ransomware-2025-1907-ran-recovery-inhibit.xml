<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-1907 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 1ac87a98-e193-5aa1-906f-7d2070e05ba3 -->
  <rule id="662029" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-1907 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>