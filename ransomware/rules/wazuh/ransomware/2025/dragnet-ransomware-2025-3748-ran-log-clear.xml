<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3748 — Event Log Clearing (hellcat) | Status: deprecated | Sigma ID: 4c0b0849-44e3-5dfb-988b-3489a51e61d9 -->
  <rule id="417108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3748 — Event Log Clearing (hellcat)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>