<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-5864 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b0586bcf-f012-548a-8fea-9706f70269fb -->
  <rule id="969387" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-5864 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>