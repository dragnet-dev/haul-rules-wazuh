<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0853 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f4ff9114-adad-5774-b56b-5707678518b1 -->
  <rule id="467991" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0853 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>