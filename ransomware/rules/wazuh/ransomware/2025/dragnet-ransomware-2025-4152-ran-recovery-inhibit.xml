<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4152 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: e077c36d-f40f-5529-b11b-94dc85892f98 -->
  <rule id="552443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4152 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>