<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7329 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 52b9196b-9f33-56cd-8a50-0451103d9143 -->
  <rule id="439196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7329 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>