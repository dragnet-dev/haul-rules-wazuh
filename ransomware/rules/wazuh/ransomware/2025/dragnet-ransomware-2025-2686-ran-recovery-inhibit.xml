<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2686 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: d2075f00-f9f7-5d9b-89d7-447caa7c3cec -->
  <rule id="413215" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2686 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>