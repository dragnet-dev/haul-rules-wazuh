<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3349 — Event Log Clearing (rebornvc) | Status: deprecated | Sigma ID: a8cc7e97-e7cf-58ce-800b-cfc536359e9f -->
  <rule id="956446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3349 — Event Log Clearing (rebornvc)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>