<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2615 — Recovery Inhibition (devman) | Status: experimental | Sigma ID: 5c0f78a7-018a-5a07-a1b2-cfa0425db527 -->
  <rule id="673578" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2615 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>