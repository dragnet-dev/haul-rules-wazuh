<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2704 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: c5184c9c-a464-5822-aced-1ed357a3c617 -->
  <rule id="302956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2704 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>