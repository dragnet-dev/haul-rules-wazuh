<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-7821 — Event Log Clearing (abyss) | Status: deprecated | Sigma ID: 8d21b9f9-f106-59a4-b8a8-ed0638ae7975 -->
  <rule id="559479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-7821 — Event Log Clearing (abyss)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>