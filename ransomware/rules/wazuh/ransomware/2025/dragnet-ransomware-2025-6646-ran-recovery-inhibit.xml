<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6646 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 4e0b5231-3573-5386-91e7-e054148a0964 -->
  <rule id="449152" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6646 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>