<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4327 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 39c0ddcb-2b6a-5894-9298-a30349573b4e -->
  <rule id="828381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4327 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>