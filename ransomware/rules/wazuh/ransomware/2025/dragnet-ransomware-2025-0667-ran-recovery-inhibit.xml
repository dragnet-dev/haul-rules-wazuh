<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-0667 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: e1d76849-f110-5613-b8f4-74e8c6371623 -->
  <rule id="569768" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-0667 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>