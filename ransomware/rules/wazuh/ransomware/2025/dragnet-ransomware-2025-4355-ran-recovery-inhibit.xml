<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-4355 — Recovery Inhibition (qilin) | Status: test | Sigma ID: a36cb7b2-4d6a-5b42-b948-f510c4d54514 -->
  <rule id="954197" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-4355 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>