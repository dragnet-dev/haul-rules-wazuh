<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-3070 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: bd62d436-5ca6-5a89-b261-cc3062b5b917 -->
  <rule id="434054" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-3070 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>