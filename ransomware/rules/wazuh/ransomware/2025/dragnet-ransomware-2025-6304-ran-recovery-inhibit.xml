<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-6304 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 35707d08-7b07-577e-a24e-fdac6d6b4974 -->
  <rule id="413250" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-6304 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>