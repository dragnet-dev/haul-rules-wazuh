<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2025-2029 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: 44b0c86c-5c49-5259-8b6b-cd097cac7a4f -->
  <rule id="344128" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2025-2029 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>