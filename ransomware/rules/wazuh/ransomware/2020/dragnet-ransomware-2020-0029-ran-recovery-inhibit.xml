<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0029 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: f3600dab-b338-5100-9105-f87e113d7346 -->
  <rule id="757613" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0029 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>