<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0093 — Event Log Clearing (ragnarlocker) | Status: deprecated | Sigma ID: 3258d733-69e4-5b79-9ef7-cabd7cef0b44 -->
  <rule id="814173" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0093 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>