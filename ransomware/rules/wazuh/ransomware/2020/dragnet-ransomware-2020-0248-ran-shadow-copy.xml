<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0248 — Shadow Copy Deletion (pay2key) | Status: deprecated | Sigma ID: c4d9d8ec-6ccc-5339-b3c4-5fb3a4dc6220 -->
  <rule id="596778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0248 — Shadow Copy Deletion (pay2key)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>