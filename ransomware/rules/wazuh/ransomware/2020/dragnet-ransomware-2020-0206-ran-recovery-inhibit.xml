<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0206 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 3b250504-5a6a-52fd-a1f2-f3b0366076b6 -->
  <rule id="625050" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0206 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>