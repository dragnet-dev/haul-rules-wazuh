<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0106 — Event Log Clearing (ragnarlocker) | Status: deprecated | Sigma ID: 67a6364b-fb0f-50e8-9f21-645b1f93cf13 -->
  <rule id="282636" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0106 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>