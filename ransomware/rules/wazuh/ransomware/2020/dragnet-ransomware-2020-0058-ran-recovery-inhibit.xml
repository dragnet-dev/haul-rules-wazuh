<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0058 — Recovery Inhibition (lockbit) | Status: deprecated | Sigma ID: 637026fb-a5d1-5462-91ef-fe07ea667859 -->
  <rule id="392431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0058 — Recovery Inhibition (lockbit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>