<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0037 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 4c88ace8-b50e-5dcb-b9a7-8bba5c1ba410 -->
  <rule id="268300" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0037 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>