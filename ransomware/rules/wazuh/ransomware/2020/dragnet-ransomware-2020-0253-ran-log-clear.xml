<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0253 — Event Log Clearing (revil) | Status: deprecated | Sigma ID: 0ba446d2-9fa6-5b77-8ae3-d3bc948f06f7 -->
  <rule id="383149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0253 — Event Log Clearing (revil)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>