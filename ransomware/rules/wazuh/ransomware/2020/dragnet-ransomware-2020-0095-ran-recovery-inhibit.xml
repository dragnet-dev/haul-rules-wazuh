<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0095 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 3aa7c233-8f4f-5466-8878-8ee0fc83f4aa -->
  <rule id="702042" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0095 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>