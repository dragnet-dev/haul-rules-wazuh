<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0141 — Recovery Inhibition (ransomexx) | Status: deprecated | Sigma ID: fc90c7ff-817b-5043-bce4-8a424539bd10 -->
  <rule id="546527" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0141 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>