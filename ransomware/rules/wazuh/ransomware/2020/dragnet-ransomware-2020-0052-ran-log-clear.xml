<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0052 — Event Log Clearing (maze) | Status: deprecated | Sigma ID: afa7b693-75d3-5874-97cf-38a1d367ba65 -->
  <rule id="997236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0052 — Event Log Clearing (maze)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>