<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0212 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 53a87212-1ae8-5757-8dda-a27e3ab775df -->
  <rule id="588721" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0212 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>