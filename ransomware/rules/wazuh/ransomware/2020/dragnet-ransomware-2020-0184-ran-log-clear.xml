<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0184 — Event Log Clearing (revil) | Status: deprecated | Sigma ID: 6ea97e99-4880-5936-8b37-9a7f5a3100d4 -->
  <rule id="233566" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0184 — Event Log Clearing (revil)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>