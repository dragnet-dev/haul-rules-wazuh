<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0113 — Event Log Clearing (doppelpaymer) | Status: deprecated | Sigma ID: 80b4c8bc-0c9d-5045-8b05-99f4589dd5f9 -->
  <rule id="366368" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0113 — Event Log Clearing (doppelpaymer)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>