<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0199 — Event Log Clearing (ryuk) | Status: deprecated | Sigma ID: a9ea2f25-abee-5e7a-b27f-c8d357bfc24d -->
  <rule id="102127" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0199 — Event Log Clearing (ryuk)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>