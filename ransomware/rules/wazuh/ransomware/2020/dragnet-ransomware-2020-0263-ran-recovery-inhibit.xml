<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0263 — Recovery Inhibition (ransomexx) | Status: deprecated | Sigma ID: 76625554-9c9b-5670-ac25-16d5987eb8a8 -->
  <rule id="562555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0263 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>