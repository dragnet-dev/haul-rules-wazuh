<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0018 — Recovery Inhibition (lockbit) | Status: deprecated | Sigma ID: a7d5ab52-c8df-56ac-a01a-5d5f10baa0c9 -->
  <rule id="917451" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0018 — Recovery Inhibition (lockbit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>