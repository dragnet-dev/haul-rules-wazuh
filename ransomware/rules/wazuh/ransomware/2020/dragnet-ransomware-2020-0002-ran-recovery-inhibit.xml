<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0002 — Recovery Inhibition (nefilim) | Status: deprecated | Sigma ID: 2b02670f-db38-5527-9a56-e7ea2917f8ca -->
  <rule id="802670" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0002 — Recovery Inhibition (nefilim)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>