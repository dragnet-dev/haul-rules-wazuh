<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0195 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 28606290-bc55-527d-b67e-98f6a4e87ee0 -->
  <rule id="260629" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0195 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>