<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0132 — Event Log Clearing (netwalker) | Status: deprecated | Sigma ID: aa50b6ab-d54c-5a5b-afad-ce3a203f1f6a -->
  <rule id="128116" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0132 — Event Log Clearing (netwalker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>