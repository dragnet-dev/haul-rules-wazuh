<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0127 — Event Log Clearing (netwalker) | Status: deprecated | Sigma ID: 4ad46ccf-1e5c-55cb-9930-a4e2f760dc00 -->
  <rule id="215948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0127 — Event Log Clearing (netwalker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>