<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0022 — Recovery Inhibition (ryuk) | Status: deprecated | Sigma ID: e4f1d650-69b9-5089-834f-abea558c46bb -->
  <rule id="210696" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0022 — Recovery Inhibition (ryuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>