<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0144 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 78cb7e53-9b78-5008-a772-51a888d07c37 -->
  <rule id="627486" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0144 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>