<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0043 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 10344df3-6999-5172-8003-a4c25a45e0d9 -->
  <rule id="948287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0043 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>