<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0174 — Recovery Inhibition (sekhmet) | Status: deprecated | Sigma ID: 452fc3c5-be5c-5701-a636-3b8d837198b1 -->
  <rule id="359643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0174 — Recovery Inhibition (sekhmet)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>