<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0153 — Shadow Copy Deletion (doppelpaymer) | Status: deprecated | Sigma ID: 72af5156-34f7-5cdb-9002-f34e2c041f2f -->
  <rule id="160751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0153 — Shadow Copy Deletion (doppelpaymer)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>