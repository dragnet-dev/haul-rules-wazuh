<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0065 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 9d1478ce-d6ac-5c5c-8589-db1a87d1d40f -->
  <rule id="771478" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0065 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>