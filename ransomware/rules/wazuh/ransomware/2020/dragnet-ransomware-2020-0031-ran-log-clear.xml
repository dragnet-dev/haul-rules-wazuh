<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0031 — Event Log Clearing (agelocker) | Status: deprecated | Sigma ID: 0d0f66cb-4dfb-53c6-98a9-7439819c6b2d -->
  <rule id="753068" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0031 — Event Log Clearing (agelocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>