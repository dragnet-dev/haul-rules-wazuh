<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0055 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 4b3a8be2-7f51-5cde-abe2-78a9fa693f8a -->
  <rule id="229419" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0055 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>