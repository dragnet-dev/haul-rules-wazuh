<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0189 — Recovery Inhibition (maze) | Status: deprecated | Sigma ID: 95cf5c03-2150-5f80-9461-d89340d5a584 -->
  <rule id="424412" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0189 — Recovery Inhibition (maze)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>