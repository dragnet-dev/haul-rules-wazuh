<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0131 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: da8ae1b9-aea4-5d9f-bbbd-38cc9bb486e0 -->
  <rule id="303021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0131 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>