<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0162 — Recovery Inhibition (netwalker) | Status: deprecated | Sigma ID: 68ca98d2-4c5a-5ddf-99c1-3cdbf07095e5 -->
  <rule id="961098" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0162 — Recovery Inhibition (netwalker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>