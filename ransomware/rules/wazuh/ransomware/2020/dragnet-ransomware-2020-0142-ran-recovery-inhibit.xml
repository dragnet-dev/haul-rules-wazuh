<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0142 — Recovery Inhibition (ryuk) | Status: deprecated | Sigma ID: 0e30bf07-74fd-542f-9348-51d7fd4647bc -->
  <rule id="162710" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0142 — Recovery Inhibition (ryuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>