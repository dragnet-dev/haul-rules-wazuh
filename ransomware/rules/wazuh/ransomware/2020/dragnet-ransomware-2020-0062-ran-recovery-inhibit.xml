<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0062 — Recovery Inhibition (maze) | Status: deprecated | Sigma ID: f7a5bbef-9173-5e03-9f77-44e82207f43f -->
  <rule id="257787" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0062 — Recovery Inhibition (maze)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>