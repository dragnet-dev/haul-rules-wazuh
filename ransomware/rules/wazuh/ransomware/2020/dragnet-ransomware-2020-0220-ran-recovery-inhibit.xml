<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0220 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 3e355196-3efd-545c-815f-68955429ba20 -->
  <rule id="935519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0220 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
