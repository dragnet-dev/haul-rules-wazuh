<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0237 — Event Log Clearing (maze) | Status: deprecated | Sigma ID: 4ec05072-46bd-52be-8e14-1c0480edb24e -->
  <rule id="460050" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0237 — Event Log Clearing (maze)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>