<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0188 — Event Log Clearing (revil) | Status: deprecated | Sigma ID: 52a8b44b-ebf7-5fb5-9d0d-d18a60c8c8f5 -->
  <rule id="548594" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0188 — Event Log Clearing (revil)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>