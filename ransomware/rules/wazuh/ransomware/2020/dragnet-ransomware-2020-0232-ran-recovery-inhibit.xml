<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0232 — Recovery Inhibition (doppelpaymer) | Status: deprecated | Sigma ID: 22bdf385-8c82-5975-a88d-7c8549f833de -->
  <rule id="415138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0232 — Recovery Inhibition (doppelpaymer)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>