<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0058 — Event Log Clearing (lockbit) | Status: deprecated | Sigma ID: 2a93cfb3-cbcf-5d9d-abd8-90f90e3057e9 -->
  <rule id="299215" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0058 — Event Log Clearing (lockbit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>