<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0205 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: 55e469be-f13a-5bde-a1ac-bc2a2906c744 -->
  <rule id="911515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0205 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>