<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0120 — Event Log Clearing (netwalker) | Status: deprecated | Sigma ID: 7e60a2f1-711c-5cc6-bf9c-c20d80b5515b -->
  <rule id="325702" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0120 — Event Log Clearing (netwalker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>