<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0027 — Recovery Inhibition (mamba) | Status: deprecated | Sigma ID: 312c5f53-f710-5ef4-b825-5f340b721c9c -->
  <rule id="907355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0027 — Recovery Inhibition (mamba)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>