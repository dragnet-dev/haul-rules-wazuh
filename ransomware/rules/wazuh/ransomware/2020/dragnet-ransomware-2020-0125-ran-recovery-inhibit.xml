<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0125 — Recovery Inhibition (ransomexx) | Status: deprecated | Sigma ID: 8ce7d053-7670-5f12-95dd-5e1e15863266 -->
  <rule id="107650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0125 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>