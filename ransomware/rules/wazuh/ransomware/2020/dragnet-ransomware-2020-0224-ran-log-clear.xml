<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0224 — Event Log Clearing (netflim) | Status: deprecated | Sigma ID: 8200d670-0178-5f04-8e2f-fe07f3484be2 -->
  <rule id="512136" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0224 — Event Log Clearing (netflim)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>