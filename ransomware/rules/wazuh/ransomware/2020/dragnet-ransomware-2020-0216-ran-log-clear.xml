<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0216 — Event Log Clearing (coldlock) | Status: deprecated | Sigma ID: e8621c4a-9829-55a0-9534-c489ab6012cd -->
  <rule id="677948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0216 — Event Log Clearing (coldlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>