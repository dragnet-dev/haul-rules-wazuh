<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0150 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 29a7564d-cc59-5f40-a6b4-a610821dfaca -->
  <rule id="347564" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0150 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>