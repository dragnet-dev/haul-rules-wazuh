<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0170 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 627c4119-081c-5f7f-ae02-91095928cc74 -->
  <rule id="204441" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0170 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
