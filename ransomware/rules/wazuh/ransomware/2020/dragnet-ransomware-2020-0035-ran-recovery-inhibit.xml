<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0035 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: c7fd2f1b-a461-5766-a0df-f3be2efe3388 -->
  <rule id="842447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0035 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>