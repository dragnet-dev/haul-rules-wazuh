<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0119 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: cd81ce8b-ef03-5f05-9a34-7866ff2cda74 -->
  <rule id="868942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0119 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>