<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0043 — Event Log Clearing (ragnarlocker) | Status: deprecated | Sigma ID: 73b1e5fb-fffa-5bdd-8c3c-cf0cdbff0db9 -->
  <rule id="186705" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0043 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>