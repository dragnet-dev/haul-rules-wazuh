<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0171 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: df4bc89e-9989-542a-9e5c-cef8cb928d9f -->
  <rule id="420928" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0171 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>