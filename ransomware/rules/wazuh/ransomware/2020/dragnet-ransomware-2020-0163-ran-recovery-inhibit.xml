<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0163 — Recovery Inhibition (netwalker) | Status: deprecated | Sigma ID: 1340dea5-b9a8-5070-8185-bfba19b551e2 -->
  <rule id="192202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0163 — Recovery Inhibition (netwalker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>