<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0268 — Recovery Inhibition (babuk) | Status: deprecated | Sigma ID: dcb83e44-abaa-5fe1-99c9-174f0810fffe -->
  <rule id="350942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0268 — Recovery Inhibition (babuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
