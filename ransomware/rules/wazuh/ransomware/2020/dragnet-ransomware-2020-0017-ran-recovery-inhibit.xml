<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0017 — Recovery Inhibition (doppelpaymer) | Status: deprecated | Sigma ID: ad4f9472-246e-54dd-938c-b48f18c2db1a -->
  <rule id="175994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0017 — Recovery Inhibition (doppelpaymer)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>