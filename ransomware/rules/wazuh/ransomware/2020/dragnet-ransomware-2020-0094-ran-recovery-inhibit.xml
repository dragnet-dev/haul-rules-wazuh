<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0094 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 32342b82-b635-5e41-92c1-cdd23130f2bc -->
  <rule id="774838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0094 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>