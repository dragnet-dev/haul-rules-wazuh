<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0250 — Event Log Clearing (doppelpaymer) | Status: deprecated | Sigma ID: 59f07cc9-57fa-5376-8c96-463fcbe4bd34 -->
  <rule id="734524" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0250 — Event Log Clearing (doppelpaymer)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>