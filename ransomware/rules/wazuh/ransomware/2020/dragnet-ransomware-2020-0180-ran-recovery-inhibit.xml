<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0180 — Recovery Inhibition (ransomexx) | Status: deprecated | Sigma ID: d7d5363e-f334-57c0-a9ef-5880ea4d7a12 -->
  <rule id="505536" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0180 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>