<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0156 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: e73331f8-3e1e-59c9-9fb8-60caf4bcd362 -->
  <rule id="673331" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0156 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>