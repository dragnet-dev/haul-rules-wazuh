<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0147 — Recovery Inhibition (coldlock) | Status: deprecated | Sigma ID: 18183819-6861-5230-b29f-9086070fa876 -->
  <rule id="118381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0147 — Recovery Inhibition (coldlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>