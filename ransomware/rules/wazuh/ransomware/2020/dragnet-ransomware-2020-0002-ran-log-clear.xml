<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0002 — Event Log Clearing (nefilim) | Status: deprecated | Sigma ID: 12eb01a4-fd8b-59ed-838c-6d81f799e398 -->
  <rule id="891226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0002 — Event Log Clearing (nefilim)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>