<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0245 — Event Log Clearing (ryuk) | Status: deprecated | Sigma ID: a1e26003-0c2b-5977-80f1-e3bd7b4c30e3 -->
  <rule id="830260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0245 — Event Log Clearing (ryuk)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>