<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0030 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 1849c37d-2b7b-5d48-82af-c428e3f75a3d -->
  <rule id="359637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0030 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>