<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0091 — Event Log Clearing (snake) | Status: deprecated | Sigma ID: 0cf27cd8-1e06-5890-be02-ed87755f7c44 -->
  <rule id="906317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0091 — Event Log Clearing (snake)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>