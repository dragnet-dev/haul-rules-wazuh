<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0166 — Event Log Clearing (netwalker) | Status: deprecated | Sigma ID: e0e4d420-5075-538c-a2c4-58929f1f1268 -->
  <rule id="107174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0166 — Event Log Clearing (netwalker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>