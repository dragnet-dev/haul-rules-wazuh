<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0192 — Event Log Clearing (ragnarlocker) | Status: deprecated | Sigma ID: af9b7dc7-a756-50a7-8523-4ebcbc2370b8 -->
  <rule id="104925" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0192 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>