<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0223 — Recovery Inhibition (suncrypt) | Status: deprecated | Sigma ID: 5f44bbd6-9e1e-5144-b1ce-a70f76e537f6 -->
  <rule id="743451" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0223 — Recovery Inhibition (suncrypt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>