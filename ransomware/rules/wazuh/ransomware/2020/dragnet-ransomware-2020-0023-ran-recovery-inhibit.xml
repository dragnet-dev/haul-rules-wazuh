<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0023 — Recovery Inhibition (ransomexx) | Status: deprecated | Sigma ID: 9e97bcaf-0da3-577d-9f11-e81fb560c759 -->
  <rule id="569820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0023 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>