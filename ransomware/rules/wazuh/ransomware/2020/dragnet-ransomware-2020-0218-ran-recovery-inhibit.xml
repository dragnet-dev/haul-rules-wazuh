<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0218 — Recovery Inhibition (ryuk) | Status: deprecated | Sigma ID: bfd1d0fd-b6fa-5f89-a25e-e57f83a82ebf -->
  <rule id="510690" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0218 — Recovery Inhibition (ryuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>