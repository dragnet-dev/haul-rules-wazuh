<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0159 — Event Log Clearing (snake) | Status: deprecated | Sigma ID: 08cd395e-d975-505c-880b-a06fda33f00f -->
  <rule id="553395" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0159 — Event Log Clearing (snake)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>