<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0032 — Recovery Inhibition (ryuk) | Status: deprecated | Sigma ID: bbec5f88-74f6-5780-a320-1e6dfa86dc89 -->
  <rule id="597375" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0032 — Recovery Inhibition (ryuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>