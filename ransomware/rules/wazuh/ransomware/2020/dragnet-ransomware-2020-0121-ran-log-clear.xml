<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0121 — Event Log Clearing (egregor) | Status: deprecated | Sigma ID: 3e7a8ef0-6212-5957-be9c-73af5a02a839 -->
  <rule id="806862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0121 — Event Log Clearing (egregor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>