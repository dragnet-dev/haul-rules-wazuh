<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0034 — Recovery Inhibition (ryuk) | Status: deprecated | Sigma ID: a2017a49-860a-5c1e-8bbe-98fb258cbce7 -->
  <rule id="832282" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0034 — Recovery Inhibition (ryuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>