<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0195 — Event Log Clearing (ragnarlocker) | Status: deprecated | Sigma ID: 3a2d8448-0ac6-5cd9-bfdd-785b13ac28da -->
  <rule id="425844" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0195 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>