<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0036 — Recovery Inhibition (ryuk) | Status: deprecated | Sigma ID: 0ce790ee-7cab-57c1-a010-e02ff48f07a7 -->
  <rule id="708654" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0036 — Recovery Inhibition (ryuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>