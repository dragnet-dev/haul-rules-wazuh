<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0227 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 7337a00b-a83f-51cd-9079-e4506a2a5672 -->
  <rule id="374020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0227 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>