<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0208 — Recovery Inhibition (ryuk) | Status: deprecated | Sigma ID: b3ccf491-a872-5e75-8fbe-fc36fa49428f -->
  <rule id="261274" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0208 — Recovery Inhibition (ryuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>