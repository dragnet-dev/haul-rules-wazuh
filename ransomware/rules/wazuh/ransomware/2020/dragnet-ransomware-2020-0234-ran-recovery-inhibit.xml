<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0234 — Recovery Inhibition (ryuk) | Status: deprecated | Sigma ID: da4eb0d3-f4d8-50c5-8855-c1161356b656 -->
  <rule id="293390" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0234 — Recovery Inhibition (ryuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>