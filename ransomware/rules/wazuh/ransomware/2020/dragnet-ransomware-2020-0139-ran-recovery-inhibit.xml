<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0139 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 916e0955-53f5-569c-b2b6-6dc46ca19658 -->
  <rule id="667009" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0139 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>