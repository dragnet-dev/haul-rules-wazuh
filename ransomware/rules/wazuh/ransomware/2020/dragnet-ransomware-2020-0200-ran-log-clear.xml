<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0200 — Event Log Clearing (ryuk) | Status: deprecated | Sigma ID: 431a346a-49df-52bf-aa9a-89492693ca91 -->
  <rule id="706346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0200 — Event Log Clearing (ryuk)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>