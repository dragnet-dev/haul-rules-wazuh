<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0244 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: f1ee778b-ac77-5ab1-a631-2ea4dc110b2e -->
  <rule id="389477" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0244 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>