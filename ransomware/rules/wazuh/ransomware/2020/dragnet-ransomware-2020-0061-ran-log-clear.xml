<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0061 — Event Log Clearing (egregor) | Status: deprecated | Sigma ID: 482a6279-3572-52f1-8dc7-ee4b4c0854cf -->
  <rule id="622627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0061 — Event Log Clearing (egregor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>