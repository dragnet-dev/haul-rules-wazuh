<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0014 — Recovery Inhibition (doppelpaymer) | Status: deprecated | Sigma ID: 4aa56460-57cd-5375-9823-d87b0d794c19 -->
  <rule id="394564" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0014 — Recovery Inhibition (doppelpaymer)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>