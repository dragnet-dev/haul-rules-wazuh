<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0022 — Event Log Clearing (ryuk) | Status: deprecated | Sigma ID: 06a0237e-59b3-5ee0-bb3d-a08ce691cfa5 -->
  <rule id="260237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0022 — Event Log Clearing (ryuk)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>