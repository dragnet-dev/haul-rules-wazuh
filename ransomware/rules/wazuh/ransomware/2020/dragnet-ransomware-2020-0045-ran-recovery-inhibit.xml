<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0045 — Recovery Inhibition (ransomexx) | Status: deprecated | Sigma ID: b1f22ce6-d7cb-559d-a4a8-655bce9bdd74 -->
  <rule id="265964" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0045 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>