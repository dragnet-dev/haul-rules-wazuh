<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0224 — Recovery Inhibition (netflim) | Status: deprecated | Sigma ID: 6e1010ef-2256-5ec1-afb2-a9095901cc84 -->
  <rule id="301010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0224 — Recovery Inhibition (netflim)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
