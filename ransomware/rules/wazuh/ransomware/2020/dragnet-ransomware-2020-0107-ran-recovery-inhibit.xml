<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0107 — Recovery Inhibition (maze) | Status: experimental | Sigma ID: 481e091a-fc4f-5927-80a1-4be9af631393 -->
  <rule id="610091" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0107 — Recovery Inhibition (maze)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>