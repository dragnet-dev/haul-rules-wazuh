<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0158 — Event Log Clearing (ragnarlocker) | Status: deprecated | Sigma ID: f6c70e2d-6b4e-5996-a172-3b1f9ec04d7c -->
  <rule id="513934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0158 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>