<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0139 — Event Log Clearing (ragnarlocker) | Status: deprecated | Sigma ID: 91707545-c19f-5e8e-9d41-72ad877d4ef2 -->
  <rule id="270754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0139 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>