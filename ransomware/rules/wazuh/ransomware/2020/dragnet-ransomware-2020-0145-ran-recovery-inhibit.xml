<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0145 — Recovery Inhibition (ransomexx) | Status: deprecated | Sigma ID: b6d0b5eb-ee22-5f01-b205-e831b9505032 -->
  <rule id="390515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0145 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>