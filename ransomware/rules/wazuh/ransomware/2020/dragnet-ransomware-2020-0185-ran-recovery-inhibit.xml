<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0185 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 015334ab-984f-5523-bb1f-c15f64c3d6eb -->
  <rule id="425675" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0185 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>