<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0172 — Recovery Inhibition (ransomexx) | Status: deprecated | Sigma ID: 1f0ae5cd-bd18-5f12-bca1-208bce21f2ae -->
  <rule id="225532" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0172 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>