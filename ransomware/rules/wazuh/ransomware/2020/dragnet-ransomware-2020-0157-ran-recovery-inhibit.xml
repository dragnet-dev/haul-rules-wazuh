<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0157 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 15d8d442-870e-5a26-ad3f-21d9fb8c6c7f -->
  <rule id="562144" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0157 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>