<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0243 — Recovery Inhibition (clop) | Status: deprecated | Sigma ID: 0835ba3b-d62c-5306-a697-513ad5e13ca7 -->
  <rule id="439463" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0243 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>