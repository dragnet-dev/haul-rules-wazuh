<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0088 — Event Log Clearing (ragnarlocker) | Status: deprecated | Sigma ID: 39a1301d-6dc7-5490-a06c-96232a93cd86 -->
  <rule id="141301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0088 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>