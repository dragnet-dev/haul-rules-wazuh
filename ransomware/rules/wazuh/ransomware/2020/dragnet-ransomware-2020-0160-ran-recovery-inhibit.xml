<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0160 — Recovery Inhibition (doppelpaymer) | Status: deprecated | Sigma ID: 35f6127e-5afc-5ce1-8232-b95f046be146 -->
  <rule id="456127" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0160 — Recovery Inhibition (doppelpaymer)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>