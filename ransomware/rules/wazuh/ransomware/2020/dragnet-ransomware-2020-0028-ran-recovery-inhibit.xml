<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0028 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: b9d58ec0-ac48-55c0-8443-ff752d882570 -->
  <rule id="468142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0028 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>