<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0247 — Event Log Clearing (netwalker) | Status: deprecated | Sigma ID: 9a7fa1e2-4b60-54dc-ac96-96f456433cd5 -->
  <rule id="462821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0247 — Event Log Clearing (netwalker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>