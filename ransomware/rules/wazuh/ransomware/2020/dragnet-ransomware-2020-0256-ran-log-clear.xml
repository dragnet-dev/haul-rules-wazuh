<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0256 — Event Log Clearing (maze) | Status: deprecated | Sigma ID: 432775dd-cd3f-56a6-9e49-7fbf9d7090b5 -->
  <rule id="724413" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0256 — Event Log Clearing (maze)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>