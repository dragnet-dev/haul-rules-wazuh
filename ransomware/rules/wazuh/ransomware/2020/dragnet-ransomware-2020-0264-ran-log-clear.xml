<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0264 — Event Log Clearing (prolock) | Status: deprecated | Sigma ID: b6c1a2e0-159c-589e-a0ed-e49d13ed938f -->
  <rule id="389062" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0264 — Event Log Clearing (prolock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>