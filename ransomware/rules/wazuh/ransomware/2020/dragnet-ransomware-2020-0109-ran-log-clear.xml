<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0109 — Event Log Clearing (maze) | Status: deprecated | Sigma ID: f7deed9c-114b-53c9-b4bb-cedb89bbd3e0 -->
  <rule id="546221" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0109 — Event Log Clearing (maze)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>