<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0166 — Recovery Inhibition (netwalker) | Status: deprecated | Sigma ID: cd99eff5-bedf-5376-86ae-7aa5bc5b92fb -->
  <rule id="873583" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0166 — Recovery Inhibition (netwalker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>