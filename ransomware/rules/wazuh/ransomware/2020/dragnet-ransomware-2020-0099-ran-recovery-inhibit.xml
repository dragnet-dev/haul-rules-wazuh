<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0099 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 387fb54f-ed71-554e-920e-3f111878c2df -->
  <rule id="132354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0099 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>