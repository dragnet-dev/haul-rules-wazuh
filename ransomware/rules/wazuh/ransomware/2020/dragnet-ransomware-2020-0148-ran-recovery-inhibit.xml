<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0148 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: b1908094-3bf6-575d-842c-e82d9b208fe1 -->
  <rule id="319080" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0148 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>