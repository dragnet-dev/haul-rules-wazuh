<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0182 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: e08ae91e-144c-58ed-8811-ef36eee1409d -->
  <rule id="106229" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0182 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>