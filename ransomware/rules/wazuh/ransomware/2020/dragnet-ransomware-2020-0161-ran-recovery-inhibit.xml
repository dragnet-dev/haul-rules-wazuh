<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0161 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 98dad983-cfe9-595b-8941-bb624d275b7c -->
  <rule id="549099" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0161 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
