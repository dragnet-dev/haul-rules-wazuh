<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0245 — Recovery Inhibition (ryuk) | Status: deprecated | Sigma ID: bb618a96-8994-55ae-abf8-674d15899dff -->
  <rule id="401898" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0245 — Recovery Inhibition (ryuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>