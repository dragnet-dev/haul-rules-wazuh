<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0188 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 787fbbd7-6985-53e6-a962-fd5c19ff4b59 -->
  <rule id="627579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0188 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>