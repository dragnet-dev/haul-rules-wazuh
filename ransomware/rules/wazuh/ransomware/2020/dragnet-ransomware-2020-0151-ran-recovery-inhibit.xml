<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0151 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: b785ca61-e169-5762-a2f0-c2b1d32d84b8 -->
  <rule id="417162" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0151 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>