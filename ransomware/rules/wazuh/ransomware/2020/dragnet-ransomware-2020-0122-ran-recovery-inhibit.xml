<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0122 — Recovery Inhibition (ryuk) | Status: deprecated | Sigma ID: 297f2a59-90f2-52b7-b23f-9662a76a4faa -->
  <rule id="527625" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0122 — Recovery Inhibition (ryuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>