<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0073 — Recovery Inhibition (ransomexx) | Status: deprecated | Sigma ID: 514ac63a-9589-5863-9dfa-e4a2eedf2215 -->
  <rule id="517566" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0073 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>