<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0242 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: ec5016af-2a0e-52ef-bd78-6849c0c6c47b -->
  <rule id="665016" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0242 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>