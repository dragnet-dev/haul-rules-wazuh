<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0081 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: ee687261-12e7-5730-bcd2-89de3aa4e9a1 -->
  <rule id="686872" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0081 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>