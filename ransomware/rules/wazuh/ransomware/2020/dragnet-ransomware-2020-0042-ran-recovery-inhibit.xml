<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0042 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 8f15acdb-8ee2-54ca-be59-554ab28e4bba -->
  <rule id="164812" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0042 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>