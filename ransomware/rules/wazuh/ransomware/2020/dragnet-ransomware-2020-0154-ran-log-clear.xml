<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2020-0154 — Event Log Clearing (ryuk) | Status: deprecated | Sigma ID: bbd00ec3-72f8-52b8-b3fd-3eda36ad1d1f -->
  <rule id="408014" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2020-0154 — Event Log Clearing (ryuk)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>