  <rule id="507083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0584 — Event Log Clearing (quantum)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
