<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0501 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: a89c706b-97f1-5b24-8b27-2c3d6b9a77dd -->
  <rule id="943670" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0501 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>