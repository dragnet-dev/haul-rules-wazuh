<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0529 — Event Log Clearing (sabbath) | Status: deprecated | Sigma ID: 73c3e601-9db0-558b-8ccb-2e0f371e8dda -->
  <rule id="188626" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0529 — Event Log Clearing (sabbath)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>