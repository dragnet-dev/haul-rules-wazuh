<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0553 — Shadow Copy Deletion (darkleakmarket) | Status: deprecated | Sigma ID: 3b317a20-3494-517d-a81c-121b8cb8bf91 -->
  <rule id="590822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0553 — Shadow Copy Deletion (darkleakmarket)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>