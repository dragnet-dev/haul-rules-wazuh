<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1486 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: 5993cc2d-44d2-5fd7-8115-be5ff062afb5 -->
  <rule id="734412" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1486 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>