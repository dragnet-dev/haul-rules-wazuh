<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0024 — Recovery Inhibition (spook) | Status: deprecated | Sigma ID: c3597280-832a-58c0-a58e-d91f0009bedc -->
  <rule id="435972" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0024 — Recovery Inhibition (spook)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
