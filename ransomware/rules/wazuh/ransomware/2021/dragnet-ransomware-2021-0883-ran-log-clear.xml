<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0883 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 2f4400d4-0cf4-5225-9744-2d182eff4f5f -->
  <rule id="490413" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0883 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>