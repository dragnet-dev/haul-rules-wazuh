<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1375 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: b60be2e4-2744-5ef3-94a8-f2b273011ab3 -->
  <rule id="371502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1375 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>