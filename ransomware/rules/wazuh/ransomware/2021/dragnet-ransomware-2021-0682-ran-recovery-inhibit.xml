<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0682 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 1fe6459b-3361-5d09-8429-67531cc50f80 -->
  <rule id="706459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0682 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>