<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1436 — Event Log Clearing (marketo) | Status: deprecated | Sigma ID: a975c825-10e2-5cec-9a44-ce75f11a69cb -->
  <rule id="956128" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1436 — Event Log Clearing (marketo)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>