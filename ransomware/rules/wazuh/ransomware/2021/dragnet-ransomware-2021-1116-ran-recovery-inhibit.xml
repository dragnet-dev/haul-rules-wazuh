<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1116 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: be64e329-ea22-5e08-ab52-5526e913531a -->
  <rule id="450383" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1116 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>