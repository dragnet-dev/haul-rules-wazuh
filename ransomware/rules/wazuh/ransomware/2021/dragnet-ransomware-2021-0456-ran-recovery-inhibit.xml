<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0456 — Recovery Inhibition (rook) | Status: deprecated | Sigma ID: d9a704ff-0c97-55a2-abf4-8468b2924752 -->
  <rule id="534704" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0456 — Recovery Inhibition (rook)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>