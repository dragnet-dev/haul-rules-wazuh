<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1737 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 325a231c-8e4d-5eef-89c5-3bf514fff55b -->
  <rule id="810231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1737 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>