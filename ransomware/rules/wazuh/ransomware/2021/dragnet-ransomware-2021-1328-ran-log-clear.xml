<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1328 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: a0dfc63e-badf-5681-b29d-c1ed7ad8fda6 -->
  <rule id="631806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1328 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>