<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1265 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: 5cf63c3c-baff-5c02-945a-ac11c70894c9 -->
  <rule id="680220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1265 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>