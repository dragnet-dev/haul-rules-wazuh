<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0322 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 089739ad-2ad4-5aac-af3d-aa42071d978b -->
  <rule id="635834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0322 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>