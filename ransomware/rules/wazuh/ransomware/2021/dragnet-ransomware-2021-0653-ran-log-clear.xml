<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0653 — Event Log Clearing (atomsilo) | Status: experimental | Sigma ID: 03cde2ce-cd3e-5225-9fee-9981b663e5ac -->
  <rule id="793164" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0653 — Event Log Clearing (atomsilo)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>