<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0862 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 3c2ac31b-8854-507f-9c67-9725bf8c7031 -->
  <rule id="742843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0862 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
