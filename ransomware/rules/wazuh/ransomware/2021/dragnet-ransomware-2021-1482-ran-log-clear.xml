<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1482 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: b9af1a0c-47b7-59cd-ba2c-559b58d2c9ca -->
  <rule id="502266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1482 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>