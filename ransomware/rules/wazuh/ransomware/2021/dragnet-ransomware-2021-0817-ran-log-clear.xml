<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0817 — Event Log Clearing (pysa) | Status: deprecated | Sigma ID: 3622bf35-d58f-5b97-9c6d-02af079c99c3 -->
  <rule id="374233" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0817 — Event Log Clearing (pysa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>