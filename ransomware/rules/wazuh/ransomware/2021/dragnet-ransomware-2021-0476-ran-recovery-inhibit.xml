<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0476 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 5927874f-a3ca-5289-a970-e20f29220de8 -->
  <rule id="627874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0476 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>