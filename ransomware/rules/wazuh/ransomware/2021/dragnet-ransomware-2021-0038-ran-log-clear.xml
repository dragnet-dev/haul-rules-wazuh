<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0038 — Event Log Clearing (blackmatter) | Status: deprecated | Sigma ID: f9f209bf-fc5f-5e1f-9267-f509165aa260 -->
  <rule id="859209" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0038 — Event Log Clearing (blackmatter)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>