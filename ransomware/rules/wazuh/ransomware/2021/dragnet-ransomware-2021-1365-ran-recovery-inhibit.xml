<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1365 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 378c5e30-0981-5c60-8474-7888d151a8eb -->
  <rule id="796943" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1365 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>