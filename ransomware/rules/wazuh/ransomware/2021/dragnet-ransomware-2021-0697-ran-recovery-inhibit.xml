<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0697 — Recovery Inhibition (mountlocker) | Status: deprecated | Sigma ID: 3944230d-36c2-5508-bb9a-39670cf25b5a -->
  <rule id="444230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0697 — Recovery Inhibition (mountlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>