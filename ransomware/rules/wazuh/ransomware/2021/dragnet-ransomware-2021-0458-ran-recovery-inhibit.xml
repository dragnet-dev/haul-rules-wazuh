<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0458 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: dd8bd62a-8320-5ec0-9970-920825372892 -->
  <rule id="379976" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0458 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
