<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1713 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 71dcf86e-ff64-501b-92cb-9bd79c364fc6 -->
  <rule id="343518" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1713 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
