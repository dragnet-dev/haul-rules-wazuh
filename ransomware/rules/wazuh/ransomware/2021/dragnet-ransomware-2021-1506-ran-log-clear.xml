<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1506 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: 9f1d84fe-2200-59ab-8ed0-4efb33ce2fa1 -->
  <rule id="846984" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1506 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>