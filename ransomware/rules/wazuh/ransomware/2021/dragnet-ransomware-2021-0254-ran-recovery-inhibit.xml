<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0254 — Recovery Inhibition (groove) | Status: deprecated | Sigma ID: bda40a67-f911-52d7-828a-e22366470f77 -->
  <rule id="455050" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0254 — Recovery Inhibition (groove)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
