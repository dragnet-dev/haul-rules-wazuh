<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0642 — Event Log Clearing (ransomexx) | Status: deprecated | Sigma ID: 1deb5d56-9527-5f41-9e09-e93ec58c84a2 -->
  <rule id="425533" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0642 — Event Log Clearing (ransomexx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>