<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0629 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 42695d6e-51b2-5fc8-ba9b-b1c298b2d067 -->
  <rule id="631336" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0629 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>