<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1707 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 04b3287b-aaab-526e-8527-00e8e4c115ef -->
  <rule id="452603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1707 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>