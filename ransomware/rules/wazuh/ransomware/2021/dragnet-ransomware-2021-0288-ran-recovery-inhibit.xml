<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0288 — Recovery Inhibition (spook) | Status: deprecated | Sigma ID: 39969e2e-2e0c-5718-ab9b-edab2f929582 -->
  <rule id="195182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0288 — Recovery Inhibition (spook)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>