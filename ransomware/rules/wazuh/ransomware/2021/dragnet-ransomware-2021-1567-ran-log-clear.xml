<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1567 — Event Log Clearing (pysa) | Status: deprecated | Sigma ID: 1d5aa1b1-279f-51e2-a65c-4629a85f4e02 -->
  <rule id="510427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1567 — Event Log Clearing (pysa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>