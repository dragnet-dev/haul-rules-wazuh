<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0725 — Event Log Clearing (midas) | Status: deprecated | Sigma ID: 1ff8e6f1-8b0d-5b03-9000-906dd108cb7a -->
  <rule id="604431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0725 — Event Log Clearing (midas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>