<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0972 — Recovery Inhibition (babuk) | Status: experimental | Sigma ID: 6fb5c329-e02f-5cb4-8b3f-6513187d1dd9 -->
  <rule id="260123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0972 — Recovery Inhibition (babuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>