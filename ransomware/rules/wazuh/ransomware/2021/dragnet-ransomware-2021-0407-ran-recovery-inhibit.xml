<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0407 — Recovery Inhibition (avoslocker) | Status: deprecated | Sigma ID: 9e11adea-a274-5501-894c-2ddb7f9b650f -->
  <rule id="547789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0407 — Recovery Inhibition (avoslocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>