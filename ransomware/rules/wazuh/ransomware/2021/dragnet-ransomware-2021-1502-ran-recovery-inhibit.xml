<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1502 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: d4a83758-78b4-51ec-9140-90606a126f85 -->
  <rule id="454837" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1502 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>