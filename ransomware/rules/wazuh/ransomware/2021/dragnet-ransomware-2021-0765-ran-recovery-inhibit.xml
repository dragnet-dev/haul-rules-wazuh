<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0765 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 150c9cba-e2f8-5477-8920-a18552766e28 -->
  <rule id="877227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0765 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>