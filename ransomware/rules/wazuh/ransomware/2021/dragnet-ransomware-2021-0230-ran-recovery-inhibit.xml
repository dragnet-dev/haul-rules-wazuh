<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0230 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 76aed74f-cf03-58a8-9367-946267dccd73 -->
  <rule id="540937" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0230 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>