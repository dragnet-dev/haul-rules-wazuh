<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1366 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 57194466-50d8-55e7-a55c-6cae371b5fdc -->
  <rule id="419446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1366 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>