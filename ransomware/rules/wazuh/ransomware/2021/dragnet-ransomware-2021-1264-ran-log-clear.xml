<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1264 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 1292b364-21f0-54a6-9c1c-8a5c3db39c29 -->
  <rule id="368336" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1264 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>