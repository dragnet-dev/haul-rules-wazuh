<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0483 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: 02fd6317-a131-50fb-be6d-746e9d0f6803 -->
  <rule id="556317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0483 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>