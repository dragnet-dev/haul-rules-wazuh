<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0806 — Event Log Clearing (pysa) | Status: deprecated | Sigma ID: 9f75e02c-ffdd-50fd-9294-a0336cd2ac2d -->
  <rule id="856140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0806 — Event Log Clearing (pysa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>