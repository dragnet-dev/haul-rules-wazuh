<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0718 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 8935129f-a38e-50e1-9a32-aaae6fc4e27b -->
  <rule id="935129" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0718 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>