<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0155 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: a3c9f2e6-718e-5a6a-bffb-9d9354909084 -->
  <rule id="957592" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0155 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>