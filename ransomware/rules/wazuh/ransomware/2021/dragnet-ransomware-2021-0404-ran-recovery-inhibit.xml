<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0404 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: b89157ec-ddd8-5e2b-8d96-97630d1307e7 -->
  <rule id="389157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0404 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>