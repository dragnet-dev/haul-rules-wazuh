<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0571 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: 7bcb32e0-4b6e-54ba-ba76-e4d3c64ca523 -->
  <rule id="569132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0571 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>