<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1184 — Event Log Clearing (mosesstaff) | Status: deprecated | Sigma ID: 188d8518-7a4e-5984-abdd-cc872ae9911c -->
  <rule id="421851" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1184 — Event Log Clearing (mosesstaff)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>