<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1060 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: f4b4f2f7-6ad2-5a24-94ba-0501d9d2f4b7 -->
  <rule id="460792" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1060 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>