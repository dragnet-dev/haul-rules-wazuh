<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1697 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: ff916163-3fdb-576e-a1cb-87810d849619 -->
  <rule id="859161" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1697 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
