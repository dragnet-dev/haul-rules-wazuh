<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1144 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 79312da5-6741-566a-995b-369ef368f897 -->
  <rule id="469005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1144 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>