<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1383 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: 20cbf6c7-72f3-5c92-9b86-c27c1dd845b1 -->
  <rule id="229388" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1383 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>