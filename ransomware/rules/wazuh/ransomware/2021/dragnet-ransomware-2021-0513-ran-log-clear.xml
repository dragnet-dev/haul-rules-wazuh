<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0513 — Event Log Clearing (groove) | Status: deprecated | Sigma ID: 691e47c7-e42e-5cd5-b9a0-834d4a0c06a1 -->
  <rule id="307047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0513 — Event Log Clearing (groove)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>