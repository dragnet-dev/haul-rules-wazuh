<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0127 — Event Log Clearing (pysa) | Status: deprecated | Sigma ID: 2b8a6b61-b98b-5219-9a2d-b34a9c9eae28 -->
  <rule id="322987" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0127 — Event Log Clearing (pysa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>