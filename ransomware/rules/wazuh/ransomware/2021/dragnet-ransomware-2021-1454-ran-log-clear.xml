<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1454 — Event Log Clearing (ransomexx) | Status: deprecated | Sigma ID: 5e760f57-6ce8-538f-8547-c9480c556a61 -->
  <rule id="716175" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1454 — Event Log Clearing (ransomexx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>