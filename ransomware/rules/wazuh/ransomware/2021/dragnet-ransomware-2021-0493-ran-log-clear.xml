<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0493 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 7a0c88d9-2ca0-5ad0-8803-3c9b14e7a666 -->
  <rule id="253288" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0493 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>