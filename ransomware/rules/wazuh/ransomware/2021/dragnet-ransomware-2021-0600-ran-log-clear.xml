<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0600 — Event Log Clearing (blackshadow) | Status: deprecated | Sigma ID: 98a050f1-66a6-5550-a630-7b2e8bfc60d7 -->
  <rule id="778050" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0600 — Event Log Clearing (blackshadow)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>