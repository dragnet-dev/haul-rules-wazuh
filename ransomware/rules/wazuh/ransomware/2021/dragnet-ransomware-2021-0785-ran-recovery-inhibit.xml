<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0785 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: ee1d95a6-a376-5321-9be2-60e50878318b -->
  <rule id="310995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0785 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>