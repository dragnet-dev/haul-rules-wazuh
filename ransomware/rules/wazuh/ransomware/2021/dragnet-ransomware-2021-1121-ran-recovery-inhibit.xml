<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1121 — Recovery Inhibition (astroteam) | Status: deprecated | Sigma ID: be26613d-20b5-5173-8971-700f31086b7f -->
  <rule id="202661" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1121 — Recovery Inhibition (astroteam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>