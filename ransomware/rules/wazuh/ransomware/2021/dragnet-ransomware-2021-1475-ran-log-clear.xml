<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1475 — Event Log Clearing (pysa) | Status: deprecated | Sigma ID: a1b879f8-6fdf-5c6e-b7ce-e3d0a0286f5d -->
  <rule id="827879" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1475 — Event Log Clearing (pysa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>