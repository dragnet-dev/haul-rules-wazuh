<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1737 — Event Log Clearing (hive) | Status: deprecated | Sigma ID: 7545cf00-1cb5-58f4-81a3-7a49d9b2bec3 -->
  <rule id="231727" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1737 — Event Log Clearing (hive)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>