<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0012 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: efd10463-e49e-55a7-96d7-93deb0a961fa -->
  <rule id="337104" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0012 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>