<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0582 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 91643c32-0a6b-5063-b62f-17a080631d35 -->
  <rule id="666300" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0582 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>