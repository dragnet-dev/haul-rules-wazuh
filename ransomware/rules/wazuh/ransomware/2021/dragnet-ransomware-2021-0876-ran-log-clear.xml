<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0876 — Event Log Clearing (rook) | Status: deprecated | Sigma ID: 3264e6c6-a0b3-5c88-998a-b0b62830d97c -->
  <rule id="358188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0876 — Event Log Clearing (rook)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>