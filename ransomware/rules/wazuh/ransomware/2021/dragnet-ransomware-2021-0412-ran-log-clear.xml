<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0412 — Event Log Clearing (lockdata) | Status: deprecated | Sigma ID: 88051397-141a-5ae0-9734-1a99dba3de7c -->
  <rule id="805139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0412 — Event Log Clearing (lockdata)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>