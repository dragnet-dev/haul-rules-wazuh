<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1738 — Event Log Clearing (pay2key) | Status: deprecated | Sigma ID: b43c9cd5-0431-5736-bba9-08c1a53ab405 -->
  <rule id="328156" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1738 — Event Log Clearing (pay2key)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>