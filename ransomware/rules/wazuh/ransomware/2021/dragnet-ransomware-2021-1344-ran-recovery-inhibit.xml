<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1344 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 5de1b1fa-fdc1-5688-99ca-85af70d16237 -->
  <rule id="703471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1344 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>