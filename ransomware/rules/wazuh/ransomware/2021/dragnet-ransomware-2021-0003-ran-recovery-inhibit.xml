<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0003 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 12706739-6b7c-5dfe-a013-7431d0e92eab -->
  <rule id="470673" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0003 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
