<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0865 — Recovery Inhibition (azroteam) | Status: deprecated | Sigma ID: d7a66ab0-c808-5712-8ed8-dd88b45a115d -->
  <rule id="924266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0865 — Recovery Inhibition (azroteam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
