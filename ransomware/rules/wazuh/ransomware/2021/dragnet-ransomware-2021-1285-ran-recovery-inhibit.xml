<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1285 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 160466f3-53be-5d24-9ebf-424af312b6b3 -->
  <rule id="867471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1285 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>