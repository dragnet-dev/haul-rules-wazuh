<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0064 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 15be64fd-6088-58b0-b28e-a54ca6d5f022 -->
  <rule id="249039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0064 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>