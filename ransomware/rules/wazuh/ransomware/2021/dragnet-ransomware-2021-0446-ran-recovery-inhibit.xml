<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0446 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 5a1569c2-8b45-5383-9d2c-ec96225492cb -->
  <rule id="125116" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0446 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>