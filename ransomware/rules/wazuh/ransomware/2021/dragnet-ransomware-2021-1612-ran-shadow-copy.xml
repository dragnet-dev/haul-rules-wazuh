<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1612 — Shadow Copy Deletion (doppelpaymer) | Status: deprecated | Sigma ID: 4f2c4c64-fad8-5327-82be-72c773e746f7 -->
  <rule id="329516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1612 — Shadow Copy Deletion (doppelpaymer)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>