<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1339 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: 9220e1f1-aee1-5db8-a4a7-8000ce92e682 -->
  <rule id="675341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1339 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>