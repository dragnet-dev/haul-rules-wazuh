<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0789 — Event Log Clearing (ragnarok) | Status: deprecated | Sigma ID: 3119a797-86fd-5f34-be95-fe724063b37f -->
  <rule id="591479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0789 — Event Log Clearing (ragnarok)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>