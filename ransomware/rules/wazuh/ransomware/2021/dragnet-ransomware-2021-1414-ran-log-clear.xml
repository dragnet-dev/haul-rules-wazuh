<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1414 — Event Log Clearing (babuk) | Status: deprecated | Sigma ID: 6b06d5b0-0515-56ee-86fd-fdf51296a632 -->
  <rule id="913095" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1414 — Event Log Clearing (babuk)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>