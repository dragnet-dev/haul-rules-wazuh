<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0308 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 1ba0e28a-24c1-5a21-80f5-fe80d71d8246 -->
  <rule id="873428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0308 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>