<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0050 — Recovery Inhibition (midas) | Status: deprecated | Sigma ID: 3be0840b-53eb-544a-b1bc-a6840a825ce9 -->
  <rule id="680840" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0050 — Recovery Inhibition (midas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>