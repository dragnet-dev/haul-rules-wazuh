<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1788 — Event Log Clearing (egregor) | Status: deprecated | Sigma ID: 5b7a0ed4-4329-5f69-99ce-47fdbe834ac3 -->
  <rule id="649134" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1788 — Event Log Clearing (egregor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>