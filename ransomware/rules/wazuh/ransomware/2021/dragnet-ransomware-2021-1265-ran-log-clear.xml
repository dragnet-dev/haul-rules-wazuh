<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1265 — Event Log Clearing (medusalocker) | Status: experimental | Sigma ID: e79afcfc-28a3-56e4-a3e3-5a40e32b7f92 -->
  <rule id="760796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1265 — Event Log Clearing (medusalocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>