<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0631 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: ec2650c3-c2ec-5964-a921-5b98f68415fb -->
  <rule id="662650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0631 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>