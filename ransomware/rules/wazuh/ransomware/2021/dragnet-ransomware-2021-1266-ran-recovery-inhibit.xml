<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1266 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: a9d415cd-63ad-5aa1-8b84-c6b198362239 -->
  <rule id="957415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1266 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>