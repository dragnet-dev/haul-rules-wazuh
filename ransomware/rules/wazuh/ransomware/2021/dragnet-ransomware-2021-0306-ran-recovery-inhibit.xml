<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0306 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 6216fc3d-1ee5-5164-8e74-94f57e80f324 -->
  <rule id="791548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0306 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>