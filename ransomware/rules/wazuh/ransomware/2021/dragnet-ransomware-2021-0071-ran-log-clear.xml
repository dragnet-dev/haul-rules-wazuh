<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0071 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: 387550fa-0b0b-5ef9-b646-6fd3f2d9c11f -->
  <rule id="900815" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0071 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>