<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1453 — Event Log Clearing (darkside) | Status: deprecated | Sigma ID: 522988d7-d7d2-5a8f-9ba8-3b2747047156 -->
  <rule id="367821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1453 — Event Log Clearing (darkside)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>