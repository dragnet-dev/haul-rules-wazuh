<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0783 — Recovery Inhibition (spook) | Status: deprecated | Sigma ID: edaf6234-82e5-5d74-9df2-348a0cf4df58 -->
  <rule id="784762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0783 — Recovery Inhibition (spook)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>