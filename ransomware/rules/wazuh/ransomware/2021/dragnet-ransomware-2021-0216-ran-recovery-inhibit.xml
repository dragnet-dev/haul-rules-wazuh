<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0216 — Recovery Inhibition (xinglocker) | Status: deprecated | Sigma ID: 64837560-e8da-5093-b366-87ee2a71e5fd -->
  <rule id="283756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0216 — Recovery Inhibition (xinglocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>