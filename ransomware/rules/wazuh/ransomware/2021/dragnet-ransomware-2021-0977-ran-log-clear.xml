<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0977 — Event Log Clearing (darkleakmarket) | Status: deprecated | Sigma ID: b8a64a98-1cb4-5d9a-aeb4-a1baf9754540 -->
  <rule id="437834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0977 — Event Log Clearing (darkleakmarket)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>