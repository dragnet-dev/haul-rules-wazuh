<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0599 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: a2a6dd6d-aab0-51dd-a9da-9ee8dbf6e6fa -->
  <rule id="705277" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0599 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>