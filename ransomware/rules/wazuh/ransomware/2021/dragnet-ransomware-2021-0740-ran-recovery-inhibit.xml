<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0740 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 45d8f735-5aff-533c-bee9-c7647c53dc55 -->
  <rule id="374237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0740 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>