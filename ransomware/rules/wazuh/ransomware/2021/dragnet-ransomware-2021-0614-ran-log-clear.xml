<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0614 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 0fc108f2-9d71-5d67-a6f3-74e9d544929b -->
  <rule id="533743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0614 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>