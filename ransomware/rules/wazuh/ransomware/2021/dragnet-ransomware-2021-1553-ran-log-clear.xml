<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1553 — Event Log Clearing (everest) | Status: deprecated | Sigma ID: 2dc78dd9-6c3c-5a5a-abd3-23799e554d1b -->
  <rule id="372461" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1553 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>