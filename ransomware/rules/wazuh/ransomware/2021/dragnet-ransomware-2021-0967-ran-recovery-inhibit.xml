<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0967 — Recovery Inhibition (mountlocker) | Status: deprecated | Sigma ID: 964e900e-b7dd-5334-a269-54b6d2f41672 -->
  <rule id="743890" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0967 — Recovery Inhibition (mountlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
