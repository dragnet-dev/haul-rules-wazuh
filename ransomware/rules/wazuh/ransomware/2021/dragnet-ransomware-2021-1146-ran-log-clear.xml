<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1146 — Event Log Clearing (mountlocker) | Status: deprecated | Sigma ID: 19d839c4-5409-56fc-aac4-d602e1883df3 -->
  <rule id="685436" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1146 — Event Log Clearing (mountlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>