<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0932 — Event Log Clearing (karma) | Status: deprecated | Sigma ID: fc133406-2424-5a19-997e-c98990cdf60e -->
  <rule id="821334" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0932 — Event Log Clearing (karma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>