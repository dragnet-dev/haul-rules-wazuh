<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0262 — Event Log Clearing (darkleakmarket) | Status: deprecated | Sigma ID: aae298bb-8904-5c7a-a8cf-1c6313962ede -->
  <rule id="134298" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0262 — Event Log Clearing (darkleakmarket)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>