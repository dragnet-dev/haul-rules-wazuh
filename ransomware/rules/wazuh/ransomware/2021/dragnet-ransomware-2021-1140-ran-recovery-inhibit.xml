  <rule id="841727" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1140 — Recovery Inhibition (mountlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
