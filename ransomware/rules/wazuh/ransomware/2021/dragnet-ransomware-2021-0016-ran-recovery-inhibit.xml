<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0016 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 1574e63e-50bb-5b48-b657-c1e7dcf76827 -->
  <rule id="819863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0016 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>