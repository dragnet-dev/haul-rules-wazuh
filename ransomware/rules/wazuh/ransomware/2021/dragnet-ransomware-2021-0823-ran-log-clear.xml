<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0823 — Event Log Clearing (quantum) | Status: deprecated | Sigma ID: 454749c3-89cb-539d-a77d-086eec4af873 -->
  <rule id="175996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0823 — Event Log Clearing (quantum)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>