<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0504 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 5b452e80-c0da-5c8c-9806-79e3d1b270b9 -->
  <rule id="663246" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0504 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>