<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0957 — Event Log Clearing (spook) | Status: deprecated | Sigma ID: 65f93451-d1e6-5ef5-8b9c-a5b6f5679778 -->
  <rule id="255934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0957 — Event Log Clearing (spook)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>