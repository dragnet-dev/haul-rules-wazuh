<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1543 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: d3b53299-eeb2-546c-bace-1ab28b26536d -->
  <rule id="439532" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1543 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>