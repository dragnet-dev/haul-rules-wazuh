<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0046 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: 90b312d0-b480-5b53-9cc2-89e5bb82a6a4 -->
  <rule id="651312" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0046 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>