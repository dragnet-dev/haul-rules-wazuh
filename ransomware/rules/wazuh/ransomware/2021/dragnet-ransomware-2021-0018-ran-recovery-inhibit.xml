<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0018 — Recovery Inhibition (darkside) | Status: deprecated | Sigma ID: e6d22dd5-4e91-503d-9b22-8476a28cbfbd -->
  <rule id="258765" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0018 — Recovery Inhibition (darkside)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>