<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0805 — Event Log Clearing (marketo) | Status: deprecated | Sigma ID: 421e6dea-3bc6-50fc-b86f-a42a9da5ac9b -->
  <rule id="280109" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0805 — Event Log Clearing (marketo)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>