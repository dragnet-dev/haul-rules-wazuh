<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1478 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: b4bd1d7b-bc35-5c02-9120-de56a8fa9e24 -->
  <rule id="299709" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1478 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>