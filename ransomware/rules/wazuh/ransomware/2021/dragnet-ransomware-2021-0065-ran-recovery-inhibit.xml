<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0065 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 70f1a305-971e-571d-8694-2d39248741e4 -->
  <rule id="116263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0065 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>