<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0880 — Event Log Clearing (darkleakmarket) | Status: deprecated | Sigma ID: 8d076b0d-2d4e-579e-9d36-98a31d5f7702 -->
  <rule id="557227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0880 — Event Log Clearing (darkleakmarket)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>