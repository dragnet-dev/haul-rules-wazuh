<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0770 — Event Log Clearing (maui) | Status: deprecated | Sigma ID: af9426f2-8c15-52b9-983c-f85dee8c6ccf -->
  <rule id="959426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0770 — Event Log Clearing (maui)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>