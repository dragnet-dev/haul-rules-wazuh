<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0042 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 5bc97ccc-a2c6-5301-a514-684b4f4a8a44 -->
  <rule id="650364" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0042 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>