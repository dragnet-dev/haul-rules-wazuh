<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0400 — Shadow Copy Deletion (mosesstaff) | Status: deprecated | Sigma ID: 0579a5eb-c03b-5f39-adf8-ee62bafcf8d2 -->
  <rule id="683934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0400 — Shadow Copy Deletion (mosesstaff)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>