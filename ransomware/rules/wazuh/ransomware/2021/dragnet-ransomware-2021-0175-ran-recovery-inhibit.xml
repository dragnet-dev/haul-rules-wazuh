<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0175 — Recovery Inhibition (deathkitty) | Status: deprecated | Sigma ID: 829859a7-e004-54d3-a7f3-156a5ccdbb82 -->
  <rule id="777754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0175 — Recovery Inhibition (deathkitty)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>