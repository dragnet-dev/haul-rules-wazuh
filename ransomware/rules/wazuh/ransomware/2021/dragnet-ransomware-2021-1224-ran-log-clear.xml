<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1224 — Event Log Clearing (cring) | Status: deprecated | Sigma ID: 14c3cd13-dc3b-549c-9f8b-f8db88f72e6b -->
  <rule id="751331" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1224 — Event Log Clearing (cring)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>