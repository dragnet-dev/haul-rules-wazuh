<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0055 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 43881597-6eee-598f-8780-bdde7276bd69 -->
  <rule id="888159" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0055 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>