<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0507 — Recovery Inhibition (azroteam) | Status: deprecated | Sigma ID: aa939b97-0155-543a-8e72-691ce37db78f -->
  <rule id="135035" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0507 — Recovery Inhibition (azroteam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>