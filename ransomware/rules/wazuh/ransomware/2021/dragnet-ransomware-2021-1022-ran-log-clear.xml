<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1022 — Event Log Clearing (mosesstaff) | Status: deprecated | Sigma ID: fd883cf3-ac3a-5651-96b0-8a39980f1820 -->
  <rule id="562140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1022 — Event Log Clearing (mosesstaff)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>