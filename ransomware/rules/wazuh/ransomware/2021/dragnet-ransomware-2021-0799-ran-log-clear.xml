<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0799 — Event Log Clearing (marketo) | Status: deprecated | Sigma ID: ee122ad6-9fb4-56f7-a31e-f4e77d7699a2 -->
  <rule id="309962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0799 — Event Log Clearing (marketo)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>