<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0573 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 67a52563-143c-544f-844d-4b77777a99f6 -->
  <rule id="282525" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0573 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
