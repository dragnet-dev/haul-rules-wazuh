<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1761 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: c99fcdbc-6af7-5366-9955-8edde1bf0407 -->
  <rule id="924749" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1761 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>