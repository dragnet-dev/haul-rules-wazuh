<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0866 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: e0818a31-d569-5a9a-ba60-7d91e11a8fb5 -->
  <rule id="553098" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0866 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>