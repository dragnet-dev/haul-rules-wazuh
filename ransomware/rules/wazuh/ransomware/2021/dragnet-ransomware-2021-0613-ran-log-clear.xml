<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0613 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 5b232ac7-f7f5-51b1-b2b6-4fa8d3be9434 -->
  <rule id="659722" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0613 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>