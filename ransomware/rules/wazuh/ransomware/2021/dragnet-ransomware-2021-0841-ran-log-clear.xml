<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0841 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: 459e3b37-34e3-58e5-8dc0-a0f85a5b4301 -->
  <rule id="377339" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0841 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>