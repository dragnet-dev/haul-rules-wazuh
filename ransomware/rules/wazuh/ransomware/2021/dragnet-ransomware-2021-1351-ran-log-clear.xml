<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1351 — Event Log Clearing (ransomexx) | Status: deprecated | Sigma ID: 91dbe02e-bb18-5717-94b9-7401491f9aa1 -->
  <rule id="262540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1351 — Event Log Clearing (ransomexx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>