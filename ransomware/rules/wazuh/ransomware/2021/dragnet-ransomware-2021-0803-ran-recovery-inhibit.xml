<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0803 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 3f47fc72-130e-5a46-adea-050253b741ad -->
  <rule id="825084" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0803 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>