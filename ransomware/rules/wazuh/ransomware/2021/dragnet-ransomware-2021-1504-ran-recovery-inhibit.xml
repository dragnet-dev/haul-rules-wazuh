<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1504 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 0428bdd4-4964-54dd-8afe-cd63494f5ee6 -->
  <rule id="956125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1504 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
