<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0926 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 467d2915-0093-50d7-95d4-429b6fdc04d8 -->
  <rule id="385291" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0926 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>