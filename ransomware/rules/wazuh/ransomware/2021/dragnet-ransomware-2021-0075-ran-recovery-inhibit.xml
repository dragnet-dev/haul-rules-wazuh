<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0075 — Recovery Inhibition (xinglocker) | Status: deprecated | Sigma ID: 2f0be3d5-fd7b-50ca-905f-e033fde84929 -->
  <rule id="405103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0075 — Recovery Inhibition (xinglocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>