<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0411 — Recovery Inhibition (payloadbin) | Status: deprecated | Sigma ID: e3167518-804f-5b75-82ec-3d9ed9bf3c42 -->
  <rule id="631675" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0411 — Recovery Inhibition (payloadbin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>