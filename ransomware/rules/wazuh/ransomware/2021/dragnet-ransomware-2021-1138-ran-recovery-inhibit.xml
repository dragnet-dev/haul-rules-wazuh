<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1138 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 90d59a11-fd72-5b34-8099-afd14128da85 -->
  <rule id="625754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1138 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
