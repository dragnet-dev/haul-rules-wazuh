<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0557 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 688f54c1-f216-5ab2-b13f-f6933ca2639c -->
  <rule id="302354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0557 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
