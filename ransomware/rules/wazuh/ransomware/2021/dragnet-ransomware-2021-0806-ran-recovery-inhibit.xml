<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0806 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 3264562e-6b42-57fe-98e6-185916b258b7 -->
  <rule id="664562" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0806 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>