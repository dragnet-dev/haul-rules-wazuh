<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0421 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 89b888d7-76df-5370-a882-fe94a9dcceac -->
  <rule id="635888" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0421 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>