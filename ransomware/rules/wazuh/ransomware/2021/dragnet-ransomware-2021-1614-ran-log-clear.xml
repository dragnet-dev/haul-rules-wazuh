<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1614 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: f722d7f2-f295-55c4-a364-7774add2985b -->
  <rule id="815657" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1614 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>