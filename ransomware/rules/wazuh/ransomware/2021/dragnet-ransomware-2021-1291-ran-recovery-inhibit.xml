<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1291 — Recovery Inhibition (mountlocker) | Status: deprecated | Sigma ID: ed6df684-fd75-5417-ab63-54fc3593edbd -->
  <rule id="784796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1291 — Recovery Inhibition (mountlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>