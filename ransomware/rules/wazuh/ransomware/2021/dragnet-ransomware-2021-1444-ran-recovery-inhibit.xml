<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1444 — Recovery Inhibition (mountlocker) | Status: deprecated | Sigma ID: 127a2f37-2def-51a3-8236-c31d572c627d -->
  <rule id="667673" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1444 — Recovery Inhibition (mountlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>