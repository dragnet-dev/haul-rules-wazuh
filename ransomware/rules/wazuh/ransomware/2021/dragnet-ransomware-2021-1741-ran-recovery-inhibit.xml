<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1741 — Recovery Inhibition (avaddon) | Status: deprecated | Sigma ID: 3333ccaf-54eb-5282-a0d2-43610f920c7f -->
  <rule id="255242" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1741 — Recovery Inhibition (avaddon)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
