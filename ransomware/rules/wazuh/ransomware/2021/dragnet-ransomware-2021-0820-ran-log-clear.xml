<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0820 — Event Log Clearing (alphv) | Status: deprecated | Sigma ID: 5a2bee01-3ecd-5686-be51-1d1aed68dfd7 -->
  <rule id="197646" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0820 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>