<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1566 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 191e17f2-ed00-5723-badc-4b399d570bab -->
  <rule id="512287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1566 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>