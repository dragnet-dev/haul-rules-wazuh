<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0008 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: d8af371d-f6ca-5526-830e-142a32d38ba6 -->
  <rule id="950337" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0008 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>