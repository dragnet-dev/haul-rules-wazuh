<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0047 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: cfcdc1ab-b3e8-56ce-8a3e-250c862b8456 -->
  <rule id="511641" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0047 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>