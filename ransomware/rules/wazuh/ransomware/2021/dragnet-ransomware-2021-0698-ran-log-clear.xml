<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0698 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 62bdcbf7-06c9-5744-a141-9b1208c465e4 -->
  <rule id="611819" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0698 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>