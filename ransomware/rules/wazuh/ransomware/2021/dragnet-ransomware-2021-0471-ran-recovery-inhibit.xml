<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0471 — Recovery Inhibition (ransomexx) | Status: deprecated | Sigma ID: c5161da9-c3f8-5900-972d-818277b433f8 -->
  <rule id="302589" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0471 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
