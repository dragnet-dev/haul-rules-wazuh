<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1556 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 1af3994e-05cc-5198-a3eb-85364ab2e795 -->
  <rule id="813994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1556 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>