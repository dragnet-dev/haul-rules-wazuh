<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1109 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: b930bce3-4d99-5ffd-bfee-eb503319fc5c -->
  <rule id="454268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1109 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>