<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0754 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 3d8c6f1c-31c1-5898-ae2d-be82ee3420fb -->
  <rule id="784111" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0754 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>