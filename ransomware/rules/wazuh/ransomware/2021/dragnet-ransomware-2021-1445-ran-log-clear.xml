<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1445 — Event Log Clearing (lockbit) | Status: deprecated | Sigma ID: 2a6cf3a8-682e-5c38-bd70-25ad32f4fe4b -->
  <rule id="292633" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1445 — Event Log Clearing (lockbit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>