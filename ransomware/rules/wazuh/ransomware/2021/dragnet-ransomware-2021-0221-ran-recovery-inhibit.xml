<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0221 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: 7622b8f1-5484-562a-a791-429a60ef5a18 -->
  <rule id="419638" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0221 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>