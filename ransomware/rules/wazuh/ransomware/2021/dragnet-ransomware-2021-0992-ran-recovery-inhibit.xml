<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0992 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: e054d014-2a9c-5484-9947-09a85846c630 -->
  <rule id="548770" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0992 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>