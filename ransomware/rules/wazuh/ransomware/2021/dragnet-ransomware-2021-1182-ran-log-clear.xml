<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1182 — Event Log Clearing (azroteam) | Status: deprecated | Sigma ID: 0f49e8ad-66fa-5b1b-94d4-65f03de5f00b -->
  <rule id="467818" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1182 — Event Log Clearing (azroteam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>