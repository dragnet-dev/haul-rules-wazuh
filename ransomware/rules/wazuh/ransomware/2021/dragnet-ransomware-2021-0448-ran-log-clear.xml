<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0448 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: e2b5a7c4-7858-5f2d-aea3-375e9d716cfe -->
  <rule id="153707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0448 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>