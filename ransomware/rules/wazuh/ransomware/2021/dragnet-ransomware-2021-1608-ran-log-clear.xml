<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1608 — Event Log Clearing (nefilim) | Status: deprecated | Sigma ID: bd9adb4d-d45b-5798-992c-54e394935ea9 -->
  <rule id="681083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1608 — Event Log Clearing (nefilim)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>