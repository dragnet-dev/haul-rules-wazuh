<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0507 — Event Log Clearing (azroteam) | Status: deprecated | Sigma ID: 19ed9b31-c7f8-51f4-ad23-ea612e92a811 -->
  <rule id="163153" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0507 — Event Log Clearing (azroteam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>