<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0444 — Event Log Clearing (darkleakmarket) | Status: deprecated | Sigma ID: d3f4be90-a98e-5d7e-988e-b9ba34c1a9a2 -->
  <rule id="187294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0444 — Event Log Clearing (darkleakmarket)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>