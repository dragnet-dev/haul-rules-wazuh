<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0108 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: ef6138cd-fdcc-5483-a4dc-1292b0fe1e82 -->
  <rule id="696138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0108 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>