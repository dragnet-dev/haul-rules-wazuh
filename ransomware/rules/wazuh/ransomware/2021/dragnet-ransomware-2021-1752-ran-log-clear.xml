<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1752 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: 968b906a-00ae-5f90-8b35-e9fb1ca10fd1 -->
  <rule id="749990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1752 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>