<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0961 — Recovery Inhibition (xinglocker) | Status: deprecated | Sigma ID: d079ddbe-fc63-584e-a026-3969e0eb7668 -->
  <rule id="748445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0961 — Recovery Inhibition (xinglocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>