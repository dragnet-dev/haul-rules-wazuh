<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0115 — Recovery Inhibition (avaddon) | Status: deprecated | Sigma ID: 0714d333-5f5b-53a4-9d85-11010b5e48d9 -->
  <rule id="343733" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0115 — Recovery Inhibition (avaddon)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>