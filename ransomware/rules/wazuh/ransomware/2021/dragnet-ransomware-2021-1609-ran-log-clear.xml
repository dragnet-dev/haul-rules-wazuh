<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1609 — Event Log Clearing (pysa) | Status: deprecated | Sigma ID: e470f8fd-d0bd-5527-9973-2fe4b18da559 -->
  <rule id="615358" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1609 — Event Log Clearing (pysa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>