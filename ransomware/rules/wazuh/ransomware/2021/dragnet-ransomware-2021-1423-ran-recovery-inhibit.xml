<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1423 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 16488598-c657-5b0b-99f9-d62c4195d407 -->
  <rule id="848859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1423 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>