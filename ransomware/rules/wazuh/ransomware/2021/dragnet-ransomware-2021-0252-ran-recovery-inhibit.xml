<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0252 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 60cc21a4-13ac-58ff-ac75-f7270abc767a -->
  <rule id="756421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0252 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>