  <rule id="875293" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1445 — Recovery Inhibition (lockbit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
