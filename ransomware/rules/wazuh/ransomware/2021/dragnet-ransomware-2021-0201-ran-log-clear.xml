<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0201 — Event Log Clearing (arvinclub) | Status: deprecated | Sigma ID: 75513656-bdf9-5d80-b3c8-1b6a7686b231 -->
  <rule id="451365" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0201 — Event Log Clearing (arvinclub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>