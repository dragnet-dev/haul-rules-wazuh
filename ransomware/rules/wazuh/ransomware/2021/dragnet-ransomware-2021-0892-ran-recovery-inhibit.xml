<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0892 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 11e88f44-8a8a-5f3a-9523-51fd121f60ac -->
  <rule id="454234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0892 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>