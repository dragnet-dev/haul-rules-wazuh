<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1652 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: 599cfc4b-3b4d-50e7-bef3-bbb8fda0f91b -->
  <rule id="756828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1652 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>