<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0032 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 838a0623-d3a6-541d-ae40-4f533c4f4eea -->
  <rule id="541806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0032 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>