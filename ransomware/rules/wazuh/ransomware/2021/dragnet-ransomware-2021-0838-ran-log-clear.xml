<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0838 — Event Log Clearing (marketo) | Status: deprecated | Sigma ID: a5e0f254-8dc5-51b2-82f8-e8da70be400b -->
  <rule id="110552" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0838 — Event Log Clearing (marketo)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>