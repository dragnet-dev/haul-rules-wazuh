<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1252 — Event Log Clearing (synack) | Status: deprecated | Sigma ID: 3c5c2c36-7c2b-564b-8c18-c89808517949 -->
  <rule id="750764" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1252 — Event Log Clearing (synack)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>