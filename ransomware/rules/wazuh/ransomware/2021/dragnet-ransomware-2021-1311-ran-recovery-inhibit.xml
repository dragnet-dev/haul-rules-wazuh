<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1311 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 592262c7-57ca-5404-90c3-fbb3c58d9f4a -->
  <rule id="576204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1311 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>