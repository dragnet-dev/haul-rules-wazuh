<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0793 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 88ac92eb-5fa7-54af-a999-a0b38cd15a50 -->
  <rule id="570092" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0793 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>