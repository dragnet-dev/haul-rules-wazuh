<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0354 — Recovery Inhibition (xinglocker) | Status: deprecated | Sigma ID: 1729ecc8-95cb-511c-a779-979da773a2b5 -->
  <rule id="885772" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0354 — Recovery Inhibition (xinglocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>