<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1194 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 5779b8ed-2705-5875-94de-2c8f272184ee -->
  <rule id="496142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1194 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>