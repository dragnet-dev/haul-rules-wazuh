<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0144 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 5d91c5ce-2c37-5e14-a2ae-829ec14b3ab7 -->
  <rule id="702685" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0144 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>