<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1065 — Event Log Clearing (spook) | Status: deprecated | Sigma ID: a293abb8-2997-5f7e-b8a4-ebd4a82c3a97 -->
  <rule id="935179" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1065 — Event Log Clearing (spook)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>