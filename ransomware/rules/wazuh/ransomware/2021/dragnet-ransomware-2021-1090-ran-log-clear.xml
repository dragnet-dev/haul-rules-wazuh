<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1090 — Event Log Clearing (xinglocker) | Status: deprecated | Sigma ID: 095d8f0a-b201-5eae-8461-c0cfb2a2b91c -->
  <rule id="754230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1090 — Event Log Clearing (xinglocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>