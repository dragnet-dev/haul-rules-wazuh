<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1104 — Recovery Inhibition (avaddon) | Status: deprecated | Sigma ID: 8111cbbe-e78e-5dd4-acc3-d581e7d8beca -->
  <rule id="376619" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1104 — Recovery Inhibition (avaddon)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>