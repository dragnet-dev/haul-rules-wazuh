<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0304 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 6fcfe84b-6edb-5b2b-86d4-40ddfc57326b -->
  <rule id="179828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0304 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>