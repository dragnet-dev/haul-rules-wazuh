  <rule id="212620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1672 — Recovery Inhibition (midas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>