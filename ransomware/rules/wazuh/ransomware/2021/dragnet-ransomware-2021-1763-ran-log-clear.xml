<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1763 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: d14cc8cc-4909-53cb-a3f2-178ad32748c0 -->
  <rule id="765888" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1763 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>