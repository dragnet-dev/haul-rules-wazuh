<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1437 — Event Log Clearing (revil) | Status: deprecated | Sigma ID: 24c9262a-09dd-51f5-bd9b-1fa348ac57a0 -->
  <rule id="469262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1437 — Event Log Clearing (revil)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>