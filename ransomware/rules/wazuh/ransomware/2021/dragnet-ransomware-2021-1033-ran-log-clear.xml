<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1033 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 9b9b2ee2-7688-5641-8ba7-ad128b5692f7 -->
  <rule id="492846" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1033 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>