<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1748 — Shadow Copy Deletion (darkleakmarket) | Status: deprecated | Sigma ID: f7c0ddd5-ccaa-560b-9388-2a51955dad36 -->
  <rule id="261661" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1748 — Shadow Copy Deletion (darkleakmarket)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>