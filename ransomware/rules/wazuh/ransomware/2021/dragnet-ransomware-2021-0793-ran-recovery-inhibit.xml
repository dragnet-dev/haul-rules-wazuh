<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0793 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: fafa1e25-d231-53e4-9637-4e91aa47ba2f -->
  <rule id="480030" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0793 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>