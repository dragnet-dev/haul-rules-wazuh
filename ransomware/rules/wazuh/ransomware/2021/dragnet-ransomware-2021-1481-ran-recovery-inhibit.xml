<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1481 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 6517daa0-e045-52e8-86ef-049bbd4de976 -->
  <rule id="868570" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1481 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
