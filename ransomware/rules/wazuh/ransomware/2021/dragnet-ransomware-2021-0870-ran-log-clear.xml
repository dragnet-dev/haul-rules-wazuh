<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0870 — Event Log Clearing (pay2key) | Status: deprecated | Sigma ID: b4da7dbb-53da-5cc7-ab49-776e1b542b90 -->
  <rule id="304445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0870 — Event Log Clearing (pay2key)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>