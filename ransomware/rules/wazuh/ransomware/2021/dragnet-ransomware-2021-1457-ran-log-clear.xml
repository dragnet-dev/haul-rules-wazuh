<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1457 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: c48588a9-b8d6-5749-870f-2e2c8c6fad5a -->
  <rule id="448588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1457 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>