<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1505 — Recovery Inhibition (mountlocker) | Status: deprecated | Sigma ID: f82ed370-bfcd-5dc9-b3b5-324eff66f6c6 -->
  <rule id="552293" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1505 — Recovery Inhibition (mountlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>