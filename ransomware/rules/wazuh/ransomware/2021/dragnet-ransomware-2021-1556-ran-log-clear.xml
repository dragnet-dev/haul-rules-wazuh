<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1556 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: f56af4cd-ee28-5dc9-8390-706eb7c083b3 -->
  <rule id="485114" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1556 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>