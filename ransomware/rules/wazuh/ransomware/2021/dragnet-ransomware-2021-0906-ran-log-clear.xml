<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0906 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 5cdd9036-f1f9-586d-9dcd-09c7fbc22193 -->
  <rule id="677390" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0906 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>