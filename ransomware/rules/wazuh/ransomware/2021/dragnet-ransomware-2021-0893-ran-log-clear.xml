<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0893 — Event Log Clearing (rook) | Status: deprecated | Sigma ID: 1b861cf7-4cab-5652-839d-9f4a81bcdf46 -->
  <rule id="932623" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0893 — Event Log Clearing (rook)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>