<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0175 — Event Log Clearing (deathkitty) | Status: deprecated | Sigma ID: bc5b0a6e-5b7c-5869-9115-23ee01b9af55 -->
  <rule id="427370" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0175 — Event Log Clearing (deathkitty)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>