<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0562 — Event Log Clearing (alphv) | Status: deprecated | Sigma ID: 6385a1b5-f57c-56aa-946a-19c1d9f6cd29 -->
  <rule id="221701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0562 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>