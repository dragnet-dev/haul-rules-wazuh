<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1653 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 22f1a9d9-ff46-561b-a616-e496c131f467 -->
  <rule id="499517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1653 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>