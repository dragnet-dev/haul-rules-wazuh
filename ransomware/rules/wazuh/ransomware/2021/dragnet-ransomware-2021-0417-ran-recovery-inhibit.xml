<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0417 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 6f3f881e-ba33-5088-9a84-bf65ec81375d -->
  <rule id="982388" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0417 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
