<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1196 — Event Log Clearing (pysa) | Status: deprecated | Sigma ID: 0a347c40-ed45-55d7-9aa9-b7db33e3eaf5 -->
  <rule id="855644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1196 — Event Log Clearing (pysa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>