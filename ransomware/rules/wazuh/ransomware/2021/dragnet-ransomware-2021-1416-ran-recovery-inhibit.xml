<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1416 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: d3b5d3cf-0c09-50d4-ae5d-2f68550c8036 -->
  <rule id="823333" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1416 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>