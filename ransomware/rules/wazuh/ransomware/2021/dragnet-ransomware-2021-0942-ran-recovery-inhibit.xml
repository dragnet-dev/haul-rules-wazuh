<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0942 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: cfc58867-655f-520d-8e7d-2bd891e606d2 -->
  <rule id="724588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0942 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>