<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0603 — Event Log Clearing (suncrypt) | Status: deprecated | Sigma ID: 903b2855-2689-5e4d-abfe-1c1ab8cd9b28 -->
  <rule id="645928" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0603 — Event Log Clearing (suncrypt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>