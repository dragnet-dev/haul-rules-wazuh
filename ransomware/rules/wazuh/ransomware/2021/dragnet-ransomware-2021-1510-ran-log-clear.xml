<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1510 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 5d0acaa6-c32c-579d-83fc-f74ced5fb2ca -->
  <rule id="312042" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1510 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>