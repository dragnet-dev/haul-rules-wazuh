<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0598 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 895308bf-a841-5a19-a65c-a6ccf7b75d07 -->
  <rule id="924939" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0598 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>