<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1351 — Recovery Inhibition (ransomexx) | Status: deprecated | Sigma ID: 212ffa9a-222d-591f-8f3d-014592e26ca6 -->
  <rule id="724429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1351 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>