<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0611 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 6e8cdb31-9031-5ff0-a695-f0284ceb7e38 -->
  <rule id="141659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0611 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>