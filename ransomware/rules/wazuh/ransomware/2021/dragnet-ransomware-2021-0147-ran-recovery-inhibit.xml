<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0147 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: f154a6eb-b23a-57e9-b954-ec774fd557b6 -->
  <rule id="724746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0147 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>