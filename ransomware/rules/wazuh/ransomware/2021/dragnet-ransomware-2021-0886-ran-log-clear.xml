<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0886 — Event Log Clearing (blackmatter) | Status: deprecated | Sigma ID: 59dc1658-3ca7-5f2b-a887-1dcb11048f5b -->
  <rule id="732416" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0886 — Event Log Clearing (blackmatter)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>