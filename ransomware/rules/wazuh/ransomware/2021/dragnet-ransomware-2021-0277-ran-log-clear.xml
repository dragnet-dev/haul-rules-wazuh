<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0277 — Event Log Clearing (phoenixcryptolocker) | Status: deprecated | Sigma ID: ad242591-28c7-5e77-914b-67778e0913cc -->
  <rule id="932425" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0277 — Event Log Clearing (phoenixcryptolocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>