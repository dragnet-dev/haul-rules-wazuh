<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0080 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: c21fff3f-03df-5ecf-962b-dd7e8a06187a -->
  <rule id="605311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0080 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>