<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1610 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 50646c7c-8c76-5e0a-8608-434585c2a480 -->
  <rule id="103487" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1610 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>