<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0308 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: d148230a-0aa4-557d-8279-9e191460f89a -->
  <rule id="514823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0308 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>