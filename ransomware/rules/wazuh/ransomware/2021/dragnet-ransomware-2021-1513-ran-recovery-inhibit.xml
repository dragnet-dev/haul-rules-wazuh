<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1513 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: e2d205db-60cf-5ba0-8b10-1df589d3e689 -->
  <rule id="585205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1513 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
