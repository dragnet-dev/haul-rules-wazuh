<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0410 — Recovery Inhibition (spook) | Status: deprecated | Sigma ID: 8947e648-6b2a-5964-978e-a2abf5712003 -->
  <rule id="631666" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0410 — Recovery Inhibition (spook)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>