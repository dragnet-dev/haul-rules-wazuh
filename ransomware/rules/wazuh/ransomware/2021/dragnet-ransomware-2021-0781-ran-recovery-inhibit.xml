<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0781 — Recovery Inhibition (avaddon) | Status: deprecated | Sigma ID: 2bd151a4-b252-58a5-90b3-b7acc752a449 -->
  <rule id="518426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0781 — Recovery Inhibition (avaddon)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>