<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1247 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: be237c7d-f5e4-5ab2-9a3f-507704323f27 -->
  <rule id="443804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1247 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>