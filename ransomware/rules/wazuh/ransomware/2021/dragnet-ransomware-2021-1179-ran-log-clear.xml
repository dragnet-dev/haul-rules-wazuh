<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1179 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: 0bdc9f3f-03c5-5fa2-aeae-1de1ca7d7232 -->
  <rule id="459193" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1179 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>