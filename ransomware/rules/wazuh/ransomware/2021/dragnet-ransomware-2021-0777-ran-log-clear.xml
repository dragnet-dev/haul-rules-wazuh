<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0777 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: d25aeb3a-da62-56d4-812f-f9d4dd1a47d2 -->
  <rule id="129995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0777 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>