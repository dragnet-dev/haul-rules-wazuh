<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1575 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 3589d79d-6d60-52b8-95e7-b54e74e5aaed -->
  <rule id="443779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1575 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>