  <rule id="987086" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1778 — Event Log Clearing (marketo)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
