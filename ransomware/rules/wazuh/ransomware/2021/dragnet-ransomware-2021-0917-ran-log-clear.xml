<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0917 — Event Log Clearing (groove) | Status: deprecated | Sigma ID: 8d0cfedc-d68f-510b-adf6-ffa5d6f0bbe1 -->
  <rule id="478686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0917 — Event Log Clearing (groove)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>