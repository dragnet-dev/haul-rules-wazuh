<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0713 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 4d8423b3-eb85-5e2f-8745-b6a36ca1fb44 -->
  <rule id="854779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0713 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>