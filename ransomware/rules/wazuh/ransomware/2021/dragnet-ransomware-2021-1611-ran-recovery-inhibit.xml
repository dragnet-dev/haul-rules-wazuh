<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1611 — Recovery Inhibition (blacktor) | Status: deprecated | Sigma ID: 035d0774-8f8e-57eb-8417-fdab0754d660 -->
  <rule id="430774" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1611 — Recovery Inhibition (blacktor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
