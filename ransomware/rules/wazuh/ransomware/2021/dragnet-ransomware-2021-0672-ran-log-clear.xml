<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0672 — Event Log Clearing (darkleakmarket) | Status: deprecated | Sigma ID: c7cd8762-c4b9-5280-8534-19db9c744a7e -->
  <rule id="671787" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0672 — Event Log Clearing (darkleakmarket)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>