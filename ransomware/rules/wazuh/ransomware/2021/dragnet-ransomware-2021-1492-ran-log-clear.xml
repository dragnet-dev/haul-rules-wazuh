<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1492 — Event Log Clearing (snatch) | Status: deprecated | Sigma ID: 39bf1e0c-efe7-598d-9be9-1df109a72e4f -->
  <rule id="828030" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1492 — Event Log Clearing (snatch)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>