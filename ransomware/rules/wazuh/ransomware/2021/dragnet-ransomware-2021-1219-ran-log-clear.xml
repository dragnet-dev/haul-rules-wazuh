<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1219 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: 1d30ae58-4c1d-58f8-94a8-6cb06fca12f2 -->
  <rule id="402545" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1219 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>