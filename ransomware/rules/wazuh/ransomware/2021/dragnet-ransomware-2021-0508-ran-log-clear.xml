<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0508 — Event Log Clearing (pysa) | Status: deprecated | Sigma ID: a9e3ec7c-62ec-53bb-8f7c-0efc79ba05ca -->
  <rule id="101484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0508 — Event Log Clearing (pysa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>