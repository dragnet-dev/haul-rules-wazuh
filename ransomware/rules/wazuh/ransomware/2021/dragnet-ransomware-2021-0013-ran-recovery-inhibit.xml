<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0013 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: dcd02e5d-d01b-5674-bb0c-ce7e9732723b -->
  <rule id="352846" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0013 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>