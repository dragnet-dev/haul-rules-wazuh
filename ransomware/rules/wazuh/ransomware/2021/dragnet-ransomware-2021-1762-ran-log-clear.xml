<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1762 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: b0eaa404-8c2b-5be8-96b0-8e7e0688cd01 -->
  <rule id="143144" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1762 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>