<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0069 — Event Log Clearing (suncrypt) | Status: deprecated | Sigma ID: 7dd46b8c-8900-5628-be7d-ea94984d1bfd -->
  <rule id="621547" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0069 — Event Log Clearing (suncrypt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>