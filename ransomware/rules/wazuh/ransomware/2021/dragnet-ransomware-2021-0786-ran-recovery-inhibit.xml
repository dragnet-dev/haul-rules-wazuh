<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0786 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 16ea2aa2-1acd-5ef8-a526-145033fb13be -->
  <rule id="385482" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0786 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>