<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0379 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: a3524693-8abd-5d12-aa7a-222a73286454 -->
  <rule id="235246" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0379 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>