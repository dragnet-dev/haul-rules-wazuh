<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1013 — Event Log Clearing (darkleakmarket) | Status: deprecated | Sigma ID: 2dafa34a-0690-504a-a54c-bbd95bc94631 -->
  <rule id="171303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1013 — Event Log Clearing (darkleakmarket)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>