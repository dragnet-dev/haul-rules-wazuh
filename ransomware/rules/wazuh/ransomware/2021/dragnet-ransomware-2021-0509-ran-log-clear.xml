<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0509 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: 1f4162aa-7b6b-5bf4-b86a-c8b4a32a8e85 -->
  <rule id="626602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0509 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>