<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1146 — Recovery Inhibition (mountlocker) | Status: deprecated | Sigma ID: be44cc9d-c73b-554f-bcb2-fc554b31fce9 -->
  <rule id="475468" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1146 — Recovery Inhibition (mountlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>