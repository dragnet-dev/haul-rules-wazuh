<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0816 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: 0d200448-4536-5c97-ab31-b7abd32de7d6 -->
  <rule id="520044" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0816 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>