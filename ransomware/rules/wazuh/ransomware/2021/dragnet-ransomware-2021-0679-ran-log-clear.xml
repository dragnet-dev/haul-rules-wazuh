<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0679 — Event Log Clearing (pysa) | Status: deprecated | Sigma ID: 6f0b3efd-05ef-5a8b-9cc7-ed5d53809c1d -->
  <rule id="243422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0679 — Event Log Clearing (pysa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>