<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1122 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: aceb0356-2a51-5685-a424-c241dd3f5d79 -->
  <rule id="926703" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1122 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>