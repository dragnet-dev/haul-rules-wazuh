<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1688 — Recovery Inhibition (ransomexx) | Status: deprecated | Sigma ID: 8bd8d911-6693-54b2-86ba-cb4bd0e81851 -->
  <rule id="980619" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1688 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>