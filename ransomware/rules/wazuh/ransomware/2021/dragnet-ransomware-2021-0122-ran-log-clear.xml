<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0122 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: c9cb9bd8-bd6b-58c7-8b76-a921a2c67cc7 -->
  <rule id="916475" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0122 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>