<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0358 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: 2c0f3a2f-7ea9-54ff-aecc-a6b970b566f6 -->
  <rule id="328858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0358 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>