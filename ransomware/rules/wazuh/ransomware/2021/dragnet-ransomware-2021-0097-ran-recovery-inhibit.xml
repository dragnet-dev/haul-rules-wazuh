<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0097 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 51203c22-b50b-5e07-b6cf-7ed601e56802 -->
  <rule id="192602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0097 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>