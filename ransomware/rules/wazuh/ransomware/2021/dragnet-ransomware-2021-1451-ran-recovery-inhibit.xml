<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1451 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: faf83ee7-ebc0-5288-a9a6-e72a216aa7e2 -->
  <rule id="225342" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1451 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>