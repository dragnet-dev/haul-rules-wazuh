<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0416 — Recovery Inhibition (pay2key) | Status: deprecated | Sigma ID: d31ef150-5fd2-5fec-a187-71b76f60da2a -->
  <rule id="809751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0416 — Recovery Inhibition (pay2key)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>