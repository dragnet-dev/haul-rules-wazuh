  <rule id="944957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0357 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
