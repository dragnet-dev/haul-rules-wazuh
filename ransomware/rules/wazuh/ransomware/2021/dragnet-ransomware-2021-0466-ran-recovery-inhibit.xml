<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0466 — Recovery Inhibition (spook) | Status: deprecated | Sigma ID: 40dbe268-37bd-5b55-9646-a68917e2d841 -->
  <rule id="873582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0466 — Recovery Inhibition (spook)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>