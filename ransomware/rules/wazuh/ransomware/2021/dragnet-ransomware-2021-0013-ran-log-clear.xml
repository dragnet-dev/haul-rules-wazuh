<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0013 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 999eb7ff-b7ac-53fc-805a-38cbf5586061 -->
  <rule id="859797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0013 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>