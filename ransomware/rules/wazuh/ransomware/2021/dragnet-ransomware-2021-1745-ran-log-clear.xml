<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1745 — Event Log Clearing (avoslocker) | Status: deprecated | Sigma ID: 4040c867-ea13-551a-b8e9-4e12aa6e80d6 -->
  <rule id="265286" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1745 — Event Log Clearing (avoslocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>