  <rule id="745501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1525 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
