<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0814 — Recovery Inhibition (babuk) | Status: deprecated | Sigma ID: 7e6460e2-5041-569d-ac1c-5655744eb3a1 -->
  <rule id="466460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0814 — Recovery Inhibition (babuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
