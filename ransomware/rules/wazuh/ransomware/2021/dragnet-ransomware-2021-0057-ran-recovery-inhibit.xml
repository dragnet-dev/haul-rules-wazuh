<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0057 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: a01169c2-3034-5b8c-9918-c102a268aa1f -->
  <rule id="201169" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0057 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
