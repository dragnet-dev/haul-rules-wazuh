<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1604 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: ff0a4d3f-97e9-5df6-ad4e-f04622e8e4b6 -->
  <rule id="329677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1604 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>