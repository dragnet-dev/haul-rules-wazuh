<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1479 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 954410c3-f8fc-59d8-8337-10883a731159 -->
  <rule id="970572" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1479 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
