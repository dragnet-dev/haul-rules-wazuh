<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1243 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 49c282bf-2a15-5901-9177-f9b0568464ab -->
  <rule id="240523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1243 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>