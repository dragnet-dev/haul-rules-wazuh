<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1280 — Recovery Inhibition (xinglocker) | Status: deprecated | Sigma ID: 48be7c01-2cca-541f-8439-20929cbf9371 -->
  <rule id="296604" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1280 — Recovery Inhibition (xinglocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>