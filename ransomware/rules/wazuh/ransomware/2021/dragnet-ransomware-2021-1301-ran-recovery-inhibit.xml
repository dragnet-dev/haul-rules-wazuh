<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1301 — Recovery Inhibition (mountlocker) | Status: deprecated | Sigma ID: cfbe7ea6-8963-5e09-b1e9-3a6b4ad43fdc -->
  <rule id="509246" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1301 — Recovery Inhibition (mountlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>