<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0100 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: e247e8c4-ac0d-5572-a1c5-07922d941cd2 -->
  <rule id="579668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0100 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
