<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1164 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: d0549864-29ad-51b6-b288-a4f31ea8c4a4 -->
  <rule id="505498" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1164 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>