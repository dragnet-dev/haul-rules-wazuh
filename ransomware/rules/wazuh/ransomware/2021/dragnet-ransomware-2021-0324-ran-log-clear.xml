<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0324 — Event Log Clearing (suncrypt) | Status: deprecated | Sigma ID: ea205129-a4ae-508f-a7be-e7cca4c26ab7 -->
  <rule id="642051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0324 — Event Log Clearing (suncrypt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>