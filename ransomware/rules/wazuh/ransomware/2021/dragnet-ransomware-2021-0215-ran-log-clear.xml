<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0215 — Event Log Clearing (blackmatter) | Status: deprecated | Sigma ID: 2102a375-ac1c-5d2a-baa1-c3bd9d18d425 -->
  <rule id="764237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0215 — Event Log Clearing (blackmatter)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>