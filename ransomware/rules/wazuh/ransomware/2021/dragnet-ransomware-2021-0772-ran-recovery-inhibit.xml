<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0772 — Recovery Inhibition (suncrypt) | Status: deprecated | Sigma ID: 6eb908ee-117e-5176-a7cc-c274f73e92a2 -->
  <rule id="971908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0772 — Recovery Inhibition (suncrypt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
