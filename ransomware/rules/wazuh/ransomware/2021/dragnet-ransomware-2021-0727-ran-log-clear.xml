<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0727 — Event Log Clearing (blackmatter) | Status: deprecated | Sigma ID: 1fe8be5a-6a20-5025-a7d8-3fcd86f2ed81 -->
  <rule id="507838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0727 — Event Log Clearing (blackmatter)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>