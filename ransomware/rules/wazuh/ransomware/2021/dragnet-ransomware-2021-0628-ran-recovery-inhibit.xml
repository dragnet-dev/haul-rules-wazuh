<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0628 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 2385e229-6332-55d6-95d4-947df0252e22 -->
  <rule id="317422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0628 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>