<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0237 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 29fe19c7-b190-5d56-bc4a-5506e984360b -->
  <rule id="685116" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0237 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>