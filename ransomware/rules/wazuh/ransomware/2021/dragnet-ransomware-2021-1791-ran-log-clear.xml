<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1791 — Event Log Clearing (alphv) | Status: deprecated | Sigma ID: b2bc6cc6-3b13-5e77-ade3-d0b7eb9230b8 -->
  <rule id="217708" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1791 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>