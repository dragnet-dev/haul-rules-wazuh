<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1158 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 8e884abb-901d-560d-8fe3-e694e9ed2766 -->
  <rule id="586154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1158 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>