<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0298 — Event Log Clearing (mosesstaff) | Status: deprecated | Sigma ID: c0900b68-3ca8-5bae-8fe3-0a0a2e80085c -->
  <rule id="234411" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0298 — Event Log Clearing (mosesstaff)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>