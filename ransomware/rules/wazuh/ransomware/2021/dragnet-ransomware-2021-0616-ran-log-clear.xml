<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0616 — Event Log Clearing (pysa) | Status: deprecated | Sigma ID: a8f2a5bb-ce82-5a33-9f7d-9e35ccad87b8 -->
  <rule id="189225" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0616 — Event Log Clearing (pysa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>