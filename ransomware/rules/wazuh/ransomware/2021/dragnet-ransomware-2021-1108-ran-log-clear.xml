<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1108 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: d3bbc4cf-7397-5e21-b362-7bc7e5f82f70 -->
  <rule id="177724" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1108 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>