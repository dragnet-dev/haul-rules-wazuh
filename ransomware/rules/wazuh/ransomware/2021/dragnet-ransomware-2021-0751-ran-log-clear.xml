<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0751 — Event Log Clearing (snatch) | Status: deprecated | Sigma ID: a25d21d5-b5cf-5dd7-831a-b151544b9b50 -->
  <rule id="841321" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0751 — Event Log Clearing (snatch)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>