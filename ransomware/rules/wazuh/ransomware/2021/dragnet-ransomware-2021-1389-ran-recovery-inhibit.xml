<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1389 — Recovery Inhibition (ransomexx) | Status: deprecated | Sigma ID: e64e9819-2dcf-53d4-b492-a5d19568b458 -->
  <rule id="643898" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1389 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>