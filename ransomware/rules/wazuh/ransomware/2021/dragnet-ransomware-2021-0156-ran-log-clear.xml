<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0156 — Event Log Clearing (lockdata) | Status: deprecated | Sigma ID: 9be884c7-ca70-52c8-8501-196f9f3a0d11 -->
  <rule id="794884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0156 — Event Log Clearing (lockdata)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>