<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1729 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: c88633ac-f34b-5bb1-8eb7-6f9c22fdef2d -->
  <rule id="488633" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1729 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>