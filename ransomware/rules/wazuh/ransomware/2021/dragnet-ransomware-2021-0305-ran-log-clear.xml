<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0305 — Event Log Clearing (blacktor) | Status: deprecated | Sigma ID: 3f767622-fdd2-5304-91be-0120baae8773 -->
  <rule id="176762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0305 — Event Log Clearing (blacktor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>