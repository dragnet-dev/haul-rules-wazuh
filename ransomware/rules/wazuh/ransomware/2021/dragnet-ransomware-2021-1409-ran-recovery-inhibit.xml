<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1409 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: ae9ebf13-7385-5643-9708-f2d7e2979e64 -->
  <rule id="967679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1409 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
