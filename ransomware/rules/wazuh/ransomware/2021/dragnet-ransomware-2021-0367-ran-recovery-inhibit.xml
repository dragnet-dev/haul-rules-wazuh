<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0367 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 8aeb3605-5c2a-5095-992e-9e9e640c93d1 -->
  <rule id="956336" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0367 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>