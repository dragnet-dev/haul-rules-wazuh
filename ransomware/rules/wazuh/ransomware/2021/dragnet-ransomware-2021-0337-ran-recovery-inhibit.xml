<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0337 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: a16da03b-028e-5d4d-a5fe-b3363409548a -->
  <rule id="903140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0337 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>