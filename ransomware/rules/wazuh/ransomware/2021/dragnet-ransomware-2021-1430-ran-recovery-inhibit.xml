<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1430 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 884bf86c-797f-5364-906a-cd23de53f6b7 -->
  <rule id="564958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1430 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
