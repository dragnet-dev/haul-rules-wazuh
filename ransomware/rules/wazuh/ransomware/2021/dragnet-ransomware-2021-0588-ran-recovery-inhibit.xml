<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0588 — Recovery Inhibition (xinglocker) | Status: deprecated | Sigma ID: 1ff4da43-d127-5413-963c-4a5617e6a570 -->
  <rule id="509402" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0588 — Recovery Inhibition (xinglocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>