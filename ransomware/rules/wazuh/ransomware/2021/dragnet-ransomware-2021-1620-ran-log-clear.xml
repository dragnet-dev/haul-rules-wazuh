<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1620 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 617837df-4e2d-5e9d-a1ad-6ed68d40c43b -->
  <rule id="985405" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1620 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>