<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1236 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 23e69704-199d-5ee2-a333-c4b110eb778a -->
  <rule id="326970" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1236 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
