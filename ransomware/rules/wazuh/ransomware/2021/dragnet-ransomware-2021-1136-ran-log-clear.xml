<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1136 — Event Log Clearing (pysa) | Status: deprecated | Sigma ID: 0a06fb54-97ee-525a-8a1d-7d3e3c40a5eb -->
  <rule id="877875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1136 — Event Log Clearing (pysa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>