<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0949 — Event Log Clearing (doppelpaymer) | Status: deprecated | Sigma ID: 01d59040-f2d5-59d0-8bf5-d8ed102d283f -->
  <rule id="359040" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0949 — Event Log Clearing (doppelpaymer)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>