<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1537 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: da381afe-8c2c-5312-946f-035c496c3784 -->
  <rule id="894106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1537 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>