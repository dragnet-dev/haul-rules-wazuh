<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1516 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 31cf2d6d-d83c-5e37-a018-a2c70abcbf56 -->
  <rule id="502925" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1516 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>