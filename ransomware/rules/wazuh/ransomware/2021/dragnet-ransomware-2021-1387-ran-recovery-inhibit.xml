<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1387 — Recovery Inhibition (suncrypt) | Status: deprecated | Sigma ID: 28eaede4-d122-5b87-a3e7-e013e5e2053f -->
  <rule id="195149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1387 — Recovery Inhibition (suncrypt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>