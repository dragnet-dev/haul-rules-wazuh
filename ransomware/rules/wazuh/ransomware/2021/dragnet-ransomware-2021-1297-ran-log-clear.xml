<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1297 — Event Log Clearing (ransomexx) | Status: deprecated | Sigma ID: 4f7deb58-d716-5741-9256-8eb9bf7a18cf -->
  <rule id="668075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1297 — Event Log Clearing (ransomexx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>