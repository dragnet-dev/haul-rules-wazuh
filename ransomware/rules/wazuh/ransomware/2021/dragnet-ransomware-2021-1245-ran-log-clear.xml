<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1245 — Event Log Clearing (lockdata) | Status: deprecated | Sigma ID: 738c3c66-7226-5a67-8b17-cf179a27ac10 -->
  <rule id="191260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1245 — Event Log Clearing (lockdata)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>