<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0903 — Event Log Clearing (avaddon) | Status: deprecated | Sigma ID: 27667433-5b0e-5c3b-8aee-264d719204c5 -->
  <rule id="166743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0903 — Event Log Clearing (avaddon)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>