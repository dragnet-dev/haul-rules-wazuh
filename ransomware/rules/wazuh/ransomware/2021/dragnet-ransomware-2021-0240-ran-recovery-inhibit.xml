<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0240 — Recovery Inhibition (ransomexx) | Status: deprecated | Sigma ID: 59713a03-d206-5e00-8f46-5d729800ac95 -->
  <rule id="654180" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0240 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
