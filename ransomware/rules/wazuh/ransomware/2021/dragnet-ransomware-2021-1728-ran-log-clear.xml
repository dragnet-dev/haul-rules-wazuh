<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1728 — Event Log Clearing (suncrypt) | Status: deprecated | Sigma ID: a78e19ed-a8e0-59e9-b63e-1aa683d0bf79 -->
  <rule id="926219" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1728 — Event Log Clearing (suncrypt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>