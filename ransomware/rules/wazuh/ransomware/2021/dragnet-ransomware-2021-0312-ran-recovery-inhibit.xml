<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0312 — Recovery Inhibition (ryuk) | Status: deprecated | Sigma ID: f94458cc-ebef-5ccd-a10a-dfb39d7611d8 -->
  <rule id="794458" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0312 — Recovery Inhibition (ryuk)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>