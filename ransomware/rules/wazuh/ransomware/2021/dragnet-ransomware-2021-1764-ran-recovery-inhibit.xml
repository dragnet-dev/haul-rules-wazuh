<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1764 — Recovery Inhibition (atomsilo) | Status: experimental | Sigma ID: 7a04c41c-ed8e-54bc-8949-b81cefb95ffd -->
  <rule id="252764" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1764 — Recovery Inhibition (atomsilo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>