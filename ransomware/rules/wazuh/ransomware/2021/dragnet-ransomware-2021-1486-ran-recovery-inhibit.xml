<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1486 — Recovery Inhibition (avaddon) | Status: deprecated | Sigma ID: 225121e6-818a-5ebe-92c6-434a9d762df8 -->
  <rule id="101950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1486 — Recovery Inhibition (avaddon)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>