<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0171 — Recovery Inhibition (networm) | Status: deprecated | Sigma ID: 6a04e135-14af-5638-bc4d-d86a9491fae4 -->
  <rule id="896781" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0171 — Recovery Inhibition (networm)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>