<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0485 — Recovery Inhibition (mountlocker) | Status: deprecated | Sigma ID: 28f5a981-5bbf-52e8-b162-f7887d15a111 -->
  <rule id="317098" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0485 — Recovery Inhibition (mountlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>