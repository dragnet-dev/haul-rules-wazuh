<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0512 — Recovery Inhibition (spook) | Status: deprecated | Sigma ID: bd40c996-41f5-5ace-b36f-ca01940f098a -->
  <rule id="430529" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0512 — Recovery Inhibition (spook)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
