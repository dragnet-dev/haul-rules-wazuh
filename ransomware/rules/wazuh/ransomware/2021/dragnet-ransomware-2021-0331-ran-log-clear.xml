<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0331 — Event Log Clearing (karma) | Status: deprecated | Sigma ID: 733a8885-489b-5997-938c-b294ca308953 -->
  <rule id="373888" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0331 — Event Log Clearing (karma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>