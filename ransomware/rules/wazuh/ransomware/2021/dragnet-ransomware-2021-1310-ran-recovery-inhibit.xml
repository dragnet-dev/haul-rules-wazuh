<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1310 — Recovery Inhibition (ransomexx) | Status: deprecated | Sigma ID: ad86185e-930a-51e5-a29a-d04cc9463ad5 -->
  <rule id="938618" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1310 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>