<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1080 — Event Log Clearing (payloadbin) | Status: deprecated | Sigma ID: 0aaf73fb-5d0e-545f-bf76-97c6d1f90e11 -->
  <rule id="877183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1080 — Event Log Clearing (payloadbin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>