<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0802 — Recovery Inhibition (pysa) | Status: deprecated | Sigma ID: c62af361-6522-58ee-85b8-27a946c098e8 -->
  <rule id="632473" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0802 — Recovery Inhibition (pysa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>