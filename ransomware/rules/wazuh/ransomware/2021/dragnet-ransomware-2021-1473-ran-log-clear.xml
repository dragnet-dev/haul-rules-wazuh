<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1473 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 9f19e612-32aa-539f-81a9-8cbe3406c2ce -->
  <rule id="847186" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1473 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>