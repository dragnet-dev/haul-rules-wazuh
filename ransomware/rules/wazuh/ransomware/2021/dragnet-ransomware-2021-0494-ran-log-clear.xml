<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0494 — Event Log Clearing (cryp70n1c0d3) | Status: deprecated | Sigma ID: 05e477c2-abe2-5967-b093-06e34ed05176 -->
  <rule id="711644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0494 — Event Log Clearing (cryp70n1c0d3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>