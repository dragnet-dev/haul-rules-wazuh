<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0962 — Event Log Clearing (midas) | Status: deprecated | Sigma ID: 6b5d9bbe-a3d1-56ae-b896-e0e007dbe1e2 -->
  <rule id="154235" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0962 — Event Log Clearing (midas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>