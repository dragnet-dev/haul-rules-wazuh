<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1756 — Event Log Clearing (karma) | Status: deprecated | Sigma ID: 5c7576c1-e8fa-51bd-83b1-1b8c75bea9cd -->
  <rule id="541228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1756 — Event Log Clearing (karma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>