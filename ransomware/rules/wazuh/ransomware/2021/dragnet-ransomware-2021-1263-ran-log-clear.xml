<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1263 — Event Log Clearing (conti) | Status: deprecated | Sigma ID: e7c4c2ac-27f8-5bbf-ba19-6b9da9e9882f -->
  <rule id="283162" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1263 — Event Log Clearing (conti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>