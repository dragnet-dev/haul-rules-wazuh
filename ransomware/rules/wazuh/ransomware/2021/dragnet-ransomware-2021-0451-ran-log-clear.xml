<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0451 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 0a6230b7-6fbf-50cc-916f-1c592d31d71e -->
  <rule id="899691" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0451 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>