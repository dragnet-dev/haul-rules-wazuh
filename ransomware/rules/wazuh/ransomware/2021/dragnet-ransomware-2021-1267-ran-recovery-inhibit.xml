<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1267 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 209a2d54-7204-5edc-a09b-c61921cf0dc5 -->
  <rule id="966855" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1267 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
