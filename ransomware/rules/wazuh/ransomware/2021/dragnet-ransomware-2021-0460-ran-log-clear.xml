<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0460 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 4d0687fd-7cdd-572b-9cc1-5ddf0bd19eb4 -->
  <rule id="731007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0460 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>