<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1794 — Event Log Clearing (babuk) | Status: experimental | Sigma ID: 2446047f-0257-5d8d-b804-70e96d2549bc -->
  <rule id="746047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1794 — Event Log Clearing (babuk)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>