<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0178 — Event Log Clearing (azroteam) | Status: deprecated | Sigma ID: 1eebce3e-b076-5be8-9cc6-8b36b3c77770 -->
  <rule id="326446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0178 — Event Log Clearing (azroteam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>