<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1038 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 95af3af3-c136-5630-913a-2ad3158e062c -->
  <rule id="419258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1038 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>