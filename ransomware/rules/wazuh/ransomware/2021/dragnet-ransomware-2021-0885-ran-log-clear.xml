<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0885 — Event Log Clearing (pysa) | Status: deprecated | Sigma ID: 4f3d28a1-5fa1-5e7f-ae35-2df29956b679 -->
  <rule id="470128" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0885 — Event Log Clearing (pysa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>