<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0478 — Event Log Clearing (lorenz) | Status: deprecated | Sigma ID: b2b03421-d99f-5933-907a-90830204edc6 -->
  <rule id="103034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0478 — Event Log Clearing (lorenz)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>