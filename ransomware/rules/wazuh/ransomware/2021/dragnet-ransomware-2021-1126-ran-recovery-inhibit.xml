<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1126 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 102e5a39-9427-562b-b063-ed8181f833fd -->
  <rule id="934503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1126 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>