<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1529 — Event Log Clearing (darkleakmarket) | Status: deprecated | Sigma ID: 4d1ea991-753e-5cb2-bce6-cd7b67ffe0c0 -->
  <rule id="276109" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1529 — Event Log Clearing (darkleakmarket)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>