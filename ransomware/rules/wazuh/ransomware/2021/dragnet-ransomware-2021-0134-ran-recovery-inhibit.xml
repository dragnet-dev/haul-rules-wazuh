<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0134 — Recovery Inhibition (avaddon) | Status: deprecated | Sigma ID: 137e46e4-83a8-5662-9033-c29366d766a8 -->
  <rule id="930350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0134 — Recovery Inhibition (avaddon)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
