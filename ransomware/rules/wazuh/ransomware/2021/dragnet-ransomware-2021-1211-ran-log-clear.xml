<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1211 — Event Log Clearing (avoslocker) | Status: deprecated | Sigma ID: 4ed79558-edf2-5a8f-b847-b524d2f8dc27 -->
  <rule id="461795" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1211 — Event Log Clearing (avoslocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>