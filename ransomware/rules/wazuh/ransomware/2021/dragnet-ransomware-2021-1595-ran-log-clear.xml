<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1595 — Event Log Clearing (darkside) | Status: deprecated | Sigma ID: 8f36f8a9-5a4e-526a-b1ef-9cefe3d9b38f -->
  <rule id="593918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1595 — Event Log Clearing (darkside)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>