<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1151 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 90395629-1e15-5bdd-8113-67a24b46f194 -->
  <rule id="139562" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1151 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>