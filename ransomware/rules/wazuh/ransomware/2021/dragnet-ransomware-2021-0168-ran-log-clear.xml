<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0168 — Event Log Clearing (babuk) | Status: experimental | Sigma ID: 5330ec03-97ff-52eb-a726-fb098a9766fe -->
  <rule id="564716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0168 — Event Log Clearing (babuk)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>