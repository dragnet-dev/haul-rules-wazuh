<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0627 — Event Log Clearing (everest) | Status: deprecated | Sigma ID: 4f32efa5-08b0-5ff0-a1b1-397ec450aa75 -->
  <rule id="330831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0627 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>