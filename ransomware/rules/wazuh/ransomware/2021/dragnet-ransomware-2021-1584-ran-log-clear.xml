<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1584 — Event Log Clearing (lockdata) | Status: deprecated | Sigma ID: 357ea78a-0c1f-5c84-8d0e-e4c5cedd75d8 -->
  <rule id="262678" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1584 — Event Log Clearing (lockdata)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>