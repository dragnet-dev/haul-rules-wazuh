<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0321 — Event Log Clearing (pay2key) | Status: deprecated | Sigma ID: 686f0961-1f93-52e9-b01f-ffc72ae61b16 -->
  <rule id="299109" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0321 — Event Log Clearing (pay2key)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>