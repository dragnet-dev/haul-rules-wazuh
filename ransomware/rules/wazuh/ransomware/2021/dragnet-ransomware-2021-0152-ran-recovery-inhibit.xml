<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0152 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 9f152340-4813-5cd3-b7ab-352f3111bf62 -->
  <rule id="791523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0152 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>