<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1212 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 534daaa3-5003-5ce4-b806-99ef0d5a4cb9 -->
  <rule id="490762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1212 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>