<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0990 — Event Log Clearing (ronggolawe) | Status: deprecated | Sigma ID: 1048295f-1602-5cb9-881f-a8614eaa95b5 -->
  <rule id="248295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0990 — Event Log Clearing (ronggolawe)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>