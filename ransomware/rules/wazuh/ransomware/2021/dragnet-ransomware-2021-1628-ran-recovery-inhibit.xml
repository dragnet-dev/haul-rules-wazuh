<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1628 — Recovery Inhibition (azroteam) | Status: deprecated | Sigma ID: 09f63320-7fac-5809-81ab-af8f7cc89a5a -->
  <rule id="796332" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1628 — Recovery Inhibition (azroteam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>