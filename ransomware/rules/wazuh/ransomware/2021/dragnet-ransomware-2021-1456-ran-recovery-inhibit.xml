<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1456 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: d0e1356d-beda-5fa5-b609-79b933925f7e -->
  <rule id="394135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1456 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>