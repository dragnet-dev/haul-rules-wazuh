<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0798 — Event Log Clearing (ragnarlocker) | Status: deprecated | Sigma ID: c5db9fb8-72bd-5afc-a05d-9b3f253e9d73 -->
  <rule id="755199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0798 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>