<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-1249 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 91e43810-134b-5727-8cc9-280cafe19fa7 -->
  <rule id="670438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-1249 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>