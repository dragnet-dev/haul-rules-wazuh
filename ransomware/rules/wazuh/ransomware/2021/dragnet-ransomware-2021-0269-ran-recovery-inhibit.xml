<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0269 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 6b5d7ae3-df88-5f15-865a-65075f175695 -->
  <rule id="154202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0269 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
