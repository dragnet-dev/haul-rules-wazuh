<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2021-0428 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 8194f91b-8172-5b1d-b439-55d77af549f7 -->
  <rule id="511199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2021-0428 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>