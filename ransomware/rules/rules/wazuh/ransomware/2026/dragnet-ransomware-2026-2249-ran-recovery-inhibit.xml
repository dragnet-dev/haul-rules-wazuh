<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2249 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 30abd218-f9c1-5005-856d-e46067893d36 -->
  <rule id="456292" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2249 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>