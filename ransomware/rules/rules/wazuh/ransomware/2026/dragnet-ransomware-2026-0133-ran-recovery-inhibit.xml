<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0133 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 2bf3118c-0885-5256-ac7f-6942df1a068e -->
  <rule id="833118" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0133 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>