<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2083 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 54847343-7ca4-5e8a-a2b1-914c25ad85c6 -->
  <rule id="184734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2083 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>