<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1008 — Recovery Inhibition (lynx) | Status: test | Sigma ID: 774476e7-9f64-5adf-a196-71acea2e2f46 -->
  <rule id="791630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1008 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>