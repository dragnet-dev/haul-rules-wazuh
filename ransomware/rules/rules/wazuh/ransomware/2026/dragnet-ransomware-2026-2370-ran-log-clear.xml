<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2370 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: d35e15b1-27ad-5c3b-8234-009f92c4dee5 -->
  <rule id="437415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2370 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>