<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0330 — Event Log Clearing (apt73) | Status: stable | Sigma ID: 32b404ac-4fd1-59b0-b5c6-4f2338c1a1e5 -->
  <rule id="374474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0330 — Event Log Clearing (apt73)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>