<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0012 — Event Log Clearing (payoutsking) | Status: deprecated | Sigma ID: 405b3daa-6831-56fa-a4a3-d85a7c3335a3 -->
  <rule id="238621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0012 — Event Log Clearing (payoutsking)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>