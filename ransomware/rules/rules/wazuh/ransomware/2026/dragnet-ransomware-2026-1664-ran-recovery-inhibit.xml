<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1664 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 98bb9ac5-2cd2-5e7b-ad6a-2ea1ab05401a -->
  <rule id="544154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1664 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>