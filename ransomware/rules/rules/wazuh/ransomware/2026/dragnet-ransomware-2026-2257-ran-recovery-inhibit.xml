<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2257 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 9d657d02-ec8c-5c0f-b47f-3a31fa17aa0c -->
  <rule id="822525" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2257 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>