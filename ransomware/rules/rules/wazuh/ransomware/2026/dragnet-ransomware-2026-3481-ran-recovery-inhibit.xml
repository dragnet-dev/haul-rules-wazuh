<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3481 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 52001378-6879-507c-a48a-95b8f30fce6f -->
  <rule id="800137" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3481 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>