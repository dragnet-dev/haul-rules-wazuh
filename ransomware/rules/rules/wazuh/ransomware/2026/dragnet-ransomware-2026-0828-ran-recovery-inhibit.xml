<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0828 — Recovery Inhibition (lynx) | Status: stable | Sigma ID: 973cdb74-a9ce-554b-8d05-ff10f34b7c16 -->
  <rule id="488699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0828 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>