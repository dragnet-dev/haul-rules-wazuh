<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1938 — Recovery Inhibition (beast) | Status: stable | Sigma ID: e6514880-8543-51dc-bcb6-587b1f35b575 -->
  <rule id="665148" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1938 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>