<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0062 — Recovery Inhibition (play) | Status: stable | Sigma ID: b5602e68-1fba-57cf-b84a-92352e5d4efd -->
  <rule id="149646" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0062 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>