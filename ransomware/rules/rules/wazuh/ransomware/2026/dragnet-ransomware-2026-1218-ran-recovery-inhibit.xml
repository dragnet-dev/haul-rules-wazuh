<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1218 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 02051619-b78f-578e-bde6-d0bc1813e7ed -->
  <rule id="351619" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1218 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>