<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0231 — Recovery Inhibition (direwolf) | Status: test | Sigma ID: 7cfa84e6-5ac1-5720-8502-49fcc74b032c -->
  <rule id="599484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0231 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>