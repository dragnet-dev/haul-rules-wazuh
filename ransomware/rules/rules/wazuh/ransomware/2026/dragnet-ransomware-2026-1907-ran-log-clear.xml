<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1907 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: a173d1bf-3372-5829-9389-efa0f3bcb302 -->
  <rule id="827811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1907 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>