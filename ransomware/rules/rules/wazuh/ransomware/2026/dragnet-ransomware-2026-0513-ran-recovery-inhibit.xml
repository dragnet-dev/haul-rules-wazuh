<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0513 — Recovery Inhibition (safepay) | Status: stable | Sigma ID: eaec0326-ca30-5789-9c41-569a08731cb1 -->
  <rule id="714003" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0513 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
