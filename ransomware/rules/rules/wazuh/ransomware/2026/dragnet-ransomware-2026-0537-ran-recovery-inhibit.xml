<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0537 — Recovery Inhibition (incransom) | Status: test | Sigma ID: 430ec7af-482a-58b0-a128-9520c39ec7ed -->
  <rule id="303167" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0537 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
