<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2152 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 1c7d7f56-a4ce-57a6-b8da-16bc6611e13d -->
  <rule id="269275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2152 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>