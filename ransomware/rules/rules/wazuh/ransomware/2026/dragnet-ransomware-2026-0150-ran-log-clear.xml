<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0150 — Event Log Clearing (lockbit5) | Status: stable | Sigma ID: 9e5309ec-7799-52a0-a6a8-ac98ef8ada88 -->
  <rule id="785309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0150 — Event Log Clearing (lockbit5)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>