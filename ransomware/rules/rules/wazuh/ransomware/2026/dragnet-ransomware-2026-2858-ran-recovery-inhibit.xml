<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2858 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 457fac10-aa9d-58d3-a3d4-d2599499cef9 -->
  <rule id="175884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2858 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>