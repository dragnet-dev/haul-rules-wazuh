<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1582 — Recovery Inhibition (incransom) | Status: test | Sigma ID: be35b527-7f70-58e2-9bc6-d776944332a2 -->
  <rule id="445715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1582 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
