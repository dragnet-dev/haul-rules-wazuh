<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2197 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: 29b0514a-d401-5480-8b12-255a2c55a792 -->
  <rule id="350514" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2197 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>