<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2536 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: 1e60a2d0-7f0a-5a86-9d51-f24e15903323 -->
  <rule id="735245" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2536 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>