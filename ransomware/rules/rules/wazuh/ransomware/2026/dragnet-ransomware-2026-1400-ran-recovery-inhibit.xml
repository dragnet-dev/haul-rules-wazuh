<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1400 — Recovery Inhibition (everest) | Status: stable | Sigma ID: 05c0aa97-27d3-58be-ba73-7c93de45a288 -->
  <rule id="656909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1400 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>