<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2803 — Event Log Clearing (medusalocker) | Status: stable | Sigma ID: 080c4273-646b-5947-8486-8e0311daf95a -->
  <rule id="492427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2803 — Event Log Clearing (medusalocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>