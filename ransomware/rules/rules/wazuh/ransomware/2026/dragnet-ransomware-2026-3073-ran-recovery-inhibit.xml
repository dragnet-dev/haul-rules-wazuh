<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3073 — Recovery Inhibition (qilin) | Status: test | Sigma ID: a02e651f-789d-5e42-b12a-46ef885a9478 -->
  <rule id="804665" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3073 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>