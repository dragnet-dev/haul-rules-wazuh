<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1501 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: bbf4dfe1-9400-5107-b34e-45dedbbcb7cf -->
  <rule id="599167" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1501 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>