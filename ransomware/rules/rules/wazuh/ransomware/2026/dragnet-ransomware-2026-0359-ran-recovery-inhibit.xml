<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0359 — Recovery Inhibition (incransom) | Status: test | Sigma ID: be681aa8-1f11-504c-9ca4-c5808b2f3621 -->
  <rule id="450906" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0359 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>