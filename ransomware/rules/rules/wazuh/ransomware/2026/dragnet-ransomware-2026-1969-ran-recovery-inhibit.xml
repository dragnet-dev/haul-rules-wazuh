<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1969 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: f1a43faf-eea4-51bc-9961-86a315428e2a -->
  <rule id="382303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1969 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>