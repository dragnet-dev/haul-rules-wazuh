<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0545 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: cc99a67f-9d9b-527a-9e43-54544a72e5fc -->
  <rule id="679946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0545 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>