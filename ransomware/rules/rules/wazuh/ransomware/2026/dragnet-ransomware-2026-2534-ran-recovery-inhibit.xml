<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2534 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: f098d055-4347-5e3f-9982-7ea888ff85ab -->
  <rule id="715810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2534 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>