<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3217 — Recovery Inhibition (pear) | Status: stable | Sigma ID: 7c24471a-0525-5a3a-bd57-f859ff6688a4 -->
  <rule id="442447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3217 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>