<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2972 — Recovery Inhibition (handala) | Status: stable | Sigma ID: e533e173-b0b6-5fe7-bcbf-61bc229a091d -->
  <rule id="625421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2972 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>