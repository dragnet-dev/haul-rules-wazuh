<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0392 — Recovery Inhibition (play) | Status: stable | Sigma ID: 95fd0496-e1f7-54b4-92d1-497c7e758f4a -->
  <rule id="757304" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0392 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
