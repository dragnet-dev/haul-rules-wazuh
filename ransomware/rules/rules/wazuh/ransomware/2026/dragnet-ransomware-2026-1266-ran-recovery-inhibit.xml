<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1266 — Recovery Inhibition (pear) | Status: stable | Sigma ID: 10258626-7ec0-5a29-939e-18feb1d31970 -->
  <rule id="225862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1266 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>