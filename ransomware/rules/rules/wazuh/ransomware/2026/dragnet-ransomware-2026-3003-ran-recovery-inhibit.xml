<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3003 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 19a9e21f-32f6-5d58-801a-2f7b1d5d4590 -->
  <rule id="639821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3003 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>