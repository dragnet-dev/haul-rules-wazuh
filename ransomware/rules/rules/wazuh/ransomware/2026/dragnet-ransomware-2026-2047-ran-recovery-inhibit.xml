<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2047 — Recovery Inhibition (medusalocker) | Status: stable | Sigma ID: 37677d19-0836-5c21-8cd4-b7dffe907c2d -->
  <rule id="728451" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2047 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>