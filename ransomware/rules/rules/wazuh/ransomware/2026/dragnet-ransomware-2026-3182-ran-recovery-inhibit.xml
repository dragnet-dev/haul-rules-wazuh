<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3182 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 0846d587-a5c0-58b0-aad0-9edba3bc2a40 -->
  <rule id="554958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3182 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>