<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0220 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: ef2c4e09-d43a-52d4-b2fa-aabf8c67c37d -->
  <rule id="825518" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0220 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>