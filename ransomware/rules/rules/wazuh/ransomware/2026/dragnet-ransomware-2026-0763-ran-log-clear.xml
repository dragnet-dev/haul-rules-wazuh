  <rule id="459233" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0763 — Event Log Clearing (cmdorganization)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
