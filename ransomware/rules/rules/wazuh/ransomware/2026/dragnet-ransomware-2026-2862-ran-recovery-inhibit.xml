<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2862 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: a8c1ab2d-8a95-580f-a27f-dbefa8485517 -->
  <rule id="954827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2862 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>