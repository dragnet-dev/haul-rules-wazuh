<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1190 — Event Log Clearing (lynx) | Status: test | Sigma ID: 09bf20cd-7ee3-5b7e-87da-e0d9b52ca6b6 -->
  <rule id="492332" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1190 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>