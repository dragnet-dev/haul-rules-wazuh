<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1620 — Recovery Inhibition (play) | Status: stable | Sigma ID: 7ba5adf9-f2b7-51e8-b30d-9853387bfd72 -->
  <rule id="665133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1620 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>