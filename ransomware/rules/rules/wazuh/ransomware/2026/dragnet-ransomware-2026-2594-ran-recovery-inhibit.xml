<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2594 — Recovery Inhibition (direwolf) | Status: test | Sigma ID: 365e9385-c206-5302-8518-6ab4cebf7e20 -->
  <rule id="554938" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2594 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>