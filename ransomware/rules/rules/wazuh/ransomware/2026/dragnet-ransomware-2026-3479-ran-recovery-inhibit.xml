<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3479 — Recovery Inhibition (everest) | Status: stable | Sigma ID: 05f945d3-110d-5bcd-a48b-944ec2b4943c -->
  <rule id="735133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3479 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>