<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0148 — Recovery Inhibition (ransomhouse) | Status: stable | Sigma ID: 1b661f16-8d87-52e3-83fa-d2dd750723bc -->
  <rule id="925911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0148 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>