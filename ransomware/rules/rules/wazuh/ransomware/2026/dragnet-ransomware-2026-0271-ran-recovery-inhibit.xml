<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0271 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 6da3acf2-f8c8-5a8f-b770-6fbf32e5b3f5 -->
  <rule id="991180" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0271 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>