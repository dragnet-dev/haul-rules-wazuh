<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0064 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: e4613922-2a4d-5396-99c9-959484951855 -->
  <rule id="646139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0064 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>