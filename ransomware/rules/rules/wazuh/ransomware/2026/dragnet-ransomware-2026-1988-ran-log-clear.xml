<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1988 — Event Log Clearing (threeam) | Status: stable | Sigma ID: e067d2a2-c26d-5486-ae51-5e759be3d1c1 -->
  <rule id="550852" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1988 — Event Log Clearing (threeam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>