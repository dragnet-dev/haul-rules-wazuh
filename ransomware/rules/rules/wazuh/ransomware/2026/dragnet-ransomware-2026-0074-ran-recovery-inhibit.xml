<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0074 — Recovery Inhibition (cipherforce) | Status: stable | Sigma ID: 86fce352-9a51-5614-8b0c-447d041915c7 -->
  <rule id="963023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0074 — Recovery Inhibition (cipherforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
