  <rule id="504588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2521 — Recovery Inhibition (exitium)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
