<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3001 — Event Log Clearing (dragonforce) | Status: test | Sigma ID: 4cdf5e9b-eb7b-5a34-bcbb-26c5dd6a599f -->
  <rule id="548734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3001 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>