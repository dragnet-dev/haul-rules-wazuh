<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1870 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: 6749f5da-a37b-5e38-8e7d-d0010ec72019 -->
  <rule id="279995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1870 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>