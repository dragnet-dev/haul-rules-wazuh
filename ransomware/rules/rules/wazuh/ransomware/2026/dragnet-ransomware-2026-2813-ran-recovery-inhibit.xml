<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2813 — Recovery Inhibition (lynx) | Status: test | Sigma ID: da130fea-fc64-5b42-b6fa-4a2319931a7e -->
  <rule id="890095" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2813 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>