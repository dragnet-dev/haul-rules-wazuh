<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2686 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: 41204536-1b5d-5756-8aeb-e775c3814e7a -->
  <rule id="620453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2686 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>