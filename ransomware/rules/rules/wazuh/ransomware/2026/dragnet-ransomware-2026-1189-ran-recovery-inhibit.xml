<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1189 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: e8402d7f-3b76-5d97-8ddb-7d27f2b96983 -->
  <rule id="674445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1189 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>