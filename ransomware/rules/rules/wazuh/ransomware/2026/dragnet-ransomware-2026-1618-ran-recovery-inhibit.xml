<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1618 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 67d5b1c0-7aa5-5707-b23d-db0f2efdbe9a -->
  <rule id="936911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1618 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>