<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1979 — Recovery Inhibition (anubis) | Status: stable | Sigma ID: b27c60f9-cccf-55bc-b712-252c69a15422 -->
  <rule id="104460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1979 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>