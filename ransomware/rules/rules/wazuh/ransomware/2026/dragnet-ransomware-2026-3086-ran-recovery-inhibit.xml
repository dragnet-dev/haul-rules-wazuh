<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3086 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 58c6c060-2e55-5f62-9549-f5d8b4acc13d -->
  <rule id="705080" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3086 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>