<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1844 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: 709c6ff2-8216-58f6-a530-83cf63d3fa0d -->
  <rule id="117071" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1844 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>