<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0168 — Recovery Inhibition (nova) | Status: stable | Sigma ID: 445a7ded-88df-52bf-92ef-50217a11eb18 -->
  <rule id="340925" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0168 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>