<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2902 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 0de55c14-c2f0-5522-b991-6ba771e7de04 -->
  <rule id="960921" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2902 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>