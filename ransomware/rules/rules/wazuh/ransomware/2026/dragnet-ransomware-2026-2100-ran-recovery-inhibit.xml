<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2100 — Recovery Inhibition (anubis) | Status: stable | Sigma ID: dddb278d-1dd5-5e7b-a203-97b70bf56831 -->
  <rule id="379527" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2100 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>