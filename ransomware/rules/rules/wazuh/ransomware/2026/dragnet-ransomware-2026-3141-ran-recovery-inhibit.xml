<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3141 — Recovery Inhibition (termite) | Status: stable | Sigma ID: 08848878-a036-5d80-913b-6c0fbc7e1413 -->
  <rule id="848878" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3141 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>