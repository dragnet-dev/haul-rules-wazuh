<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0803 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: 0fc4e81d-4c9b-58fa-bf9e-415dafcdce80 -->
  <rule id="539881" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0803 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>