<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2832 — Recovery Inhibition (play) | Status: stable | Sigma ID: 7396a5a2-d8e2-5d1a-b671-1e6dbdc02e34 -->
  <rule id="383465" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2832 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>