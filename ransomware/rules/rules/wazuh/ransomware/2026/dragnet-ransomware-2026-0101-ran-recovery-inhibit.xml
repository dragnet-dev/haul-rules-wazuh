<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0101 — Recovery Inhibition (fulcrumsec) | Status: stable | Sigma ID: d9834d3d-ef86-5729-99e7-7cf3ba1a3c7b -->
  <rule id="537357" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0101 — Recovery Inhibition (fulcrumsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>