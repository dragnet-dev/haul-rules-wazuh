<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1209 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: ef2f77f3-1cb6-52de-a039-c7e193623d3b -->
  <rule id="328777" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1209 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>