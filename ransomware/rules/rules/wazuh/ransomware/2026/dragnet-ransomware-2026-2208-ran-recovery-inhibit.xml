<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2208 — Recovery Inhibition (sinobi) | Status: stable | Sigma ID: f5841f24-08e7-584d-a5e7-6da59278f1d3 -->
  <rule id="793471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2208 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>