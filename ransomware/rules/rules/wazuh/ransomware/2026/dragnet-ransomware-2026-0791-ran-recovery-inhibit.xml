<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0791 — Recovery Inhibition (interlock) | Status: stable | Sigma ID: 17903c8a-22d3-5690-84b1-1e0d33e9789f -->
  <rule id="264608" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0791 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>