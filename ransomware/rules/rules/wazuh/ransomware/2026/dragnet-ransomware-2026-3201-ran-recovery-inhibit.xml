<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3201 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: fca738c7-f1ef-5059-8130-e92a56f31db6 -->
  <rule id="542738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3201 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>