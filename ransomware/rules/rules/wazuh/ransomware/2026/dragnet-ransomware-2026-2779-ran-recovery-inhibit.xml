<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2779 — Recovery Inhibition (gunra) | Status: stable | Sigma ID: 265eb490-3f89-5878-a8dd-a0030d7c5919 -->
  <rule id="607549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2779 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>