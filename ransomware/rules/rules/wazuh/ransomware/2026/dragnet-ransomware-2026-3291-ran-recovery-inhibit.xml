<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3291 — Recovery Inhibition (beast) | Status: stable | Sigma ID: 723c5bbc-9052-59a9-8e4a-2abdc9b00a29 -->
  <rule id="152891" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3291 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>