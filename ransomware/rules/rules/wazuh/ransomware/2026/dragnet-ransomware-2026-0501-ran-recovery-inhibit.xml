<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0501 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 852c1674-a818-575b-8bc5-c969e61fdd52 -->
  <rule id="564416" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0501 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>