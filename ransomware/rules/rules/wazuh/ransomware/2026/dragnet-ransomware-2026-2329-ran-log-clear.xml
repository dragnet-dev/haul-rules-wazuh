<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2329 — Event Log Clearing (krybit) | Status: stable | Sigma ID: 18d22042-c9bc-5859-8f8a-902649bf7ec5 -->
  <rule id="412204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2329 — Event Log Clearing (krybit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>