<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3459 — Event Log Clearing (dragonforce) | Status: stable | Sigma ID: 1ca341ab-c271-5a5e-9ca1-86c13d591cc8 -->
  <rule id="233466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3459 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>