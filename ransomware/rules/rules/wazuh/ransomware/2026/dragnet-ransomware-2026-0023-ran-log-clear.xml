<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0023 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: 812738ee-b8db-5e88-a0a4-39ad5c388fa2 -->
  <rule id="503822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0023 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>