<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2893 — Event Log Clearing (stormous) | Status: deprecated | Sigma ID: 6d160bbc-bb76-54a2-b7bd-e0751bb81ee3 -->
  <rule id="946571" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2893 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>