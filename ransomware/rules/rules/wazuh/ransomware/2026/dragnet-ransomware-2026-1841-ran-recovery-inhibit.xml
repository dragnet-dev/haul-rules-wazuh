<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1841 — Recovery Inhibition (everest) | Status: stable | Sigma ID: c4457652-4971-5a56-92e1-0c1fcec65535 -->
  <rule id="444576" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1841 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>