<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2135 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 282e27a6-df6a-5bbe-b422-5b0f8b8ed033 -->
  <rule id="142042" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2135 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>