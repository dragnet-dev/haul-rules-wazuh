<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1639 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 5cc22e60-313c-5764-b575-fc1871c2b092 -->
  <rule id="674766" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1639 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>