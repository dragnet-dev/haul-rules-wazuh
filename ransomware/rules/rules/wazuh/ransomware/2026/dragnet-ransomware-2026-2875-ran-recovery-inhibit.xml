<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2875 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: b4a83378-4593-5b5b-9ee8-1d74f84ce60f -->
  <rule id="134833" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2875 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>