<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3129 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: f6758c94-97c4-59ea-8f23-89fd59ef7db4 -->
  <rule id="808140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3129 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>