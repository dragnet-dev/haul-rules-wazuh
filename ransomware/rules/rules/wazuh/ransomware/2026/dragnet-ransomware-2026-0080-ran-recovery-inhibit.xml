<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0080 — Recovery Inhibition (play) | Status: stable | Sigma ID: 2d1aac91-5191-5169-8a85-44f233253e24 -->
  <rule id="150028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0080 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>