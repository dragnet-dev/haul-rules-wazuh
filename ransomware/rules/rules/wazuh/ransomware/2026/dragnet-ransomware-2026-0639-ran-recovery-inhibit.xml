<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0639 — Recovery Inhibition (interlock) | Status: test | Sigma ID: 7371c1dd-986b-5bb5-a93f-28f781bf9458 -->
  <rule id="379481" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0639 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>