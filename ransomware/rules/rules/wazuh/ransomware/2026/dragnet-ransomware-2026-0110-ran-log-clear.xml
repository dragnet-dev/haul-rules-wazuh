<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0110 — Event Log Clearing (apt73) | Status: stable | Sigma ID: 3feba36a-7c00-5a52-9ab6-6cbf2dc7a6c6 -->
  <rule id="918183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0110 — Event Log Clearing (apt73)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>