<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1771 — Event Log Clearing (lapsus$) | Status: deprecated | Sigma ID: fbda6abb-db88-5abc-8826-69dba416af78 -->
  <rule id="515946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1771 — Event Log Clearing (lapsus$)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>