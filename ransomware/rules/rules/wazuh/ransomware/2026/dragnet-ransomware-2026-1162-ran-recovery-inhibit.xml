<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1162 — Recovery Inhibition (thegentlemen) | Status: stable | Sigma ID: 1daa71da-07ea-553b-9b20-00387a2c1ebc -->
  <rule id="551549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1162 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>