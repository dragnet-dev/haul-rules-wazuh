<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3365 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: e52a4037-de32-526d-8198-e3e40f81e0b3 -->
  <rule id="624240" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3365 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>