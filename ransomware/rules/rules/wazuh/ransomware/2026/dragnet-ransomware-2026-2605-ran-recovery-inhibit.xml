<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2605 — Recovery Inhibition (AiLock) | Status: deprecated | Sigma ID: 687e2524-576f-5154-8f87-b51d34d656b7 -->
  <rule id="300625" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2605 — Recovery Inhibition (AiLock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>