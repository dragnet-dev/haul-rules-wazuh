<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0945 — Recovery Inhibition (payload) | Status: stable | Sigma ID: 03185978-15e6-5f1c-a33f-544fbf907367 -->
  <rule id="585978" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0945 — Recovery Inhibition (payload)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
