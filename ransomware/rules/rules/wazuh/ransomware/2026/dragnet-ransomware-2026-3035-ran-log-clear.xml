<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3035 — Event Log Clearing (shinyhunters) | Status: deprecated | Sigma ID: 7ceeb7b0-98cf-5520-84a2-dd3a5c006115 -->
  <rule id="717237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3035 — Event Log Clearing (shinyhunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>