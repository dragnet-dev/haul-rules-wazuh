<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2830 — Event Log Clearing (sinobi) | Status: test | Sigma ID: b204580c-a0b8-5d04-8b6e-a749cd8fe7db -->
  <rule id="320458" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2830 — Event Log Clearing (sinobi)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>