<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2507 — Event Log Clearing (dragonforce) | Status: stable | Sigma ID: fad1aae6-5a7c-52c6-9e8c-4b46e2d69e53 -->
  <rule id="473706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2507 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>