<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0451 — Recovery Inhibition (lynx) | Status: test | Sigma ID: f89339d2-58a0-55aa-9056-3809d3e40131 -->
  <rule id="789339" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0451 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>