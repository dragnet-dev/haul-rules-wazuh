<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0745 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: e454eaa7-5614-554c-a7ec-3e5644161306 -->
  <rule id="200458" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0745 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>