<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2341 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: f14ed0fd-d61f-5bde-8877-71e3146d4d8e -->
  <rule id="378210" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2341 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>