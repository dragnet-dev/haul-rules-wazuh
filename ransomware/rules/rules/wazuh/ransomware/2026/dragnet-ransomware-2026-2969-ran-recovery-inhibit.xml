<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2969 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: f5ea1984-42d8-5923-ac4e-51b147331a05 -->
  <rule id="491419" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2969 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>