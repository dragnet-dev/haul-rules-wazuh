<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1689 — Recovery Inhibition (threeam) | Status: stable | Sigma ID: 75c758ae-025d-592a-916b-f731fb6d9135 -->
  <rule id="412758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1689 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>