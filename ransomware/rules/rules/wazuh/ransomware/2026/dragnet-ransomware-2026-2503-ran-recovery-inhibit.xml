<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2503 — Recovery Inhibition (secpo) | Status: stable | Sigma ID: 39dbefea-00f8-5b41-82aa-e2373a957c88 -->
  <rule id="912207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2503 — Recovery Inhibition (secpo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>