<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1765 — Recovery Inhibition (handala) | Status: test | Sigma ID: 3c5635f8-73ba-563e-b4fb-ae207ab7473a -->
  <rule id="790175" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1765 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>