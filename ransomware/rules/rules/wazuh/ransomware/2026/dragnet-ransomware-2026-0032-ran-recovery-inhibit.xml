<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0032 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: a44b0ce6-047f-5677-ade6-9a5ce4dcf087 -->
  <rule id="974412" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0032 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
