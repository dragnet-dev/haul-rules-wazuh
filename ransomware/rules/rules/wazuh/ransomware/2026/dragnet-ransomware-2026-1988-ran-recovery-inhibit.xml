<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1988 — Recovery Inhibition (threeam) | Status: stable | Sigma ID: 4b71aba0-8451-5fc3-95d2-a44c4e76ae34 -->
  <rule id="238347" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1988 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>