<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0997 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 8e5aeda7-986b-56fb-8b8a-37504f2b70ae -->
  <rule id="539597" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0997 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>