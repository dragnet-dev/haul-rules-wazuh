<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0029 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 1f1de430-1d21-5c78-a2a0-db140ba065f7 -->
  <rule id="883843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0029 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>