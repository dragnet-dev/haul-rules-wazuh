<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2149 — Recovery Inhibition (payload) | Status: stable | Sigma ID: 31862eb9-e409-5ca7-8375-568dcdd850a9 -->
  <rule id="156907" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2149 — Recovery Inhibition (payload)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>