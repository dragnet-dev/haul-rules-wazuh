<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1632 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 4eefa771-1dea-5fe7-b1a8-10fc1015f8d1 -->
  <rule id="633227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1632 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>