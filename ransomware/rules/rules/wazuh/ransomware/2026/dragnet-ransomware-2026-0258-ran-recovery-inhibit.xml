<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0258 — Recovery Inhibition (insomnia) | Status: stable | Sigma ID: fd63fffd-27a6-50c3-b0bc-7ed391cde700 -->
  <rule id="293183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0258 — Recovery Inhibition (insomnia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>