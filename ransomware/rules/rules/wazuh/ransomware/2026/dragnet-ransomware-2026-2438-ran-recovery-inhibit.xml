<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2438 — Recovery Inhibition (devman) | Status: test | Sigma ID: 2e506247-8fb7-564a-bed2-ff9dfec2bd3f -->
  <rule id="250624" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2438 — Recovery Inhibition (devman)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>