<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2563 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: b017bec5-2ced-514b-8052-b70d91ebb984 -->
  <rule id="220542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2563 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
