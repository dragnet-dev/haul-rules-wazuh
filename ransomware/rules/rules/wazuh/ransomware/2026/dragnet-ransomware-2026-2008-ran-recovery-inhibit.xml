<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2008 — Recovery Inhibition (lockbit5) | Status: test | Sigma ID: dee240b6-430e-59b3-a539-20bf70190455 -->
  <rule id="966240" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2008 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>