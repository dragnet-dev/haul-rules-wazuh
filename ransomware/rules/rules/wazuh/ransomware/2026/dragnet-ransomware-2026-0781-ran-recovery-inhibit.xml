<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0781 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 40a6dd87-55da-5b3c-a24b-606a98819b92 -->
  <rule id="865757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0781 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
