<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0525 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: 2ee5e443-e0f2-5a28-b555-ed5c41487e2d -->
  <rule id="400944" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0525 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>