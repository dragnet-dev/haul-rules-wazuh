<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1345 — Recovery Inhibition (nova) | Status: stable | Sigma ID: 1e0b9a5f-3aa3-55b2-9de6-cfc51b226c6a -->
  <rule id="599145" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1345 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>