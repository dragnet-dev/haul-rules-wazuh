<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2271 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 47bc91f5-e0b7-5321-afe1-52b17a2f5f51 -->
  <rule id="422091" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2271 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>