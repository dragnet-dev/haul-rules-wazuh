<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1934 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: d4f6028c-5eb2-56fd-92eb-ba0a11f463e3 -->
  <rule id="459602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1934 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>