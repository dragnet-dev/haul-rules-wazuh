<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0855 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: a5a82e12-9696-519d-adbe-5fbc6c3c641a -->
  <rule id="105326" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0855 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>