<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3536 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 258bc336-8e98-5f33-80f1-8e9112e1b906 -->
  <rule id="423633" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3536 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>