<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3336 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: f3ad505b-00e2-508e-964f-cb4209a5e324 -->
  <rule id="434150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3336 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>