<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0065 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 4d27d026-e0c6-53e9-9c3e-4ff686c07da8 -->
  <rule id="436450" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0065 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>