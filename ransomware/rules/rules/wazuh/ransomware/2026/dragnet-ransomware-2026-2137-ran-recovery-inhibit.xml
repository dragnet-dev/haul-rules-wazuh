<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2137 — Recovery Inhibition (payload) | Status: stable | Sigma ID: 1ab48650-18f0-50b5-8636-41b49cc622ca -->
  <rule id="774865" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2137 — Recovery Inhibition (payload)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>