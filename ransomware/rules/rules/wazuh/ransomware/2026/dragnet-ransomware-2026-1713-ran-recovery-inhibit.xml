<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1713 — Recovery Inhibition (spacebears) | Status: stable | Sigma ID: a34adfe7-1a3c-53b6-b66c-75f4832bde37 -->
  <rule id="738047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1713 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>