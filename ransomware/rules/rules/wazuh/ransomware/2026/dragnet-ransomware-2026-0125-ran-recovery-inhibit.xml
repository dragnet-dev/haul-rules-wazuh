<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0125 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: 1aea9839-6ff5-533c-b147-d65c9e2a38b5 -->
  <rule id="690983" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0125 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>