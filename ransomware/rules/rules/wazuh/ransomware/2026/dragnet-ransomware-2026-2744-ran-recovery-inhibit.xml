<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2744 — Recovery Inhibition (bravox) | Status: stable | Sigma ID: 7095968d-6f72-59be-bd07-d2e4f9326eba -->
  <rule id="895968" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2744 — Recovery Inhibition (bravox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>