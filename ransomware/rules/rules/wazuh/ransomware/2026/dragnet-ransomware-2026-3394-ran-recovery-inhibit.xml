<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3394 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 270c4954-5566-5235-a136-12c209a45cb2 -->
  <rule id="832495" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3394 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>