<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0883 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: f12ef03f-3e6f-5110-a02e-c3919010b061 -->
  <rule id="373110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0883 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>