<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3114 — Event Log Clearing (vect) | Status: deprecated | Sigma ID: fe3699ed-10e7-5933-a724-a0478b2e5865 -->
  <rule id="843699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3114 — Event Log Clearing (vect)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>