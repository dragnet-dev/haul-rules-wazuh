<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3260 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 0262df72-7b75-5d4b-b575-c6c3561bd6de -->
  <rule id="529572" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3260 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>