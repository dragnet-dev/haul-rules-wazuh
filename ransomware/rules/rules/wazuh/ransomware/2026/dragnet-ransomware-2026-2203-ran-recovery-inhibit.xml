<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2203 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 333d6ba3-21b5-53cf-91d9-784d5678c7de -->
  <rule id="274682" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2203 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>