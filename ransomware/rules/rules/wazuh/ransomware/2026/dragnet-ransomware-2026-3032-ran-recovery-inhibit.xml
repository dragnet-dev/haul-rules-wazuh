<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3032 — Recovery Inhibition (killsec) | Status: deprecated | Sigma ID: 498d40c9-6a3e-54dd-af49-7cc5bdbdb1bb -->
  <rule id="270252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3032 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>