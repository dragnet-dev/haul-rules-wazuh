<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1508 — Event Log Clearing (titan) | Status: stable | Sigma ID: a4f5c36f-e34c-5883-840f-8b423cf65cbc -->
  <rule id="987323" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1508 — Event Log Clearing (titan)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>