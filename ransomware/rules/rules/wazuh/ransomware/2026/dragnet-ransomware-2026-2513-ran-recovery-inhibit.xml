<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2513 — Recovery Inhibition (lamashtu) | Status: stable | Sigma ID: c842857c-3ffd-567a-bb68-ce45817e879d -->
  <rule id="484285" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2513 — Recovery Inhibition (lamashtu)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>