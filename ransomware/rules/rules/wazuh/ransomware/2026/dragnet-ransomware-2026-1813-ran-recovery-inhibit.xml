<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1813 — Recovery Inhibition (nightspire) | Status: stable | Sigma ID: f160e2a6-491f-537b-880c-af8a84e3f631 -->
  <rule id="725742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1813 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>