<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1350 — Recovery Inhibition (lynx) | Status: stable | Sigma ID: 90051426-6531-5979-ac49-fc8732fbb868 -->
  <rule id="105142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1350 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>