<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2093 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 9e34b9a4-e86c-5475-89cb-77ab89ebdb34 -->
  <rule id="833559" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2093 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
