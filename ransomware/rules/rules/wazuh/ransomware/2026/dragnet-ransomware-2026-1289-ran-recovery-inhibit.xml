<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1289 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 82dcdb1a-b615-5d3c-a66e-6e63cb5db079 -->
  <rule id="130491" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1289 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>