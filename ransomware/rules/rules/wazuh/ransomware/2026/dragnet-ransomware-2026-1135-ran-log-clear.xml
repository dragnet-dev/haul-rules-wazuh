<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1135 — Event Log Clearing (thegentlemen) | Status: stable | Sigma ID: ad04f8a8-6fb3-5bdb-b288-11f5578ac9a3 -->
  <rule id="168798" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1135 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>