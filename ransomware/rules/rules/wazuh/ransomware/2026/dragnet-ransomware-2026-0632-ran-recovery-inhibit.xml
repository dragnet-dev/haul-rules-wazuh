<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0632 — Recovery Inhibition (incransom) | Status: test | Sigma ID: 613e557e-77eb-54eb-a90a-723a37d6a940 -->
  <rule id="922557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0632 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>