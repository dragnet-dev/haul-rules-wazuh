<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0211 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: b621cf2b-cb83-541e-b769-051da91d0f67 -->
  <rule id="375183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0211 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>