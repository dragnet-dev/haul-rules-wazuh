<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3405 — Recovery Inhibition (incransom) | Status: test | Sigma ID: af5a6e2d-6285-5dee-a13a-085195fa499a -->
  <rule id="994510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3405 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>