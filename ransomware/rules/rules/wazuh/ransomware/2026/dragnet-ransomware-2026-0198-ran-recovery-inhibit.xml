<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0198 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 809d4168-f308-5eb8-a99d-eb19df672478 -->
  <rule id="495741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0198 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>