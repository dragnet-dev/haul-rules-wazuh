<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1950 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 9eede1bc-18da-54ee-b0c9-15f5dc15f1e3 -->
  <rule id="309741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1950 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>