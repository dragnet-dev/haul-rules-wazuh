<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0715 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 01e2e5d3-b165-516e-b716-348c6860864e -->
  <rule id="654533" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0715 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>