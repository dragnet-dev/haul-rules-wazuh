<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0969 — Event Log Clearing (linkc) | Status: test | Sigma ID: 69035d45-c15f-5d5d-b247-f4a0a19c882b -->
  <rule id="304573" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0969 — Event Log Clearing (linkc)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>