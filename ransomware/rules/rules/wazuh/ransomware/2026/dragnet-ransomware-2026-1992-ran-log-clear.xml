<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1992 — Event Log Clearing (shinyhunters) | Status: deprecated | Sigma ID: d1e0f4a8-4d5d-5950-afc4-23106fe58e47 -->
  <rule id="776154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1992 — Event Log Clearing (shinyhunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>