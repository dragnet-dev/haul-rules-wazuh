<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2646 — Recovery Inhibition (m3rx) | Status: stable | Sigma ID: e7fca558-c769-5509-938a-e4d032b369d5 -->
  <rule id="761545" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2646 — Recovery Inhibition (m3rx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>