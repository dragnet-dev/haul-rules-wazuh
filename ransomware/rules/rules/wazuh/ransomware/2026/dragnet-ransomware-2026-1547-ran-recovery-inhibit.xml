<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1547 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 57e5e060-8536-55c6-bc11-f8937bbba064 -->
  <rule id="682540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1547 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>