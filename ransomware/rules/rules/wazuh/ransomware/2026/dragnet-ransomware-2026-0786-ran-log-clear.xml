<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0786 — Event Log Clearing (titan) | Status: stable | Sigma ID: 0cecd79f-5d58-5470-be58-81d336e6fc05 -->
  <rule id="894179" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0786 — Event Log Clearing (titan)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>