<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0625 — Recovery Inhibition (blackwater) | Status: stable | Sigma ID: 8e144180-beb3-5f63-86b8-2a6cc7bdcf3d -->
  <rule id="621441" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0625 — Recovery Inhibition (blackwater)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>