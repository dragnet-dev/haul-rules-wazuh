<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0250 — Recovery Inhibition (incransom) | Status: test | Sigma ID: 68903fec-8fd1-5523-a35a-08d64d527453 -->
  <rule id="302463" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0250 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
