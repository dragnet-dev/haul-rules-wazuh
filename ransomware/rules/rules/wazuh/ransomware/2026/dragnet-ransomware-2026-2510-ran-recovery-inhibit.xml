<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2510 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 8fba0921-4cb8-533d-aa4e-ccc76a403f39 -->
  <rule id="179409" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2510 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>