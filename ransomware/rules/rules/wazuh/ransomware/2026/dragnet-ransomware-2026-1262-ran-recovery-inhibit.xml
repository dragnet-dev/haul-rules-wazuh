<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1262 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: fa4e0a10-3379-56c4-a94f-d803eb94364f -->
  <rule id="212490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1262 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>