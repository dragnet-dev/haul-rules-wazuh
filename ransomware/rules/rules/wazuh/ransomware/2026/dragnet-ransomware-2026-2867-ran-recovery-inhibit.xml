<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2867 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 798e394a-e305-5cf7-91a2-8d847a15659f -->
  <rule id="478239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2867 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>