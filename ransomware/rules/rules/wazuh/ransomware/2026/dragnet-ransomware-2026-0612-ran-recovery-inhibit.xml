<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0612 — Recovery Inhibition (payoutsking) | Status: stable | Sigma ID: 42da1533-e14f-56dd-a21d-827e278b6c96 -->
  <rule id="297015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0612 — Recovery Inhibition (payoutsking)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>