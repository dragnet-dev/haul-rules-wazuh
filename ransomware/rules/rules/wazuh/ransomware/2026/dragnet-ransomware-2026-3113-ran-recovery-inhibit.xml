<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3113 — Recovery Inhibition (lynx) | Status: stable | Sigma ID: a59e235b-1dc2-501b-8abf-f2c9985855d7 -->
  <rule id="895823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3113 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>