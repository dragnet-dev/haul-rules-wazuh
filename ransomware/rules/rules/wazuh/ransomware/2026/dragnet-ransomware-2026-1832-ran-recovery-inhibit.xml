<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1832 — Recovery Inhibition (play) | Status: stable | Sigma ID: e3fb4e2c-b386-52c2-bf68-860e180cefa9 -->
  <rule id="597518" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1832 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
