<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2263 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 5823a6d4-9a3d-535a-9589-cdb4681c2f2e -->
  <rule id="608589" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2263 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>