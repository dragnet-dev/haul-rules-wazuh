<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0402 — Recovery Inhibition (play) | Status: test | Sigma ID: bb1244f5-59d3-5b6a-abbb-5edb5c601411 -->
  <rule id="171244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0402 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>