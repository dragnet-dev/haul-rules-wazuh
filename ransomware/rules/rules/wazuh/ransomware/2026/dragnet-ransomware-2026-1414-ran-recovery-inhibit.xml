<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1414 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 0be35ef9-1e82-521e-a8a6-9922380dacdc -->
  <rule id="473199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1414 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>