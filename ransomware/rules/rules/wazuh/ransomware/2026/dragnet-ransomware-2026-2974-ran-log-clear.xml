<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2974 — Event Log Clearing (lockbit5) | Status: test | Sigma ID: 4ae921d4-464c-5a2c-ab74-8e4e0c4cca2c -->
  <rule id="398921" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2974 — Event Log Clearing (lockbit5)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>