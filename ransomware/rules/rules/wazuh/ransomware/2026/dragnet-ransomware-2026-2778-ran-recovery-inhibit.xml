<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2778 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 78ad62cc-3248-5e3f-b354-0353c6d55502 -->
  <rule id="314162" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2778 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>