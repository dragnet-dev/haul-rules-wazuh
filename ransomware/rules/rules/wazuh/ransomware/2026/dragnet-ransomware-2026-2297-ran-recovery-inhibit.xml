<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2297 — Recovery Inhibition (insomnia) | Status: stable | Sigma ID: 25f71d1d-9d4d-53cf-a202-0327bc32ccc5 -->
  <rule id="451491" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2297 — Recovery Inhibition (insomnia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
