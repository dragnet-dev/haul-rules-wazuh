<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0260 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: d8b71f02-8e61-5af1-938d-b2e8ceed65c6 -->
  <rule id="951551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0260 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>