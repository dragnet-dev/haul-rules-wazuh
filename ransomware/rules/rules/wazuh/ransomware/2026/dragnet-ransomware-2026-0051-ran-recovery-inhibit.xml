<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0051 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 55dc43d8-360f-50b7-bb16-0c83fde22da8 -->
  <rule id="630043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0051 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>