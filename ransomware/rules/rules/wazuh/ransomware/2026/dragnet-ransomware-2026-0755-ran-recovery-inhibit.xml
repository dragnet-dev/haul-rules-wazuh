<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0755 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: bc72a4ae-6348-5e46-aefb-31f68d2f682b -->
  <rule id="419624" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0755 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>