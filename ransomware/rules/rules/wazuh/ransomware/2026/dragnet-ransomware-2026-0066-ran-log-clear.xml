<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0066 — Event Log Clearing (shinyhunters) | Status: deprecated | Sigma ID: 1319c1cd-d3a6-5ef4-911c-95fd9c48d53e -->
  <rule id="778588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0066 — Event Log Clearing (shinyhunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>