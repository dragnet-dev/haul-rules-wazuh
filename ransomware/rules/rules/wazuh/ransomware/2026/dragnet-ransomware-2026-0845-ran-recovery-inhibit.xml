<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0845 — Recovery Inhibition (qilin) | Status: test | Sigma ID: d6e9b379-2640-52dd-9c48-8d37395ffe7b -->
  <rule id="905553" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0845 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
