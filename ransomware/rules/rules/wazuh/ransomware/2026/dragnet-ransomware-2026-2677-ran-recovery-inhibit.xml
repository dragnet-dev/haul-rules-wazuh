<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2677 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: ebfb511b-7a00-559c-9750-7b8d3d7d2ea7 -->
  <rule id="741151" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2677 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>