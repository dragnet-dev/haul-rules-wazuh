<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2431 — Recovery Inhibition (play) | Status: stable | Sigma ID: 6d345b81-2fc6-55e5-88e6-675caff3517e -->
  <rule id="949531" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2431 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
