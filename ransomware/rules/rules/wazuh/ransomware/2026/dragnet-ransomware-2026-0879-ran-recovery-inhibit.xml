<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0879 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: dcd99e65-784e-541b-b918-55a40571e56f -->
  <rule id="354398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0879 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>