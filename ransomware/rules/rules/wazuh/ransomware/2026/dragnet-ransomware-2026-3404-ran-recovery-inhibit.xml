<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3404 — Recovery Inhibition (payload) | Status: stable | Sigma ID: f7484037-7a7c-5317-82c2-53ec7d46dbfc -->
  <rule id="774840" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3404 — Recovery Inhibition (payload)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>