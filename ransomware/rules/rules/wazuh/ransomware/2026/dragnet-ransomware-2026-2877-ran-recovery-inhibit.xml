<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2877 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: e66a48c0-578d-5b4b-a7c0-4de2cb3c0040 -->
  <rule id="646648" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2877 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>