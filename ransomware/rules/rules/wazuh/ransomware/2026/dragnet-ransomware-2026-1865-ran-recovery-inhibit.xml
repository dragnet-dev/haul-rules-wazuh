<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1865 — Recovery Inhibition (everest) | Status: test | Sigma ID: 8693e526-4ea8-5331-b665-6413b547f3b4 -->
  <rule id="591025" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1865 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>