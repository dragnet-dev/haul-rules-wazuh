<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2384 — Event Log Clearing (tengu) | Status: test | Sigma ID: 5cb32819-f320-5f7b-a5fb-f8de961de325 -->
  <rule id="683328" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2384 — Event Log Clearing (tengu)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>