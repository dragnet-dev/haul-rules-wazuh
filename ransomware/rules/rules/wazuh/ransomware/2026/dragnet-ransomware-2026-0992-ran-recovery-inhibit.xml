<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0992 — Recovery Inhibition (interlock) | Status: stable | Sigma ID: f11e1bf9-9fca-5b14-b7ec-2b5187578d11 -->
  <rule id="370427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0992 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>