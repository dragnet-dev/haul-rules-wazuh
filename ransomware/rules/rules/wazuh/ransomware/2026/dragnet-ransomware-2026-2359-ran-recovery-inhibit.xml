<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2359 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: fd9bb75a-9aca-5204-8187-fb1ec23f6606 -->
  <rule id="301717" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2359 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>