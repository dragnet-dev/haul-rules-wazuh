<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2901 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 5acd7c55-2a4d-54e4-bfef-cd8b725aad74 -->
  <rule id="219324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2901 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>