<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3387 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: f1d41bb8-356c-5dd0-9bed-3edb4ddd4314 -->
  <rule id="387067" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3387 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
