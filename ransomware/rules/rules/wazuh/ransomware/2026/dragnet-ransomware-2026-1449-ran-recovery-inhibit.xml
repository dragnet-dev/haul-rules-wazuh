<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1449 — Recovery Inhibition (spacebears) | Status: test | Sigma ID: 283277c2-42c3-5413-bd08-ac8056acb10d -->
  <rule id="132444" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1449 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>