<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0875 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: a70457f3-63cb-5639-bb5f-855dfa02f6db -->
  <rule id="270457" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0875 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>