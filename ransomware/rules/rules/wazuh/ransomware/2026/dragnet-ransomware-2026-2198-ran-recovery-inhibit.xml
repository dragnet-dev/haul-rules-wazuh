<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2198 — Recovery Inhibition (lynx) | Status: stable | Sigma ID: 4a4bae28-9878-5fc2-9367-eea24da65546 -->
  <rule id="450414" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2198 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>