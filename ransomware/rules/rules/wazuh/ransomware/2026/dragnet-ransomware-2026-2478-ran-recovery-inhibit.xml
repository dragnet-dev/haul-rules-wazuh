<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2478 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 87ba7e82-8668-5723-97f2-f4728780ebf1 -->
  <rule id="993406" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2478 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>