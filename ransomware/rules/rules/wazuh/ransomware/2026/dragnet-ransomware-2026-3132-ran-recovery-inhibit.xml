<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3132 — Recovery Inhibition (handala) | Status: test | Sigma ID: 1062596f-1599-5628-8fc9-3f177dc47843 -->
  <rule id="262596" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3132 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>