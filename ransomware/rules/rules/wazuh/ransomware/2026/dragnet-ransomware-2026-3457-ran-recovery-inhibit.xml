<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3457 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 4ad388a4-dba5-5370-b18f-70f03fd6f6c7 -->
  <rule id="397388" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3457 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>