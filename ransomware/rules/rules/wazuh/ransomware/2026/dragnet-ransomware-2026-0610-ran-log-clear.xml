<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0610 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: ae45100c-70c9-5a1e-8dff-6b5b65177747 -->
  <rule id="944510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0610 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>