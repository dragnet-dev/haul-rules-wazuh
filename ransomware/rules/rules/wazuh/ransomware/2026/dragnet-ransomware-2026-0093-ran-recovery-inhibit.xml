<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0093 — Recovery Inhibition (interlock) | Status: test | Sigma ID: 5fd098c8-a8af-5463-9061-693e5a61bfea -->
  <rule id="733098" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0093 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>