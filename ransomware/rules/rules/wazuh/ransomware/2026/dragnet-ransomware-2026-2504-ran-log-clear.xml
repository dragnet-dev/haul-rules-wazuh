<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2504 — Event Log Clearing (Icarus) | Status: deprecated | Sigma ID: 79497a1c-c4d1-56c2-80e5-93dcdbfcfcfd -->
  <rule id="471962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2504 — Event Log Clearing (Icarus)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>