<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2205 — Recovery Inhibition (nova) | Status: stable | Sigma ID: f9233474-9368-5fc8-9822-4fec851bdeff -->
  <rule id="792334" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2205 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>