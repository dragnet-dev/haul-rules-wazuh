<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1552 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 8e25f8ca-ae57-5125-bb85-5d208807229d -->
  <rule id="576158" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1552 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>