<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1757 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 61b6150f-45f7-5941-ab0a-25dca1c34328 -->
  <rule id="976150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1757 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>