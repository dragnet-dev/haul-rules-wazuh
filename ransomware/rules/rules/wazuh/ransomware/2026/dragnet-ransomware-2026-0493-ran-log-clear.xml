<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0493 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: 4d9c8665-2778-51d4-b0f7-a3d31531cd56 -->
  <rule id="447686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0493 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>