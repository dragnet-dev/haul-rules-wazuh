<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2852 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: d9426b52-0aa8-56b9-b65e-4bd4a470ef00 -->
  <rule id="530827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2852 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>