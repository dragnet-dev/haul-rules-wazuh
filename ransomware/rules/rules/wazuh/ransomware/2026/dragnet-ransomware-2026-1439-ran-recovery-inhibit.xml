<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1439 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 6b164599-2ec6-5893-bcb2-16dcccaab28d -->
  <rule id="271645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1439 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>