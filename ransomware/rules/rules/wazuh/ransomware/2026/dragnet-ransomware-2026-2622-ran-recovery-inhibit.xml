<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2622 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: de25ac40-1c67-570a-a45e-a868f2692d5b -->
  <rule id="389772" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2622 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>