<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2539 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: c7ae86e0-592b-58e2-8538-1633b5a484c9 -->
  <rule id="668686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2539 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>