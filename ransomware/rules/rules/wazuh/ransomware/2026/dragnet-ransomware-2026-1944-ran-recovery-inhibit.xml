<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1944 — Recovery Inhibition (gunra) | Status: stable | Sigma ID: 1825b28e-998a-5226-8d3b-b979f5e9a5c9 -->
  <rule id="321128" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1944 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>