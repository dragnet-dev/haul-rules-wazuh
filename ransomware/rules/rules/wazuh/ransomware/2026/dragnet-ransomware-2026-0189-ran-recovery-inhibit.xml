<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0189 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 6e4ee08d-d2dd-5b8f-8a39-8d6bc75d8575 -->
  <rule id="228620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0189 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>