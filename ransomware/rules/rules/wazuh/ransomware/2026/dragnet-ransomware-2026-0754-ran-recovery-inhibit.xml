<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0754 — Recovery Inhibition (safepay) | Status: stable | Sigma ID: 1643a60a-e214-566f-a192-1d51bc59f09c -->
  <rule id="929860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0754 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>