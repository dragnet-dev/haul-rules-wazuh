<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1676 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 46248ff9-84d0-555f-8754-34b0a18851d0 -->
  <rule id="239743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1676 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>