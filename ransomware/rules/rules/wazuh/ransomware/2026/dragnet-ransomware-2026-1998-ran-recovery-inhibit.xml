<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1998 — Recovery Inhibition (incransom) | Status: test | Sigma ID: 6e544610-5095-5543-ac47-4dfad3f05816 -->
  <rule id="305446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1998 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>