<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1809 — Event Log Clearing (lamashtu) | Status: stable | Sigma ID: 54bf0927-1479-58cb-8cac-76ab35ad2d50 -->
  <rule id="601509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1809 — Event Log Clearing (lamashtu)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>