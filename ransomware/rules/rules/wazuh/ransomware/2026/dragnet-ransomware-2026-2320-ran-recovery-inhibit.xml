<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2320 — Recovery Inhibition (m3rx) | Status: stable | Sigma ID: 004ae11c-38f5-53c4-bf23-1437b79de038 -->
  <rule id="216988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2320 — Recovery Inhibition (m3rx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>