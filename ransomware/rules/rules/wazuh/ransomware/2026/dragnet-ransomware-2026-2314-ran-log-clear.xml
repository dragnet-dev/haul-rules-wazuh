<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2314 — Event Log Clearing (worldleaks) | Status: test | Sigma ID: b8bb77a4-0fe6-57d2-be65-2408f4d4b2c3 -->
  <rule id="439577" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2314 — Event Log Clearing (worldleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>