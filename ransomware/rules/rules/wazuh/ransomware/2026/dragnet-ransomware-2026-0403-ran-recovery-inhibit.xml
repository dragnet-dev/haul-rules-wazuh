<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0403 — Recovery Inhibition (play) | Status: stable | Sigma ID: 9d41171a-b02a-5f17-af6a-ad77d4c25250 -->
  <rule id="774117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0403 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>