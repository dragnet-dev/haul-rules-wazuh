<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3323 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: 53fa6eea-53b2-5862-aa92-a73c326352d2 -->
  <rule id="510990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3323 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>