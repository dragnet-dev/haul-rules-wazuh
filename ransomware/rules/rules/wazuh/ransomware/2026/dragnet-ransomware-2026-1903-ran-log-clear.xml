<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1903 — Event Log Clearing (worldleaks) | Status: test | Sigma ID: 41b2e4a0-5111-5b0c-93c6-1a5fba7c18f5 -->
  <rule id="267664" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1903 — Event Log Clearing (worldleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>