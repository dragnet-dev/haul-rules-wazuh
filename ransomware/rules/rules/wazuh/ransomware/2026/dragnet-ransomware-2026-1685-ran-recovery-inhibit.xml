<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1685 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 4d7f85eb-9c41-5a77-bd8d-256c86c20a7c -->
  <rule id="444785" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1685 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>