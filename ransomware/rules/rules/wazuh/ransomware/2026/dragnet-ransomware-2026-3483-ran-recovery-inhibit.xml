<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3483 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 00b1f59f-6f3c-59ce-8847-a2f1c53fba24 -->
  <rule id="266559" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3483 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>