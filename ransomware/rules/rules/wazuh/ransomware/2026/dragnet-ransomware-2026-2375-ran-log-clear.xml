<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2375 — Event Log Clearing (kairos) | Status: deprecated | Sigma ID: d703c56b-5fb2-5de5-9c3d-ad8ea8b98fcc -->
  <rule id="492605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2375 — Event Log Clearing (kairos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>