<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2206 — Recovery Inhibition (everest) | Status: test | Sigma ID: 18b9ef25-85eb-58cf-898c-aaaeee7dcdc4 -->
  <rule id="579832" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2206 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>