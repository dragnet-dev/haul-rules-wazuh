<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1739 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: a7825fb1-f551-5cd6-925d-62b0fc944979 -->
  <rule id="925215" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1739 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>