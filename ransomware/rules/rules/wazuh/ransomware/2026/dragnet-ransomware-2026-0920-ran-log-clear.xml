<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0920 — Event Log Clearing (fulcrumsec) | Status: stable | Sigma ID: 4503d3f8-cf5c-5c32-9600-9044b33d2dd9 -->
  <rule id="829823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0920 — Event Log Clearing (fulcrumsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>