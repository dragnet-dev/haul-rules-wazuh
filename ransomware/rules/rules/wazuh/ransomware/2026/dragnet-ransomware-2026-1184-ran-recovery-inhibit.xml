<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1184 — Recovery Inhibition (blacknevas) | Status: stable | Sigma ID: 5557a89a-df5d-5b81-acd3-576db42f8e34 -->
  <rule id="892289" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1184 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>