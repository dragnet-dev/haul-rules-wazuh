<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2171 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 56cd8b31-056f-5065-99bb-ee42bf66b68d -->
  <rule id="626699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2171 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>