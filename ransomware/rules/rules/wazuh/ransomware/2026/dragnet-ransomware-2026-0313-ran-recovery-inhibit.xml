<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0313 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 3a06e9f5-bae1-55cc-8213-3a4f6f3c6691 -->
  <rule id="565759" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0313 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>