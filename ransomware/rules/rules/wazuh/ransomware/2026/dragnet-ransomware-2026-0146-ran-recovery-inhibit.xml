<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0146 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 009c1ab3-85da-51c5-93fa-8c474a4498e8 -->
  <rule id="497873" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0146 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>