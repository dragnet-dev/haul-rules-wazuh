<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3475 — Event Log Clearing (PrinzEugen) | Status: stable | Sigma ID: e0de80e6-f01b-50bf-82cc-79bf57357f22 -->
  <rule id="106280" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3475 — Event Log Clearing (PrinzEugen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>