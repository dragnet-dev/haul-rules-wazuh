<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0121 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 466ba65b-edf3-5fa0-9a90-6c6c994304bf -->
  <rule id="394826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0121 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>