<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0711 — Event Log Clearing (AiLock) | Status: deprecated | Sigma ID: 7031fd9f-6ab0-5f95-b9f1-9ff4ec43b2c6 -->
  <rule id="100189" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0711 — Event Log Clearing (AiLock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>