<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2788 — Event Log Clearing (secpo) | Status: stable | Sigma ID: ef1ca564-84d4-571d-a1ff-fdfa18934fcd -->
  <rule id="822985" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2788 — Event Log Clearing (secpo)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>