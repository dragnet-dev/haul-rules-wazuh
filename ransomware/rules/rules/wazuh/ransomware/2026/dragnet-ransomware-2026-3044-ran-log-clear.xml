<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3044 — Event Log Clearing (mnt6) | Status: stable | Sigma ID: 5b51fd90-6ba8-52a7-af08-3e08b9adb818 -->
  <rule id="642909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3044 — Event Log Clearing (mnt6)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>