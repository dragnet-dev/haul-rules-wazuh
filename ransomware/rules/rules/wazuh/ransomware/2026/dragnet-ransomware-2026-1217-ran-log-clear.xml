<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1217 — Event Log Clearing (dragonforce) | Status: stable | Sigma ID: c9b5d7dd-af66-5b93-a90e-b11f901bc9d0 -->
  <rule id="720937" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1217 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>