<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0126 — Recovery Inhibition (cipherforce) | Status: stable | Sigma ID: 273b20af-947b-51c4-bf12-da0061047b99 -->
  <rule id="806730" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0126 — Recovery Inhibition (cipherforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>