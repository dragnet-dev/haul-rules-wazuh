<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3352 — Recovery Inhibition (interlock) | Status: stable | Sigma ID: f74fe3c0-acaa-5051-bd09-94fa5cf06196 -->
  <rule id="531983" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3352 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>