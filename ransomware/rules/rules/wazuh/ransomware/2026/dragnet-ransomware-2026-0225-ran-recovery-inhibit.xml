<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0225 — Recovery Inhibition (everest) | Status: stable | Sigma ID: 21b7d6f1-c248-50c8-b970-7a14f582f586 -->
  <rule id="903311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0225 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>