<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0151 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 6bd9efe6-60f4-5258-9694-7931fb17bb06 -->
  <rule id="918543" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0151 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>