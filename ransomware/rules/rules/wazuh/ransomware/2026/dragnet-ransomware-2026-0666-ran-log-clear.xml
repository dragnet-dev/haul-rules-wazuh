<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0666 — Event Log Clearing (fulcrumsec) | Status: stable | Sigma ID: 7058e8de-b0e0-50f7-91f3-a610ca7b36a7 -->
  <rule id="329428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0666 — Event Log Clearing (fulcrumsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>