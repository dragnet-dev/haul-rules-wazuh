<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3284 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 89dd19f4-e1bd-50cd-b20c-9a23089f627d -->
  <rule id="600519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3284 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>