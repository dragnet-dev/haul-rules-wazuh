<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0475 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: fc8ed3da-d654-5e8c-89b6-185212754370 -->
  <rule id="274053" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0475 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>