<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2340 — Recovery Inhibition (handala) | Status: stable | Sigma ID: c63cf765-987e-55af-8dcd-ccc41e9f5460 -->
  <rule id="635357" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2340 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>