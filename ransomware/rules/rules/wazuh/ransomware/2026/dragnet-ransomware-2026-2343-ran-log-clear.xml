<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2343 — Event Log Clearing (genesis) | Status: test | Sigma ID: 1fbcc1ca-f34a-5aed-a25b-f2269dc170c0 -->
  <rule id="499961" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2343 — Event Log Clearing (genesis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>