<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0911 — Event Log Clearing (apt73) | Status: stable | Sigma ID: ddf2ab90-36d2-5861-a22f-e4abf8ae6cc5 -->
  <rule id="191243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0911 — Event Log Clearing (apt73)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>