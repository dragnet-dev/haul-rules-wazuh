<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0177 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 5f4df026-7748-5220-a22c-42b857c0e80b -->
  <rule id="744470" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0177 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>