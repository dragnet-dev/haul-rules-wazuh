<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1303 — Recovery Inhibition (bravox) | Status: stable | Sigma ID: 66ebe6e8-4814-51e8-9350-69bbad4946c8 -->
  <rule id="141106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1303 — Recovery Inhibition (bravox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>