<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0428 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: b7455cf7-dce2-53aa-87fa-5ca6f1611dcf -->
  <rule id="179292" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0428 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>