<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2175 — Recovery Inhibition (medusalocker) | Status: stable | Sigma ID: 13c6ba5a-ac8d-55cd-82ca-cd45125edd2d -->
  <rule id="349225" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2175 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>