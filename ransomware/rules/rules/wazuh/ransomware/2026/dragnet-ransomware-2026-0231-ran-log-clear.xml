<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0231 — Event Log Clearing (direwolf) | Status: test | Sigma ID: e9e2a6dd-162a-5e39-af07-cef496180f4a -->
  <rule id="337226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0231 — Event Log Clearing (direwolf)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>