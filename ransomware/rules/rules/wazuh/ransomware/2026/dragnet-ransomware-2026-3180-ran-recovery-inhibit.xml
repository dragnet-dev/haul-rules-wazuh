<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3180 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 4f04cd7f-5535-5b1d-904c-e4837f6cac65 -->
  <rule id="323629" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3180 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>