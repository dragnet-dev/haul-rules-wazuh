<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3262 — Recovery Inhibition (anubis) | Status: stable | Sigma ID: 11d90ef1-5c2e-5780-a8fe-62dd7d0a682d -->
  <rule id="461679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3262 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>