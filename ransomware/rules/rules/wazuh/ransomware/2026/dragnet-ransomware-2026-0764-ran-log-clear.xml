<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0764 — Event Log Clearing (TiMc) | Status: deprecated | Sigma ID: b9c78e35-f68b-50ce-ad5f-44e0c1c00514 -->
  <rule id="466862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0764 — Event Log Clearing (TiMc)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>