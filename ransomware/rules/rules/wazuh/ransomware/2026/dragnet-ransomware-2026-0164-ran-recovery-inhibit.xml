<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0164 — Recovery Inhibition (insomnia) | Status: stable | Sigma ID: 3e2404d7-9fda-519f-9d12-fb4ef8a2aa67 -->
  <rule id="158477" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0164 — Recovery Inhibition (insomnia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>