<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0862 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: 20c2033b-fbdd-50a7-bb7b-b032b7755dfa -->
  <rule id="722033" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0862 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>