<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0620 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 9da998db-528b-5736-8421-c49e3757b4a8 -->
  <rule id="822998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0620 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>