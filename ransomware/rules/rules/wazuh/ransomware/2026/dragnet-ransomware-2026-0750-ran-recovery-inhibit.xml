<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0750 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 301c3095-ca76-575e-967a-d670e0c830cf -->
  <rule id="428309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0750 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>