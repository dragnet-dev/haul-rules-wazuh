<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1893 — Recovery Inhibition (gunra) | Status: stable | Sigma ID: dc7d7ed6-a33b-5473-84b7-4d19b5da99e4 -->
  <rule id="352126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1893 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>