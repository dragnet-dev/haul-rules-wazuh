<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1718 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: ef146dd8-290c-5f1b-8abd-cefb27fbaa72 -->
  <rule id="326349" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1718 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>