<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3239 — Event Log Clearing (AiLock) | Status: deprecated | Sigma ID: 95a51952-9c40-5ba1-a99e-0bcdaa0638c9 -->
  <rule id="730519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3239 — Event Log Clearing (AiLock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>