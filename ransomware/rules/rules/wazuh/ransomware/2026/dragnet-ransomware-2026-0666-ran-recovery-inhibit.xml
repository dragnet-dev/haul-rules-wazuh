<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0666 — Recovery Inhibition (fulcrumsec) | Status: stable | Sigma ID: 017bc335-e8e3-57bc-a237-a3571f6cf8ff -->
  <rule id="140335" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0666 — Recovery Inhibition (fulcrumsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>