<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1995 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: ce8bfddd-522a-5292-ae19-e52d9cd7da11 -->
  <rule id="473597" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1995 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>