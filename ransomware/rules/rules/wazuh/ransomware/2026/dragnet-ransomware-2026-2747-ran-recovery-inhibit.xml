<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2747 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 83559317-46d3-5cf2-b665-9be546fd33d2 -->
  <rule id="355931" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2747 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>