<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1380 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: c056d9cb-ed4d-59d4-9fc1-b444ec56ea81 -->
  <rule id="229099" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1380 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>