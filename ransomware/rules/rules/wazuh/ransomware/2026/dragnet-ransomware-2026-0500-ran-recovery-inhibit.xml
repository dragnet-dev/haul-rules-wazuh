<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0500 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: e47c1110-7e2d-57e0-bbe4-842be0f28979 -->
  <rule id="616411" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0500 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
