<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2538 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 305c40ac-4048-511e-bb23-751b2ff72285 -->
  <rule id="727850" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2538 — Recovery Inhibition (qilin)</description>
