<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2698 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 6a105594-285f-5d86-bf90-bffc8bf86092 -->
  <rule id="261055" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2698 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>