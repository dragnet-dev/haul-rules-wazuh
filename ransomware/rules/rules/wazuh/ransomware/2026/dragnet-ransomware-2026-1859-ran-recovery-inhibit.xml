<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1859 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: c032a0a3-4ef8-5ba7-ba6c-ccc9149415da -->
  <rule id="225220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1859 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>