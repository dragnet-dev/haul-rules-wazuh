<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0435 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 6603b078-9649-5084-85e3-8d51fcec57e6 -->
  <rule id="256590" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0435 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>