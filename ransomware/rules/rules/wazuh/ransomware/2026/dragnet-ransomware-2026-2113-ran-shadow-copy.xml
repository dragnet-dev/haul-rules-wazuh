<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2113 — Shadow Copy Deletion (SilentRansomGroup) | Status: deprecated | Sigma ID: 84733f3b-35e1-5bb7-9c98-f3cc9b1ca432 -->
  <rule id="555743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2113 — Shadow Copy Deletion (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>