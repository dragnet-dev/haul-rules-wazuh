<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2913 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: ba96b8eb-8a80-5f96-b7a9-21d1c40e44d5 -->
  <rule id="391478" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2913 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>