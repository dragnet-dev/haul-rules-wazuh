<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3411 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 9143dac9-b2e1-536e-be8e-092a0679a62d -->
  <rule id="640826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3411 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>