<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1820 — Event Log Clearing (coinbasecartel) | Status: stable | Sigma ID: 9e717794-5dc8-5375-a4fc-d7a45a4da1b4 -->
  <rule id="787177" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1820 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>