<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1636 — Recovery Inhibition (titan) | Status: stable | Sigma ID: a70a5ff0-b52a-55cd-808f-a007e75b79f7 -->
  <rule id="140895" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1636 — Recovery Inhibition (titan)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>