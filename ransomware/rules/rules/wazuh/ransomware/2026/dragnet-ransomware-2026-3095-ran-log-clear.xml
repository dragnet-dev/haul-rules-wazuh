<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3095 — Event Log Clearing (securotrop) | Status: stable | Sigma ID: 48faa911-4538-5d4c-a933-2e50eda8f6c1 -->
  <rule id="306189" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3095 — Event Log Clearing (securotrop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>