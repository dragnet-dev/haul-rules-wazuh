<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2383 — Recovery Inhibition (handala) | Status: stable | Sigma ID: ad49e05a-6c2f-5816-ab9c-f6f4978a1683 -->
  <rule id="175980" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2383 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>