<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2668 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 66d466e5-1a6b-5bc9-be56-3fa161466ac8 -->
  <rule id="269466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2668 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>