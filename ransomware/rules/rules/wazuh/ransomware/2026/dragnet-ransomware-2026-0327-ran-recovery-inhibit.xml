<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0327 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 6b6d65a4-646d-5df9-be41-c2d4d95b8070 -->
  <rule id="922965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0327 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>