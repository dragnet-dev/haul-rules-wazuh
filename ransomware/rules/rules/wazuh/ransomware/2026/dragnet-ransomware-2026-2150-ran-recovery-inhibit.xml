<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2150 — Recovery Inhibition (ALP-001) | Status: stable | Sigma ID: d2c3459f-1ad7-5cca-9218-23f05594e65b -->
  <rule id="424345" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2150 — Recovery Inhibition (ALP-001)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>