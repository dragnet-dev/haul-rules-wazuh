<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1726 — Recovery Inhibition (lamashtu) | Status: stable | Sigma ID: af465480-1872-557c-8ff7-d90ed16ff018 -->
  <rule id="954654" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1726 — Recovery Inhibition (lamashtu)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>