<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2884 — Event Log Clearing (genesis) | Status: stable | Sigma ID: 0c9e9b20-ef27-5753-af8d-e08db48d7ae0 -->
  <rule id="726352" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2884 — Event Log Clearing (genesis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>