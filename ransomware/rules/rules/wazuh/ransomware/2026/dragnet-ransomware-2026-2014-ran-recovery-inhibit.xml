<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2014 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 9c02b648-9c63-5b73-a058-30d4f872c698 -->
  <rule id="796436" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2014 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>