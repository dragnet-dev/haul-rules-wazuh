<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2749 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: ba4849d9-4961-53fa-98f3-c62ed0153aa6 -->
  <rule id="164849" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2749 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>