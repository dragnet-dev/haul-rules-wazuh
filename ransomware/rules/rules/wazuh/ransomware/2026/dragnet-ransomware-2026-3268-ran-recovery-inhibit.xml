<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3268 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 93173f96-888c-5028-8a7a-c2d2ee50098e -->
  <rule id="690783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3268 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>