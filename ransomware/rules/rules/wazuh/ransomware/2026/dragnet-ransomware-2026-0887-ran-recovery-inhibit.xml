<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0887 — Recovery Inhibition (ransomexx) | Status: stable | Sigma ID: 8f13b08c-3430-5719-8185-aec4c091eb02 -->
  <rule id="590190" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0887 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>