<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1853 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 00c0574a-c914-56dd-bb00-23066bf0b2a2 -->
  <rule id="229194" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1853 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>