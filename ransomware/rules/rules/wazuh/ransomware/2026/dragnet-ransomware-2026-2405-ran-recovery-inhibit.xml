<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2405 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: 1aa669cb-4961-567d-b27e-362b0569def2 -->
  <rule id="626716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2405 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
