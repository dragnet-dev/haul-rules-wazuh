<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3398 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: a5d19fc1-0f83-52ad-a7f7-bfdd17e2bf53 -->
  <rule id="109119" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3398 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>