<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3233 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: dd66d02f-25ef-5c6a-b135-31f24cdb5b63 -->
  <rule id="946690" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3233 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>