<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2428 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 7d4ae422-2659-5f80-88ae-f1a427ec84a7 -->
  <rule id="611984" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2428 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>