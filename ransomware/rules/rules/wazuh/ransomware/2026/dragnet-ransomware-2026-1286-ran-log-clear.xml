<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1286 — Event Log Clearing (fulcrumsec) | Status: stable | Sigma ID: 05959a3b-03a9-59aa-a6bb-19e5ea9e4ce7 -->
  <rule id="956699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1286 — Event Log Clearing (fulcrumsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>