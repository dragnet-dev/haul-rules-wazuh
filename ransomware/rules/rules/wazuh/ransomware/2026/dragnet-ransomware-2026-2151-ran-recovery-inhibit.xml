<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2151 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 4a7563a8-d4ea-57a0-be0d-331224165cc3 -->
  <rule id="361018" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2151 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>