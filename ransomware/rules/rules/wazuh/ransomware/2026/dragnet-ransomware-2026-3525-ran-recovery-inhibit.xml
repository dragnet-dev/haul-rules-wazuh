<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3525 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: 69647fb8-6a2e-5a3f-b048-7be235b0e989 -->
  <rule id="314367" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3525 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>