<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2665 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: e2e91374-70b1-5517-aa06-73e4be80a174 -->
  <rule id="586913" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2665 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>