<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2692 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 46ad92f7-3eb1-5675-9788-16317a253171 -->
  <rule id="394992" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2692 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>