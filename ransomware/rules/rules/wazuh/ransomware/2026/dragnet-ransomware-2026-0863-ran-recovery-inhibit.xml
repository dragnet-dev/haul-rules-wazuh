<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0863 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 1c585770-2741-50ad-9c1e-43a9e82c2460 -->
  <rule id="258577" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0863 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>