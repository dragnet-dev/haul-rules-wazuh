<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3288 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 68e516e4-a0f4-55a0-bc68-1b1212aad8a4 -->
  <rule id="302516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3288 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>