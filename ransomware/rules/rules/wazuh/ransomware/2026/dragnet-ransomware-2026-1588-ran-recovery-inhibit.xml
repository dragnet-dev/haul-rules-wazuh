<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1588 — Recovery Inhibition (qilin) | Status: test | Sigma ID: f269f7fc-eca4-57a5-b4ec-8d6d596ca064 -->
  <rule id="743197" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1588 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
