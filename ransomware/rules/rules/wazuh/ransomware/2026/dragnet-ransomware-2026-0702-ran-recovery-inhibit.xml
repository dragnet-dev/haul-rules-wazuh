<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0702 — Recovery Inhibition (titan) | Status: stable | Sigma ID: 33eb755b-f336-5710-a0f6-88ee5c4ab256 -->
  <rule id="683755" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0702 — Recovery Inhibition (titan)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>