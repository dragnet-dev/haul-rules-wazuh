<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3279 — Recovery Inhibition (play) | Status: stable | Sigma ID: 1185ca29-1da2-5dc9-85f3-61688737bdf3 -->
  <rule id="435622" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3279 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>