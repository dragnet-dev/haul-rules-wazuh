<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3209 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: c7a55376-410f-55fe-b59b-78f37ad7555b -->
  <rule id="342553" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3209 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>