<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0510 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 66fc0b51-40e6-54ce-aa10-c7a85335586c -->
  <rule id="143691" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0510 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
