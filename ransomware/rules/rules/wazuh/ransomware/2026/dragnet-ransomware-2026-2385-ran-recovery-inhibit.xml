<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2385 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 812e5099-1c23-5962-86e7-16a2bf4bca31 -->
  <rule id="500650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2385 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>