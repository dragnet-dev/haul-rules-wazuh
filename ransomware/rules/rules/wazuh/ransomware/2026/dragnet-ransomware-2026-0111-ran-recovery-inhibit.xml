<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0111 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 6c113c67-03b6-5a4f-93d6-fd118288bc52 -->
  <rule id="929820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0111 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>