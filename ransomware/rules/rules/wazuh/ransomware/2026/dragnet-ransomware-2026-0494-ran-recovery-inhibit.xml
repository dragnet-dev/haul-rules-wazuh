<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0494 — Recovery Inhibition (sinobi) | Status: stable | Sigma ID: 172d7e55-4755-50c0-969e-b7004f330865 -->
  <rule id="925265" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0494 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>