<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0390 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: f935e830-6809-5441-b17d-b17fa9271d46 -->
  <rule id="849748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0390 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>