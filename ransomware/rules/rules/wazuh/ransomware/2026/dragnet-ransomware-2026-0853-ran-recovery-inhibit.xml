<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0853 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 8ee9ad75-22de-595e-9146-3140e542ebfc -->
  <rule id="554637" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0853 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
