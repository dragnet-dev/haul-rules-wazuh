<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1124 — Event Log Clearing (thegentlemen) | Status: test | Sigma ID: b6fa3a2c-3a8c-5cf8-8bf8-33f356a058e4 -->
  <rule id="391418" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1124 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>