<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2745 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: e54413d1-0be5-520b-ae6f-23eae5e4956f -->
  <rule id="654413" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2745 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>