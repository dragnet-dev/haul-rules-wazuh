<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0939 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 245e808b-6ae2-51b8-8178-b6e8094a8096 -->
  <rule id="434808" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0939 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>