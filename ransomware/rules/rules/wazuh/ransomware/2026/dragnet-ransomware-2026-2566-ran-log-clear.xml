<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2566 — Event Log Clearing (qilin) | Status: stable | Sigma ID: 71fb8b4b-26b6-57b8-a4e9-0d48e3ecbec7 -->
  <rule id="348459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2566 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>