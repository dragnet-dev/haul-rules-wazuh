<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3539 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: ef440b33-f887-5f5d-8f70-ad24178bd828 -->
  <rule id="331051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3539 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>