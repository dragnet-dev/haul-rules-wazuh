<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1413 — Event Log Clearing (linkc) | Status: stable | Sigma ID: d94d9bb7-8a18-561c-86b2-4a7a5f3ea03a -->
  <rule id="970875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1413 — Event Log Clearing (linkc)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>