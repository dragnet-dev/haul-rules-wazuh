<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2050 — Recovery Inhibition (everest) | Status: stable | Sigma ID: 5b9fe05a-8129-55ee-95c4-a9afec56051e -->
  <rule id="655180" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2050 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>