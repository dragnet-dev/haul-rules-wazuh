<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1001 — Recovery Inhibition (sinobi) | Status: stable | Sigma ID: a3be4a94-19b0-5044-ad7f-be4e5337c22a -->
  <rule id="749354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1001 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>