<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2758 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: ec482ad0-3415-5e17-93e4-8c8a2ec2763b -->
  <rule id="283722" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2758 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>