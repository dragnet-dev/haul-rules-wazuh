<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1731 — Event Log Clearing (dragonforce) | Status: stable | Sigma ID: 7ed76fd3-1e4f-5100-8d2d-f1a8bec0c5a0 -->
  <rule id="647631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1731 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>