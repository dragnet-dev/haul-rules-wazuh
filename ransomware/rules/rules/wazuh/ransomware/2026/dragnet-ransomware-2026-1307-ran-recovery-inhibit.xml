<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1307 — Recovery Inhibition (qilin) | Status: test | Sigma ID: c2d86302-f7a8-5850-86ae-b1c11e953bca -->
  <rule id="265863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1307 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>