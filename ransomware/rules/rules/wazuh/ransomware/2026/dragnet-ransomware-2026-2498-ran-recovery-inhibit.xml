<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2498 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 269f4a71-b51c-54c6-8950-838f3da781bd -->
  <rule id="711147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2498 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>