<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0653 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: a5a85586-c63b-5a38-b454-c9fb361e5985 -->
  <rule id="890855" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0653 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>