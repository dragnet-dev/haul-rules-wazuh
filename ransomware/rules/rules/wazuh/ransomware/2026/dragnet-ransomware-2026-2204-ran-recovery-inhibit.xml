<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2204 — Recovery Inhibition (safepay) | Status: stable | Sigma ID: 318bd30e-326a-5e8a-ae09-681c374a769c -->
  <rule id="159730" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2204 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>