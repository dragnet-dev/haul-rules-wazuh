<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0466 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 213cb61f-267b-5ac0-8a33-d43a00026c81 -->
  <rule id="173161" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0466 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>