<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1459 — Recovery Inhibition (nova) | Status: stable | Sigma ID: 5a6f39af-4e28-5da2-978a-ded810446047 -->
  <rule id="651139" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1459 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>