<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0806 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: a3748498-ca2b-5319-b897-cad1dbc16ef2 -->
  <rule id="237484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0806 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>