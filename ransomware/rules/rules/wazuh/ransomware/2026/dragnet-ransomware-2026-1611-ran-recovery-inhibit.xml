<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1611 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: d3c71436-4e6b-558e-a07a-f2cceeb54b73 -->
  <rule id="440714" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1611 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>