<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3157 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 90304f2f-5b18-5622-afaa-d0f0587244e7 -->
  <rule id="644879" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3157 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>