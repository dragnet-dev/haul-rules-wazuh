<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1842 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: af0b09f5-9ed6-5ac9-b5a3-f2efb1bb5504 -->
  <rule id="201109" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1842 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>