<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1800 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: e8b6c227-e316-566b-ba7f-79ad64a3ac73 -->
  <rule id="307482" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1800 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>