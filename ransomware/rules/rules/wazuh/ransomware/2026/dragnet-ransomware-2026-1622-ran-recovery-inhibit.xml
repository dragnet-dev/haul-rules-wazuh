<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1622 — Recovery Inhibition (handala) | Status: stable | Sigma ID: ad36f8bb-0dfa-567a-b763-655db93fcc29 -->
  <rule id="173918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1622 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>