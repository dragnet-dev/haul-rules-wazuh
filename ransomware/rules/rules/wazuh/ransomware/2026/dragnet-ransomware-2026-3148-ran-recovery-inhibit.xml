<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3148 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: e492efef-f334-5ce1-8935-746a086affa6 -->
  <rule id="210191" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3148 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>