<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0243 — Recovery Inhibition (pear) | Status: stable | Sigma ID: 340a56ae-d373-5c67-b2d8-9eab844a933b -->
  <rule id="720906" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0243 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>