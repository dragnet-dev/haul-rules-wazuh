<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3024 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: e3b81d2b-9050-5646-ac73-fffa7852a10c -->
  <rule id="179709" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3024 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>