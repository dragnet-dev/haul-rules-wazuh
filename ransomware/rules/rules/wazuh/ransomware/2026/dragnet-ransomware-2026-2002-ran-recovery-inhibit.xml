<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2002 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 3ab0ca83-c48b-5b16-9f0e-a95a0a1c772c -->
  <rule id="704042" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2002 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>