<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2147 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: abe87354-4451-56ac-979a-d9ff6c544422 -->
  <rule id="150873" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2147 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>