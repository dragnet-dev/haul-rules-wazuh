<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2285 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 98fecdee-a08d-54cd-9daa-30da09fed25e -->
  <rule id="287757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2285 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>