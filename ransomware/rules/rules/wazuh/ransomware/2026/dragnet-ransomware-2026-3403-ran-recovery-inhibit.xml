<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3403 — Recovery Inhibition (lamashtu) | Status: stable | Sigma ID: 1557b92c-4784-523e-8f25-116174f18450 -->
  <rule id="792392" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3403 — Recovery Inhibition (lamashtu)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>