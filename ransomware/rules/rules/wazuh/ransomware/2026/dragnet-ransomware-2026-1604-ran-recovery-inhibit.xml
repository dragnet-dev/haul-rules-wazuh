<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1604 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 6622cc0a-f4c8-5546-bfd5-f6bbafc1fce6 -->
  <rule id="895436" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1604 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>