<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0278 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: e145117e-7909-5ef5-b288-5bc27e13905b -->
  <rule id="614511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0278 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>