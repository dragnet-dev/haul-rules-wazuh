<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0743 — Event Log Clearing (obscura) | Status: deprecated | Sigma ID: eab490a9-7c40-54c0-8bc3-fc6578375025 -->
  <rule id="255490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0743 — Event Log Clearing (obscura)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>