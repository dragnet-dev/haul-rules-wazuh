<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2155 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: 544f4e97-e7dd-598a-b852-61cf072699fd -->
  <rule id="595118" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2155 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>