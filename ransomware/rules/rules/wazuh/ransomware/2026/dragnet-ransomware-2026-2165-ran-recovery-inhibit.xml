<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2165 — Recovery Inhibition (everest) | Status: stable | Sigma ID: 905c629f-0ad4-53d1-a065-c913c519a78d -->
  <rule id="649262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2165 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>