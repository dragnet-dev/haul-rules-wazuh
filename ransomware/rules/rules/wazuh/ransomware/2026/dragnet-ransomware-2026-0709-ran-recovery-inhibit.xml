<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0709 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: c3d1050d-5a82-5764-85f4-033e80f03fa2 -->
  <rule id="281105" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0709 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>