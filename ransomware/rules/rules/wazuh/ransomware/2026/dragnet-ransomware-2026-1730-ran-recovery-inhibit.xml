<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1730 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: d9a8a212-09db-53bd-9ecd-966bd607c7a3 -->
  <rule id="975782" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1730 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>