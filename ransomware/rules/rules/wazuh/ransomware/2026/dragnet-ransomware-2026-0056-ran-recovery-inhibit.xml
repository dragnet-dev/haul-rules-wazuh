<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0056 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 211fe413-4d14-57e7-94af-26a8659c9be9 -->
  <rule id="127041" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0056 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>