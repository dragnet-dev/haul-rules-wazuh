<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0332 — Event Log Clearing (lockbit5) | Status: stable | Sigma ID: 1971aa92-3757-51c7-8667-1951f7e09300 -->
  <rule id="647469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0332 — Event Log Clearing (lockbit5)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>