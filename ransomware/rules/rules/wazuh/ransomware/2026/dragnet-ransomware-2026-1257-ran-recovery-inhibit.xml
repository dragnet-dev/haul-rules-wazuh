<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1257 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 434c8fb1-ce62-560e-b971-9156f10f1822 -->
  <rule id="313103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1257 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>