<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2128 — Recovery Inhibition (payoutsking) | Status: stable | Sigma ID: 0dc12809-1247-5ae6-81dc-8ccdca368830 -->
  <rule id="501280" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2128 — Recovery Inhibition (payoutsking)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>