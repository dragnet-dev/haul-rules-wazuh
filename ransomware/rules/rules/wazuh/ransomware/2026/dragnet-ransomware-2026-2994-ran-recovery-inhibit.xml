<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2994 — Recovery Inhibition (play) | Status: stable | Sigma ID: 5a6fa393-2f6f-5b4f-bc4a-f59c8593151a -->
  <rule id="621863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2994 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>