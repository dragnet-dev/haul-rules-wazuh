<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0041 — Recovery Inhibition (everest) | Status: stable | Sigma ID: 4863c082-d03f-51a5-8e19-6754ec3767b4 -->
  <rule id="682008" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0041 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>