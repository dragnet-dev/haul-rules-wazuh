<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3522 — Recovery Inhibition (interlock) | Status: test | Sigma ID: f7c4f3ab-7b05-568c-a693-9c82ee1e6e64 -->
  <rule id="539193" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3522 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>