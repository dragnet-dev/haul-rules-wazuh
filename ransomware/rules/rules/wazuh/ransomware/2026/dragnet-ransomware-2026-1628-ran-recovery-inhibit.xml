<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1628 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 4294ea1b-6c86-5573-827b-7be625c49a16 -->
  <rule id="299498" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1628 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>