<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1823 — Recovery Inhibition (m3rx) | Status: stable | Sigma ID: 3ee26a9a-c958-5bbd-87e4-c41a89ea2eee -->
  <rule id="810026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1823 — Recovery Inhibition (m3rx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>