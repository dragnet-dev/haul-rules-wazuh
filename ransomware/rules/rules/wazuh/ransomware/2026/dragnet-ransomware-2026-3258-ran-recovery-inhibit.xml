<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3258 — Recovery Inhibition (lynx) | Status: test | Sigma ID: 79875fe6-0a45-5b05-9aa5-e7fd37879119 -->
  <rule id="478015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3258 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>