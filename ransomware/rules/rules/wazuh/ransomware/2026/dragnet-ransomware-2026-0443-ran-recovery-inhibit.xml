<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0443 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 5ca122a8-ba43-5409-9bc9-6735ff4f9688 -->
  <rule id="682122" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0443 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>