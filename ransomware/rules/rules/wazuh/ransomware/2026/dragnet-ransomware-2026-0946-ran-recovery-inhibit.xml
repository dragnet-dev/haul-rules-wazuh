<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0946 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: a5fcd7d5-9ce1-5ad9-942b-35073afb3b90 -->
  <rule id="841257" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0946 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>