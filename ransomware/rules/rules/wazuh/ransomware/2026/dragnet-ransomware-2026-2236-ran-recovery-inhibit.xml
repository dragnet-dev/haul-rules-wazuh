<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2236 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 8971c042-7559-5228-ba52-6700df79961e -->
  <rule id="635480" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2236 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>