<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1433 — Recovery Inhibition (atomsilo) | Status: stable | Sigma ID: 3cba80fc-87b4-5aaf-baef-482d3feec2b4 -->
  <rule id="754680" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1433 — Recovery Inhibition (atomsilo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>