<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0836 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 8a00fa76-0ce6-5dcf-a052-7aa63f1baf38 -->
  <rule id="933050" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0836 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>