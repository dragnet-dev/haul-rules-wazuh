<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2182 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: 0666cdf4-f195-59b6-858a-68787901ee60 -->
  <rule id="131231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2182 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>