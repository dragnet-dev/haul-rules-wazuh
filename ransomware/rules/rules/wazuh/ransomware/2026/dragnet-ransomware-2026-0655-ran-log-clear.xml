<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0655 — Event Log Clearing (lockbit5) | Status: stable | Sigma ID: 3bcfdc23-806e-5cc3-9ff6-eea2bb7cb216 -->
  <rule id="419836" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0655 — Event Log Clearing (lockbit5)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>