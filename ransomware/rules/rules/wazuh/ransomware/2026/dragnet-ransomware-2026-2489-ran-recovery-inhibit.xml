<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2489 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: f259fce5-22d7-5dbe-8728-f27d34a0cfd3 -->
  <rule id="406556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2489 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>