<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0107 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 37e75ace-9bc4-5b5f-b64a-c17cafc99942 -->
  <rule id="332972" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0107 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>