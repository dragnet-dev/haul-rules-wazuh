<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0202 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 301de47d-8b08-5c6f-a038-64f05401fac2 -->
  <rule id="627847" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0202 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>