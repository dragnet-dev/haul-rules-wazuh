<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0227 — Recovery Inhibition (aurora) | Status: stable | Sigma ID: f8bfb6ec-2b3d-5f30-ac59-574250f13bbe -->
  <rule id="302356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0227 — Recovery Inhibition (aurora)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>