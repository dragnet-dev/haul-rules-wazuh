<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0714 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: cb47dcaa-fdd9-5112-817d-b21b7d2047cb -->
  <rule id="809052" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0714 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>