<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1336 — Recovery Inhibition (nova) | Status: stable | Sigma ID: 811723d6-e123-5994-8371-b7d350f6225d -->
  <rule id="487581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1336 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>