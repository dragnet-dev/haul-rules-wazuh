<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2735 — Recovery Inhibition (pear) | Status: stable | Sigma ID: fa409689-bd8d-5346-99a8-b1d03083c26f -->
  <rule id="804096" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2735 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>