<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2861 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: c0768aad-4e35-5ee8-8f29-f4c3f8e722e9 -->
  <rule id="232298" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2861 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>