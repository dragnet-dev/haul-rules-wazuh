<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2701 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 0a04c400-752f-594d-8208-9d7b61e3ecff -->
  <rule id="807640" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2701 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>