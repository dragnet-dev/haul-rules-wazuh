<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1613 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 5905438c-2102-5a9e-afe4-bafe72bb25d8 -->
  <rule id="605438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1613 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>