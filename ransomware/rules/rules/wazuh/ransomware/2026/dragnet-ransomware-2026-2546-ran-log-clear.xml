<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2546 — Event Log Clearing (qilin) | Status: stable | Sigma ID: 48a34ae4-7a68-5231-8ce1-62704e81c960 -->
  <rule id="445354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2546 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>