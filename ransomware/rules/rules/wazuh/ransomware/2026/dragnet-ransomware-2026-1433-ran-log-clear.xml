<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1433 — Event Log Clearing (atomsilo) | Status: stable | Sigma ID: 24058e3d-92f8-5dea-9f93-f5776d69ed32 -->
  <rule id="349423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1433 — Event Log Clearing (atomsilo)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>