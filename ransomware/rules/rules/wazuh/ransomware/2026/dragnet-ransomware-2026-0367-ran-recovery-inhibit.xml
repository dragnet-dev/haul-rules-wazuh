<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0367 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: f6999cdc-7776-576d-b8c5-e80848376dee -->
  <rule id="811996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0367 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>