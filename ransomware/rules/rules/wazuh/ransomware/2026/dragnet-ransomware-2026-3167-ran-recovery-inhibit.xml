<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3167 — Recovery Inhibition (bravox) | Status: stable | Sigma ID: b63d3816-f57a-5844-93e4-4d8d17f1d900 -->
  <rule id="162138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3167 — Recovery Inhibition (bravox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>