<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1522 — Event Log Clearing (kittykatkrew) | Status: stable | Sigma ID: 6a782bcc-d926-5606-8c8d-a4ac23a2a5d3 -->
  <rule id="908523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1522 — Event Log Clearing (kittykatkrew)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>