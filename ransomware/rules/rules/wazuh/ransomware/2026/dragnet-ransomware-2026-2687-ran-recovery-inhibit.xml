<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2687 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: ba3f3738-4551-5641-b4e0-92bbf7189d68 -->
  <rule id="382337" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2687 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>