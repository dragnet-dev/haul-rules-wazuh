<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1239 — Recovery Inhibition (play) | Status: stable | Sigma ID: 850ecd4a-bfe4-500c-bc51-01a76d54f759 -->
  <rule id="885389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1239 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>