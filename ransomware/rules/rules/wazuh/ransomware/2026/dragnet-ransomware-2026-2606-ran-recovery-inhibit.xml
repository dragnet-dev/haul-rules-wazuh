<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2606 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 42f88c9b-31d6-5601-b7c7-dd958dae1e3d -->
  <rule id="300620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2606 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>