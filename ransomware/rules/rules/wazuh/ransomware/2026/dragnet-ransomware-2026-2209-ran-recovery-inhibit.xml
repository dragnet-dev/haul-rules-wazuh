<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2209 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 6b11b381-32cc-5bcd-9657-e9674d73cbdd -->
  <rule id="913873" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2209 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>