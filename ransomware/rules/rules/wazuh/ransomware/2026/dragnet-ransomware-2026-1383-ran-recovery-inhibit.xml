<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1383 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: ae17c16c-8c63-5f27-a178-39ad0632afc7 -->
  <rule id="186841" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1383 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>