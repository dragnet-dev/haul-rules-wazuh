<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2633 — Recovery Inhibition (secpo) | Status: stable | Sigma ID: 32bd64ce-32c5-5231-8953-13e45b45bd10 -->
  <rule id="910636" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2633 — Recovery Inhibition (secpo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
