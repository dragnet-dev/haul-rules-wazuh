<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3519 — Recovery Inhibition (interlock) | Status: test | Sigma ID: df3e84c9-2191-50b3-baa6-40277285c676 -->
  <rule id="974284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3519 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>