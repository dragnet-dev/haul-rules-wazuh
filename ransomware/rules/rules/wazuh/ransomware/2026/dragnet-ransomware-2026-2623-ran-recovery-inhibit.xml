<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2623 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 887ed335-d730-5f46-b70d-db566bb9866a -->
  <rule id="573093" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2623 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>