<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0221 — Recovery Inhibition (killsec) | Status: deprecated | Sigma ID: 5ba4625c-5ab5-55c8-b1a8-0250067ca49f -->
  <rule id="666462" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0221 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>