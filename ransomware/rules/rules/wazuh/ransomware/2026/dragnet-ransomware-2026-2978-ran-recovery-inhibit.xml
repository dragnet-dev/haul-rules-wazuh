<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2978 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: f1829914-d28d-54fa-996f-ee1e9a79d22d -->
  <rule id="718299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2978 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>