<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0003 — Recovery Inhibition (clop) | Status: test | Sigma ID: 283d284c-6ba7-5759-b658-c5f3ad1c58d1 -->
  <rule id="141284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0003 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>