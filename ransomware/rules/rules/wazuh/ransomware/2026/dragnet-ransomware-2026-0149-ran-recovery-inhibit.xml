<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0149 — Recovery Inhibition (ransomhouse) | Status: stable | Sigma ID: 86dee0fe-2a29-515e-a723-0de542eb4729 -->
  <rule id="958220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0149 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>