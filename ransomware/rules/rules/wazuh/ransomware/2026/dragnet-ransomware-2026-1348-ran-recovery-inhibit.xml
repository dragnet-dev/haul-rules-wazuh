<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1348 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: ea81cb7b-40ff-561d-b5f4-b47359147712 -->
  <rule id="711339" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1348 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>