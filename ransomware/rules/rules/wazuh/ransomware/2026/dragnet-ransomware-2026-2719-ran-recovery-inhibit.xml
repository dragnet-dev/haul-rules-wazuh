<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2719 — Recovery Inhibition (chaos) | Status: stable | Sigma ID: 1871192d-858e-5dc0-aa13-f37045443cff -->
  <rule id="171192" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2719 — Recovery Inhibition (chaos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
