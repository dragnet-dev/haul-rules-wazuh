<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1756 — Event Log Clearing (ALP-001) | Status: stable | Sigma ID: 3a3dfe38-c5bc-5fd4-8908-c62e491134a6 -->
  <rule id="691550" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1756 — Event Log Clearing (ALP-001)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>