<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0707 — Recovery Inhibition (gunra) | Status: stable | Sigma ID: 99297e74-28b0-57a9-8a05-7c80dce36669 -->
  <rule id="788766" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0707 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>