<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0024 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 71b4dd30-463e-5f8d-8fbf-7c7908907d2b -->
  <rule id="337565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0024 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>