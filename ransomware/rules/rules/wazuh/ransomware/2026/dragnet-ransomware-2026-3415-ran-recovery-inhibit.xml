<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3415 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 8364b222-3bbd-5856-9a0c-725a2e1a0a91 -->
  <rule id="538352" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3415 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>