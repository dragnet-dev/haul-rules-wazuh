<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0128 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: ab97551e-6a09-5ae6-ba41-f29958386882 -->
  <rule id="919755" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0128 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>