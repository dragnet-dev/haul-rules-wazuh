<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3514 — Recovery Inhibition (everest) | Status: test | Sigma ID: 02ba2390-279a-555d-9a3e-4775225f5a77 -->
  <rule id="782390" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3514 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>