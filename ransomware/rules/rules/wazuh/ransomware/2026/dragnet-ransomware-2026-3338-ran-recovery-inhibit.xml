<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3338 — Recovery Inhibition (everest) | Status: stable | Sigma ID: 732365a5-c9e6-51bb-b00e-79d8ffa43253 -->
  <rule id="117850" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3338 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>