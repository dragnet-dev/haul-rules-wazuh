<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0338 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: 8636963e-75dc-5aba-9e83-b1e47e83f1c1 -->
  <rule id="636963" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0338 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>