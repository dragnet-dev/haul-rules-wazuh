<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1665 — Event Log Clearing (cipherforce) | Status: stable | Sigma ID: d240be67-5977-58d5-b72a-a6ec58a9d6e4 -->
  <rule id="789630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1665 — Event Log Clearing (cipherforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>