<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1583 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: c2c6a156-c959-5554-b9a6-278370737a7f -->
  <rule id="543461" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1583 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>