<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2381 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 077346cb-d190-59f6-a9a3-9df3e5bc7688 -->
  <rule id="437548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2381 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>