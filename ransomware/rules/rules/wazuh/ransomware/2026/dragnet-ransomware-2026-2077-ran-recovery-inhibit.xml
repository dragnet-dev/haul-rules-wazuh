<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2077 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: a1359c68-6687-5881-b7de-ef175166f629 -->
  <rule id="821756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2077 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>