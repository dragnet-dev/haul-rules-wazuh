<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3461 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 3b507671-4ea0-50cc-b6e8-cb50dfb99cee -->
  <rule id="650767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3461 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>