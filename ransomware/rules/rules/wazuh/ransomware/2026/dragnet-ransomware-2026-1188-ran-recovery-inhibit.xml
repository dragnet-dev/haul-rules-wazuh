<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1188 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 199902ab-1776-55de-95eb-6168feea8f30 -->
  <rule id="598442" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1188 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>