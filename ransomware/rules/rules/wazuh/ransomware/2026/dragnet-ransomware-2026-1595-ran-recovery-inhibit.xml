<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1595 — Recovery Inhibition (bravox) | Status: test | Sigma ID: ca08af04-7722-5a7f-9217-5f5235764405 -->
  <rule id="773423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1595 — Recovery Inhibition (bravox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>