<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3503 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: c2727495-3dc3-5b6d-a757-54642ebe8690 -->
  <rule id="427274" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3503 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
