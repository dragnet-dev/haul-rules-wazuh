<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0808 — Recovery Inhibition (nova) | Status: stable | Sigma ID: a933f047-db46-5f77-8d0e-0020b6b59704 -->
  <rule id="949430" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0808 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
