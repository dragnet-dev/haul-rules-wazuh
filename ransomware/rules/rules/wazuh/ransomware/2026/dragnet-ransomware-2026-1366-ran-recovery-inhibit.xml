<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1366 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: be612fd3-5a53-5637-ba74-250ef53df27a -->
  <rule id="449807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1366 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>