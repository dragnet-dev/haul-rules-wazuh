<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0652 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: b4dbfeb3-ee76-54c1-b878-c3506d02e465 -->
  <rule id="427422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0652 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>