<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0741 — Event Log Clearing (ALP-001) | Status: stable | Sigma ID: 0a6c7bf8-ab93-5d7d-9285-e3d016bbbaed -->
  <rule id="874463" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0741 — Event Log Clearing (ALP-001)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>