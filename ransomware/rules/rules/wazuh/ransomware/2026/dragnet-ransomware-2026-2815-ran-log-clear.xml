<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2815 — Event Log Clearing (blacknevas) | Status: stable | Sigma ID: 59c7c38c-4247-5fe6-9847-e288cfaaa6b7 -->
  <rule id="730843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2815 — Event Log Clearing (blacknevas)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>