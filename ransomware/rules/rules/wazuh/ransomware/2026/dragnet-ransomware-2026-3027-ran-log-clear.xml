<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3027 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: 626aaccc-88a0-5ea0-979c-3cf7129b3a3e -->
  <rule id="866828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3027 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>