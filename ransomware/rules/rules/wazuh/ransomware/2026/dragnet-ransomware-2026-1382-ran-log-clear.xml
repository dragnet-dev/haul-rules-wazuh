<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1382 — Event Log Clearing (krybit) | Status: stable | Sigma ID: 27c9e401-ac00-5c45-bd08-1c5174d412cf -->
  <rule id="919840" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1382 — Event Log Clearing (krybit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>