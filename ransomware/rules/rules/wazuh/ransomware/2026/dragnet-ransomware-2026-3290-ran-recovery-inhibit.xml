<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3290 — Recovery Inhibition (lynx) | Status: stable | Sigma ID: 8a1d8c10-de47-5bf1-b9de-946e03623a67 -->
  <rule id="937580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3290 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>