<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2500 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: f0418a66-3d69-5e7b-b3f8-a4e4ed416a01 -->
  <rule id="706698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2500 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>