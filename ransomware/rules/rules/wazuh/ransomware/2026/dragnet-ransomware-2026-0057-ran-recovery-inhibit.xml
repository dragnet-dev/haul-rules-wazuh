<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0057 — Recovery Inhibition (fulcrumsec) | Status: stable | Sigma ID: 309a729e-b97d-5aec-855c-649c0f28dd6a -->
  <rule id="554729" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0057 — Recovery Inhibition (fulcrumsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>