<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0619 — Recovery Inhibition (anubis) | Status: test | Sigma ID: eff60087-8f06-5bde-8367-7c123f021d80 -->
  <rule id="339600" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0619 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
