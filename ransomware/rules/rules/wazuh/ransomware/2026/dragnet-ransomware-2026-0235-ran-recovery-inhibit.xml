<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0235 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 9c9fac95-3240-5ba3-909e-97a0bbb8c7ea -->
  <rule id="230636" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0235 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>