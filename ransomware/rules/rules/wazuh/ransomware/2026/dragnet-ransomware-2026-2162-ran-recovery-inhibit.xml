<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2162 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: ee85dcc1-3e6d-59d1-9d0e-b8ab9a2b821b -->
  <rule id="814780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2162 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>