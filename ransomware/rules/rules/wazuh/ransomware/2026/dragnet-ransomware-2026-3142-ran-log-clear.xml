<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3142 — Event Log Clearing (thegentlemen) | Status: deprecated | Sigma ID: 0fc3b3bb-271b-561a-9a3d-42ad8e214c02 -->
  <rule id="260699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3142 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>