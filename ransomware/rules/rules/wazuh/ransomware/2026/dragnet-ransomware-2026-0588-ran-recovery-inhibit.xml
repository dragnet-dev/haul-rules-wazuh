<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0588 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: d4db8af3-1d70-5fe7-9e35-7ffc0be3c4aa -->
  <rule id="223818" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0588 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>