<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1649 — Event Log Clearing (dragonforce) | Status: stable | Sigma ID: 5f7fc3d4-5d77-5532-9c85-b05b1ad1164b -->
  <rule id="752443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1649 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>