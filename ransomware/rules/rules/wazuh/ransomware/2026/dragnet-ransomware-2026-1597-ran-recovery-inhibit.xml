<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1597 — Recovery Inhibition (qilin) | Status: test | Sigma ID: a60db9cd-5184-55ad-a33b-43d7878e015b -->
  <rule id="115799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1597 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
