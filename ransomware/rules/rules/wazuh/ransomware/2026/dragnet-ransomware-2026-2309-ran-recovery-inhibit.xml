<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2309 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: eb932a3b-961e-5836-9abd-7fb36af27777 -->
  <rule id="274922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2309 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>