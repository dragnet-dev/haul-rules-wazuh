<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0592 — Recovery Inhibition (AiLock) | Status: deprecated | Sigma ID: 60af2d20-80f1-58df-9073-30a8679b38ad -->
  <rule id="785645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0592 — Recovery Inhibition (AiLock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>