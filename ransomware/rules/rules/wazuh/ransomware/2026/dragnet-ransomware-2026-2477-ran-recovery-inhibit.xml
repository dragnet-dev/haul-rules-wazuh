<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2477 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 5a07d188-11e6-58b9-beaf-406a18acd4a0 -->
  <rule id="641251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2477 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>