<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2418 — Recovery Inhibition (everest) | Status: test | Sigma ID: 588738bc-6909-5250-b921-9dedc45c79a6 -->
  <rule id="519819" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2418 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>