<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0607 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: 48244271-e4ed-5ed4-aad2-948ff5f43a6b -->
  <rule id="424427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0607 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>