<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1477 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 3b378dbb-54c6-52d6-b157-13a617916e2a -->
  <rule id="900987" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1477 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>