<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2684 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 0066be36-a347-5097-b10b-4cd28ac9c988 -->
  <rule id="908636" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2684 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>