<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3223 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 86b5062b-861c-5b55-860a-bb498ad0a96b -->
  <rule id="587506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3223 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>