<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2756 — Recovery Inhibition (play) | Status: stable | Sigma ID: 67ddc425-b688-5ed9-a18c-66705a7e8e3f -->
  <rule id="179804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2756 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>