<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2207 — Recovery Inhibition (everest) | Status: test | Sigma ID: c2b71612-5b69-5b42-9ec2-ebb5e1d2f2bc -->
  <rule id="263716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2207 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>