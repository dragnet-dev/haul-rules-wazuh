<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2312 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: f4a39e4f-7106-56ab-a1f0-d3ca4df3ab95 -->
  <rule id="459038" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2312 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>