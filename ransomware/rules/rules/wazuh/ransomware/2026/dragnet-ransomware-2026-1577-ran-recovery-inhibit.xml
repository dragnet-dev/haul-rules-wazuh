<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1577 — Recovery Inhibition (play) | Status: stable | Sigma ID: 214334df-d9e4-51b2-bafe-c0fd14c1a109 -->
  <rule id="829357" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1577 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
