<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2907 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: b82d8542-d8b2-5473-8703-845edb36f952 -->
  <rule id="192585" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2907 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>