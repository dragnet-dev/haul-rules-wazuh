<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2555 — Recovery Inhibition (aurora) | Status: stable | Sigma ID: 218c6bb1-b76e-5fdf-8193-9fe254e25fe1 -->
  <rule id="961723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2555 — Recovery Inhibition (aurora)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>