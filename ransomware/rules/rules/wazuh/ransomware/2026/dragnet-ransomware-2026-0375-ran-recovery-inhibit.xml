<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0375 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: acc4b09c-e2d4-5d5a-8809-83499f56578d -->
  <rule id="923150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0375 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>