<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0518 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 871ad5bf-6e20-5466-ad7f-0fcb10855f65 -->
  <rule id="531495" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0518 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>