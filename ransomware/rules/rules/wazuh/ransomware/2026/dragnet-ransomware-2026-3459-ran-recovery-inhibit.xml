<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3459 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 7b213aea-f2be-5d5b-b7c1-3ee1acec1737 -->
  <rule id="271418" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3459 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>