<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0346 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 1bbd6657-adc8-5a9e-903f-6c2e2aec5e64 -->
  <rule id="901665" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0346 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>