<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0985 — Recovery Inhibition (play) | Status: stable | Sigma ID: 52d4962b-36ca-5b54-b97b-922d36c9e348 -->
  <rule id="454962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0985 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>