<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1705 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 1a578c26-4807-5c01-ab3b-acc8d7edd3fc -->
  <rule id="752602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1705 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>