<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1695 — Event Log Clearing (everest) | Status: stable | Sigma ID: 1ec194dc-4e2d-5ae3-bc71-bdf449bff1b5 -->
  <rule id="775117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1695 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>