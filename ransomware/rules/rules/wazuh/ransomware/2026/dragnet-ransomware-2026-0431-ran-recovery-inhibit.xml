<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0431 — Recovery Inhibition (titan) | Status: stable | Sigma ID: f42c3d63-d0e7-5ed7-ba72-8fb8c3e12b91 -->
  <rule id="449501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0431 — Recovery Inhibition (titan)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>