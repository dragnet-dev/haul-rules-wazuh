<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2101 — Recovery Inhibition (lynx) | Status: test | Sigma ID: add13829-2213-5ed8-bf44-50cfdd896536 -->
  <rule id="181138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2101 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>