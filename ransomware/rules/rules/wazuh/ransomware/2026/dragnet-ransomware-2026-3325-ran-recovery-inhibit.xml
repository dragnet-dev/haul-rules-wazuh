<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3325 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: d4a927f4-6b48-56cf-aaac-84e54ab9db84 -->
  <rule id="454927" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3325 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>