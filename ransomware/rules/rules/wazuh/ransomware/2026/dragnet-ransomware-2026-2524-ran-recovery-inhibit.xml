<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2524 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 67ad7b6d-ed12-5f4c-aa37-a0623caea36b -->
  <rule id="172123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2524 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>