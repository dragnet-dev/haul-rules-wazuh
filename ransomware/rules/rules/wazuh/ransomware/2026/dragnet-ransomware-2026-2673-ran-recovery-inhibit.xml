<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2673 — Recovery Inhibition (medusalocker) | Status: stable | Sigma ID: b6ccfecc-b4db-58e6-a00f-2ea5f0234aee -->
  <rule id="554654" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2673 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>