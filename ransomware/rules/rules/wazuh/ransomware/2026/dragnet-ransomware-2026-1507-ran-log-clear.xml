<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1507 — Event Log Clearing (ALP-001) | Status: stable | Sigma ID: 2fe3c738-dd15-503f-a739-ee3ac9039b68 -->
  <rule id="426207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1507 — Event Log Clearing (ALP-001)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>