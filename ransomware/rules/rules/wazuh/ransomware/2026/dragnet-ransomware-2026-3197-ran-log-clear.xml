<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3197 — Event Log Clearing (pear) | Status: stable | Sigma ID: ec5ad436-4a4d-5aaf-b26c-0e44e6fbbfc0 -->
  <rule id="756134" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3197 — Event Log Clearing (pear)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>