<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3383 — Recovery Inhibition (play) | Status: stable | Sigma ID: fba382cd-3899-527a-9927-b8167c578797 -->
  <rule id="526382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3383 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
