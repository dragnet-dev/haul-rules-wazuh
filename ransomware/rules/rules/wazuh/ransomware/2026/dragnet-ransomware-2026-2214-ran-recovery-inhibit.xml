<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2214 — Recovery Inhibition (medusalocker) | Status: stable | Sigma ID: 4472da21-84c2-54d7-b74d-e6b33a5789ef -->
  <rule id="345050" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2214 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>