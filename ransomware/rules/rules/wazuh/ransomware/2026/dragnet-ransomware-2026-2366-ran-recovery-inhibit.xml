<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2366 — Recovery Inhibition (everest) | Status: test | Sigma ID: ed379f53-9f49-58b6-9625-0e3a74ff2116 -->
  <rule id="298079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2366 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
