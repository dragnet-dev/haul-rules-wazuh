<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2776 — Recovery Inhibition (everest) | Status: stable | Sigma ID: 5670e6c5-9ab1-5972-a0e7-ce97e167024a -->
  <rule id="217548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2776 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>