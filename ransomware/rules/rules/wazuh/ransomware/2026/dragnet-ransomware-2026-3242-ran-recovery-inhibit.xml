<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3242 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 099be2aa-5f3b-5eef-91b6-bd8bce56c9cd -->
  <rule id="585482" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3242 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>