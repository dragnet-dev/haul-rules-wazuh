<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3482 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 5f12c2dc-5346-5998-b311-3decb629c187 -->
  <rule id="722042" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3482 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>