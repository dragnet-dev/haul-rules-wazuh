<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0957 — Recovery Inhibition (everest) | Status: stable | Sigma ID: 600a86c1-8c2a-5467-ac24-edc22d50ba61 -->
  <rule id="177388" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0957 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>