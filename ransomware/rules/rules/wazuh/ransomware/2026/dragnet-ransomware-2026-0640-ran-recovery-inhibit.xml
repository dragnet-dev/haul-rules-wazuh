<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0640 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: d9311ebc-12ce-570d-b7d5-bc2ce6b84b66 -->
  <rule id="528990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0640 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>