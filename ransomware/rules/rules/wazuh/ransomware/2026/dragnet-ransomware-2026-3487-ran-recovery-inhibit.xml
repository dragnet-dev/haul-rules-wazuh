<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3487 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 76d6e41b-2117-58ed-8665-f1334d195cdb -->
  <rule id="267504" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3487 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>