<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2240 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 7de5668b-882a-5c55-b03f-ca7bc6412553 -->
  <rule id="314566" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2240 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>