<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0169 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: f5d03ab0-387b-54b8-91ff-0cad3b72a0c5 -->
  <rule id="488858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0169 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>