<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1279 — Event Log Clearing (genesis) | Status: stable | Sigma ID: 1e5b3152-12e1-5d17-b0d7-776bfe035d7c -->
  <rule id="491315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1279 — Event Log Clearing (genesis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>