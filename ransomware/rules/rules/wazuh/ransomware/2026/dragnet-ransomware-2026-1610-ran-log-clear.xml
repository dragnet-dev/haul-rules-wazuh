<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1610 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: daa024c9-7b0d-5c3f-b0ad-05fd25746acb -->
  <rule id="898024" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1610 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>