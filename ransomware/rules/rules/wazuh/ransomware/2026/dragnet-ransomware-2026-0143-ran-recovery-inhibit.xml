<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0143 — Recovery Inhibition (medusa) | Status: test | Sigma ID: 455d267a-e9cb-50c5-a7cc-71e820497437 -->
  <rule id="193267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0143 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>