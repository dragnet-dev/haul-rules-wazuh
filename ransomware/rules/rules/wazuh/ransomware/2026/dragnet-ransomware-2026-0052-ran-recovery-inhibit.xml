<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0052 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 3049b2af-664e-5fe2-adcf-6f52f7bc377b -->
  <rule id="707242" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0052 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>