<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1764 — Event Log Clearing (embargo) | Status: stable | Sigma ID: 8b91831c-7f7f-5b0f-91e7-898ada2f7531 -->
  <rule id="599183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1764 — Event Log Clearing (embargo)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>