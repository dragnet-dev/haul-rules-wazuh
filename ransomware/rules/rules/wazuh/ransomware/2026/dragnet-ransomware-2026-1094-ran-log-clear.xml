<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1094 — Event Log Clearing (thegentlemen) | Status: test | Sigma ID: 81c8ac69-26e1-5c22-9f7f-a0bf60c014f7 -->
  <rule id="750700" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1094 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>