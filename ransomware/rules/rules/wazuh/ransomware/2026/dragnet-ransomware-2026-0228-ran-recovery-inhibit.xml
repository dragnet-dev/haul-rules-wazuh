<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0228 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 73ddcdd9-59eb-5bac-840d-023354f65677 -->
  <rule id="440909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0228 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>