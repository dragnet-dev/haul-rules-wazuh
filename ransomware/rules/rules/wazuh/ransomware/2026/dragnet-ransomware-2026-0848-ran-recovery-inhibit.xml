<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0848 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 89cf53af-008e-5fc3-bfe2-25e966850c50 -->
  <rule id="599153" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0848 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>