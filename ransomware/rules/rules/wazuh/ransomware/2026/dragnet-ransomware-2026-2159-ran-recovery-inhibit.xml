<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2159 — Recovery Inhibition (anubis) | Status: stable | Sigma ID: f2903ac0-5501-5049-bf50-e75944722234 -->
  <rule id="746458" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2159 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>