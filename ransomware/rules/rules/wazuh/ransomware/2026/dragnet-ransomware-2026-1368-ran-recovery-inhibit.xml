<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1368 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: 036ec3e8-efac-5bff-9838-efaecf361832 -->
  <rule id="712382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1368 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>