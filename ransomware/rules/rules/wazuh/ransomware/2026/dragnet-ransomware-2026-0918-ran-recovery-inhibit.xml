<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0918 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 48dec302-6607-53c7-9d35-509e37b92011 -->
  <rule id="301723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0918 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>