<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2759 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: c5a11fbb-9aac-59db-81d1-2d2c1534e430 -->
  <rule id="616191" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2759 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>