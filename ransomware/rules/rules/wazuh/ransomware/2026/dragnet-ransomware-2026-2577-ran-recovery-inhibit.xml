<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2577 — Recovery Inhibition (handala) | Status: stable | Sigma ID: cafe76f0-a07f-5148-bb43-758fad9ca0a5 -->
  <rule id="796676" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2577 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>