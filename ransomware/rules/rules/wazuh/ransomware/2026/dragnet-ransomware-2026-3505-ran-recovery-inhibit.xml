<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3505 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: fbac3251-3cb6-51b6-bfd9-9344b3928380 -->
  <rule id="242832" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3505 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>