<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0609 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: 5c04c2f2-e63a-52b2-83bc-085f547a847b -->
  <rule id="672762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0609 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>