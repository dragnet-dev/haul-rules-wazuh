<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0033 — Recovery Inhibition (lamashtu) | Status: stable | Sigma ID: 79a349e0-9edd-57a6-800f-56e7e7b832a1 -->
  <rule id="474349" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0033 — Recovery Inhibition (lamashtu)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>