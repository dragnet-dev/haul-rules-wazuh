<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0438 — Recovery Inhibition (anubis) | Status: test | Sigma ID: 97f28885-5636-54e8-b095-59c74b42d7e8 -->
  <rule id="767288" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0438 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
