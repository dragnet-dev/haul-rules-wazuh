<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1277 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: e3dc6090-c633-5c60-bb17-b6d96e292c96 -->
  <rule id="182860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1277 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>