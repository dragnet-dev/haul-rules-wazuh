<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2588 — Event Log Clearing (linkc) | Status: test | Sigma ID: 39ea2a61-db3f-5f25-b6d8-28187966253f -->
  <rule id="834922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2588 — Event Log Clearing (linkc)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>