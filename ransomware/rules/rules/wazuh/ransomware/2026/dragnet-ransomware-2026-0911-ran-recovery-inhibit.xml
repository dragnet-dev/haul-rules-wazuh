<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0911 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 89675358-4222-5ec9-8dad-fce4cc499a5b -->
  <rule id="967535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0911 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>