<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0184 — Recovery Inhibition (anubis) | Status: stable | Sigma ID: a31dd27c-d301-559b-9769-cdb4a02e0bf2 -->
  <rule id="941572" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0184 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>