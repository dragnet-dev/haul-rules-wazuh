<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2480 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 039f8458-6ea5-5cca-98c8-6e9f62f7bf77 -->
  <rule id="198458" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2480 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>