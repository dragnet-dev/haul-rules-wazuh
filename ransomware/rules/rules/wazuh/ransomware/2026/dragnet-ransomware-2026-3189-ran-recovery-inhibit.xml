<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3189 — Recovery Inhibition (rhysida) | Status: test | Sigma ID: 98d15c65-2d32-50b4-a587-75394172b86a -->
  <rule id="829852" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3189 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>