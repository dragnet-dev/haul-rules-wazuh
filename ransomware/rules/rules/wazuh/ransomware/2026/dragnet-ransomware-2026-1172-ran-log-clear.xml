<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1172 — Event Log Clearing (thegentlemen) | Status: stable | Sigma ID: 7b87ab70-ed07-5c73-9ac6-3eae8f2faef4 -->
  <rule id="571243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1172 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>