<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0724 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 80a91306-d434-55e0-8031-3254e2ee452a -->
  <rule id="490913" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0724 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>