<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2754 — Event Log Clearing (embargo) | Status: stable | Sigma ID: 71e0dcfa-093c-5e0a-ae25-57147b73d56b -->
  <rule id="344220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2754 — Event Log Clearing (embargo)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>