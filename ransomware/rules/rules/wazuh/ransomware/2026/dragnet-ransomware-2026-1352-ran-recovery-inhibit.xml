<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1352 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 574dc27a-5fdf-5c9c-9a86-5d0b3ca892d8 -->
  <rule id="671642" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1352 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>