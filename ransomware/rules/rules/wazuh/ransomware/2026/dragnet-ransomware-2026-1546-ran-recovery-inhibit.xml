<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1546 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 83b46c39-aca4-5e5f-871e-92b5349e2324 -->
  <rule id="443148" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1546 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>