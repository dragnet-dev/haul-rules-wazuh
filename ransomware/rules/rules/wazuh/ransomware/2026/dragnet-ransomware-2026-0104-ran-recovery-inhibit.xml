<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0104 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: d0044fa9-1238-5f80-8029-ebbf57175107 -->
  <rule id="380719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0104 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>