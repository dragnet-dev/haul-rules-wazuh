<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3234 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: b6f6ce47-ddae-5117-a13c-c6ba35f1b2e2 -->
  <rule id="391502" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3234 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>