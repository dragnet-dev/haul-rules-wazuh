<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1656 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: d7499b0e-3ed4-5029-aead-872bb47d7323 -->
  <rule id="499995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1656 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>