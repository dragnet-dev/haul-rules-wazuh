<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1828 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: 1bede53d-4616-57d9-ad08-a92644824866 -->
  <rule id="343985" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1828 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>