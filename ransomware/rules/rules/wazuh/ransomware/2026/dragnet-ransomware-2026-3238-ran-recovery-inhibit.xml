<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3238 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: ec4c8c6e-de69-5c6c-8f43-36972bb74fe1 -->
  <rule id="753900" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3238 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>