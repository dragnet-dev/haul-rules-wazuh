<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2187 — Recovery Inhibition (payload) | Status: stable | Sigma ID: 35193b7b-c819-5596-8f6c-f97d0635049b -->
  <rule id="330997" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2187 — Recovery Inhibition (payload)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
