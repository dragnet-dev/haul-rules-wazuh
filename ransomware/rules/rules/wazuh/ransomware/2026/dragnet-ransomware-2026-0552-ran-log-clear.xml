<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0552 — Event Log Clearing (lapsus$) | Status: deprecated | Sigma ID: 0a4e03e3-c896-58a6-92ad-b82e39fbf524 -->
  <rule id="984862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0552 — Event Log Clearing (lapsus$)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>