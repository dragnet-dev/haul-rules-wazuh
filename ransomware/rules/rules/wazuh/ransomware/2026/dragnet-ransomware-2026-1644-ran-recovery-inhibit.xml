<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1644 — Recovery Inhibition (anubis) | Status: stable | Sigma ID: 73f75742-9ec2-500f-99f0-a1397097cd57 -->
  <rule id="383757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1644 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>