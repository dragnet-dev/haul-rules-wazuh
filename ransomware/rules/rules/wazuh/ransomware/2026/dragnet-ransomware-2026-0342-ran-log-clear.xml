<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0342 — Event Log Clearing (shinyhunters) | Status: deprecated | Sigma ID: 3498da52-0b33-5530-a6a2-b1efb5f1a66c -->
  <rule id="957065" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0342 — Event Log Clearing (shinyhunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>