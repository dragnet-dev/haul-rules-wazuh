<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0947 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: fb92cbe3-c838-56c3-93a5-eb9c5cf9d5be -->
  <rule id="249355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0947 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>