<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3429 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 7f40248f-1572-5f72-a89c-3ae396b2f269 -->
  <rule id="474024" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3429 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>