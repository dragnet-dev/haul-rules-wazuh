<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0633 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: ea25167a-3d7c-561a-bd04-1183f7918edb -->
  <rule id="642516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0633 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>