<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0257 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 44c3505d-05bb-5e9c-ac18-62cfa2f5b6ab -->
  <rule id="963505" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0257 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>