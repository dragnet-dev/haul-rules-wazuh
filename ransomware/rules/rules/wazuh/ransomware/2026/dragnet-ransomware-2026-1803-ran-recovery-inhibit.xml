<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1803 — Recovery Inhibition (lynx) | Status: stable | Sigma ID: ff59bf77-60be-5939-8728-891bd90ff635 -->
  <rule id="343295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1803 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>