<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2060 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: a28d2def-fcfc-584e-9cc7-3be058cf6713 -->
  <rule id="933805" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2060 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>