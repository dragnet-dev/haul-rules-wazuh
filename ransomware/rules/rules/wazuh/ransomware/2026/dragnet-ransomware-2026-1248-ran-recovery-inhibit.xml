<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1248 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 732c33b2-d6c6-5081-adf1-93203036de2c -->
  <rule id="372433" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1248 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>