<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1712 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 8ecac1de-3bb6-562f-842a-d90034f0e681 -->
  <rule id="548761" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1712 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>