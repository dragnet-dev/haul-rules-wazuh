<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2738 — Recovery Inhibition (lynx) | Status: test | Sigma ID: 348aa34d-be18-5c19-bf86-32ddad5f6fa2 -->
  <rule id="925834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2738 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>