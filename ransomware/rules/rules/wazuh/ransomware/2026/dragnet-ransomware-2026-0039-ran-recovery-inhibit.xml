<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0039 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 70d39127-261b-5341-96d0-2c59c52e5161 -->
  <rule id="333391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0039 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>