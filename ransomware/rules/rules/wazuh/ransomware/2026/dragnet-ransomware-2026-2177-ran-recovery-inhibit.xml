<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2177 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 1dbdcaa9-ae20-5572-a635-5f85ddeb3b3a -->
  <rule id="249130" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2177 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>