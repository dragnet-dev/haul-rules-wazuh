<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2328 — Recovery Inhibition (qilin) | Status: test | Sigma ID: ac7822f7-1a56-53ba-b46e-6a92157d0af5 -->
  <rule id="927822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2328 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>