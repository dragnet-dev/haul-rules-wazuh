<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3181 — Recovery Inhibition (handala) | Status: stable | Sigma ID: d63dd2fc-7e02-5ab4-befd-581052b42ebb -->
  <rule id="891492" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3181 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>