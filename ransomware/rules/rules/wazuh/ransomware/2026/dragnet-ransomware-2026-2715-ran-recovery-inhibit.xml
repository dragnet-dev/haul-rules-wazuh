<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2715 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: fd79ae24-4ab5-56ca-98f7-cb57fc0f1ccf -->
  <rule id="297198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2715 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>