<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0002 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 03b426d1-95b3-507d-9ccf-d98f460f30ab -->
  <rule id="608291" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0002 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>