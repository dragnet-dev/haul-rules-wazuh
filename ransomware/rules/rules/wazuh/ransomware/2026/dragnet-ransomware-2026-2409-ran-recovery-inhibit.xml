<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2409 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 900d3007-8ea3-5030-824f-f99fde080ba1 -->
  <rule id="641330" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2409 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>