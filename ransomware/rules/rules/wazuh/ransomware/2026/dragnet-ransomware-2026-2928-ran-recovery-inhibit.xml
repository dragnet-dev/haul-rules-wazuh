<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2928 — Recovery Inhibition (termite) | Status: stable | Sigma ID: e1be8814-b45c-5df0-b983-693434c1462a -->
  <rule id="128688" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2928 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>