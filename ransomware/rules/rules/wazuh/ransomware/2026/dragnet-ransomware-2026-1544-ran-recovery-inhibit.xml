<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1544 — Recovery Inhibition (fulcrumsec) | Status: stable | Sigma ID: c67220d1-5349-5575-82b7-68d9838517d6 -->
  <rule id="467220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1544 — Recovery Inhibition (fulcrumsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>