<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3087 — Event Log Clearing (worldleaks) | Status: stable | Sigma ID: 8b03119d-6d32-5f96-bb07-5a9c1fa66a7b -->
  <rule id="590311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3087 — Event Log Clearing (worldleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>