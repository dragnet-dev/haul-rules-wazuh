<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3128 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: d1f9a93b-b6d5-59e5-ba48-636cf4854f86 -->
  <rule id="779149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3128 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>