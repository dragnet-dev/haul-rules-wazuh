<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2509 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 106c7a9f-9d7f-5c5b-b8df-02de9420e4ca -->
  <rule id="134029" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2509 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>