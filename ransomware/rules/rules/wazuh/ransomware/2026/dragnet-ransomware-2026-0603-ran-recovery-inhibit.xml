<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0603 — Recovery Inhibition (qilin) | Status: test | Sigma ID: fa62e509-522f-5c72-b71c-94278ac5990e -->
  <rule id="510065" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0603 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>