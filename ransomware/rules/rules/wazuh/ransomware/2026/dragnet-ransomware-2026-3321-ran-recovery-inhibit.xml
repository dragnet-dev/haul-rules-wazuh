<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3321 — Recovery Inhibition (clop) | Status: test | Sigma ID: 18e03e50-29c9-5168-aaea-90802ab11da5 -->
  <rule id="432625" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3321 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>