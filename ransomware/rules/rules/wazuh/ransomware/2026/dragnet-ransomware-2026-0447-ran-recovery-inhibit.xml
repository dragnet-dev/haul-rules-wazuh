<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0447 — Recovery Inhibition (play) | Status: stable | Sigma ID: bb4c3b0d-11ba-58f7-bcc8-28e63a11647e -->
  <rule id="399419" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0447 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>