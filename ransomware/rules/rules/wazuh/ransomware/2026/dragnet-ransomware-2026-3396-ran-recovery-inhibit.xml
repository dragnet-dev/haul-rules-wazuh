<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3396 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: b259502a-8acf-5445-aea7-a63af149d976 -->
  <rule id="325950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3396 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>