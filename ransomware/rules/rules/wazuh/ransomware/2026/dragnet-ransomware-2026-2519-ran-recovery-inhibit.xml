<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2519 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 5f9a6031-aa47-5cc5-a054-d3599e5f7e78 -->
  <rule id="735460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2519 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>