<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2215 — Recovery Inhibition (blackwater) | Status: stable | Sigma ID: bb3f8e09-46d6-5413-af0a-5901e4d80a20 -->
  <rule id="397422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2215 — Recovery Inhibition (blackwater)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>