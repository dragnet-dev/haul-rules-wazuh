<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0046 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: a2358960-c964-5533-8fe4-a440f913ec32 -->
  <rule id="223589" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0046 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>