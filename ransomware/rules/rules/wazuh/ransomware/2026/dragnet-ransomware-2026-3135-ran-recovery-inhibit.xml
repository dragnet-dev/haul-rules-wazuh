<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3135 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 188d4fac-9d6f-5589-ba33-6813f3ffa323 -->
  <rule id="635034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3135 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>