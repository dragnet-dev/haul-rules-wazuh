<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3225 — Event Log Clearing (cipherforce) | Status: stable | Sigma ID: 2802c9b7-eda9-5b74-baa5-02ebf5e0ac62 -->
  <rule id="975195" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3225 — Event Log Clearing (cipherforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>