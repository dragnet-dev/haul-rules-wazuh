<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1881 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 96821e44-ff97-5719-b6ad-d928dd0e2320 -->
  <rule id="749150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1881 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>