<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1585 — Recovery Inhibition (aurora) | Status: stable | Sigma ID: 83f07466-1b28-5d08-a5c8-12846427c9ba -->
  <rule id="543074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1585 — Recovery Inhibition (aurora)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>