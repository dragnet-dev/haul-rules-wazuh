<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1237 — Recovery Inhibition (netrunner) | Status: stable | Sigma ID: aa95c698-7c73-5c91-8c6e-b08f79577544 -->
  <rule id="135326" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1237 — Recovery Inhibition (netrunner)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>