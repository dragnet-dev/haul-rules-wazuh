<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3166 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 635a33b8-5a1d-5f16-8fed-d7679eec388e -->
  <rule id="217033" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3166 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>