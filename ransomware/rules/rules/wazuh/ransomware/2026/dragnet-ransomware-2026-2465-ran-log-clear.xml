<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2465 — Event Log Clearing (lockbit5) | Status: stable | Sigma ID: c5d01f8a-21af-5e0b-aa6f-d57a8c7aaf32 -->
  <rule id="620831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2465 — Event Log Clearing (lockbit5)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>