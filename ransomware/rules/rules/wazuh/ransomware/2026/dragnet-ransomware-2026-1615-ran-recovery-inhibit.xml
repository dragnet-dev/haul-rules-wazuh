<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1615 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 96336762-55b8-5948-a449-fb09a7a7d9e6 -->
  <rule id="733676" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1615 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>