<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1663 — Event Log Clearing (tridentlocker) | Status: test | Sigma ID: 44bce0c8-0282-590c-8c50-1a594c057fa9 -->
  <rule id="132460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1663 — Event Log Clearing (tridentlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>