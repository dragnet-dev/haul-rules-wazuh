<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2041 — Recovery Inhibition (incransom) | Status: test | Sigma ID: 518527fa-2079-5746-878f-16ef5fd3bf34 -->
  <rule id="296447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2041 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
