<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2130 — Recovery Inhibition (pear) | Status: test | Sigma ID: 375a958e-bd75-5e37-bf1d-6bdae74ae865 -->
  <rule id="710958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2130 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>