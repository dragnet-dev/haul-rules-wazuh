<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3186 — Recovery Inhibition (handala) | Status: stable | Sigma ID: abfbce25-adc6-5b1e-97ed-6ab6f7878bc2 -->
  <rule id="571118" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3186 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>