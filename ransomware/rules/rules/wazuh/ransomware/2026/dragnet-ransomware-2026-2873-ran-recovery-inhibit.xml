<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2873 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 4b36eaa5-6b35-5774-901c-af330a18e9a4 -->
  <rule id="229450" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2873 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>