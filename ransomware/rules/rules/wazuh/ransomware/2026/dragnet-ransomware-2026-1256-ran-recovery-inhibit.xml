<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1256 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 868bcfe5-c773-5d22-99b5-0897488318a0 -->
  <rule id="958351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1256 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>