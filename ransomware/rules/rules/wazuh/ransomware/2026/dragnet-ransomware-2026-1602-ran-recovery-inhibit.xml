<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1602 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 8b8cdff1-29c9-5006-803a-176b51be226f -->
  <rule id="429503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1602 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>