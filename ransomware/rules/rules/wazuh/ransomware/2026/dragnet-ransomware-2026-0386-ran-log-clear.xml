<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0386 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: a3be8dfd-44e8-59b6-8f30-33d94e1ae428 -->
  <rule id="749421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0386 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>