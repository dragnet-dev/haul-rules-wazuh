<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3022 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 2b5839ae-be8b-53d2-b91b-25d1f5b3302f -->
  <rule id="773434" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3022 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>