<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2016 — Recovery Inhibition (safepay) | Status: stable | Sigma ID: d5a35405-9c6c-55b3-ad65-a7afc922d87b -->
  <rule id="470354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2016 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>