<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0482 — Recovery Inhibition (m3rx) | Status: stable | Sigma ID: 03a6a4da-4b05-5d3d-be5f-c3e67f9dd431 -->
  <rule id="701837" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0482 — Recovery Inhibition (m3rx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>