<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2613 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 8ff457fa-c153-5d4a-aee2-3400830e7a8b -->
  <rule id="603457" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2613 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>