<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2156 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 7e4be2c7-b999-5547-a3a9-f25fc4a580c1 -->
  <rule id="637742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2156 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>