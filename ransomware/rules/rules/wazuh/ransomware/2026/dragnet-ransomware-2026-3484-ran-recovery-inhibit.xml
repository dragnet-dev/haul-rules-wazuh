<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3484 — Recovery Inhibition (blackwater) | Status: stable | Sigma ID: eeea85dd-cab1-5a6a-8802-8c58f979411c -->
  <rule id="816285" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3484 — Recovery Inhibition (blackwater)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>