<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2533 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: a78bad95-c32a-5c64-83e4-08349d900a23 -->
  <rule id="918477" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2533 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>