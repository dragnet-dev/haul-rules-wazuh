<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1699 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: b966ca3a-c896-5654-a2ae-218950f03211 -->
  <rule id="463498" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1699 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>