<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1679 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: eeee5a2b-5513-519b-a6b2-b490cb2a1438 -->
  <rule id="886650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1679 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>