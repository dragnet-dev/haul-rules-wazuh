<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1839 — Recovery Inhibition (play) | Status: stable | Sigma ID: 66a50ebe-f4a1-5187-af7f-6d55b33b7303 -->
  <rule id="906414" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1839 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
