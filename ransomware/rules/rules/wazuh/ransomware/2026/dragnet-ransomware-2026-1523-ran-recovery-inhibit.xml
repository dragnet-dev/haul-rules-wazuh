<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1523 — Recovery Inhibition (threeam) | Status: stable | Sigma ID: 45b77bae-eec9-556b-a574-7c032c506ae6 -->
  <rule id="370843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1523 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>