<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2678 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: b72aa8ed-b08f-5e6a-b196-46a86dc8b3bf -->
  <rule id="402028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2678 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>