<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0580 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 886409f9-ba3f-54b9-9b72-cc97791125bc -->
  <rule id="782559" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0580 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>