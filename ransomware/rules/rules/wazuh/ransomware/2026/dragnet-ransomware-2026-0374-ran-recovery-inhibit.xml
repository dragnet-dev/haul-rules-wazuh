<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0374 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: 2dd5acca-b155-577d-8088-77806e3385cf -->
  <rule id="177932" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0374 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>