<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0293 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: a6f89053-91d6-504e-8c08-a7179e90b2b7 -->
  <rule id="911890" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0293 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>