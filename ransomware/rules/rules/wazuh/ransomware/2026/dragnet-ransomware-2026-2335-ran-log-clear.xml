<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2335 — Event Log Clearing (aurora) | Status: stable | Sigma ID: 00385b49-e878-5399-9c8d-8583c0ea8b5a -->
  <rule id="974398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2335 — Event Log Clearing (aurora)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>