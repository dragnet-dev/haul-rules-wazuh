<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3204 — Recovery Inhibition (insomnia) | Status: test | Sigma ID: 1001bcfe-de44-5955-9787-bbe21d0f7aa4 -->
  <rule id="603119" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3204 — Recovery Inhibition (insomnia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
