<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0829 — Event Log Clearing (interlock) | Status: test | Sigma ID: 73696e9f-d1fb-5cb2-bc72-c0854952c06a -->
  <rule id="379150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0829 — Event Log Clearing (interlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>