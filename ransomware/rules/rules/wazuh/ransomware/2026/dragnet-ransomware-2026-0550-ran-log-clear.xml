<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0550 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 2bdb417d-4c20-5a8b-a47f-ad0f1f851632 -->
  <rule id="322741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0550 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>