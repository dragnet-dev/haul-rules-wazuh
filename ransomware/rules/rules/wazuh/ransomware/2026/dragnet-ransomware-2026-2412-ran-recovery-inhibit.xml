<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2412 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: be0a4b42-93aa-5004-9e40-d95916f8b480 -->
  <rule id="465675" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2412 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>