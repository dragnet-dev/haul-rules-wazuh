<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0497 — Recovery Inhibition (sinobi) | Status: stable | Sigma ID: cb61d49a-e448-56e6-8c0a-58ef850ed504 -->
  <rule id="657894" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0497 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
