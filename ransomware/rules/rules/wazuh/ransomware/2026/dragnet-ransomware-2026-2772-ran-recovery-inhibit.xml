<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2772 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 3538a65c-fa9f-50dd-b697-4fc748ac3744 -->
  <rule id="361865" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2772 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>