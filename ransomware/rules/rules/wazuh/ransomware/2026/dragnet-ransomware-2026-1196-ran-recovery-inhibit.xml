<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1196 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: d744b56a-db20-5b54-be3f-7ad69e7bc3f2 -->
  <rule id="499155" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1196 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>