<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0667 — Event Log Clearing (sicarii) | Status: deprecated | Sigma ID: 434c0831-88d0-52c0-b028-13ea74465e3d -->
  <rule id="756083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0667 — Event Log Clearing (sicarii)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>