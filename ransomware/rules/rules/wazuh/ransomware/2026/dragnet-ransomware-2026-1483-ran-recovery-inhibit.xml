<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1483 — Recovery Inhibition (cipherforce) | Status: stable | Sigma ID: e0da69bc-a3a1-5b73-9581-5a7da4c103ac -->
  <rule id="105869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1483 — Recovery Inhibition (cipherforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>