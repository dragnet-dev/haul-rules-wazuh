<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1146 — Recovery Inhibition (thegentlemen) | Status: stable | Sigma ID: 6062741c-34e1-5609-80a7-e8bd3f09ce70 -->
  <rule id="762741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1146 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
