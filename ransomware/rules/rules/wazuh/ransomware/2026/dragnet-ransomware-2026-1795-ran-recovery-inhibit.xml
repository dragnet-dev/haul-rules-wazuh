<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1795 — Recovery Inhibition (netrunner) | Status: stable | Sigma ID: 9adaa555-e375-5cb9-a2db-0126a8ea20d2 -->
  <rule id="142825" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1795 — Recovery Inhibition (netrunner)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>