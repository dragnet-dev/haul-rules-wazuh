<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2291 — Recovery Inhibition (everest) | Status: test | Sigma ID: 063750f3-57dd-51eb-867b-52a48728a344 -->
  <rule id="220015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2291 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>