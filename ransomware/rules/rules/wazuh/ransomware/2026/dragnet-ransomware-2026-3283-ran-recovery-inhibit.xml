<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3283 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 27e1b756-a632-5278-aaae-6306ec0f3b3c -->
  <rule id="938775" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3283 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>