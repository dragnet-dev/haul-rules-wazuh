<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1096 — Event Log Clearing (thegentlemen) | Status: test | Sigma ID: 1a5403f0-b1e7-50b8-b83f-0c61ce86922e -->
  <rule id="746463" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1096 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>