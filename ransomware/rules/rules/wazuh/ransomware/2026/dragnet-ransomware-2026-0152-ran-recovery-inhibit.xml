<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0152 — Recovery Inhibition (handala) | Status: stable | Sigma ID: dca9745a-fec9-5a26-9a65-d77226b9b962 -->
  <rule id="930974" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0152 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>