<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0736 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 78a5812e-eb2e-583b-b9f1-d759270ea2ee -->
  <rule id="458581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0736 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>