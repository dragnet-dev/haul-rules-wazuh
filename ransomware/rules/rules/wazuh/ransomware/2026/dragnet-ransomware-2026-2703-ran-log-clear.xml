<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2703 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: e9cbd3ac-dbf4-5038-8561-c08ddc79a310 -->
  <rule id="835653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2703 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>