<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0140 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 15e7c577-8764-5673-8d06-bab213a5fb8a -->
  <rule id="576457" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0140 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>