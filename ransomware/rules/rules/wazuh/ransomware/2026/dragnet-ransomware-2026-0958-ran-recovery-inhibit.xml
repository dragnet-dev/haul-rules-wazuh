<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0958 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: ce06e6d4-7384-5da6-a6c5-04241c0fe600 -->
  <rule id="697106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0958 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>