<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0850 — Event Log Clearing (LeakBazaar) | Status: stable | Sigma ID: 6e8cddd2-c0ce-5ae2-9dc6-8e80a6879b43 -->
  <rule id="141661" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0850 — Event Log Clearing (LeakBazaar)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>