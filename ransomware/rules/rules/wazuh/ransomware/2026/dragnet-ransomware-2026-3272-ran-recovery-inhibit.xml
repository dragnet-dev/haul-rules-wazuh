<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3272 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 4b1fb67b-7044-5dfa-9d8d-268c1d9558cd -->
  <rule id="225076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3272 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>