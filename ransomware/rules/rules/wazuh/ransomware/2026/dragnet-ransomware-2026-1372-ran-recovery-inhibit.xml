<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1372 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 3ca9dada-1303-54bc-a3aa-3dcd1f8d3e69 -->
  <rule id="785722" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1372 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>