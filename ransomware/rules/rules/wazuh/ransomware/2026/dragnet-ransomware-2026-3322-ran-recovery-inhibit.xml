<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3322 — Recovery Inhibition (dragonforce) | Status: test | Sigma ID: 52a89ae5-4f69-5334-8341-3d28902348f7 -->
  <rule id="548634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3322 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>