<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0892 — Recovery Inhibition (termite) | Status: stable | Sigma ID: a424d32f-afa5-509b-bea7-7aeac83fa439 -->
  <rule id="867973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0892 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>