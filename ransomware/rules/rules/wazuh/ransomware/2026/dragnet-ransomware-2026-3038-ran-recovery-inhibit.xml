<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3038 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 11ea5c35-787d-5e98-aea2-3d1966996530 -->
  <rule id="480923" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3038 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>