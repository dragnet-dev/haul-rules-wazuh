<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1322 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: c4aefb4b-69f8-58d6-941e-8f2c888fff85 -->
  <rule id="171259" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1322 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>