<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0495 — Recovery Inhibition (lynx) | Status: test | Sigma ID: 5695462f-7246-5a23-926d-4c6312e6240d -->
  <rule id="395462" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0495 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>