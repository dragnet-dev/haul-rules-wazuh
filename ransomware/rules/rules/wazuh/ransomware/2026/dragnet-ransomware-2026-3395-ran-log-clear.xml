<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3395 — Event Log Clearing (medusalocker) | Status: stable | Sigma ID: 4475be6f-7218-52ed-9576-b0676142a5b1 -->
  <rule id="345790" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3395 — Event Log Clearing (medusalocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>