<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0999 — Event Log Clearing (shinyhunters) | Status: deprecated | Sigma ID: a71e3557-551f-5b02-bdc1-6f4c2949ab33 -->
  <rule id="915035" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0999 — Event Log Clearing (shinyhunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>