<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3373 — Event Log Clearing (payload) | Status: stable | Sigma ID: b3f005db-60a7-51d9-9077-4b5b0f324770 -->
  <rule id="123005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3373 — Event Log Clearing (payload)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>