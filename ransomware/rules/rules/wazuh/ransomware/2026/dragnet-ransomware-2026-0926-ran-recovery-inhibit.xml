<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0926 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: fc1f4c70-71ec-5aaf-9788-a27366571bb1 -->
  <rule id="256236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0926 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>