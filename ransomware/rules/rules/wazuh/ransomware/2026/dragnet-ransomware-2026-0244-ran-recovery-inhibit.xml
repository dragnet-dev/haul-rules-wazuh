<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0244 — Recovery Inhibition (spacebears) | Status: test | Sigma ID: ae96fafc-8f98-5fcc-8cd3-3005c61701e6 -->
  <rule id="979226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0244 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>