<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1425 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 82f351fd-0e21-537f-9355-59c9283a4ada -->
  <rule id="527351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1425 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>