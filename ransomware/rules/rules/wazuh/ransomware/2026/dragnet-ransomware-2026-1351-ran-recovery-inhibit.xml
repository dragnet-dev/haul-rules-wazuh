<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1351 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: f0f16af9-a559-57ae-a019-92dff7c49017 -->
  <rule id="364266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1351 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>