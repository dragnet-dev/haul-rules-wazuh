<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0742 — Event Log Clearing (BrainCipher) | Status: stable | Sigma ID: 54bf66cc-7e18-5e37-9291-0f6e3139ffb2 -->
  <rule id="601566" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0742 — Event Log Clearing (BrainCipher)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>