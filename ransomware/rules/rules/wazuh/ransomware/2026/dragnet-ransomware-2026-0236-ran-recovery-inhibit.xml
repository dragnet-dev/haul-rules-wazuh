<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0236 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 0f485596-cda4-57e8-8921-a1351bb4a738 -->
  <rule id="748559" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0236 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>