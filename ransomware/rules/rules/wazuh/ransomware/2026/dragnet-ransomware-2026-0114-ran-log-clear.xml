<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0114 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: fdc53ff9-77a7-5f1e-a0ba-099aa32bb0c2 -->
  <rule id="296863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0114 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>