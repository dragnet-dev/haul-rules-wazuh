<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1319 — Event Log Clearing (worldleaks) | Status: stable | Sigma ID: 40fb9984-ab52-5da0-b03c-77c0ec3f1f64 -->
  <rule id="249199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1319 — Event Log Clearing (worldleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>