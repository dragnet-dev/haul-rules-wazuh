<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0792 — Recovery Inhibition (gunra) | Status: stable | Sigma ID: fc9feaa4-ab64-57ed-8cee-bae280ecfe2b -->
  <rule id="562858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0792 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>