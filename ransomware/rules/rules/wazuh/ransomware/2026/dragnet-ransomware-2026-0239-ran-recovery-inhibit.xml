<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0239 — Recovery Inhibition (aurora) | Status: stable | Sigma ID: 2b487d80-cdf4-50fe-83f5-ca9bfbece589 -->
  <rule id="758058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0239 — Recovery Inhibition (aurora)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>