<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1332 — Event Log Clearing (incransom) | Status: stable | Sigma ID: 9411b44e-8f41-51c0-a443-ba7745fde896 -->
  <rule id="705874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1332 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>