<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0448 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 97f638f2-481e-5570-b944-d31000a94f9e -->
  <rule id="767638" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0448 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>