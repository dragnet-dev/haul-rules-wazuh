<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0427 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 3921a968-97cb-57f2-80e5-69b4d93c7958 -->
  <rule id="974696" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0427 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>