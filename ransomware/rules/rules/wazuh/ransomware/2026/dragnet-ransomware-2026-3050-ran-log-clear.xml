<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3050 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 72e3c18b-ed7c-5d75-b1ed-dbccb3d9dc87 -->
  <rule id="166201" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3050 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>