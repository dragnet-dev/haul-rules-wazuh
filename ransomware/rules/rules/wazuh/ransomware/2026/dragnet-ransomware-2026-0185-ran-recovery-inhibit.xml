<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0185 — Recovery Inhibition (spacebears) | Status: test | Sigma ID: 0909fe24-d7d9-5c61-bd06-93adb1220e37 -->
  <rule id="629582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0185 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>