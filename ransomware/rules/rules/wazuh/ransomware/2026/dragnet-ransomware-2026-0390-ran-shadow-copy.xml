<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0390 — Shadow Copy Deletion (SilentRansomGroup) | Status: deprecated | Sigma ID: 70b4b351-b4e6-54e4-b24e-1f61a07029fc -->
  <rule id="110353" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0390 — Shadow Copy Deletion (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>