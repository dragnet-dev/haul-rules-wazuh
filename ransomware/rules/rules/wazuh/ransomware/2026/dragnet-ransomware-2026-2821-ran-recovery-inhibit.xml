<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2821 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: c2c9407c-baa8-52e6-8497-61cad0491aa9 -->
  <rule id="264940" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2821 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>