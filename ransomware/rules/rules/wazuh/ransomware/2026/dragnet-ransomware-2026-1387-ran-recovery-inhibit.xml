<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1387 — Recovery Inhibition (beast) | Status: stable | Sigma ID: be2203d1-a205-541c-a0f0-5ce796b6be3c -->
  <rule id="202203" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1387 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>