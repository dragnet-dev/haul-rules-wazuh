<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3534 — Recovery Inhibition (krybit) | Status: stable | Sigma ID: ef4f8e40-32b2-5386-aab4-245b1a9dcf2b -->
  <rule id="831182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3534 — Recovery Inhibition (krybit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>