<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1556 — Event Log Clearing (insomnia) | Status: stable | Sigma ID: ffd424b3-b793-5b44-8eb1-ab02a9fc1bc3 -->
  <rule id="593424" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1556 — Event Log Clearing (insomnia)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>