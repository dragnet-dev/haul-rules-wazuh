<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0813 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 4fde4769-527b-579c-ae7d-c51e5ee61d39 -->
  <rule id="344647" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0813 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>