<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2144 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 69a0031b-038b-5ab4-8493-94b7df9e2e76 -->
  <rule id="314003" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2144 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>