<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3342 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 12be691d-0258-523b-92f8-a4850ab6efc7 -->
  <rule id="662691" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3342 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>