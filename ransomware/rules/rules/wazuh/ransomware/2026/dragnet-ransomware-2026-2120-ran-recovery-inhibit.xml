<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2120 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 024c745f-5418-5c72-a8ad-e72b7409adcb -->
  <rule id="147935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2120 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>