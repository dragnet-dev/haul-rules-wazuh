<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3354 — Recovery Inhibition (anubis) | Status: stable | Sigma ID: aa151eb1-65d4-5dee-b545-2be19caeaa54 -->
  <rule id="122430" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3354 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>