<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2671 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 55da05c4-b92d-5924-b7b2-6d9357294380 -->
  <rule id="629805" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2671 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>