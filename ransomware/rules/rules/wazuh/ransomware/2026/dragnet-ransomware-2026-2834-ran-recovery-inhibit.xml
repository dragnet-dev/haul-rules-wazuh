<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2834 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 6fd71ea3-4ad2-5fef-8eca-3e05f759c8f4 -->
  <rule id="263550" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2834 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>