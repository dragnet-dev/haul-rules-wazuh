<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0178 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 848048a7-1316-5636-a984-1cc48f8dff0a -->
  <rule id="168778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0178 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>