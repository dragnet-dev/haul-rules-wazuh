<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2415 — Recovery Inhibition (play) | Status: stable | Sigma ID: 75e0e03d-4e1d-5b7e-b248-bfe90eaa015c -->
  <rule id="242540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2415 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>