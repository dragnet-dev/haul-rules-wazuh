<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0266 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: bb2f99ff-5e4a-5d0e-9eda-53b7edb4889c -->
  <rule id="396799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0266 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>