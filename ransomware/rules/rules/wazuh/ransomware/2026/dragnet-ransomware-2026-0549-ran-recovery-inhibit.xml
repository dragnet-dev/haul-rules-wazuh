<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0549 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: ed987ce4-85b2-5413-a93e-78c784f7d22a -->
  <rule id="307804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0549 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>