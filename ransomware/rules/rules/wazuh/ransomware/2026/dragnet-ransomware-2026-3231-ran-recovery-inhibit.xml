<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3231 — Recovery Inhibition (anubis) | Status: stable | Sigma ID: 0e60cfd0-d9ff-5ba5-8e10-b5fed86171ab -->
  <rule id="683485" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3231 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>