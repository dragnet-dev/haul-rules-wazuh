<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2558 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: d0b0f240-531c-5ec6-bafa-2b80788958fd -->
  <rule id="745752" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2558 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>