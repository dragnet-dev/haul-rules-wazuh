<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0784 — Recovery Inhibition (everest) | Status: stable | Sigma ID: fdc1e817-21eb-5a30-b23d-b357e725a288 -->
  <rule id="296308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0784 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>