<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0217 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: 226ab348-a418-596c-815d-dd3bf78fcd7e -->
  <rule id="502734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0217 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
