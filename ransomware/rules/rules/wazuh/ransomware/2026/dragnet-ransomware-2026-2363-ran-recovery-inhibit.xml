<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2363 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 19e84ab2-50b4-5262-b120-91739195bfef -->
  <rule id="162475" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2363 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>