<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2644 — Recovery Inhibition (m3rx) | Status: stable | Sigma ID: 6aa8034e-6991-5b74-a028-3d255c4347ac -->
  <rule id="906803" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2644 — Recovery Inhibition (m3rx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>