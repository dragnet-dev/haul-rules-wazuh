<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2119 — Recovery Inhibition (spacebears) | Status: stable | Sigma ID: a052fb05-4cdb-52ff-8530-bb217b5a53f9 -->
  <rule id="873563" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2119 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>