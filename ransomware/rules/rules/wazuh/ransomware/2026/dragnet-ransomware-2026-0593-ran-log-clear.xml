<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0593 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 02ebc5d6-3aa4-5cbc-b0ca-3e8b74e8a5e6 -->
  <rule id="214333" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0593 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>