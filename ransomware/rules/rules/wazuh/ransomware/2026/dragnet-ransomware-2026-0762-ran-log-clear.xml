<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0762 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: 4a6491c7-998c-5a6a-9aae-43825a7d2161 -->
  <rule id="343868" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0762 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>