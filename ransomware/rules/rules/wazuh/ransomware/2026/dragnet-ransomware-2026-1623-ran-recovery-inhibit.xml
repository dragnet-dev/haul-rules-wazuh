<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1623 — Recovery Inhibition (threeam) | Status: stable | Sigma ID: 9e03b563-76a8-5b04-a6e2-2e030c5a42b6 -->
  <rule id="828595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1623 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>