<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0820 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: fa8f2401-3b5c-5d02-8abf-be0b8692cc5e -->
  <rule id="514324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0820 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>