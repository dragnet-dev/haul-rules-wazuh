<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1645 — Recovery Inhibition (tridentlocker) | Status: stable | Sigma ID: e0023ebb-6832-5122-9fb4-56f7a40a56f0 -->
  <rule id="540382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1645 — Recovery Inhibition (tridentlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>