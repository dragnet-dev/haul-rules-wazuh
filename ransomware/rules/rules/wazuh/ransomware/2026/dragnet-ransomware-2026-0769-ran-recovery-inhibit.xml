<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0769 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 98504412-e8f2-5e8c-a01f-e2bd5036b20d -->
  <rule id="950441" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0769 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>