<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1500 — Event Log Clearing (payoutsking) | Status: deprecated | Sigma ID: 61d24b22-bf3b-553b-9bbd-3140da3db0f8 -->
  <rule id="782795" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1500 — Event Log Clearing (payoutsking)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>