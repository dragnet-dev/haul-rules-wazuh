<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2621 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 6fbfabe4-b0a6-5581-a556-42fad64f5bf0 -->
  <rule id="223563" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2621 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>