<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2631 — Recovery Inhibition (exitium) | Status: stable | Sigma ID: f0824076-cba4-599f-a96b-af43de70310d -->
  <rule id="708240" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2631 — Recovery Inhibition (exitium)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>