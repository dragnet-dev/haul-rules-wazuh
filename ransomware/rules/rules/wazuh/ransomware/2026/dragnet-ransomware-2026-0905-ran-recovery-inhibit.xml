<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0905 — Recovery Inhibition (tridentlocker) | Status: stable | Sigma ID: 889173d4-077f-5d6b-9be9-8607b8e1de7d -->
  <rule id="826781" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0905 — Recovery Inhibition (tridentlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>