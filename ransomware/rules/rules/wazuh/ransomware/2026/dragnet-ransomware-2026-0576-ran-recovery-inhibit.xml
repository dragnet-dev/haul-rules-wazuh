<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0576 — Recovery Inhibition (nova) | Status: stable | Sigma ID: a0019a71-6b82-589a-9121-6c39435e3f5d -->
  <rule id="800314" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0576 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>