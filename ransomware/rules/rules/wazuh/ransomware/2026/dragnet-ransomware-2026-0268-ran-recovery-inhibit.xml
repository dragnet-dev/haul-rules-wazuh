<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0268 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 7e212ed1-072d-58eb-9561-855c64aa7465 -->
  <rule id="319406" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0268 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>