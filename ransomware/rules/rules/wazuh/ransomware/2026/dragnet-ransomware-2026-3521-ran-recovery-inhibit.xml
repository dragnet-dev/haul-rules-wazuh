<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3521 — Recovery Inhibition (play) | Status: stable | Sigma ID: 14bb7ad6-4f19-5e4c-8b81-4f00a0248abe -->
  <rule id="755725" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3521 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>