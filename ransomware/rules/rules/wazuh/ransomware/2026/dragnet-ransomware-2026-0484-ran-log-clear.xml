<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0484 — Event Log Clearing (payload) | Status: stable | Sigma ID: 6bb0678a-2215-589b-9795-75d341bd1e3b -->
  <rule id="923067" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0484 — Event Log Clearing (payload)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>