<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2876 — Event Log Clearing (sinobi) | Status: test | Sigma ID: 4026b0a6-cdb8-58c0-8b69-dcc1b4a315a4 -->
  <rule id="508330" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2876 — Event Log Clearing (sinobi)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>