<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2407 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 35aa5b1a-5f99-550c-baf5-576ec3666bc3 -->
  <rule id="660891" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2407 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
