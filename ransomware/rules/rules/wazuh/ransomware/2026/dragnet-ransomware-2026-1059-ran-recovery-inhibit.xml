<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1059 — Recovery Inhibition (thegentlemen) | Status: stable | Sigma ID: ffd682ea-516e-520f-89c8-ecbe22134d52 -->
  <rule id="593682" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1059 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
