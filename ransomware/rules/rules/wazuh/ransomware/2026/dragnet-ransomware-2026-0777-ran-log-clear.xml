<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0777 — Event Log Clearing (netrunner) | Status: stable | Sigma ID: d9ee486e-888e-5183-a12f-88858c02e7bd -->
  <rule id="982248" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0777 — Event Log Clearing (netrunner)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>