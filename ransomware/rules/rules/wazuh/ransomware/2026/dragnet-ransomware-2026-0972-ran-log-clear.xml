<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0972 — Event Log Clearing (benzona) | Status: deprecated | Sigma ID: d8037990-3422-574e-a332-fc7de9f81d0a -->
  <rule id="580379" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0972 — Event Log Clearing (benzona)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>