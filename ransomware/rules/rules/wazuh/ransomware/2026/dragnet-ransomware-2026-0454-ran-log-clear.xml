<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0454 — Event Log Clearing (coinbasecartel) | Status: stable | Sigma ID: 3c53be9f-da8b-5fb7-9a40-133accaee9e0 -->
  <rule id="749758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0454 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>