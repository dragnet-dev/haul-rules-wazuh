<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0305 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: ee22fb6d-227b-5d36-996d-1ae6d98a96c6 -->
  <rule id="798683" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0305 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>