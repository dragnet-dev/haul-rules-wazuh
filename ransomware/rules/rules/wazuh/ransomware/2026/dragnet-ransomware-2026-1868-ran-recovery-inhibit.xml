<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1868 — Recovery Inhibition (nova) | Status: stable | Sigma ID: 579e5409-88af-596b-aa5f-43a08b732115 -->
  <rule id="378540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1868 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>