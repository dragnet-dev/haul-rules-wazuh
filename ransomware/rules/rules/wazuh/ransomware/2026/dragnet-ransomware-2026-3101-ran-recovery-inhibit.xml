<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3101 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 648d371d-3fcb-5ce7-b18a-89b287ff9eed -->
  <rule id="238137" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3101 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>