<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1956 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: e1a417c4-bd45-5bb2-b988-96f8227888e8 -->
  <rule id="566417" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1956 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>