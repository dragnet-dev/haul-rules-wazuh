<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3100 — Shadow Copy Deletion (shadowbyt3$) | Status: deprecated | Sigma ID: 2bad721a-c9b9-5b4e-8962-3db97c5563bc -->
  <rule id="318172" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3100 — Shadow Copy Deletion (shadowbyt3$)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>