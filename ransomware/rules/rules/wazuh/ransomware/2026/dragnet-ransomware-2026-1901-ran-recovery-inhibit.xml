<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1901 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: b7035a33-8ee9-5e6b-a997-2ddad1bd33c4 -->
  <rule id="172570" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1901 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>