<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1475 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: 40a7fad1-33bd-54f9-b217-4e1d45c947bb -->
  <rule id="866042" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1475 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>