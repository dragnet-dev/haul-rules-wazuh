<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1835 — Event Log Clearing (benzona) | Status: deprecated | Sigma ID: 8218d65d-eee6-5859-8e35-6b83c9ceb9e2 -->
  <rule id="515016" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1835 — Event Log Clearing (benzona)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>