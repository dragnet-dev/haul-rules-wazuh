<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0322 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: cb331ccd-f665-5e8b-863c-cb37a08df94d -->
  <rule id="653308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0322 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>