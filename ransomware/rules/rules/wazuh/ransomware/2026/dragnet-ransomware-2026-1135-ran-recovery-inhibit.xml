<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1135 — Recovery Inhibition (thegentlemen) | Status: stable | Sigma ID: 150729a6-799f-5a74-b484-cf1626f9264f -->
  <rule id="711674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1135 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>