<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1530 — Recovery Inhibition (gunra) | Status: stable | Sigma ID: 09ba7bef-5ed7-5eec-a23b-ba60c6e46e6c -->
  <rule id="176382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1530 — Recovery Inhibition (gunra)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>