<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0017 — Event Log Clearing (genesis) | Status: stable | Sigma ID: 9c39dfd3-8dfa-5247-a5ad-2e0f409f0f21 -->
  <rule id="503807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0017 — Event Log Clearing (genesis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>