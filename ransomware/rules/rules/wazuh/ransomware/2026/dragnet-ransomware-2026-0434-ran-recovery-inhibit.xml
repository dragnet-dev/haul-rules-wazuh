<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0434 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 1cc2b748-9460-556a-97a3-b3018f5f253f -->
  <rule id="264374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0434 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>