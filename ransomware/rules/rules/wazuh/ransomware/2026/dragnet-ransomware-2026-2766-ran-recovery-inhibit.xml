<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2766 — Recovery Inhibition (clop) | Status: test | Sigma ID: d2a22e42-e349-5222-a1cf-014be9e65fbe -->
  <rule id="795566" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2766 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
