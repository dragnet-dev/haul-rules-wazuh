<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0560 — Event Log Clearing (fulcrumsec) | Status: stable | Sigma ID: 1a52889a-3cfc-5cb3-8680-8e7cab393bb6 -->
  <rule id="952889" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0560 — Event Log Clearing (fulcrumsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>