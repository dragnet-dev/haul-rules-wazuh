<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3229 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: a6e27743-a933-5eb3-ac51-d8795f134fd0 -->
  <rule id="910277" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3229 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
