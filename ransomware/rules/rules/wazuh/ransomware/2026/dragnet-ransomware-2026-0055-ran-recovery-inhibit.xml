<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0055 — Recovery Inhibition (lynx) | Status: test | Sigma ID: 647a32d2-a1cd-5785-ac74-6b5f98e70268 -->
  <rule id="236232" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0055 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>