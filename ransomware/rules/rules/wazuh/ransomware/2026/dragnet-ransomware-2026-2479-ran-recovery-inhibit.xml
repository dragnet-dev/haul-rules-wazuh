<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2479 — Recovery Inhibition (fulcrumsec) | Status: stable | Sigma ID: 8a97dace-bd66-504e-86ab-4821d254fe9e -->
  <rule id="957850" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2479 — Recovery Inhibition (fulcrumsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>