<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1896 — Event Log Clearing (m3rx) | Status: stable | Sigma ID: 10510aa6-b572-565c-8499-f14a8c8b9c4c -->
  <rule id="990730" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1896 — Event Log Clearing (m3rx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>