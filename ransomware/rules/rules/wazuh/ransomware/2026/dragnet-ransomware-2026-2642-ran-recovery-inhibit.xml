<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2642 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: e0d7bfdc-72d1-5373-b4f7-a64415a6b03f -->
  <rule id="469663" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2642 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>