<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2173 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: c95c6680-aef9-5409-828c-5304d8319db4 -->
  <rule id="373266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2173 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>