<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1694 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 70e96d3e-d975-567e-a441-718a2539c875 -->
  <rule id="115949" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1694 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
