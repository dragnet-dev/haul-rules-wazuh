<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0772 — Event Log Clearing (LeakBazaar) | Status: stable | Sigma ID: 9607f0b6-66a9-5bd9-b793-06c8afd0da51 -->
  <rule id="737270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0772 — Event Log Clearing (LeakBazaar)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>