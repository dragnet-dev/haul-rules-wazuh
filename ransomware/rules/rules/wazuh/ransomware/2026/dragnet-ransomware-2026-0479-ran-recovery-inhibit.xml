<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0479 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 73b76b4d-f02e-5064-a5ae-55e90065bd52 -->
  <rule id="187627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0479 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>