<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0840 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 1c28a508-efe6-50d4-8df8-330255f639da -->
  <rule id="125850" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0840 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>