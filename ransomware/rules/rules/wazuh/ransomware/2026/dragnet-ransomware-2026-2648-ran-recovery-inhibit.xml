<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2648 — Recovery Inhibition (m3rx) | Status: stable | Sigma ID: f0677427-ce32-5286-8d88-890d487ce128 -->
  <rule id="706774" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2648 — Recovery Inhibition (m3rx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>