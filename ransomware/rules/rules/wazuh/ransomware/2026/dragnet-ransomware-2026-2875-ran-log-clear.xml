<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2875 — Event Log Clearing (qilin) | Status: stable | Sigma ID: 9d1edfa8-4bd2-59b7-9c49-4cfdb3d89987 -->
  <rule id="238623" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2875 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>