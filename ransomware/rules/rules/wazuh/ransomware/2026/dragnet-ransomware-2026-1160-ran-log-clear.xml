<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1160 — Event Log Clearing (thegentlemen) | Status: stable | Sigma ID: 84afb6ec-5fdb-56bf-bb75-6e3a3a334697 -->
  <rule id="868756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1160 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>