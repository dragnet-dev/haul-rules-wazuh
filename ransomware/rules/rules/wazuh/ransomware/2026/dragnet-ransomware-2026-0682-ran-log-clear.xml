<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0682 — Event Log Clearing (ciphbit) | Status: deprecated | Sigma ID: 937d5cf7-c1a5-5ea1-876e-e0554cd8ac4f -->
  <rule id="700892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0682 — Event Log Clearing (ciphbit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>