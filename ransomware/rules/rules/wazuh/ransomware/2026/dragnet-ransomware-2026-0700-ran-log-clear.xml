<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0700 — Event Log Clearing (abyss) | Status: deprecated | Sigma ID: 3e423cf2-57f0-5820-b677-988fd248e4e4 -->
  <rule id="780495" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0700 — Event Log Clearing (abyss)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>