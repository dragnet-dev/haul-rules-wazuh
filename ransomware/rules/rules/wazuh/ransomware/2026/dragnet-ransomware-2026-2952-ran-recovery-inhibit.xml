<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2952 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: d5df9406-9707-514f-847f-15572fe3981e -->
  <rule id="878394" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2952 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>