<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2088 — Recovery Inhibition (handala) | Status: stable | Sigma ID: 7f518002-3927-5fa0-ad88-d7fc8c09eb3d -->
  <rule id="475180" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2088 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
