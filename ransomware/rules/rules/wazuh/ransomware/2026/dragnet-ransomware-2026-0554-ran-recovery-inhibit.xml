<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0554 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: 58acdd41-3da9-50e4-bacb-4404975be836 -->
  <rule id="345341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0554 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>