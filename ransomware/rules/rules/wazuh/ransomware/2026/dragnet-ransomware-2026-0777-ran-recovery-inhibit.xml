<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0777 — Recovery Inhibition (netrunner) | Status: stable | Sigma ID: ee57a35f-628f-595d-9e27-cf02d9777415 -->
  <rule id="317223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0777 — Recovery Inhibition (netrunner)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>