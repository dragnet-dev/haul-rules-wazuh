<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1816 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 53c6e311-a807-52d7-af35-b09110e1a884 -->
  <rule id="577103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1816 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>