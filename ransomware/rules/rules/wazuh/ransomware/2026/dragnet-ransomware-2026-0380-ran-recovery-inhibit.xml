<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0380 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 4f921afe-13c9-5e1d-87d9-fdf110f71fc8 -->
  <rule id="478746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0380 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>