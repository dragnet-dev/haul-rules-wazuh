<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3451 — Recovery Inhibition (anubis) | Status: stable | Sigma ID: e2d26f0c-56b6-5800-9bd8-27ac16797c9b -->
  <rule id="156431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3451 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>