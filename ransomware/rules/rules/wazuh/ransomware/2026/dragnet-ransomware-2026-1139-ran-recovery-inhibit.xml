<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1139 — Recovery Inhibition (thegentlemen) | Status: stable | Sigma ID: 5060e897-5814-57f9-a2f7-a1fb22959d22 -->
  <rule id="997489" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1139 — Recovery Inhibition (thegentlemen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
