<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2691 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 3e41b7d2-6609-540b-9caf-cd0635e187cc -->
  <rule id="778845" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2691 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>