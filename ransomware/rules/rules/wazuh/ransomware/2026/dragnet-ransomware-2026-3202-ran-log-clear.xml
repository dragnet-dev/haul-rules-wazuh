<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3202 — Event Log Clearing (tengu) | Status: test | Sigma ID: a28b6742-85e9-5397-8432-776d6a5038c2 -->
  <rule id="845967" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3202 — Event Log Clearing (tengu)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>