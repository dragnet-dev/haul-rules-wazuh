<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0776 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 7bb13aa2-7aa4-5cbb-ae9d-e2f04120d6b1 -->
  <rule id="566618" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0776 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>