<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2835 — Recovery Inhibition (lamashtu) | Status: stable | Sigma ID: fca5234e-e924-5e05-a2f8-35e247817218 -->
  <rule id="542523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2835 — Recovery Inhibition (lamashtu)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>