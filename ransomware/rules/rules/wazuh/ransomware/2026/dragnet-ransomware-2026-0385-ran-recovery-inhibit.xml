<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0385 — Recovery Inhibition (direwolf) | Status: test | Sigma ID: 11484210-961c-5f73-ade4-4bf773521fcb -->
  <rule id="348421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0385 — Recovery Inhibition (direwolf)</description>
