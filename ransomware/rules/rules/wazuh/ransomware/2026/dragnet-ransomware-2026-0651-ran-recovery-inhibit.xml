<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0651 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: aa162bcc-d40f-5370-aaee-f1981b5d9bbd -->
  <rule id="122603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0651 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>