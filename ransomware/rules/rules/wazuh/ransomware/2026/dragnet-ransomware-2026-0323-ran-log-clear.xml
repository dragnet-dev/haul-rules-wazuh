<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0323 — Event Log Clearing (genesis) | Status: stable | Sigma ID: 67d74cf8-a3a4-5ef5-b84c-1bb6997c08d3 -->
  <rule id="937196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0323 — Event Log Clearing (genesis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>