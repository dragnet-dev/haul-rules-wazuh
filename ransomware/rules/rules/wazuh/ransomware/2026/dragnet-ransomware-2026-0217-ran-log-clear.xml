<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0217 — Event Log Clearing (nightspire) | Status: deprecated | Sigma ID: 0a2e9467-781b-5b97-99ea-803d4045b5f2 -->
  <rule id="846946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0217 — Event Log Clearing (nightspire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>