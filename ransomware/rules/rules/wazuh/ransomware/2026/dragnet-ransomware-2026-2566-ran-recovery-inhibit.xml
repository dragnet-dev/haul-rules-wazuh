<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2566 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 8779e4db-6888-5047-b83c-a46e3583ffc0 -->
  <rule id="604784" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2566 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>