<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0108 — Recovery Inhibition (nova) | Status: stable | Sigma ID: f3ab3399-c3c2-5512-84f1-b32af669ab4c -->
  <rule id="433933" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0108 — Recovery Inhibition (nova)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>