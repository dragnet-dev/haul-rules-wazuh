<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2541 — Recovery Inhibition (lockbit5) | Status: stable | Sigma ID: 26a5a214-69ea-5e5b-852d-a20793427a61 -->
  <rule id="625021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2541 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>