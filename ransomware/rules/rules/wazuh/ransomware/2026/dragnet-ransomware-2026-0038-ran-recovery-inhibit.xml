<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0038 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 1d8d9524-4f76-524b-aa1b-87ecf80532c5 -->
  <rule id="381952" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0038 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>