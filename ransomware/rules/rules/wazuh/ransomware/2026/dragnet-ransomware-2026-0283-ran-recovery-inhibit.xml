<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0283 — Recovery Inhibition (payload) | Status: stable | Sigma ID: 96fd9ade-4eeb-505c-af25-c6bfc1551c60 -->
  <rule id="472794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0283 — Recovery Inhibition (payload)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>