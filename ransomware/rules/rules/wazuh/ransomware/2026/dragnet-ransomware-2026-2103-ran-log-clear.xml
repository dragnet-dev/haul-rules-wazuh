<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2103 — Event Log Clearing (shinyhunters) | Status: deprecated | Sigma ID: 7c0efec1-7445-53b6-99cc-142ef074740f -->
  <rule id="682878" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2103 — Event Log Clearing (shinyhunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>