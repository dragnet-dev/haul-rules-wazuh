<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2966 — Event Log Clearing (AuditTeam) | Status: stable | Sigma ID: 5a01d52e-12a1-506f-a6e3-cd9184f37112 -->
  <rule id="640295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2966 — Event Log Clearing (AuditTeam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>