<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2963 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 069d36f3-74fc-56e7-8a50-efcfcf6af489 -->
  <rule id="987791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2963 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>