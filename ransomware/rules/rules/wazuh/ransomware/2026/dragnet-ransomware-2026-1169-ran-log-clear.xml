<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1169 — Event Log Clearing (thegentlemen) | Status: stable | Sigma ID: 0893c060-801f-5b5e-8ca6-8de8aa89e9f7 -->
  <rule id="630006" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1169 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>