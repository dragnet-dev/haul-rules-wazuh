<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3060 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: e020f567-0e35-5608-833f-f558108391bd -->
  <rule id="543355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3060 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>