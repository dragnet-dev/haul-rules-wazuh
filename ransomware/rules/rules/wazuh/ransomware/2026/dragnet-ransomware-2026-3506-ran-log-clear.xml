<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3506 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: f2fa0bc2-90d1-5aa1-8ef4-592ead549a95 -->
  <rule id="965931" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3506 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>