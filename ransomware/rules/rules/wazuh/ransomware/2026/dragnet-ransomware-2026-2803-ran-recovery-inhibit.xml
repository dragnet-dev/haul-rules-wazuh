<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2803 — Recovery Inhibition (medusalocker) | Status: stable | Sigma ID: 02182d6c-1c19-5bc9-a073-1bdf8f7e8955 -->
  <rule id="288108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2803 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>