<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2140 — Event Log Clearing (AiLock) | Status: deprecated | Sigma ID: 1f3fe2b0-b74f-520d-a51f-9362a7d633d3 -->
  <rule id="361163" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2140 — Event Log Clearing (AiLock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>