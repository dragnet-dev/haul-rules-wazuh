<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2195 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: dd976e39-0281-50b3-9ef1-c5b92b9f7b3e -->
  <rule id="951630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2195 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>