<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0783 — Recovery Inhibition (pear) | Status: stable | Sigma ID: f17f6000-c787-5bae-b35c-0264eadbade0 -->
  <rule id="728760" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0783 — Recovery Inhibition (pear)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>