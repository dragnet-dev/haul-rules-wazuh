<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0248 — Recovery Inhibition (everest) | Status: test | Sigma ID: c3f20297-0bb3-5acc-a8a0-910f07be63c5 -->
  <rule id="283202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0248 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>