<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1764 — Recovery Inhibition (embargo) | Status: stable | Sigma ID: 400557e1-ce7f-5828-b4a8-a4d4fdd04245 -->
  <rule id="208926" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1764 — Recovery Inhibition (embargo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>