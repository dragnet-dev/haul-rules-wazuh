<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3417 — Recovery Inhibition (anubis) | Status: stable | Sigma ID: d5c55a81-f046-5a25-982a-f5eeeb4fad1d -->
  <rule id="876090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3417 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>