<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2192 — Recovery Inhibition (nightspire) | Status: deprecated | Sigma ID: 615b83f1-0635-57cb-be6b-002179935b18 -->
  <rule id="562943" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2192 — Recovery Inhibition (nightspire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>