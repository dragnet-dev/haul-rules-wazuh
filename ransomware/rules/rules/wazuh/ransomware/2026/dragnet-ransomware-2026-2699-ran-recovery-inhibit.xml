<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2699 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: ef84c7b6-bafa-5b59-8577-2c1deed675b2 -->
  <rule id="337567" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2699 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>