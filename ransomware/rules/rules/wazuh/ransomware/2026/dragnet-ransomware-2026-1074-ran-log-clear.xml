<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1074 — Event Log Clearing (thegentlemen) | Status: stable | Sigma ID: f7a63fc9-c843-5cd0-9f1a-c0f80b7a13f3 -->
  <rule id="536223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1074 — Event Log Clearing (thegentlemen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>