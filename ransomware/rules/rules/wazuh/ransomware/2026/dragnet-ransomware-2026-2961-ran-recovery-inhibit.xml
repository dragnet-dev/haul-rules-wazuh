<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2961 — Recovery Inhibition (direwolf) | Status: test | Sigma ID: ad62d550-5048-50ce-96a3-7b594359727a -->
  <rule id="178055" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2961 — Recovery Inhibition (direwolf)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>