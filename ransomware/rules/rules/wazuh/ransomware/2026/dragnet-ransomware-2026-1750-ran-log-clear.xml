<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1750 — Event Log Clearing (incransom) | Status: stable | Sigma ID: 5ee1344f-74b4-5d3f-b4e2-3fef0db0d0fd -->
  <rule id="718134" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1750 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>