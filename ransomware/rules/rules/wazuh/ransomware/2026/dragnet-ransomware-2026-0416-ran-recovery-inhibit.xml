<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0416 — Recovery Inhibition (incransom) | Status: stable | Sigma ID: db513b95-31d6-5e26-868c-aea85e478f93 -->
  <rule id="912219" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0416 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>