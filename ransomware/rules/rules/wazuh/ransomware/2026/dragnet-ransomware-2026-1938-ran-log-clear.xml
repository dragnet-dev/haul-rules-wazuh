<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1938 — Event Log Clearing (beast) | Status: stable | Sigma ID: ecf84f36-6f1f-58ce-96a4-06c034f86f25 -->
  <rule id="766959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1938 — Event Log Clearing (beast)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>