<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0413 — Event Log Clearing (genesis) | Status: test | Sigma ID: 1289d1c8-6c70-51a3-99ec-591e60064521 -->
  <rule id="701948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0413 — Event Log Clearing (genesis)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>