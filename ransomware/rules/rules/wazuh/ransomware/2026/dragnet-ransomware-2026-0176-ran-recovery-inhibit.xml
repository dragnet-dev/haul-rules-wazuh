<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0176 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 6e503314-3b5a-5688-91e5-39a42138b2a8 -->
  <rule id="305033" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0176 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>