<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1737 — Event Log Clearing (kairos) | Status: deprecated | Sigma ID: a0f9e264-77a6-5031-9f48-c6c1eb2b740c -->
  <rule id="885582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1737 — Event Log Clearing (kairos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>