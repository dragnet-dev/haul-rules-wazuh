<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2531 — Recovery Inhibition (morpheus) | Status: deprecated | Sigma ID: 65679369-7ccf-5cb6-817e-67432d10e17c -->
  <rule id="367936" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2531 — Recovery Inhibition (morpheus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
