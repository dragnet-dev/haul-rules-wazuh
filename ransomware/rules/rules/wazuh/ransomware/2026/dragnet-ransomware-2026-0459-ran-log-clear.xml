<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0459 — Event Log Clearing (titan) | Status: stable | Sigma ID: 08c38874-4e4f-59eb-95b7-8c8e23001ecb -->
  <rule id="603887" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0459 — Event Log Clearing (titan)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>