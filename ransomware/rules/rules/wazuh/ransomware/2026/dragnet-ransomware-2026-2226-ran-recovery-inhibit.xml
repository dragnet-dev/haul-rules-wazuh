<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2226 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 30d01e0d-9f5e-526e-a56e-4f2c42dda215 -->
  <rule id="788300" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2226 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>