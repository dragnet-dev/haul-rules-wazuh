<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2922 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: 1da9a1d3-6938-500a-a77a-a9d6533f9127 -->
  <rule id="559069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2922 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>