<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2560 — Recovery Inhibition (apt73) | Status: stable | Sigma ID: c35861df-a112-5c95-8bd6-ed4296440615 -->
  <rule id="435861" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2560 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>