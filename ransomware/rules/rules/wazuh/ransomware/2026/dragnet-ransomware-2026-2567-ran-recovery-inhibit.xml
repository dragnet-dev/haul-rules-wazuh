<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2567 — Recovery Inhibition (handala) | Status: stable | Sigma ID: e2434114-991c-56e4-ad31-e1c87e50343e -->
  <rule id="624341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2567 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>