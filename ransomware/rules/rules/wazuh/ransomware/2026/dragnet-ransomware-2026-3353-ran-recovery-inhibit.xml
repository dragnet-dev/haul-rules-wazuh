<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3353 — Recovery Inhibition (AiLock) | Status: deprecated | Sigma ID: e522bee4-6c98-5a41-9519-7ff6ab222e48 -->
  <rule id="217822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3353 — Recovery Inhibition (AiLock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
