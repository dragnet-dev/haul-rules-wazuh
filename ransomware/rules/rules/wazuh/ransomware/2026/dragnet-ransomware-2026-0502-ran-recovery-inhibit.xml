<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0502 — Recovery Inhibition (qilin) | Status: test | Sigma ID: f5fc2d04-d406-565c-b3d7-c18d29dc7d26 -->
  <rule id="189165" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0502 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>