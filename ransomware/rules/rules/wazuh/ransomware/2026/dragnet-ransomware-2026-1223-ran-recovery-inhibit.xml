<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1223 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: fc33bf0d-dfaa-5988-bf31-e88c97e39829 -->
  <rule id="259839" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1223 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>