<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1181 — Recovery Inhibition (safepay) | Status: stable | Sigma ID: 6ac6eba1-cb50-5a4f-b112-5a5ad6968a27 -->
  <rule id="874251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1181 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>