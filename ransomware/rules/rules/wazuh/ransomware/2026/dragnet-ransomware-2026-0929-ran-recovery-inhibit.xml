<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0929 — Recovery Inhibition (anubis) | Status: stable | Sigma ID: 3f55d0e8-6080-5c07-9a3b-320f56a118e8 -->
  <rule id="216930" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0929 — Recovery Inhibition (anubis)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
