<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2948 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 84c8da68-7f9a-51e4-8bf0-e521105adcb5 -->
  <rule id="873626" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2948 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>