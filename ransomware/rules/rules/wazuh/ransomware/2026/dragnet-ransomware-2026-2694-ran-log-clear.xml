<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2694 — Event Log Clearing (pear) | Status: test | Sigma ID: 0d7a1594-b24d-510c-b5dc-b54d8c441d42 -->
  <rule id="502159" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2694 — Event Log Clearing (pear)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>