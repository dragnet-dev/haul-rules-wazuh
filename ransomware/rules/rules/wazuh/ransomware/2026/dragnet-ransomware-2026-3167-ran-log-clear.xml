<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3167 — Event Log Clearing (bravox) | Status: stable | Sigma ID: 5f647eca-60ba-58e1-afd8-5ad44b4d9d3f -->
  <rule id="730366" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3167 — Event Log Clearing (bravox)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>