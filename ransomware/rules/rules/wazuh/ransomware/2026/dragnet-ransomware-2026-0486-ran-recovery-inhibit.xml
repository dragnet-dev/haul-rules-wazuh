  <rule id="750620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0486 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>