<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3424 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 3ed4b02e-fba4-5a65-b2f1-ce497406cf91 -->
  <rule id="808750" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3424 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>