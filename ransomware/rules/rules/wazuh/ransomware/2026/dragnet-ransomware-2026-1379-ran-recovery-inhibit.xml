<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1379 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: 0dca1628-cac2-5c6c-bd07-cf95ae4f2e13 -->
  <rule id="930162" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1379 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>