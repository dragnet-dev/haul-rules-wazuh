<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2133 — Recovery Inhibition (sinobi) | Status: test | Sigma ID: 75cee7ef-ba10-5ebd-85d2-680b3af60ce2 -->
  <rule id="505107" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2133 — Recovery Inhibition (sinobi)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
