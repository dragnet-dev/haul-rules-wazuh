<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1937 — Recovery Inhibition (spacebears) | Status: stable | Sigma ID: 8afb43be-fdaa-544c-b628-17f7bae0c97f -->
  <rule id="957943" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1937 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
