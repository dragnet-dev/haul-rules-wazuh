<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2949 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 8c2cebaa-d428-5b06-a7d4-526c74e5d148 -->
  <rule id="445899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2949 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>