<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2662 — Recovery Inhibition (lamashtu) | Status: stable | Sigma ID: 876b60ec-d010-567d-9c85-8ad553c9f9d1 -->
  <rule id="602760" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2662 — Recovery Inhibition (lamashtu)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>