<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2634 — Recovery Inhibition (fulcrumsec) | Status: stable | Sigma ID: 19ef2406-1205-57df-b203-c22d759c458c -->
  <rule id="703240" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2634 — Recovery Inhibition (fulcrumsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>