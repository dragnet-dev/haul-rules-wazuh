<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2787 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 478342b0-e279-5028-b3a0-bd631bed4fce -->
  <rule id="553483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2787 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>