<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3473 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: b3043a3c-b4e9-57cd-b202-8138fa017be9 -->
  <rule id="108698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3473 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>