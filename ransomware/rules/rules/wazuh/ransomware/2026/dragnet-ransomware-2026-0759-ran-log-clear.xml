<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0759 — Event Log Clearing (tengu) | Status: test | Sigma ID: e6f0f9e1-6639-5714-b71b-54032be038ff -->
  <rule id="261759" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0759 — Event Log Clearing (tengu)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>