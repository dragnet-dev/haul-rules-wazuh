<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2729 — Recovery Inhibition (dragonforce) | Status: stable | Sigma ID: f9516e16-9475-5e16-b51e-128ab7936047 -->
  <rule id="852270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2729 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>