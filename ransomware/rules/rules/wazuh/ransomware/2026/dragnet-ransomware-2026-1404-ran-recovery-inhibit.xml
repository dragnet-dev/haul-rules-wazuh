<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1404 — Recovery Inhibition (qilin) | Status: test | Sigma ID: 37dcc461-c199-5cc4-b645-4daa6e3e4e2e -->
  <rule id="750844" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1404 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>