<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2850 — Event Log Clearing (handala) | Status: stable | Sigma ID: 6b0c8f28-0b7b-52bc-95e8-aaae0cff5b36 -->
  <rule id="141263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2850 — Event Log Clearing (handala)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>