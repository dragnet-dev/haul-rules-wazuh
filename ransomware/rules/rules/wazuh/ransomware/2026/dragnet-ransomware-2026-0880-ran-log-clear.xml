<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0880 — Event Log Clearing (clop) | Status: test | Sigma ID: 2e5d11fc-dc9b-50c3-9ae0-ca17cfbf38cc -->
  <rule id="324991" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0880 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>