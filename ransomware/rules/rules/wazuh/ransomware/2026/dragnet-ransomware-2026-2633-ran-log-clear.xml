<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2633 — Event Log Clearing (secpo) | Status: stable | Sigma ID: 7f605235-f28d-5792-8ece-61523108b5f0 -->
  <rule id="476052" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2633 — Event Log Clearing (secpo)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>