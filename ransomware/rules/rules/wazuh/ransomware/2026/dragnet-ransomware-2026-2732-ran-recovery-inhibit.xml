<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2732 — Recovery Inhibition (clop) | Status: test | Sigma ID: 32960008-04eb-5e4d-9973-56443a4807a2 -->
  <rule id="696000" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2732 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
