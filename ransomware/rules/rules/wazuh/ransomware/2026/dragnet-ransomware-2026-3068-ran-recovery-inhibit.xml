<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-3068 — Recovery Inhibition (everest) | Status: test | Sigma ID: 115e16b5-f5be-5965-aabc-54dfe5c9c323 -->
  <rule id="366667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-3068 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
