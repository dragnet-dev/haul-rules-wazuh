<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2128 — Event Log Clearing (payoutsking) | Status: stable | Sigma ID: 8bf2e3b7-476f-5dee-81e2-fc3de5a24157 -->
  <rule id="982863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2128 — Event Log Clearing (payoutsking)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>