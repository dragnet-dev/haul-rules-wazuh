<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0049 — Recovery Inhibition (interlock) | Status: stable | Sigma ID: b3b6ba4e-69ee-520c-8a89-0fd3721fabe0 -->
  <rule id="258362" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0049 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>