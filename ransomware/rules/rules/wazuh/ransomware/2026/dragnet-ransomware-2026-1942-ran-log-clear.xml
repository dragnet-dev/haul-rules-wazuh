<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-1942 — Event Log Clearing (LeakBazaar) | Status: stable | Sigma ID: 6bff67e4-b688-5455-bf1f-8a66df7e5708 -->
  <rule id="164767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-1942 — Event Log Clearing (LeakBazaar)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>