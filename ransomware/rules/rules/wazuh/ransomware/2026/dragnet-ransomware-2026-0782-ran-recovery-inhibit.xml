<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0782 — Recovery Inhibition (clop) | Status: stable | Sigma ID: 37566e70-14e9-50df-b4c3-295d9ed71aee -->
  <rule id="710707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0782 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>