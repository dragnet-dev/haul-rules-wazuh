<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-0004 — Recovery Inhibition (qilin) | Status: stable | Sigma ID: 44486c7c-4e97-5123-a12b-4469e64289d4 -->
  <rule id="917887" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-0004 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>