<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2026-2661 — Recovery Inhibition (play) | Status: stable | Sigma ID: 1515397b-908c-5c36-909a-23bf97a89c0e -->
  <rule id="715397" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2026-2661 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>