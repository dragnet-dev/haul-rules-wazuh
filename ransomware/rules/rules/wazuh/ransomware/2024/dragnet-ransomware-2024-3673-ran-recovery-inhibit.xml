<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3673 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 93d2eb4f-25d1-5089-91c1-ae4317b6f0e2 -->
  <rule id="343307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3673 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>