<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5699 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: df83e947-3e04-5549-8fb1-2ce2fa5ba392 -->
  <rule id="981429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5699 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>