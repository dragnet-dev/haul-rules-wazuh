<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3511 — Recovery Inhibition (play) | Status: experimental | Sigma ID: fdbf1754-ee23-5808-add2-205260bcdd67 -->
  <rule id="295917" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3511 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>