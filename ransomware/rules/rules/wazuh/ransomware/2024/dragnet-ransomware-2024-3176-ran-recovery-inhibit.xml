<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3176 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 781dfe74-5431-5b3e-a2b3-86935903bcc1 -->
  <rule id="602558" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3176 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>