<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3841 — Event Log Clearing (qilin) | Status: deprecated | Sigma ID: bb0e1f4a-5cf2-5a0f-ac68-7eefe04d45ce -->
  <rule id="389471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3841 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>