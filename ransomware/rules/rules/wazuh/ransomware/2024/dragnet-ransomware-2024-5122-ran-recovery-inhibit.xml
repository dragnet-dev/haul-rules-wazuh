<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5122 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e3cea2aa-4c5b-5c7f-9c11-92fc32dd26b0 -->
  <rule id="590342" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5122 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>