<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4927 — Event Log Clearing (malekteam) | Status: experimental | Sigma ID: 3ceb3fcc-5e67-5ab9-a480-a742c3147aee -->
  <rule id="795263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4927 — Event Log Clearing (malekteam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>