<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0591 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: d7dae070-e09c-56a9-a674-fe5629840ba1 -->
  <rule id="346540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0591 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>