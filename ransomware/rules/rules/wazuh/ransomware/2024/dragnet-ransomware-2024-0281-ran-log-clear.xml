<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0281 — Event Log Clearing (unsafe) | Status: deprecated | Sigma ID: ffbd619f-9493-5f0b-92ee-bf1e3b773e0c -->
  <rule id="346961" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0281 — Event Log Clearing (unsafe)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>