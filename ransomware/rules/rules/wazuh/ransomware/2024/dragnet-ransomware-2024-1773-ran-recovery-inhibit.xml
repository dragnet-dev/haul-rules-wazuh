<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1773 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e92359bb-f6e8-5591-b995-b472c879c500 -->
  <rule id="692359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1773 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>