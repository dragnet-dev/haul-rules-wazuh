<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0510 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 7907a342-f782-54ff-8ef2-f6b1df75042f -->
  <rule id="465223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0510 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>