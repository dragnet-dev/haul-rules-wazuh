<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3736 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 25989642-8375-5b84-bde8-b77c5f778b5e -->
  <rule id="898964" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3736 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>