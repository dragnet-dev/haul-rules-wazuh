<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4050 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 69b00dd5-664d-5049-aab5-2584209afbd3 -->
  <rule id="984013" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4050 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>