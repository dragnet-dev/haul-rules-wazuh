<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1888 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 3eeecb65-23b0-584e-bd3b-6f571a18c729 -->
  <rule id="624363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1888 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>