<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3941 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: e04a6656-b298-5111-a885-3de9012a3a9d -->
  <rule id="547466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3941 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>