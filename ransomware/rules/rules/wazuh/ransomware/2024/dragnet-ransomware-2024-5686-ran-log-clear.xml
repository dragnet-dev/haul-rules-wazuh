<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5686 — Event Log Clearing (arcusmedia) | Status: experimental | Sigma ID: eef752ff-e9b0-5fdc-8d6f-1b4421c71963 -->
  <rule id="323752" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5686 — Event Log Clearing (arcusmedia)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>