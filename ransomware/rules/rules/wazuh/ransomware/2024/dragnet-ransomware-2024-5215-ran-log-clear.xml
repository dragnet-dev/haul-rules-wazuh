<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5215 — Event Log Clearing (safepay) | Status: deprecated | Sigma ID: e633aa3e-7d2b-51fe-a55a-118fc01bf3d3 -->
  <rule id="246218" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5215 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>