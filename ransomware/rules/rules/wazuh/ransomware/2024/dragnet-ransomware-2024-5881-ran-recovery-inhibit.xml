<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5881 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7c62360e-a025-5208-be32-531485aee0a8 -->
  <rule id="446236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5881 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>