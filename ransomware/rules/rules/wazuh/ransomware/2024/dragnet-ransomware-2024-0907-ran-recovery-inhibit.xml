<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0907 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: e92fc1f7-d3d4-5b05-9835-ff8bef98481b -->
  <rule id="322041" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0907 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>