<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0229 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 68dc00b3-3655-55df-a273-f2d22086ad6b -->
  <rule id="962800" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0229 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>