<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0715 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e4da409f-e8b4-543b-8981-84dc5a3682de -->
  <rule id="208240" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0715 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>