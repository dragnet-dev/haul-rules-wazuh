<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3257 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: ec178e76-ff2a-55a8-bbc2-ede83e42c393 -->
  <rule id="278862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3257 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>