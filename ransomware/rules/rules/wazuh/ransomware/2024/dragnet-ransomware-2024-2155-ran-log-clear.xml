<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2155 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 304eaa46-9f6b-5ec0-8dd7-bcc1068dc2f8 -->
  <rule id="448938" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2155 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>