<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1642 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7391f08b-01d8-5090-bcf6-f503c239599d -->
  <rule id="382710" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1642 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>