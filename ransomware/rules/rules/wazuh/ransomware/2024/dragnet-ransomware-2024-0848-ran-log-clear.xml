<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0848 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 8cbcde72-9f2f-594e-b9ba-9e5dd99e2f32 -->
  <rule id="323390" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0848 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>