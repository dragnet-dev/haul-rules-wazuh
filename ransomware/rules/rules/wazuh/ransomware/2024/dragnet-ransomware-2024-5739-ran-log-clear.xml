<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5739 — Event Log Clearing (mogilevich) | Status: deprecated | Sigma ID: f38526fc-fa19-5e55-9cce-cea3a44abc9a -->
  <rule id="738526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5739 — Event Log Clearing (mogilevich)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>