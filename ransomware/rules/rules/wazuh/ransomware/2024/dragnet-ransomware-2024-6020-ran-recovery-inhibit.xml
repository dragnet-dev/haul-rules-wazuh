<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6020 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 5c688c3e-b39d-5223-b563-077a4a9382ea -->
  <rule id="683020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6020 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>