<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1543 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: c258305b-0876-50df-9e8c-7c619b7d57f5 -->
  <rule id="425830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1543 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>