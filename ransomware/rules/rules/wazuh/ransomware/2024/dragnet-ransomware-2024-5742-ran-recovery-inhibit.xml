<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5742 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: e93ed3e1-53fc-51ea-889b-5ff20b89eb1c -->
  <rule id="324453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5742 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>