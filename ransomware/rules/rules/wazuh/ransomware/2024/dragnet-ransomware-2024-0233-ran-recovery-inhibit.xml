<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0233 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: a6c4abe3-8451-5da8-8561-773222bc3d53 -->
  <rule id="873675" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0233 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>