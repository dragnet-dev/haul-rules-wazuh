<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2843 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: bfb14ed4-36a9-5950-9d56-3cb33dedcc2b -->
  <rule id="507438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2843 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>