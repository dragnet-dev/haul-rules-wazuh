<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0772 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: a2ad267b-1e3e-58f4-b8f4-bcddda88de50 -->
  <rule id="928526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0772 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>