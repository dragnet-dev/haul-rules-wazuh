<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0675 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: ea40bd28-f2ea-5e7c-9388-7a822bfc19dd -->
  <rule id="700829" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0675 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>