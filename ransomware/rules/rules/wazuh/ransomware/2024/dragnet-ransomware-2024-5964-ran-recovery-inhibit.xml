<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5964 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 7ee94bc1-509b-51f8-921e-8d613e854226 -->
  <rule id="649515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5964 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>