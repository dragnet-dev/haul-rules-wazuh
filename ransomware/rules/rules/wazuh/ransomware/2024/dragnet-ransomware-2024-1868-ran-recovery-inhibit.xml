<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1868 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: a23f5c21-436c-5423-91d9-d99523d9d919 -->
  <rule id="921372" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1868 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>