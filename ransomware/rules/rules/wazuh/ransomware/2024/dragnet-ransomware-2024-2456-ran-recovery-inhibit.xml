<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2456 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: ab6b5313-a342-57e7-bcfc-1f1e128224bc -->
  <rule id="146753" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2456 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>