<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2442 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 9804d087-96eb-54e0-9233-7eccd04ac5dd -->
  <rule id="768770" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2442 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>