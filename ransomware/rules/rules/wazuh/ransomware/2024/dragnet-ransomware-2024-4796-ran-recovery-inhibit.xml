<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4796 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: ee9a9e00-81d2-5d50-9479-79ffa8515004 -->
  <rule id="817598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4796 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>