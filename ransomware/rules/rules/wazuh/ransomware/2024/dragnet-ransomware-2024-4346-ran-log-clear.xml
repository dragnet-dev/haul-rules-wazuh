<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4346 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 1949b2c5-7a70-5b4f-8be0-4b4c9a0334bf -->
  <rule id="591244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4346 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>