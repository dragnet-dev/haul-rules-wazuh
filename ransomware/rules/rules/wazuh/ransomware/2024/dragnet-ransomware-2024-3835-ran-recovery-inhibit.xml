<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3835 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: edf4847f-a44a-58b2-a35a-29c57063c64e -->
  <rule id="307484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3835 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>