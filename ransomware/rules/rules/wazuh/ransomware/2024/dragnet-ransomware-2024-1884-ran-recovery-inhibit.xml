<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1884 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4d1d8c75-53f7-5c4e-8779-88f0f0848624 -->
  <rule id="275980" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1884 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>