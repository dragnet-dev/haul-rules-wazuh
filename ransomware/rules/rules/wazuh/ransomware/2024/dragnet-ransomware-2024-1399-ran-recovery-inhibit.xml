<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1399 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 5cecf313-9087-5ca4-954f-89ed8fbe282a -->
  <rule id="306233" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1399 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>