<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6034 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: dc993e47-0318-552e-84df-aa8707485ce9 -->
  <rule id="935902" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6034 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>