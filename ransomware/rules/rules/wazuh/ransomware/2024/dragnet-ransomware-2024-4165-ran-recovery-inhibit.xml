<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4165 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: 3e0bcd67-e6fa-5d01-a6ac-459bbc6aa71a -->
  <rule id="842541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4165 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>