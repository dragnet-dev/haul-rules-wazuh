<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1441 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: bed36351-22fe-5261-936a-35c1f7b8ef22 -->
  <rule id="453363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1441 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>