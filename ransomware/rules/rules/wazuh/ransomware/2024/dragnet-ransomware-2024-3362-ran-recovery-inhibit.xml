<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3362 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 4f5299de-668d-5a05-ba43-4ad172d8f7d0 -->
  <rule id="224797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3362 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>