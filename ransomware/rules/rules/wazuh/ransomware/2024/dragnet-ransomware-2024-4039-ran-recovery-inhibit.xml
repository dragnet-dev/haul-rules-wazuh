<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4039 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 5c806877-5e0d-5a51-a7d7-901b7b3cdd96 -->
  <rule id="380687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4039 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>