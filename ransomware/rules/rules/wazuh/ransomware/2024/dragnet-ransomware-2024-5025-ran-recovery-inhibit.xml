<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5025 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 4c8affe2-efba-5310-b96c-99652c57e9c7 -->
  <rule id="548543" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5025 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>