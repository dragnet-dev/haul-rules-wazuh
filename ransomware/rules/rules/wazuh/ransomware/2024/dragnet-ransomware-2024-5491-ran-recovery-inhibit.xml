<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5491 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: fe97e80b-5820-52b1-9d98-4d440bc7c6f2 -->
  <rule id="579668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5491 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>