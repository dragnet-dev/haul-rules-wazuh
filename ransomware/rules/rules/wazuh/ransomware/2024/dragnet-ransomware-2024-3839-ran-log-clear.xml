<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3839 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 8bc7a3cb-5d76-5bc4-a8b3-fed3c1bdd2de -->
  <rule id="978823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3839 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>