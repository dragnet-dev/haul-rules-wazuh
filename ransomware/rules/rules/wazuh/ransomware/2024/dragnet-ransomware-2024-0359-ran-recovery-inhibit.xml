<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0359 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 636b5324-14df-55df-934d-ddcdb869809b -->
  <rule id="218753" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0359 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>