<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5666 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 2451113a-2ff3-52ed-885d-005222133cb2 -->
  <rule id="751113" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5666 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>