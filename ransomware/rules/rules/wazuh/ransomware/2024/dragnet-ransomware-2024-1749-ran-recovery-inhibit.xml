<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1749 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 59fc6ebb-bb3b-5255-9970-899e2df4a4bd -->
  <rule id="757070" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1749 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>