<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3898 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: 7d93f139-c0e0-539d-90fd-c76249aa6402 -->
  <rule id="315031" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3898 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>