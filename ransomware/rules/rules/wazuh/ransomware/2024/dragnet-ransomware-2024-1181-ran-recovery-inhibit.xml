<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1181 — Recovery Inhibition (trinity) | Status: experimental | Sigma ID: 9a1a8ba7-d073-5438-bd24-c044c5302629 -->
  <rule id="446699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1181 — Recovery Inhibition (trinity)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>