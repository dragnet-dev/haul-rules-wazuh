<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3401 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: b3f04afb-92f6-5816-bf3d-f71c3b57bb39 -->
  <rule id="316874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3401 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>