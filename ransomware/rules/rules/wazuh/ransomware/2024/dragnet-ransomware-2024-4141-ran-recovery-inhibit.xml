<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4141 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ff4981a2-3fab-5109-abf7-1c28f8d7056f -->
  <rule id="854981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4141 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>