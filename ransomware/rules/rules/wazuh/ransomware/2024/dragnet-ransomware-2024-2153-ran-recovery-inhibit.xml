<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2153 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7f8ece74-6e4e-5619-90ff-6da2c28313e3 -->
  <rule id="838478" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2153 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>