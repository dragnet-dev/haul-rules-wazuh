<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1861 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 8100b5eb-31b0-546a-adac-efb967122a58 -->
  <rule id="496115" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1861 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>