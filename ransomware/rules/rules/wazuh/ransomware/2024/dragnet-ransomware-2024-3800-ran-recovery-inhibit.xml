<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3800 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: e64c9201-9e63-5645-aeb4-fefce75dcb23 -->
  <rule id="643692" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3800 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>