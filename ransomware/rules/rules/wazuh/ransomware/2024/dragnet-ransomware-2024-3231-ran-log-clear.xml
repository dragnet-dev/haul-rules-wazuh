<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3231 — Event Log Clearing (8base) | Status: experimental | Sigma ID: af191c0a-78b3-5bdb-8b4e-7f6b67aa63f3 -->
  <rule id="203068" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3231 — Event Log Clearing (8base)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>