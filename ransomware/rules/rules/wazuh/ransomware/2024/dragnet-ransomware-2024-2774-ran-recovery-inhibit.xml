<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2774 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 8de62087-87dd-5a71-b3c6-cd61a22bb043 -->
  <rule id="570620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2774 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>