<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4118 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2c7b647b-c0f1-5325-a717-55130e22f7b7 -->
  <rule id="963647" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4118 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>