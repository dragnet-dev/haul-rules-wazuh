<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2460 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: a23d3e26-027f-5517-8dae-1f330aa8c7f7 -->
  <rule id="921022" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2460 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>