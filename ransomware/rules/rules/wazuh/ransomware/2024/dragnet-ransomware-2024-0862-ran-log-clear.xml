<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0862 — Event Log Clearing (dAn0n) | Status: experimental | Sigma ID: 31b5abc9-065e-51c0-a663-30b2d1a7fb68 -->
  <rule id="499371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0862 — Event Log Clearing (dAn0n)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>