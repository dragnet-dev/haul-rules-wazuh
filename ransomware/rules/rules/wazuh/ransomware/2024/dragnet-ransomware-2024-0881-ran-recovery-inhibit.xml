<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0881 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: 2a707a5d-c43d-549e-bfcc-a0af6589eb12 -->
  <rule id="633225" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0881 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
