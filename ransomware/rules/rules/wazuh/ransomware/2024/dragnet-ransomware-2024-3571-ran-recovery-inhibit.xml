<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3571 — Recovery Inhibition (blackout) | Status: experimental | Sigma ID: 21d531b3-051d-5cde-a17c-897c185871b7 -->
  <rule id="292507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3571 — Recovery Inhibition (blackout)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>