<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3266 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3034eb26-0bd1-54b5-9e17-daffbe21cbc3 -->
  <rule id="669392" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3266 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>