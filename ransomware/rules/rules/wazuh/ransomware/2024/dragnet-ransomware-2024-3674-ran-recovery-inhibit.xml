<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3674 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: ab8d5805-c0b1-51fd-aee3-0bcfad6117d9 -->
  <rule id="150158" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3674 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>