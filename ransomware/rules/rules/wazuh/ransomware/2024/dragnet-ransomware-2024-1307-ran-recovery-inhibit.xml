<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1307 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: b3bff3e6-eac7-50d2-951b-98c76ae726ab -->
  <rule id="259193" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1307 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>