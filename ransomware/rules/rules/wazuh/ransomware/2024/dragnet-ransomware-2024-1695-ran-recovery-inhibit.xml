<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1695 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: f00a0e20-72b6-5f81-814d-9d255302b509 -->
  <rule id="341614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1695 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>