<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0078 — Event Log Clearing (argonauts) | Status: experimental | Sigma ID: f6029498-9579-5f47-9b28-d8ad86400c0b -->
  <rule id="760294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0078 — Event Log Clearing (argonauts)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>