<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1085 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: bf7c0cb6-f958-5f99-a6a4-a0b1a5212bc2 -->
  <rule id="509452" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1085 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>