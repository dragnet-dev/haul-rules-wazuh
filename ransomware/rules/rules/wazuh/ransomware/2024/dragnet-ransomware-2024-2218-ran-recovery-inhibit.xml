<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2218 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: cc25a5f1-21ed-5703-98b7-aac7b92f2510 -->
  <rule id="668105" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2218 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>