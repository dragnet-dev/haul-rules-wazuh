<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2717 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 8ca1fb38-d925-58c7-8c72-ba75e0850a2c -->
  <rule id="460507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2717 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>