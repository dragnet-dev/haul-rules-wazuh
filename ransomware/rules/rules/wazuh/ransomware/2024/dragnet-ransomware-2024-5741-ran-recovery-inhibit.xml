<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5741 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 9a7b7983-3957-5c4d-bae4-736c99945b56 -->
  <rule id="776379" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5741 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>