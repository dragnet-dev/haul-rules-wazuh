<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5232 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 59024ceb-08c8-5385-a5b0-695d6b0b3aab -->
  <rule id="810350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5232 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>