<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0029 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 3a872881-fabf-5669-9012-79c2a1e75de9 -->
  <rule id="587288" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0029 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>