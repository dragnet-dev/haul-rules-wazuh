<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4296 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 5b8641ea-6140-5005-9dac-468533dd6f02 -->
  <rule id="398270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4296 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>