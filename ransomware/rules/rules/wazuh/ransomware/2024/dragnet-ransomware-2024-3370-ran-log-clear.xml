<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3370 — Event Log Clearing (cicada3301) | Status: experimental | Sigma ID: 8f2f1c83-b820-5307-b6ee-8b134cc1dc88 -->
  <rule id="168348" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3370 — Event Log Clearing (cicada3301)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>