<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3142 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: bee21643-19bd-5adc-b617-64784b2673da -->
  <rule id="454216" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3142 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>