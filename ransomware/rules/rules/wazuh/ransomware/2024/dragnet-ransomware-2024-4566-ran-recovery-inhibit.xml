<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4566 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 20f5c449-8dc8-5c9e-973f-8938aaf3d0b9 -->
  <rule id="969244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4566 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>