<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4143 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2fa2ea8d-ce37-5b40-82c4-2d315823ba3e -->
  <rule id="251466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4143 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>