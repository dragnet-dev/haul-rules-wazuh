<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1105 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 08289547-c579-5521-86f2-8c0ce8333ab2 -->
  <rule id="289547" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1105 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>