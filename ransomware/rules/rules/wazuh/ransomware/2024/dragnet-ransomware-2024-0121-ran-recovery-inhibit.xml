<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0121 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1419aa3e-0746-5bad-b441-f24b02764879 -->
  <rule id="134343" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0121 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>