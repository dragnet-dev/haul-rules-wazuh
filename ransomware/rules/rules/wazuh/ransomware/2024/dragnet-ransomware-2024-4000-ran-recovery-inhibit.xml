<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4000 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 00f2a17d-8233-58c5-b423-192ec90aad56 -->
  <rule id="407485" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4000 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>