<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4737 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 987579a1-73ec-5865-a6b6-8ef4007b39f8 -->
  <rule id="601274" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4737 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>