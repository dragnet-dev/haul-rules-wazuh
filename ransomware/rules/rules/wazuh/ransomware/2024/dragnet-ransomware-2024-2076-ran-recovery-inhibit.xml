<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2076 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 04d02142-e26a-5197-b181-d65cf5204d77 -->
  <rule id="602142" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2076 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>