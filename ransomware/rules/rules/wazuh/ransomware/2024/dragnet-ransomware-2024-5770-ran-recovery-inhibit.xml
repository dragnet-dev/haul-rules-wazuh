<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5770 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 63984e45-63ff-5a70-b293-9b9a7213a6cc -->
  <rule id="223758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5770 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>