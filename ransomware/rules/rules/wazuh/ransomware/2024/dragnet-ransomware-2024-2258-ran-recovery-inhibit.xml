<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2258 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: 051de018-c7e7-5b39-aa2e-ead7051018a4 -->
  <rule id="527801" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2258 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>