<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2294 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 173480ca-0ef6-548d-baba-e659cbeb5bbf -->
  <rule id="175692" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2294 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>