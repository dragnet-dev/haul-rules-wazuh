<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4265 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6ead0e62-ad3c-50cf-9d5e-847fb56e9360 -->
  <rule id="133294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4265 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>