<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0683 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 99b87cff-1efa-56d8-a5b4-f45ca50e0dd1 -->
  <rule id="853404" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0683 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>