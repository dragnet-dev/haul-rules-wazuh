<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0566 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 75d0ef82-c328-5b51-a839-c2fa562914f5 -->
  <rule id="505519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0566 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>