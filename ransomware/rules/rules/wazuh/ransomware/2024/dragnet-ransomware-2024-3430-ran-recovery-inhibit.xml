<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3430 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6e3c0430-41ea-5621-a5c0-49ef3e53deb0 -->
  <rule id="966004" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3430 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>