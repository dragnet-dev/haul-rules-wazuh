<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5077 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 19d59db3-f2ed-52ad-9dff-71ce05925259 -->
  <rule id="130523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5077 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>