<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3075 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 61e99b42-1b67-595b-9959-2fa419a5a306 -->
  <rule id="785595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3075 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>