<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2971 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b47677e3-b9c0-5538-8e53-ffe4e97b0420 -->
  <rule id="347677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2971 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
