<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1214 — Event Log Clearing (play) | Status: experimental | Sigma ID: c4f52b5c-dcf9-56b1-a627-cfaa0c51bbd8 -->
  <rule id="599243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1214 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>