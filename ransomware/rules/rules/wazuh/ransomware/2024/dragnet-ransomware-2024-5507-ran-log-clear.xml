<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5507 — Event Log Clearing (killsec) | Status: experimental | Sigma ID: 7df4dcce-b1d7-56c9-8fc4-eaa8f09669a3 -->
  <rule id="759644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5507 — Event Log Clearing (killsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>