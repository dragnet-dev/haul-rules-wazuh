<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0124 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: bcbdef4e-3c6a-5905-be10-d75a5c73eedd -->
  <rule id="769391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0124 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>