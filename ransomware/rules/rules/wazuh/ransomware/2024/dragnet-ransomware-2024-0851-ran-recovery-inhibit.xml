<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0851 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 15871e0a-f99f-50ee-9ebd-92a8a804341f -->
  <rule id="839500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0851 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>