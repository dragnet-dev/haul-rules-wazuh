<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3828 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 390c29b6-caf7-58c6-9d63-28a13d5b1e9e -->
  <rule id="203675" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3828 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>