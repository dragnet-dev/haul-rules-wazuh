<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5360 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 404f80fd-dc33-50b7-a1ed-7797a7e6d8d4 -->
  <rule id="567695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5360 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>