<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4080 — Recovery Inhibition (madliberator) | Status: experimental | Sigma ID: 60b320a5-0feb-591f-a184-0a73483166a8 -->
  <rule id="341130" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4080 — Recovery Inhibition (madliberator)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>