<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5060 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 0b4c64ba-e4a4-56da-9a5b-be3f3d443371 -->
  <rule id="338635" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5060 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>