<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0930 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 425ae428-f06c-5fd6-8cd2-54da8c5956ba -->
  <rule id="289744" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0930 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>