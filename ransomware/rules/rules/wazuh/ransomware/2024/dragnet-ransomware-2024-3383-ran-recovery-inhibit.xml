<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3383 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 0f5784fd-cdb7-5831-aab0-7e8ab6253d44 -->
  <rule id="792559" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3383 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>