<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0810 — Recovery Inhibition (play) | Status: experimental | Sigma ID: fcadfd98-1b17-543f-8bbd-25d584b9eb5e -->
  <rule id="234975" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0810 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>