<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4037 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 20578ad6-723b-5a88-8610-7c49b9bb3297 -->
  <rule id="868141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4037 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>