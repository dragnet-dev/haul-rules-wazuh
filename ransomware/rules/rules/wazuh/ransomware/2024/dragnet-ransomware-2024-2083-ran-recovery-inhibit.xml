<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2083 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: a01557de-324f-5467-a889-b9f4bcdca0f8 -->
  <rule id="201557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2083 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>