<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3662 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 7907d0dd-431b-50a5-9c74-4460ca6f2cb3 -->
  <rule id="465250" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3662 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>