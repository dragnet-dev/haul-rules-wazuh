<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5988 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 5a0ae204-8fca-5248-b36b-52138c52fb6f -->
  <rule id="605742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5988 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>