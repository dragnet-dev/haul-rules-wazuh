<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1177 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 56351b3b-23b2-505a-9036-6357c246386d -->
  <rule id="116273" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1177 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>