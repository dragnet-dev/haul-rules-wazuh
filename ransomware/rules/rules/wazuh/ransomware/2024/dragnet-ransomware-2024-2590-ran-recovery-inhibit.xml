<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2590 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 8f957580-d1a0-5053-b96d-40e388cb2b29 -->
  <rule id="639575" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2590 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>