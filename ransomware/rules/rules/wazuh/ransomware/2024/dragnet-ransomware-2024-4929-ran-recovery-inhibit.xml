<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4929 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 881bf566-9fed-5ccf-8c08-8df313e745a3 -->
  <rule id="557275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4929 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>