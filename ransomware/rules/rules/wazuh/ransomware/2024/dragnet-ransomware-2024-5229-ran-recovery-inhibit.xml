<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5229 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6f41acaf-3a98-5ecc-ace8-279d6bec2149 -->
  <rule id="252268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5229 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>