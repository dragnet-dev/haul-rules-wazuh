<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3739 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 077897e4-c19b-5e0c-bcfd-e3d65a91df98 -->
  <rule id="446366" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3739 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>