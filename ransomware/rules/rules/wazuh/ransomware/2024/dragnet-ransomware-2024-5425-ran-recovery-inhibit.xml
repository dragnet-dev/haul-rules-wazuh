<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5425 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ae7c39ef-b8da-5a96-9b92-c03e41dadb9c -->
  <rule id="196439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5425 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>