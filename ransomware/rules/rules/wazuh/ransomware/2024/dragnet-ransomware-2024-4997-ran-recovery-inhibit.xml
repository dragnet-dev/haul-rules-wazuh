<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4997 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: a680d0e3-15e1-53b9-a668-a6ebd91240cd -->
  <rule id="908930" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4997 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>