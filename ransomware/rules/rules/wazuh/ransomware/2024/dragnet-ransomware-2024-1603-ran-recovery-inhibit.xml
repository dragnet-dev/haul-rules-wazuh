<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1603 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 22f1bcfb-7c27-5392-a79d-45b286ccec6c -->
  <rule id="739439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1603 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>