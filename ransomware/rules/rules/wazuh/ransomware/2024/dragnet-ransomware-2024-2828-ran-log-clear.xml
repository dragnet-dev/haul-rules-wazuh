<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2828 — Event Log Clearing (hunters) | Status: experimental | Sigma ID: fbb9b4e9-40f0-5f32-8a19-9e18d774e7b5 -->
  <rule id="244754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2828 — Event Log Clearing (hunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>