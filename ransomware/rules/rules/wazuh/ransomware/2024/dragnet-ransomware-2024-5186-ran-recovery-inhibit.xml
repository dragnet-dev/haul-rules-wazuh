<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5186 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 250571ba-35a2-5d24-879e-16c15e33c647 -->
  <rule id="509147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5186 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>