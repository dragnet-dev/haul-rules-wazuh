<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5122 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 58f0e36c-083c-5e0b-93cf-6f5308d8d225 -->
  <rule id="708943" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5122 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>