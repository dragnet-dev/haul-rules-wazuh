<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1726 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 28e1b191-55cf-51fe-ab3a-1ee5469b1603 -->
  <rule id="294719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1726 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>