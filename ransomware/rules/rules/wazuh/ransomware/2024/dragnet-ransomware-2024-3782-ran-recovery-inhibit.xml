<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3782 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b51fabe7-7fcd-55ef-a98a-1769f83cbc1a -->
  <rule id="318507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3782 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>