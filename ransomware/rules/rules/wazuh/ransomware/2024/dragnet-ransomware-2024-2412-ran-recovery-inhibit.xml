<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2412 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 1891415a-82d0-5fee-b945-5394986d651a -->
  <rule id="191415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2412 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>