<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5532 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 2c747296-7ac1-595a-ae7e-51f20ac88828 -->
  <rule id="974729" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5532 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>