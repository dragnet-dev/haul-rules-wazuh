<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1098 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 487eb598-076b-5037-8f2a-ad3126dfd378 -->
  <rule id="449075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1098 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>