<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5870 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 408fe8e5-854b-5153-8e76-f11c0fb693d5 -->
  <rule id="247028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5870 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>