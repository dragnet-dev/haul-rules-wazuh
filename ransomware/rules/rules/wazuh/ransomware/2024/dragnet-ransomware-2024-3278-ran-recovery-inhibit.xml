<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3278 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 90e69f79-2939-5e31-bd38-ec1ba394ae5d -->
  <rule id="627519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3278 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>