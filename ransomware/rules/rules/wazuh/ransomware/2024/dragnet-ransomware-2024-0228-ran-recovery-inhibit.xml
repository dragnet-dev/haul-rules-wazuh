<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0228 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 307be0c2-2c63-5e49-989a-88968ba617ec -->
  <rule id="105132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0228 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>