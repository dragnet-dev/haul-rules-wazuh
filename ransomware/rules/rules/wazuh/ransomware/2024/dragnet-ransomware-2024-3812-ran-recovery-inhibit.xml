<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3812 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 285ffe6b-d8ad-5034-8d3e-279371740922 -->
  <rule id="371454" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3812 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>