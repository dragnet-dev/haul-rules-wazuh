<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0103 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: ffa0a8ad-160f-537f-be5f-e39a3d34bc26 -->
  <rule id="344108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0103 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>