<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3749 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: bc51a2fe-6af0-551b-a70e-c59a3ff4f2bb -->
  <rule id="416262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3749 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>