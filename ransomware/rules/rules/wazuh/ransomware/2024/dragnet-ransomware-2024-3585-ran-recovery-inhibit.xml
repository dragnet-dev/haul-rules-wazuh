<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3585 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4358b427-175f-5299-a1f4-63fc85d7307e -->
  <rule id="773942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3585 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>