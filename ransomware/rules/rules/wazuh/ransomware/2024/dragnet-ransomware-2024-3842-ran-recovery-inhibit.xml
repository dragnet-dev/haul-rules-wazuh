<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3842 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: a9c05274-151f-557c-aa00-0153b621ad7e -->
  <rule id="956052" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3842 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>