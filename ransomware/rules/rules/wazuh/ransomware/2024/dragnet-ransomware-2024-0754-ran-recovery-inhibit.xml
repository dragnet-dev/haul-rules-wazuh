<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0754 — Recovery Inhibition (chort) | Status: experimental | Sigma ID: 26386223-09c3-50da-8211-eeef93d512fe -->
  <rule id="938622" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0754 — Recovery Inhibition (chort)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>