<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3411 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: 3c595b51-f531-5de6-aa2a-68cf9de9a2f3 -->
  <rule id="795315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3411 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>