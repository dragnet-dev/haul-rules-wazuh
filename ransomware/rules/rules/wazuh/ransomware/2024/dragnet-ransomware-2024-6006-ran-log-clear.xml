<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6006 — Event Log Clearing (snatch) | Status: experimental | Sigma ID: 692f4cdd-5c34-5afb-991e-0c0ae9bdd1e1 -->
  <rule id="973996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6006 — Event Log Clearing (snatch)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>