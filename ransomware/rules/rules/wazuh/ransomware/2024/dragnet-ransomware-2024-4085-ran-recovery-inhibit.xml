<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4085 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: c24e47d2-e5fa-5e11-933b-13a6f7b9f398 -->
  <rule id="259847" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4085 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>