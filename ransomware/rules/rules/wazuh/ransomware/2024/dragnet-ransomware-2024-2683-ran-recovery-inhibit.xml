<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2683 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: f7ea2879-f25f-518f-95a0-e1c7d57eb1ea -->
  <rule id="542628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2683 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>