<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3910 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 1b732a6c-93b5-5a5f-a5a2-a4b8c8da1907 -->
  <rule id="937226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3910 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>