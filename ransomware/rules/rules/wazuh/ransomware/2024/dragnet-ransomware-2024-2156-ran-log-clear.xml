<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2156 — Event Log Clearing (raworld) | Status: experimental | Sigma ID: 7e293a8d-ee9e-55c6-ac00-b12c7fbbc398 -->
  <rule id="320698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2156 — Event Log Clearing (raworld)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>