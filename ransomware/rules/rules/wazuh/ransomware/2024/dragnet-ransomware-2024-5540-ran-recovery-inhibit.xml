<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5540 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 10c9b7f4-d524-50e7-8b5e-7aeea40c3065 -->
  <rule id="928127" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5540 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>