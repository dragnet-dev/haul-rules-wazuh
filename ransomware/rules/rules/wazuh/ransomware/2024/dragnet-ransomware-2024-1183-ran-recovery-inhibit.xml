<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1183 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e2aaad88-a768-5401-850e-2d0d50ba139b -->
  <rule id="449805" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1183 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>