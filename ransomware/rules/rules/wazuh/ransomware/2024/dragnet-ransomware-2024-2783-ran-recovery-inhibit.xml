<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2783 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6734477a-0a44-5c40-8452-8a93789c27ee -->
  <rule id="534477" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2783 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>