<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2060 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 5ec02d08-0712-5cee-a97f-a67a2cf79864 -->
  <rule id="725645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2060 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>