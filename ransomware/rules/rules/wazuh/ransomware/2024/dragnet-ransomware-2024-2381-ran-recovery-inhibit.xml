<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2381 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a506a6a6-d204-5a87-8391-9a02f9b8d340 -->
  <rule id="881066" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2381 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>