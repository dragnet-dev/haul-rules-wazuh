<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0461 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b214219f-fe50-55b4-a8ea-c0b2c31d3956 -->
  <rule id="321421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0461 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>