<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5454 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: bc63f835-9352-5ec8-a279-12cf77ac8eda -->
  <rule id="418238" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5454 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>