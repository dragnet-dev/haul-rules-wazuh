<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5209 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 3bc8929e-7d55-5d5f-86a7-0a55262345b6 -->
  <rule id="668929" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5209 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>