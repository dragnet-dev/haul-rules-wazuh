<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1076 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a4f6d0cd-a311-571e-a2b2-255b8ed95d0c -->
  <rule id="987490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1076 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>