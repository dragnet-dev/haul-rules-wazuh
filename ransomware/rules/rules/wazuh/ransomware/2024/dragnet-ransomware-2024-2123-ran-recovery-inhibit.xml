<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2123 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 59a8ffc2-f47b-53c1-840b-5aa191e41087 -->
  <rule id="744543" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2123 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>