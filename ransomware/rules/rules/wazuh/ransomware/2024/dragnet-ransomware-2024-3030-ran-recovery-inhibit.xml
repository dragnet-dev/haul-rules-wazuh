<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3030 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 33b8392d-6c70-5be8-aadf-be81fd21b141 -->
  <rule id="998392" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3030 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>