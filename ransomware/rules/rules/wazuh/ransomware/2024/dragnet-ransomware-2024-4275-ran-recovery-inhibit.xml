<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4275 — Recovery Inhibition (coinbasecartel) | Status: experimental | Sigma ID: cfbb7ea1-d4a1-5e51-abfe-409fbc237021 -->
  <rule id="508766" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4275 — Recovery Inhibition (coinbasecartel)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>