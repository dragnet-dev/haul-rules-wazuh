<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1788 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: 4b3ff9e5-bfa8-5d6e-9972-dd39622ed11e -->
  <rule id="230239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1788 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>