<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1228 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: a912170f-b2cd-51af-8400-7a5b168da604 -->
  <rule id="291217" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1228 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>