<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5627 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 9c2a24a7-bc32-5bff-b945-db6b9a97b398 -->
  <rule id="800224" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5627 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>