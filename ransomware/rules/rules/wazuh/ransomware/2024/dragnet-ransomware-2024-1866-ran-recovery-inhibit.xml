<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1866 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 2ea1c7ba-fb9e-517f-9cfc-aa8c7cb6672d -->
  <rule id="393887" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1866 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>