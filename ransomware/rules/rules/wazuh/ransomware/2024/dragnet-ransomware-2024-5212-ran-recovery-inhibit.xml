<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5212 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f40b0e2a-cb7a-5f95-94df-14ae4dfcaf8a -->
  <rule id="444174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5212 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>