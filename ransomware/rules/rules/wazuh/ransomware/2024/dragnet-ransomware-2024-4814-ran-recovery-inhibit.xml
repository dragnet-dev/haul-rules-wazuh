<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4814 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 23766e3c-c599-5c7a-946c-4869d7c2e6a2 -->
  <rule id="302703" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4814 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>