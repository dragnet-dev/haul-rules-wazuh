<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0306 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 17c388c8-b84e-5b8b-b4be-9b242eb4b09a -->
  <rule id="150220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0306 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>