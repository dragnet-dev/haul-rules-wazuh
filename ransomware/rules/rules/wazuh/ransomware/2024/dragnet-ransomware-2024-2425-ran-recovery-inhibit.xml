<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2425 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b883af3c-09d1-529a-9205-c99a3d1ca80f -->
  <rule id="442223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2425 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>