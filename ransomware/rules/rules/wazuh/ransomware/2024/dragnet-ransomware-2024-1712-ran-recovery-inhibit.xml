<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1712 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: b6c90dfe-9140-5f8e-a116-0b2e77bddf6d -->
  <rule id="390253" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1712 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>