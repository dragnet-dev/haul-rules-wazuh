<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3831 — Recovery Inhibition (play) | Status: experimental | Sigma ID: af7f97bd-69d8-59c6-870a-b89dbd8f6aac -->
  <rule id="212797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3831 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>