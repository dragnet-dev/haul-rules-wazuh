<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1265 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: a17fdf12-b560-5f2e-b174-bb70354425d9 -->
  <rule id="669695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1265 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>