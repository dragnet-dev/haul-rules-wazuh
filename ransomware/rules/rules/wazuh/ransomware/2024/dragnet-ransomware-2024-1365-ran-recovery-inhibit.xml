<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1365 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 7d4bf17a-a3ca-55ee-8e7d-17ae6bf66933 -->
  <rule id="612151" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1365 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>