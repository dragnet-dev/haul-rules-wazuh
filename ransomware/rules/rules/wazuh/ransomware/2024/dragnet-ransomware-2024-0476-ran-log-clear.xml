<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0476 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 3f32942d-c7c8-5a17-b2e4-e3c5e3ef4910 -->
  <rule id="132942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0476 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>