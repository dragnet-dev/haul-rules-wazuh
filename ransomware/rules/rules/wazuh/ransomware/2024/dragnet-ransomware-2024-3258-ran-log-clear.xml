<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3258 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 0811eeaa-e0e2-5809-bbb7-5e72fb1d0e16 -->
  <rule id="725674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3258 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>