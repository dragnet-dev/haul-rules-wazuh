<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2690 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 1cff5bdf-077a-5544-9911-7675da655b77 -->
  <rule id="387771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2690 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>