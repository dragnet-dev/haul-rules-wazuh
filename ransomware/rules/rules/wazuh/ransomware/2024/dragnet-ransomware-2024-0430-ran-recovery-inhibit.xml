<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0430 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2973eb49-f05b-58ab-83fc-8056c05e85b3 -->
  <rule id="513234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0430 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>