<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2362 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: b987c384-bd7c-5c45-9a1c-4476dba937c7 -->
  <rule id="218043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2362 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>