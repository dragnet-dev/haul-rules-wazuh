<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5370 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: d0000495-0a99-56d1-b59a-69ab1c7ac2d2 -->
  <rule id="500004" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5370 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>