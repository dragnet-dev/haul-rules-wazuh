<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1623 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: f9ba9d4f-8f5a-536c-a11a-0d5f2aaf1f5f -->
  <rule id="342557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1623 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>