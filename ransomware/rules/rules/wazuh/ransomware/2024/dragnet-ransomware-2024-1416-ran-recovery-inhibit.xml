<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1416 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f748c552-877d-5ac8-b8e1-77896dac4f37 -->
  <rule id="819805" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1416 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>