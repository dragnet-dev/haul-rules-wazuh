<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4596 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f9641aa1-b237-53d0-8cec-1e6688a93a7f -->
  <rule id="854266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4596 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>