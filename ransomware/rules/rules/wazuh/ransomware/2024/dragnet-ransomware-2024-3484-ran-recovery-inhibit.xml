<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3484 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: a0460739-0704-5984-999e-fc50dd04bae4 -->
  <rule id="204607" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3484 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>