<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3875 — Event Log Clearing (everest) | Status: experimental | Sigma ID: 1a9fa8f7-4818-5ead-981f-34a708ace381 -->
  <rule id="358383" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3875 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>