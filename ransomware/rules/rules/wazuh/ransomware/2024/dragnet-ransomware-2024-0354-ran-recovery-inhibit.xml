<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0354 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 0fdc17f3-d02e-5c5e-9f3d-fe24810c40d5 -->
  <rule id="296287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0354 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>