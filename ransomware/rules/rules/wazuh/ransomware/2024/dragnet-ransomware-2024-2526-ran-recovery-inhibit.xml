<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2526 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4205a61a-c2d6-50fe-9e0c-8e10f89ff14e -->
  <rule id="529061" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2526 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>