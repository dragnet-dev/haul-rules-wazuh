<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5871 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 44996a43-4a35-5f6b-a674-6b8c26296164 -->
  <rule id="999464" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5871 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>