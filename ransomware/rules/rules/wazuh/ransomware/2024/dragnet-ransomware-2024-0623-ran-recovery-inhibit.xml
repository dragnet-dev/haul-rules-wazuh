<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0623 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 20d9db36-64c6-5e36-83fd-a049a8041ff1 -->
  <rule id="550033" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0623 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>