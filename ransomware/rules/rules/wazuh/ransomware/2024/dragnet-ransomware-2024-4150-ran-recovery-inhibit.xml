<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4150 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 60835bfd-b81b-58ce-9020-5794afb13de2 -->
  <rule id="373951" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4150 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>