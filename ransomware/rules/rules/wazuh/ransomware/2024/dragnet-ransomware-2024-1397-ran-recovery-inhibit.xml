<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1397 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 50fda3ce-ee0c-5393-bb48-cf43deb13782 -->
  <rule id="388583" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1397 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>