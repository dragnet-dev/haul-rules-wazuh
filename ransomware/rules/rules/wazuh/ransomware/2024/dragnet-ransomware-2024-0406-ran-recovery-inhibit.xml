<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0406 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3c69d8ee-77da-55dc-8d3d-39ae5bae502f -->
  <rule id="338862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0406 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>