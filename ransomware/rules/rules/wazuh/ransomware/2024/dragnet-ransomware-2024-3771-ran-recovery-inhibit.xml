<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3771 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: 52d07b2b-764f-5ab7-ad64-85589a7feded -->
  <rule id="552123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3771 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>