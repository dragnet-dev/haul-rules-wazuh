<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1161 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 0a9b59e6-492d-57df-a1df-04136bfe59c7 -->
  <rule id="208958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1161 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>