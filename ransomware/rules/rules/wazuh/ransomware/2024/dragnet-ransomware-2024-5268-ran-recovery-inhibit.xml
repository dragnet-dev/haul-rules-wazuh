<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5268 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: fb13bda9-ee83-508a-9c7c-11db0ef1b387 -->
  <rule id="229117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5268 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>