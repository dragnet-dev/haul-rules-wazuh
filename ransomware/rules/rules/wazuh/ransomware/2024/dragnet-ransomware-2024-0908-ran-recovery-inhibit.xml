<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0908 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 59ce73b9-e3a8-5837-995e-53ad9bb48ddc -->
  <rule id="731073" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0908 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>