<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4923 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 53dde729-fcb2-5f97-8812-4c41136a03cb -->
  <rule id="506387" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4923 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>