<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2506 — Event Log Clearing (8base) | Status: experimental | Sigma ID: cb38b465-6ecf-5f0c-9e45-c8da3d6f50f8 -->
  <rule id="654194" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2506 — Event Log Clearing (8base)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>