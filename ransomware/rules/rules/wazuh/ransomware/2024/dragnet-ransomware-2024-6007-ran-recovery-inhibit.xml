<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6007 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: deaa5789-073f-5509-a939-b5fb4d018d81 -->
  <rule id="400257" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6007 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>