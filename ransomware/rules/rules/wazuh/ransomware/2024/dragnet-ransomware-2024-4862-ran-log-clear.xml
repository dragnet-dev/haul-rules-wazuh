<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4862 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: f57549f0-06e2-53a6-81a8-5ab8dbb02c0f -->
  <rule id="757549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4862 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>