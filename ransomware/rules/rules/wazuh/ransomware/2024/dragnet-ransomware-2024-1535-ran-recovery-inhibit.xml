<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1535 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 10929a25-079e-5039-b7c9-87bf3807f21a -->
  <rule id="948742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1535 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>