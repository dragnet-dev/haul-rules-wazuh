<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0575 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 236d037f-8432-56a3-bbf7-19de8e91d706 -->
  <rule id="289037" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0575 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>