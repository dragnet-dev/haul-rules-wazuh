<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2369 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: f2b9e269-9322-5f71-bb18-3f560514364d -->
  <rule id="410382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2369 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>