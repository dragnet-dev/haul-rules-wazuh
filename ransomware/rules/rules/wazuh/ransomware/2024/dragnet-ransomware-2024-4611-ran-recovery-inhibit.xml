<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4611 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2791864e-256e-5284-a2b1-8ccdb98c7ee3 -->
  <rule id="191864" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4611 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>