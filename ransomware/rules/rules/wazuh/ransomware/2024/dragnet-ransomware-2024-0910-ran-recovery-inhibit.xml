<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0910 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 279bb991-f8aa-571b-9d30-bf662e739095 -->
  <rule id="961199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0910 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>