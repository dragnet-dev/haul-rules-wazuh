<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1347 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: f3174f93-ce38-5e98-a8f9-147e8106cafd -->
  <rule id="750799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1347 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>