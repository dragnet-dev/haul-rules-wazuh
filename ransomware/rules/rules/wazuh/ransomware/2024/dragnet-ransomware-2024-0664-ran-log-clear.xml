<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0664 — Event Log Clearing (blackout) | Status: experimental | Sigma ID: 3c66a2e7-d9ef-54cc-89f4-4f09e328c375 -->
  <rule id="330606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0664 — Event Log Clearing (blackout)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>