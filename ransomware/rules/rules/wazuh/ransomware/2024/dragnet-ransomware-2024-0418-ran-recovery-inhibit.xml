<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0418 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 313f3798-6526-5d47-86f7-8a321a1270d6 -->
  <rule id="623379" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0418 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>