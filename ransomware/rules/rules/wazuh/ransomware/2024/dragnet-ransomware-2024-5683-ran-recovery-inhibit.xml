<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5683 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c1ce27cf-1df3-5cc0-ba8e-bd028c38b162 -->
  <rule id="518227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5683 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>