<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3517 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 7badfc53-95a1-50d3-9107-adf791ec8000 -->
  <rule id="105468" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3517 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>