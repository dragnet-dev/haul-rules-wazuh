<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4269 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 83d550af-32d4-5640-9681-6108d6eef013 -->
  <rule id="541550" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4269 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>