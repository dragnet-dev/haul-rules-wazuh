<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1777 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 2bcfe07b-b91f-5e8e-b877-5ede177f4de6 -->
  <rule id="994540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1777 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>