<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1145 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: 0a53d40e-f44a-56b7-8e2a-6e4ebaf0e1c9 -->
  <rule id="886140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1145 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>