<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4883 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 12c55167-8f57-5d36-b98a-e1c7d78ff97b -->
  <rule id="345516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4883 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>