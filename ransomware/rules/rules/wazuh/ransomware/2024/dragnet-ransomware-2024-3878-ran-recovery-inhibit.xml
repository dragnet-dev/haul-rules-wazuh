<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3878 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 90fd8d70-2cac-51f7-a010-d93bdb65b9ae -->
  <rule id="227021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3878 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>