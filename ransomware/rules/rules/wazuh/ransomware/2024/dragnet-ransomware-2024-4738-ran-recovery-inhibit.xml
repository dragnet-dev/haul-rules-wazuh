<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4738 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: ff8158bd-bf55-59cc-9bcf-ed530db6eb4c -->
  <rule id="858158" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4738 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>