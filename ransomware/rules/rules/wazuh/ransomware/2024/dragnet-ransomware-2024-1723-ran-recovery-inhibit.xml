<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1723 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 51d4ca86-2787-528c-9cf2-477e6c72a76a -->
  <rule id="423466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1723 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>