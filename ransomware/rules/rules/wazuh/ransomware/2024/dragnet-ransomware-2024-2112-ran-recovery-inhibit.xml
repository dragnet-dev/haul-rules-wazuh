<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2112 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: edc66c58-371d-538a-9ac2-4411a0e548dc -->
  <rule id="787468" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2112 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>