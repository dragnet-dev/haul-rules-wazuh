<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3466 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0c9854b7-60b3-580c-a361-86dd788cc522 -->
  <rule id="377675" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3466 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>