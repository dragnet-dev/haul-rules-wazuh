<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3482 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 3f3d3d08-1afc-574d-8276-acfe5cd1afdf -->
  <rule id="822621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3482 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>