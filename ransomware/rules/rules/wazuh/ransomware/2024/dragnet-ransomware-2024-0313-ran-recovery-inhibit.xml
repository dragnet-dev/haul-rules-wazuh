<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0313 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 64122346-2511-5046-927e-585ced1707bd -->
  <rule id="212234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0313 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>