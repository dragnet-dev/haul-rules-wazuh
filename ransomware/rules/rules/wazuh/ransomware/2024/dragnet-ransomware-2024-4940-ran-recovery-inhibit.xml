<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4940 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 1261f805-6934-5111-b451-8ee6e2500f9c -->
  <rule id="319180" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4940 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>