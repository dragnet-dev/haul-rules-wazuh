<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5626 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1f59df58-6a9c-5e7d-9542-c0beb3e186f6 -->
  <rule id="989275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5626 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>