<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5008 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: f8502645-b155-59f6-bb8b-d4d3f9fc1a37 -->
  <rule id="785026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5008 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>