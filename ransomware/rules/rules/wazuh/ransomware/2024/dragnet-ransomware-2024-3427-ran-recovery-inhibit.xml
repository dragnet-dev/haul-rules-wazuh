<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3427 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 1cf2218f-bc0d-53ea-a7ff-fbcec044a5f9 -->
  <rule id="232218" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3427 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>