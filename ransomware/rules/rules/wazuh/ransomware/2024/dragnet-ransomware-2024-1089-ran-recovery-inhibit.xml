<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1089 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e74800f1-96fc-5826-952e-7eff5a5771c0 -->
  <rule id="674800" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1089 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>