<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2602 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8b7b1261-1b89-5c35-869e-074026942a32 -->
  <rule id="536312" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2602 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>