<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1020 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: fc21e7cb-2438-51e5-acfc-b551a6bf5aa2 -->
  <rule id="535507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1020 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>