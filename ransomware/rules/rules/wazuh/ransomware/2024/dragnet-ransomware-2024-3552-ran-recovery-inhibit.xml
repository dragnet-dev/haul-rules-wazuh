<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3552 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 512464e7-f835-5849-9535-e2bf390bdb1b -->
  <rule id="199438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3552 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>