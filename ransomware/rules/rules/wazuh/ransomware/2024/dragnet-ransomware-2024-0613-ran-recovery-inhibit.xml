<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0613 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c8bd4b95-417e-580a-b8e8-795f92aeb751 -->
  <rule id="873195" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0613 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>