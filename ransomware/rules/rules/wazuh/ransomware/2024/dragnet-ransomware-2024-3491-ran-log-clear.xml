<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3491 — Event Log Clearing (funksec) | Status: experimental | Sigma ID: 81c3bc0e-42d6-5b3f-8e0b-3d07631f71a7 -->
  <rule id="749436" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3491 — Event Log Clearing (funksec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>