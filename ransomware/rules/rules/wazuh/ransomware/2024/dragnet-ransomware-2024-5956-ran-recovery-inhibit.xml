<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5956 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 5daec791-5429-52f2-b8e8-76dd9a8f7e18 -->
  <rule id="337247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5956 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>