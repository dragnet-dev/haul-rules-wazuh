<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3980 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 7258300d-c123-5aae-84b1-42bede819b76 -->
  <rule id="158300" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3980 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>