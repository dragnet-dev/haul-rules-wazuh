<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1484 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 8d798e6c-bfc5-5f59-a2e4-00b9814284ca -->
  <rule id="568782" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1484 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>