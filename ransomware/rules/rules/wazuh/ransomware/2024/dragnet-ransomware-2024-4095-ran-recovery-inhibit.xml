<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4095 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c57e5b03-d813-5ac2-8ba8-f5a4b7a3bf10 -->
  <rule id="620251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4095 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>