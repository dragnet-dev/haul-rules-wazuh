<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5136 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 62d960df-0dec-5a9e-8272-37d846c6960f -->
  <rule id="205960" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5136 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>