<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5286 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e7e9af0d-c772-52a3-8cc2-d643f5268ce8 -->
  <rule id="759439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5286 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>