<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0620 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: f7441fd2-614a-5031-bb65-5e51f14d276f -->
  <rule id="819071" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0620 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>