<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2859 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 0d4721fd-b9f2-5ce8-b231-684b71a72d69 -->
  <rule id="455551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2859 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>