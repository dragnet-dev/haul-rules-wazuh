<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0410 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 1c5e2603-2ec0-5f20-a88c-f3c405fb5423 -->
  <rule id="174260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0410 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>