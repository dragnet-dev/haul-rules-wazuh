<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5477 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: b6d7fe51-ad7a-5cd3-8e37-d067edd14138 -->
  <rule id="386686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5477 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>