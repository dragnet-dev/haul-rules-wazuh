<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1724 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6e36ae87-2ace-5cc5-92ae-756f8f3909f9 -->
  <rule id="225390" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1724 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>