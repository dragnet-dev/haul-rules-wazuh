<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0403 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 7ab2c2e9-62dd-5747-bfe6-8ed637ba5e22 -->
  <rule id="541242" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0403 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>