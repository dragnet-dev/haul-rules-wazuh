<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0170 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 319040c8-e286-56be-b77d-a6352baa90a1 -->
  <rule id="704652" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0170 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>