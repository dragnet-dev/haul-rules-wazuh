<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1743 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 57c692f5-dbbf-5beb-883b-4d953cb89a48 -->
  <rule id="495087" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1743 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>