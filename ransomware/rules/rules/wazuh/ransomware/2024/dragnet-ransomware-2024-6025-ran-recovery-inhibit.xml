<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6025 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f14dcbac-e8cb-53a2-9f03-6b7eeb7969d4 -->
  <rule id="904875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6025 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>