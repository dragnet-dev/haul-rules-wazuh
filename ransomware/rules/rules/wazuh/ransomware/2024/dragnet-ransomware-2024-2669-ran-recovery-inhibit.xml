<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2669 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 454a1786-f3cf-52b2-bf1b-949d4859107d -->
  <rule id="174178" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2669 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>