<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5383 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 459d8fc1-f0b1-5170-93f2-4ef184614053 -->
  <rule id="377263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5383 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
