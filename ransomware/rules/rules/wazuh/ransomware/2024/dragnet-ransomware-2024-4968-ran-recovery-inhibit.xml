<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4968 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: ed0fa375-1c05-5f15-8571-b6620a33c318 -->
  <rule id="769703" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4968 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>