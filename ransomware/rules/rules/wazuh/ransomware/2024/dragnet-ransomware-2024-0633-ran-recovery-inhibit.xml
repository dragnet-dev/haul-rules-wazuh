<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0633 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: fd29bfa9-c8e8-581c-8c6f-dc824170b127 -->
  <rule id="284415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0633 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>