<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0532 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5f7583a6-adcf-567c-b87f-b0e9fd12a073 -->
  <rule id="121338" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0532 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>