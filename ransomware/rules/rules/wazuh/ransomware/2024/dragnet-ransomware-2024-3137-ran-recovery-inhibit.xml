<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3137 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 35b71d8d-9bce-5f13-bdc7-dd576990d2e1 -->
  <rule id="247498" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3137 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>