<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3081 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f46e4aef-7493-51eb-992b-9e22f57c5995 -->
  <rule id="460074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3081 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>