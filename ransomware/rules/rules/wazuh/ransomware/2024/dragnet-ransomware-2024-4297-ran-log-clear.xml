<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4297 — Event Log Clearing (dragonransomware) | Status: experimental | Sigma ID: cb834aa0-4166-5078-aa00-f29685f8079e -->
  <rule id="661354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4297 — Event Log Clearing (dragonransomware)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>