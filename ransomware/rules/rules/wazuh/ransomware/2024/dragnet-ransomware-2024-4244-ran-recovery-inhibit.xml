<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4244 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 65e07766-0a1c-5391-ba94-4318bd087f74 -->
  <rule id="254077" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4244 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>