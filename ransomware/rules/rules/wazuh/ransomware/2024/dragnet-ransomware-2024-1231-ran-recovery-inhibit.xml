<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1231 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 3670361f-1a64-5881-b932-1937b1055afe -->
  <rule id="170361" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1231 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>