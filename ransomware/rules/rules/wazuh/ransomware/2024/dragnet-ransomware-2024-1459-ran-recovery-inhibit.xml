<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1459 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c94cc9af-c3b0-53c2-9064-7221586e4bff -->
  <rule id="714689" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1459 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>