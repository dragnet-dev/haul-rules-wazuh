<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3129 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: baadebb6-8596-5e41-8a62-49562dc8db84 -->
  <rule id="634219" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3129 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>