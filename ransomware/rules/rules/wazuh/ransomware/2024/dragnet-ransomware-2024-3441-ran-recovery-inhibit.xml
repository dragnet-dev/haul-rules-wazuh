<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3441 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 600493d0-b07d-5a51-86cd-2c7d5756d95a -->
  <rule id="707901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3441 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>