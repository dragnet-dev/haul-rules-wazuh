<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4756 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 850276cc-0b4a-5cfb-9108-444adfa69ab2 -->
  <rule id="204428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4756 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>