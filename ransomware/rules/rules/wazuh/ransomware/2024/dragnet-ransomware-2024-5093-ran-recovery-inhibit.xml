<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5093 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: f745edd9-eef0-5e2c-add2-5965c311d305 -->
  <rule id="530957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5093 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>