<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0518 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 867701ad-bf91-5925-85a4-d5c24a55fbae -->
  <rule id="483226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0518 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>