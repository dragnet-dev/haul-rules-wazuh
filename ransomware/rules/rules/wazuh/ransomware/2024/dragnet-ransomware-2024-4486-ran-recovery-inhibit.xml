<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4486 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: fb0a5d4a-bce7-54e5-a74d-c08bf661dbda -->
  <rule id="227293" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4486 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>