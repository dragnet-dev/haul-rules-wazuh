<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4482 — Event Log Clearing (dAn0n) | Status: experimental | Sigma ID: c2b30aad-35fa-578c-8199-741b4f678fad -->
  <rule id="541290" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4482 — Event Log Clearing (dAn0n)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>