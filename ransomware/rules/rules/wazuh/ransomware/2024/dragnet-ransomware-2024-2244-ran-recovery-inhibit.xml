<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2244 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1522b631-37f9-58cf-b5d1-2aab4f703129 -->
  <rule id="736363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2244 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>