<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5969 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 7cfbf42f-50f9-5164-bf36-c78084fdd542 -->
  <rule id="719354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5969 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>