<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2477 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: cdabf59e-f1ed-5a2a-b3db-61483fb6ad34 -->
  <rule id="424315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2477 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>