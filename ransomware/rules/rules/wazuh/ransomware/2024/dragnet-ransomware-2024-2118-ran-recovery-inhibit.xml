<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2118 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: ee6f47cd-e804-5d7d-8e66-bc23b8f11452 -->
  <rule id="319147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2118 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>