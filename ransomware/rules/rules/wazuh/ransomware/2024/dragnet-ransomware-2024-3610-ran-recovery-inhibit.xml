<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3610 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: b7b802de-0a01-57a4-8296-7e45e30113b5 -->
  <rule id="183802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3610 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>