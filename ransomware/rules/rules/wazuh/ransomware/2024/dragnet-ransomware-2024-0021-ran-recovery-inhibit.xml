<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0021 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: fb0d4dc5-2db9-574b-b7fa-3f35183bcb0a -->
  <rule id="227757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0021 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>