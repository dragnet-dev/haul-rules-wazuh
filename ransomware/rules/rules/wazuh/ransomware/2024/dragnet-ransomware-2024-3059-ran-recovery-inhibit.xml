<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3059 — Recovery Inhibition (mallox) | Status: experimental | Sigma ID: 476c58f6-6a61-5a28-89fe-c99b4ff7c25a -->
  <rule id="605743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3059 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>