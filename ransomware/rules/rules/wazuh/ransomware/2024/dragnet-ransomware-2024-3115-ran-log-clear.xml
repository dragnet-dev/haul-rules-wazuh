<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3115 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 96e0fce3-5171-5a3e-ac0f-e3e919bcbc39 -->
  <rule id="468252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3115 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>