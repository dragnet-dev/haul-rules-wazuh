<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4534 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 17ac492f-8db6-55db-966f-a6cce7739338 -->
  <rule id="124492" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4534 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>