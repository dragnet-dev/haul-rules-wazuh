<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0601 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 3fe6280c-dd1c-5dfc-86b8-b61d10d86e26 -->
  <rule id="222628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0601 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>