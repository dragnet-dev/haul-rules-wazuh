<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3792 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 80b8f48c-133a-5633-95ed-02dc7634cd01 -->
  <rule id="367034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3792 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>