<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2873 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6b74f6b4-b430-5ee3-aaab-1bfe55b0b2d7 -->
  <rule id="923996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2873 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>