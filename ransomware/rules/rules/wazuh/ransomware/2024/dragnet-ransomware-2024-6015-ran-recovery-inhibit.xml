<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6015 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 17d02862-e9f9-534e-93ab-7bed181575eb -->
  <rule id="250286" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6015 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>