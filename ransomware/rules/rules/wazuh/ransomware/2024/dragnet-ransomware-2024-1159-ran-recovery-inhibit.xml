<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1159 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 8a14a664-cb54-5d4d-860b-006f0eaabbad -->
  <rule id="510346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1159 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>