<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0646 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 9fe24202-a76b-525d-9154-df0dda7e202d -->
  <rule id="858242" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0646 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>