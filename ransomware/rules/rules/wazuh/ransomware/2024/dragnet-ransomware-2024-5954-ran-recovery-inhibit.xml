<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5954 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 459eb8b0-04ba-5183-a910-2873016959cd -->
  <rule id="377398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5954 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>