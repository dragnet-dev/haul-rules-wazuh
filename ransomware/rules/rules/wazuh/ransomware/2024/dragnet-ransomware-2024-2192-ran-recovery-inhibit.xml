<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2192 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: ee759928-a434-5999-bf0d-267479134eb4 -->
  <rule id="687599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2192 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>