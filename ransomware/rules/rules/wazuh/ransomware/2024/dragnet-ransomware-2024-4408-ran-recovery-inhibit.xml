<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4408 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 3fb24b40-809a-5810-9403-f8d38787e202 -->
  <rule id="830795" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4408 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>