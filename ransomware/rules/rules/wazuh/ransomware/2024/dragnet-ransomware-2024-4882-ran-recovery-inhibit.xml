<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4882 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 816bcfa8-10eb-562f-80a3-4b46d48ddeb9 -->
  <rule id="745359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4882 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>