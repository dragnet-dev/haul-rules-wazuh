<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1356 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 05021c2b-4303-51b5-a4fa-3757c6fd4e34 -->
  <rule id="355723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1356 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>