<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2481 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f5afc19b-4766-5e42-a9a8-8652fba608ef -->
  <rule id="176921" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2481 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>