<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0659 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ff19beb7-46d2-5ca6-bbf4-20e3c5a18f4f -->
  <rule id="333054" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0659 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>