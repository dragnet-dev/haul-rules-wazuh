<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5078 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 10ce14db-b738-5db4-a52d-45f499a5db73 -->
  <rule id="925837" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5078 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>