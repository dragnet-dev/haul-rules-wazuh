<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0211 — Event Log Clearing (everest) | Status: experimental | Sigma ID: 2cb98a48-8a1a-58c7-bd06-0d9b7a6377a9 -->
  <rule id="345578" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0211 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>