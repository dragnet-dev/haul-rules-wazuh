<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5373 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: ca98f0cb-5286-58ca-ba6d-1f4e2e53c9a2 -->
  <rule id="647830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5373 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>