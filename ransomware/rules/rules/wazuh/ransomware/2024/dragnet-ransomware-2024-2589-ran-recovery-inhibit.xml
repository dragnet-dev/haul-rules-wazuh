<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2589 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 4cf312af-82c5-50bc-9e78-6ae65a512cd9 -->
  <rule id="431312" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2589 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>