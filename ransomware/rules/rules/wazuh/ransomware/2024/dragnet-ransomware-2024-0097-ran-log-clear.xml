<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0097 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 5764d0f1-14c0-5ca8-8982-1bb53f46c22c -->
  <rule id="457935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0097 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>