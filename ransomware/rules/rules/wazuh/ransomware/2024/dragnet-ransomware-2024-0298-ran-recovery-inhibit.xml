<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0298 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: cd5f80c4-96e4-51e7-98f8-f5f1367fa228 -->
  <rule id="689580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0298 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>