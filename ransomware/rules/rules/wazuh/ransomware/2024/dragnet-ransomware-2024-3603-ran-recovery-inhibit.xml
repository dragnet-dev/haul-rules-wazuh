<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3603 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: abcb76b7-d3d2-5932-b608-70e4105e3811 -->
  <rule id="897976" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3603 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>