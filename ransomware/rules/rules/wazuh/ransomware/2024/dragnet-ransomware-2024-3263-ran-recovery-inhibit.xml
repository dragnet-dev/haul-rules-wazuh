<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3263 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 1c2125a2-9f77-5710-b16b-ccaa5cdd0afb -->
  <rule id="114010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3263 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>