<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0893 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: ba731287-530f-5d2c-b174-870c4bc28e96 -->
  <rule id="167312" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0893 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>