<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0371 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: e6874a24-b714-5c37-924b-e76b5be3c058 -->
  <rule id="649994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0371 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>