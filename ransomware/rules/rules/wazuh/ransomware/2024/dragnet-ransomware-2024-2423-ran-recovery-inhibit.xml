<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2423 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 021718c3-8f5b-56e4-a123-5a3192143515 -->
  <rule id="875003" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2423 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>