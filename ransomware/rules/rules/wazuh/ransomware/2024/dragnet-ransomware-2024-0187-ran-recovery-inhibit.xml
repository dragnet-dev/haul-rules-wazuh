<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0187 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 09b91b50-2306-5831-b06a-31ffd133785e -->
  <rule id="794675" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0187 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>