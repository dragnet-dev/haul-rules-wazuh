<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3149 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 1dc38083-ade0-550a-85e9-bd6ab0f6d4c2 -->
  <rule id="363808" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3149 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>