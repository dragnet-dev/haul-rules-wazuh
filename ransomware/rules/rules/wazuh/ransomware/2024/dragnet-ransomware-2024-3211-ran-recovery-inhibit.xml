<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3211 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: a034a544-e2fb-583a-b748-3d44a40f7caa -->
  <rule id="805545" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3211 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>