<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4955 — Event Log Clearing (hellogookie) | Status: experimental | Sigma ID: b3720a47-5c6b-5a77-b190-b12c36cb485f -->
  <rule id="119530" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4955 — Event Log Clearing (hellogookie)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>