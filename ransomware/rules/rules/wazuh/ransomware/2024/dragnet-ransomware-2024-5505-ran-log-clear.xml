<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5505 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 8d05d2d3-f125-5bc6-819c-65f91c4f17c4 -->
  <rule id="556932" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5505 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>