<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1317 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: 554bc6e8-b1dd-523c-b8f8-c75564fb31de -->
  <rule id="620126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1317 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
