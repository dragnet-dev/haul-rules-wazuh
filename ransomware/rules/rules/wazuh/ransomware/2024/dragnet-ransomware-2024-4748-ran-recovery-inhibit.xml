<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4748 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 900e41fe-e973-577b-9596-c92d4f7d32fd -->
  <rule id="641441" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4748 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>