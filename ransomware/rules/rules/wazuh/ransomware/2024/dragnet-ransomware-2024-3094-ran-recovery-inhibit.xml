<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3094 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 1c64fa82-7a01-5a14-8a74-8374f9081fd3 -->
  <rule id="234348" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3094 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>