<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2636 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 3eb7ac25-e90f-583b-8388-a51dc0f37522 -->
  <rule id="869644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2636 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>