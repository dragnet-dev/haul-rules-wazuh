<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3020 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f647c11b-f87d-5bb9-87bc-e857effcaf4f -->
  <rule id="803641" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3020 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>