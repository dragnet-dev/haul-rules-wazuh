<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1048 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 5207a3ed-caaf-543d-bd8f-ad18f5b4fa34 -->
  <rule id="831582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1048 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>