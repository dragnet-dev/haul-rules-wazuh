<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4109 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 6ba3eb27-f61a-5c6b-ac98-92038119d86d -->
  <rule id="909323" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4109 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>