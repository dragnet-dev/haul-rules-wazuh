<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3228 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4ba3d795-1268-58a3-be58-cb57af73689e -->
  <rule id="236617" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3228 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>