<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1016 — Event Log Clearing (dragonransomware) | Status: experimental | Sigma ID: f58dee95-4375-5819-9de6-0f0e09a9a761 -->
  <rule id="185134" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1016 — Event Log Clearing (dragonransomware)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>