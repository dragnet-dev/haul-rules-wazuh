<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0230 — Event Log Clearing (redransomware) | Status: deprecated | Sigma ID: 1740b0f5-e25f-5ae8-9420-d03538b2fb8c -->
  <rule id="956175" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0230 — Event Log Clearing (redransomware)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>