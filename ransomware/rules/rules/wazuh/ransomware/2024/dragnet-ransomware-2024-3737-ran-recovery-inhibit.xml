<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3737 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: bdcd2296-6c0e-564d-8ddc-5b1c404fba56 -->
  <rule id="458922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3737 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>