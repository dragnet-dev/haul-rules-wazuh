<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1592 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 5ad2094a-3d6c-5a88-ae0c-aaa2eaef4c38 -->
  <rule id="653209" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1592 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>