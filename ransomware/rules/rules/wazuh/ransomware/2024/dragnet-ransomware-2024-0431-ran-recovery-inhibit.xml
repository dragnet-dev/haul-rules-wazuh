<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0431 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 08499c7b-5bf7-5023-a3d9-29c645eb8286 -->
  <rule id="559967" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0431 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>