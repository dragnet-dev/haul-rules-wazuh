<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1568 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 711283e5-5ab9-550c-a184-6e5e9653b1ed -->
  <rule id="680542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1568 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>