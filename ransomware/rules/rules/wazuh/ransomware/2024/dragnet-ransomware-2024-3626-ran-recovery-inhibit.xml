<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3626 — Recovery Inhibition (play) | Status: experimental | Sigma ID: fda4aa82-76c3-586b-a658-49b18ab90f54 -->
  <rule id="589674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3626 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>