<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5903 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 2dbcffeb-62e8-546c-a28b-dc60989f20cd -->
  <rule id="397503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5903 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>