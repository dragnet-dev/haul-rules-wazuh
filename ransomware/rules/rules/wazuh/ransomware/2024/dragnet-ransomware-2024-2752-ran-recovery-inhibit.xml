<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2752 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 538e89f5-02e6-5440-bcc4-685f0f57ed15 -->
  <rule id="396639" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2752 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>