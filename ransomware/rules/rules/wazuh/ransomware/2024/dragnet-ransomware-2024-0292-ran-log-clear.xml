<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0292 — Event Log Clearing (sensayq) | Status: experimental | Sigma ID: 9ec23166-fc08-532e-b7aa-bcc2989ad2bf -->
  <rule id="840231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0292 — Event Log Clearing (sensayq)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>