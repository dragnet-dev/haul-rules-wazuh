<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3032 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 8f69e7e9-8cad-597a-8942-6c3737d20bd8 -->
  <rule id="599187" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3032 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>