<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4309 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 84b51768-55b4-56d1-8d00-5f0583e4fa44 -->
  <rule id="555517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4309 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>