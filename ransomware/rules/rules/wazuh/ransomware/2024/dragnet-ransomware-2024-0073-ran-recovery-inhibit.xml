<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0073 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1f39b67b-7f73-5d8b-ba62-586e491b76e0 -->
  <rule id="623567" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0073 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>