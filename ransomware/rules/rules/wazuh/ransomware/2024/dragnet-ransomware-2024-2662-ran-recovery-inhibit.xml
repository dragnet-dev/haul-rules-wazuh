<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2662 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 5f470a77-1373-57d0-9443-664d4159d9f1 -->
  <rule id="727530" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2662 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>