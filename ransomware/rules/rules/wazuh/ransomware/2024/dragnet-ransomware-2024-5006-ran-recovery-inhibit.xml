<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5006 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: bf3cdad7-1469-5acc-987e-abf163e2109b -->
  <rule id="738938" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5006 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>