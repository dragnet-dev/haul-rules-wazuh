<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1037 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c0458e5f-8676-5082-8dac-53878a1364e5 -->
  <rule id="227342" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1037 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>