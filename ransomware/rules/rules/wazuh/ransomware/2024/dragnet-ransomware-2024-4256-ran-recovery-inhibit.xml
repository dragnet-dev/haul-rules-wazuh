<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4256 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c13e1076-115d-594a-bc52-9863893b0627 -->
  <rule id="242210" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4256 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>