<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0446 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 51faadf7-8872-58c3-b645-af2fe463c30f -->
  <rule id="806509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0446 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>