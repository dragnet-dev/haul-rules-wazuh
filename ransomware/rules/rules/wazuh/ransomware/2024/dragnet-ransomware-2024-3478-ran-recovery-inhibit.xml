<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3478 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: cb5af4e9-4835-5fd3-9389-bab4a1ffd68f -->
  <rule id="811354" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3478 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>