<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5457 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 34b43ec4-f97c-501b-8969-3b86e0873261 -->
  <rule id="819244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5457 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>