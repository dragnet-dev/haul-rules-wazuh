<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2311 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: bfb90b0a-5b4c-5cb8-9bdd-8b747f810f0d -->
  <rule id="508651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2311 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>