<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2353 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 1a55d65e-74cb-56e5-a05c-93558cb3dc0b -->
  <rule id="749365" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2353 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>