<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1394 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 23337480-7dab-5b45-9399-6ec72cb7e362 -->
  <rule id="633748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1394 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>