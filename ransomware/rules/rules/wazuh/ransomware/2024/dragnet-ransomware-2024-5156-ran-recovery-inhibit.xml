<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5156 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: cb988983-2ff6-5068-820e-115851af078e -->
  <rule id="339889" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5156 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>