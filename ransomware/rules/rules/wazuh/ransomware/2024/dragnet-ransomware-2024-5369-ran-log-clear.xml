<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5369 — Event Log Clearing (blacklock) | Status: experimental | Sigma ID: 0ea97ceb-0ed8-5fec-b19e-e5d9b9044a25 -->
  <rule id="715438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5369 — Event Log Clearing (blacklock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>