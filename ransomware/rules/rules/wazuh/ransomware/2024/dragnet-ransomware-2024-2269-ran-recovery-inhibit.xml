<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2269 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ef64fe02-7b8a-5251-b7b6-280a293b1a5f -->
  <rule id="835038" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2269 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>