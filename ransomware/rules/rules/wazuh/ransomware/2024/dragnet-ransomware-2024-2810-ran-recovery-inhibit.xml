<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2810 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 03c5a74c-1157-5172-92f8-5eddade20267 -->
  <rule id="305196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2810 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>