<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5297 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 02d8ea17-89b7-5144-bc25-ae4f2990aef9 -->
  <rule id="374821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5297 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>