<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0210 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1e502cb3-df6b-5da9-b812-af481c248ca1 -->
  <rule id="708715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0210 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>