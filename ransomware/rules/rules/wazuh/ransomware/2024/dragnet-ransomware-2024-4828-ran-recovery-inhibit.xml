<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4828 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 796ff21b-9957-5b8b-a18a-6c5e89ff9a15 -->
  <rule id="340312" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4828 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>