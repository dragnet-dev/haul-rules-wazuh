<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1563 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 3cd3060b-c29a-5961-8c9b-8cba1d799309 -->
  <rule id="833060" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1563 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>