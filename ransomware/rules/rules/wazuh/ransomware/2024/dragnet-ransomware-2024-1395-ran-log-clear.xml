<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1395 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 072b7f40-910a-5c4f-9a8d-fe8d495d50ae -->
  <rule id="162074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1395 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>