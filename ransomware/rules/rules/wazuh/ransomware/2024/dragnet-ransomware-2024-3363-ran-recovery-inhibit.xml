<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3363 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: a167b19b-48ae-566f-a755-dbf14ff38a77 -->
  <rule id="826831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3363 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>