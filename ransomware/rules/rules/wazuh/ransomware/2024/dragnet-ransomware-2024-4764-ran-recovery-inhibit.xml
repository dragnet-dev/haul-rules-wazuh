<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4764 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1f0391db-b41a-5065-b738-cbfdd5482ed7 -->
  <rule id="566269" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4764 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>