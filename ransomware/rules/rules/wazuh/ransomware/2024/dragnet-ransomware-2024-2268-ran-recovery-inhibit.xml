<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2268 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 755e01c6-ff8a-5110-a0bb-877c79a7aa04 -->
  <rule id="409401" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2268 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>