<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3007 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 8bcc8a13-634e-58b7-951d-ef37e6612268 -->
  <rule id="426218" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3007 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>