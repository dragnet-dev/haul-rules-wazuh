<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3553 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: bf997280-92f2-5e76-9334-60fe6ce3ba93 -->
  <rule id="219972" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3553 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>