<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0895 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 468141fc-46ae-562d-80ed-b43c4807bcad -->
  <rule id="390271" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0895 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>