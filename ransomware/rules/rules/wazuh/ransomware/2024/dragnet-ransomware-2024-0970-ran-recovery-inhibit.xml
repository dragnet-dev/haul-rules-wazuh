<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0970 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 6b49fc89-1fb2-5c81-9e59-ae7cdf4fb768 -->
  <rule id="151996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0970 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>