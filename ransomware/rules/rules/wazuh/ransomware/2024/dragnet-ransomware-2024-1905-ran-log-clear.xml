<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1905 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: 56af4e48-5a0f-5a80-ac35-e1a8c9a281a6 -->
  <rule id="621838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1905 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>