<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3696 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 90548fc3-41a6-5d6c-9cbe-3ee43e5c3b61 -->
  <rule id="648783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3696 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>