<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1555 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e00bbf98-93a7-5bff-9201-687be2c3ad44 -->
  <rule id="437407" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1555 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>