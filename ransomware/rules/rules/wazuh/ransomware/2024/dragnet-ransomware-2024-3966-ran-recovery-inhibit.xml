<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3966 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: e17cd973-daa9-5446-b5af-f60be640ea3e -->
  <rule id="129579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3966 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>