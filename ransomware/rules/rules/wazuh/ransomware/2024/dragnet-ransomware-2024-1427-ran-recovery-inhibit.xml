<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1427 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 103a6a9b-f351-5f0d-8a64-ff46430232ed -->
  <rule id="953869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1427 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
