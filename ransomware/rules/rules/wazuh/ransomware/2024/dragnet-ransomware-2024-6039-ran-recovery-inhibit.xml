<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6039 — Recovery Inhibition (ransomcortex) | Status: experimental | Sigma ID: 941cc16e-5853-55bf-8a4e-cc519ee8e92c -->
  <rule id="711001" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6039 — Recovery Inhibition (ransomcortex)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>