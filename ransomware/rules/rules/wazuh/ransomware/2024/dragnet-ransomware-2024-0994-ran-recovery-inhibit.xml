<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0994 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 4d812251-6278-5cb7-89ef-03038dbc60ae -->
  <rule id="681225" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0994 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>