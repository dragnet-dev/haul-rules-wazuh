<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5237 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 6dd3f5e2-9874-5020-b718-b6fdd48cfc08 -->
  <rule id="211835" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5237 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>