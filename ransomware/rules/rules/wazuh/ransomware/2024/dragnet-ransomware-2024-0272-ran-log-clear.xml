<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0272 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: ff66a1ba-1b3a-5a80-95e4-2d3d5705552b -->
  <rule id="590661" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0272 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>