<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4564 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 48d415c2-3a70-5d33-afba-c4e6c99c7227 -->
  <rule id="902652" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4564 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>