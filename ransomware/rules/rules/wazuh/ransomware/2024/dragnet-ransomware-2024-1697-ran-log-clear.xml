<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1697 — Event Log Clearing (vanirgroup) | Status: deprecated | Sigma ID: 39dac79f-2083-535d-bfcf-cb9092e1a617 -->
  <rule id="832447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1697 — Event Log Clearing (vanirgroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>