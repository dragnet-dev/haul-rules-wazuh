<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1684 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1af49c82-126c-5e71-bb45-49a466247567 -->
  <rule id="703968" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1684 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>