<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1130 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 5e3f1911-63f3-52d5-84ae-cda0a6ab39a6 -->
  <rule id="710319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1130 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>