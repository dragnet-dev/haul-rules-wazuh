<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5841 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: b3ad0d86-ce5d-5d85-b6ac-a0c23eca04f3 -->
  <rule id="256173" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5841 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>