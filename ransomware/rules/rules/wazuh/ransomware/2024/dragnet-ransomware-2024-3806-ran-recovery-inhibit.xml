<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3806 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 562d2041-7214-5d33-8af1-4e507894870c -->
  <rule id="105204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3806 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>