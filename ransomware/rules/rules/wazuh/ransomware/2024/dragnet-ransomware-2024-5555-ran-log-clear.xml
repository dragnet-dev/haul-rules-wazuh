<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5555 — Event Log Clearing (stormous) | Status: deprecated | Sigma ID: 2b2c04d0-c0e7-507c-9968-0b18c65f66e7 -->
  <rule id="378477" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5555 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>