<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2563 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 79cfc508-007b-5108-ac79-ceed4e4d26d7 -->
  <rule id="669085" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2563 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>