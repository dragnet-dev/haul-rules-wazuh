<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5662 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 90b249a8-502a-5e23-b392-12e8623c7a7b -->
  <rule id="651249" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5662 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>