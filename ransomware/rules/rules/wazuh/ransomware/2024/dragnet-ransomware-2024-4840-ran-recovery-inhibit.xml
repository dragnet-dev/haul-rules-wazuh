<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4840 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 308dae1d-6b44-586d-906c-9913d9b7c7e4 -->
  <rule id="465070" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4840 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>