<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0974 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b353b94c-8f0c-53c3-a087-0eff842199db -->
  <rule id="116599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0974 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>