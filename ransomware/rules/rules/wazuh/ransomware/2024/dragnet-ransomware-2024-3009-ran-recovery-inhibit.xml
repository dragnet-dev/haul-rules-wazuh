<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3009 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 4293989f-4759-58da-9c64-bb94d93f76d8 -->
  <rule id="793989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3009 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>