<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2718 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 633b7db7-bf06-501c-b821-fc0df5804507 -->
  <rule id="822365" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2718 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>