<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0356 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: c756962d-9813-50e8-9c26-8feab75ae87e -->
  <rule id="475696" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0356 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>