<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1476 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ee2a8e3a-267e-5c8c-af61-e6bc846dd5ab -->
  <rule id="799662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1476 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>