<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1772 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 9ecb0628-1e44-5151-9677-1c85397811c8 -->
  <rule id="565106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1772 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>