<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0409 — Event Log Clearing (playboy) | Status: experimental | Sigma ID: 461a119e-fabf-595f-9015-ea5aec72825e -->
  <rule id="286119" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0409 — Event Log Clearing (playboy)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>