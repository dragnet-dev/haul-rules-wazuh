<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1666 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 32db1d29-5f45-5f58-90d8-cbc227abab99 -->
  <rule id="545789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1666 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>