<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6036 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: c36a3b6c-2ad9-5dbf-8db1-3890f64f117d -->
  <rule id="565819" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6036 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>