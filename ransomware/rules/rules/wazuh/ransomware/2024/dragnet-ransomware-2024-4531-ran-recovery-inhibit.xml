<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4531 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: c60bf214-c396-5bf3-91fc-4a36bc09a817 -->
  <rule id="627512" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4531 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>