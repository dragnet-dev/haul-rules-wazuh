<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4268 — Event Log Clearing (stormous) | Status: experimental | Sigma ID: 1aca2cd6-c06e-5a5f-86ed-4febdbf1edf5 -->
  <rule id="297324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4268 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>