<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0637 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: da6cd6e9-f5fd-5abc-8838-d8906165c905 -->
  <rule id="298216" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0637 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>