<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3433 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 324b8678-e57d-53b7-9738-e44f48b0e907 -->
  <rule id="795867" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3433 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>