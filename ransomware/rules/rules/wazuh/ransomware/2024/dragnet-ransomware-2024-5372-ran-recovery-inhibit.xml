<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5372 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 043237a3-1908-5044-b5df-515452019f43 -->
  <rule id="718023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5372 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>