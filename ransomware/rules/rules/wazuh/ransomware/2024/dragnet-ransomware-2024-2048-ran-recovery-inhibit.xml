<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2048 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d3e41071-8e89-56e2-94fe-263c47d4ae01 -->
  <rule id="442410" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2048 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>