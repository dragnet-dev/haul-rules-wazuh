<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5993 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 9b5f6c95-4688-5de8-b40e-ee33b1814fd0 -->
  <rule id="483308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5993 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>