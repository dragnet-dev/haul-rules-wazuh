<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3347 — Recovery Inhibition (madliberator) | Status: experimental | Sigma ID: b24ad924-5b58-5474-a4b1-213f135ed360 -->
  <rule id="279179" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3347 — Recovery Inhibition (madliberator)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>