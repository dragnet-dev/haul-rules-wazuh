<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4916 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d458d587-23fb-5eaa-81a1-a484562cfd45 -->
  <rule id="453415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4916 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>