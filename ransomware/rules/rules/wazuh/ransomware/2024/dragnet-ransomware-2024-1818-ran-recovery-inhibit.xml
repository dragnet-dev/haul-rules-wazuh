<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1818 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 9cac1c2d-4d00-5409-8504-a2d07c3d9e9d -->
  <rule id="217308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1818 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>