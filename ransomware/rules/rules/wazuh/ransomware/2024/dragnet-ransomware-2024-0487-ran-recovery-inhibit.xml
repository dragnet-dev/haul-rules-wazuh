<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0487 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 69d7d383-f591-564e-a5fd-23d5c675fc53 -->
  <rule id="988453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0487 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>