<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4549 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7ceb8352-c826-59ce-ad75-3a4935771f70 -->
  <rule id="597983" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4549 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>