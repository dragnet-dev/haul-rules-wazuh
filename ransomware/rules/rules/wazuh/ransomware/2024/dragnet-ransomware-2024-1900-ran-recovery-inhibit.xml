<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1900 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 0fe36de2-8b16-5c9f-ba07-7f6cf2c929fd -->
  <rule id="311838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1900 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>