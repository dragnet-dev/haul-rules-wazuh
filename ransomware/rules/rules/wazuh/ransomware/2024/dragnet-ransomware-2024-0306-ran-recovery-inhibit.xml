<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0306 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8aa6b0bd-919e-5ff9-8ccd-9f5efa938331 -->
  <rule id="949870" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0306 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>