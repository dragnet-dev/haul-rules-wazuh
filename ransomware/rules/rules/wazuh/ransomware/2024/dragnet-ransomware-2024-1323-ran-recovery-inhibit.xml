<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1323 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 166f9aa8-4fa9-58eb-ae38-eca14f2a87a0 -->
  <rule id="640234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1323 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>