<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3371 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 38b99e21-df64-53f1-b0d2-e0bf2fdba839 -->
  <rule id="119982" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3371 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>