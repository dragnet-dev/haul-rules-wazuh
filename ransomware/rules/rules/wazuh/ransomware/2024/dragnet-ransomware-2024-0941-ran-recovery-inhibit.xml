<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0941 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: cff59eea-1b0d-5d5f-a052-e8498bf0b227 -->
  <rule id="924158" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0941 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>