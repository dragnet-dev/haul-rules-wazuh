<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3095 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 9e005442-816b-5618-827f-b7ec29c58ee8 -->
  <rule id="780054" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3095 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
