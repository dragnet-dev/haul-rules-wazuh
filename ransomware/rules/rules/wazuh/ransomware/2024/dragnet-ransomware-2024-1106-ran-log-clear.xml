<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1106 — Event Log Clearing (abyss) | Status: deprecated | Sigma ID: 00d5bbf0-5b52-5a2a-9ed6-758f8d7f73e9 -->
  <rule id="259670" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1106 — Event Log Clearing (abyss)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>