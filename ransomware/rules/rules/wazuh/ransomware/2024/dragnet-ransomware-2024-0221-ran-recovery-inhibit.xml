<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0221 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e23546a5-6f65-5a6d-b600-feb6ba6a5330 -->
  <rule id="623546" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0221 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>