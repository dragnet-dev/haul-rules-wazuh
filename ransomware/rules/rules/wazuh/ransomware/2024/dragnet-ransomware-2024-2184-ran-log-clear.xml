<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2184 — Event Log Clearing (ElDorado) | Status: deprecated | Sigma ID: 026126d7-6cb3-540c-ad7e-8d9d559ce6fa -->
  <rule id="680297" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2184 — Event Log Clearing (ElDorado)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>