<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0389 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 54d5daa5-d0d2-5e68-9532-a42db9dadec7 -->
  <rule id="546618" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0389 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>