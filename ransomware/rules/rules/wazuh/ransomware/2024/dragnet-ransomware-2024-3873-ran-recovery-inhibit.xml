<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3873 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: b082a365-ec85-5ca8-acef-cbf2f9932160 -->
  <rule id="973223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3873 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>