<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0802 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 1c5029e4-8cc3-5ad9-97ed-10c6c1e39ca7 -->
  <rule id="160478" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0802 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>