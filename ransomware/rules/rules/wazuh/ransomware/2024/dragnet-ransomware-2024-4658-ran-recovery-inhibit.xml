<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4658 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 0343f821-f808-5b83-b5fa-338f77437d5b -->
  <rule id="203821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4658 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>