<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4160 — Recovery Inhibition (embargo) | Status: experimental | Sigma ID: 2555af27-19ec-5307-b338-5e18dc773b04 -->
  <rule id="342552" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4160 — Recovery Inhibition (embargo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>