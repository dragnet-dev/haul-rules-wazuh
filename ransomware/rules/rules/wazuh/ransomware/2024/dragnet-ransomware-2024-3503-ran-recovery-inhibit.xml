<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3503 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: dd34a26e-1a8f-5083-b53a-347b8b82ab61 -->
  <rule id="941542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3503 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>