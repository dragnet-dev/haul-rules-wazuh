<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0674 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f5973cbe-2046-5f1b-ac6e-ef8a1186e9a8 -->
  <rule id="795580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0674 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>