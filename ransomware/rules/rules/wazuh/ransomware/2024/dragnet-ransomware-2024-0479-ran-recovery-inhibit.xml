<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0479 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 502c7bf1-fd07-53c0-9517-959be4931996 -->
  <rule id="487163" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0479 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>