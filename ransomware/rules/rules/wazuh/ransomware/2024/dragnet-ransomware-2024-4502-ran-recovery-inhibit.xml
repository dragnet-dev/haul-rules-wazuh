<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4502 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: c8859634-783e-5d2f-9d0d-a4b8e208d1e0 -->
  <rule id="488596" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4502 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>