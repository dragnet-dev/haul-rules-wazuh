<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3130 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: f8354ed6-30c0-5128-9a8a-a9d005865758 -->
  <rule id="833678" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3130 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>