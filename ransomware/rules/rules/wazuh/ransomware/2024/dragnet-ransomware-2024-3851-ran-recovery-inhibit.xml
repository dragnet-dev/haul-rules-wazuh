<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3851 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4fc0392e-21d3-5f06-bd4a-3045329893fb -->
  <rule id="476039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3851 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>