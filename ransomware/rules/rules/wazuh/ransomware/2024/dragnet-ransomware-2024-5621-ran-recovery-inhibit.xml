<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5621 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: a039fe75-86e4-5ac2-b8cd-ffba1d2a2b1a -->
  <rule id="870238" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5621 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>