<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0035 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 8f998121-d774-5dc1-a2c1-2b81d2448c81 -->
  <rule id="639981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0035 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>