<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2982 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: c123a478-9cf2-590d-b56e-1cb419de74f8 -->
  <rule id="239784" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2982 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>