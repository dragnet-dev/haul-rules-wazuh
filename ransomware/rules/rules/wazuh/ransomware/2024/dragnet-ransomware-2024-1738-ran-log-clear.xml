<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1738 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 0e3de762-b2c5-506f-9df2-6800a9cebf0e -->
  <rule id="183076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1738 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>