<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4278 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ca5dbdc1-c928-55db-95bc-563fd937326a -->
  <rule id="297917" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4278 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>