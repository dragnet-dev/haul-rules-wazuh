<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5562 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9f6ff75c-b715-51d8-b9b6-d6a492ae98d8 -->
  <rule id="588317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5562 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>