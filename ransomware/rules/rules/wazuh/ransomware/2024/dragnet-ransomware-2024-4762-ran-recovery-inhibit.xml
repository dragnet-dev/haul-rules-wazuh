<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4762 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 8a6d82cc-d61d-52a2-aa61-1cb3e91c0abe -->
  <rule id="518982" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4762 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>