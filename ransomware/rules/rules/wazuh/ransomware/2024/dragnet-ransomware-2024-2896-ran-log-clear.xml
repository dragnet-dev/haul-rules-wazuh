<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2896 — Event Log Clearing (spacebears) | Status: experimental | Sigma ID: e69ffb74-f57f-5b34-88ce-ba9e4af8a2fa -->
  <rule id="721115" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2896 — Event Log Clearing (spacebears)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>