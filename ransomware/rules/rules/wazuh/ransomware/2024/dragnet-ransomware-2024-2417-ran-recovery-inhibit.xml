<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2417 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 68b79441-5976-53b6-8906-2534808521c7 -->
  <rule id="299794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2417 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>