<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2361 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: c84d64b1-65da-5ecf-934a-5668caea3170 -->
  <rule id="355764" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2361 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>