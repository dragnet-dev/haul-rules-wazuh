<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3837 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: d3c5c148-83e0-5a95-8000-b852d91d02c6 -->
  <rule id="824921" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3837 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>