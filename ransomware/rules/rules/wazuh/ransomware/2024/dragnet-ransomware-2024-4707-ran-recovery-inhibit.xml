<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4707 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: 10414e32-a45b-563d-b533-f2aa7f16ef47 -->
  <rule id="866383" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4707 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>