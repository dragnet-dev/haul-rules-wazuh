<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1676 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: fb63f240-41d8-5dac-b3e1-58efcbbe3e12 -->
  <rule id="526232" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1676 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>