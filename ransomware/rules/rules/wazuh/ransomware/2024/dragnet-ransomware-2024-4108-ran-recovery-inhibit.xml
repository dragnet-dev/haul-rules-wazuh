<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4108 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 7ada850e-a4ac-5585-bd20-7658794f42d8 -->
  <rule id="545085" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4108 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>