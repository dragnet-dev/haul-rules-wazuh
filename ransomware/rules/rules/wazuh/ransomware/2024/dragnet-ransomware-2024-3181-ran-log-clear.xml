<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3181 — Event Log Clearing (vanirgroup) | Status: deprecated | Sigma ID: 25c1aa8f-ceca-5f58-b336-38b9a83f679c -->
  <rule id="255146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3181 — Event Log Clearing (vanirgroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>