<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2586 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e04ba003-bb77-52b6-8f9e-0bec964806d0 -->
  <rule id="996100" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2586 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>