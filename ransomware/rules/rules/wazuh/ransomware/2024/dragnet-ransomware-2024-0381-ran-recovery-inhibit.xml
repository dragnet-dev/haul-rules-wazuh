<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0381 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 7a347660-bf23-58b6-b87b-f1d53aec0100 -->
  <rule id="423476" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0381 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>