<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4111 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 9d8a8dbd-ae4e-5af7-9731-eaf7e289a7ff -->
  <rule id="541421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4111 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>