<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1040 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: fa175f29-8fb2-5c84-995a-99dbf9486b41 -->
  <rule id="502815" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1040 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>