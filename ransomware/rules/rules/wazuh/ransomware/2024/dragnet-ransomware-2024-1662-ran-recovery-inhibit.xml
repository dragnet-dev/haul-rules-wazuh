<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1662 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 5add4b47-fbac-5720-a3b9-8b2f79b3486c -->
  <rule id="221835" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1662 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>