<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3703 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7c082103-3cbf-52f9-8445-8ee119502977 -->
  <rule id="440821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3703 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>