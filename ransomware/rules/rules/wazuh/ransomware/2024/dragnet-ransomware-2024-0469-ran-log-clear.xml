<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0469 — Event Log Clearing (arcusmedia) | Status: experimental | Sigma ID: f9e3e5c9-dff3-54a1-8a84-abc4c36942f8 -->
  <rule id="593425" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0469 — Event Log Clearing (arcusmedia)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>