<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2723 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6827bc96-06c5-5767-98fb-bee9a4a0a621 -->
  <rule id="947900" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2723 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>