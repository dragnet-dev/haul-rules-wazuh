<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3630 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 5a124360-e0fe-5503-b72f-b00bfe9cde02 -->
  <rule id="112436" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3630 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>