<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3122 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: c30b607a-a3e6-5d10-931c-c7f4a89d2442 -->
  <rule id="269160" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3122 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>