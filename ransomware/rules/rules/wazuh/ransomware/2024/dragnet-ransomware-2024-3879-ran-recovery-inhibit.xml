<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3879 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: e3c0812e-8c4f-5f4b-8c80-716ed272dc21 -->
  <rule id="600081" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3879 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>