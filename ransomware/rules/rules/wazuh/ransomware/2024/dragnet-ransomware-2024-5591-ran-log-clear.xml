<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5591 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 2928cb9b-5d7c-5b65-a880-eb3817e2c42c -->
  <rule id="397719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5591 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>