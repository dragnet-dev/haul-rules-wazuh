<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4102 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 5190dbed-c1b3-5edf-b37b-f95dd96b19ff -->
  <rule id="528859" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4102 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>