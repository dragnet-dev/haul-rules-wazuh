<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5086 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: fb17a18b-ab52-54b0-bb5b-a26dbc1ba869 -->
  <rule id="518821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5086 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>