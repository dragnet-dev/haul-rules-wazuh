<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0453 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: cfa03e02-dd42-5c3a-9eaf-9464ec08074d -->
  <rule id="915262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0453 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>