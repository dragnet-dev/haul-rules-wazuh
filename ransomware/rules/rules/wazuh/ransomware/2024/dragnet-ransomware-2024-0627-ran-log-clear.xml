<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0627 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: 2f304b5d-92f4-5e63-9f27-52fddc086bd2 -->
  <rule id="468755" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0627 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>