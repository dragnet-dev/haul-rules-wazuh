<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1187 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 5350105a-3dc6-5897-aa63-4474e9f2bdb3 -->
  <rule id="950105" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1187 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>