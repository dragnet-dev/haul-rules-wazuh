<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0024 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: da576193-c849-5e28-9087-d2dd1df64266 -->
  <rule id="485761" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0024 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>