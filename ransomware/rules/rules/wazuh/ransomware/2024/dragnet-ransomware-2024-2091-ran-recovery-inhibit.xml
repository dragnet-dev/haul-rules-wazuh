<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2091 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: af74238f-8913-517a-8b4c-93c0d0b5d7ac -->
  <rule id="957423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2091 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>