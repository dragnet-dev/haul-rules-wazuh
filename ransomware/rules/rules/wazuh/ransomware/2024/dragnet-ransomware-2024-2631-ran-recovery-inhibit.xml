<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2631 — Recovery Inhibition (donex) | Status: experimental | Sigma ID: 7e7e13b7-95e2-559c-aeb3-927ed7727d3f -->
  <rule id="328613" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2631 — Recovery Inhibition (donex)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>