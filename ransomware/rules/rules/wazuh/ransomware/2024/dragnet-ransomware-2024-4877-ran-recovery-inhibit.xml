<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4877 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a9fcb5d8-e253-5562-a010-381c9ff129d0 -->
  <rule id="105075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4877 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>