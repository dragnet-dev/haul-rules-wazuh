<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5858 — Event Log Clearing (cactus) | Status: experimental | Sigma ID: 3cfbe49e-6bd8-5cb2-8ce2-d0752f8fe235 -->
  <rule id="797904" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5858 — Event Log Clearing (cactus)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>