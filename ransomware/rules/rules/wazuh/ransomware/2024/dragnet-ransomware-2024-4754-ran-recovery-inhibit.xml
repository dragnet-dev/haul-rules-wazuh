<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4754 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: ea85fe1c-85c6-54a3-82c2-9f6d1e31992b -->
  <rule id="712414" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4754 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>