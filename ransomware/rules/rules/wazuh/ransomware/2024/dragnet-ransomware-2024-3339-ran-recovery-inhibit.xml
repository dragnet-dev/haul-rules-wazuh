<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3339 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 559f8017-2a93-5c7b-8515-3cbb6dfb7675 -->
  <rule id="959801" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3339 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>