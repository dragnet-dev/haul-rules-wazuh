<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1583 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: ea8c7791-5f58-56ec-95e3-429bc0a0d738 -->
  <rule id="258077" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1583 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>