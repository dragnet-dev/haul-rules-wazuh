<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0448 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: 97c77d55-fd97-53e1-b232-0a47ac1e939c -->
  <rule id="803645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0448 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>