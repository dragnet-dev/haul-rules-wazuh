<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3045 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: bb9fa4cc-840d-5401-9dc9-e99a27f80e1c -->
  <rule id="412744" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3045 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>