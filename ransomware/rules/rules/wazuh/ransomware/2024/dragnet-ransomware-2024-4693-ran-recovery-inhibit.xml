<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4693 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 98e6b09d-0aa6-5e8b-878d-7e7256588dce -->
  <rule id="832270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4693 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>