<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3599 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 6a104332-658c-5d25-8dd0-7ab2604ba0b5 -->
  <rule id="261043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3599 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>