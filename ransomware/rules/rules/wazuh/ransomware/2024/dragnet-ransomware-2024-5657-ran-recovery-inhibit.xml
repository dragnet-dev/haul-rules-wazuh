<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5657 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 22ccc5b9-839d-5a75-892d-eb686322e81e -->
  <rule id="642171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5657 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>