<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2924 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: abfc89be-9e88-53f1-845c-8c2c73d673e6 -->
  <rule id="902889" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2924 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>