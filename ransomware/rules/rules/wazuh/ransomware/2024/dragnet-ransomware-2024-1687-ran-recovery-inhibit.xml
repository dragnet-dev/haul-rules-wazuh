<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1687 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 9c4cac5d-ee3c-51e4-b34f-b0db95f1be17 -->
  <rule id="209388" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1687 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>