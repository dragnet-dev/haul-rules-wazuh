<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4136 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 3d77a80d-bd8b-512a-b291-11e3595d0c5d -->
  <rule id="984280" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4136 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>