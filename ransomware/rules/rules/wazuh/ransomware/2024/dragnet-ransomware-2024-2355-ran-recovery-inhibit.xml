<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2355 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a0ebc3db-3fa5-5db1-9680-8ca59d50159f -->
  <rule id="633723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2355 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>