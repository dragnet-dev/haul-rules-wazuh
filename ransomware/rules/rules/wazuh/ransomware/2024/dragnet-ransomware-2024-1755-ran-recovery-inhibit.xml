<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1755 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 4ef2e310-4aff-5ddf-ad1c-f8b405370518 -->
  <rule id="321263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1755 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>