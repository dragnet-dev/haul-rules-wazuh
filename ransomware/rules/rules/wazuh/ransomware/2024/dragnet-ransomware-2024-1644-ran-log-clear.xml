<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1644 — Event Log Clearing (apos) | Status: experimental | Sigma ID: afe4adee-f281-55db-a296-6213b062c32e -->
  <rule id="105037" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1644 — Event Log Clearing (apos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>