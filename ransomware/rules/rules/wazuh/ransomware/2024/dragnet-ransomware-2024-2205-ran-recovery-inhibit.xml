<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2205 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c30f3662-84b0-544d-8bce-a052a430c5eb -->
  <rule id="269536" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2205 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>