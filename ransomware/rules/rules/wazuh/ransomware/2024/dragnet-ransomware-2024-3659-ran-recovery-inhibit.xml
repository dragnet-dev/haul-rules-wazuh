<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3659 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4a68b6a4-7f7c-557c-9f13-482f2b22fe3d -->
  <rule id="394996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3659 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>