<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5917 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: db84d8ce-81dc-5c67-88d4-4c17befdcf1f -->
  <rule id="917578" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5917 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>