<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1421 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 38f4eca9-c32a-5bfe-a6d3-93fa5c0d9ad1 -->
  <rule id="796140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1421 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>