<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4599 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0f8aaa34-4eb2-5be5-8d0e-bf4c10b91ae3 -->
  <rule id="298983" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4599 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>