<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4568 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 10d540c8-a32d-57f2-8d11-73a58d693f4a -->
  <rule id="176652" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4568 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>