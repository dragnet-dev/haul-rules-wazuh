<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3485 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 59bd165d-a563-56d3-b550-7e8eee90fc4f -->
  <rule id="729316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3485 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>