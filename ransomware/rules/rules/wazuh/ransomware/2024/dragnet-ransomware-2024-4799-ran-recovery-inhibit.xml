<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4799 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: de8dbb87-eeee-58b9-83ec-77732a8f5bb5 -->
  <rule id="229403" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4799 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>