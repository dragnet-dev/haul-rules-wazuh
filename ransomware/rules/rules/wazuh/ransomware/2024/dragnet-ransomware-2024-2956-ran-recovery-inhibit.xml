<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2956 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: 101563f2-882c-51d7-8d01-a4e0a137e7f5 -->
  <rule id="825023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2956 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>