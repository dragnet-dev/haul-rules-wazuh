<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3499 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 634dfb25-13ef-55b6-97fd-cd6630139ef4 -->
  <rule id="900443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3499 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>