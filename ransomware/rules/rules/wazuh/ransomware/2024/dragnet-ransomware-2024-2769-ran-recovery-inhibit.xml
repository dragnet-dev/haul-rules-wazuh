<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2769 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e74f66c1-f23d-54ae-85c1-d9945d1cc830 -->
  <rule id="659966" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2769 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>