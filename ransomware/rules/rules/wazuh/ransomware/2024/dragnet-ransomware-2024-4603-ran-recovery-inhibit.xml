<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4603 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: a808565d-2810-55bf-a1ad-2f15a27364a0 -->
  <rule id="280856" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4603 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>