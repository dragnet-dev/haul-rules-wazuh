<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1077 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 6d0802de-3bfe-5db5-bd01-d21b4c15e002 -->
  <rule id="290802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1077 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>