<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5434 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 5a4d599f-c297-5a5e-be54-ae7affb8e7bf -->
  <rule id="647759" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5434 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>