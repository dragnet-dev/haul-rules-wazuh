<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3969 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0b0a6ed2-c3fb-5e6b-aa25-a2d347fc8ec2 -->
  <rule id="132973" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3969 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>