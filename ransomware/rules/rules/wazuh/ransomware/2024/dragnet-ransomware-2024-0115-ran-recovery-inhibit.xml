<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0115 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: e3556012-1716-5f53-aa4d-259bdd0abb2b -->
  <rule id="635560" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0115 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>