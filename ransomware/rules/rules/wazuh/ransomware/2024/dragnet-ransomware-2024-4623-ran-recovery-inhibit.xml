<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4623 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: be0582ae-e318-5c07-b0ac-43a3279625a9 -->
  <rule id="200582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4623 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>