<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5123 — Event Log Clearing (alphv) | Status: experimental | Sigma ID: 4f85ee0e-9a07-5c3b-b5e5-ffbde0fd9917 -->
  <rule id="344398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5123 — Event Log Clearing (alphv)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>