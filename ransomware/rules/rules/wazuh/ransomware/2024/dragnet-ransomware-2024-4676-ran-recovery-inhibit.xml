<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4676 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: d59955de-6beb-5cd2-b360-1afd15df51c8 -->
  <rule id="559955" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4676 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>