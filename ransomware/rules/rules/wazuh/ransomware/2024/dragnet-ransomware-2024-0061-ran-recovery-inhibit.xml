<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0061 — Recovery Inhibition (argonauts) | Status: experimental | Sigma ID: 6f03df22-4df9-586e-b4ae-d742a1b3365f -->
  <rule id="242591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0061 — Recovery Inhibition (argonauts)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>