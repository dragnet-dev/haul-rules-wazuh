<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3678 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 2bca7cfc-125f-5493-97c1-0f13d072c5df -->
  <rule id="993724" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3678 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>