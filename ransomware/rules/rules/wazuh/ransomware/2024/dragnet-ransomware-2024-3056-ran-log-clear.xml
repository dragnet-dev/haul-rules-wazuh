<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3056 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: f9a01845-57f3-57cc-bb7e-4d6bfeb0ba31 -->
  <rule id="854018" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3056 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>