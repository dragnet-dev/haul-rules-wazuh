<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4996 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 5cb51217-6b6a-5cab-a12c-5895dea5437b -->
  <rule id="683512" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4996 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>