<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0050 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 39b8c083-b3c0-56f1-a15a-94eb1b83a922 -->
  <rule id="217400" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0050 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>