<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4680 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e8ef5666-65c1-5112-ac8b-0bec6d8d40ee -->
  <rule id="312756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4680 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>