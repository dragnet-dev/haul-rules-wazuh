<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1141 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0003a4fb-0324-5359-8ec6-52ee18bad98b -->
  <rule id="697550" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1141 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>