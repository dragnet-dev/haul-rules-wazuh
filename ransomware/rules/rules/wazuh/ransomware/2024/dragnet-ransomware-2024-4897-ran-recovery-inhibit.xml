<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4897 — Recovery Inhibition (chort) | Status: experimental | Sigma ID: db6d2bd1-0a25-592a-b8b7-19200c38922a -->
  <rule id="323883" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4897 — Recovery Inhibition (chort)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>