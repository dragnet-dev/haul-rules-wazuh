<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2408 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: 6fef54cc-3df5-59c2-9349-5a6416a40bef -->
  <rule id="265554" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2408 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>