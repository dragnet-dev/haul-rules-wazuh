<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1937 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9a9c4ef3-5567-5e62-b5ce-f98ce3fb1cd3 -->
  <rule id="467438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1937 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>