<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3872 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 93f24f89-1cb1-5507-92f9-2e84362ea9de -->
  <rule id="705199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3872 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>