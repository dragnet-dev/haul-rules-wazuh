<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5877 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b6362e2c-bdb4-5f47-8a71-def3875d8a5f -->
  <rule id="161806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5877 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>