<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2393 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 21572a31-4e95-5955-8c85-910e028594d6 -->
  <rule id="851623" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2393 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>