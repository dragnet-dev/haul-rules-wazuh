<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1867 — Event Log Clearing (ransomexx) | Status: experimental | Sigma ID: 1b6df68f-53c2-54c3-bbd8-1a8fd3e2d456 -->
  <rule id="887968" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1867 — Event Log Clearing (ransomexx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>