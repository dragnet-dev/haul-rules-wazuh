<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2689 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 976e13fe-4a2e-52c0-9342-b8b460325cef -->
  <rule id="763013" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2689 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>