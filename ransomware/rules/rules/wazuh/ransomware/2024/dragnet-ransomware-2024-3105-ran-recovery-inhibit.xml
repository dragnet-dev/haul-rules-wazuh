<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3105 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: 9af95375-d2e0-55d3-a548-d777676b74fb -->
  <rule id="779953" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3105 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>