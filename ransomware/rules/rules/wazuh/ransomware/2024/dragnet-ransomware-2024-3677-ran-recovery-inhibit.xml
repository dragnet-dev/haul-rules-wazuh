<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3677 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 5f7d2e24-f63c-5777-b792-d3466fa806f7 -->
  <rule id="752046" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3677 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>