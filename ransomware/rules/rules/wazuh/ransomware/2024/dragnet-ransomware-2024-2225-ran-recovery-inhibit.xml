<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2225 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e301dfb1-4b84-50a4-acb5-a6726ef71381 -->
  <rule id="161279" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2225 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>