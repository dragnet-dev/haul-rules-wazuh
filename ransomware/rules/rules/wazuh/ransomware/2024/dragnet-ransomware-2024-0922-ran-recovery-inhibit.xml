<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0922 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: b6839ce5-adf4-539c-a4f3-f37af660824b -->
  <rule id="169436" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0922 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>