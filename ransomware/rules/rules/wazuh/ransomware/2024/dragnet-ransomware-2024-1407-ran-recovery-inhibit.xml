<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1407 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 89f51606-4a75-560d-8ba4-9a79f2f592b4 -->
  <rule id="639516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1407 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>