<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1931 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 3fd006da-e86a-57fc-b319-db22aef62582 -->
  <rule id="221006" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1931 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>