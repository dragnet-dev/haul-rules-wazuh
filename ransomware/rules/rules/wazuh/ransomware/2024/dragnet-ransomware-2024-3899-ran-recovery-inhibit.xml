<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3899 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b1f294a3-391d-52c1-82e4-0e299b31d61d -->
  <rule id="991294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3899 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
