<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5026 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 081800c4-c4da-5c9f-8a45-4a48c1caffa6 -->
  <rule id="508812" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5026 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>