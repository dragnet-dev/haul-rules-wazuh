<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4559 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: a9d5396b-7788-5f62-ad81-98bdf45b2ced -->
  <rule id="957539" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4559 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>