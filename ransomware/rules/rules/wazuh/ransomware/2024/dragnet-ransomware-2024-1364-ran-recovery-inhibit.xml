<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1364 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: a80ace79-f4a9-512e-8a8e-4cbf7e1e0ba7 -->
  <rule id="926446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1364 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>