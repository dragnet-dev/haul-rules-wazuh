<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3669 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 3526052b-74df-5482-a819-a39c3278e00d -->
  <rule id="926052" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3669 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>