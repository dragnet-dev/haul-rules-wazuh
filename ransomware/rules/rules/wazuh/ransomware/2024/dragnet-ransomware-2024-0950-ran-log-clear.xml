<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0950 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 3fbe64a0-a1bd-5938-9cec-6b53be89b267 -->
  <rule id="831864" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0950 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>