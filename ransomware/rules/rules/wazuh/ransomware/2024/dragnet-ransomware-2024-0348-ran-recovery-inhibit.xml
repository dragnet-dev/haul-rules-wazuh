<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0348 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 561b033d-764b-55ed-a41c-0471e8061f4f -->
  <rule id="987033" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0348 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>