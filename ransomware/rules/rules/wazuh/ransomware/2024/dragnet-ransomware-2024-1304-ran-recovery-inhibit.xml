<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1304 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5fd6e1aa-02d4-5ae3-8674-7bc191015f3b -->
  <rule id="753901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1304 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>