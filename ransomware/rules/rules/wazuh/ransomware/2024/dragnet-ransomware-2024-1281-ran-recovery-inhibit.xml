<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1281 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 5c0d86d5-2162-5620-9fb4-56b9de188f14 -->
  <rule id="673386" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1281 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>