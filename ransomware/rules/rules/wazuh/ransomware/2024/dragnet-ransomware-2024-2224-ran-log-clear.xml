<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2224 — Event Log Clearing (hellcat) | Status: deprecated | Sigma ID: c47f122f-a6b6-5d22-a41f-22761f7bd3a9 -->
  <rule id="296712" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2224 — Event Log Clearing (hellcat)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>