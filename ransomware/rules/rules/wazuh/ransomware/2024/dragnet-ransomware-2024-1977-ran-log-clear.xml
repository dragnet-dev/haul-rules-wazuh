<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1977 — Event Log Clearing (helldown) | Status: experimental | Sigma ID: c58b42db-8380-577e-a2bf-a70c93f9a491 -->
  <rule id="313942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1977 — Event Log Clearing (helldown)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>