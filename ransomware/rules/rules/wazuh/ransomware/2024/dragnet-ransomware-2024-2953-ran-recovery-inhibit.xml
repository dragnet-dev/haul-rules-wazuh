<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2953 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: b7ed761f-4d07-5780-9a01-241b79ad94da -->
  <rule id="418976" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2953 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>