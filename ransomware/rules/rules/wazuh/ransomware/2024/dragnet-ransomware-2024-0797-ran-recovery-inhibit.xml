<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0797 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2453f314-9d34-56f0-bceb-21996dd37b68 -->
  <rule id="426331" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0797 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>