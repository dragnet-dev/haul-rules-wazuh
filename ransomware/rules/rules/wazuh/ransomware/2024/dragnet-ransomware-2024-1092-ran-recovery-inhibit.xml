<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1092 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 73e8f5dd-b107-56dd-981e-f5a3a976ac36 -->
  <rule id="192635" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1092 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>