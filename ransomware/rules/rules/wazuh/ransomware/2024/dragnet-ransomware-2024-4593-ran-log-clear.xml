<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4593 — Event Log Clearing (safepay) | Status: deprecated | Sigma ID: 7bef7b93-fca8-5ce3-b8e1-aa3e91dd6046 -->
  <rule id="676443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4593 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>