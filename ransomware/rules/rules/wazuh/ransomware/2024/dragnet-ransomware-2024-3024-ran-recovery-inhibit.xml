<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3024 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: fa78946e-2912-59c7-b67e-a5fa58376f71 -->
  <rule id="807894" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3024 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>