<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0758 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 88ab7a46-cea9-56af-b3ee-2e21e352894a -->
  <rule id="131962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0758 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>