<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1202 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7fa4b672-49d8-51cc-aa63-60965beda86a -->
  <rule id="667956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1202 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>