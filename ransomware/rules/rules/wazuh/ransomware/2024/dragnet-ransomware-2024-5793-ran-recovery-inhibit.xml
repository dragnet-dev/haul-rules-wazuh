<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5793 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 00b61427-ba14-53fd-b198-1974980b56c3 -->
  <rule id="361427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5793 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>