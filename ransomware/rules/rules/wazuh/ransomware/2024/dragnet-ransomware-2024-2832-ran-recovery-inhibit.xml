<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2832 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: b329614f-c730-52aa-b710-35074ab2ecb8 -->
  <rule id="332961" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2832 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>