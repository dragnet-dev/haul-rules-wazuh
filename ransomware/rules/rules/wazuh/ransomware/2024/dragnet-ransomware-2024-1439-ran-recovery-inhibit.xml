<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1439 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: fb3f071c-622b-5116-9f79-32a737d80785 -->
  <rule id="522307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1439 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>