<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1498 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 302f67ae-f228-5e9a-910a-edab4a75aab3 -->
  <rule id="656282" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1498 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>