<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5154 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e188af4e-8023-54c5-a60d-798fa123b12e -->
  <rule id="132303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5154 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>