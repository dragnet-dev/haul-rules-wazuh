<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2791 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 25fe88d4-68d1-5971-970c-4293dd34c993 -->
  <rule id="847821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2791 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>