<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4595 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 36c0edfb-2f4d-54cd-9312-9d526b7f7fb0 -->
  <rule id="705517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4595 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
