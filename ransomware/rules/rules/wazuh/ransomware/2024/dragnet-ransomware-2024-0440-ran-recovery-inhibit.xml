<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0440 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: dbb1c9c6-d6f3-53b9-9754-5e950ff1b18f -->
  <rule id="324289" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0440 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>