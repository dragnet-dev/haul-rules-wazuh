<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5059 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: d8f22b2b-c4a0-51e8-8c58-71d5d8d402fb -->
  <rule id="957163" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5059 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>