<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3663 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: b28a4618-dbe9-5435-a62d-441135742b49 -->
  <rule id="105846" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3663 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>