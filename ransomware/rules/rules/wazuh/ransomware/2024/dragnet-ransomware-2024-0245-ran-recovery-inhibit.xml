<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0245 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 5e108c5a-da42-5d02-8d90-d0f01742fe0a -->
  <rule id="705740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0245 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>