<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1448 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 90983da7-4590-52a3-85b1-192711787272 -->
  <rule id="655741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1448 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>