<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5494 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: b5e6e60f-c455-5b72-9b86-512c10bddfdc -->
  <rule id="367506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5494 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>