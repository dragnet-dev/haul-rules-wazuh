<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0212 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d03f6fa5-d9fa-59bb-9c44-cc11e229a3f9 -->
  <rule id="738191" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0212 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>