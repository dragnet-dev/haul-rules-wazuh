<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0078 — Recovery Inhibition (argonauts) | Status: experimental | Sigma ID: 114c520d-f7a6-50b9-b9b5-9482bcc62196 -->
  <rule id="136520" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0078 — Recovery Inhibition (argonauts)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>