<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5401 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 79384b76-6bdb-5e46-8cd2-c2b328e689b3 -->
  <rule id="470155" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5401 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>