<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4218 — Recovery Inhibition (dunghill) | Status: experimental | Sigma ID: 2963b4ec-7752-5897-a5e7-e9782a0401fd -->
  <rule id="487118" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4218 — Recovery Inhibition (dunghill)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>