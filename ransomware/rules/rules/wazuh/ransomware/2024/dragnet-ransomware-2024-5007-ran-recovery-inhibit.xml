<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5007 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 8d22a1ce-eea7-57a7-aec2-c5c0e7017152 -->
  <rule id="559621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5007 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>