<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3323 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c784cf6d-3160-560b-84ee-7a0d9c3ca698 -->
  <rule id="672911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3323 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>