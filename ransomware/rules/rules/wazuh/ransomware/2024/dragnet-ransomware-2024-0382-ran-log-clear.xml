<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0382 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: a61f3865-9247-5eca-a85a-27f2d10f7be4 -->
  <rule id="899138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0382 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>