<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4398 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 116613cc-cbb9-513c-b782-d594238ee4fa -->
  <rule id="165820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4398 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>