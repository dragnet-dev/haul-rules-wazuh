<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0552 — Recovery Inhibition (argonauts) | Status: experimental | Sigma ID: 3f177064-59e4-5221-ada0-1174052994f1 -->
  <rule id="117706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0552 — Recovery Inhibition (argonauts)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>