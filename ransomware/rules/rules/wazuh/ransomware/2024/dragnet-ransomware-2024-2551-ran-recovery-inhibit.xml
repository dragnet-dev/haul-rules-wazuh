<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2551 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 00884823-5297-58e9-9616-7afc04f95fb9 -->
  <rule id="848235" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2551 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>