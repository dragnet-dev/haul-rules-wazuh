<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5675 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 4775a672-c8c1-5f3d-bee3-c3caa52bbbcc -->
  <rule id="541067" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5675 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>