<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2090 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 865b21a4-4501-5246-b115-b97e0e6038fc -->
  <rule id="585121" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2090 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>