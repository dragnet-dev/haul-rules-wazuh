<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4551 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 2fa07ab2-b2f1-5e68-84df-c469444bb2d9 -->
  <rule id="419322" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4551 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>