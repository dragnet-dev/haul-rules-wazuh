<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3227 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: df6388bc-b786-5cba-84b5-89dc1aa85c68 -->
  <rule id="536388" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3227 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>