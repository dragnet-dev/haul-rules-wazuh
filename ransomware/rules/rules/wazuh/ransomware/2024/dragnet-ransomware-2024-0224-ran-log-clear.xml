<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0224 — Event Log Clearing (nitrogen) | Status: experimental | Sigma ID: 82e27678-2b5f-5fbc-ba76-fd0c7c42792d -->
  <rule id="526276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0224 — Event Log Clearing (nitrogen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>