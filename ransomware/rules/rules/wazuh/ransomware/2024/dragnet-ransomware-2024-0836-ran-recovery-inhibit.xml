<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0836 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: efb8e1e8-4364-508b-972d-a09d4ab8e52f -->
  <rule id="837421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0836 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>