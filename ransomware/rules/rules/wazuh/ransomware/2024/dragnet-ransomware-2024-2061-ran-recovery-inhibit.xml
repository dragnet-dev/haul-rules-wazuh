<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2061 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: 480b3e67-ce55-502e-b69e-1752b9415a95 -->
  <rule id="430622" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2061 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>