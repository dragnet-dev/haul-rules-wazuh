<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5123 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: b3ce719a-3c1d-52db-8da1-56d288e94168 -->
  <rule id="313471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5123 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>