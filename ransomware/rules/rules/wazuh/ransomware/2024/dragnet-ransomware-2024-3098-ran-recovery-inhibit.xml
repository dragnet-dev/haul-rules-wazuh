<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3098 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7ee75eac-df16-51fb-8800-5616bc9e7888 -->
  <rule id="649214" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3098 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>