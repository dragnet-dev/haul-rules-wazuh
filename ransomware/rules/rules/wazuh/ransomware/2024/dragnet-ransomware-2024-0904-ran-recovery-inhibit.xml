<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0904 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: f6c225dc-721f-5b66-bea1-d990e3c4be68 -->
  <rule id="808225" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0904 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>