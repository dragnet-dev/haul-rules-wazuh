<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4727 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: da6e3525-1795-537e-97c4-446bf8d452ff -->
  <rule id="899035" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4727 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>