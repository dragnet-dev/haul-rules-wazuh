<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5901 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1ca3755e-f1f9-5cc5-8e5c-0af191c44951 -->
  <rule id="183755" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5901 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>