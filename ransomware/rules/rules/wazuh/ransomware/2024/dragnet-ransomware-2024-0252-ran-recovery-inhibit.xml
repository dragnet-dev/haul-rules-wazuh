<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0252 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3d1b546a-9c74-54dc-9668-3bef9ae20fa8 -->
  <rule id="887546" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0252 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>