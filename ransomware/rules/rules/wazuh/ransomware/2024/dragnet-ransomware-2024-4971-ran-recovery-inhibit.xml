<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4971 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 5c9cb2c1-fd20-5508-b688-dadf338f0380 -->
  <rule id="680272" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4971 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>