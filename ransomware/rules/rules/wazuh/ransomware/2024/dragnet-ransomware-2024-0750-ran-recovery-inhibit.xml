<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0750 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 9eb0014f-42b4-53c1-8ff7-205e2d934c94 -->
  <rule id="839001" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0750 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>