<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4451 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f8ff760f-c37f-5736-8bee-3966808513ad -->
  <rule id="570376" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4451 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>