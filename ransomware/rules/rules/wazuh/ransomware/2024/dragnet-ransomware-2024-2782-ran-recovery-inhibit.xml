<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2782 — Recovery Inhibition (embargo) | Status: experimental | Sigma ID: 825a1000-9e0b-5da3-aae4-fe134639df9d -->
  <rule id="521010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2782 — Recovery Inhibition (embargo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
