<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0436 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 76bf56a3-a62c-5840-a70d-e951ed7fa4dc -->
  <rule id="264756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0436 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>