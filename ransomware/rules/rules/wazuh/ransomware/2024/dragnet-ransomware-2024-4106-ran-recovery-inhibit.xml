<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4106 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: 61cbd7ea-e648-582a-9bb3-a64a7b664686 -->
  <rule id="831177" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4106 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>