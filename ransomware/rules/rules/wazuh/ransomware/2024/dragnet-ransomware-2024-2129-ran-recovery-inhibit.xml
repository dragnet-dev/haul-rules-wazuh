<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2129 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: f8e00a11-8ae5-5ec2-a46a-f8388c67e643 -->
  <rule id="567210" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2129 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>