<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0804 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0e184840-8afa-5f4f-aa1c-9ba0086f15ed -->
  <rule id="618484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0804 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>