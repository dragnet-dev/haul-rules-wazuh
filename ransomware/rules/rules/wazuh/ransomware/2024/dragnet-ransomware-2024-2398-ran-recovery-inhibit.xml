<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2398 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: abf5764e-f1d1-52db-a698-ff331d974937 -->
  <rule id="151576" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2398 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>