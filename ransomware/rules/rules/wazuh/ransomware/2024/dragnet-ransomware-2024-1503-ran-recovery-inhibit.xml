<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1503 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 724ec0d0-5771-554a-b990-749d4dbfd602 -->
  <rule id="155800" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1503 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>