<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4709 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 8bee8576-0d31-530e-9b91-cbbb6f634934 -->
  <rule id="982285" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4709 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>