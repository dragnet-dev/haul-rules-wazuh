<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1013 — Recovery Inhibition (cicada3301) | Status: experimental | Sigma ID: 09c6afba-8ac2-5eda-8035-359796d75113 -->
  <rule id="217147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1013 — Recovery Inhibition (cicada3301)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
