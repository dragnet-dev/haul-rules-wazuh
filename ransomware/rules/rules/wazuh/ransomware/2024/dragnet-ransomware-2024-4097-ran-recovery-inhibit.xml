<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4097 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 07a3a16c-0555-5ac7-ae12-7e0fb36c64de -->
  <rule id="257816" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4097 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>