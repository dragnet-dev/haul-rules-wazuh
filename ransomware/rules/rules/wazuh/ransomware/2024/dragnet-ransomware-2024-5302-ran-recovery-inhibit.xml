<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5302 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b75b331e-0310-59bb-95a6-2c30a4924f8f -->
  <rule id="181133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5302 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>