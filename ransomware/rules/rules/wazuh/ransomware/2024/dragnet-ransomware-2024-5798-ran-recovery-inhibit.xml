<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5798 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 509c779a-24d8-5c98-b0d0-db7fa7f68df5 -->
  <rule id="156779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5798 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>