<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2613 — Event Log Clearing (frag) | Status: deprecated | Sigma ID: d191525f-1836-5ec7-97fb-7f267e5bae58 -->
  <rule id="519152" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2613 — Event Log Clearing (frag)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>