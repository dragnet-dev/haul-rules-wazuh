<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2842 — Recovery Inhibition (mallox) | Status: experimental | Sigma ID: f7cbb0cb-e971-590b-b3f6-252a98d651cd -->
  <rule id="263310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2842 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>