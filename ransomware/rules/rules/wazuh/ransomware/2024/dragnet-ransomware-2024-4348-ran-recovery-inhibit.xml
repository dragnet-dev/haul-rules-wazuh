<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4348 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0ca1a969-4557-5891-8c52-b250ff080f48 -->
  <rule id="634696" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4348 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>