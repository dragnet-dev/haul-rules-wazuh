<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2341 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 90f1b2dc-c37e-5fac-b841-048110e327c0 -->
  <rule id="628272" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2341 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>