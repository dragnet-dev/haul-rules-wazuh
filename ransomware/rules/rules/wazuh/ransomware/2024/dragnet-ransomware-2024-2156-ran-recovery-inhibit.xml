<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2156 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 0c44df5f-94e1-5c61-b1ac-068ad1f85da9 -->
  <rule id="586875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2156 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>