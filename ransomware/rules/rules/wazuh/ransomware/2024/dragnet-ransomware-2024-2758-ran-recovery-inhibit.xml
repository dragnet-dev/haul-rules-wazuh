<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2758 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: a42189bd-aba5-503f-a13f-20a01e3cba7c -->
  <rule id="242189" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2758 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>