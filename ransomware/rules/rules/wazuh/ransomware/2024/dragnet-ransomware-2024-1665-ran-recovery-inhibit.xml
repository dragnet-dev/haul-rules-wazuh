<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1665 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 571f680b-ce80-55d8-a8e0-df1b6849a26c -->
  <rule id="251680" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1665 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>