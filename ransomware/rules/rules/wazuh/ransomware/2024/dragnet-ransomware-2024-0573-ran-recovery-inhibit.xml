<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0573 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: b8f4dcdb-c8bb-505c-9053-4180be32159a -->
  <rule id="472924" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0573 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>