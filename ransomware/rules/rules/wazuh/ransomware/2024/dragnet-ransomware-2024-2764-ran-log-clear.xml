<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2764 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: e5ae6ad0-3f8e-573a-90c7-6decc3bb063b -->
  <rule id="667146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2764 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>