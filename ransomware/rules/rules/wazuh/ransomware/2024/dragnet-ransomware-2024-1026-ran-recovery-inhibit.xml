<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1026 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f1bd8fe9-053f-51b9-8f16-236e0a219041 -->
  <rule id="915343" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1026 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>