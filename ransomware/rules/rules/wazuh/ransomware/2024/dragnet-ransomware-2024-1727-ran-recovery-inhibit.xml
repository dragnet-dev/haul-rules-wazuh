<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1727 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: d7339646-2893-5bf3-b491-a9e646590d2c -->
  <rule id="573396" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1727 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>