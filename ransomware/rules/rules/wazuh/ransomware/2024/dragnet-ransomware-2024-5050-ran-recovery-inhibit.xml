<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5050 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 0c01ef48-4696-510e-b025-efc266c65ba7 -->
  <rule id="476954" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5050 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>