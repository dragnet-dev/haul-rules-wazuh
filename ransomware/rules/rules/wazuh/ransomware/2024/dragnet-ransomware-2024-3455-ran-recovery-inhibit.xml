<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3455 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 57fdb49a-0e64-51ce-968e-312197a2b3a0 -->
  <rule id="675314" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3455 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>