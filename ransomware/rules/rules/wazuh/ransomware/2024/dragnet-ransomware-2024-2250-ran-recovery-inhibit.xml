<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2250 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 05bc88d6-1249-5577-86f1-85ff4d12be3c -->
  <rule id="650221" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2250 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>