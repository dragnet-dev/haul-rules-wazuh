<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2405 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 13c680cf-4acd-5c45-82e0-9ef997af05a8 -->
  <rule id="930892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2405 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>