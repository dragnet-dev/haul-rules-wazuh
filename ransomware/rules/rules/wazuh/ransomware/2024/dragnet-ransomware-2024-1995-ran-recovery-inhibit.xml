<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1995 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 14300f8f-8d49-5fc5-aef7-a49d8caa5bca -->
  <rule id="588158" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1995 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>