<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2977 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: 6ba3ce99-098c-59ff-9bea-c57b5d38fff2 -->
  <rule id="909294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2977 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>