<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1260 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 49facf6c-aaa3-5351-8319-b83d3e1862de -->
  <rule id="675471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1260 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>