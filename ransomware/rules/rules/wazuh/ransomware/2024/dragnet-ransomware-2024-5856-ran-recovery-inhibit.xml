<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5856 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 6c48d32e-afa4-51ac-b226-202bc5c02219 -->
  <rule id="935813" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5856 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>