<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0972 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 3640dc0f-f3e7-579e-a670-06f06303fa08 -->
  <rule id="420600" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0972 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>