<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3559 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 270e778d-1301-54fd-bb48-c079d0b8f77f -->
  <rule id="834778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3559 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>