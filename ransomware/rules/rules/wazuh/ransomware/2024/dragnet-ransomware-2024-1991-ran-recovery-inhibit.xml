<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1991 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1564c7d5-b351-5ddc-9479-26027463c580 -->
  <rule id="505885" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1991 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>