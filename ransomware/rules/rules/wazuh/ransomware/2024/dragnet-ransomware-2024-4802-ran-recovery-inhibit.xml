<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4802 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 2b4e1d82-0a94-5589-9e81-459c7304c1c3 -->
  <rule id="313309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4802 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>