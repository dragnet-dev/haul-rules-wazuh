<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3260 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: aded4376-6046-5e3a-b54d-9391980bf60a -->
  <rule id="952543" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3260 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>