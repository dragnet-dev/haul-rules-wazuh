<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2329 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3630267e-1ad5-5fc1-8bc5-0f8c57563458 -->
  <rule id="130267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2329 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>