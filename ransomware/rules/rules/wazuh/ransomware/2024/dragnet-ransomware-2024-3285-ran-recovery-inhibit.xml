<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3285 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 185b3bf0-f1d6-5aec-a4d7-b67868b5c894 -->
  <rule id="506719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3285 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>