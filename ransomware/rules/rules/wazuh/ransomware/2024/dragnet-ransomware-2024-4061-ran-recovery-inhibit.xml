<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4061 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 0ad956db-9c2c-502b-ac53-e36d72370804 -->
  <rule id="183309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4061 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>