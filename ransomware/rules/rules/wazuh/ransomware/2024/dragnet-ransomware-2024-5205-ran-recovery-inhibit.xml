<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5205 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: f57f96f9-56f7-50e3-af00-d9a6adc275ae -->
  <rule id="792796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5205 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>