<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0953 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: d8ec31f1-dc06-5b04-a2c6-0cc13d38dfce -->
  <rule id="956431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0953 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>