<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5476 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 26e7ef6d-f518-5e6a-8cba-ab029882e28a -->
  <rule id="302831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5476 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>