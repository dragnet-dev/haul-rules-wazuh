<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4195 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: c1ec7f9f-3608-5644-9726-a2ed4e515b9b -->
  <rule id="594047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4195 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>