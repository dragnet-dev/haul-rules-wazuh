<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2217 — Event Log Clearing (BrainCipher) | Status: experimental | Sigma ID: d2c8faf7-8b90-5b49-85f2-80e06aa85fb9 -->
  <rule id="139738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2217 — Event Log Clearing (BrainCipher)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>