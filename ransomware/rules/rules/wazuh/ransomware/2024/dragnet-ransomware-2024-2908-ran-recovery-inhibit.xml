<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2908 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: f42a6a54-808b-560e-a814-ce48daff17b8 -->
  <rule id="449226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2908 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>