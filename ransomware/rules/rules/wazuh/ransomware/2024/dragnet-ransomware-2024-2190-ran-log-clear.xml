<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2190 — Event Log Clearing (argonauts) | Status: experimental | Sigma ID: 8024da63-c7a5-5849-a95f-3e27f16ed3aa -->
  <rule id="354362" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2190 — Event Log Clearing (argonauts)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>