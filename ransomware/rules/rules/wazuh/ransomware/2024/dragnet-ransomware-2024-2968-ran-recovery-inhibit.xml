<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2968 — Recovery Inhibition (dunghill) | Status: experimental | Sigma ID: 547feaa5-7f86-5402-a5e9-d71346830cd9 -->
  <rule id="544586" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2968 — Recovery Inhibition (dunghill)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>