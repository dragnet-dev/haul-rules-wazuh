<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0120 — Event Log Clearing (donex) | Status: experimental | Sigma ID: f7ca2117-9e0c-5382-bd5c-a4d4ee8cbe8d -->
  <rule id="539421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0120 — Event Log Clearing (donex)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>