<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2824 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f448e279-ae38-5268-9091-33a34a595514 -->
  <rule id="771822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2824 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>