<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0643 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 2f5c6518-029f-5620-8917-4b08c138ae0b -->
  <rule id="512651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0643 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>