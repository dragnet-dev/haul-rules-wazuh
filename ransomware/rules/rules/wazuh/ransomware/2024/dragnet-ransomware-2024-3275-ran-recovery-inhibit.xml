<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3275 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 82c4af6a-69d1-5af8-9988-170c147eca40 -->
  <rule id="790639" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3275 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>