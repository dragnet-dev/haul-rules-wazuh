<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0732 — Event Log Clearing (ElDorado) | Status: deprecated | Sigma ID: ca87bfe1-1e9d-5a6a-b06f-84b36810740e -->
  <rule id="793663" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0732 — Event Log Clearing (ElDorado)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>