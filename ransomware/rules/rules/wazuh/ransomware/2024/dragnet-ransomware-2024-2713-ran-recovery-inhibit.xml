<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2713 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: b2a798d1-a78a-5e5d-93c3-39492586549c -->
  <rule id="102798" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2713 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>