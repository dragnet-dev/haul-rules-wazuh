<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4517 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8aefdad3-b85c-5e59-b7ba-ca990d581e06 -->
  <rule id="205370" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4517 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>