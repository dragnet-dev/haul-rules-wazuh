<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0558 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: a650586d-88a5-597c-bd2c-6bcccc096cdc -->
  <rule id="265058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0558 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>