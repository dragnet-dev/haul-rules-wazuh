<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3516 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 14c7bf62-6597-5887-b291-3e5b44f1c424 -->
  <rule id="761436" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3516 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>