<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0604 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 7e5c9397-96c3-5be6-a111-990f2c23fd3b -->
  <rule id="325293" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0604 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>