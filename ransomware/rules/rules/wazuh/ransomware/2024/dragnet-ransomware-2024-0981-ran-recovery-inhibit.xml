<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0981 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: aa11c0af-124d-5b24-8e9a-4ac36c64c431 -->
  <rule id="121880" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0981 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>