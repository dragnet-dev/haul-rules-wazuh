<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5516 — Event Log Clearing (spacebears) | Status: experimental | Sigma ID: 541ce80f-1064-56ca-b38e-3991af4b06dd -->
  <rule id="587028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5516 — Event Log Clearing (spacebears)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>