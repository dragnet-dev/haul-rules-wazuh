<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3325 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 1b2aa5b0-22cf-51f0-9736-efa45e260a57 -->
  <rule id="468411" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3325 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>