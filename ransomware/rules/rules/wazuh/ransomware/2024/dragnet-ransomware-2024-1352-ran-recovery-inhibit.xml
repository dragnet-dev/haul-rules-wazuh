<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1352 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 17f94881-0280-5f33-8386-9699b959f49b -->
  <rule id="279488" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1352 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>