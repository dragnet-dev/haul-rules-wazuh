<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0913 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 1ecb1e15-4919-5879-ab29-e570aaeb130f -->
  <rule id="461310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0913 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>