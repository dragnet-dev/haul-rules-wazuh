<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2261 — Recovery Inhibition (dAn0n) | Status: experimental | Sigma ID: 32cab6e4-24ea-5a12-8f9a-20346af8e357 -->
  <rule id="543156" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2261 — Recovery Inhibition (dAn0n)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>