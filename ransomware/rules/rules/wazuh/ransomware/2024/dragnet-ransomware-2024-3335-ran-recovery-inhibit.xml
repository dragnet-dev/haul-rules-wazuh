<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3335 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 3388fd31-0977-5a47-b683-b4c9d45c3d71 -->
  <rule id="675813" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3335 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>