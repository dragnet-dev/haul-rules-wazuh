<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3750 — Recovery Inhibition (ElDorado) | Status: experimental | Sigma ID: 1068b568-8251-5c27-a70d-11d5bb7f025a -->
  <rule id="909956" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3750 — Recovery Inhibition (ElDorado)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>