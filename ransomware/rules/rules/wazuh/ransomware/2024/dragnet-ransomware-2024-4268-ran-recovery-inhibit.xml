<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4268 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: 8148c8cc-1668-5132-89fa-0dacec27d21f -->
  <rule id="503808" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4268 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>