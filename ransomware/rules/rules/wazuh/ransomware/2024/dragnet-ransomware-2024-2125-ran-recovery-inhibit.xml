<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2125 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 06d5f572-8ac5-5ae1-adab-956228fde885 -->
  <rule id="953557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2125 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>