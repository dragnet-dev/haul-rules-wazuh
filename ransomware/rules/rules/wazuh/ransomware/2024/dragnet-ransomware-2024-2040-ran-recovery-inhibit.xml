<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2040 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c984f92c-4068-523b-867f-eabd4aa69249 -->
  <rule id="377599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2040 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>