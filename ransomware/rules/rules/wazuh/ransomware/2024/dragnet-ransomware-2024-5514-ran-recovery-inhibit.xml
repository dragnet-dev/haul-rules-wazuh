<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5514 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: e34eebe6-a08a-5382-8ad9-ffd5aba453e8 -->
  <rule id="577483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5514 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>