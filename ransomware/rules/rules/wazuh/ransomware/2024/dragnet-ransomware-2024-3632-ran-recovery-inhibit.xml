<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3632 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: ff1baead-7b2e-54f5-a83e-b0078ba27a69 -->
  <rule id="651886" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3632 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>