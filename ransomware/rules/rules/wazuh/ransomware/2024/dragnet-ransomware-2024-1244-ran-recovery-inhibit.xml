<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1244 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: bdfe7a08-5099-5eed-a40f-2f2061bbb6ef -->
  <rule id="682202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1244 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>