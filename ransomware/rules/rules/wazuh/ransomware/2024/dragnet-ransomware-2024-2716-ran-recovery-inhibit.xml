<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2716 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: fdf3795f-17a0-5aca-9fac-f2b90f1483b4 -->
  <rule id="563379" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2716 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>