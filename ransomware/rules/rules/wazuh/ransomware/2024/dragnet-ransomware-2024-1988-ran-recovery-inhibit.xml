<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1988 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: af4ad5d9-6624-55b6-8ce1-559055d71a9d -->
  <rule id="991975" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1988 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>