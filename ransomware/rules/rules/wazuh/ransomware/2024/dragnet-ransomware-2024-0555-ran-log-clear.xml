<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0555 — Event Log Clearing (darkvault) | Status: experimental | Sigma ID: b9b1fda0-2b7c-5e5b-b782-27cb36a1d1f8 -->
  <rule id="502909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0555 — Event Log Clearing (darkvault)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>