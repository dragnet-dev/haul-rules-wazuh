<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2543 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: 6c1cf1bc-b62f-54e5-80d9-fb8c9bcadd2a -->
  <rule id="169431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2543 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>