<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0372 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 65a65f40-38f4-5dd5-99f8-e732c7b36065 -->
  <rule id="881055" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0372 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>