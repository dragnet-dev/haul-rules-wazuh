<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3102 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 1fee98f5-53e0-54be-b24c-c6daf62c329b -->
  <rule id="579983" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3102 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>