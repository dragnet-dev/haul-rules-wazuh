<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2465 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a75de9de-08a1-502a-bb4f-14ed5b61553a -->
  <rule id="154229" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2465 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>