<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4236 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: bb92bff9-16c0-5468-a5a8-5562454bf248 -->
  <rule id="410943" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4236 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>