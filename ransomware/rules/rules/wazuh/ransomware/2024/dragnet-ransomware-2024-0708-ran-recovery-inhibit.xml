<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0708 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 106f57be-3dc2-5646-84f4-68a2264f67d0 -->
  <rule id="138523" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0708 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>