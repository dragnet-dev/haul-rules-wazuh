<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2509 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0a235671-f564-5fec-8f99-c5ab1849b390 -->
  <rule id="223567" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2509 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>