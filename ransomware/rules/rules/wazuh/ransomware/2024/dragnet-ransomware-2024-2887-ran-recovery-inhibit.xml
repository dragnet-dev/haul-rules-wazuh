<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2887 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 01b92da7-2591-5fb2-a219-bc21b5a6f33b -->
  <rule id="949707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2887 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>