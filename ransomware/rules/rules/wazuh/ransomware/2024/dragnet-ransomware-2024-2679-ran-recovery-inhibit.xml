<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2679 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: c7a9d9ea-6184-5947-bcc1-459517e69993 -->
  <rule id="668779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2679 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>