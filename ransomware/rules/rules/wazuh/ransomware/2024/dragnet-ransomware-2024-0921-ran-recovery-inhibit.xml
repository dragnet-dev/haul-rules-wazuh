<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0921 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 23097990-9d88-50e2-a054-2e27958308a1 -->
  <rule id="609799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0921 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>