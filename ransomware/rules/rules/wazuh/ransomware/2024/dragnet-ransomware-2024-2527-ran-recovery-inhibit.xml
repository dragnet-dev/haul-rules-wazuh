<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2527 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 80ce7ed8-dc8d-52e5-a6fb-065a6bf0015a -->
  <rule id="709886" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2527 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>