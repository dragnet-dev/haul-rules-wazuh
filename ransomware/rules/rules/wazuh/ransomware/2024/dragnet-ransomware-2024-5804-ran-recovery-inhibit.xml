<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5804 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1a03f075-921f-5d0a-9164-92e40cf1d27e -->
  <rule id="666307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5804 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>