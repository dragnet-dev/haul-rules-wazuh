<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0307 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 43424671-5fb2-56aa-b840-407b31b28e49 -->
  <rule id="842467" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0307 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>