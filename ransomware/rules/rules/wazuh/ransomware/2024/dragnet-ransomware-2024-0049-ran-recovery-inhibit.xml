<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0049 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f4600de5-18ae-5d15-8aaa-2e14e00ceda6 -->
  <rule id="773613" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0049 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>