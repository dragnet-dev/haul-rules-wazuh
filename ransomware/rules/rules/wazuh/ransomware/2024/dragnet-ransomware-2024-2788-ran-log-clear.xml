<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2788 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 632e8ab3-2ac0-5b44-b131-4b8353c9e911 -->
  <rule id="820298" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2788 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>