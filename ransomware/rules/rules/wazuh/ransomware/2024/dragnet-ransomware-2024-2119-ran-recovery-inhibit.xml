<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2119 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: 0597d7f3-1422-5fc6-9ad3-4b1ceded08eb -->
  <rule id="730527" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2119 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>