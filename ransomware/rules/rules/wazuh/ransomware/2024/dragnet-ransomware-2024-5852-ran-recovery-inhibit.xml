<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5852 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: e0d2ca70-196b-561c-8c02-0bf0fb5b122d -->
  <rule id="468394" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5852 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>