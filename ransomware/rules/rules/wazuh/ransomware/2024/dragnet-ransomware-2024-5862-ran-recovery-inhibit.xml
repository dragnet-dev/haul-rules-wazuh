<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5862 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 3b9dd3e0-659b-54b9-beb9-ae48adc55fae -->
  <rule id="735653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5862 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>