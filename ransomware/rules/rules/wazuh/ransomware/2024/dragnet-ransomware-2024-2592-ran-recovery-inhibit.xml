<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2592 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e879ac88-40e5-56b7-8482-1008af968dff -->
  <rule id="309196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2592 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>