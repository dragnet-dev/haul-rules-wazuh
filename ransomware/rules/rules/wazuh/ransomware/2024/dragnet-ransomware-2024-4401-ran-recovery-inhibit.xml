<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4401 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 6c97105d-d8c5-56cd-8cfb-d9cb6411efcd -->
  <rule id="289710" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4401 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>