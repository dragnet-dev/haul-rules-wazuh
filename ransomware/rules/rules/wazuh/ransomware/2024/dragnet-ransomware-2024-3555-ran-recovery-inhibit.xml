<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3555 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: 0773687d-6da7-53f8-b81a-65b572d610f5 -->
  <rule id="779005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3555 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>