<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2655 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 4ab74b69-8578-5eb8-84b4-63e41ddd5c1a -->
  <rule id="213195" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2655 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>