<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3758 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 73ee5b21-e555-5feb-be7e-d0f0fa5390f5 -->
  <rule id="428251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3758 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>