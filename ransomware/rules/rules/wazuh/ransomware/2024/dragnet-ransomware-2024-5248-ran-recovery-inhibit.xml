<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5248 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2708ad99-d2fe-511b-9c55-8c63fa239ed2 -->
  <rule id="734219" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5248 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>