<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5826 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 98647622-40c8-5d1f-9b70-82c0cf1f15c2 -->
  <rule id="964762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5826 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>