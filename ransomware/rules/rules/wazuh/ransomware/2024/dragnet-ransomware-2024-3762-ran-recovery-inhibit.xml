<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3762 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 512dd746-0e93-5648-9f8a-538331fa2dc4 -->
  <rule id="512937" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3762 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>