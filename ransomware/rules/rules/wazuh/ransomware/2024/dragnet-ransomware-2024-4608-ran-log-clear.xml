<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4608 — Event Log Clearing (redransomware) | Status: deprecated | Sigma ID: c68c3fee-2fd5-55c5-a147-def73d8e4f84 -->
  <rule id="648063" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4608 — Event Log Clearing (redransomware)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>