<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5442 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 6238d3dc-d93e-5fb4-85fa-f9c5caa3ae10 -->
  <rule id="771421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5442 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>