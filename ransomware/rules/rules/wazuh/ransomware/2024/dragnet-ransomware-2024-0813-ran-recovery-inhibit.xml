<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0813 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 842310b5-2578-578a-82b1-dc53958cab43 -->
  <rule id="976971" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0813 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>