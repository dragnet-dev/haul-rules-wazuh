<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0482 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 3bde8a76-dba1-51be-a5b1-b0afc5a37f65 -->
  <rule id="752298" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0482 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>