<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3988 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e67bd56a-f515-5a80-8aaa-693c0c0658c4 -->
  <rule id="257415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3988 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>