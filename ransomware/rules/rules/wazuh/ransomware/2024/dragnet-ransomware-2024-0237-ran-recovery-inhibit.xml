<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0237 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: eb2879f7-3e22-569e-966e-afcf806a7bea -->
  <rule id="652879" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0237 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>