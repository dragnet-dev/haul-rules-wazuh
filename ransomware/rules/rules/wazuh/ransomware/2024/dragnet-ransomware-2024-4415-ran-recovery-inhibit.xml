<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4415 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 724696bf-e153-5ab2-b87d-33b6bf257adc -->
  <rule id="895147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4415 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>