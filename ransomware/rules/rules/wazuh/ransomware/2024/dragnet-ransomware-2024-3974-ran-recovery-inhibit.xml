<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3974 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c4937f23-42aa-5b5f-8137-9bb7ee9a9cdb -->
  <rule id="299007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3974 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>