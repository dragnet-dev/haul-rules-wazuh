<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0834 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: e37b4874-66e7-57c5-bc94-21b169925653 -->
  <rule id="600348" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0834 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>