<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2531 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: 15908d68-74e7-5ea5-a23a-d888d8d05a10 -->
  <rule id="845416" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2531 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>