<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2967 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4f388716-bdda-5531-85aa-62ca95996ecb -->
  <rule id="838871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2967 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
