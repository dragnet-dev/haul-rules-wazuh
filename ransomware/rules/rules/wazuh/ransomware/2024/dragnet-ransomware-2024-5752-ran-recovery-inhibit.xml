<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5752 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: a00a4d68-1bc4-53a9-8091-1579564fbf42 -->
  <rule id="861677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5752 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>