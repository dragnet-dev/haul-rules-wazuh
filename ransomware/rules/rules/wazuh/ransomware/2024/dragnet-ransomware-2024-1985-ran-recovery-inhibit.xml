<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1985 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: fc95bb75-2df9-53dc-87a1-0c7b4c0e3961 -->
  <rule id="275707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1985 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>