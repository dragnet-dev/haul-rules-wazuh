<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2707 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2a957b44-a220-5107-8733-66376cbafe67 -->
  <rule id="673234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2707 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>