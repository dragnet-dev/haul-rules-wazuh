<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1369 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: b988d08b-75ae-591e-81b7-be6b841a8740 -->
  <rule id="218210" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1369 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>