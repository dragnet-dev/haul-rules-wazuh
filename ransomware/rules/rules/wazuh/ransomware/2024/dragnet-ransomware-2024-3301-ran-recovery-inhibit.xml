<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3301 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: fcabf2d5-d7a7-5270-987f-1546c25f7d15 -->
  <rule id="234943" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3301 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>