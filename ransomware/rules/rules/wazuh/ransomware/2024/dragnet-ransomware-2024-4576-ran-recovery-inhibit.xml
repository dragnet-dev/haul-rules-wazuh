<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4576 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: b2c59b89-4809-59c5-a7c2-839ee28042ce -->
  <rule id="287355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4576 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>