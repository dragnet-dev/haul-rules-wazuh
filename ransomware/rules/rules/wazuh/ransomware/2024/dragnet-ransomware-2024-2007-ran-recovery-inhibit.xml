<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2007 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 97d52219-93ba-52bd-94fc-53278aa711ea -->
  <rule id="765522" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2007 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>