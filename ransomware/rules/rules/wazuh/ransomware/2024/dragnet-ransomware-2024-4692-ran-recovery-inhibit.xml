<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4692 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 1ca2d954-eb66-50e4-b07a-98e032461475 -->
  <rule id="232595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4692 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>