<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5204 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1ac27521-7a04-5384-857f-b4191cd46937 -->
  <rule id="782752" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5204 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>