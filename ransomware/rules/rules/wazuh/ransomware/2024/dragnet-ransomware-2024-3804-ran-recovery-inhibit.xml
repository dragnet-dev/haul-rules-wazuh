<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3804 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 42e51a8d-036f-5ffd-9a9f-f7756d7b6fc6 -->
  <rule id="298426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3804 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>