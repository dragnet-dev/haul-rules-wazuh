<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3146 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d0d6f155-e2d6-514a-9edf-09ba572df537 -->
  <rule id="749911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3146 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>