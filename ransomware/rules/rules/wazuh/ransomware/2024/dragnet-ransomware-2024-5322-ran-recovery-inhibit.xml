<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5322 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: cb105683-9d97-5b52-a3fb-7c13ae8c060f -->
  <rule id="331056" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5322 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>