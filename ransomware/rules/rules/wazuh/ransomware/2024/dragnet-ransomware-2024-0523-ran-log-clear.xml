<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0523 — Event Log Clearing (chort) | Status: experimental | Sigma ID: 1a185e61-b951-5e56-a599-e00ca9628f6d -->
  <rule id="689746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0523 — Event Log Clearing (chort)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>