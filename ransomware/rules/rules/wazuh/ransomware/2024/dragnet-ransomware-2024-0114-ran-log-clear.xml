<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0114 — Event Log Clearing (8base) | Status: experimental | Sigma ID: 6077d4d1-bd9d-57d4-ba18-1632cb8ab9c8 -->
  <rule id="359277" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0114 — Event Log Clearing (8base)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>