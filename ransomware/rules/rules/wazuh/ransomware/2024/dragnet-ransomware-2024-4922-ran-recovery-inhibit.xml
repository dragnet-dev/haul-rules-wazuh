<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4922 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 4348a9c7-dfa0-599e-82c7-9f0f294a86fb -->
  <rule id="432636" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4922 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>