<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0327 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: a8860aa3-1730-5027-990e-1407fc866d64 -->
  <rule id="941770" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0327 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>