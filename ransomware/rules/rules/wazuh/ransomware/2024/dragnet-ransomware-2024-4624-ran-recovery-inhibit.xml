<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4624 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 35d39c69-06a1-583b-9252-eb1eacc8cdac -->
  <rule id="274366" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4624 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>