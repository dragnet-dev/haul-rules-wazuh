<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4295 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: a788634c-bfcf-5bf8-bb01-9b93bc37903d -->
  <rule id="278863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4295 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>