<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3506 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 91fff630-0272-5c35-a289-18a0224c4b90 -->
  <rule id="268316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3506 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>