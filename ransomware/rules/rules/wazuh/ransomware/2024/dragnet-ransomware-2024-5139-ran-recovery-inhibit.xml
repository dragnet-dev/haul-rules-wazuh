<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5139 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: c5e59c09-5095-578a-8a3b-1f842f551aa1 -->
  <rule id="623356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5139 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>