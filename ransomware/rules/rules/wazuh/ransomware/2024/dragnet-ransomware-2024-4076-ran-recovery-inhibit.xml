<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4076 — Recovery Inhibition (madliberator) | Status: experimental | Sigma ID: b6831325-5255-553d-9807-2df8570f4656 -->
  <rule id="368313" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4076 — Recovery Inhibition (madliberator)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>