<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3648 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 70fcff39-21cf-56d8-ab78-df0529e3f950 -->
  <rule id="252287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3648 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>