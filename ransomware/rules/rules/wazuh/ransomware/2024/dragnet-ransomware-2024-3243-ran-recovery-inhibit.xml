<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3243 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 7d461a49-d3c8-5ed0-8b13-3f4a79392ac8 -->
  <rule id="307386" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3243 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>