<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3103 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 300837bf-79a1-590e-8f3d-32b2f60a7266 -->
  <rule id="413403" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3103 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>