<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5451 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0ae31ab9-9877-5371-9f66-726e74810472 -->
  <rule id="962507" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5451 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>