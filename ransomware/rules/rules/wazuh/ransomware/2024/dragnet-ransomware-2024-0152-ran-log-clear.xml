<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0152 — Event Log Clearing (blacklock) | Status: experimental | Sigma ID: 43f7645c-2f7d-57c2-b956-1fef87e09a7d -->
  <rule id="837645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0152 — Event Log Clearing (blacklock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>