<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0909 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 45a78ccf-5c89-5494-9d41-d26635dde738 -->
  <rule id="369260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0909 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>