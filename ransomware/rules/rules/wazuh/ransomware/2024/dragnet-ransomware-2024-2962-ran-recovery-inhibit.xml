<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2962 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 72a21b48-2453-5843-bc2b-e52634bd59cc -->
  <rule id="159547" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2962 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>