<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4732 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 98e2eeaa-4457-524b-9396-62c2d05b4a4d -->
  <rule id="550670" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4732 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>