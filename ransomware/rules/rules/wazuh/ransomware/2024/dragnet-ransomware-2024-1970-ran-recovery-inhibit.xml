<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1970 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 10c0aa43-414e-5a39-9c05-ad792ffce415 -->
  <rule id="904904" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1970 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>