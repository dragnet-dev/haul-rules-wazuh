<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1747 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: f21b2fd5-9824-5b50-91db-51063202faa3 -->
  <rule id="395567" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1747 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>