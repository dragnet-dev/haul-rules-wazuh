<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2948 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 0800ad8b-8abc-5d72-bc59-a230def0f06b -->
  <rule id="349738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2948 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>