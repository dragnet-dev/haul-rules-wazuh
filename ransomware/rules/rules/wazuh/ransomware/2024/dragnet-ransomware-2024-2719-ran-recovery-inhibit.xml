<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2719 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 8c0ff2ca-d177-51ef-8b29-79f86ef4bb7b -->
  <rule id="986552" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2719 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>