<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5765 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 184a5aa4-17d2-510b-8ab0-56f3f3ca1f65 -->
  <rule id="463690" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5765 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>