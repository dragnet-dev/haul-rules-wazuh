<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0355 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: 05109f04-4fb5-5de9-b040-2a536017be2c -->
  <rule id="175904" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0355 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>