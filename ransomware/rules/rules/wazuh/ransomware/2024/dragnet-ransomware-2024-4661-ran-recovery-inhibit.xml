<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4661 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 9809c37b-c43e-5f3d-8543-601980ce71d4 -->
  <rule id="769563" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4661 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>