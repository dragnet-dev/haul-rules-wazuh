<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5910 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: 20d2b824-d5ce-5a23-aa82-f7c22b24bbf6 -->
  <rule id="932382" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5910 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>