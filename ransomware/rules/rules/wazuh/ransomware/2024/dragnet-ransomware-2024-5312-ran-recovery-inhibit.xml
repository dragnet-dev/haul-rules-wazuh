<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5312 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 90704bcd-848a-5326-9e5d-cc4374bc511e -->
  <rule id="651275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5312 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>