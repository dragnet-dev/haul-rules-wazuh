<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3584 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 2baa145f-9617-5a45-b6ac-2a046bf18857 -->
  <rule id="317814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3584 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>