<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3900 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 3e3f3501-7b7e-5dd9-aeaa-e1bdb328b4bd -->
  <rule id="183350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3900 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>