<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4227 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b5c64fc7-7c91-58a6-8bc7-f73d1c2a1e44 -->
  <rule id="364239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4227 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>