<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2961 — Recovery Inhibition (mallox) | Status: experimental | Sigma ID: 1f6e3daf-ea6f-50a8-8efe-31e7b5759eb9 -->
  <rule id="480186" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2961 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>