<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0217 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 931323d0-e501-5b07-9ef3-b3dab3b9d9f1 -->
  <rule id="601181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0217 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>