<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3180 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 81f77d68-53e6-5c3c-a57a-fc4459b5f4f0 -->
  <rule id="398845" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3180 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>