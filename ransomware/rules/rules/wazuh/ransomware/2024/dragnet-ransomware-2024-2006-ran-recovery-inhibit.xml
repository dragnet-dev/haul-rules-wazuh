<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2006 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: 9722a7e7-cc8c-50d2-abaa-b5bedf54142a -->
  <rule id="755627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2006 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>