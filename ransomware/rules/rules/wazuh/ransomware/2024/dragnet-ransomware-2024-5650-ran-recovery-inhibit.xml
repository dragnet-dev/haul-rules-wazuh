<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5650 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 8314145c-e45f-57f8-b57d-f6dda2575b2e -->
  <rule id="314145" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5650 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>