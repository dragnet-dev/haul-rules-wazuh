<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5190 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: f91fdd90-5a26-5c17-9475-41d31e9bd467 -->
  <rule id="320797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5190 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>