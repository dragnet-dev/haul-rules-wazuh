<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5001 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: a8f40580-3761-5f5e-925c-47059d48aefc -->
  <rule id="943405" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5001 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>