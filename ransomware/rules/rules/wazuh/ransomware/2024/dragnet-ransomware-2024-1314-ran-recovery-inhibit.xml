<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1314 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 608cccf4-403b-52ea-88d4-d3ee0ae311de -->
  <rule id="793644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1314 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>