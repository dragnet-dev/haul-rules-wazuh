<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2939 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8621eadd-6b0d-5f20-bf1e-978f486c953e -->
  <rule id="507210" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2939 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>