<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3799 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: a3ec9268-a4e7-51e8-a30c-9d7faacb9aa1 -->
  <rule id="960492" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3799 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>