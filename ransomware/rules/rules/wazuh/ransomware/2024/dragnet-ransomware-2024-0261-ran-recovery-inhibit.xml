<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0261 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: 1f369aa5-f22d-5544-97f7-9def3e5e44bf -->
  <rule id="930634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0261 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>