<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3977 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d42b11a6-6b4c-5094-a532-11195f7bd77e -->
  <rule id="448311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3977 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>