<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5222 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4ec62d12-aaaf-5813-a60f-d98dc3283b5a -->
  <rule id="317005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5222 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>