<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3497 — Recovery Inhibition (bluebox) | Status: experimental | Sigma ID: 74eb3804-ffd4-539c-bce6-538e707a7d97 -->
  <rule id="217938" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3497 — Recovery Inhibition (bluebox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>