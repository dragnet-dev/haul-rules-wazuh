<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2451 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 491d07c6-0dab-5cb8-80a9-40f32b602a9c -->
  <rule id="990524" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2451 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>