<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5438 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 511cd21d-5066-57c3-9318-43cdc31c5356 -->
  <rule id="510212" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5438 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>