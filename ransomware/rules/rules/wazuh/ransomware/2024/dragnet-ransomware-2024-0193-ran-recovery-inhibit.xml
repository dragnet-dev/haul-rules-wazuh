<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0193 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 5839d14f-e8c5-5f4d-a409-2ac64fb520c3 -->
  <rule id="443714" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0193 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>