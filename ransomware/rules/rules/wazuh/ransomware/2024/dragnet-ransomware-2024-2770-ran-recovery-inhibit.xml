<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2770 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 61fd019e-32d3-57e1-9048-3c17fc5c7f66 -->
  <rule id="786901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2770 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>