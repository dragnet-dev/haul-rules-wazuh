<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1829 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 0445b0c3-7d63-592f-845d-74ee59cdd71b -->
  <rule id="340972" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1829 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>