<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5615 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 528c4bc8-c3b4-572a-92c4-e42b094c3ae0 -->
  <rule id="553675" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5615 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>