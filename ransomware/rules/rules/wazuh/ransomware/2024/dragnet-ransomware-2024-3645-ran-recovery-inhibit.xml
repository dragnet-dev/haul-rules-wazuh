<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3645 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1c030761-2204-519c-bceb-0892ee507205 -->
  <rule id="203076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3645 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>