<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3212 — Recovery Inhibition (knight) | Status: experimental | Sigma ID: 221dcb96-2492-51ed-8e4b-049fa736dacc -->
  <rule id="187479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3212 — Recovery Inhibition (knight)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>