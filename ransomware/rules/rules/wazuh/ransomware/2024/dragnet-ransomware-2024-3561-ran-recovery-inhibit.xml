<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3561 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 311f8c12-d41d-5703-9d85-9048c11ba5c4 -->
  <rule id="887001" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3561 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>