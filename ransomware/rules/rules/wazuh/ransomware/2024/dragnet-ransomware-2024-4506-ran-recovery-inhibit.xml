<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4506 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 13ecedca-9b06-535e-8875-fbca6af9fd14 -->
  <rule id="301948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4506 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>