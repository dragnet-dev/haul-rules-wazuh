<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1473 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d3329631-0c6c-53d8-927a-2879e78d6bc5 -->
  <rule id="533296" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1473 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>