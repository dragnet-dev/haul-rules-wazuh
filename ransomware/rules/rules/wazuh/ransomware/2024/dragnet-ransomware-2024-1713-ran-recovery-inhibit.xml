<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1713 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 39a3d14b-a481-5862-abf0-bf4570935f92 -->
  <rule id="215011" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1713 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>