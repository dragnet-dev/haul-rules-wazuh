<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1266 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: dcdd86dc-d92a-5107-9e2f-109d3f5c496f -->
  <rule id="354186" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1266 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>