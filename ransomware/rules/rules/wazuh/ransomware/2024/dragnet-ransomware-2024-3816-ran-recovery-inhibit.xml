<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3816 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 6730eeab-ed07-5263-b38f-b19b8875af65 -->
  <rule id="923118" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3816 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>