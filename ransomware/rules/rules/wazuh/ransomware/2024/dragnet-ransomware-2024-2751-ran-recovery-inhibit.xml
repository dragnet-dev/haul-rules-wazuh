<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2751 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: a8054253-f932-538a-a23b-cfae3be46ae8 -->
  <rule id="280542" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2751 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>