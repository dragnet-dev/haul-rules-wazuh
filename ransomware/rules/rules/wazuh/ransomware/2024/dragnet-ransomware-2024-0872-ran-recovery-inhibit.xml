<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0872 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: f70f4f24-026d-53eb-b483-8f9c2a0f915f -->
  <rule id="521679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0872 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>