<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5147 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 5c96292f-6530-516a-b2df-6d63b1f56814 -->
  <rule id="396292" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5147 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>