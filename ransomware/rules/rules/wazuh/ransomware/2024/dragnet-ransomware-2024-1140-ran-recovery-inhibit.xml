<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1140 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: e3d6a6e5-f195-5ff4-9ebd-019883a03973 -->
  <rule id="182666" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1140 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>