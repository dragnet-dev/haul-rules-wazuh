<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3607 — Event Log Clearing (ElDorado) | Status: deprecated | Sigma ID: d6acb4f9-1d17-50d9-984b-69bc7c7c24e5 -->
  <rule id="298194" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3607 — Event Log Clearing (ElDorado)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>