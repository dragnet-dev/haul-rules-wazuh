<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1405 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7e88e6c8-e432-5fd5-83fc-a09b91dee6d4 -->
  <rule id="330226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1405 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>