<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0209 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1d607e44-b3d1-56a5-a0a7-5713ed4967fc -->
  <rule id="337264" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0209 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>