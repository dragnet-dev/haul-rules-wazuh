<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4418 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: f0a13b59-5351-505a-b420-ec8ccc58a3c8 -->
  <rule id="356219" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4418 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>