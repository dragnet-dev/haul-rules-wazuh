<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1320 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 33061b15-f740-5a68-b6a8-f0748baa52c7 -->
  <rule id="889871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1320 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>