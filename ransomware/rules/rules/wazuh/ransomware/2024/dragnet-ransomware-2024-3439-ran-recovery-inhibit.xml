<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3439 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 0fe6b610-a197-5c0d-bb59-c780a1c00831 -->
  <rule id="574761" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3439 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>