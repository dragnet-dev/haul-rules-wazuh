<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3451 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 41cf33cf-d14f-5a21-944e-000b6d9b1216 -->
  <rule id="270333" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3451 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>