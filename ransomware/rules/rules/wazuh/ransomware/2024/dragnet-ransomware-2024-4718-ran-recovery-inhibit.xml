<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4718 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: fa005145-0e50-5842-90ca-f9d090263a9d -->
  <rule id="800051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4718 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>