<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5166 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 85876bef-33df-5d40-885e-b9dcc64620f0 -->
  <rule id="574027" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5166 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>