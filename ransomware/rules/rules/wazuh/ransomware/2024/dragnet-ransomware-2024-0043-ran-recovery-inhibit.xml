<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0043 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 9b65eab8-d5ee-506b-89c1-b46e17b56599 -->
  <rule id="484874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0043 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>