<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3709 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 05a52965-a175-53fe-906a-ae95675f1766 -->
  <rule id="152965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3709 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>