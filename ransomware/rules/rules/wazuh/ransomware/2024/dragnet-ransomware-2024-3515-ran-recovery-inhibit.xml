<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3515 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 3e181e28-6e8a-5de4-8af1-1b5d863f85d6 -->
  <rule id="149102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3515 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>