<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1311 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 630ecc4f-b174-50e2-a494-d363e8d0861c -->
  <rule id="884268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1311 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>