<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3924 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: cfabda70-f05a-5308-9957-24ff3227cf17 -->
  <rule id="209946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3924 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>