<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3421 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 7c1647a1-a17a-5a3d-822b-1c65ff615be7 -->
  <rule id="441647" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3421 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>