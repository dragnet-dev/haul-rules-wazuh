<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4459 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: c709b0ea-42d5-5f19-b2df-2e33a326c7fb -->
  <rule id="333550" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4459 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>