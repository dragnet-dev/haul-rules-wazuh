<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0198 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3d2250da-7720-5a0a-9a68-f7d57f5050e5 -->
  <rule id="896013" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0198 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>