<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2543 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 9b6381ab-538b-5e83-9e9f-ac66ac0141cd -->
  <rule id="756381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2543 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>