<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4469 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 5b7504d8-a892-5d8f-8d98-4861e7a7a908 -->
  <rule id="380077" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4469 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>