<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3155 — Recovery Inhibition (trinity) | Status: experimental | Sigma ID: ef164718-1706-5282-9e7b-76c687efe58f -->
  <rule id="691647" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3155 — Recovery Inhibition (trinity)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>