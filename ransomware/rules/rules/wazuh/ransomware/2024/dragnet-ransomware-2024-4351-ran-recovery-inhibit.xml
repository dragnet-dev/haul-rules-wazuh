<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4351 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 9c72f3ef-782b-5d07-bccf-a6cdbd57704d -->
  <rule id="807673" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4351 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>