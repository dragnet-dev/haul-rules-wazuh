<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1674 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 68b7d20c-19c1-55fa-bee4-e25ab127f6b8 -->
  <rule id="959652" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1674 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>