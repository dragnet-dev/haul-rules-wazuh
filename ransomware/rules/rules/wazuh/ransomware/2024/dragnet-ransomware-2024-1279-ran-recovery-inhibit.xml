<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1279 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: beef1927-81e3-5247-84fb-e2fcadd9923d -->
  <rule id="487919" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1279 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>