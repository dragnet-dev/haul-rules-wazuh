<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1588 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 9a8cc4a3-c1b5-5f93-9186-d461c57026e3 -->
  <rule id="464924" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1588 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>