<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2288 — Event Log Clearing (snatch) | Status: experimental | Sigma ID: 4a6440bf-5d0a-54f7-bd1f-6b38e65a51a4 -->
  <rule id="343051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2288 — Event Log Clearing (snatch)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>