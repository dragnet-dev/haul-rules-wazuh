<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1756 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b3096466-9fc2-59f5-afba-9c7c6ce4a657 -->
  <rule id="330964" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1756 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>