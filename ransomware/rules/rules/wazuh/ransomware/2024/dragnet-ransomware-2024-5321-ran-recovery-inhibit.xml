<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5321 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1c338aad-e874-5ba1-98d7-015533e8e610 -->
  <rule id="154698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5321 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>