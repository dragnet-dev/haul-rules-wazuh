<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5618 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: c9b34095-41d1-53eb-b806-8c35b36b8b5a -->
  <rule id="375340" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5618 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>