<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5005 — Event Log Clearing (interlock) | Status: experimental | Sigma ID: 6f881cc9-2e9e-5c14-aab5-dc47db71d5d6 -->
  <rule id="990108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5005 — Event Log Clearing (interlock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>