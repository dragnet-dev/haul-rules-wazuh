<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0980 — Event Log Clearing (datacarry) | Status: deprecated | Sigma ID: 9262176f-e6a5-5e9d-8fd4-e3c6d318d242 -->
  <rule id="362176" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0980 — Event Log Clearing (datacarry)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>