<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1015 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: bc44ffd9-445f-5d9b-b477-4b69f67c9a9e -->
  <rule id="424319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1015 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>