<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4155 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 4b3743b4-dc4d-5719-92c2-22815450b439 -->
  <rule id="459899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4155 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>