<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5309 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: aec06ba3-6f13-5b96-b07c-28d100e4d0c1 -->
  <rule id="973707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5309 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>