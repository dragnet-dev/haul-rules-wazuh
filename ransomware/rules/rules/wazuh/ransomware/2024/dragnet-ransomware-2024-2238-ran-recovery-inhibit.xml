<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2238 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3e1d93bf-dd3b-58af-bf21-c3a667d19b64 -->
  <rule id="719899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2238 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>