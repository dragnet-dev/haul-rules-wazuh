<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5426 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 79b5219a-9aa8-5585-8603-8e162c201897 -->
  <rule id="475521" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5426 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>