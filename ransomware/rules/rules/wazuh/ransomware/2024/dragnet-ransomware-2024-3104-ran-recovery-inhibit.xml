<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3104 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 5419648e-e511-5d13-8c4c-fd983c7d02b9 -->
  <rule id="119648" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3104 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>