<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1386 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 03d5ed48-229d-5b1d-8ebb-c9f44c42d8a1 -->
  <rule id="776774" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1386 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>