<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1784 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c6199b4a-8db6-53ee-a646-9e3d0b7c8574 -->
  <rule id="319195" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1784 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>