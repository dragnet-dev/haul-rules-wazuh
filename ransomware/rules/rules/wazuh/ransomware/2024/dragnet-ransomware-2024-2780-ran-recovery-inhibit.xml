<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2780 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 066ea10e-8c5e-5c37-b055-6c7de9abecc9 -->
  <rule id="913010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2780 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>