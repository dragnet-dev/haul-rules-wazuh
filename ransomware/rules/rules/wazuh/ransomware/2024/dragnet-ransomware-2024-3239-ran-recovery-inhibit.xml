<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3239 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: d45b9b6e-bca9-5d5a-af13-17df38407193 -->
  <rule id="845115" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3239 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>