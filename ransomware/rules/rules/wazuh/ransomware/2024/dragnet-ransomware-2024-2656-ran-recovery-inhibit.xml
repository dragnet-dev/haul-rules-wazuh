<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2656 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: a549e92f-bfd0-5616-a645-e0e4cfe7f1a4 -->
  <rule id="887989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2656 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>