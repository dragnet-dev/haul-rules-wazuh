<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2605 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: d6ca3de3-6cdd-5f78-ad25-920f38aa0ff5 -->
  <rule id="302941" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2605 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>