<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3174 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0c2ec189-0d32-5605-be56-80744e89dcdf -->
  <rule id="546818" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3174 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>