<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3814 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 0d3c1bdf-fa42-5acb-b714-8f102f08ce81 -->
  <rule id="178845" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3814 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>