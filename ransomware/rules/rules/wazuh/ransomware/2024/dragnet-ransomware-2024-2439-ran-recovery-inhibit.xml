<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2439 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: cbc58ca2-b90f-5da1-a591-cf751cb6d93d -->
  <rule id="816940" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2439 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>