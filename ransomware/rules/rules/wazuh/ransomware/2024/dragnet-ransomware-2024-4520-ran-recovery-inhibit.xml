<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4520 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 45ce1e2a-0e0b-5aba-a138-bec6cf76b483 -->
  <rule id="176190" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4520 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>