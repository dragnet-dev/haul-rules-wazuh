<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3333 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: c7b5f8d4-7c50-5371-9302-7e37396f01d8 -->
  <rule id="669758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3333 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>