<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1200 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 926d3002-8dd5-517c-8fcc-0288e759ad28 -->
  <rule id="682930" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1200 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>