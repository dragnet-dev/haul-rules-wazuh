<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0621 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c95053f4-e9c7-5edf-b6b5-21d8735f3f63 -->
  <rule id="495053" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0621 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>