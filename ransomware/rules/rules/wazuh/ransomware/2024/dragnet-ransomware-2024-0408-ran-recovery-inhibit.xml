<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0408 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: c4006801-cdde-5424-87bf-e55aac552db9 -->
  <rule id="440068" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0408 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>