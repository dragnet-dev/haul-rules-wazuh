<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4962 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 97796e60-2d2e-5b97-bee1-79eb62203e55 -->
  <rule id="764750" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4962 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>