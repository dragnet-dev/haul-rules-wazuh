<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5246 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5a4fe58f-b1c5-59c2-9223-db9bc0b1b632 -->
  <rule id="616785" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5246 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>