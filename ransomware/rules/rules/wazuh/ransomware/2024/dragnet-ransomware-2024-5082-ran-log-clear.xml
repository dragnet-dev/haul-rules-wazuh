<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5082 — Event Log Clearing (metaencryptor) | Status: experimental | Sigma ID: e7eeb1fd-7044-5760-82d9-9fe64fdb7918 -->
  <rule id="759311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5082 — Event Log Clearing (metaencryptor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>