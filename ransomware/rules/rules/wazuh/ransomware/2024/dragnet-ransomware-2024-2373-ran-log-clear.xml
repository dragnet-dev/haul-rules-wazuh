<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2373 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 78fee2a8-9bc2-5e78-bc70-40c6d8a98607 -->
  <rule id="635662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2373 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>