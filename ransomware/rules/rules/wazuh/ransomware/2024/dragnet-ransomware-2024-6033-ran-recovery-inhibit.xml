<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6033 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: b2ed2481-d010-5944-bd11-cb8c1a68abe5 -->
  <rule id="290924" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6033 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>