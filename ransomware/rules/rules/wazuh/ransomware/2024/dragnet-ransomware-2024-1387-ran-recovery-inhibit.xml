<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1387 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 944fe399-e582-5b17-8dab-5898908544ff -->
  <rule id="719183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1387 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>