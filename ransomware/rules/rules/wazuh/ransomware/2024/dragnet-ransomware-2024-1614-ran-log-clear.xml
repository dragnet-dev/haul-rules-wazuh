<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1614 — Event Log Clearing (qiulong) | Status: experimental | Sigma ID: ce6c42dd-315e-52d8-8fa5-4f5929639396 -->
  <rule id="706842" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1614 — Event Log Clearing (qiulong)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>