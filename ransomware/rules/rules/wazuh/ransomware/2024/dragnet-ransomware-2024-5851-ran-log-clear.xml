<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5851 — Event Log Clearing (cloak) | Status: deprecated | Sigma ID: 69fd68c8-2513-56f6-bd22-9ce4a7e07100 -->
  <rule id="991768" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5851 — Event Log Clearing (cloak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>