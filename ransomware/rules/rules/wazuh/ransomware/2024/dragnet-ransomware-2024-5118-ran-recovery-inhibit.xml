<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5118 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 675dd4cf-c126-5049-a914-924dbb6f5a21 -->
  <rule id="930214" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5118 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>