<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5404 — Recovery Inhibition (play) | Status: experimental | Sigma ID: fbc021e2-a8cd-5c30-a4bf-3d6a321f5824 -->
  <rule id="528021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5404 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>