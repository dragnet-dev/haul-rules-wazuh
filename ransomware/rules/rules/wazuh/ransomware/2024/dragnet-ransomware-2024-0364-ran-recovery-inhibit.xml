<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0364 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: cc3bcfbb-d8cc-5d67-961e-e6477c551ee8 -->
  <rule id="371151" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0364 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>