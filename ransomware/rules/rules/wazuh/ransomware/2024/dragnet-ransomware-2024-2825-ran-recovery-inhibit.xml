<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2825 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: ace04062-0a85-5ad5-bc08-b71bfd3fcf41 -->
  <rule id="166040" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2825 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>