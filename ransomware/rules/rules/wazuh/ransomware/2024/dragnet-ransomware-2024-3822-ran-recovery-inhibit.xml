<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3822 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 07e30b30-4be7-5280-84b3-b6b0b76fff15 -->
  <rule id="320913" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3822 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>