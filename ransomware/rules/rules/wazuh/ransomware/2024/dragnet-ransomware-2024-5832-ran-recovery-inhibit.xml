<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5832 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 312429cc-dff7-56a5-a4f2-fa2b135707c6 -->
  <rule id="598876" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5832 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>