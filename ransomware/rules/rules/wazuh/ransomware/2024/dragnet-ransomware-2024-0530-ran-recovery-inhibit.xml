<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0530 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 6fae03bb-e63e-51e3-b4aa-fb3c02bca892 -->
  <rule id="259003" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0530 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>