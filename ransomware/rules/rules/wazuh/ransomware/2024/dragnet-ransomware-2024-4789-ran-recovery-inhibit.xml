<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4789 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 2ce7773e-5f0a-5659-93dd-577708601438 -->
  <rule id="987773" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4789 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>