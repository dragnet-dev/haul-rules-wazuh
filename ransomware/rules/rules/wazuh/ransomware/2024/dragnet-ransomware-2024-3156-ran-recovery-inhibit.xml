<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3156 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: e1ec4a7c-006f-5415-9ceb-b0d3ff16c9d2 -->
  <rule id="513194" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3156 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
