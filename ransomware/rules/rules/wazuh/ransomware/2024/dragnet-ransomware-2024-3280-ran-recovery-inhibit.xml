<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3280 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3ec777de-72d4-5929-a359-1a38d2b437bb -->
  <rule id="204777" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3280 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>