<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2370 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: f8fcd461-097a-5582-b998-29d6e3b726e3 -->
  <rule id="312134" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2370 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>