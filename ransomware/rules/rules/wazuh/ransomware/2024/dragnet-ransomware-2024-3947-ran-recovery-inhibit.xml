<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3947 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: b843ef86-5d1e-53c9-895f-3320f994c4db -->
  <rule id="432047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3947 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>