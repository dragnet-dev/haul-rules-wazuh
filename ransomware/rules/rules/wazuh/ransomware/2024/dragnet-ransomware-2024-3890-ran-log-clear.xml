<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3890 — Event Log Clearing (funksec) | Status: experimental | Sigma ID: aad3fd48-f090-5dab-a068-242af17d7617 -->
  <rule id="797501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3890 — Event Log Clearing (funksec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>