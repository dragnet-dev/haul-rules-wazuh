<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0107 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: 97937a8b-fdee-56b1-85f0-c5593bd79cd6 -->
  <rule id="767002" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0107 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>