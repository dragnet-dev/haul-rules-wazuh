<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4827 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 5c0b3555-3ecc-5c8b-ae9b-79b9c7a52155 -->
  <rule id="673135" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4827 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>