<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5304 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: ba1dc50f-68a5-5fd8-bb66-4aac3daa042a -->
  <rule id="366365" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5304 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>