<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3223 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: 15d7819a-e332-56a9-9b57-287b8288b937 -->
  <rule id="837819" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3223 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
