<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5578 — Recovery Inhibition (play) | Status: experimental | Sigma ID: fe078b8b-2081-5575-9d4f-dd237b3a0e3c -->
  <rule id="565259" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5578 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>