<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4573 — Event Log Clearing (ransomhub) | Status: deprecated | Sigma ID: c1b2a950-78a3-5b3a-9c85-6c4b93ddd27e -->
  <rule id="515629" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4573 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>