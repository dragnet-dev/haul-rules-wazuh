<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1986 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f1a9c7d1-63ac-503f-bb19-7b8c3b49e907 -->
  <rule id="383167" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1986 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>