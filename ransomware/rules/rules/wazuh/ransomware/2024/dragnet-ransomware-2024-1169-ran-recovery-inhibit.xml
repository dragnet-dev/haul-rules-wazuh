<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1169 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: e3fd2d73-c23f-5f13-ba37-f52a6ba8a415 -->
  <rule id="597805" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1169 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>