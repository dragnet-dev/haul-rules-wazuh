<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0527 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: e967a88e-6b71-52bd-b713-26b76af319a5 -->
  <rule id="694828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0527 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>