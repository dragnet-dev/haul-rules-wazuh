<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0088 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 2b2f02de-8a42-5f37-8a02-378a59883ee5 -->
  <rule id="383245" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0088 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>