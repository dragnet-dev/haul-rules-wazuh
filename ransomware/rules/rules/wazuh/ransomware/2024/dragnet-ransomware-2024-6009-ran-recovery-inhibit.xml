<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6009 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4f709b1a-a590-582d-8e82-e6cbf6873b9a -->
  <rule id="475355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6009 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>