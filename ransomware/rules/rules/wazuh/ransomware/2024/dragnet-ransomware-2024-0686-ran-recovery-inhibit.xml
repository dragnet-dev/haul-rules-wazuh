  <rule id="217215" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0686 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
