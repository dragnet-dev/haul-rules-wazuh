<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2578 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 27949ced-25a9-5d7c-8986-3e7a2fb0fef5 -->
  <rule id="955150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2578 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>