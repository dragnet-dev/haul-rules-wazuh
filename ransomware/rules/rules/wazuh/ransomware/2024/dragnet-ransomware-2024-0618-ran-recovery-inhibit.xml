<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0618 — Recovery Inhibition (qiulong) | Status: experimental | Sigma ID: 310121c5-9756-5b48-84bc-5f08c636f442 -->
  <rule id="561948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0618 — Recovery Inhibition (qiulong)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>