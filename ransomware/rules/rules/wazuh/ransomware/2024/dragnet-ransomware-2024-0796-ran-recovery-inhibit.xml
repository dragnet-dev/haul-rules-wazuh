<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0796 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c8abcc35-5bff-59e3-b121-eed9ebc5b05d -->
  <rule id="432588" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0796 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>