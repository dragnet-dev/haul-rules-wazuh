<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1895 — Recovery Inhibition (raznatovic) | Status: experimental | Sigma ID: 2963b4d2-0082-51de-acbe-eb313b99d36b -->
  <rule id="487117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1895 — Recovery Inhibition (raznatovic)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>