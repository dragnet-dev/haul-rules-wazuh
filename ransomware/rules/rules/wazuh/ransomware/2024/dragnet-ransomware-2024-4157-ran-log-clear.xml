<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4157 — Event Log Clearing (werewolves) | Status: experimental | Sigma ID: 40c6d5ff-f7f9-50cf-b6c4-632d58f2f3cf -->
  <rule id="244295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4157 — Event Log Clearing (werewolves)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>