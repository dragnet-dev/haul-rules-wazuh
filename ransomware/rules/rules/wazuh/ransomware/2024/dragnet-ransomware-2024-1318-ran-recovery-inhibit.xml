<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1318 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 0726df5f-0870-59f4-8672-44c88826e927 -->
  <rule id="160795" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1318 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>