<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0848 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: a364c20c-5b94-5f30-b008-78c6ba562ff7 -->
  <rule id="858362" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0848 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>