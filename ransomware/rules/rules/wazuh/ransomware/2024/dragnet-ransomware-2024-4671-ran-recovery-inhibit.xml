<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4671 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 0957f9c1-5e72-549b-a6bd-126d62cf6f52 -->
  <rule id="752476" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4671 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>