<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1990 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 33bb1dee-c646-5700-a100-a705f0818b69 -->
  <rule id="581629" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1990 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>