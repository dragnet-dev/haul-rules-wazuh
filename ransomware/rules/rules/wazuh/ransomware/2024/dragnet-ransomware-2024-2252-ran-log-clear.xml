<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2252 — Event Log Clearing (8base) | Status: experimental | Sigma ID: 2cdf8e53-bee6-5f2a-aa4a-4be16ffaca6e -->
  <rule id="138062" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2252 — Event Log Clearing (8base)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>