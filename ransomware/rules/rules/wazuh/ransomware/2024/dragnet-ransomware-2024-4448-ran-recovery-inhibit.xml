<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4448 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: fed5a71c-ac1f-5696-89bc-e8b65dfa6413 -->
  <rule id="324107" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4448 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>