<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5769 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 2b421ffc-2955-5ef4-9995-5d306f32b06d -->
  <rule id="416031" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5769 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>