<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0614 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b21c931c-1f0a-5dbe-8e03-8603ecdeb082 -->
  <rule id="994893" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0614 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>