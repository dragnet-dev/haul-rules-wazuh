<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3110 — Event Log Clearing (abyss) | Status: deprecated | Sigma ID: 5ade8d76-e8a2-5a0d-9c00-9a8b61db7747 -->
  <rule id="222061" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3110 — Event Log Clearing (abyss)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>