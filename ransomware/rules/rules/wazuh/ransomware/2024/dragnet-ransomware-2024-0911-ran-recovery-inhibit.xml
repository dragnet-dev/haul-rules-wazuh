<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0911 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 7cc9dee3-7803-51ad-9e6a-6b8e0e25f62c -->
  <rule id="712286" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0911 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>