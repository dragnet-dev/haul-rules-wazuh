<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2232 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: fd5f6fb2-9327-5c73-9e2e-b60a5a0182e8 -->
  <rule id="292111" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2232 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>