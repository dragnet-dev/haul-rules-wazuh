<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2286 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: b69a9ec6-2ce2-5de3-8e3e-6b51d1ef58e9 -->
  <rule id="394398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2286 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>