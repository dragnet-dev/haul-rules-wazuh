<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5161 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: d2513651-ee31-5eb8-b2a6-830db3a7a208 -->
  <rule id="525136" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5161 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
