<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3254 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 39e6ab71-09c7-5238-ba43-4d8934d8e5b5 -->
  <rule id="834987" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3254 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>