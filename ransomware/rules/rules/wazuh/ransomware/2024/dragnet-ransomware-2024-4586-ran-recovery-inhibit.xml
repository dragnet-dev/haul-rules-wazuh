<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4586 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 27c9f7d6-4402-558e-ac2e-b9ded9697f60 -->
  <rule id="691965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4586 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>