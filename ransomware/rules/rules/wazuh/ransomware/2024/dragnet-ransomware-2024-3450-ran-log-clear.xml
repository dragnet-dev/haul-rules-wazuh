<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3450 — Event Log Clearing (qiulong) | Status: experimental | Sigma ID: 31d3d546-d357-5843-8b47-7a08ba6f1a8f -->
  <rule id="150154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3450 — Event Log Clearing (qiulong)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>