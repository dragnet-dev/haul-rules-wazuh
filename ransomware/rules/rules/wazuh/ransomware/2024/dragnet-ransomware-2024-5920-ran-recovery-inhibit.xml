<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5920 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7f5f5661-8b84-52b4-a903-354f3403d170 -->
  <rule id="341556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5920 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>