<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1947 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: bbdfbc3e-5659-53d6-a7dd-d77bc15cda8b -->
  <rule id="712508" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1947 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>