<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5130 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 0312dbb9-48a3-5c16-8963-abb9885b0230 -->
  <rule id="481467" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5130 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>