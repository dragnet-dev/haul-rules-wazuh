<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4706 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: b2b7f015-8ebc-5924-a209-d2f4ee1ebed3 -->
  <rule id="286070" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4706 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>