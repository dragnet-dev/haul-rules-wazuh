<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0310 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 7051f729-3d27-54eb-9c8b-158b2ab4f3ce -->
  <rule id="328317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0310 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>