<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4938 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7cacb296-7703-5730-ad39-b730ed373359 -->
  <rule id="706672" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4938 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>