<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2987 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: bcca08fb-2668-54d5-aa7c-fa36951b163e -->
  <rule id="433008" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2987 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>