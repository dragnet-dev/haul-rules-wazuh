<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4205 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: 86ae5d86-fa4a-5223-98a4-09b5c1994d76 -->
  <rule id="950493" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4205 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>