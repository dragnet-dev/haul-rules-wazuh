<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5534 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 96e14bb3-89ea-5050-b380-1a742a612235 -->
  <rule id="780235" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5534 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>