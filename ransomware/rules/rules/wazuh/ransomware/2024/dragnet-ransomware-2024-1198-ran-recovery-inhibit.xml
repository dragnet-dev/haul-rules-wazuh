<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1198 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 5951095b-6ea9-52ee-9271-a501876d587b -->
  <rule id="651095" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1198 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>