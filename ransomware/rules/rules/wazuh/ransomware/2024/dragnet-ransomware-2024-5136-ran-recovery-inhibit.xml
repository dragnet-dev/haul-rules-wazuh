<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5136 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f68b7b11-0421-5e26-af19-0557bc1d7a86 -->
  <rule id="515963" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5136 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>