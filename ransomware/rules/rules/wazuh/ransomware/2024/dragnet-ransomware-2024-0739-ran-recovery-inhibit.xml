<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0739 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 1ef79d44-ad6c-525b-bacd-8b7135132b38 -->
  <rule id="832774" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0739 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>