<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0717 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 4163ed11-e177-5d6d-8bd2-5d2166975422 -->
  <rule id="265965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0717 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>