<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4376 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 14f43786-ec08-5321-b50e-c588719d1dc9 -->
  <rule id="694378" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4376 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>