<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2535 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 8457aa8d-f42a-59c9-8a15-6bd6af895c2b -->
  <rule id="465162" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2535 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>