<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2290 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 3e737ada-b1a1-5821-92a3-74e060ef3e9c -->
  <rule id="203802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2290 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>