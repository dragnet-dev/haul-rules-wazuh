<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2491 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 94490d9f-a4d0-546e-ba20-741caa105611 -->
  <rule id="711853" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2491 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>