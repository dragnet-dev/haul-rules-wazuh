<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3290 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5f668c67-dff4-5575-9d5c-ff4319f89fa1 -->
  <rule id="730700" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3290 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>