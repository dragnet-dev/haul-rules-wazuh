<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4255 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 537398a3-a368-5f0e-8c92-4f77eabcf227 -->
  <rule id="598378" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4255 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>