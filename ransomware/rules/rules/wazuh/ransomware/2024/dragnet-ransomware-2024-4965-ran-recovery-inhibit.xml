<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4965 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 9c6b571e-5b90-54a9-ba07-87064c6f4cf2 -->
  <rule id="806757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4965 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>