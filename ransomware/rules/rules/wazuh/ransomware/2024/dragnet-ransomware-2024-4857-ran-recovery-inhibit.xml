<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4857 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: c3bf8f89-70f7-55cc-97c0-ac7acf315d4c -->
  <rule id="668783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4857 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>