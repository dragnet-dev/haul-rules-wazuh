<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6032 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: aaf5a1e5-cf4e-58c1-85d9-91065d014797 -->
  <rule id="876901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6032 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>