<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1547 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: dfb55bcf-4ece-568f-9b4e-abcf1c96ae03 -->
  <rule id="427291" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1547 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>