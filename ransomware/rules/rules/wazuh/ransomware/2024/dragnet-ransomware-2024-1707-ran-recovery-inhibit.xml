<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1707 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 6049738a-5c4f-5178-bffc-2334ee7da105 -->
  <rule id="749738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1707 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>