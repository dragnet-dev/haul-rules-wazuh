<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4443 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: a1b427ed-0599-580f-81f3-73a7667a6e91 -->
  <rule id="827427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4443 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>