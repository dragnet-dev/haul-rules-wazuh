<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4428 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 1710a1ae-4f5f-53b3-ada4-dea9600cade1 -->
  <rule id="879226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4428 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>