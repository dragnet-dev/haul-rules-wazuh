<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2876 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: ad958aae-1dde-530b-815e-a5bab81f51a0 -->
  <rule id="183338" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2876 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>