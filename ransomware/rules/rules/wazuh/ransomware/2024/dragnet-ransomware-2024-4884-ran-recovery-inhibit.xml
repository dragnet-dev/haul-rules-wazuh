<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4884 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 70e650e6-4eba-5c02-b1c5-3c970e8a7d82 -->
  <rule id="334650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4884 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>