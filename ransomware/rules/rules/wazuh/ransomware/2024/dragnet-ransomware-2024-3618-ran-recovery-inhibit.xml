<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3618 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 537bbbbc-9019-5592-8360-26c1de1ff0e9 -->
  <rule id="502555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3618 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>