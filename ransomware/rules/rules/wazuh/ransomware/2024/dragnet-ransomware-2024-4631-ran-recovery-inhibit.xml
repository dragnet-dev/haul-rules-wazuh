<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4631 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ed433a2e-ee72-57c1-92ec-5d708dd49dcc -->
  <rule id="298938" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4631 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>