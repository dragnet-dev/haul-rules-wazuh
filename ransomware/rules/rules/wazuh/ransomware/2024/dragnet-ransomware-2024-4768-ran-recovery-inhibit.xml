<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4768 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0f446fed-2797-50f4-b5ad-593ebeed2850 -->
  <rule id="454430" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4768 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>