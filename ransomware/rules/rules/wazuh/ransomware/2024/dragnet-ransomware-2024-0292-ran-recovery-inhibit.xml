<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0292 — Recovery Inhibition (sensayq) | Status: experimental | Sigma ID: 45a3901a-605e-5fce-9fd0-0021ec1f4a22 -->
  <rule id="203901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0292 — Recovery Inhibition (sensayq)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>