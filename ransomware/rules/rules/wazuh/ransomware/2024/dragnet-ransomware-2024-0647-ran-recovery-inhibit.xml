<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0647 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 6dd99dbe-bded-5cfe-a447-b347266ee2dc -->
  <rule id="212797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0647 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>