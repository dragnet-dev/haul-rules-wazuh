<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4270 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 80916207-1966-5fc5-ad2f-1460b1fa4796 -->
  <rule id="991620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4270 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>