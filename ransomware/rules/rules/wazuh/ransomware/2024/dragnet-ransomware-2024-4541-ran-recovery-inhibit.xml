<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4541 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8e7a6159-cfce-55d0-836a-79b0b1f40646 -->
  <rule id="584261" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4541 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>