<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2507 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: ffaff7cc-6442-5fa7-b129-c560af802a1d -->
  <rule id="247295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2507 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>