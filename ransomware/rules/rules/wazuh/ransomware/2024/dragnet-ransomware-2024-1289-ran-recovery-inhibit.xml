<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1289 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: bc93a1fd-62d1-5f46-80d3-1d262fd84ae1 -->
  <rule id="422981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1289 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>