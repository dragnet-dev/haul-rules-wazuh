<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1158 — Event Log Clearing (apt73) | Status: experimental | Sigma ID: 11f6e6fc-c04a-5602-8b20-2ac839086001 -->
  <rule id="507311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1158 — Event Log Clearing (apt73)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>