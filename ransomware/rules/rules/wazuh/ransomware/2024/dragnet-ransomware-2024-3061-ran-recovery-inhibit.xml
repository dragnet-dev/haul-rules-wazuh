<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3061 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8e727d93-9bca-5965-8df2-1d5f257e5129 -->
  <rule id="583645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3061 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>