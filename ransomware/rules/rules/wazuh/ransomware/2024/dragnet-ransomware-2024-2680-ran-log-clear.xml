<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2680 — Event Log Clearing (vanirgroup) | Status: deprecated | Sigma ID: eef14867-36e9-582d-85b2-1c06c0ae9ecb -->
  <rule id="323148" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2680 — Event Log Clearing (vanirgroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>