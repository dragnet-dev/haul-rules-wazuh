<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4326 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 79b36958-8f4b-5d34-831a-5419528659ea -->
  <rule id="475369" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4326 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>