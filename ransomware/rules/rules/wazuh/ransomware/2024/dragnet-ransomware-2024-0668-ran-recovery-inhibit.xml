<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0668 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: d9f0b3cf-d65e-5142-8811-35927bcc7959 -->
  <rule id="982513" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0668 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>