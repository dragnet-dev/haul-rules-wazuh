<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4609 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 2ce21451-6a11-5eeb-b43f-1898138e292d -->
  <rule id="982145" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4609 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>