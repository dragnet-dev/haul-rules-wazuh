<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0215 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 71b4a833-100c-5dde-809e-c7d2153b7fe0 -->
  <rule id="135948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0215 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>