<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3496 — Event Log Clearing (cloak) | Status: deprecated | Sigma ID: d5af447a-92a0-5e5f-8c65-df8f58cd1b51 -->
  <rule id="873544" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3496 — Event Log Clearing (cloak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>