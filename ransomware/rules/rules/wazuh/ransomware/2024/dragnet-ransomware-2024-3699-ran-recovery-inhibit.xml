<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3699 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 9f9d1dd4-eeef-5da3-b8c2-26971b26b378 -->
  <rule id="595549" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3699 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>