<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1651 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f12d149e-6263-5f8f-a5a5-7463c9394bde -->
  <rule id="720514" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1651 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>