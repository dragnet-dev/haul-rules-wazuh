<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4755 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a4d59c25-5655-5361-bf85-dea5ce395a17 -->
  <rule id="984156" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4755 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>