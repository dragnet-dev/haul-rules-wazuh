<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0070 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b86c5a2b-2a00-52af-af1c-5cfb31882d0a -->
  <rule id="438170" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0070 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>