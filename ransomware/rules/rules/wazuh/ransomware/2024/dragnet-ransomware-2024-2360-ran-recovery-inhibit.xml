<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2360 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 1cb88601-a5f0-5d14-8991-bbe07a5a1353 -->
  <rule id="198860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2360 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>