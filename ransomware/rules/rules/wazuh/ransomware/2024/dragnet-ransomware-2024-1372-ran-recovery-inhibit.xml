<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1372 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: ccc8a78b-c08c-539e-86f0-c1ad22aa22d0 -->
  <rule id="842987" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1372 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>