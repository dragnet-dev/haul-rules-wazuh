<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0962 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 28064d82-fb5f-59be-8685-10dba4cb0a14 -->
  <rule id="990378" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0962 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>