<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1781 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 217bf17c-5794-5ae1-b228-e98bd18a9e04 -->
  <rule id="274317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1781 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>