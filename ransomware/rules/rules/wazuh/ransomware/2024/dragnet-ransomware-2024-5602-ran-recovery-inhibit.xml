<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5602 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 29dd9b75-01c5-533c-a0bd-c60441717474 -->
  <rule id="423355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5602 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>