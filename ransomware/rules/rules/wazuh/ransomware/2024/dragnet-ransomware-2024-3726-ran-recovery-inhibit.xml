<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3726 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: a7613163-5c56-50ed-80bb-7f59e39b6be6 -->
  <rule id="276131" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3726 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>