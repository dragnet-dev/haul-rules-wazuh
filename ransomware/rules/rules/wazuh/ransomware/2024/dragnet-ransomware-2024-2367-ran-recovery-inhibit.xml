<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2367 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 96b1a66d-b70c-524c-b3fa-44877cd2ea67 -->
  <rule id="775466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2367 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
