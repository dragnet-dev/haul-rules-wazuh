<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4478 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 4aa24113-e65e-5bd4-851f-aac873954875 -->
  <rule id="394241" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4478 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>