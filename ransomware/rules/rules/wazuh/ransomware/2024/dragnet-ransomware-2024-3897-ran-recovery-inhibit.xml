<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3897 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: a54dc634-f3eb-55ec-b2e0-13b9abb03762 -->
  <rule id="100446" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3897 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>