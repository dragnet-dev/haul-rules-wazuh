<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5812 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a7e7399a-931c-5ab4-bf2a-fc6429557df4 -->
  <rule id="926739" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5812 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>