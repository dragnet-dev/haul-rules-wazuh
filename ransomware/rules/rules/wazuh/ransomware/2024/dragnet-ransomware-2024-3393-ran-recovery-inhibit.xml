<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3393 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 83b37906-e0ff-5c73-84a2-044dcbf2c539 -->
  <rule id="539379" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3393 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>