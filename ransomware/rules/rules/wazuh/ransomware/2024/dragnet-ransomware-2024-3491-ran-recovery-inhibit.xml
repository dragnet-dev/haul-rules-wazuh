<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3491 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 10a84bc8-b182-5efb-a036-26cd7ed2234a -->
  <rule id="873692" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3491 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
