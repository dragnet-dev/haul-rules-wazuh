<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1290 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b5664610-73f8-5160-a80a-888fe9566b21 -->
  <rule id="356646" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1290 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>