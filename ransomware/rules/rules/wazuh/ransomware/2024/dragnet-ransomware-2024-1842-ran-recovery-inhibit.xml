<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1842 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 90197119-8ee7-5f38-a136-9fdcbd08b932 -->
  <rule id="119711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1842 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>