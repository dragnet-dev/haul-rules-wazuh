<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5339 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 63253af0-a4ff-590e-935f-910b3ec65cb3 -->
  <rule id="212058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5339 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>