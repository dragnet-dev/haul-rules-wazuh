<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1979 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 7465a42e-1069-5fd2-84ed-db59bf429d86 -->
  <rule id="394504" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1979 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>