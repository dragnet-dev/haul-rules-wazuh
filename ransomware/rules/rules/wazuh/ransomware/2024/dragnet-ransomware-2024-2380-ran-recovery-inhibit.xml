<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2380 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: a1a23860-6cbc-58fa-9443-ca2c7f8eeaf0 -->
  <rule id="826238" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2380 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>