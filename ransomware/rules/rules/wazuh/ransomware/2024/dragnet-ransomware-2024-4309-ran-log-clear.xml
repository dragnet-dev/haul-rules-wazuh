<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4309 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: 4bc1d83d-b9da-5873-a2a1-f3dc8e8fa41f -->
  <rule id="239498" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4309 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>