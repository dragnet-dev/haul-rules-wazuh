<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2313 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 38509816-29a5-526e-b62c-a1e7419f99c4 -->
  <rule id="350981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2313 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>