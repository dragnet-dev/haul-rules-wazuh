<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0030 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 8f439421-cf51-5255-a439-97b73502a579 -->
  <rule id="634394" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0030 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>