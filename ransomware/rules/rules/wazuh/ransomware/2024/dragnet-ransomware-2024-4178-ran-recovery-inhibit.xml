<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4178 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5ad5c882-cd18-5681-8a07-8d9cf4b7d858 -->
  <rule id="625728" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4178 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>