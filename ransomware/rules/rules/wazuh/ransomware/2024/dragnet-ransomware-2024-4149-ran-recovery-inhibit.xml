<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4149 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 748abce5-5e4e-5e07-be4a-02e1d144d94a -->
  <rule id="466556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4149 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>