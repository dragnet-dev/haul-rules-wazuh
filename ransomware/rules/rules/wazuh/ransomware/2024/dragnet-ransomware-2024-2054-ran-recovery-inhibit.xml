<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2054 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: 8c3cd8fd-809a-598b-94b2-4bd49d923c63 -->
  <rule id="993738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2054 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>