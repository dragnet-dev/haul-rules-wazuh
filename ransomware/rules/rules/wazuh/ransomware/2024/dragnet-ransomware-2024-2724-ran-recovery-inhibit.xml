<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2724 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 3ce1da8b-6204-5046-9de9-ccee09e5ba1a -->
  <rule id="793914" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2724 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>