<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2511 — Recovery Inhibition (play) | Status: experimental | Sigma ID: cdb31f99-56f5-558b-947c-afc8ce7625c9 -->
  <rule id="866111" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2511 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>