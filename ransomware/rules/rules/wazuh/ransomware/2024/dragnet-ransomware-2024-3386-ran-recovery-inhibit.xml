<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3386 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: dc3ea984-3127-5a44-9bed-e38afd0dd275 -->
  <rule id="342029" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3386 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>