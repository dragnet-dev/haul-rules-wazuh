<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2695 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 8a4f3cfd-2851-551b-953e-23369bb1c685 -->
  <rule id="945500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2695 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>