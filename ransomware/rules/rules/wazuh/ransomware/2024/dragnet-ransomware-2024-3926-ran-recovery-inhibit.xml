<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3926 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 8bd7e1a2-39b9-5ad3-b850-3d3491558353 -->
  <rule id="980461" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3926 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>