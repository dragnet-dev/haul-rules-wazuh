<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5034 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2ae2ea38-fd3a-5ec1-adcd-b3e56c7eec39 -->
  <rule id="956906" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5034 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>