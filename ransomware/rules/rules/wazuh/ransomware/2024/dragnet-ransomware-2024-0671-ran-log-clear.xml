<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0671 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: 0b9af9d5-533a-57df-a4d6-db7eef8bb523 -->
  <rule id="502397" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0671 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>