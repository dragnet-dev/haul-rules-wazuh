<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0681 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 4c341c4a-ef43-52f2-b437-998ce5780c21 -->
  <rule id="421468" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0681 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>