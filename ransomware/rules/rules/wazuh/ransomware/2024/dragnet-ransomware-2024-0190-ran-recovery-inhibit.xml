<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0190 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 573a573a-de4d-59e1-8664-b14626c58ac5 -->
  <rule id="278573" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0190 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>