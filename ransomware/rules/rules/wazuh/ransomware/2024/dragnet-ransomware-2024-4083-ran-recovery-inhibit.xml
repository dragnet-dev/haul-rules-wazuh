<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4083 — Recovery Inhibition (madliberator) | Status: experimental | Sigma ID: 472f141c-30a8-5540-9196-d301c4473577 -->
  <rule id="467141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4083 — Recovery Inhibition (madliberator)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>