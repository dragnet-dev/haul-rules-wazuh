<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1452 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 330924a7-aac6-51be-87a6-a1ef1978985e -->
  <rule id="894794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1452 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>