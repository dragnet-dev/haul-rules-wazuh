<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5376 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: c5ef8712-3d60-552a-a521-9fc8be10f88a -->
  <rule id="623987" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5376 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>