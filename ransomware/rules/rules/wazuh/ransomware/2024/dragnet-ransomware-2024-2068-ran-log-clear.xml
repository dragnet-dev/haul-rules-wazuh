<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2068 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 2fc0102a-c21b-5616-bdd2-9e7c2f1373b9 -->
  <rule id="540102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2068 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>