<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2105 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7bf9661d-d93b-5262-991d-cdc67a1fcbc1 -->
  <rule id="283966" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2105 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>