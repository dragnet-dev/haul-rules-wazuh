<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5179 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e6b6f599-f55c-5dfa-ac5c-370d42ef3338 -->
  <rule id="256315" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5179 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>