<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1646 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a31dfb51-71af-5613-8a2c-8641fafe4196 -->
  <rule id="726555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1646 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>