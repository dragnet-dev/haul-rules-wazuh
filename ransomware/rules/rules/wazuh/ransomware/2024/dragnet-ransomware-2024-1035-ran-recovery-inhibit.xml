<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1035 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 59c043a5-8c08-5fdb-b264-9546e75f3722 -->
  <rule id="996698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1035 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>