<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4396 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 3b605402-7505-5552-9ae3-1c171cf8d9a8 -->
  <rule id="660540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4396 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>