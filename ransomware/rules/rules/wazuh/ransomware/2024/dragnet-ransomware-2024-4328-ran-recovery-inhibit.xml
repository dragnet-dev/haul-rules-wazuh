<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4328 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: abeccbe6-46a4-5073-9ac8-16d0a87bf059 -->
  <rule id="567275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4328 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>