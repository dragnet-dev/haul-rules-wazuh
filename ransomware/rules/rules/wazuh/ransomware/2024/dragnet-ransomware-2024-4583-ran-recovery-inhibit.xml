<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4583 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8025d18e-330d-5f0e-a901-1712447194d9 -->
  <rule id="484131" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4583 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>