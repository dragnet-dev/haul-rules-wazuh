<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0163 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: 1a34b5ef-7f98-59e0-8cb9-a7a8aa1af78e -->
  <rule id="544894" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0163 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>