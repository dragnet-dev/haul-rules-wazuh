<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3603 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 5f10788b-1b07-5b4d-a7b1-918cf95bdc0a -->
  <rule id="610788" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3603 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>