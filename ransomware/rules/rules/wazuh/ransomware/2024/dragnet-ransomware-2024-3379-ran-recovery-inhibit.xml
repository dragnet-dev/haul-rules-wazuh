<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3379 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: b2e30137-83b4-5ca2-b319-b0e243afe462 -->
  <rule id="106301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3379 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>