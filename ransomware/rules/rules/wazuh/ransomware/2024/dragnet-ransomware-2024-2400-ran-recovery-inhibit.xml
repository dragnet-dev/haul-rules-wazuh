<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2400 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 29bf9e16-1169-596c-8c96-c3065a2d897a -->
  <rule id="418558" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2400 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>