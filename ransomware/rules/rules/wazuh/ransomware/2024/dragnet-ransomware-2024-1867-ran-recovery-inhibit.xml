<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1867 — Recovery Inhibition (ransomexx) | Status: experimental | Sigma ID: 954c052e-666d-5d9d-bcf1-75959b2415da -->
  <rule id="727605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1867 — Recovery Inhibition (ransomexx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>