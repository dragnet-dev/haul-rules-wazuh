<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1271 — Event Log Clearing (BrainCipher) | Status: experimental | Sigma ID: 25cc76fb-05ee-58a3-87a8-62817325744c -->
  <rule id="767631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1271 — Event Log Clearing (BrainCipher)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>