<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2522 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: a19ef5ae-a208-5d8b-b76f-e3851a8551b1 -->
  <rule id="911035" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2522 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>