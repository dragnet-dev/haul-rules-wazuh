<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1023 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 1dff653c-1920-53df-a4f7-6bb3a83e531d -->
  <rule id="579653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1023 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>