<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5151 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 9b906af5-01f5-5ddf-a76e-92566bf5ca38 -->
  <rule id="794506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5151 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>