<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2938 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: de3a766d-d535-5d4b-ba8a-17378bc547fc -->
  <rule id="957876" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2938 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>