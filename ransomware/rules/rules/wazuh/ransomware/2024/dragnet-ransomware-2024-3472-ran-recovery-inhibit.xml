<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3472 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 1d1043dd-aa2d-505f-9c35-8e8998bb9968 -->
  <rule id="256701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3472 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>