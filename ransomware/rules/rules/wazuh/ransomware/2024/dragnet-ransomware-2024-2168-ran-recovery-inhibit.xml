<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2168 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: c40d0877-2ca9-5aa4-8e9b-ce8b4f49b817 -->
  <rule id="285308" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2168 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>