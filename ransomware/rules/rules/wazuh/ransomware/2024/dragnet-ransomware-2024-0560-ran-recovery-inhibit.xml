  <rule id="215153" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0560 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
