<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3424 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: b72d5fc2-fead-5ba1-a555-7e5d2ec5e0d2 -->
  <rule id="402495" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3424 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>