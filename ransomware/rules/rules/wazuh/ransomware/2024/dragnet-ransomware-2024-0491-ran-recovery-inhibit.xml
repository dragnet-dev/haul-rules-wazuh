<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0491 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 1853559b-79db-5b7a-b41d-59747d04a53c -->
  <rule id="153559" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0491 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>