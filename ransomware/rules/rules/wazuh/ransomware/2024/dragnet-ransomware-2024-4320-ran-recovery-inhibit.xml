<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4320 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 975bce58-1189-5a50-a109-bcc338413076 -->
  <rule id="496622" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4320 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>