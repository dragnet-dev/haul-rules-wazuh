<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1516 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 9594b4fc-f1d8-5a38-a090-438b98845c6e -->
  <rule id="735154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1516 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>