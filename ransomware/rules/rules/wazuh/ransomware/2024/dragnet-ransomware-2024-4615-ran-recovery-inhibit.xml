<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4615 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4d9e1c02-d6c1-5f39-bd2e-289a4858d654 -->
  <rule id="296508" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4615 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>