<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0819 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: e3825a89-e42a-54c0-a350-e35f5fee650c -->
  <rule id="601210" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0819 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>