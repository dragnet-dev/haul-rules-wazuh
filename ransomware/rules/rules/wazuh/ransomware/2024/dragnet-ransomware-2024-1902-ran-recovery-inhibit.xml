<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1902 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: fee1561e-8afe-5531-ac7e-72066d46825d -->
  <rule id="578156" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1902 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>