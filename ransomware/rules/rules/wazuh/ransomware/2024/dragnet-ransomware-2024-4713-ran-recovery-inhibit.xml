<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4713 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: dd8ab954-ec01-5fb4-95a7-2aff43f27330 -->
  <rule id="379799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4713 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>