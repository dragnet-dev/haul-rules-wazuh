<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1401 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d458deef-5b5a-50a4-bc7a-e7862ee500b4 -->
  <rule id="845470" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1401 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>