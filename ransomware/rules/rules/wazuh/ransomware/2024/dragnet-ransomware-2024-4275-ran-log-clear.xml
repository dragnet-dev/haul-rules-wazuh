<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4275 — Event Log Clearing (coinbasecartel) | Status: experimental | Sigma ID: 5a9e4033-e690-56b4-af7d-4bbe4da0d2c7 -->
  <rule id="655840" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4275 — Event Log Clearing (coinbasecartel)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>