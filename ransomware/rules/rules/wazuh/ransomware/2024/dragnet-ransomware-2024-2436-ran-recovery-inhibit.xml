<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2436 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: a20e12b8-42ba-5105-8636-88f3fb70ae3f -->
  <rule id="833412" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2436 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>