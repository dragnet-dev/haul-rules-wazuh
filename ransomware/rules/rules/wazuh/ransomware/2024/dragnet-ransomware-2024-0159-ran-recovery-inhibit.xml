<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0159 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: c5a3778b-af80-52e8-b8d0-f49a9cd94cc7 -->
  <rule id="310377" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0159 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>