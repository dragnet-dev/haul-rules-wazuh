<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4975 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 6321626d-10a4-5933-a858-194a01a465a3 -->
  <rule id="121626" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4975 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>