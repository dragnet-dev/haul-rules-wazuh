<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2217 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: d33724d5-d390-5661-9231-64eaab4be200 -->
  <rule id="533724" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2217 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>