<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2516 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: cf1f6a9c-cbbf-5027-b7b6-70e338172c76 -->
  <rule id="904266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2516 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>