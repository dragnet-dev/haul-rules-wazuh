<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4849 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f28cb49e-0250-5423-a020-694da2f2b5be -->
  <rule id="413714" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4849 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>