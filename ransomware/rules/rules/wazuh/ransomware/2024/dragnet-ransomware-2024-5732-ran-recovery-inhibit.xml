<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5732 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 9868d093-a04a-5e86-adf6-a0b2012c5216 -->
  <rule id="779010" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5732 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>