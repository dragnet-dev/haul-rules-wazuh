<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4871 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 12910a57-df61-5d8b-998c-7b98d6b0927c -->
  <rule id="365705" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4871 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>