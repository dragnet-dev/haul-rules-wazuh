<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3051 — Event Log Clearing (ElDorado) | Status: deprecated | Sigma ID: 90341d90-d702-5eca-8921-9a00e6c2b5f9 -->
  <rule id="645469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3051 — Event Log Clearing (ElDorado)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>