<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5157 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 72af1248-b526-5696-8233-3029cb45a907 -->
  <rule id="160712" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5157 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>