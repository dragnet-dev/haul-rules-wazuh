<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4104 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d0440f6e-3da6-5c9f-a7d2-956cae267955 -->
  <rule id="387055" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4104 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>