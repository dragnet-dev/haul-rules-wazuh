<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5859 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: 29f254fc-82f4-5975-9418-1c9a757a8272 -->
  <rule id="568079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5859 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>