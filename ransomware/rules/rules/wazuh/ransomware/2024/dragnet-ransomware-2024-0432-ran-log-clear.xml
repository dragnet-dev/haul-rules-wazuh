<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0432 — Event Log Clearing (knight) | Status: experimental | Sigma ID: 6ffdb4dc-01e0-5c9c-b917-af1eb493e1f8 -->
  <rule id="187154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0432 — Event Log Clearing (knight)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>