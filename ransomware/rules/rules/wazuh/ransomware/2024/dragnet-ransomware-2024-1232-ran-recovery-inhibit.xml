<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1232 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 3c9dc6d5-b0f1-5041-bd43-ad1f2aa47aa3 -->
  <rule id="761246" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1232 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>