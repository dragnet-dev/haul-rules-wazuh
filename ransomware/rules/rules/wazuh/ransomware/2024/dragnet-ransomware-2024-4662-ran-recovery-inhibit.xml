<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4662 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 9bc2707d-19dc-5269-b1df-efc9410b060f -->
  <rule id="792270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4662 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>