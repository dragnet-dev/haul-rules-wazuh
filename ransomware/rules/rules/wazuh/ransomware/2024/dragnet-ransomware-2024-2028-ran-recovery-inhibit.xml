<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2028 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 1af791e9-450c-5195-afdf-557d9ae4de80 -->
  <rule id="708670" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2028 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>