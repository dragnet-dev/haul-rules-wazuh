<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5258 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: de73f00f-2504-55cc-bbfe-08223379082c -->
  <rule id="963830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5258 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>