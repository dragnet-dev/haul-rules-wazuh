<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1114 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: 5023fd18-1b2b-5520-8b72-96c37e0b9a51 -->
  <rule id="486141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1114 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>