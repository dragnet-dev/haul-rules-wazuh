<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5417 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a21573c7-e03e-54ce-ac28-335f80d4601e -->
  <rule id="221573" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5417 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>