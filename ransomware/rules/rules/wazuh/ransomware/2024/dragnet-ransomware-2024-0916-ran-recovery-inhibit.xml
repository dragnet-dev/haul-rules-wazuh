<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0916 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: e7902321-8ad8-58d7-8866-e56ae500eb46 -->
  <rule id="679023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0916 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>