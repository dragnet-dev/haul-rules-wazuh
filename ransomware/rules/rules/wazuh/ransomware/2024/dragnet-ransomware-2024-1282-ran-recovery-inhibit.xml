<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1282 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 3f50d8fb-a0ed-5d83-a535-db97cdb962f8 -->
  <rule id="216138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1282 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>