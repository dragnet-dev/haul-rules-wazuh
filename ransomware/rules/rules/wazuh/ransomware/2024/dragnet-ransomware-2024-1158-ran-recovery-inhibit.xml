<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1158 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: d0277de3-6990-56f2-9271-a8b9196dfab0 -->
  <rule id="384445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1158 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>