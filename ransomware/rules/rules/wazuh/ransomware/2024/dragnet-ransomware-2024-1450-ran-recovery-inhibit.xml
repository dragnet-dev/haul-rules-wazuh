<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1450 — Recovery Inhibition (cuba) | Status: experimental | Sigma ID: 1f8df2bd-9141-5f5f-8f19-c31ea6250c6f -->
  <rule id="561003" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1450 — Recovery Inhibition (cuba)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>