<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3152 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: a8d0d9dc-fb7e-5cde-8f8b-84023a88d655 -->
  <rule id="185739" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3152 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>