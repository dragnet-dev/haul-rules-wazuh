<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3246 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 43adffdf-0cd2-59e7-b882-b3e91b0f4e05 -->
  <rule id="262591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3246 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>