<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4614 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: af4f50e5-44bc-55bf-9cdf-853684328329 -->
  <rule id="207950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4614 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>