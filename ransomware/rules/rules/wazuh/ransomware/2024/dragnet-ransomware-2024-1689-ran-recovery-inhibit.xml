<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1689 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 9ea37862-3849-5873-8a02-e3abf8ddb17b -->
  <rule id="838378" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1689 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>