<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4372 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: b7fb8498-9c63-55b5-9f70-7b3a60a7d85e -->
  <rule id="420384" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4372 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>