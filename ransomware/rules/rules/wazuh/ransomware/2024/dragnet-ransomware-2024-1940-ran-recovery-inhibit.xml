<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1940 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: c95ab761-576e-5318-a304-476d183aaebe -->
  <rule id="716917" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1940 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>