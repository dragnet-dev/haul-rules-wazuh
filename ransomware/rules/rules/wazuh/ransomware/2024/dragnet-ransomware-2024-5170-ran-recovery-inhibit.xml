<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5170 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 50efb2f4-4959-5277-8310-075c4b520a12 -->
  <rule id="386352" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5170 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>