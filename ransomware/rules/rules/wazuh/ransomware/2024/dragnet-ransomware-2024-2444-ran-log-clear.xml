<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2444 — Event Log Clearing (handala) | Status: experimental | Sigma ID: 1ec4a5bf-0ab0-5353-9f22-b67d8af19ca3 -->
  <rule id="107131" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2444 — Event Log Clearing (handala)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>