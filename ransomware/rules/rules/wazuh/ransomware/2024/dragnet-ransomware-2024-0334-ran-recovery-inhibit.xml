<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0334 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 70f3fc4b-b47a-5d36-8677-75d763489f67 -->
  <rule id="306620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0334 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>