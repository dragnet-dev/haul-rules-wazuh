<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0656 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 30026652-a2e1-540b-8999-f7a501df0d0e -->
  <rule id="402665" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0656 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>