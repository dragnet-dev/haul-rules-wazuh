<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0820 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 3184fcf1-a6fb-5cb3-adac-68fef1ed50bd -->
  <rule id="545711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0820 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>