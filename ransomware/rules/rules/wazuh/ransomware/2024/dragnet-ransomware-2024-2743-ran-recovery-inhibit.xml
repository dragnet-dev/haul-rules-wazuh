<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2743 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 19570438-1d01-5605-9c47-6a1ce1526d7c -->
  <rule id="257043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2743 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>