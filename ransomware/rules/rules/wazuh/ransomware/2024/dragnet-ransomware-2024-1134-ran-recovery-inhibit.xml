<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1134 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 4c273d5b-b1ab-572d-9bd0-8e760cad86b4 -->
  <rule id="420381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1134 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>