<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1466 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 7f3f56ae-0c9b-551b-a1b5-04d3f83267fc -->
  <rule id="338356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1466 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>