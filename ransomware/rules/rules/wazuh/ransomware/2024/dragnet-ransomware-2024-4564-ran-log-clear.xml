<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4564 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 870c0ea9-c859-5c45-8ebf-a0309fa95b81 -->
  <rule id="529134" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4564 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>