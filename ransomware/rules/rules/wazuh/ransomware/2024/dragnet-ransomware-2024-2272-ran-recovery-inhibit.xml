<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2272 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 62128963-342b-5431-87e6-5b09c402b0cb -->
  <rule id="912896" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2272 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>