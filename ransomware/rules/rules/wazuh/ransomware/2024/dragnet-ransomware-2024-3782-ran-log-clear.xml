<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3782 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 35161c40-5d75-5ae6-be93-8aa2f3c28a27 -->
  <rule id="325884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3782 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>