<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5613 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 0aaae5a9-2a11-5f42-b46a-e8cbd62b986d -->
  <rule id="791130" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5613 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>