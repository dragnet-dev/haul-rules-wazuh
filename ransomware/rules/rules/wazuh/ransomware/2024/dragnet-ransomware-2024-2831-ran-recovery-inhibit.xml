<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2831 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 24f607e2-3953-550f-bc8b-cf07e57cead6 -->
  <rule id="193726" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2831 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>