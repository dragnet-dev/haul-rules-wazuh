<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1584 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 73e94c72-fe8a-5bfb-af2d-491186c032a9 -->
  <rule id="192716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1584 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>