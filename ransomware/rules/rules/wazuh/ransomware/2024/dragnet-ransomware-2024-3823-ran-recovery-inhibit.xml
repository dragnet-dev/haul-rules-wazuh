<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3823 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: a91a7e69-67fc-5982-8bec-866f92a53058 -->
  <rule id="194686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3823 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>