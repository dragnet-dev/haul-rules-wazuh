<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3239 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: 89f08c3a-9696-5d10-9dc8-4b0d0f5a8b18 -->
  <rule id="602540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3239 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>