<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0057 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 46c44ae3-ea48-5663-b972-41c1bc9cd82a -->
  <rule id="397514" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0057 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>