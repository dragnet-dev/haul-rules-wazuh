<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3136 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8b08a194-a50d-5762-85b1-ed6513b6a504 -->
  <rule id="525381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3136 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>