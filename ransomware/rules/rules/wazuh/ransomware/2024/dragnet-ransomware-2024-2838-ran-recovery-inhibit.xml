<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2838 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: e8ceca48-6828-5cd1-a22d-85b4a79def54 -->
  <rule id="852266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2838 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>