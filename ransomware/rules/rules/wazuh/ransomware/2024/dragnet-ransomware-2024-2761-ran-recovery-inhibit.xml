<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2761 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 764bea61-2417-56ea-a15e-10c0e22f4a29 -->
  <rule id="532394" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2761 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>