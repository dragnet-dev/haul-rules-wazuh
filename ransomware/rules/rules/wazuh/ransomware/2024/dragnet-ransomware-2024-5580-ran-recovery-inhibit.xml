<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5580 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2c5184f9-e74e-52b7-8f0f-48f924419b9b -->
  <rule id="922959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5580 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>