<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0272 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: fa973051-5003-54d4-b6a5-15c6f9aca924 -->
  <rule id="809730" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0272 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>