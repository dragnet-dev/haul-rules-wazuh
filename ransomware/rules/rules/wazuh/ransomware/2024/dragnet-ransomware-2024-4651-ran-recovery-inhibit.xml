<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4651 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 00632ec2-6156-53fe-896b-5c5a3afc92c5 -->
  <rule id="820282" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4651 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>