<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4642 — Recovery Inhibition (sarcoma) | Status: experimental | Sigma ID: 0091d794-0b42-50c2-81d4-785780406101 -->
  <rule id="669794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4642 — Recovery Inhibition (sarcoma)</description>
