<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0254 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: f343edf1-da2f-50b2-ae43-1fe5e8dc3c0c -->
  <rule id="428045" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0254 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>