<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2014 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 01392d8b-f4e1-5869-a6b2-6758d9f35ac8 -->
  <rule id="965739" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2014 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>