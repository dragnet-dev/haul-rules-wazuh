<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3756 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8be6255d-c6e2-5911-a74e-7c10bff055cc -->
  <rule id="538625" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3756 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>