<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1086 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 02979778-19ed-5e74-a780-a6ed3235e6ad -->
  <rule id="379778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1086 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>