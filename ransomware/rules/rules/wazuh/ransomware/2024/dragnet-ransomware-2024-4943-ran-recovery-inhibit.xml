<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4943 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 955e28f0-f079-5dd4-9c68-1c4dfb7703cd -->
  <rule id="729428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4943 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>