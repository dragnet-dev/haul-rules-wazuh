<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0080 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: 1668a36c-0df1-57c6-b8cb-f3ca794b7e49 -->
  <rule id="969836" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0080 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>