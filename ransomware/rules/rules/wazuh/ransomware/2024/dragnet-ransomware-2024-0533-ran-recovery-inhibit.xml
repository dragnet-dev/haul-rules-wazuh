<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0533 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 49c9e146-a23f-5eca-b34a-28e537e4ffd7 -->
  <rule id="475181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0533 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>