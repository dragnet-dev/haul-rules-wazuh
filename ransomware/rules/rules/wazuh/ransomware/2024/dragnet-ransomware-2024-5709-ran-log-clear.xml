<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5709 — Event Log Clearing (daixin) | Status: deprecated | Sigma ID: a53efe6b-837a-5a2f-a75d-475c348d9b24 -->
  <rule id="816926" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5709 — Event Log Clearing (daixin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>