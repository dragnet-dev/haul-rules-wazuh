<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1403 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 2d8de4a3-e014-54e0-8e81-946ac44879b4 -->
  <rule id="374704" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1403 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>