<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2918 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: cec28664-c36c-5f64-8f55-b6904ae94a08 -->
  <rule id="708286" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2918 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>