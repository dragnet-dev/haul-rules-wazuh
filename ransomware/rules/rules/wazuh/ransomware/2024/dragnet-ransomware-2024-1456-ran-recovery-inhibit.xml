<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1456 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 7994be65-9911-5ef9-941e-a0b14478077c -->
  <rule id="346654" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1456 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>