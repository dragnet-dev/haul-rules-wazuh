<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0827 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: df5c6ad1-2980-5330-b436-4e9abfb2b3d0 -->
  <rule id="423626" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0827 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>