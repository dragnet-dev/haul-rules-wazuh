<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3577 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 72f07470-2d67-5ce9-9a39-aae4870732d0 -->
  <rule id="367074" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3577 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
