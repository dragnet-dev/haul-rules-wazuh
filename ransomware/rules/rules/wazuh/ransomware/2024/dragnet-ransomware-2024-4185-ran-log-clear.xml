<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4185 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 44a99c9c-89ce-5387-a477-e2c67eeb7a1d -->
  <rule id="343996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4185 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>