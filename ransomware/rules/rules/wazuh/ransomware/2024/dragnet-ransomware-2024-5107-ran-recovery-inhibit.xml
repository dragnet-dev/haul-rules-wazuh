<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5107 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: df349522-4c14-5500-8c63-887c57cadd9e -->
  <rule id="533495" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5107 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>