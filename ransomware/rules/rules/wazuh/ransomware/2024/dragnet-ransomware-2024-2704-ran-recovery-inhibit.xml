<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2704 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 7281405d-49a7-513d-81f5-103eeeff5d39 -->
  <rule id="181405" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2704 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>