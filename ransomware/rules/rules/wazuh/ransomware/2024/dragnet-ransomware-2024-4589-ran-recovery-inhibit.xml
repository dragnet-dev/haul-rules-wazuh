<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4589 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: 05954ba8-11c0-5722-bbaf-e675d5f83ff4 -->
  <rule id="724410" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4589 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>