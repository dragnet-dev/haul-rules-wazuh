<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4493 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 5b8192ba-d01f-54fe-9833-75bb2fbe20a5 -->
  <rule id="391083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4493 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>