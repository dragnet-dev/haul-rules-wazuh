<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1935 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 9018bcba-8c95-5b0d-927f-744809f216e5 -->
  <rule id="608796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1935 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>