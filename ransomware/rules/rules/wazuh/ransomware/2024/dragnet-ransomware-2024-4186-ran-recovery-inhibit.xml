<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4186 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 011c8006-81c2-589d-a268-4b7d553cdba9 -->
  <rule id="188006" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4186 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>