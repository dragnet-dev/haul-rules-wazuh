<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0037 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 18dfe768-9bab-5a48-8b1c-211e542de921 -->
  <rule id="631076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0037 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>