<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4668 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 17058694-01db-5305-8f3e-f2a8781e4d72 -->
  <rule id="905869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4668 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>