<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4637 — Event Log Clearing (medusalocker) | Status: experimental | Sigma ID: 72bb9328-b357-5b9d-bc6c-55ef8873c1a3 -->
  <rule id="161993" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4637 — Event Log Clearing (medusalocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>