<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0041 — Event Log Clearing (arcusmedia) | Status: experimental | Sigma ID: d4e1f5f8-96eb-5fb6-b640-cf133b96c34e -->
  <rule id="853115" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0041 — Event Log Clearing (arcusmedia)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>