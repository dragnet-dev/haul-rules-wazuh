<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5599 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 57294c42-0685-54e6-bd83-a1035f312aa8 -->
  <rule id="267164" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5599 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>