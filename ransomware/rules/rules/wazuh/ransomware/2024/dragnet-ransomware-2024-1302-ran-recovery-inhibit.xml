<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1302 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 06f95f9e-7c4c-5222-82f5-50fecc89f875 -->
  <rule id="991359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1302 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>