<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2029 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: f9f69eae-16a3-59b3-a5f8-cf3b54bc6010 -->
  <rule id="595518" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2029 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>