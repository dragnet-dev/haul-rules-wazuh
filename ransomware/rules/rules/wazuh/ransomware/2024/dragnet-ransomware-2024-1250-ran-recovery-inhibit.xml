<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1250 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d4031d57-a451-5dbc-b072-5154d60875cd -->
  <rule id="444509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1250 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>