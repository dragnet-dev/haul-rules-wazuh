<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4470 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 1376fc2d-c46f-5944-9885-26c30e0acf3b -->
  <rule id="925082" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4470 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>