<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1297 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: de1000cc-59cd-5d29-84d8-f6386dc1d825 -->
  <rule id="521000" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1297 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>