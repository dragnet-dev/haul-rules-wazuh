<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3486 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ad7da833-fe98-56d9-8291-68acbebe24fa -->
  <rule id="948908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3486 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>