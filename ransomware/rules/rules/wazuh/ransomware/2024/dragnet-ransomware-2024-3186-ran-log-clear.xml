<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3186 — Event Log Clearing (arcusmedia) | Status: experimental | Sigma ID: 3cd9753c-79a7-5ea0-a6d1-b245f6e35ca2 -->
  <rule id="839753" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3186 — Event Log Clearing (arcusmedia)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>