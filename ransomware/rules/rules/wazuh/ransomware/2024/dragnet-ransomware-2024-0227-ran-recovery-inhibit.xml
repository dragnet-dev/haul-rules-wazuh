<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0227 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 32980471-52c0-5290-a90d-f9105e3e5b51 -->
  <rule id="698047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0227 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>