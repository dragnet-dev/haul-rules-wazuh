<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0616 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 4c394831-60a0-50de-8928-7789baf114c7 -->
  <rule id="539483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0616 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>