<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0617 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 5fc4d889-e33d-529e-8c94-598f3a42c39d -->
  <rule id="751978" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0617 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>