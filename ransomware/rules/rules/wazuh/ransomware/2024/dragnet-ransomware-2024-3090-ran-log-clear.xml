<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3090 — Event Log Clearing (moneymessage) | Status: experimental | Sigma ID: 780c5869-a0b8-584b-93df-ae1375b03b6b -->
  <rule id="449258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3090 — Event Log Clearing (moneymessage)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>