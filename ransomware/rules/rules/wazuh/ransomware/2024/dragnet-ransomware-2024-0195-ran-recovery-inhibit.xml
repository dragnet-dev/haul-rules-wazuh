<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0195 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: d881f7cb-7c64-58a3-a897-9222eabda7b2 -->
  <rule id="521117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0195 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>