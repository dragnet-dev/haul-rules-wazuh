<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2686 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 7602cca1-27e6-5e0e-9170-0765f68a81a5 -->
  <rule id="246316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2686 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>