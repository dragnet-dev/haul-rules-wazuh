<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1581 — Recovery Inhibition (argonauts) | Status: experimental | Sigma ID: c46d350c-49e6-5b4a-9756-6977fbf83ef0 -->
  <rule id="294935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1581 — Recovery Inhibition (argonauts)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>