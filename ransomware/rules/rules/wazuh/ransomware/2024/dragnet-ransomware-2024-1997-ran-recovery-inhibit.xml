<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1997 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6e2695f5-9cff-5f72-b8fc-f9b3a27079d4 -->
  <rule id="302695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1997 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>