<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1836 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: fc657735-a452-5e27-8fbb-1dc5ff8fd7fc -->
  <rule id="826577" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1836 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>