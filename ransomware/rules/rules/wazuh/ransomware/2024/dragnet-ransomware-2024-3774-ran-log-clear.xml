<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3774 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 05e1ced8-6d3d-5ccf-9113-00849b1c66aa -->
  <rule id="357645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3774 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>