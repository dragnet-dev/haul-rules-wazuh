<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1326 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 18bb7e4f-1344-56b4-abcd-990d59d28366 -->
  <rule id="573264" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1326 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>