<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1116 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: a66f8385-035b-5846-aff5-8822e2664f27 -->
  <rule id="907183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1116 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>