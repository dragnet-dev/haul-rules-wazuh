<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1983 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 32ccdc8f-a355-5bf1-b66f-fd9f0971ae6b -->
  <rule id="449596" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1983 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>