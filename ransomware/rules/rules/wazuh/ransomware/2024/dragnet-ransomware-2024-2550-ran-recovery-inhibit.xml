<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2550 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a73c6f35-cc3c-54a2-8105-a24c006a84b5 -->
  <rule id="148911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2550 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>