<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0458 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 38e72730-dc77-5bdc-b7ae-add6b796d349 -->
  <rule id="927273" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0458 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>