<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5572 — Event Log Clearing (ValenciaLeaks) | Status: experimental | Sigma ID: ca1e5eb0-d6f9-58f9-aa6d-76944e0c847b -->
  <rule id="776094" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5572 — Event Log Clearing (ValenciaLeaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>