<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1454 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: f30a12e4-aeda-5571-9041-a17abb0bcffb -->
  <rule id="749012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1454 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>