<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1182 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 0bdf08c6-886f-516f-a621-848dca10037b -->
  <rule id="462540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1182 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>