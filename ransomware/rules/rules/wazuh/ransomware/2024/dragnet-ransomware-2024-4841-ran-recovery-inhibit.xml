<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4841 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 2a3a6621-36ea-5454-af47-a18363abc4b6 -->
  <rule id="578662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4841 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>