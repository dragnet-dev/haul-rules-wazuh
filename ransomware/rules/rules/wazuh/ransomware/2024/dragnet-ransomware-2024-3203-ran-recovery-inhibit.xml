<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3203 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 896e05ba-2b22-5ada-a26d-7a0cd8310719 -->
  <rule id="635005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3203 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>