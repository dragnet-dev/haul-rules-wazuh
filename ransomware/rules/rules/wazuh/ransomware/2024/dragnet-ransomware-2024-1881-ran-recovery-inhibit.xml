<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1881 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 638651ff-b167-55a7-9462-4c2fac75d88b -->
  <rule id="418431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1881 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>