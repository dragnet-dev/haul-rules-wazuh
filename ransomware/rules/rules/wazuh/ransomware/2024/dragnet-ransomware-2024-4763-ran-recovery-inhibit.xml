<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4763 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 35cf0e4d-ee59-5069-9a03-e7d7382be41c -->
  <rule id="666734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4763 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>