<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4238 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: e8dc10ff-d10a-5d49-bd6d-cc02eb35d9bb -->
  <rule id="310810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4238 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>