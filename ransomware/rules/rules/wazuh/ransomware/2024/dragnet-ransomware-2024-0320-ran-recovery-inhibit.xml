<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0320 — Recovery Inhibition (orca) | Status: experimental | Sigma ID: d0870366-cdec-51b9-8605-f781731f76b0 -->
  <rule id="508703" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0320 — Recovery Inhibition (orca)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>