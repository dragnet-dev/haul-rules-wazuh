<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1976 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d1ba3f09-eef2-5857-9371-15c959f946f9 -->
  <rule id="995583" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1976 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>