<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4018 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c5b49374-2981-5d70-9148-a0d47489cc64 -->
  <rule id="311493" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4018 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>