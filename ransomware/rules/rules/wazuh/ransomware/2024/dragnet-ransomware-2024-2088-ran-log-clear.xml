<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2088 — Event Log Clearing (mallox) | Status: deprecated | Sigma ID: 031270c4-e30a-5aef-a6f7-39e6c7ee0cf0 -->
  <rule id="603324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2088 — Event Log Clearing (mallox)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>