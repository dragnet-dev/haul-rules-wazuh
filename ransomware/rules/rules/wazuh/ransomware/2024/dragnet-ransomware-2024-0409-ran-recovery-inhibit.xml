<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0409 — Recovery Inhibition (playboy) | Status: experimental | Sigma ID: a620f187-f801-57c2-aa43-f1221dde27b5 -->
  <rule id="899351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0409 — Recovery Inhibition (playboy)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>