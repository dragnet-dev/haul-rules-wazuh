<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3365 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 90dd5a5e-39a7-54f5-b223-13a03e11a2c6 -->
  <rule id="221850" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3365 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>