<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1702 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: a3a99090-5919-58f0-add5-a37dd9ec585f -->
  <rule id="858990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1702 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>