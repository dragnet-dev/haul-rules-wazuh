<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5770 — Event Log Clearing (lynx) | Status: experimental | Sigma ID: a45bbebd-4edf-5bae-b8fa-17a5d85eb7d6 -->
  <rule id="783326" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5770 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>