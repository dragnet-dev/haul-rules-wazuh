<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4921 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: ad738505-7e4a-5f97-88d9-83107c6fbf16 -->
  <rule id="937385" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4921 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>