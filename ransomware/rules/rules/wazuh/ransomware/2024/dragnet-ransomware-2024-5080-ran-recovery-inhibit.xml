<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5080 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 81b39439-5861-5390-bd63-f32acb732a69 -->
  <rule id="507394" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5080 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>