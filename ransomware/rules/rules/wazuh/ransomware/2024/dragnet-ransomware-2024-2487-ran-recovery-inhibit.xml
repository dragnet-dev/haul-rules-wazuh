<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2487 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: e4bec930-7a51-5d02-ba29-f934458bc877 -->
  <rule id="628769" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2487 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>