<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5336 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: fca121c8-05a4-590c-85fb-ced857b96d8a -->
  <rule id="542121" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5336 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>