<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2964 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 00e1b815-9522-5724-a5cd-ca4b31025a8b -->
  <rule id="567815" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2964 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>