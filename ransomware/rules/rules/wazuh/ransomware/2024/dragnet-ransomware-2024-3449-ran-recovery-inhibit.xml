<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3449 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4d1bcfda-e5f7-5704-99a9-238aaba8b181 -->
  <rule id="561039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3449 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>