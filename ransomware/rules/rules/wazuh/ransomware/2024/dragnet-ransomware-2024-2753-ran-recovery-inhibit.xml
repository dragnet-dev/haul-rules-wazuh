<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2753 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 59eb0b8d-e865-5315-b8c4-c7bd74d50618 -->
  <rule id="754251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2753 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>