<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4852 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c2716fa2-ced7-5323-83b9-cdbe661345e5 -->
  <rule id="263471" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4852 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>