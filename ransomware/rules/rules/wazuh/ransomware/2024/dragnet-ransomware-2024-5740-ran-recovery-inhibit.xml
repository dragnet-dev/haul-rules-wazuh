<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5740 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 3eba3df6-562d-5e87-a412-e3b6da2eb9c4 -->
  <rule id="869341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5740 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>