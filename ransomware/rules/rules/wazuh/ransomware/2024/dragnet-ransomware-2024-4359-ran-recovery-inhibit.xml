<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4359 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 3d15ce11-8a97-5cea-aa60-965c9e6630ae -->
  <rule id="765646" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4359 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>