<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3641 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: a68b93ed-b8af-51bc-9949-6d53f6802d85 -->
  <rule id="909993" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3641 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>