<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0859 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 86b63afa-3a40-58a2-8a11-9d3e3d45a75d -->
  <rule id="520218" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0859 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>