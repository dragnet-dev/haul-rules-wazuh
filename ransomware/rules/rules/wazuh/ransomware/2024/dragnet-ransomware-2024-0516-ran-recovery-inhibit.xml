<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0516 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 8bed4e17-66d0-5368-881a-946e167f862b -->
  <rule id="431438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0516 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>