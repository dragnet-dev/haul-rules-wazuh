<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0128 — Recovery Inhibition (cloak) | Status: experimental | Sigma ID: 78e5bd6c-ecb2-5d81-bb3d-72c1060350b2 -->
  <rule id="632189" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0128 — Recovery Inhibition (cloak)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>