<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5469 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 1642613f-8fc9-5de6-95a2-dcfb0dc08f90 -->
  <rule id="842613" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5469 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>