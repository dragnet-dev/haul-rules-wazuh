<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1266 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: a573b1b0-ec2c-5046-acb1-b3f86ea018cf -->
  <rule id="891791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1266 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>