<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5707 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 606cb973-c4b7-5052-83d3-2b0e63709268 -->
  <rule id="753399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5707 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>