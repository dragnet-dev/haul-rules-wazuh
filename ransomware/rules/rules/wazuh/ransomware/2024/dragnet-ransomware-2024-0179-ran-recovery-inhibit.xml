<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0179 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: c5a1dcea-1a47-5a18-8d8e-b3352fe48d6c -->
  <rule id="746076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0179 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>