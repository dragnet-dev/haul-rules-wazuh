<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1419 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 387e3b4e-1cb0-5381-ac3d-956e35b9f613 -->
  <rule id="130194" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1419 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>