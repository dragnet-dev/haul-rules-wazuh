<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0500 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: dc2e6d07-a770-5175-8b1b-3a54e88d32b6 -->
  <rule id="339469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0500 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>