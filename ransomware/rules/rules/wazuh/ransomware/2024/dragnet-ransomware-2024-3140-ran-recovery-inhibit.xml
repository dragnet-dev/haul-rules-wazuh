<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3140 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a4ffa93f-d4d9-571c-9aa7-5ccfd92748e4 -->
  <rule id="800749" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3140 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>