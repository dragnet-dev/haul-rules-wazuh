<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1870 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 95ee907f-7c86-58fe-8aee-7ae4b51e122a -->
  <rule id="755890" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1870 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>