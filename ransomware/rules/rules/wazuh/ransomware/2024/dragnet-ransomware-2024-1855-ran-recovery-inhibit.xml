<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1855 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 72875f15-be41-5578-9d02-1468dc7d6629 -->
  <rule id="366015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1855 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>