<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4865 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 35377438-f5b6-5d54-b22e-3755cb7fbe89 -->
  <rule id="937743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4865 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>