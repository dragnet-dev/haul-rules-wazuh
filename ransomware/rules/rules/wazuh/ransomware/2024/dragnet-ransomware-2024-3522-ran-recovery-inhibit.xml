<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3522 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 93f8e9a6-b2bb-58ff-b5be-756d63614ac8 -->
  <rule id="706229" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3522 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>