<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3960 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 8cbece49-3779-5f2f-8303-876bdba3584b -->
  <rule id="323886" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3960 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>