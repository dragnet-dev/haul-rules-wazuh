<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2338 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 8580e283-c954-5f1f-8a05-bc4054c582c4 -->
  <rule id="572942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2338 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>