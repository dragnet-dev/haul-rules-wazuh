<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1517 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1caa9472-fa6f-5e71-8762-7d52917fca9a -->
  <rule id="238947" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1517 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>