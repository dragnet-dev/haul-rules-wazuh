<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1461 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: b3153003-2313-50ee-b779-4d8c823fc4e0 -->
  <rule id="331530" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1461 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>