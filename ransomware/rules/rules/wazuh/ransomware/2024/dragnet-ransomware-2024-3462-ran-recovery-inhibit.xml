<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3462 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: bb50cefa-edb8-57d0-b386-bc31fffc4b62 -->
  <rule id="400206" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3462 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>