<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0709 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 85985584-ac47-5ccf-aaea-d8bce5884212 -->
  <rule id="598558" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0709 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>