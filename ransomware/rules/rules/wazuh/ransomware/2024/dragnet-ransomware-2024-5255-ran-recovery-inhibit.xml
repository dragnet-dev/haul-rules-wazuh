<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5255 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6222a772-3089-5316-9246-e2535c37c103 -->
  <rule id="156277" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5255 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>