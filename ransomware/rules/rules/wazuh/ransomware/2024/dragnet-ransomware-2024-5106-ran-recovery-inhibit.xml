<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5106 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 3c2380cd-523d-57c0-a4ef-ed8180e5d6e7 -->
  <rule id="738092" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5106 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>