<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2483 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 7b10f4a2-9163-5870-9501-0597eadb67e2 -->
  <rule id="269754" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2483 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>