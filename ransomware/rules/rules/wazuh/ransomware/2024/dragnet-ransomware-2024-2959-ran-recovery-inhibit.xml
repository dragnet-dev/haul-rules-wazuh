<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2959 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 8ac37d63-de09-57c7-8314-92633c8fd118 -->
  <rule id="952605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2959 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>