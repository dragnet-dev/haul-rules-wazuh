<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5287 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5be44e61-f8c1-5911-8b49-703a33c350c2 -->
  <rule id="652718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5287 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>