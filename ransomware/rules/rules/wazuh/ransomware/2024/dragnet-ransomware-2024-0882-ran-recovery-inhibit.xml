<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0882 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 25542ed9-9fec-5e44-8c07-01883801cf6a -->
  <rule id="338989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0882 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>