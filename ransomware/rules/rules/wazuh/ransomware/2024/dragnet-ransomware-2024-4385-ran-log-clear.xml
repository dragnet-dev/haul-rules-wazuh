<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4385 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 4740b0dc-7b3e-5fdb-9d8f-8e1a74398242 -->
  <rule id="536173" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4385 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>