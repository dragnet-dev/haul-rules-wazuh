<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0456 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2c0e7d24-304b-5d31-8338-d2f189d94c6d -->
  <rule id="328765" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0456 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>