<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1688 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 898663db-0b76-55b5-a6a0-5634bb5ede92 -->
  <rule id="978621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1688 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>