<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5762 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: afae9441-abc8-590a-acb6-46b5ebece15d -->
  <rule id="997494" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5762 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>