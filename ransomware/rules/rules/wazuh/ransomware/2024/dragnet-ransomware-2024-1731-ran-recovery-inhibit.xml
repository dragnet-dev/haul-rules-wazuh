<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1731 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 898ee6ac-40e1-5d7a-bda0-8b54486df877 -->
  <rule id="601266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1731 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>