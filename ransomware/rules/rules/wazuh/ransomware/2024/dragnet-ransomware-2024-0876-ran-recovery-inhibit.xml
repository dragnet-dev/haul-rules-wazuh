<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0876 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: d0dda17c-4452-54c4-94cd-7cc9c4c962f7 -->
  <rule id="960261" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0876 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>