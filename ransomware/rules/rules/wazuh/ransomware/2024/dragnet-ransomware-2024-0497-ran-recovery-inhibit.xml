<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0497 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 9acb8f96-dcf6-5cdc-be79-75a515213baf -->
  <rule id="140463" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0497 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>