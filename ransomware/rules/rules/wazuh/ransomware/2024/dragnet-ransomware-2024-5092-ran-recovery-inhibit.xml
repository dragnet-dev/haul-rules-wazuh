<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5092 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 72f29072-5970-583a-997e-19ceb1646337 -->
  <rule id="367290" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5092 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>