<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5226 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6660c848-1557-57e7-acdc-3ba5646babd3 -->
  <rule id="265728" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5226 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>