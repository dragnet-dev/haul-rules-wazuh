<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5601 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 7eff627d-69c9-5a37-a23b-fb52613f4f35 -->
  <rule id="651162" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5601 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>