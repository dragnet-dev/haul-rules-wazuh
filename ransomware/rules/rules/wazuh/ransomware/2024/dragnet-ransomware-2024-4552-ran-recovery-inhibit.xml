<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4552 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 714cae72-4a1d-5343-88ac-f7c02e290d28 -->
  <rule id="327790" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4552 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>