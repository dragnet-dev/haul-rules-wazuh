<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4393 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1d94e195-dc0e-5202-8a31-22c72dac14fc -->
  <rule id="391819" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4393 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>