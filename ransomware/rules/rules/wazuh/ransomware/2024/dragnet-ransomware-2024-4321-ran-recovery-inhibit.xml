<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4321 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: cc631ecc-baaf-580d-85a8-ab38a28f9f90 -->
  <rule id="674110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4321 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>