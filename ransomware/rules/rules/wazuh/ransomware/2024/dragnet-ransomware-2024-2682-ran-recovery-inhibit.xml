<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2682 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 43b5c906-9b92-5d10-8699-ea280cec143b -->
  <rule id="319329" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2682 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>