<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4441 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: c283ae95-57c0-585c-a434-b3ae67758123 -->
  <rule id="544622" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4441 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>