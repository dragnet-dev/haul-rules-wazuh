<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5360 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 8dd5b21d-0640-523f-95a9-016c48c87073 -->
  <rule id="131312" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5360 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
