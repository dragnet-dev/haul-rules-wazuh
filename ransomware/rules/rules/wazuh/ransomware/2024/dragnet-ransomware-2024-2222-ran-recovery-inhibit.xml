<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2222 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a2b6c500-3f53-5aa7-9ebf-c901dfbe91a4 -->
  <rule id="929885" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2222 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>