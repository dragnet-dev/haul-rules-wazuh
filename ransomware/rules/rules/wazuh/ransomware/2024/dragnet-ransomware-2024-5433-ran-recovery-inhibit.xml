<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5433 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 50ec7621-a900-59c9-8a08-6223cadd130a -->
  <rule id="503676" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5433 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>