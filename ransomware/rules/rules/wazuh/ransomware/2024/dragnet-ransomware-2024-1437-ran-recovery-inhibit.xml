<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1437 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7689417e-e0c8-5a21-8314-fdc9d89255d4 -->
  <rule id="589417" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1437 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>