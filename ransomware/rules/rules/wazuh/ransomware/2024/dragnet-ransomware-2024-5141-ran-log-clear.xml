<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5141 — Event Log Clearing (snatch) | Status: experimental | Sigma ID: 4cb47a7f-25a5-5dd2-9b5b-abf1728baae7 -->
  <rule id="263962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5141 — Event Log Clearing (snatch)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>