<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2367 — Event Log Clearing (clop) | Status: experimental | Sigma ID: 1fa1db73-814d-5aa9-a0bb-3d7ba4315c79 -->
  <rule id="495835" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2367 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>