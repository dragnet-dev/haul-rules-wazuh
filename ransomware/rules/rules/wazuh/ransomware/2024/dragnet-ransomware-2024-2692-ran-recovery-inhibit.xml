<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2692 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 4879f272-06c9-57a5-9001-19a859734fe0 -->
  <rule id="707927" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2692 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>