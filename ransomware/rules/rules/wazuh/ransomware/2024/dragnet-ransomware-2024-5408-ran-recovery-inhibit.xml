<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5408 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 038638c6-4afd-5fd7-89e5-22a42022151e -->
  <rule id="882206" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5408 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>