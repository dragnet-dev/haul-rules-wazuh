<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1507 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4d21869f-cd43-5c98-b432-6811087d06d5 -->
  <rule id="621869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1507 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>