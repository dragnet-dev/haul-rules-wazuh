<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5188 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 39c2c40b-94cd-5063-9279-c216a6f85b6d -->
  <rule id="218044" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5188 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>