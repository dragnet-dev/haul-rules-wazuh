<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2615 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 7b13f7a6-e2c4-5abe-8f1a-23b45e291e9f -->
  <rule id="270237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2615 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>