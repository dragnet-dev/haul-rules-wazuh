<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3471 — Event Log Clearing (trisec) | Status: experimental | Sigma ID: 3d50865c-7a89-566e-a45a-863c0139b4c4 -->
  <rule id="850865" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3471 — Event Log Clearing (trisec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>