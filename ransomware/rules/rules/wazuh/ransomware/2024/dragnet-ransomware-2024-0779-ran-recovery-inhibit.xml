<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0779 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 4703a788-5f8d-51fc-b4d3-66d3c01f7dd8 -->
  <rule id="425878" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0779 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>