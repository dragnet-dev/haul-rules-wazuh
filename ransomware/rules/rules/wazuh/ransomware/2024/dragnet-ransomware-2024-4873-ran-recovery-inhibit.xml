<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4873 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: da0a2856-877b-5418-b9d7-76550e4187e7 -->
  <rule id="889028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4873 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>