<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5528 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5227a959-f590-55aa-917e-fcd40805d4d3 -->
  <rule id="364295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5528 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>