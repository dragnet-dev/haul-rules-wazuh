<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2193 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7c073ba3-6ccc-5c24-8540-b4ce849245f0 -->
  <rule id="285179" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2193 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>