<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2722 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 726909cd-3342-5cf7-b19a-ff587f915e0b -->
  <rule id="930556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2722 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>