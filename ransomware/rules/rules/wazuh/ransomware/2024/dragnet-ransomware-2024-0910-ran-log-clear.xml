<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0910 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: 55799c29-88d5-541f-b8da-9b75f04d6774 -->
  <rule id="927962" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0910 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>