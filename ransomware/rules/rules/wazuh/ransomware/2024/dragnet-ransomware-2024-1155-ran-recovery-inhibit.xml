<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1155 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: fdecba1a-893e-5e4e-a1a1-f74f5341ca39 -->
  <rule id="240075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1155 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>