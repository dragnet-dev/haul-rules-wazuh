<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5861 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: b3685bd5-7b73-5058-bd9e-b9dc6e13a6cb -->
  <rule id="118971" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5861 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>