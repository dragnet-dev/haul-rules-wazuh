<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5216 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: c5ab362c-8eea-5601-ae03-78cfb49e5cab -->
  <rule id="617136" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5216 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>