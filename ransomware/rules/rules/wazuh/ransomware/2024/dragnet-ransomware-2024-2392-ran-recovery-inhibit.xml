<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2392 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: f542a518-dcdd-55e4-9a13-8d275b4cd6f4 -->
  <rule id="786825" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2392 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>