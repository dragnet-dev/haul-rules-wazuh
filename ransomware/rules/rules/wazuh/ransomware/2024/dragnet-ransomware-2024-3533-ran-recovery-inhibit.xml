<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3533 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 3d4414aa-f10c-5b3b-a2c2-19b680c65fba -->
  <rule id="930634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3533 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>