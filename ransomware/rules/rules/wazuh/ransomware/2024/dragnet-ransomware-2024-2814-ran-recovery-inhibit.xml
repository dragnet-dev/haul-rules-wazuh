<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2814 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 23230363-aea4-58fc-98fb-4ba6a5db4d50 -->
  <rule id="623036" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2814 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
