<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4279 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2525999b-6324-586c-b68b-456ee63f9dbb -->
  <rule id="825999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4279 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>