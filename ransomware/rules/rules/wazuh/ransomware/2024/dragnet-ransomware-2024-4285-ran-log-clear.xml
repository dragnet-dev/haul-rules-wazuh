<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4285 — Event Log Clearing (funksec) | Status: experimental | Sigma ID: f8c4dc77-6c8e-5a8c-8ea2-2710af132617 -->
  <rule id="303644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4285 — Event Log Clearing (funksec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>