<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4258 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 80c11edb-ccb2-5bf7-bae1-a6d5856c3c8b -->
  <rule id="367390" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4258 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>