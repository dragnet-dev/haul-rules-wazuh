<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1927 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 9fc32e5e-6c60-5ee4-89db-930af2ee08ba -->
  <rule id="590126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1927 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>