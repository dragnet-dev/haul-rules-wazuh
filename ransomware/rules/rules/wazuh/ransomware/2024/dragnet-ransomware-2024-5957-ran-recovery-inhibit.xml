<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5957 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: c76b797e-70a9-584b-a1d0-943b5f320130 -->
  <rule id="342779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5957 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>