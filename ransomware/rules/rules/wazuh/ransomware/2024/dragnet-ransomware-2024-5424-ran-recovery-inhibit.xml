<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5424 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 99af5b81-fb91-5948-a1ad-0dd82c59c606 -->
  <rule id="583131" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5424 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>