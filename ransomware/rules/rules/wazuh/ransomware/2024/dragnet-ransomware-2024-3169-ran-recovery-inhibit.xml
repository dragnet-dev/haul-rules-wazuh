<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3169 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 58aa6088-8922-558b-bb44-325cc9c23e30 -->
  <rule id="701860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3169 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>