<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4032 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 1d889698-ca25-5932-83fe-dc8f1daf7809 -->
  <rule id="388969" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4032 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>