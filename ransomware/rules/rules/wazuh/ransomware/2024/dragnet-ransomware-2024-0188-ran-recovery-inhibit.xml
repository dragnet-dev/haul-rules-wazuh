<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0188 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: d5a7b6f6-b73c-5966-b239-8238a06ee140 -->
  <rule id="873236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0188 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>