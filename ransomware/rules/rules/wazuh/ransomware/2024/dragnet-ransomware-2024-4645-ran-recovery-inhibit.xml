<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4645 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 27cbefea-11cf-59b4-9fc0-f1ebb40abc00 -->
  <rule id="121679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4645 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>