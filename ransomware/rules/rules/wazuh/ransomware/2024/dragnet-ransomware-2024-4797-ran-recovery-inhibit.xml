<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4797 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 8c2dcd2a-1d24-59c3-8bc0-42c641a8ea44 -->
  <rule id="446125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4797 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>