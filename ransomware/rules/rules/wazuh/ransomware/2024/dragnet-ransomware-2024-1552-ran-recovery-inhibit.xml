<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1552 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 7a4b5ce6-72d1-5ef4-be44-eae734ba2029 -->
  <rule id="535292" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1552 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>