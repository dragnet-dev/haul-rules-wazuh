<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5040 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 65536f67-5f91-5a15-881d-81a0803080ad -->
  <rule id="248591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5040 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>