<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1301 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7967fb39-01b6-5af5-bcb3-7fcdf7b961e6 -->
  <rule id="339803" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1301 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>