<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3913 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0b1ac547-7b35-5894-bb33-b8ddba08fcaa -->
  <rule id="258854" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3913 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>