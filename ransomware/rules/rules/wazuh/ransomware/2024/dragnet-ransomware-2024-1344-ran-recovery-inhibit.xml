<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1344 — Recovery Inhibition (play) | Status: experimental | Sigma ID: aa21a199-a5da-575d-8d29-99095bfb28ad -->
  <rule id="123461" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1344 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>