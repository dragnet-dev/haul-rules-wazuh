<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0682 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b349bcf3-082c-5097-96b4-8ac7741e4b6e -->
  <rule id="305532" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0682 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>