<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4726 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: cbeafb28-5ff3-5a3c-a7a4-19794ffe15d8 -->
  <rule id="863963" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4726 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>