<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5949 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f28dc9df-400d-5e6b-9c46-addeda03b9c8 -->
  <rule id="413889" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5949 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>