<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4010 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: e20a5f7a-d783-5ec8-98b1-05dea01b8169 -->
  <rule id="136895" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4010 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>