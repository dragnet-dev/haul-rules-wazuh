<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2980 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: f6aeb6d2-bb33-5b1a-ada3-8d1f02eff539 -->
  <rule id="217716" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2980 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>