<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3380 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 835d2104-47f2-5ad9-8cf0-a536776a4e5b -->
  <rule id="537321" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3380 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>