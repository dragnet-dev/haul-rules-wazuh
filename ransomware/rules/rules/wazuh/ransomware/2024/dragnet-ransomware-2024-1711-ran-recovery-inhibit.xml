<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1711 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ccb05f9a-8315-5332-875b-58885caed6e4 -->
  <rule id="840095" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1711 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
