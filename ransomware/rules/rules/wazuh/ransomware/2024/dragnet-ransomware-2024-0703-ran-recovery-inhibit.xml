<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0703 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: ff3842b7-60ca-5a19-8801-cbb86c10bd41 -->
  <rule id="853842" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0703 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>