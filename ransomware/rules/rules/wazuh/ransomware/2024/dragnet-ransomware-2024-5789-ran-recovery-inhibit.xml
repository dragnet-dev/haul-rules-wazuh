<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5789 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 15f94f0d-ce33-5b13-82b3-682d7354638d -->
  <rule id="595190" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5789 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>