<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0727 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 58b1cd03-b197-51b0-a491-e6c58049a0ee -->
  <rule id="704301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0727 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>