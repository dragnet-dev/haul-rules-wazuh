<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4209 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: eeccfb92-7f07-5277-8163-8418d3b53707 -->
  <rule id="450043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4209 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>