<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5387 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 8d1af202-b5df-56c9-84f9-2cf542de16b1 -->
  <rule id="113912" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5387 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>