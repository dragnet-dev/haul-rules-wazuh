<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5593 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 23a416fc-56be-52bb-bae9-cf7a21c67471 -->
  <rule id="754671" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5593 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
