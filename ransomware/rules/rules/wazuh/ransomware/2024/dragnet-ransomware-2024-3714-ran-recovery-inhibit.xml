<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3714 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 8b82c987-8f06-5590-962b-9d0e25a3281e -->
  <rule id="537249" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3714 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>