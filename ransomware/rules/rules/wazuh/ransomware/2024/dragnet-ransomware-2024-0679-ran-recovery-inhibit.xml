<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0679 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 2b1c2d5c-bc9b-5374-aa32-8a175bf92d84 -->
  <rule id="305325" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0679 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>