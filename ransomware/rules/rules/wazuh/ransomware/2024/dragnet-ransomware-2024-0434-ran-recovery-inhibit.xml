<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0434 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 6d84edff-c2bc-5050-880c-857cf6ba086d -->
  <rule id="212141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0434 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>