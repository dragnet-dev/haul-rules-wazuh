<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0536 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 7f062cca-82a8-5fae-b13b-004c5e0446cc -->
  <rule id="333004" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0536 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>