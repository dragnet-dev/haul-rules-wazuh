<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3313 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2d4f990d-ece6-5f97-8759-d9124765ec58 -->
  <rule id="179990" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3313 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>