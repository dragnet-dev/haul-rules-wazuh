<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1978 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: d800f00d-b129-571c-9c16-8ed4e32a43c3 -->
  <rule id="508150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1978 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>