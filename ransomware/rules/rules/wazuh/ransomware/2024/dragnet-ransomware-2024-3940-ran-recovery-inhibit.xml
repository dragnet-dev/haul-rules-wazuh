<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3940 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 28da357d-67d3-5a26-9b2b-b02ab662e9d6 -->
  <rule id="286357" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3940 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>