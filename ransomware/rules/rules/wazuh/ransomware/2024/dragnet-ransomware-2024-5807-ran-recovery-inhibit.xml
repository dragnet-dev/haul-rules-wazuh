<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5807 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 64642ae1-d81a-5306-a459-9f199797cbdd -->
  <rule id="234282" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5807 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>