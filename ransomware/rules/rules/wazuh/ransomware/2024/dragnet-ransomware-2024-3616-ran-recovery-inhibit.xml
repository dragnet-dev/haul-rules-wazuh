<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3616 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 07ebc976-349e-5374-97bd-b4b9c982e064 -->
  <rule id="644497" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3616 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>