<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5319 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 97836123-25ab-5b2b-a2dd-7fc7212657a5 -->
  <rule id="883612" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5319 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>