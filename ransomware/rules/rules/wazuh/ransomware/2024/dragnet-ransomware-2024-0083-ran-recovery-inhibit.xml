<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0083 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: a134fa7f-5096-5301-a4b0-b777a3d9ad0c -->
  <rule id="894554" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0083 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>