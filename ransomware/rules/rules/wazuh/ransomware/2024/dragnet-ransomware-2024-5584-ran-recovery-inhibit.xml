<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5584 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 9f7be1cc-c38c-56b4-9f52-5723e6ca5b13 -->
  <rule id="590221" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5584 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
