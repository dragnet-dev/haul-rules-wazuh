<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2315 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4886bb33-dad7-5cb5-8755-8fa971008709 -->
  <rule id="451003" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2315 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>