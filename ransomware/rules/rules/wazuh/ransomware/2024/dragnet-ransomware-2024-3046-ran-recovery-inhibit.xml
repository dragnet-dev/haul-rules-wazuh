<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3046 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 69169605-eb36-5089-a354-16638e8e4bbc -->
  <rule id="716960" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3046 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>