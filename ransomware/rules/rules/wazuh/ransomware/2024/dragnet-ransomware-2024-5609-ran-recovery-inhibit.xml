<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5609 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 05dee109-8c07-5d34-8a2c-3e4517d689aa -->
  <rule id="704610" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5609 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>