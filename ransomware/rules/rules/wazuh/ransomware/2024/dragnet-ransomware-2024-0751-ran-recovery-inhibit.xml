<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0751 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ec66cd5c-0fcf-55a8-867f-c71974186e9a -->
  <rule id="758701" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0751 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>