<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4119 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ad59d74a-14b2-5588-afeb-6efd76a26724 -->
  <rule id="177577" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4119 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>