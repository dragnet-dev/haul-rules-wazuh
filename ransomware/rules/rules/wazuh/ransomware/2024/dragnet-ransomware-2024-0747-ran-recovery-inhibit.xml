<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0747 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: d45243b5-1d9e-5888-980b-f00c70b2405c -->
  <rule id="545243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0747 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>