<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3787 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: eda8d963-9497-56c1-9e0e-029668be5322 -->
  <rule id="784619" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3787 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>