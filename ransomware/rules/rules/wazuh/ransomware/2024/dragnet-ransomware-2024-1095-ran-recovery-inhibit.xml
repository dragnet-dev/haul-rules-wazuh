<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1095 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 3e65ffe9-8a65-55e6-b171-506b7ab21b9e -->
  <rule id="804095" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1095 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>