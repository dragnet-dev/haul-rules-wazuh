<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2818 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: e8f6ef79-ef1e-5642-95d9-aec9fb88edb8 -->
  <rule id="802255" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2818 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>