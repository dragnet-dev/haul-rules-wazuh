<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3003 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 50e1740a-dce0-5ca4-97a6-dce4fcc1e212 -->
  <rule id="141740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3003 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>