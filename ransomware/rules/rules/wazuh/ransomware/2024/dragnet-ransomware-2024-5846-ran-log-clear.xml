<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5846 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: 11b3e4f1-8372-5a0d-8a39-777e1e99e02f -->
  <rule id="397199" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5846 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>