<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0829 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 67b928fb-b9c1-53d8-ae02-2c3b1f1ed88a -->
  <rule id="283928" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0829 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>