<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3722 — Recovery Inhibition (madliberator) | Status: experimental | Sigma ID: a54451ed-63d4-53fe-ae3e-3feabd5c0ce8 -->
  <rule id="254451" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3722 — Recovery Inhibition (madliberator)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>