<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5160 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: a6c2a149-2fae-513c-b7e3-e508363cc9fa -->
  <rule id="133221" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5160 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>