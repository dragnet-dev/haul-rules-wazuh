<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4705 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ff9d698e-b73b-5d57-89c1-e69d88e08ea2 -->
  <rule id="595769" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4705 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>