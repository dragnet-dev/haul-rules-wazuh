<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0097 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 4cecd075-ed8d-5443-a6ec-f73bf921ea91 -->
  <rule id="550850" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0097 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>