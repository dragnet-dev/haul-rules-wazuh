<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2304 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: 54334f19-30d4-528d-a2db-31e1862038e0 -->
  <rule id="693591" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2304 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>