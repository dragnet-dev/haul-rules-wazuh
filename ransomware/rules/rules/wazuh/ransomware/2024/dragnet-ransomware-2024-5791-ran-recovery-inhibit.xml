<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5791 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: aec324eb-5515-5145-a8ad-0bf9b3eb394f -->
  <rule id="196324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5791 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>