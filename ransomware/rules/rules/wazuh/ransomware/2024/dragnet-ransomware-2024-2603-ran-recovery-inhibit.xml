<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2603 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: c15ffe77-0996-5444-882c-63209dc5307b -->
  <rule id="580734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2603 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>