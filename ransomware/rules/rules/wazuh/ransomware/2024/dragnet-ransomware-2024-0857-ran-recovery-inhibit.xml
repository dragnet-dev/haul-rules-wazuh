<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0857 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 24ecf9f8-4744-58a5-baa4-3a7b64b0e613 -->
  <rule id="220959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0857 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>