<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0553 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 66a5f6cf-2250-52a6-8dc3-3e894df92f9b -->
  <rule id="906556" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0553 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>