<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5126 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: cd8052bd-3a77-5dcd-8582-4a857f5e2f64 -->
  <rule id="358052" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5126 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>