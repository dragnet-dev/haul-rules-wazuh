<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3415 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 2c062875-2057-5a51-9d66-ffac44df8372 -->
  <rule id="906287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3415 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>