<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3463 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: 3f084ba8-89c5-5899-b96d-77bdc4e4d91e -->
  <rule id="209355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3463 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>