<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5043 — Event Log Clearing (cicada3301) | Status: experimental | Sigma ID: db016100-2b3d-5b65-a263-8970bc40aabb -->
  <rule id="490161" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5043 — Event Log Clearing (cicada3301)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>