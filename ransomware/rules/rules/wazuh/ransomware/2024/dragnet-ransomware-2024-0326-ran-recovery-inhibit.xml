<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0326 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6fc9d700-676b-5dc5-9fd2-60c394cb6b70 -->
  <rule id="262377" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0326 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>