<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4316 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 98faa4cf-8fd2-50d5-8e6e-071a88bf1c98 -->
  <rule id="554184" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4316 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>