<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5202 — Recovery Inhibition (dAn0n) | Status: experimental | Sigma ID: 6c027018-dba6-5bdd-938b-aaad7f09a226 -->
  <rule id="280270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5202 — Recovery Inhibition (dAn0n)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>