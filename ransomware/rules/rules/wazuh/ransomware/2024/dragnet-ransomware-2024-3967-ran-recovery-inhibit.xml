<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3967 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 71902746-3d69-5275-9c20-1741eb56c573 -->
  <rule id="990274" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3967 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>