<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4751 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: d0f168a2-1e76-5a06-ad91-b86a63805407 -->
  <rule id="395168" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4751 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>