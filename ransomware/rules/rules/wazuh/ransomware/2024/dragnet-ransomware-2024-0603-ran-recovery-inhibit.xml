<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0603 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: b697963a-17e6-5061-b713-03d19353cd32 -->
  <rule id="369796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0603 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>