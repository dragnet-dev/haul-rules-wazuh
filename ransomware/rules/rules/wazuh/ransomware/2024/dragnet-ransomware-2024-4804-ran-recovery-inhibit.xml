<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4804 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d998e7b3-f985-548a-9f0d-09afeef49595 -->
  <rule id="539827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4804 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>