<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0439 — Event Log Clearing (redransomware) | Status: deprecated | Sigma ID: 01fc2e88-0c86-5003-a82c-709f758dfc26 -->
  <rule id="132688" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0439 — Event Log Clearing (redransomware)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>