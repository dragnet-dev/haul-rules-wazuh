<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4096 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4ff6b93c-9249-5e09-88f4-7f5ed6b12590 -->
  <rule id="347479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4096 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>