<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2383 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: df172d10-25aa-5645-a0cc-0a24eaec9c57 -->
  <rule id="970765" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2383 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>