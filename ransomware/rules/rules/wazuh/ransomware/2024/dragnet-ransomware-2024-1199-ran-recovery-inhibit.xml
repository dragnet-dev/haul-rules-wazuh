<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1199 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: e6dad158-e786-5f4c-af2d-585d223e1f6c -->
  <rule id="715171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1199 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>