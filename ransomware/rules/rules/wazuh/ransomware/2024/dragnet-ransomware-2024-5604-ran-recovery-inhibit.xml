<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5604 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 878b3683-7c0e-51b6-90b6-521e8bb1ab77 -->
  <rule id="605936" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5604 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>