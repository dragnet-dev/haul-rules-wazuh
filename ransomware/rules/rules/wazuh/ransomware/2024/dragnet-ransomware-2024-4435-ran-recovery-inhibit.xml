<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4435 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: c93e2a01-b74e-5cf7-b9ec-f7e22e29ffe2 -->
  <rule id="712362" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4435 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>