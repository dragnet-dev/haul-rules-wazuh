<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5356 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 34e5e1a6-5c6d-59d2-8258-5947ca027845 -->
  <rule id="899866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5356 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>