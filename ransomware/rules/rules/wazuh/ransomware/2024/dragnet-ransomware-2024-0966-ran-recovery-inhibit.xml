<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0966 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 4a1c3be2-d24a-5d66-86f9-0133c6d431f0 -->
  <rule id="198939" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0966 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>