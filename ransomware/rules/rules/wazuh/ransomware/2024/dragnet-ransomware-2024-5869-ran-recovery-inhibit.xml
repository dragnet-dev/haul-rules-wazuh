<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5869 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 88e7e533-aa9a-549b-8f1f-2b51b5a8bd33 -->
  <rule id="576465" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5869 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>