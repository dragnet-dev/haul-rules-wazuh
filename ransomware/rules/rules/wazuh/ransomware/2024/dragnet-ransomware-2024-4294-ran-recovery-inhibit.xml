<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4294 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: bec1003b-4ded-5c38-9ca2-7a1ae37bc553 -->
  <rule id="452100" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4294 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>