<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5418 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f0733fc2-8ab4-5f98-be55-e440fffd46ac -->
  <rule id="711743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5418 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>