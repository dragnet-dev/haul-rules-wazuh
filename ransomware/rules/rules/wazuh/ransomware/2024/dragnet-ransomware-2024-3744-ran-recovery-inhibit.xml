<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3744 — Recovery Inhibition (dAn0n) | Status: experimental | Sigma ID: 7af57c72-e234-585c-a20b-04199f2e273e -->
  <rule id="548124" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3744 — Recovery Inhibition (dAn0n)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>