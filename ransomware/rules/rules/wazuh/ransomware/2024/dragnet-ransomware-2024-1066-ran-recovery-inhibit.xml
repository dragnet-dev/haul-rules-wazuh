<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1066 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: 2a9cb873-78a3-5ea7-89ea-9e725b68f141 -->
  <rule id="300278" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1066 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>