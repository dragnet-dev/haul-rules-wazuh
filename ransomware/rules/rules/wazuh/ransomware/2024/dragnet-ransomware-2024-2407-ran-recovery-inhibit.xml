<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2407 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: c6388032-7937-56e7-b0f4-b96fc9d1b864 -->
  <rule id="463880" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2407 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>