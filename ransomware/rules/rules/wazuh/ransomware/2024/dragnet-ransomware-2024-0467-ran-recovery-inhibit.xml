<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0467 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: d59023e7-3c28-52ec-a8b7-60e599ebbdd8 -->
  <rule id="559023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0467 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>