<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4289 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: bab6a946-0331-5702-8188-d6eb9db907d8 -->
  <rule id="380269" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4289 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>