<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1410 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: edc1260d-9e24-559f-92f7-1853120f4eb1 -->
  <rule id="304126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1410 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>