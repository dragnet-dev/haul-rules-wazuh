<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5913 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1db897fe-13f6-520f-a4c5-672ea985221d -->
  <rule id="514367" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5913 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>