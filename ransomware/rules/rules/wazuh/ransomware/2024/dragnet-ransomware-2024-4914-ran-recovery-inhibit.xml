<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4914 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: e97d5fc5-81fe-56ea-b08e-1f5fd4377477 -->
  <rule id="334495" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4914 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>