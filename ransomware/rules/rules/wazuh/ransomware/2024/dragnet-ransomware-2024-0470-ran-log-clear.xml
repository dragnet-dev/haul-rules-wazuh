<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0470 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 9d10a65f-5adf-5231-91af-0eaf2b6c22c5 -->
  <rule id="813706" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0470 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>