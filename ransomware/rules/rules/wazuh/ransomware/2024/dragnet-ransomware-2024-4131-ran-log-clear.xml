<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4131 — Event Log Clearing (ciphbit) | Status: deprecated | Sigma ID: 6c93a4a4-7b95-5274-b4da-a8ab153c965f -->
  <rule id="942984" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4131 — Event Log Clearing (ciphbit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>