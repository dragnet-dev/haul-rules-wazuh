<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5430 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: ab2a80c3-419e-5d5f-9653-bb7a5737367e -->
  <rule id="140280" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5430 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>