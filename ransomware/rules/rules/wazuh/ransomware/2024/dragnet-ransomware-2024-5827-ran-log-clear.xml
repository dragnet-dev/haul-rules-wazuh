<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5827 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: b96553c1-f46e-5e53-93c2-7c78b4ece3e6 -->
  <rule id="396553" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5827 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>