<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2437 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 964ce13e-83ff-595e-a151-f80f766737a1 -->
  <rule id="769901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2437 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>