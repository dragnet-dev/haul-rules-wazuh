<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4146 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 4e4236da-6e28-58ab-881f-777e440e7839 -->
  <rule id="947789" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4146 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>