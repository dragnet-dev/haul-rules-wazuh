<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5149 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: b7f8e32d-7aa5-50d1-a0a1-1121d1ba2073 -->
  <rule id="420623" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5149 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>