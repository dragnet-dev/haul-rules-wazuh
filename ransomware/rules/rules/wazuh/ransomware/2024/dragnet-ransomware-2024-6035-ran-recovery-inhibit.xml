<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6035 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: d80020e5-7940-517f-bd43-b0cec7d5e206 -->
  <rule id="580020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6035 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>