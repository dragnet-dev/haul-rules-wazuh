<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3006 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1ba865e9-1480-56f1-ab6c-f1fd19042deb -->
  <rule id="885854" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3006 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>