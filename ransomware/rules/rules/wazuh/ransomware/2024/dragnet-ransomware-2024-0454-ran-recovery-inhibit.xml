<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0454 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4362cbed-88bb-50f1-bcbc-ebc03870576d -->
  <rule id="316875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0454 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>