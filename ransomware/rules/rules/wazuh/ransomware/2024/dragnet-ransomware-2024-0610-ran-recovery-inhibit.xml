<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0610 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: e40a6ff5-a779-5d4c-b079-9efad120c888 -->
  <rule id="188111" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0610 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>