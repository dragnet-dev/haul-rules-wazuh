<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5838 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 522687d8-c956-5478-8ba5-c894cfe5f005 -->
  <rule id="363005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5838 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>