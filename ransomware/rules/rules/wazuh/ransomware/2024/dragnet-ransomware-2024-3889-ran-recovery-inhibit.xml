<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3889 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 4f3710f5-da27-5f72-ae86-7e313daefd6e -->
  <rule id="199375" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3889 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>