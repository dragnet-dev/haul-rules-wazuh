<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3052 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 8a9d634a-6d9b-5898-8ebc-20bf593186c6 -->
  <rule id="523763" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3052 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>