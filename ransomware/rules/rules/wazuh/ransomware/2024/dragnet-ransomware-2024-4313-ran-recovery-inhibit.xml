<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4313 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: cba1d5ea-9754-5045-b7aa-f86a3bd993c6 -->
  <rule id="813095" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4313 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>