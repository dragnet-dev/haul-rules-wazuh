<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2041 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: 8e4ad2ba-07cd-5d53-b1a3-02e1f6353551 -->
  <rule id="147172" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2041 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>