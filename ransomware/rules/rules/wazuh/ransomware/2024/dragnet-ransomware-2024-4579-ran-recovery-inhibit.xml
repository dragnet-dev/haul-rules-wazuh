<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4579 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 7904483b-4ab0-5793-aaba-e6136a6a55c9 -->
  <rule id="804483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4579 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>