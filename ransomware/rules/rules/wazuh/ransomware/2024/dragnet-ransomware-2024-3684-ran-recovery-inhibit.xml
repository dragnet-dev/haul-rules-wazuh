<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3684 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: fa992198-3ce1-56e2-917f-7e848f6e7d46 -->
  <rule id="809921" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3684 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>