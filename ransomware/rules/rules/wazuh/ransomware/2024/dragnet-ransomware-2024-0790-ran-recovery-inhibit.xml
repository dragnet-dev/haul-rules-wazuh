<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0790 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 16bb643a-d646-5d9f-a119-774c10b04016 -->
  <rule id="783643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0790 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>