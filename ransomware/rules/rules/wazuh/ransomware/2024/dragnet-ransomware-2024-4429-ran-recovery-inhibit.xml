<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4429 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 59875938-933f-55db-a6ee-d140dd8aa266 -->
  <rule id="687593" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4429 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>