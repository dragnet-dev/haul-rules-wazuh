<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0132 — Event Log Clearing (cloak) | Status: experimental | Sigma ID: 0a0f0e30-dd4a-53dc-8fc1-20c52ae4c36e -->
  <rule id="884143" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0132 — Event Log Clearing (cloak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>