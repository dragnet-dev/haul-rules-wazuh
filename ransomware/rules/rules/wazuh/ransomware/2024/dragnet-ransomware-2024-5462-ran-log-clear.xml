<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5462 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: d33f2152-2da9-529b-8ec3-5dbc3aa69f21 -->
  <rule id="434321" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5462 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>