<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1893 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ff873fc6-3ba3-5cf0-a075-cd84b216dce3 -->
  <rule id="593983" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1893 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
