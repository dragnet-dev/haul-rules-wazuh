<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3112 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 2ed117b1-5e26-5877-9fc8-d6efe66b79ce -->
  <rule id="385883" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3112 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>