<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1536 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 5fc6b538-e324-55b0-905f-c7d9b7969e6a -->
  <rule id="752275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1536 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>