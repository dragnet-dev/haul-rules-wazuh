<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5351 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 072693b6-8f99-5c02-8e37-ebbe743b4d0c -->
  <rule id="363099" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5351 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>