<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5955 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 4d4f1a2a-a5b8-5b03-8dd3-1e3738bd57d3 -->
  <rule id="283866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5955 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>