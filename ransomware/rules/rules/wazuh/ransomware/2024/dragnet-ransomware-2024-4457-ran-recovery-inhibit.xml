<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4457 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: f1f3e67f-f2a5-5012-adbc-ed89e1e6d19e -->
  <rule id="390226" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4457 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>