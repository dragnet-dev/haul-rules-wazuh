<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0651 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ca425c1d-8cdc-5dc8-a572-b4966fd31a60 -->
  <rule id="638812" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0651 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>