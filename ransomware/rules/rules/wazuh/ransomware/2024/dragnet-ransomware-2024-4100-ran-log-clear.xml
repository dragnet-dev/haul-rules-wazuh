<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4100 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 1923c1f7-dc0d-58ef-99be-6946e556e7b9 -->
  <rule id="524831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4100 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>