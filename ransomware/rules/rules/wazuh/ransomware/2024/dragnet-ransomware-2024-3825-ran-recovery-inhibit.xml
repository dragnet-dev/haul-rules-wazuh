<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3825 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: db37412d-8323-5b49-8302-e8ba4aeb1236 -->
  <rule id="493741" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3825 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>