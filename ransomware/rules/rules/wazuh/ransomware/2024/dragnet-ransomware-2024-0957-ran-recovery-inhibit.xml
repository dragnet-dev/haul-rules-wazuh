<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0957 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 655c38e7-31c7-568a-98b2-707e9b78819a -->
  <rule id="249238" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0957 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>