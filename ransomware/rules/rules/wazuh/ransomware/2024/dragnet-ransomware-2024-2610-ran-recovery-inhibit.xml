<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2610 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: e7f9ec83-28d4-5e68-a1c9-071d57681957 -->
  <rule id="762060" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2610 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>