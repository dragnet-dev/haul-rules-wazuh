<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2999 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 7dce834a-4c98-5b98-819c-38acfb02a35a -->
  <rule id="620683" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2999 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>