<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2933 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 7af1b244-5852-5f11-99f1-e81288e5f813 -->
  <rule id="547472" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2933 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>