<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0007 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 4ca5b10b-14f8-5364-ba84-b7b6b3fd7220 -->
  <rule id="262511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0007 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>