<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2305 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: e95d2f64-39b6-5953-b2c6-d9b8484c9ea3 -->
  <rule id="329327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2305 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>