<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0869 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 725d2b51-13bc-5499-946e-5e5fc45a59a8 -->
  <rule id="158123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0869 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>