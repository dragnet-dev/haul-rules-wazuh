<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0866 — Event Log Clearing (apt73) | Status: experimental | Sigma ID: f689e8d0-a15c-5f4d-8ee6-e7fe8f9fa2cb -->
  <rule id="810388" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0866 — Event Log Clearing (apt73)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>