<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2611 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 1c5f3d14-90e3-5a5b-a293-a90878d8f49b -->
  <rule id="220611" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2611 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>