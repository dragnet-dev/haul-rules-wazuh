<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5701 — Recovery Inhibition (bluebox) | Status: experimental | Sigma ID: 92a33e08-0503-5eb5-8fe0-38740b5eebfe -->
  <rule id="671742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5701 — Recovery Inhibition (bluebox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>