<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5619 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a78e5bde-4413-5018-b9ab-fafb29f18586 -->
  <rule id="162011" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5619 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>