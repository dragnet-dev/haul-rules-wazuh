<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4170 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: b2baac49-297c-5c21-871b-89dd2866e0b2 -->
  <rule id="287820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4170 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>