<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5048 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: b879e856-332b-5a86-8ee0-6e423555e774 -->
  <rule id="200788" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5048 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>