<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3479 — Recovery Inhibition (play) | Status: experimental | Sigma ID: de44f2a1-274a-5f0a-a824-b9e7d1381308 -->
  <rule id="959192" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3479 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>