<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5634 — Event Log Clearing (apos) | Status: experimental | Sigma ID: dbbe8f05-628a-54e9-8da2-ee890b10e488 -->
  <rule id="100783" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5634 — Event Log Clearing (apos)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>