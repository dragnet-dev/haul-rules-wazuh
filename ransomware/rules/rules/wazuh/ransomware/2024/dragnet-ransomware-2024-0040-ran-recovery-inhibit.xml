<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0040 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: f0e1a8cf-b8e8-5f21-85a4-5f778c7c1214 -->
  <rule id="362668" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0040 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>