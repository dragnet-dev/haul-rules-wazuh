<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1434 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0d20afa1-adb5-5a0f-be49-e6657bc511ff -->
  <rule id="109530" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1434 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>