<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3249 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 4fd662d4-c42f-521a-a2ea-a5bc50fc0487 -->
  <rule id="477662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3249 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>