<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0199 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 5def9873-e02e-5529-912d-f29829e1dda1 -->
  <rule id="704798" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0199 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>