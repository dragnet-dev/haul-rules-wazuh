<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3843 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4ba721a0-0695-53c6-ac24-6a5736c4775f -->
  <rule id="410721" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3843 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>