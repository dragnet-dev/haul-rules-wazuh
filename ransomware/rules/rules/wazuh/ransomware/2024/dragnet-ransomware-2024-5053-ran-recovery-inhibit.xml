<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5053 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 5870e290-3403-5348-b94d-2ebc3dce3045 -->
  <rule id="493429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5053 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>