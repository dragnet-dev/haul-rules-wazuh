<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2769 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 7dd8b664-dc2e-5e6c-b891-938e59f7ca8c -->
  <rule id="622196" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2769 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>