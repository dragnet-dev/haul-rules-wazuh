<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5121 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: a3b78bc2-8766-500e-aeab-359b0f0b5296 -->
  <rule id="955659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5121 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>