<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5847 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 43f282e9-829a-5096-a590-e9afb694aa60 -->
  <rule id="552526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5847 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>