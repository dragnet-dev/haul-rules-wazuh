<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0945 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 38b413eb-278c-50c7-9286-78170deeaa34 -->
  <rule id="110622" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0945 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>