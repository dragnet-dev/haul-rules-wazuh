<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0592 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 45e52c59-503a-55b6-b1c4-c726bbbaa1e6 -->
  <rule id="375244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0592 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>