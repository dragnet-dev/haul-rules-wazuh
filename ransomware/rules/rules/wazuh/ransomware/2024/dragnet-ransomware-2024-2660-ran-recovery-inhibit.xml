<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2660 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 42e148cf-2250-59b9-b112-65eb6cdd6ea3 -->
  <rule id="278380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2660 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>