<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4556 — Recovery Inhibition (ElDorado) | Status: experimental | Sigma ID: 3fecb138-bd42-5fb8-b0d0-26a1731d28df -->
  <rule id="918351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4556 — Recovery Inhibition (ElDorado)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>