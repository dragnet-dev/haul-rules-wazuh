<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4484 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: af749e65-4a27-5847-85ce-7ef9ee567790 -->
  <rule id="211998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4484 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>