<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5682 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c8fc4d61-be51-5b20-b03d-e366f0b3f3ed -->
  <rule id="883277" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5682 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>