<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3034 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e5651d37-4fe2-580b-8b93-69e0fd2ea51b -->
  <rule id="630429" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3034 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>