<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4262 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 83b6e5ad-ae97-5d6e-a3cc-16bb9a0bffa9 -->
  <rule id="443505" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4262 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>