<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4667 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: 5c2d3c27-7e8e-511c-8674-a2d8ce94e15b -->
  <rule id="662460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4667 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>