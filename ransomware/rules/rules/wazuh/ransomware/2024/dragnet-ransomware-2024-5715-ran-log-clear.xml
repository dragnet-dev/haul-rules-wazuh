<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5715 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 132e9fa8-39d2-5243-8ee4-19813aeb4ddc -->
  <rule id="145114" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5715 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>