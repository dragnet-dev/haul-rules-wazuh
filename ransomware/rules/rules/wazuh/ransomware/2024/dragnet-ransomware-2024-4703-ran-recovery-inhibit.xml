<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4703 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 309c1d57-f094-5c7c-acc3-de0803b9dfda -->
  <rule id="829895" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4703 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>