<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3848 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: d720591f-9ba9-5d2f-98b7-c3054efdfa7e -->
  <rule id="572059" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3848 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>