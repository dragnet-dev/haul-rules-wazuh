<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4820 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2e11b7a4-50a2-5bbd-90f0-e6a35299186a -->
  <rule id="206042" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4820 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>