<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5241 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 8ccd4151-101c-5b73-a51a-26b37e6b6773 -->
  <rule id="104541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5241 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>