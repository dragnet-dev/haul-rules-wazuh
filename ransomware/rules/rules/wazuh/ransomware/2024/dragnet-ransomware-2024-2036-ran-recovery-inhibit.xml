<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2036 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: b6633a65-b17c-569e-82bc-5482e7971220 -->
  <rule id="166138" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2036 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>