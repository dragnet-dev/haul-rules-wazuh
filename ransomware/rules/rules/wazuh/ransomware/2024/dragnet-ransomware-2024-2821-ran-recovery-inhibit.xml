<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2821 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e846b532-c7ad-5c0f-94c5-60ff8d02f197 -->
  <rule id="675475" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2821 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>