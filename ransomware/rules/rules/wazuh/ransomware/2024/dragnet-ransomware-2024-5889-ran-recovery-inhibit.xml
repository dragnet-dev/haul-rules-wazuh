<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5889 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 4a1acf35-8256-51c8-90bc-b0d89da18fa1 -->
  <rule id="437903" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5889 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>