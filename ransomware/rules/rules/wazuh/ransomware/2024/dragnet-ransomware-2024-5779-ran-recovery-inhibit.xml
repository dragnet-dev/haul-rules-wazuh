<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5779 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 4c83f853-30c5-5a4a-a19b-15f61c53f62f -->
  <rule id="429438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5779 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>