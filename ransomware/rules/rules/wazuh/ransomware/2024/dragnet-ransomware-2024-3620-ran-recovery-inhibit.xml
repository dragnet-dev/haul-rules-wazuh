<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3620 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: b8e1a866-143d-5d10-90f0-0db71ac700ac -->
  <rule id="443468" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3620 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>