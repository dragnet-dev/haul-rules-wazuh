<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0583 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 212c3dbe-0047-5ca7-ab10-f1a81cbc44fc -->
  <rule id="715227" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0583 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>