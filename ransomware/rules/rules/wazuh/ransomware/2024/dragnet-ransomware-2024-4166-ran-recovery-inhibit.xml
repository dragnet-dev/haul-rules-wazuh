<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4166 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d9bf0b54-9b12-59ea-b15c-6e0ca87b2623 -->
  <rule id="424011" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4166 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>