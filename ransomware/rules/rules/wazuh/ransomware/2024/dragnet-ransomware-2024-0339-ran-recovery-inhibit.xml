<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0339 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e4ff43ff-72d6-503a-acdf-7b0bfba251ab -->
  <rule id="211943" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0339 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>