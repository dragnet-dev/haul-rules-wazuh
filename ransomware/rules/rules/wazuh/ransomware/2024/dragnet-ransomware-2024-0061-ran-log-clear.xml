<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0061 — Event Log Clearing (argonauts) | Status: experimental | Sigma ID: 6f0b14a7-6299-5bd3-b8ec-891e52fc54dd -->
  <rule id="977114" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0061 — Event Log Clearing (argonauts)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>