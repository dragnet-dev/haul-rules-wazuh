<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0842 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0dd6f7ed-761f-539f-b4ee-a5d68820b505 -->
  <rule id="375486" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0842 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>