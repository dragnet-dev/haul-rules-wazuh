<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4665 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: b193cb80-6a3d-5ab6-9dac-78387c463e31 -->
  <rule id="265611" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4665 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>