<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1276 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: abaf338d-24d4-50c4-a2b4-903dfddfbd6b -->
  <rule id="895133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1276 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>