<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2856 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 0d9ebbe6-d398-5888-a8f0-365656553ccb -->
  <rule id="269854" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2856 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>