<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3554 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 30e1d57a-3f85-5c76-81a8-9841201ced59 -->
  <rule id="806957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3554 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>