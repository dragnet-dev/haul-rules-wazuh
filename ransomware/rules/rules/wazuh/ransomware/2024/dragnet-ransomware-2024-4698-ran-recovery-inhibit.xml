<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4698 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 5e1bd6ab-2838-574e-991e-f44f0560d866 -->
  <rule id="710856" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4698 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>