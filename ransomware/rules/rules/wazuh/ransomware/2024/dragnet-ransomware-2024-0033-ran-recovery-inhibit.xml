<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0033 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: a073d42f-452a-536e-a9a5-63a1e0b919d7 -->
  <rule id="811814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0033 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>