<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1742 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8824b9db-2b16-55a5-b318-5d9a9389a26e -->
  <rule id="611959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1742 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>