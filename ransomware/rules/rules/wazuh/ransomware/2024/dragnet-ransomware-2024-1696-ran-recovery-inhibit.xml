<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1696 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: fe41bf76-ea02-5f69-849c-f31a687c5dee -->
  <rule id="313087" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1696 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>