<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2506 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f833c5a6-9f51-5df4-9717-e02bedf6fa78 -->
  <rule id="833405" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2506 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>