<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3126 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: ba95876b-d94f-59d1-adbc-300d4eaf9a81 -->
  <rule id="169587" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3126 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>