<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4817 — Event Log Clearing (raworld) | Status: experimental | Sigma ID: 5278c996-379a-52b2-a863-1b42a3f72733 -->
  <rule id="446099" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4817 — Event Log Clearing (raworld)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>