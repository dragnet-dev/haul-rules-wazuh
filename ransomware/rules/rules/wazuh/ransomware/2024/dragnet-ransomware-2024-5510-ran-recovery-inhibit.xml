<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5510 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: afef2217-42dd-5d37-964c-03733643821d -->
  <rule id="103922" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5510 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>