<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0169 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: cf0b4e49-95ac-5c9c-935a-81cc813681ad -->
  <rule id="901038" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0169 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>