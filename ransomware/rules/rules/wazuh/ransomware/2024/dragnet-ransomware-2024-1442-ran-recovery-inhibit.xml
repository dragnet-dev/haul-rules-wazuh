<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1442 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 011c88a1-b485-575b-ac6e-a7af133cbe04 -->
  <rule id="422181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1442 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>