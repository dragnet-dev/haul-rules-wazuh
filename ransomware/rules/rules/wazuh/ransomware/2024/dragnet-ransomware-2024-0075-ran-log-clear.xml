<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0075 — Event Log Clearing (alphalocker) | Status: experimental | Sigma ID: 30c628f6-b4ec-55bd-841d-be4a048bd078 -->
  <rule id="782063" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0075 — Event Log Clearing (alphalocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>