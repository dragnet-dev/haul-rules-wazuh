<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3863 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 90cd3a22-123f-5bef-b0d3-6999892241f0 -->
  <rule id="219258" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3863 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>