<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1104 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: ad7ce863-57f8-51cc-8a09-cad8edc7feab -->
  <rule id="948788" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1104 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>