<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5247 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 22ce598c-04a4-5c68-b606-afa9ca9e1a58 -->
  <rule id="538598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5247 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>