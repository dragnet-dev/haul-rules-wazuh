<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0648 — Event Log Clearing (dAn0n) | Status: experimental | Sigma ID: 2deb5ab5-631a-532f-b9a2-911cd54eaeb3 -->
  <rule id="180890" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0648 — Event Log Clearing (dAn0n)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>