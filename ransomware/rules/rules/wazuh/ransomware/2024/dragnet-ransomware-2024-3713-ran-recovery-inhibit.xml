<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3713 — Recovery Inhibition (ransomcortex) | Status: experimental | Sigma ID: 3807d4d8-d3e5-5f87-87a6-603286c34a7e -->
  <rule id="848077" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3713 — Recovery Inhibition (ransomcortex)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>