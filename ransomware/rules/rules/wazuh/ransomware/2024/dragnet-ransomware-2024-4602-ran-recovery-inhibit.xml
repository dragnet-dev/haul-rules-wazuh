<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4602 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 040ebf89-a4c1-5350-a38c-5bc93cc09198 -->
  <rule id="876158" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4602 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>