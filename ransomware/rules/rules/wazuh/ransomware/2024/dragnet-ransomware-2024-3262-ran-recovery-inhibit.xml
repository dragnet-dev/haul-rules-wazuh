<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3262 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: e14aa1cd-8eae-5f41-a311-11cd05b0fd10 -->
  <rule id="121541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3262 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>