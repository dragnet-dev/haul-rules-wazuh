<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5895 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 51ebaa72-4657-5fc5-83d4-7cf037510f62 -->
  <rule id="802666" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5895 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>