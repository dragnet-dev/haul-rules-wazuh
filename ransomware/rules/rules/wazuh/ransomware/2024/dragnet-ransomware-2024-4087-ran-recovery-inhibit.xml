<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4087 — Recovery Inhibition (play) | Status: experimental | Sigma ID: af6bb60f-c0a8-532f-988c-fc20c801f4d6 -->
  <rule id="997236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4087 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>