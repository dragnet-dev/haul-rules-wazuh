<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4021 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e509d518-d4a8-5103-80d3-ecfc0dfa0d60 -->
  <rule id="621575" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4021 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>