<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1194 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: a8804289-52ad-5192-a3e1-4d21bd7dba33 -->
  <rule id="288042" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1194 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>