<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0116 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: af8bbae8-bb3b-5380-b959-c53f541e019f -->
  <rule id="103770" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0116 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>