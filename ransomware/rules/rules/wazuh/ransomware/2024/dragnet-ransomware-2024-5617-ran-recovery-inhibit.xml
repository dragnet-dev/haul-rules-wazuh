<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5617 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 59ce88bf-308e-59ec-8967-97dae37feb52 -->
  <rule id="731088" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5617 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>