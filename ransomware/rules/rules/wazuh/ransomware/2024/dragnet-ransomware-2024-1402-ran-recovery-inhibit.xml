<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1402 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 2638dbdd-6ed3-5367-82e9-d02c9aa5279e -->
  <rule id="108765" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1402 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>