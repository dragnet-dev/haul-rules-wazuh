<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5787 — Event Log Clearing (meow) | Status: experimental | Sigma ID: 7a2e261f-8871-5078-a5c7-460dadc2671a -->
  <rule id="256626" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5787 — Event Log Clearing (meow)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>