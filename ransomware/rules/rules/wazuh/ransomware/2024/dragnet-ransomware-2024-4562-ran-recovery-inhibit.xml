<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4562 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: b8c9337e-dbb2-555c-b090-099189a31195 -->
  <rule id="200933" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4562 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>