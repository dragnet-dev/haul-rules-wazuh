<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2797 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 46857593-cef2-59f8-b07b-b8e4f5f11b2b -->
  <rule id="285759" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2797 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>