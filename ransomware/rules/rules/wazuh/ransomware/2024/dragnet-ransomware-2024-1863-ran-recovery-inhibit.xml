<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1863 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 9006abbf-8600-5592-be15-722621ef0864 -->
  <rule id="605707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1863 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>