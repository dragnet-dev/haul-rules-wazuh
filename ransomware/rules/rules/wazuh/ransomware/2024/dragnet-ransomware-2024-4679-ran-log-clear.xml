<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4679 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 9d7cac1a-f456-57f6-b789-0de7c3d8fbc4 -->
  <rule id="262636" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4679 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>