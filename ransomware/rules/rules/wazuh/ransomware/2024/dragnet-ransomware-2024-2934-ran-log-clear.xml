<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2934 — Event Log Clearing (ElDorado) | Status: deprecated | Sigma ID: d0a2c2ac-7509-5b5c-8ef4-0151d9186125 -->
  <rule id="744442" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2934 — Event Log Clearing (ElDorado)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>