<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5100 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5cea53d6-28d5-5f51-96c8-6f9db9787530 -->
  <rule id="678653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5100 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>