  <rule id="726978" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1998 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
