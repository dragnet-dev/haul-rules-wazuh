<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5955 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: dc5f66e7-d24b-56ff-9b0b-ce5927e2bbe5 -->
  <rule id="929566" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5955 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>