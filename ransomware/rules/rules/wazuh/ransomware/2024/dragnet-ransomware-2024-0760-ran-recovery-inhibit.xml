<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0760 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 75a3e225-9704-55b8-8baf-9bc77bdc38f0 -->
  <rule id="236622" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0760 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>