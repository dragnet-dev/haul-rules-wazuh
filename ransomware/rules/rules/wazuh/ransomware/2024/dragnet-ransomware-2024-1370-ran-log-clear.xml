<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1370 — Event Log Clearing (8base) | Status: experimental | Sigma ID: 85cd24ab-8a4e-5e4a-8632-1a1290b82ba4 -->
  <rule id="496524" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1370 — Event Log Clearing (8base)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>