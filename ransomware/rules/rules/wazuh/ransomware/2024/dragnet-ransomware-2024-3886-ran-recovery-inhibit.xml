<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3886 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 74ee9f74-c6b6-5561-aa4c-17a6f1fc2b82 -->
  <rule id="469279" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3886 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>