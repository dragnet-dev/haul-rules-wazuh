<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1634 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: f60a6594-9571-53a1-b80b-ee81c383f5f3 -->
  <rule id="797065" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1634 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>