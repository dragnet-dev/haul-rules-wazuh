<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3821 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: f62b7b8d-1fe3-5c07-9460-7f5f0de67739 -->
  <rule id="500603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3821 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>