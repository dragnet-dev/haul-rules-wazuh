<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5506 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9040181d-5908-5896-b36e-17428404dd0b -->
  <rule id="140181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5506 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>