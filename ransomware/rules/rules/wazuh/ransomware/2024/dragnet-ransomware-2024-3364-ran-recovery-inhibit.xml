<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3364 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 95ae6af4-9385-5412-83eb-bbf4ed6e151e -->
  <rule id="419146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3364 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>