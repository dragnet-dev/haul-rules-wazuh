<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1924 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: f26f7087-5621-5b8e-b871-4846a6d92d50 -->
  <rule id="743170" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1924 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>