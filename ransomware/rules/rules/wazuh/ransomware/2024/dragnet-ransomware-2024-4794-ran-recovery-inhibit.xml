<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4794 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 860af071-aaae-5e7f-8ff2-f047b9e77737 -->
  <rule id="503350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4794 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>