<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0251 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 2504a37a-9c6b-5bd1-9e39-4b4e2713f26e -->
  <rule id="507437" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0251 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>