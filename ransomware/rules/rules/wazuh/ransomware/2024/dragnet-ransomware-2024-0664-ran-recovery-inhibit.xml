<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0664 — Recovery Inhibition (blackout) | Status: experimental | Sigma ID: 76b20ec0-7656-5b1e-8ea1-621c0cc3a84d -->
  <rule id="263534" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0664 — Recovery Inhibition (blackout)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>