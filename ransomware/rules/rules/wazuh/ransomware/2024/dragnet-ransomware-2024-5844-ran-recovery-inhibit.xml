<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5844 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 5fcd3cf5-f8d1-508c-aaf7-8db93ab6e875 -->
  <rule id="424060" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5844 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>