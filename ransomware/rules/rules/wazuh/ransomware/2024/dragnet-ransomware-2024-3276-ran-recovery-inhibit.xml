<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3276 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a47bf744-4ecc-51be-b4c3-a2d9674e69b0 -->
  <rule id="982237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3276 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>