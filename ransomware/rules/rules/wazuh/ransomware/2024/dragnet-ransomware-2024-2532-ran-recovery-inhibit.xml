<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2532 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: c165516d-1778-51b4-b266-9f4b42053c84 -->
  <rule id="416551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2532 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>