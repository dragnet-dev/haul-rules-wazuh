<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5082 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: 5f13dfbb-1c27-5e1e-97cf-e8c890167748 -->
  <rule id="735551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5082 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>