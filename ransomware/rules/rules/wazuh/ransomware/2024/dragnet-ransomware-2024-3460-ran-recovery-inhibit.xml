<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3460 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: a5d1d1db-6da9-534d-ba46-4d5f497e01e6 -->
  <rule id="109091" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3460 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>