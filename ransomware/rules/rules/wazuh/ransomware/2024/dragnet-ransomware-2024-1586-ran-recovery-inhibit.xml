<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1586 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 96763cfe-1db2-5fd2-b1e2-f4b97633f093 -->
  <rule id="748220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1586 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>