<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3215 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 62ce17ad-a289-55b6-b022-4a2b8417c818 -->
  <rule id="807817" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3215 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>