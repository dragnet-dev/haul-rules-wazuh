<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0071 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: dd4fe6a7-2328-5c89-a5c0-4f6be5b935d1 -->
  <rule id="370386" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0071 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>