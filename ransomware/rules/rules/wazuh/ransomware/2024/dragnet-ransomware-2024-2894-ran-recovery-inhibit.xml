<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2894 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 54706029-43fc-51dd-92dc-f5f37bec76c8 -->
  <rule id="170602" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2894 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>