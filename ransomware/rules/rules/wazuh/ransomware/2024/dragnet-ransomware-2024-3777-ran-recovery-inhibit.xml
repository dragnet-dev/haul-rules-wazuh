<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3777 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 7f2b7d7c-1f87-5812-8200-a3f2580555c4 -->
  <rule id="658205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3777 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>