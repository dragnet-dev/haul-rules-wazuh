<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1263 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: d6e8775d-f86e-5dcc-9b10-f9b6bbb58d17 -->
  <rule id="490877" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1263 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>