<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1268 — Recovery Inhibition (sensayq) | Status: experimental | Sigma ID: 4650fac1-1e9c-5baa-871d-d41b11a81d6a -->
  <rule id="390650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1268 — Recovery Inhibition (sensayq)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>