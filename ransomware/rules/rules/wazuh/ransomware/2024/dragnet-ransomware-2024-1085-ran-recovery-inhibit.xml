<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1085 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f2ddd0ff-210c-5a22-9816-949962317d79 -->
  <rule id="961410" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1085 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>