<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1564 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 60db2f7c-2f8f-5746-9656-63a99032d781 -->
  <rule id="792687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1564 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>