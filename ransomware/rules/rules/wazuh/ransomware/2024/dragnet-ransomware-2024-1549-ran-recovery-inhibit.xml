<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1549 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 08715350-68e8-5057-83fa-d8154fe048e1 -->
  <rule id="715350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1549 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>