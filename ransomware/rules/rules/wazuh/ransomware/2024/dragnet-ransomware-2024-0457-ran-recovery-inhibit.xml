<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0457 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 60619236-ebfe-5d15-ae52-4e0afe9fc64d -->
  <rule id="761923" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0457 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>