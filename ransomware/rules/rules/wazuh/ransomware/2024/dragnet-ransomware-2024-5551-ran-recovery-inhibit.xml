<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5551 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4a1a3175-c362-569f-b829-092d36974639 -->
  <rule id="386631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5551 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>