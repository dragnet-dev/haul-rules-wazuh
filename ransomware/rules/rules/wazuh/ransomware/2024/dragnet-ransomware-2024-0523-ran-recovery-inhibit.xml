<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0523 — Recovery Inhibition (chort) | Status: experimental | Sigma ID: f8ae70ec-4d91-5003-9bcc-d0dd750f13da -->
  <rule id="562270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0523 — Recovery Inhibition (chort)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>