<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2796 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 91d32f1b-8b9f-5949-be19-6f6cf8af7799 -->
  <rule id="650927" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2796 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>