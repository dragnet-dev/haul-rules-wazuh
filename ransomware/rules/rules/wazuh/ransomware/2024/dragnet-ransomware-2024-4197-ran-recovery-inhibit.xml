<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4197 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 095b2419-6a76-50cb-a3b4-c092019705c1 -->
  <rule id="731241" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4197 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>