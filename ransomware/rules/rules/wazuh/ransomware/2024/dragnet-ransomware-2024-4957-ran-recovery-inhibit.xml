<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4957 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 334616d0-335e-575f-80dc-aab39f941aa1 -->
  <rule id="953869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4957 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>