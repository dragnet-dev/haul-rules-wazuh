<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5802 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: a9489cad-0248-533b-bf22-07c4a4bbf4ed -->
  <rule id="951836" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5802 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>