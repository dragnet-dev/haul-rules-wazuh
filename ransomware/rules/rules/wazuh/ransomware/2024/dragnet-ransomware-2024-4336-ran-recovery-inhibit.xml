<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4336 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8c0d5e2c-dfb3-5a6b-b71b-4c332e4a9275 -->
  <rule id="986174" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4336 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>