<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0314 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: abdb4405-0939-505e-90e9-2fc05aa55c08 -->
  <rule id="899544" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0314 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>