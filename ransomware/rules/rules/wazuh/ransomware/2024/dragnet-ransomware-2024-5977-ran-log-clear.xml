<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5977 — Event Log Clearing (mallox) | Status: deprecated | Sigma ID: 40af8fea-1875-56c3-9f1b-9bcfdc44b0c7 -->
  <rule id="866543" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5977 — Event Log Clearing (mallox)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>