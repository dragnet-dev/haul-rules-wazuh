<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5587 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 381a5099-e8be-5af8-adae-05a039afb32c -->
  <rule id="806509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5587 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>