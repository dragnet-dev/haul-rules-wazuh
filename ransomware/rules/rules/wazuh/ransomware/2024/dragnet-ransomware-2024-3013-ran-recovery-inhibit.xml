<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3013 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 61db6540-f444-544d-a14e-df4c038f132b -->
  <rule id="783565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3013 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>