<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5970 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 1852de5d-7c92-59d1-8b8a-994b3c204ed3 -->
  <rule id="343345" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5970 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>