<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5958 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 0470b5b0-847c-594d-95dd-87496c3ae1bc -->
  <rule id="405051" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5958 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>