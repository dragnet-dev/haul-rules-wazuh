<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3651 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 9e0d5013-eb9d-5296-9393-790647d2eb8b -->
  <rule id="829350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3651 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>