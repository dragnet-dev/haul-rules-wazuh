<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5743 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 96a220e3-8720-50bc-97e1-19d205815696 -->
  <rule id="746220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5743 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>