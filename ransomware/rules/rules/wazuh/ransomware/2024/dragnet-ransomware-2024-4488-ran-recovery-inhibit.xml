<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4488 — Recovery Inhibition (madliberator) | Status: experimental | Sigma ID: c836fcbc-3516-5b8f-8ec2-7884b21ead8e -->
  <rule id="686268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4488 — Recovery Inhibition (madliberator)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>