<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4078 — Event Log Clearing (madliberator) | Status: experimental | Sigma ID: d923718d-1313-594d-93a2-ac05c70ebdec -->
  <rule id="592371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4078 — Event Log Clearing (madliberator)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>