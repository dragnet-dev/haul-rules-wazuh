<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5184 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 23f1f3cb-d591-5104-a573-9592f24a6240 -->
  <rule id="909820" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5184 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
