<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2164 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 53065948-75f7-562b-a941-6310571d414e -->
  <rule id="906594" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2164 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>