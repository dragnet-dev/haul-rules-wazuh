<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2760 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: e07fc890-5974-5594-bae0-3aa78d7d3c8f -->
  <rule id="104448" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2760 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>