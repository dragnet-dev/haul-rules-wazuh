<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5633 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: eeafee14-be9e-5e87-9935-d1648009492b -->
  <rule id="442606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5633 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>