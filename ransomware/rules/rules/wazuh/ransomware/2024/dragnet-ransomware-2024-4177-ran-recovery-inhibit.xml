<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4177 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: deece426-2747-57d2-b8ba-944e3e7a9f49 -->
  <rule id="231024" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4177 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>