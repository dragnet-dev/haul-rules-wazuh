<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3725 — Recovery Inhibition (akira) | Status: experimental | Sigma ID: f9fb4080-4d66-5203-a272-1d5cd73d4f6a -->
  <rule id="595540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3725 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>