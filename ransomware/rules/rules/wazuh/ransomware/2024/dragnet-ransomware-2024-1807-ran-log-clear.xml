<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1807 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 9d639bbf-7f0d-5cff-bfca-a37f24999c0e -->
  <rule id="822235" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1807 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>