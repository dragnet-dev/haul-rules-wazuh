<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2004 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 94d7bb32-8417-5cc7-a101-528171efb2f8 -->
  <rule id="385499" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2004 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>