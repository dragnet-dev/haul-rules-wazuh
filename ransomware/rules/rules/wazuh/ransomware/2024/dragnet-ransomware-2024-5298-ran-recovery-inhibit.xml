<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5298 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: a13f104f-232e-5f3b-830c-29ef4aca3df4 -->
  <rule id="822310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5298 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>