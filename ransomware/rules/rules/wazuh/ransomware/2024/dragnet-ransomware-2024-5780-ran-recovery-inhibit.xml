<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5780 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 10611b60-022c-57b8-a267-67f29733014e -->
  <rule id="897876" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5780 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>