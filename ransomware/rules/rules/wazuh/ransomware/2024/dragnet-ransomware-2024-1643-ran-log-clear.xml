<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1643 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 65f348c8-7f6d-5a34-8ead-ba71b32cfc79 -->
  <rule id="255348" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1643 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>