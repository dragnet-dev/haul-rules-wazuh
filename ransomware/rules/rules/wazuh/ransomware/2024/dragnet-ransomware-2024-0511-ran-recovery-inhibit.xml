<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0511 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 12a2007f-3393-5060-83be-d00f41d8246d -->
  <rule id="322007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0511 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>