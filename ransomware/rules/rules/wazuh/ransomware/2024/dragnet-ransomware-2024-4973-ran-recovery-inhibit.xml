<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4973 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: cbcaf561-e3c9-5a1d-ab1c-328b31092ead -->
  <rule id="347355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4973 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>