<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2023 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 32d44e0e-1be0-5e7d-a4bc-2f20f3f9e4eb -->
  <rule id="407180" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2023 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>