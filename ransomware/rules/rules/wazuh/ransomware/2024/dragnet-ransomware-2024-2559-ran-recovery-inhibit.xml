<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2559 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 7a3c8a04-7d4c-5185-b76e-8c7c78e9a2a1 -->
  <rule id="532938" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2559 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>