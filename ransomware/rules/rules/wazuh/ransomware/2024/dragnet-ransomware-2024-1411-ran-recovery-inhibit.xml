<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1411 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 84ea358f-ea10-533e-b290-33bfab652c3b -->
  <rule id="473835" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1411 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>