<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5058 — Event Log Clearing (hellcat) | Status: deprecated | Sigma ID: 7cbcecb0-0a15-5b70-b4f9-f90e08746e27 -->
  <rule id="174828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5058 — Event Log Clearing (hellcat)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>