<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4051 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6932a4e1-ba60-5212-86c7-24a168a66a82 -->
  <rule id="309224" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4051 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>