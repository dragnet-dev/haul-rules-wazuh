<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1420 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d330fa69-a666-5f2e-b130-8028b562950c -->
  <rule id="812730" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1420 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>