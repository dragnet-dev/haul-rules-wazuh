<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0426 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0c949400-26af-5ea4-bc33-064de2ebe118 -->
  <rule id="494940" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0426 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>