<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1120 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 45d15c48-bfe3-5a10-87fd-1316748ee4d0 -->
  <rule id="373052" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1120 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>