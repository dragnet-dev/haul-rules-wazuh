<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1195 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: bf747333-42b5-529b-a3c7-1680f5c92203 -->
  <rule id="217473" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1195 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>