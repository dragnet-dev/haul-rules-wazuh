<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1275 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 9e82c30f-73a1-56fa-b740-2c95892816bd -->
  <rule id="841243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1275 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>