<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3597 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: c7215548-3d6d-5185-ad2e-9818b350d6fe -->
  <rule id="472155" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3597 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>