<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3784 — Recovery Inhibition (dAn0n) | Status: experimental | Sigma ID: dae67647-f156-5a02-b79c-01d83540f851 -->
  <rule id="902676" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3784 — Recovery Inhibition (dAn0n)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>