<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0979 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 26237460-0e6e-500b-9aff-557ca76e99c4 -->
  <rule id="923746" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0979 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>