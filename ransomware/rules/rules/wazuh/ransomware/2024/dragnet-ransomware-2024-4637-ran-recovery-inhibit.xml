<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4637 — Recovery Inhibition (medusalocker) | Status: experimental | Sigma ID: d6c6ef8b-06bb-57f5-84ae-88eecc82be1b -->
  <rule id="303055" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4637 — Recovery Inhibition (medusalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>