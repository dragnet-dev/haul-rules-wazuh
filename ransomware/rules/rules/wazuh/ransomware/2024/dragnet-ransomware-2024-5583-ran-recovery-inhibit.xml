<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5583 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 57e4bd3f-fb30-5c20-9e7f-08e4d95eeec4 -->
  <rule id="671773" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5583 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>