<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1457 — Recovery Inhibition (play) | Status: experimental | Sigma ID: d514cba5-0764-5bb8-be62-4cd5c649483d -->
  <rule id="859787" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1457 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>