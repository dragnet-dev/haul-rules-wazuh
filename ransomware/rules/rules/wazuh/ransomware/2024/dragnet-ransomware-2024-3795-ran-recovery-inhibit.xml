<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3795 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 7c4ad912-a6c0-583c-9359-71866084653e -->
  <rule id="586379" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3795 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>