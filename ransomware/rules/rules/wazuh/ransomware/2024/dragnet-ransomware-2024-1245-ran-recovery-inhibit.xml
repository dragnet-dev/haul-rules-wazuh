<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1245 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 3c8d6fb0-0e2d-546a-ac5e-1c54d3c3d138 -->
  <rule id="758671" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1245 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>