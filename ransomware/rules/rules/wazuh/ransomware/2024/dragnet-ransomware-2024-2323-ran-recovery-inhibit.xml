<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2323 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: eb303358-763c-52d7-9fc3-8551cb649a09 -->
  <rule id="653033" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2323 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>