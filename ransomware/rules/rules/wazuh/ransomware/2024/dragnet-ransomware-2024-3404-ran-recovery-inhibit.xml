<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3404 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: cf6c6e0e-12fe-5805-aace-fbad72286921 -->
  <rule id="916590" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3404 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>