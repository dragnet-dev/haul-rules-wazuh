<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2298 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 803cc147-c320-5915-89c6-26daa7b5db83 -->
  <rule id="357721" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2298 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>