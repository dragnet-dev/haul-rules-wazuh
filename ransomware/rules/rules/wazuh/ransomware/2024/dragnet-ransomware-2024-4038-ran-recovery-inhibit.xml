<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4038 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6a87ae9f-8b07-5ee3-930a-31beb7cd66ce -->
  <rule id="136046" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4038 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>