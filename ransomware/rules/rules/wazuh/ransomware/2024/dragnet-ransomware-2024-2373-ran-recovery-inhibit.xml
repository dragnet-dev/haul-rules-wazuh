<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2373 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: c27e143a-00fd-5da8-ac38-36f8753aa5a0 -->
  <rule id="264614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2373 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>