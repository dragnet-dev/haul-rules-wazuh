<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3829 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: 58117d4d-9c7c-50c5-b3cf-eff83bfd8c75 -->
  <rule id="398854" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3829 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>