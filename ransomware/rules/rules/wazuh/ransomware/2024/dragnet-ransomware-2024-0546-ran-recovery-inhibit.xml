<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0546 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 2d0e6d32-74e5-551d-b262-dc084bd1ee83 -->
  <rule id="354349" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0546 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>