<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4302 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: dc8b8cca-3ee0-579e-909e-90efe6391b85 -->
  <rule id="354380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4302 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>