<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0978 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5a24e024-6a69-58dd-944c-1712e7c6ba0d -->
  <rule id="643980" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0978 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>