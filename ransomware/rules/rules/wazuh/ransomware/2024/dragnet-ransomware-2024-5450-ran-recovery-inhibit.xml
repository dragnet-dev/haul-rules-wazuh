<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5450 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ab26703d-4135-576b-b882-ba94821fa2ca -->
  <rule id="912670" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5450 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>