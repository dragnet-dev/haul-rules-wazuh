<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5488 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: 51f4c4db-a8d4-5625-a038-124e6fae6556 -->
  <rule id="530364" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5488 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>