<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4093 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 9b164ad7-708f-5a93-903a-f5f8bdf147f1 -->
  <rule id="782634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4093 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>