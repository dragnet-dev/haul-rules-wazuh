<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0304 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a1578235-be35-554d-a2e2-4cb7901d59d0 -->
  <rule id="215782" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0304 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>