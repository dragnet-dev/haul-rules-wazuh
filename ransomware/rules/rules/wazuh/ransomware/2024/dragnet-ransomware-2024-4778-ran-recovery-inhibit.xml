<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4778 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 62831537-1da3-5ec4-aabb-ca8070aefa58 -->
  <rule id="983153" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4778 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>