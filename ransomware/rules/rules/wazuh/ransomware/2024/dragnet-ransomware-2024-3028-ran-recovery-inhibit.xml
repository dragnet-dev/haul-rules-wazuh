<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3028 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ea9f2c04-e671-5a8c-bd7a-6728e39bbb4a -->
  <rule id="715884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3028 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>