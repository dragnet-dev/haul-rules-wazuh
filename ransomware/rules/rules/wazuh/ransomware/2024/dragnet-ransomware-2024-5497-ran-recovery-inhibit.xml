<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5497 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 4c81073b-ccc5-52eb-b6eb-ababbead3839 -->
  <rule id="581073" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5497 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>