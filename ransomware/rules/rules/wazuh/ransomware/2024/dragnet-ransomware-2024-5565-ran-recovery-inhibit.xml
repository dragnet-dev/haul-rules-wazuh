<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5565 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: f5d15361-0b23-521a-8413-e18f8a7f3ced -->
  <rule id="793153" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5565 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>