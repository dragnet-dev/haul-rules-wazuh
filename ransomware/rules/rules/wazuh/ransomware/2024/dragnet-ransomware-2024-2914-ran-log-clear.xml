<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2914 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 7ccb0f4c-2f88-5c34-a7e4-109ebe5b9907 -->
  <rule id="711535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2914 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>