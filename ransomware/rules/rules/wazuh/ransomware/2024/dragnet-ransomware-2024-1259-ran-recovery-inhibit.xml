<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1259 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5fdff351-6fed-55f1-a054-f6b8714640e8 -->
  <rule id="427033" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1259 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>