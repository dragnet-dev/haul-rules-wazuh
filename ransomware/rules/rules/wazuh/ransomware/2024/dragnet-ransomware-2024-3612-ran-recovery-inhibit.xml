<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3612 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 53235f7a-8338-57a8-b5bf-8eca7bbf5352 -->
  <rule id="517757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3612 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>