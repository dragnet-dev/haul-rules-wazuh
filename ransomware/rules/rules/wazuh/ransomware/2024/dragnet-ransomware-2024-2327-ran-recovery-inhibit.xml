<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2327 — Recovery Inhibition (blackout) | Status: experimental | Sigma ID: eec3601e-1cca-5dd5-99d0-b7cc7ca69408 -->
  <rule id="320360" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2327 — Recovery Inhibition (blackout)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>