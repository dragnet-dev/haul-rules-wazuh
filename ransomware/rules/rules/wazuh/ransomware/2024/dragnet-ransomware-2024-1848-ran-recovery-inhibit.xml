<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1848 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: 637f1385-197d-5c3c-b8dd-f6074f10e858 -->
  <rule id="220713" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1848 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>