<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5137 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: afc75aef-df1a-583c-90aa-f2d0bf8dc07f -->
  <rule id="100410" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5137 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>