<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2223 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 593dd7f8-11f2-57af-b707-1f5661dea829 -->
  <rule id="720297" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2223 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>