<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4237 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 473dbdf5-e2e6-56ff-80b7-05fe2aec8eda -->
  <rule id="240925" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4237 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>