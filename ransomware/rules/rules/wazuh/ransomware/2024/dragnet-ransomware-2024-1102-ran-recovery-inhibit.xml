<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1102 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: f00c05fd-ba93-5683-956b-1aca03457bf3 -->
  <rule id="701205" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1102 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>