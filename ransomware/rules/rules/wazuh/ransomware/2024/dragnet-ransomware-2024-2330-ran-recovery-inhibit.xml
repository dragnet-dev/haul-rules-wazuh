<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2330 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2366126a-0200-5729-9854-ca157b2a3d78 -->
  <rule id="666126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2330 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>