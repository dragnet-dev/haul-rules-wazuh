<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1519 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 99fefdab-ccb2-56c3-9d58-3a41ef6f8541 -->
  <rule id="353341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1519 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>