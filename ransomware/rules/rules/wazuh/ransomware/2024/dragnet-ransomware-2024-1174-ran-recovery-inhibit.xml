<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1174 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 0679716d-91d2-53c8-a987-a65db684232f -->
  <rule id="175469" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1174 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>