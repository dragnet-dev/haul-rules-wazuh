<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3150 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: f8f68a9b-90cc-5606-87cd-bdeffe574644 -->
  <rule id="569898" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3150 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>