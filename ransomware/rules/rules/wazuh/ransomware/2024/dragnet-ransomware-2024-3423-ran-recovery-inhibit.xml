<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3423 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 631a4fd5-f722-5698-80d5-ed4b09232523 -->
  <rule id="817039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3423 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>