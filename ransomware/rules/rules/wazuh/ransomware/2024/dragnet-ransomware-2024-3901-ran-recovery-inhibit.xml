<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3901 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 029a1c31-71e2-5dee-b734-853cdd2cc062 -->
  <rule id="486831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3901 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>