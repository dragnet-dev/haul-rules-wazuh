<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1376 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 44524d71-676c-5b39-b167-91e94eca8b86 -->
  <rule id="923977" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1376 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>