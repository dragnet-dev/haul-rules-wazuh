<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2169 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 38865bcf-2f29-54ea-a0cd-27736a987c2c -->
  <rule id="149628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2169 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>