<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0178 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: c4b37eea-151b-5e66-9b1f-8d2f148893d2 -->
  <rule id="592606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0178 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>