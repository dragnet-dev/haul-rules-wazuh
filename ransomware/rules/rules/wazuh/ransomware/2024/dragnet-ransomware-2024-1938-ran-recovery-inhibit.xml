<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1938 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 631aebcc-f97f-5e8e-9e62-8182c09ebb4c -->
  <rule id="887371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1938 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>