<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1858 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: d30094c8-aa07-5fcc-9bb9-1f8fb1fd437b -->
  <rule id="530094" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1858 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>