<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5381 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b8aafa9a-abd4-5e9d-83ff-31ebd44b0351 -->
  <rule id="677018" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5381 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>