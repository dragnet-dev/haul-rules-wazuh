<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0992 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: a24021a7-50e1-51e7-b299-22a080885011 -->
  <rule id="224021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0992 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>