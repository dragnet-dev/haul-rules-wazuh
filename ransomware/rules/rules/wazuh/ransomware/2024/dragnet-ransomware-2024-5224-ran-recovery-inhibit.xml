<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5224 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ddc8b7b3-2e6d-5d99-a1ca-77f2dd96ef4d -->
  <rule id="378197" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5224 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>