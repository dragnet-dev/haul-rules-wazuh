<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0712 — Event Log Clearing (datacarry) | Status: deprecated | Sigma ID: 444cd790-1e51-5cac-bbbb-0f0dfe843643 -->
  <rule id="338697" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0712 — Event Log Clearing (datacarry)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>