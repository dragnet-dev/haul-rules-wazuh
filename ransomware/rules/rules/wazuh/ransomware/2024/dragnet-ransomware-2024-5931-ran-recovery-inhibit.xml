<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5931 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5320b589-8649-58a4-90ef-fc16cbb73297 -->
  <rule id="513158" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5931 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>