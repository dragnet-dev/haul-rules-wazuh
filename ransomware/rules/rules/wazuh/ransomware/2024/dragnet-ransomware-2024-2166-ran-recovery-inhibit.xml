<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2166 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 8e4c560a-665b-5a33-93ae-7a06aa69d177 -->
  <rule id="579656" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2166 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>