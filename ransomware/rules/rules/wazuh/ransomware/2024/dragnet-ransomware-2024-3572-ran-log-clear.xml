<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3572 — Event Log Clearing (hunters) | Status: experimental | Sigma ID: 8b7b9959-c2cb-5c4c-95a7-556582c1c8b9 -->
  <rule id="536399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3572 — Event Log Clearing (hunters)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>