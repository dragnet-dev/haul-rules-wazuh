<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5556 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 873c4791-5382-57f6-acb2-def7ad7bcae5 -->
  <rule id="598047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5556 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>