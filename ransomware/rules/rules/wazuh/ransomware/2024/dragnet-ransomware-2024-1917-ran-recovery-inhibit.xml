<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1917 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: fa37a454-a475-5043-895e-89f5ea12d32c -->
  <rule id="506024" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1917 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>