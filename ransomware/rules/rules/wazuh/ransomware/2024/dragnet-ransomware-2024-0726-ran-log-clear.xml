<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0726 — Event Log Clearing (nitrogen) | Status: experimental | Sigma ID: 211cb66c-ac3b-5b61-b7d0-6502ce799fd7 -->
  <rule id="121966" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0726 — Event Log Clearing (nitrogen)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>