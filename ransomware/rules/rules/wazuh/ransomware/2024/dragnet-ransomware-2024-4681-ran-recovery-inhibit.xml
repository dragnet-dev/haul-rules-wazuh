<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4681 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 81ef35aa-7e16-5850-bb79-7634b41c56b1 -->
  <rule id="397535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4681 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>