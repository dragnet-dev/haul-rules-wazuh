<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0754 — Event Log Clearing (chort) | Status: experimental | Sigma ID: 93477916-4d0e-51f5-a82e-353b32d35057 -->
  <rule id="447791" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0754 — Event Log Clearing (chort)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>