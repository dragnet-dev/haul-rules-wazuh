<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3015 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0f9cb9aa-70ef-5522-bd4a-b640abcd83e2 -->
  <rule id="345274" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3015 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>