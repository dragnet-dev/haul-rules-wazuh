<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1117 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: cdf5a527-9d46-52dc-9576-c9bbd2ac0398 -->
  <rule id="872905" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1117 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>