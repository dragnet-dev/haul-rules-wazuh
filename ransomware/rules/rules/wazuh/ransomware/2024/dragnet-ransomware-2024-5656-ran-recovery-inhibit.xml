<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5656 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: d615017d-100e-5be6-a141-576d7dab9bdd -->
  <rule id="561501" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5656 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>