<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3467 — Recovery Inhibition (chort) | Status: experimental | Sigma ID: 70217ce0-d441-5e59-b184-4484a393ef42 -->
  <rule id="323484" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3467 — Recovery Inhibition (chort)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>