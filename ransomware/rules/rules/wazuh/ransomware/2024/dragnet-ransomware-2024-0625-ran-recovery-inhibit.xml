<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0625 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 8f309dc2-bbf2-5f6c-950c-583708ff7fb4 -->
  <rule id="592957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0625 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>