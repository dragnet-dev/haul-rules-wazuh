<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1775 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: cd4c441c-4048-58ee-ae6c-ec2a3bbcda2f -->
  <rule id="687644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1775 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>