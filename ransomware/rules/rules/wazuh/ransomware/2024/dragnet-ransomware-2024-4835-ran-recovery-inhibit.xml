<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4835 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 74ffaa52-f41b-538d-a0c9-c52abcd85a3d -->
  <rule id="515114" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4835 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>