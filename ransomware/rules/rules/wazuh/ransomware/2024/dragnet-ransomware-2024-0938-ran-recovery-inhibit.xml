<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0938 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8733fce1-0329-5161-b9a6-4cad39c1f888 -->
  <rule id="535900" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0938 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>