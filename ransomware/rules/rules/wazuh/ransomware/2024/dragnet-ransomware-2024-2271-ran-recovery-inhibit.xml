<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2271 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6b29eab2-12d9-513c-8881-678b1e0e2050 -->
  <rule id="146858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2271 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>