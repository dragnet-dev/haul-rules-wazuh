<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3719 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 8030fd51-8493-5d46-a3c3-7d0d5f64395f -->
  <rule id="355933" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3719 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>