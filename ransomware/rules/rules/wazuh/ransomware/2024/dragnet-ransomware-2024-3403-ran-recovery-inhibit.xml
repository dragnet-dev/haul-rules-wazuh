<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3403 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 91eb634a-0849-5b2a-a29c-cd08e46bea5d -->
  <rule id="653163" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3403 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>