<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1136 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: d2730018-5df7-553b-9e63-6f85cec6101c -->
  <rule id="527300" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1136 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>