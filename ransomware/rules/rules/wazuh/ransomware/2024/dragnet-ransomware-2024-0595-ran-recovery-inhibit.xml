<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0595 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 742fe8f9-66b8-50b7-a178-b8139a4789f7 -->
  <rule id="202068" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0595 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>