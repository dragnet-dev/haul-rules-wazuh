<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3596 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 905e94b8-29d9-5be8-9e77-0d9addc3cd6b -->
  <rule id="649494" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3596 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>