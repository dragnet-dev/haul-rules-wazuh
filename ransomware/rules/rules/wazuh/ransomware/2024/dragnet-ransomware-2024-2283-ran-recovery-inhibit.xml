<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2283 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: ef00a224-8473-517c-860c-05ae4fcc53bd -->
  <rule id="324102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2283 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>