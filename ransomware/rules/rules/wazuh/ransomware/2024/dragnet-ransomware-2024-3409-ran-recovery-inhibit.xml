<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3409 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5a917cbe-1bfc-5d52-8fe7-7e48a3d2b336 -->
  <rule id="654684" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3409 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>