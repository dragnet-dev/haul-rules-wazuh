<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0085 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e70835b5-c2df-556c-81ef-ba6f229f05db -->
  <rule id="670835" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0085 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>