<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3757 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 73480af7-8198-5887-95a3-859d643eafa4 -->
  <rule id="375690" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3757 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>