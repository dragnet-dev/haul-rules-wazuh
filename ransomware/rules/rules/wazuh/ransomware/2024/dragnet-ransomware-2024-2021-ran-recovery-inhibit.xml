<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2021 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a2bbceec-b402-5c39-8466-c4e1b6c2f82c -->
  <rule id="532750" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2021 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>