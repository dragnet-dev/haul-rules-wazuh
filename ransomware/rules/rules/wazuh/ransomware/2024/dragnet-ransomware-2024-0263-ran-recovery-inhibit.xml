<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0263 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: afd42f32-fffc-5d21-9a83-558f6e560e65 -->
  <rule id="101487" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0263 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>