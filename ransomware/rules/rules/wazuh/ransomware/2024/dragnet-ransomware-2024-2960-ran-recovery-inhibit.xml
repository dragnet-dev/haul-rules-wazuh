<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2960 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 981b3128-170a-5ba6-86e4-7196e51ca0e1 -->
  <rule id="770731" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2960 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>