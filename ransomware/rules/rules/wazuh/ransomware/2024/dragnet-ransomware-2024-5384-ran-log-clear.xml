<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5384 — Event Log Clearing (ElDorado) | Status: deprecated | Sigma ID: 9bffb3e6-d2ed-50c7-bf50-dca74d2f31c9 -->
  <rule id="189713" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5384 — Event Log Clearing (ElDorado)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>