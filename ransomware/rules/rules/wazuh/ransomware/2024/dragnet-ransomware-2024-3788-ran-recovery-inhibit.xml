<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3788 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ed446cc6-3192-5ad9-aaa9-ed9eb85708f8 -->
  <rule id="299148" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3788 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>