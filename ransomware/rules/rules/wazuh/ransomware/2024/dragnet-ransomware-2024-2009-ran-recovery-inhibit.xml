<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2009 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4effd7ff-3d37-598b-af5e-d09c67973991 -->
  <rule id="635817" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2009 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>