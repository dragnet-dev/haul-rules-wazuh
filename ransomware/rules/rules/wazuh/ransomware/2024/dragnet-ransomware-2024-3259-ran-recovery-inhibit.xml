<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3259 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 7b1285ff-e590-518f-aa76-53c30643f503 -->
  <rule id="431285" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3259 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>