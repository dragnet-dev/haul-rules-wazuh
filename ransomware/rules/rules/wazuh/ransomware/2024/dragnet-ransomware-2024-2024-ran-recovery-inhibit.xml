<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2024 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 131ca4a4-a94d-565a-ad91-582b35b23d12 -->
  <rule id="998154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2024 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>