<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0654 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 2ec1b589-d61b-5e03-a958-429a6896302f -->
  <rule id="397075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0654 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>