<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1475 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6bab30d2-03aa-508f-b89b-f4d35d929e87 -->
  <rule id="156330" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1475 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>