<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2464 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 73688f24-42f0-5ba3-9fa8-c533ccc83b82 -->
  <rule id="379023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2464 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>