<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1720 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 87b23f44-49db-53f7-8a4e-3152c94c3b17 -->
  <rule id="545183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1720 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>