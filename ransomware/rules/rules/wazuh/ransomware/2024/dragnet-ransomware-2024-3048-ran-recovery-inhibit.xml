<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3048 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4c785f29-8617-5646-8648-ea2f4df9d8bc -->
  <rule id="428575" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3048 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>