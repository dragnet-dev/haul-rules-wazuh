<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4224 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: af8396fb-27ed-5487-919f-c8cca36d0135 -->
  <rule id="958396" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4224 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>