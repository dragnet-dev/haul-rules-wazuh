<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5251 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 29cd7f21-4bda-598c-87ff-2b2d3c517a0a -->
  <rule id="420767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5251 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>