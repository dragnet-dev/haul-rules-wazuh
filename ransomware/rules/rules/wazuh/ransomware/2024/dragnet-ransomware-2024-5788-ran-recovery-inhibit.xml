<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5788 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 0193cc8e-03ab-58e6-8c8a-5fa8edb98b64 -->
  <rule id="838062" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5788 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>