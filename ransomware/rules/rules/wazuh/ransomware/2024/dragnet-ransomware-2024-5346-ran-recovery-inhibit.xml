<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5346 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: d8e0be07-3517-5d64-b153-1e294bca44c8 -->
  <rule id="388510" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5346 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>