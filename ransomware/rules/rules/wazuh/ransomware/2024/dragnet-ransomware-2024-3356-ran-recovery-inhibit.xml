<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3356 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 77b5af7f-3c48-5ac5-99b9-de44601d5e2e -->
  <rule id="583535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3356 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>