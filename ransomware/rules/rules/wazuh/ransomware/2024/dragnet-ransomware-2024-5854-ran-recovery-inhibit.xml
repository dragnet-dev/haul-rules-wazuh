<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5854 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 568840a3-40d0-5ec2-b51f-f17350d72ab1 -->
  <rule id="201450" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5854 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>