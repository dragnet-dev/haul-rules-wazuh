<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0537 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 01bc84c2-46e2-5cdb-af1b-7a12185b682a -->
  <rule id="917562" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0537 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>