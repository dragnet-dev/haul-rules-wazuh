<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3956 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 463e84aa-c814-522c-8d6c-2ac77b6b8c02 -->
  <rule id="276554" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3956 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>