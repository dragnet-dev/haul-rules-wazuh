<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0136 — Recovery Inhibition (play) | Status: experimental | Sigma ID: dc50cdfb-c98d-55ff-9a6f-396846caa85b -->
  <rule id="345005" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0136 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>