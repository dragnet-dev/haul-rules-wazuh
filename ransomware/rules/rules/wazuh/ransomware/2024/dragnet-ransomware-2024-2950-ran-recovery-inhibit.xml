<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2950 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 68fe8f8a-03d3-5c48-b2a9-adcfc01bca1d -->
  <rule id="226063" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2950 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>