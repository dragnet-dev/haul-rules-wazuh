<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3609 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 98623d79-05dd-5f2f-a8d8-c16b70f9842e -->
  <rule id="777981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3609 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>