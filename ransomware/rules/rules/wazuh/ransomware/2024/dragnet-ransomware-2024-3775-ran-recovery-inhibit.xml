<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3775 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: a286278b-5145-5098-88a9-d75f5d8dd46c -->
  <rule id="228627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3775 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>