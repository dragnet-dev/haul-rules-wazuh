<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1252 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: b772f706-ff5c-5f06-abce-08d213449e3d -->
  <rule id="183677" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1252 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
