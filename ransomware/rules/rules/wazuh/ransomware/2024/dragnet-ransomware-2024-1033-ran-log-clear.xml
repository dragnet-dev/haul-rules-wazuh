<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1033 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: 04d862a5-93f5-58b7-b14f-d5ec3b9bdd30 -->
  <rule id="445802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1033 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>