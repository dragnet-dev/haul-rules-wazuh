<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0185 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6d46084c-29ae-5f41-8045-6a7b6e179d9d -->
  <rule id="294608" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0185 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>