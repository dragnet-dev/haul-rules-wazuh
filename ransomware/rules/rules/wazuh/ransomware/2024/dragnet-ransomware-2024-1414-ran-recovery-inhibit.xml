<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1414 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 168853f8-317d-5665-b15b-56d1f5579a41 -->
  <rule id="101663" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1414 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>