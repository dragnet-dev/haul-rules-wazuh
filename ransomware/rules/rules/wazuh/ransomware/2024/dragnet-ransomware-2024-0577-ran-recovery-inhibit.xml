<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0577 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8f876626-af6b-5826-a6db-5fd1a0ad6293 -->
  <rule id="638766" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0577 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>