<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0330 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: ce5372ae-78f5-59a9-97d1-f664c3220304 -->
  <rule id="365372" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0330 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>