<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2688 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 596563d8-5a23-51d2-bd05-ceb3b727ff4b -->
  <rule id="645021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2688 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>