<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4817 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 1cc78382-d70d-5c5b-b517-aee0c39e581c -->
  <rule id="207838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4817 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>