<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5942 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: fdbeada3-eebc-5d8f-a560-5a8d87e09bcf -->
  <rule id="239338" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5942 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>