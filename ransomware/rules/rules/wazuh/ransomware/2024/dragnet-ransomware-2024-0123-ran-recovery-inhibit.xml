<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0123 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: cbb31be9-535f-5f35-b916-d514aa1a8cf7 -->
  <rule id="814907" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0123 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>