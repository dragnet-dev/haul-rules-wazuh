<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2078 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 5d70bcff-7e4e-53a0-a78a-eca2457c3620 -->
  <rule id="698908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2078 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>