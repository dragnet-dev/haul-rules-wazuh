<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2546 — Event Log Clearing (qilin) | Status: deprecated | Sigma ID: e6df86f5-7ed0-5b7f-8e3c-51dfd7d0955e -->
  <rule id="259986" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2546 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>