<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2802 — Event Log Clearing (blackout) | Status: experimental | Sigma ID: b32dbcaf-ee86-57f7-9c46-9b211038f7e0 -->
  <rule id="240188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2802 — Event Log Clearing (blackout)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>