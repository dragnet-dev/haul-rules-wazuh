<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0741 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 280a7e35-437e-5161-bb2e-11c6a1f39157 -->
  <rule id="985263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0741 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>