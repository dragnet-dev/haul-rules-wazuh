<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0240 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 5f4f0b31-ba3b-5c11-9654-ad83d7e5ee78 -->
  <rule id="744651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0240 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>