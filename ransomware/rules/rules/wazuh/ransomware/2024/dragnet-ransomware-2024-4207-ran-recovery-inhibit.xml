<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4207 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 9d42242b-9b19-51ed-bd6c-54dd4fe57c8b -->
  <rule id="774224" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4207 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>