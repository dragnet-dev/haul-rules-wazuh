<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5475 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 069308e0-b798-5155-badd-41435fea95dd -->
  <rule id="308942" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5475 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>