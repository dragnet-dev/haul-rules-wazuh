<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3302 — Recovery Inhibition (embargo) | Status: experimental | Sigma ID: c040d3de-f640-5d0b-afff-169225d19f46 -->
  <rule id="226533" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3302 — Recovery Inhibition (embargo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>