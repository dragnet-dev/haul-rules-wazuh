<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5837 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 0392a4e0-2119-5056-846b-f871a2e0a195 -->
  <rule id="205198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5837 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>