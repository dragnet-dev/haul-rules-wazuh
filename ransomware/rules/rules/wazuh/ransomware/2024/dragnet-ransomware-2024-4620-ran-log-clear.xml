<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4620 — Event Log Clearing (arcusmedia) | Status: experimental | Sigma ID: 25d462bf-8e1b-5a14-9d62-954b7f2b1c97 -->
  <rule id="415403" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4620 — Event Log Clearing (arcusmedia)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>