<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0051 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: ad63a7be-63bd-5c21-969f-1a9471411fac -->
  <rule id="178187" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0051 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>