<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2574 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: c8295954-5a6e-5cda-8d47-84b8927b85d7 -->
  <rule id="482959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2574 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>