<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1831 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 3ff7ee4f-3a39-546a-9db5-1bc875914ea2 -->
  <rule id="920910" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1831 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>