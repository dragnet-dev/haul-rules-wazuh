<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2942 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 72e67595-a4ab-526f-8d17-a7726bad0dd4 -->
  <rule id="366675" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2942 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>