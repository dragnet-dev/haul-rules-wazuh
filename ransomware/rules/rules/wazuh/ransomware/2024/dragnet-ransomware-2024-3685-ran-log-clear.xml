<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3685 — Event Log Clearing (dAn0n) | Status: deprecated | Sigma ID: afb968b0-660e-5ad1-a9f7-06c3e5a53c99 -->
  <rule id="211968" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3685 — Event Log Clearing (dAn0n)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>