<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2958 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 05dd02c0-836f-59e5-a1e1-4e52947d310c -->
  <rule id="701644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2958 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>