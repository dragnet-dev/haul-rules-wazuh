<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4419 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: fef866d3-1e50-5b8d-bf61-f919b10d4056 -->
  <rule id="579866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4419 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>