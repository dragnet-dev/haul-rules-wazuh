<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0680 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a660d2df-8cf0-5a17-8c4e-6a2872b4d1f3 -->
  <rule id="905732" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0680 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>