<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2208 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 3a14349f-4468-5663-875f-827e25ac57b0 -->
  <rule id="514349" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2208 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
