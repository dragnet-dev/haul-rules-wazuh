<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1816 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 809a15c3-90d8-5aba-bf64-a3814baa240b -->
  <rule id="495415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1816 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>