<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2015 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: b9bd1cda-8fa5-5e0d-9151-f71bf34bb458 -->
  <rule id="504508" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2015 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>