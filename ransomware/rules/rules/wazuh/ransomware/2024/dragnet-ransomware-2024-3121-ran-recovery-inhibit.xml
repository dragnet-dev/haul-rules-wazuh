<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3121 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 6774714d-6cf0-579f-8ae4-ff433239b2bb -->
  <rule id="574714" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3121 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>