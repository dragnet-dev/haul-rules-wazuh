<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0329 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f6fadc95-617b-5179-81d4-2d3fea05fadf -->
  <rule id="487836" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0329 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>