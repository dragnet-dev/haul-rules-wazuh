<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3321 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 0b8641a8-808a-5e87-973f-9b0c31ec4f3e -->
  <rule id="198266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3321 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>