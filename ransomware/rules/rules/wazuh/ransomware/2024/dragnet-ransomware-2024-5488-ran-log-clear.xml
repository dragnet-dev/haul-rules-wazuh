<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5488 — Event Log Clearing (donutleaks) | Status: experimental | Sigma ID: 7a0cd7b7-785e-5ad3-9850-9c5d0e60b652 -->
  <rule id="525257" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5488 — Event Log Clearing (donutleaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>