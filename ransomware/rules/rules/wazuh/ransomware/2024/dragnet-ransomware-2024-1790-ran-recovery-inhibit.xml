<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1790 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: ff507942-147b-58a4-a672-14ee47aec070 -->
  <rule id="855079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1790 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>