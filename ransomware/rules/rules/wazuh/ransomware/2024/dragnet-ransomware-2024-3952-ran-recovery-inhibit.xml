<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3952 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1660de79-1668-5d21-bcfe-a587ac646cad -->
  <rule id="751827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3952 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>