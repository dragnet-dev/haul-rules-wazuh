<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3135 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b9f5e4b0-7dca-594f-991f-425245e8d964 -->
  <rule id="471344" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3135 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>