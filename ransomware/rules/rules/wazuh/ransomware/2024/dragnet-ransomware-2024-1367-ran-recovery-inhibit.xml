<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1367 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: bb0ac967-ab55-5c18-8779-b3a65c0d69bd -->
  <rule id="388929" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1367 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
