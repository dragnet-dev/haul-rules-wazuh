<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5201 — Recovery Inhibition (dAn0n) | Status: experimental | Sigma ID: 61ae8cb2-b459-58e3-9662-d48f1cdd477f -->
  <rule id="826540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5201 — Recovery Inhibition (dAn0n)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>