<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2931 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 835040a7-dab9-5688-8576-94a8a8218282 -->
  <rule id="860650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2931 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>