<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4743 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 176a2806-c836-5b3d-8f9a-3036b3bc71a8 -->
  <rule id="226280" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4743 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>