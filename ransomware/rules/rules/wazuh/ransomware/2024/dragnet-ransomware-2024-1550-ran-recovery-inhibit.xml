<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1550 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 21004c73-8cb7-53c7-a1cd-945d434cd219 -->
  <rule id="760767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1550 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>