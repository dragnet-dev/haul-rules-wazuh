<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2994 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 733fe223-876c-55a9-b60d-98d0ba83e88c -->
  <rule id="179022" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2994 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>