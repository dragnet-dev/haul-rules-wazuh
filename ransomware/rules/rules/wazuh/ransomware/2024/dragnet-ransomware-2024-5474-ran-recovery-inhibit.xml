<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5474 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 60281469-3b65-51c7-a133-6594075f36e2 -->
  <rule id="728146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5474 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>