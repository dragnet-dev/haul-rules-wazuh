<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0219 — Event Log Clearing (ElDorado) | Status: deprecated | Sigma ID: 8e3441f8-6cd5-556a-930c-d9a0c2baa12a -->
  <rule id="623441" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0219 — Event Log Clearing (ElDorado)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>