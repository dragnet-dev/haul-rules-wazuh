<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1827 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 9cca1b4a-ad5c-5bfc-8e44-80971ae3b5f4 -->
  <rule id="222107" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1827 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>