<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4156 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 318cf110-da50-5f54-a732-e2da7868c646 -->
  <rule id="161511" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4156 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>