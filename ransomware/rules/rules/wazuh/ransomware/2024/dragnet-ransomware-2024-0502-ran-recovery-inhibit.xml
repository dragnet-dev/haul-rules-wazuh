<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0502 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: c9e377cf-2b12-5b50-9ef2-55874ee96de2 -->
  <rule id="378377" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0502 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>