<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4680 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 36789597-7ec3-534b-b1a8-6eb2f79f4d28 -->
  <rule id="178959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4680 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>