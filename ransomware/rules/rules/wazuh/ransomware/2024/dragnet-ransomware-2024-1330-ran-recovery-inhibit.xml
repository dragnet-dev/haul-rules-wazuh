<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1330 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 4f9d8066-9e82-5968-b312-9a7284831ded -->
  <rule id="479780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1330 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>