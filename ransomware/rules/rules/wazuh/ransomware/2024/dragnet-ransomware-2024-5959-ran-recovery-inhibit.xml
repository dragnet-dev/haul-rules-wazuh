<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5959 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 46df677b-fc40-513b-afcc-2bfa4d63bec3 -->
  <rule id="399967" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5959 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>