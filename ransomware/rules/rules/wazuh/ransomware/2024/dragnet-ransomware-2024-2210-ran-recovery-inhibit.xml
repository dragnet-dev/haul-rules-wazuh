<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2210 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 9019bab5-ef14-5240-a4c7-0ed4d658d69e -->
  <rule id="609050" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2210 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>