<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2875 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 1028c5fb-70be-56fb-a907-1f230f374143 -->
  <rule id="933695" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2875 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>