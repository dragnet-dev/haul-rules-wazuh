<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0611 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: fc0a2b6a-4650-5a48-8d43-9bbccfc7fd06 -->
  <rule id="252843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0611 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>