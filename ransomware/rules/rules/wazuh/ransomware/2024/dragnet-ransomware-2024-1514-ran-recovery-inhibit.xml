<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1514 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a645de4d-a879-5c04-aacd-957a3597cf7d -->
  <rule id="125342" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1514 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>