<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1128 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f39899f1-aa8a-5b0c-a081-6f6751d2ae00 -->
  <rule id="739899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1128 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>