<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2900 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: c933487e-02e4-57ea-a599-b2e4478f2dd7 -->
  <rule id="493348" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2900 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>