<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4570 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 02be8d21-cdc9-5bc8-9c43-31c73dbe6750 -->
  <rule id="324612" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4570 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>