<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0662 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: da0aa05c-57f5-553f-a2d1-caeec29864fc -->
  <rule id="282500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0662 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>