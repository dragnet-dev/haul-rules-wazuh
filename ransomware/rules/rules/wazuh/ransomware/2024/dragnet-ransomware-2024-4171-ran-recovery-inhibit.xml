<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4171 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: f6f202c3-0064-51f5-863b-bdbc1d7bc036 -->
  <rule id="811202" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4171 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>