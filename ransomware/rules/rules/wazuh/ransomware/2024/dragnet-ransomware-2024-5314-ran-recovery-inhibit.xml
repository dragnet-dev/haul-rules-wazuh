<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5314 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 5d2aff63-317f-5212-a2fe-8a2aed1a2a63 -->
  <rule id="320287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5314 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>