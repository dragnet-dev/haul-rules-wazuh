<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2195 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7be4d575-153f-52ef-a921-6e3c67b51109 -->
  <rule id="571975" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2195 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>