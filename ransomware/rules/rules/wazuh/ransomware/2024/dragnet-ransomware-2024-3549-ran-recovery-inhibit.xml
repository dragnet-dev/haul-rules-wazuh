<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3549 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 00627833-6923-520b-9369-c19a1409263c -->
  <rule id="978336" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3549 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>