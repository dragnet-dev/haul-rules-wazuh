<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0635 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 50ca46bd-9b51-58ef-8f90-175120d3e3a7 -->
  <rule id="500246" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0635 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>