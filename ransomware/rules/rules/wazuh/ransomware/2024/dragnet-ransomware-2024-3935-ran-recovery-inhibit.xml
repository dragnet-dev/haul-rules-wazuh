<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3935 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ce090453-1ee2-5e51-9f5e-d818d0efae2b -->
  <rule id="360904" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3935 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>