<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4787 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: cc2d1e9a-32a5-5a95-889e-160786ad9eff -->
  <rule id="829630" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4787 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>