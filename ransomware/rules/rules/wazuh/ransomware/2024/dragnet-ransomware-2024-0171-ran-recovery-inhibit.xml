<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0171 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0580b728-f5a3-5417-83a0-fe062ac25b06 -->
  <rule id="391728" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0171 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>