<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2197 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: e3c56d5c-6426-51ea-b427-afe2d7337b93 -->
  <rule id="180909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2197 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>