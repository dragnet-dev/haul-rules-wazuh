<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4798 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 60049631-7d9c-5702-a07d-3346978ecd93 -->
  <rule id="704963" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4798 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>