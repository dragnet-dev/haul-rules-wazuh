<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3269 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 94c0fd35-3562-5653-abc8-f3beff349702 -->
  <rule id="381213" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3269 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>