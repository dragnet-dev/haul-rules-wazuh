<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4657 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3f498276-7496-5f75-8825-90367cc2a017 -->
  <rule id="149827" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4657 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>