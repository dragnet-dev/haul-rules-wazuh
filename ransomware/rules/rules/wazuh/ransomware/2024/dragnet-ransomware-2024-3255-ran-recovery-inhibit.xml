<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3255 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 5460d443-6dca-5b41-af57-89b129c41892 -->
  <rule id="737344" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3255 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>