<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0512 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: c4f1f01d-cd83-59c6-9aa0-ce10823541ee -->
  <rule id="598710" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0512 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>