<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2512 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: edccec5b-bb90-5d18-8b41-b4576787e392 -->
  <rule id="384492" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2512 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>