<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5668 — Event Log Clearing (embargo) | Status: experimental | Sigma ID: ea565890-67c7-50a9-a7a4-e6257f298329 -->
  <rule id="645658" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5668 — Event Log Clearing (embargo)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>