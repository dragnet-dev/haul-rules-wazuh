<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5736 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: dc709c2f-5c50-5ef0-ab93-df4919dcd519 -->
  <rule id="931356" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5736 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>