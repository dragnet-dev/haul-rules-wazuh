<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3038 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: 6b91a750-7c0a-5cf6-9014-6ee8b26a9a00 -->
  <rule id="926667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3038 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>