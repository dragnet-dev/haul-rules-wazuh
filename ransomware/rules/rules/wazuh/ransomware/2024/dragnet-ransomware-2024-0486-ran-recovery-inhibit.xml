<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0486 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 32bf62d7-03fa-5eb7-a46d-7b9c52779948 -->
  <rule id="913805" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0486 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>