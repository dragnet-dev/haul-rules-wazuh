<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1490 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 51404fec-8b40-5abb-9c59-bb1be9e76095 -->
  <rule id="659678" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1490 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
