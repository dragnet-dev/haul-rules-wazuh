<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0919 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: da8252bd-d973-5f4c-a9cb-3de1a0ae484a -->
  <rule id="488252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0919 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>