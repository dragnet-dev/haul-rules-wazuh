<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2062 — Recovery Inhibition (apos) | Status: experimental | Sigma ID: 957fa34e-6159-5d8c-825c-6516d2ff0f93 -->
  <rule id="752423" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2062 — Recovery Inhibition (apos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>