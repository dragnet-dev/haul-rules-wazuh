<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0849 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6f8204fb-31c5-5b9a-b73b-257d050fd5c2 -->
  <rule id="318204" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0849 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>