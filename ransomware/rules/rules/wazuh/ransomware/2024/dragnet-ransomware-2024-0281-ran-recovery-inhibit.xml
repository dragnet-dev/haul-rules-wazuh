<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0281 — Recovery Inhibition (unsafe) | Status: deprecated | Sigma ID: ded82ce2-185d-58e4-8899-2bd43191eefb -->
  <rule id="405324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0281 — Recovery Inhibition (unsafe)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>