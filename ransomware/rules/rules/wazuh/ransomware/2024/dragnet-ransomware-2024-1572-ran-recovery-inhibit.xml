<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1572 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3d1b5395-f4d5-526c-b29c-f6829b075bb5 -->
  <rule id="887539" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1572 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>