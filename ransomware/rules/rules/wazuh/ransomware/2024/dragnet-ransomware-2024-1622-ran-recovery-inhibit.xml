<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1622 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: a5a50695-72d5-54ca-b8ad-5296e48684de -->
  <rule id="890506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1622 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>