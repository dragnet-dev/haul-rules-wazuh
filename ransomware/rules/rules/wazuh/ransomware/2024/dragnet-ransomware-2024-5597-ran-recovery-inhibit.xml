<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5597 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: 4e9c7d68-d523-5964-a9ab-427c244601aa -->
  <rule id="321885" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5597 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>