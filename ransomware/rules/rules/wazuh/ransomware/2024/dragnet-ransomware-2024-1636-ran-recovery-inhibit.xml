<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1636 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 7cad94e4-eac2-5aa1-b988-66f6baaa4a50 -->
  <rule id="591794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1636 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>