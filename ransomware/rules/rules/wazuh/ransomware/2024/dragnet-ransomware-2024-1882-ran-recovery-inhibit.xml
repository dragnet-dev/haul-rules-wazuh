<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1882 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 76ec1e07-ff75-5f3d-b313-c9cabef97c15 -->
  <rule id="550750" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1882 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>