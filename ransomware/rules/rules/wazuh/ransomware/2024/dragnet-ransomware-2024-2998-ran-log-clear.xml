<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2998 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 9eeec7de-163e-584f-9f40-8f2c1d666b0e -->
  <rule id="309887" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2998 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>