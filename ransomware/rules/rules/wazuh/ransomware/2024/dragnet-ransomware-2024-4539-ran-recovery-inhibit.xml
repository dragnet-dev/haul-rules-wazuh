<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4539 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 36bdb85e-0357-5a81-987a-bbbfd2bae6a4 -->
  <rule id="704918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4539 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>