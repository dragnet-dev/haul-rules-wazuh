<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3715 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 9ac23652-c204-525a-9b94-fd02db115f9e -->
  <rule id="776236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3715 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>