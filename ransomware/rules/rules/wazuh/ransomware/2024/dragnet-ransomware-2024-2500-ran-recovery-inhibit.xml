<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2500 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: bc30f08e-d5ce-5143-848d-278a57fd84d1 -->
  <rule id="412950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2500 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>