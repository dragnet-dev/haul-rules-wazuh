<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4527 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: f7f359d9-4306-5bf1-b341-a206c5ab08f4 -->
  <rule id="827359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4527 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>