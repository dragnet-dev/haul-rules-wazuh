<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5605 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: bafaff30-ad7b-5573-89f2-2528b25f4de4 -->
  <rule id="653951" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5605 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>