<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5710 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 82f49416-2abd-5940-a40e-bc3a48ba06bb -->
  <rule id="527494" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5710 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>