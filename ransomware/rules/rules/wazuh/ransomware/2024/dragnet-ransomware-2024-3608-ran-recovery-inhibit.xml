  <rule id="665459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3608 — Recovery Inhibition (redransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
