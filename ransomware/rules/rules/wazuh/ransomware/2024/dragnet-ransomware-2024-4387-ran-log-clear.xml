<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4387 — Event Log Clearing (ransomcortex) | Status: experimental | Sigma ID: 1f90094b-852f-5479-a980-d521a3b577f8 -->
  <rule id="590094" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4387 — Event Log Clearing (ransomcortex)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>