<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5745 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 1a53d3ba-3b29-5076-9686-fc3d3adc9f2f -->
  <rule id="593819" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5745 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>