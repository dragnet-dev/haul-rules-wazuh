<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1915 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: 81d11a93-f7fe-54ee-92ea-a9639e342539 -->
  <rule id="394586" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1915 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>