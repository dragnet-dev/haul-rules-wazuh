<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4240 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2e652b15-ee5f-599e-a83a-828c24f3795d -->
  <rule id="364431" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4240 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>