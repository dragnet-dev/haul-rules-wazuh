<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3544 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: a63652b1-bf9c-58a0-9d91-97d55d4d120d -->
  <rule id="263652" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3544 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>