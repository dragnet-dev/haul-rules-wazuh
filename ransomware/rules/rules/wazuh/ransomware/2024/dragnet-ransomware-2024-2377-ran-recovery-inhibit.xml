<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2377 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3ec6c5bb-c364-5581-83a6-4880fbb57e5e -->
  <rule id="807485" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2377 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>