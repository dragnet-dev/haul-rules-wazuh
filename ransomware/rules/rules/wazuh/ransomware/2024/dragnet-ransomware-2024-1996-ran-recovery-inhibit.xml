<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1996 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: f13a8046-748b-5735-a990-37702fda3b4a -->
  <rule id="721880" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1996 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>