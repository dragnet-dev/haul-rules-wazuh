<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4199 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 56164941-6341-529e-bef9-7c622cd056e9 -->
  <rule id="316494" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4199 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>