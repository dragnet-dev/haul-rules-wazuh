<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1388 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d7a5aee6-e092-55e8-a1c7-482e0ac9d30f -->
  <rule id="338574" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1388 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
