<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3070 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 4d2acb42-868a-5c05-be18-ac4248cd7589 -->
  <rule id="564875" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3070 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>