<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2878 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: df037911-5dbe-5f5a-aa5e-75b68e190e52 -->
  <rule id="530379" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2878 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>