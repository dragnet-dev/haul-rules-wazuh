<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1613 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: c7cee5d1-812d-5f4d-9258-7c0fa2c9b480 -->
  <rule id="835025" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1613 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>