<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0202 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ae665417-803b-5c13-8210-d6b264a50cf9 -->
  <rule id="946654" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0202 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>