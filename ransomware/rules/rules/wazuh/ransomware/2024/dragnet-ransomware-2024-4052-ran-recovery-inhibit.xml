<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4052 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 896707ec-37ba-5c04-88ce-cfbc6238065f -->
  <rule id="947326" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4052 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>