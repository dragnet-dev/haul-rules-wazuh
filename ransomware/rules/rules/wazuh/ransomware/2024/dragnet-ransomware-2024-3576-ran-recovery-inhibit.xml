<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3576 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 28959efc-10a0-5186-be19-98cc0c1ba4a9 -->
  <rule id="313743" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3576 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>