<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3297 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: c4ac06dc-681f-5757-ae3e-41b2fd6bc73f -->
  <rule id="591606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3297 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>