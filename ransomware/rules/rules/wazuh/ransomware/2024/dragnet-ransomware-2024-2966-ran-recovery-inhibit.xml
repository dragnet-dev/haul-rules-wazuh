<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2966 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: a8c7d3ea-9978-54e5-84ef-d6c662f61d3c -->
  <rule id="185253" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2966 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>