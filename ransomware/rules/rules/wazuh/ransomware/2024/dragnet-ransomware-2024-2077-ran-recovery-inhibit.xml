<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2077 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 8c277b43-4a2a-5b60-9afc-c582e91bd80c -->
  <rule id="544443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2077 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>