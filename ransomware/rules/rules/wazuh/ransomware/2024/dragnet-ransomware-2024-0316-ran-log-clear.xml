<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0316 — Event Log Clearing (blacklock) | Status: experimental | Sigma ID: 52a2e144-e7f6-5b1a-a980-5190fd5a8d3e -->
  <rule id="547661" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0316 — Event Log Clearing (blacklock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>