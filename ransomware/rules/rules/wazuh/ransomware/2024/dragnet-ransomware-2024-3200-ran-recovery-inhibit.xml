<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3200 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 46e37ef5-150a-50f4-9637-7094b937a00f -->
  <rule id="400606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3200 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>