<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4663 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 2758406e-a1aa-5685-9d52-b799b190518e -->
  <rule id="158406" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4663 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>