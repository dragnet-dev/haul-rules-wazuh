<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3350 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 9271cb49-96c0-5a69-aeca-b2215a6ea6a2 -->
  <rule id="673579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3350 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>