<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1669 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: c54d40b2-249b-530e-873e-4a07a0c6de0d -->
  <rule id="307740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1669 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>