<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2651 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: aba6544b-560a-5e70-a253-a6489d4bacf6 -->
  <rule id="146654" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2651 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>