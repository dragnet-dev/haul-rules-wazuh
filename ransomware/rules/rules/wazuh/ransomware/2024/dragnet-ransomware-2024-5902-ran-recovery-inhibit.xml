<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5902 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4750ef06-4447-59b0-999e-1fc3fb34f86c -->
  <rule id="416239" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5902 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>