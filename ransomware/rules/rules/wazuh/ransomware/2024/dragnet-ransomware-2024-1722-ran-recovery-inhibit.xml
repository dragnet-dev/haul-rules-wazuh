<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1722 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8f2984a8-fbb8-5cff-a98f-285614b1f764 -->
  <rule id="632984" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1722 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>