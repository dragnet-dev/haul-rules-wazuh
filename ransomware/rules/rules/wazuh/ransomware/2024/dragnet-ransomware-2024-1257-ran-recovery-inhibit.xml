<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1257 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ae80db1f-d470-56db-8b50-860418e4ecff -->
  <rule id="975099" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1257 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>