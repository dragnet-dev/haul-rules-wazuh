<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1444 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 11866dd6-aed5-5945-859d-c613e14e3937 -->
  <rule id="437917" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1444 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>