<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1366 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 08a527d5-081f-5e6b-9af0-b3ec36c121cd -->
  <rule id="516445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1366 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>