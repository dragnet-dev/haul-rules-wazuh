<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4779 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a80b23aa-9914-59cb-b6a0-b6560389d735 -->
  <rule id="929123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4779 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>