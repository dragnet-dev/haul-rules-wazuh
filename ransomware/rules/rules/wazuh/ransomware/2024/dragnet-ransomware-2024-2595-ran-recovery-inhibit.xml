<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2595 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d9f57706-536a-5525-8093-9946adb8a888 -->
  <rule id="539577" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2595 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>