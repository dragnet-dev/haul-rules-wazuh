<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2045 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: d7164308-cc47-5d58-81fb-ec2091024726 -->
  <rule id="571643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2045 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>