<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2837 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 9e74c8f7-6cd9-534d-a6dd-11404deca571 -->
  <rule id="839968" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2837 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>