<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0324 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 54e9520f-86ed-5028-9a08-2a4606619d1d -->
  <rule id="789520" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0324 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>