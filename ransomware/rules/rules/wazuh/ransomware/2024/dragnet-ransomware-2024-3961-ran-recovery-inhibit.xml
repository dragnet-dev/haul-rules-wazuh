<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3961 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: 8b69e900-7202-5552-9e67-5a9efd34d48e -->
  <rule id="535189" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3961 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>