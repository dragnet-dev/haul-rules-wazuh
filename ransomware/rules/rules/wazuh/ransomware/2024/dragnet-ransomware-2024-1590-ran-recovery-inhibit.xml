<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1590 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: c29664b2-8fd0-5f29-a909-b692771f38d2 -->
  <rule id="429664" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1590 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>