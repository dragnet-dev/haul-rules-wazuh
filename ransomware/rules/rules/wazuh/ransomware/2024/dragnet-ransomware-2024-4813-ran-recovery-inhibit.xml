<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4813 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: c988e087-7bdc-544a-b130-ba9ffba95c05 -->
  <rule id="378220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4813 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>