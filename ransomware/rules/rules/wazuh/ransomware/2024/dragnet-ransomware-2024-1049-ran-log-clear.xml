<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1049 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: 1a73fb88-7f7d-5d65-8bf9-a7e3e9eda142 -->
  <rule id="645398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1049 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>