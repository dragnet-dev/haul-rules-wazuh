<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0493 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: deec838f-180c-51f9-bac1-6cc08fe87364 -->
  <rule id="406883" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0493 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>