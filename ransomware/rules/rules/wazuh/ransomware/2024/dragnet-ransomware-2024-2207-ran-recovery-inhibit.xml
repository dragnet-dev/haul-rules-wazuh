<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2207 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 3881e574-742f-55d0-b3b4-2f68fcb5ffcf -->
  <rule id="911057" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2207 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>