<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2767 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5b833a01-3377-5e77-9714-661bdda50ea8 -->
  <rule id="669338" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2767 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>