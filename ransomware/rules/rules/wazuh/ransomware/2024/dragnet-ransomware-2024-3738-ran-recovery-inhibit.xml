<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3738 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: cf6033e6-25b1-5581-bacf-721f6e3dea54 -->
  <rule id="376033" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3738 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>