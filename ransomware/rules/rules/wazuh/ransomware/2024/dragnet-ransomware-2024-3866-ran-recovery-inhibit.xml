<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3866 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: fdf16c0a-1e3e-52d3-9353-6439fdeb062b -->
  <rule id="301068" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3866 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>