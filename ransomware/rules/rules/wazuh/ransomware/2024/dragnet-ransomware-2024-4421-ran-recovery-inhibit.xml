<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4421 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 2b70541d-1613-5975-84ed-eb2bed27dd39 -->
  <rule id="870541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4421 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>