<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4533 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1c2d35ca-15d4-5969-822f-39c83bf9a47e -->
  <rule id="140572" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4533 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>