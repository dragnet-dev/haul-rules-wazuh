<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0488 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 9ac22d08-a707-50cf-86ba-8fc1984f3665 -->
  <rule id="461965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0488 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>