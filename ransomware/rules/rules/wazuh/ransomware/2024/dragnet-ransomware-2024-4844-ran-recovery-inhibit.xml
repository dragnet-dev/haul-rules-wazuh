<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4844 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2ab19d0b-f5db-575f-a229-6d3de8ad920b -->
  <rule id="293117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4844 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>