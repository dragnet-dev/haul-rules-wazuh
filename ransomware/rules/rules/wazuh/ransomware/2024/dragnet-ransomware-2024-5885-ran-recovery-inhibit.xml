<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5885 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e53d9056-65e5-5716-b803-3e9eb4abaf5b -->
  <rule id="626190" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5885 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>