<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3240 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 82978b14-2cb2-5028-a689-b73289f7d0f6 -->
  <rule id="527659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3240 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>