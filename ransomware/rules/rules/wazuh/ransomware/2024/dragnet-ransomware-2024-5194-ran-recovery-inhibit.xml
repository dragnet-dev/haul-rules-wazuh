<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5194 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 739e1553-ff20-5535-b21d-23df532ec0e5 -->
  <rule id="383815" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5194 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>