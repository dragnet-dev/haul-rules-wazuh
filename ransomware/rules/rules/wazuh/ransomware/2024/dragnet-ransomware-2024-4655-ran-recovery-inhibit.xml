<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4655 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 790e66b8-c7bb-595d-9e0b-78802f3f13fa -->
  <rule id="465466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4655 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>