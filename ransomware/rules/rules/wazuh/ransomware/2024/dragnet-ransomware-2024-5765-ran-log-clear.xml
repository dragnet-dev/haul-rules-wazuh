<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5765 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 5db2aa5e-0e22-5de7-bec0-0f2cfc15a842 -->
  <rule id="338122" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5765 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>