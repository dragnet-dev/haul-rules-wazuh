<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0545 — Event Log Clearing (safepay) | Status: deprecated | Sigma ID: bf0a7fde-2a96-5768-a3a8-f3f312a36bc5 -->
  <rule id="491327" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0545 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>