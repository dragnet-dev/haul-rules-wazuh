<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4514 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2acc82dd-170e-54f6-8e27-3480b3169104 -->
  <rule id="295682" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4514 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>