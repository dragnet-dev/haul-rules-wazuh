<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0478 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: ac47499f-1d4f-51c2-85d2-35ff2c660213 -->
  <rule id="924749" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0478 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>