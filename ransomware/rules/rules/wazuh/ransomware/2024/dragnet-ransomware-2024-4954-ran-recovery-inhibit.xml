<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4954 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1adce561-ad40-53b6-bfa4-ece9edf5e076 -->
  <rule id="300305" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4954 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>