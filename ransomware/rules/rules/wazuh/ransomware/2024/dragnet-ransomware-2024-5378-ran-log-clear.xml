<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5378 — Event Log Clearing (ElDorado) | Status: deprecated | Sigma ID: 1c7a17ba-0cc8-5944-8064-1ad5904cd84d -->
  <rule id="263483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5378 — Event Log Clearing (ElDorado)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>