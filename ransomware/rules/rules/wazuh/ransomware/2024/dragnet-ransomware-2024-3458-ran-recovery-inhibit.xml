<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3458 — Recovery Inhibition (madliberator) | Status: experimental | Sigma ID: 45a927b8-ef01-5ab3-aa6e-e4aeba3e9edf -->
  <rule id="994843" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3458 — Recovery Inhibition (madliberator)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>