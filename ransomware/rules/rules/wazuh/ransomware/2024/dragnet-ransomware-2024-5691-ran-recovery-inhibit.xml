<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5691 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: bd6c98d8-2a7e-5458-8466-e928fee133e8 -->
  <rule id="434898" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5691 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>