<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0731 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e82f79da-247d-545d-9d58-ae34906c6fd6 -->
  <rule id="672779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0731 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>