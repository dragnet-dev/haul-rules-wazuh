<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1939 — Event Log Clearing (safepay) | Status: deprecated | Sigma ID: 8fe5873f-ece4-5b1e-b8e1-2f97b5e219d1 -->
  <rule id="602587" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1939 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>