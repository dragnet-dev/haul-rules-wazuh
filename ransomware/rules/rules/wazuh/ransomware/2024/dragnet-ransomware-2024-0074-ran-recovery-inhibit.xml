<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0074 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: a3be8eb6-21c2-515f-a199-5061013a3b5e -->
  <rule id="749422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0074 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>