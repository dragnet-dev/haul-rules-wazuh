<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5347 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: e2a1d312-e2ba-5d61-95ab-13b27cc7d22b -->
  <rule id="151493" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5347 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>