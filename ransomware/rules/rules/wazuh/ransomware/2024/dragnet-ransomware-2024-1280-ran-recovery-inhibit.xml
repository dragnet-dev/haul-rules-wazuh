<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1280 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: dab874a2-fc0b-5ecf-af70-b34406b3a060 -->
  <rule id="899874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1280 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>