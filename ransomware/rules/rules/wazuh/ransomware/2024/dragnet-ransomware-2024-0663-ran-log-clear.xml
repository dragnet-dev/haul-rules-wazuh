<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0663 — Event Log Clearing (dragonransomware) | Status: experimental | Sigma ID: bc3f8fae-1e3b-53ed-9e96-85671d16b0a8 -->
  <rule id="423023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0663 — Event Log Clearing (dragonransomware)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>