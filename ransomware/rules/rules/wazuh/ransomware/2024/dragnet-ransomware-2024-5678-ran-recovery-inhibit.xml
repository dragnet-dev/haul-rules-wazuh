<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5678 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: ad2a6699-280f-5986-aeea-9718998eb959 -->
  <rule id="172266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5678 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>