<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5311 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d7f34813-949c-56d0-95cc-375e050743ec -->
  <rule id="507348" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5311 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>