<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0597 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 6ef55cd2-5b20-5b11-9f8b-f2f91a8f32a7 -->
  <rule id="240892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0597 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>