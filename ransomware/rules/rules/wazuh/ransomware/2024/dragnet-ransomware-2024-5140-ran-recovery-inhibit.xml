<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5140 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 14ebd8c3-4a10-5450-b0e3-12096d7dd029 -->
  <rule id="878860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5140 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>