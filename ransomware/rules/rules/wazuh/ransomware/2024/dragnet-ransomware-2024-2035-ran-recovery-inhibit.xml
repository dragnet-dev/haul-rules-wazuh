<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2035 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: a12af6f2-fd63-5b33-b2e8-2574544225f4 -->
  <rule id="892476" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2035 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>