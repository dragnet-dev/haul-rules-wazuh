<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1316 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e54b26c3-e094-5d88-ba4b-2858b41a3611 -->
  <rule id="627526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1316 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>