<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1332 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: eea3690c-5304-5e9c-8c38-d2a6e85424d1 -->
  <rule id="318369" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1332 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>