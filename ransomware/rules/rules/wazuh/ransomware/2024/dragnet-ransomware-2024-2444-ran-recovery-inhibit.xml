<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2444 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: f026a308-7879-595c-b67e-be28cf5ae559 -->
  <rule id="704263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2444 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>