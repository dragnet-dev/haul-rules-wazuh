<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3474 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 46a60cda-b71f-5261-aef3-8807d74ca032 -->
  <rule id="394572" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3474 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>