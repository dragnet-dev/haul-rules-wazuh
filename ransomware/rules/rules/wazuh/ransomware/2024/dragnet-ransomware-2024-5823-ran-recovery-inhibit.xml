<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5823 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 507e5621-faa6-5037-a475-03c0138da096 -->
  <rule id="126562" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5823 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>