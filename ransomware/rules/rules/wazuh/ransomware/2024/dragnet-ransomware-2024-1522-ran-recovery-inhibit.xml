<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1522 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: a9579674-dc51-5383-b609-2509ffa1315d -->
  <rule id="295796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1522 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>