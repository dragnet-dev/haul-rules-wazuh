<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2322 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 271a89a2-ea6e-537b-b186-f2a5f3f92823 -->
  <rule id="755034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2322 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>