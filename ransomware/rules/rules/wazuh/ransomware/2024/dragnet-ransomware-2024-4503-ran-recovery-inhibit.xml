<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4503 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: bbf6dbd7-17f4-5e75-8d7e-4e08168eca54 -->
  <rule id="599675" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4503 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>