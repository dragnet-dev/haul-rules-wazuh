<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3530 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3adddc7d-5f6d-5dd8-bcc9-c4efb79eaf45 -->
  <rule id="357884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3530 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>