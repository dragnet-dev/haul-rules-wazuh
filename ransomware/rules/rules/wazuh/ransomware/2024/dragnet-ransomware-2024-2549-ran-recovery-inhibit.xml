<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2549 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: babd842c-02bb-5693-841a-81aed9f71781 -->
  <rule id="380584" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2549 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>