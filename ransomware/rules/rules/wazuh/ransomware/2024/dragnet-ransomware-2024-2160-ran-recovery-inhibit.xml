<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2160 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b0211fcd-303b-5ddd-a75c-4b456adad185 -->
  <rule id="963391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2160 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>