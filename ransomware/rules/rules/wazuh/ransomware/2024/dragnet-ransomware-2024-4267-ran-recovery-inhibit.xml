<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4267 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 50a062fd-5578-50cb-b7e1-a288b61534d7 -->
  <rule id="461007" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4267 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>