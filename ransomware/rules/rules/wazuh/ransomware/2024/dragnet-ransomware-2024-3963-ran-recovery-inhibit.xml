<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3963 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 7ce5fef7-4eed-5869-91b3-946da5bdb188 -->
  <rule id="716414" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3963 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>