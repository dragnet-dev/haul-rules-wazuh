<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5175 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 7bbb089e-635b-5dbe-82ca-50737c3b23b9 -->
  <rule id="567508" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5175 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>