<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4215 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 68b9743e-2d7c-5ceb-974c-0f765aeda810 -->
  <rule id="299974" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4215 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>