<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4901 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 65ba81d9-f42a-5b2c-ad34-39a95a08a4dd -->
  <rule id="882681" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4901 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>