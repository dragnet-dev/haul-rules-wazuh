<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0366 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: abe5e65c-2fa5-562b-8d79-bb08f67ccebf -->
  <rule id="900946" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0366 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>