<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4232 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 6222a002-a12d-5104-a882-4175ad3e6ac0 -->
  <rule id="156200" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4232 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>