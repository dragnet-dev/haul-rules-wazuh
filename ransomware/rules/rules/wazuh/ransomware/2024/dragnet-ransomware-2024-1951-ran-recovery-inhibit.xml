<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1951 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 0936d5f0-456e-58b3-a05d-8ad51c3d1b63 -->
  <rule id="698335" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1951 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>