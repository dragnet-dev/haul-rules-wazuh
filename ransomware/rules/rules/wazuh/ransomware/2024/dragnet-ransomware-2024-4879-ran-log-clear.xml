<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4879 — Event Log Clearing (dAn0n) | Status: deprecated | Sigma ID: dbc3248a-fbb8-5668-8bf8-a98d6bb90dd6 -->
  <rule id="916324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4879 — Event Log Clearing (dAn0n)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>