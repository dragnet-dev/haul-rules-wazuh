<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1345 — Event Log Clearing (hellcat) | Status: deprecated | Sigma ID: 6d6c80f1-24aa-5dd6-bd7a-724e488bf0e4 -->
  <rule id="954880" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1345 — Event Log Clearing (hellcat)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>