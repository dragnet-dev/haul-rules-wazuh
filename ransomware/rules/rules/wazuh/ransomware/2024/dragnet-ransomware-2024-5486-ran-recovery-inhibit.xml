<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5486 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d22dad06-edb2-5f26-a2b5-163ec491014a -->
  <rule id="118413" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5486 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>