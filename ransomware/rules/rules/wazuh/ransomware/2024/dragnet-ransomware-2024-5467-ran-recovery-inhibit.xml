<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5467 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 85142f6c-e385-5256-b5d4-0a46008e26c6 -->
  <rule id="562287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5467 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>