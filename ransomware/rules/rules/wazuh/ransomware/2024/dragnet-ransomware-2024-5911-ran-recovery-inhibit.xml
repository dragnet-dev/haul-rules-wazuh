<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5911 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 9f2eb179-3cce-5f60-bad0-d6d46643eb9b -->
  <rule id="577871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5911 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>