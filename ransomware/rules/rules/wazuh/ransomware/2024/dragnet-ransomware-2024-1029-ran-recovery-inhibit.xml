<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1029 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: f5f25f53-7c4d-5730-b4ff-4b5798243462 -->
  <rule id="492415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1029 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>