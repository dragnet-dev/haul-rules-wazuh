<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2151 — Recovery Inhibition (kairos) | Status: experimental | Sigma ID: 7f2e0b21-f454-5c42-8eb7-db0c09e4ea62 -->
  <rule id="658571" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2151 — Recovery Inhibition (kairos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>