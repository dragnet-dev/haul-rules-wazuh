<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5470 — Recovery Inhibition (dAn0n) | Status: experimental | Sigma ID: c45cb72b-0a40-512c-8968-3546825db7b3 -->
  <rule id="589237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5470 — Recovery Inhibition (dAn0n)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>