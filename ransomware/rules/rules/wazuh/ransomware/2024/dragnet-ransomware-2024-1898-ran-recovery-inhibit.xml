<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1898 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 3c153705-4fb0-518e-958b-392bc7c9aca3 -->
  <rule id="715370" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1898 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>