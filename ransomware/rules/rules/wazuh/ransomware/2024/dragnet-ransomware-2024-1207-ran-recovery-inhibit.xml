<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1207 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 8b3d128d-c44c-5a9c-a2fc-a6a316fa7539 -->
  <rule id="530112" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1207 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>