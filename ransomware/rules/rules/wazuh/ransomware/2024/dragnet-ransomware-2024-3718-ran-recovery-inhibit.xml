<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3718 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 3dcc04dd-8d6d-5f19-90bc-4277bee280b1 -->
  <rule id="782004" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3718 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>