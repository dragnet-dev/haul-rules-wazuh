<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4357 — Recovery Inhibition (kraken) | Status: experimental | Sigma ID: d89dc0e4-7310-520b-a872-e4a12e6c53ae -->
  <rule id="958040" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4357 — Recovery Inhibition (kraken)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>