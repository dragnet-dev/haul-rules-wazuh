<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1449 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 75b8359c-83d4-58d1-96b2-72720ce573c9 -->
  <rule id="411835" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1449 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>