<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5095 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 7cd73d52-18a2-503e-8e4b-2ab6749173bf -->
  <rule id="596381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5095 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>