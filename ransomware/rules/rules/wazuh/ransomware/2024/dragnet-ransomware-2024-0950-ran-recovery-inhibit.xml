<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0950 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ccee5154-16ec-5385-b6c3-86b82d8152b6 -->
  <rule id="846251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0950 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>