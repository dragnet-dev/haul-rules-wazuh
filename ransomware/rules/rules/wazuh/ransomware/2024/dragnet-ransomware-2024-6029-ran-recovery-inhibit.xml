<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6029 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: 8ae618da-ac85-514b-8178-e2bbb4f66e3b -->
  <rule id="522618" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6029 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>