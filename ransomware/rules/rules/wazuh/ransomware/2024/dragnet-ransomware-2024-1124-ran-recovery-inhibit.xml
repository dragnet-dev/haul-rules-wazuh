<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1124 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 2fd68625-f7cb-5a50-87d0-858858d2cca6 -->
  <rule id="556862" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1124 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>