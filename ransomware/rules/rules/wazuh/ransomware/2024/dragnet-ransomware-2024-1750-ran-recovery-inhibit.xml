<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1750 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b649b011-38f6-5b48-8fdf-067cd676b772 -->
  <rule id="163950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1750 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>