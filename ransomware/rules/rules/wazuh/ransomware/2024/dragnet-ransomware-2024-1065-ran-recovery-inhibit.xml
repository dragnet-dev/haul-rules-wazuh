<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1065 — Recovery Inhibition (apos) | Status: experimental | Sigma ID: ea9d380b-1363-5822-9778-eb2b50260191 -->
  <rule id="259738" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1065 — Recovery Inhibition (apos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>