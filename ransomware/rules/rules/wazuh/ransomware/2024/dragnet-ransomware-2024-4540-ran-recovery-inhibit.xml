<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4540 — Recovery Inhibition (alphalocker) | Status: experimental | Sigma ID: 9aa9b072-b76d-5fbb-af60-3aa6a85aed8c -->
  <rule id="459950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4540 — Recovery Inhibition (alphalocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>