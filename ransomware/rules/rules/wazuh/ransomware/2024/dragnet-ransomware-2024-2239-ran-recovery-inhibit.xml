<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2239 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 5db40c7a-8a23-5717-ad0b-262dfed4985a -->
  <rule id="699052" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2239 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>