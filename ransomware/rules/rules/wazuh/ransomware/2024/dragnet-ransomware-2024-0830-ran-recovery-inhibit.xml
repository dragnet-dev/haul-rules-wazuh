<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0830 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 1938ec3f-0f90-5aa6-9062-7894b49d532a -->
  <rule id="563643" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0830 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>