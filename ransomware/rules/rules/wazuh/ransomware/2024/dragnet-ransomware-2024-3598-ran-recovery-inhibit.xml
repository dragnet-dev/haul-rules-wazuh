<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3598 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: c105345b-ae10-5b77-b350-3e673f86faac -->
  <rule id="410534" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3598 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>