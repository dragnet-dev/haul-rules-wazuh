<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0060 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c8671960-972e-506d-8fe0-cbf12bd222cb -->
  <rule id="486719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0060 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>