<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2331 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: daceb31a-310f-5031-af76-0836b7824df1 -->
  <rule id="962353" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2331 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>