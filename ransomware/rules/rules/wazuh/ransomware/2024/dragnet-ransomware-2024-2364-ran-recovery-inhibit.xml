<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2364 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 2f9249c0-29fd-508d-a25c-3e7951cc5172 -->
  <rule id="567996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2364 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>