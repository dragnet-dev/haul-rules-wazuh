<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5817 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1fca29b3-14e5-50e7-9dfc-bd6f2356125c -->
  <rule id="521275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5817 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>