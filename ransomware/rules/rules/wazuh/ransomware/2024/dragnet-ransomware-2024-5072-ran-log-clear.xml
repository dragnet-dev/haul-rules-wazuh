<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5072 — Event Log Clearing (frag) | Status: deprecated | Sigma ID: 88b21cc2-3227-5767-9140-1581150cd87b -->
  <rule id="570748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5072 — Event Log Clearing (frag)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>