<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3414 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: f52a1ffb-0046-50de-9cc0-5f42a143a436 -->
  <rule id="474751" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3414 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
