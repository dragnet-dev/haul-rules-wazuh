<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2403 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 50150e5e-ef77-5478-8d8d-7614829fdfd9 -->
  <rule id="924145" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2403 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>