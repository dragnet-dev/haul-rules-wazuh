<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3430 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 9b4a3323-a2ed-5e23-8895-b961c9f9d7d9 -->
  <rule id="787433" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3430 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>