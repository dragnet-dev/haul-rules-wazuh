<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1706 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: bc4c34c7-0c4f-5375-a3b6-d65293830a3c -->
  <rule id="415634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1706 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>