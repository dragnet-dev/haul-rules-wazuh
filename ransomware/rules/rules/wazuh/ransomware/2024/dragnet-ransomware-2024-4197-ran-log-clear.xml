<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4197 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: bb996cf2-3501-5fc4-b3da-c5e9c74eb91b -->
  <rule id="407948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4197 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>