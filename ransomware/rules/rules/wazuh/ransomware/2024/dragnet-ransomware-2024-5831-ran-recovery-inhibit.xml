<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5831 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: c5d7f87e-6a49-5677-9cf0-90f675129b02 -->
  <rule id="622078" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5831 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>