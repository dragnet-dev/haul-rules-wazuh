<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5099 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: a47a77a8-bfbc-5180-ac82-70e9ef126624 -->
  <rule id="876277" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5099 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>