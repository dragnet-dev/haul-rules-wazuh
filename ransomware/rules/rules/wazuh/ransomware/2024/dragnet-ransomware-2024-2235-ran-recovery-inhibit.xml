<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2235 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: c4e212fc-800f-5dea-bfae-3cbadf54e8ba -->
  <rule id="298212" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2235 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>