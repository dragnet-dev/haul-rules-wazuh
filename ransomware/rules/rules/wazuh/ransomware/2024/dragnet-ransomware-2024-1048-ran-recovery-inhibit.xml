<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1048 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 9a92d867-f374-5ea3-a827-763a5a3138e2 -->
  <rule id="778858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1048 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>