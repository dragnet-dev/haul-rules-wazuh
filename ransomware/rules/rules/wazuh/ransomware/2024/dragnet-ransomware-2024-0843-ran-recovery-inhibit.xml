<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0843 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 68ff2caa-ba62-5db8-877d-c7706adffb07 -->
  <rule id="226124" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0843 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>