<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1343 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 542baaf9-cb0c-5e42-9286-91b93a698d1e -->
  <rule id="523018" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1343 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>