<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3891 — Event Log Clearing (cactus) | Status: experimental | Sigma ID: 130c3b6b-5e6c-5f9a-a13c-afb21ac4be6c -->
  <rule id="747796" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3891 — Event Log Clearing (cactus)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>