<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4675 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c73a693b-6a99-591e-879d-096423a2bf9b -->
  <rule id="337869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4675 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>