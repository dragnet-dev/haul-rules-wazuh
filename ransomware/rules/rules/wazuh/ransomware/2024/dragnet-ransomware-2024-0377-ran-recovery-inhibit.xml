<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0377 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 79fbb974-31ed-532b-84a1-178e61fa68d0 -->
  <rule id="676119" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0377 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>