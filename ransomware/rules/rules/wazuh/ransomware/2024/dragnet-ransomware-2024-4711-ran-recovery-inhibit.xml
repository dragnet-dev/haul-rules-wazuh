<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4711 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: b59b0697-f4f7-5628-8e6f-6ecdb0adbe98 -->
  <rule id="155506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4711 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>