<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5398 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: e7723c95-603b-557c-b9c6-e9c186338af1 -->
  <rule id="663580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5398 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>