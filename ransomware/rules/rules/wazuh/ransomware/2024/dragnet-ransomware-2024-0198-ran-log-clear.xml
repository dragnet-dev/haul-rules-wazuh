<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0198 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 8ab9fab1-c48d-5cc7-bfaa-e31bd6843271 -->
  <rule id="383194" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0198 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>