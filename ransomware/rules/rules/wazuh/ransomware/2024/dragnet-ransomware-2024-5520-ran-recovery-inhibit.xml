<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5520 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 1e911deb-5cf9-5dcf-a572-f5d55a703037 -->
  <rule id="813438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5520 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>