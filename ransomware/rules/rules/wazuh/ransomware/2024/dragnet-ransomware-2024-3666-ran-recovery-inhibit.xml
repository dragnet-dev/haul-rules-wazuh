<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3666 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 180ac4f0-807a-52a8-814d-450f7aa1d9db -->
  <rule id="300399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3666 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>