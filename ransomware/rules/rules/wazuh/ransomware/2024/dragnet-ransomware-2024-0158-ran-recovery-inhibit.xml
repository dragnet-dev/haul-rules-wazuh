<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0158 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: b6bee32c-a8f1-582a-bb64-0f715a242e31 -->
  <rule id="381903" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0158 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>