<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0837 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: b7384807-0680-5418-ad34-b93d41055939 -->
  <rule id="373848" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0837 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>