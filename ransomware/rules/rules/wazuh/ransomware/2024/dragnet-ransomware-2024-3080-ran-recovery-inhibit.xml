<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3080 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: e34ff01e-6394-5e20-9ac4-5f9913bcfeb4 -->
  <rule id="173590" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3080 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>