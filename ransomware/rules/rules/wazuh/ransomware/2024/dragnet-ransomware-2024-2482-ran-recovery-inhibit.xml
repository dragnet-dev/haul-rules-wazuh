<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2482 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 64b32eba-af9a-5214-bc16-d8b8295c04ca -->
  <rule id="856526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2482 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>