<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4300 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 056ac7f2-9f9f-584b-afe6-7e57f86f04b1 -->
  <rule id="621407" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4300 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>