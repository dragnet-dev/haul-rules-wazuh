<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1804 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: 50e31f44-cf79-5d29-b7bd-61e0fad8c647 -->
  <rule id="502911" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1804 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>