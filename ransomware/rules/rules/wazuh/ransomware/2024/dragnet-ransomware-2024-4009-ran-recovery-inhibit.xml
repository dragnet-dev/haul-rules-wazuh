<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4009 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8fc81584-6ada-51d2-895c-f198be704c95 -->
  <rule id="600815" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4009 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>