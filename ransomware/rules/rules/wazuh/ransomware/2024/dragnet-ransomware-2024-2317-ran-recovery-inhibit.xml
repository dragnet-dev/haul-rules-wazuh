<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2317 — Recovery Inhibition (dAn0n) | Status: experimental | Sigma ID: 212afea6-b98d-580d-be8c-e246f35bcab1 -->
  <rule id="538666" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2317 — Recovery Inhibition (dAn0n)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>