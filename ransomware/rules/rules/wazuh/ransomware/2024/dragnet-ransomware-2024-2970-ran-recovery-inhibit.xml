<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2970 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: f445093c-925c-5110-b898-c63116018f3c -->
  <rule id="744509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2970 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>