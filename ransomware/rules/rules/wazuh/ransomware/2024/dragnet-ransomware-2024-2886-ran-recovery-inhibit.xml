<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2886 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 6775a83d-64de-5956-9c0c-1a85b36bb403 -->
  <rule id="284108" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2886 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>