<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0382 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 2962672b-ab9a-53cf-bae5-00fa7f282a42 -->
  <rule id="362672" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0382 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>