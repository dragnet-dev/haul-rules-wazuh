<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4805 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b636e2b8-526c-5160-ad44-75ed811b0fd4 -->
  <rule id="161902" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4805 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>