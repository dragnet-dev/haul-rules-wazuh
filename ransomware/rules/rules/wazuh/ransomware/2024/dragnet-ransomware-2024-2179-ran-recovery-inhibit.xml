<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2179 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c5eeae81-6bcb-5016-a01c-c652e66007d2 -->
  <rule id="253102" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2179 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>