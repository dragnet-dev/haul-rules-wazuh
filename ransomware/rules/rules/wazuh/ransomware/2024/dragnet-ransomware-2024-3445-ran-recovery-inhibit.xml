<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3445 — Recovery Inhibition (blacknevas) | Status: experimental | Sigma ID: ae0f1719-f0bb-5513-8cba-cce6103c6acd -->
  <rule id="185517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3445 — Recovery Inhibition (blacknevas)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>