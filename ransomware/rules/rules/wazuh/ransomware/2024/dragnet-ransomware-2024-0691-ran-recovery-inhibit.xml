<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0691 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 425385b0-f67e-5c22-822f-76f66db4a1ad -->
  <rule id="606171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0691 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>