<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2152 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: 7b870cbd-54f5-5aa2-952b-1e81b459bd82 -->
  <rule id="281932" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2152 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>