<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2229 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 03a7e900-0656-5068-8160-44513a8f4f96 -->
  <rule id="506900" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2229 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>