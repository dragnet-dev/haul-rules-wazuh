<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1864 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: df544322-feb9-5a3b-bf77-7c73be585f35 -->
  <rule id="535443" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1864 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>