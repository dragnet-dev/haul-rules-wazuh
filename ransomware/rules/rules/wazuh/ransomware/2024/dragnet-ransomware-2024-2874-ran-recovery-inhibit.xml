<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2874 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 583ceef2-ca2c-5809-9207-a52beb88a3a7 -->
  <rule id="691278" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2874 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>