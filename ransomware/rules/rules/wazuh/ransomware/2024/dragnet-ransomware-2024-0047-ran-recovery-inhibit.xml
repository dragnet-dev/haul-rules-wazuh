<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0047 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 0fb27e7e-3ee5-5c63-a55c-525786e65403 -->
  <rule id="520467" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0047 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>