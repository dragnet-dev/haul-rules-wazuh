<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4592 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 9df4e863-ca74-5ccf-abcf-882108d2f7ef -->
  <rule id="543988" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4592 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>