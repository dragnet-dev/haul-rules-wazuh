<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2231 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 18934b39-0d1f-5702-bd41-22237d8643f4 -->
  <rule id="429553" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2231 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>