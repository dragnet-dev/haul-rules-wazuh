<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4948 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 261c192a-6940-5fc3-92a3-8802acf6e21b -->
  <rule id="688192" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4948 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>