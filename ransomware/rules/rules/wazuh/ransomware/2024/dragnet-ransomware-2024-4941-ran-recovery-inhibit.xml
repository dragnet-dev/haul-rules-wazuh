<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4941 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: abcb43ea-f592-5531-807b-3fed655f5604 -->
  <rule id="897943" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4941 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>