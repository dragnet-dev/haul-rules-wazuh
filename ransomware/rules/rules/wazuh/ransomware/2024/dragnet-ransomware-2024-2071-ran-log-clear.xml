<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2071 — Event Log Clearing (donex) | Status: experimental | Sigma ID: bbe05919-a058-5e66-b431-13b2bf0e0319 -->
  <rule id="406059" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2071 — Event Log Clearing (donex)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>