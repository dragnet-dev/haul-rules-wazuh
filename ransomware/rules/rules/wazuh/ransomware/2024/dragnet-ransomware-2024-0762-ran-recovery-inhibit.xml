<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0762 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1325fe51-42ec-53b6-837d-42f481fe9d05 -->
  <rule id="794545" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0762 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>