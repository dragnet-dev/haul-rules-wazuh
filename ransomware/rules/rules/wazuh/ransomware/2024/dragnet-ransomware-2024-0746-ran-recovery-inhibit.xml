<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0746 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 24fc3b3f-eefa-5f1e-a260-26005f66b98b -->
  <rule id="223419" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0746 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>