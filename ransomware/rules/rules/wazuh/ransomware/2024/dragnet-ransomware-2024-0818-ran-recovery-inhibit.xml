<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0818 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b36e8072-8c61-5e0a-b026-7367d301c439 -->
  <rule id="119080" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0818 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>