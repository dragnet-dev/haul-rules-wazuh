<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5392 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 62db8c7e-7184-58f1-aaa6-90be00e788a2 -->
  <rule id="874700" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5392 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>