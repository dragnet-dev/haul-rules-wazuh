<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4253 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 44d3d41a-0452-5bcf-9b06-a12f27e04501 -->
  <rule id="347814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4253 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>