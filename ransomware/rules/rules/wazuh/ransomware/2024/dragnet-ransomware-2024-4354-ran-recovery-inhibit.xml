<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4354 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: 7c342800-ff8d-5f0e-bb7b-51002d95e119 -->
  <rule id="443428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4354 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
