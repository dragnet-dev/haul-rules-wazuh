<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1849 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 18158e5c-57f0-5530-8afb-8fabe605d8ab -->
  <rule id="305425" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1849 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>