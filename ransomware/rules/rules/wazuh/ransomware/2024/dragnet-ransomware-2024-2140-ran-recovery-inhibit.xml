<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2140 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: be39a470-7b09-5a34-b3dc-dd45b36df727 -->
  <rule id="446344" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2140 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>