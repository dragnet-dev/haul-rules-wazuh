<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4696 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: f71afc1c-97d8-5482-b8db-cd995797d5a9 -->
  <rule id="237628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4696 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>