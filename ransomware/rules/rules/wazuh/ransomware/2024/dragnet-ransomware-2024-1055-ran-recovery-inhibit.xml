<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1055 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 5ed932c4-9db7-5c21-a48f-b37fad38b586 -->
  <rule id="717932" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1055 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>