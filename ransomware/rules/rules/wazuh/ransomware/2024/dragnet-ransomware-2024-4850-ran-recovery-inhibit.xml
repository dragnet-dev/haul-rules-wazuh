<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4850 — Recovery Inhibition (play) | Status: experimental | Sigma ID: e10c4964-a158-50ee-8b72-18afd123dde1 -->
  <rule id="557249" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4850 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>