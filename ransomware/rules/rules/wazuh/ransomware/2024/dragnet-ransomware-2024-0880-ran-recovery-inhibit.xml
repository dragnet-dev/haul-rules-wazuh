<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0880 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 807d401b-f3bc-53f4-8730-2e671750746d -->
  <rule id="492540" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0880 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>