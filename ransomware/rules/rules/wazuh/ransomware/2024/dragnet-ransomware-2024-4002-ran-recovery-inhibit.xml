<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4002 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 61938150-3f0b-5329-acf3-94f37a1b126b -->
  <rule id="893815" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4002 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>