<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1834 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: f98f74cf-3c07-5b48-88f8-9b37cc6618b7 -->
  <rule id="858374" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1834 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>