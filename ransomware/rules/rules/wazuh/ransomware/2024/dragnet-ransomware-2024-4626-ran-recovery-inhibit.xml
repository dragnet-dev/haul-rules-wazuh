<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4626 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 1a3c16f0-1771-5a8d-ab28-dd5875c6b76b -->
  <rule id="552271" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4626 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
