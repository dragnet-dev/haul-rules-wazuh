<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3437 — Recovery Inhibition (apos) | Status: experimental | Sigma ID: ae879b59-2631-576e-82fd-336b2f4f959c -->
  <rule id="198075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3437 — Recovery Inhibition (apos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>