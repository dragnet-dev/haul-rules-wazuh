<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2634 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 1a1a2ca8-c522-5803-87e0-102d4058b18b -->
  <rule id="916874" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2634 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>