<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1989 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 93d082fb-e238-5cf6-bbab-d42859b159ec -->
  <rule id="701082" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1989 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>