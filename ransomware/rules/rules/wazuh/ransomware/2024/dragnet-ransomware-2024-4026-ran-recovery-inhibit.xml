<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4026 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 7ba8fe9a-ddca-5dea-9553-d85109bd8cc0 -->
  <rule id="665982" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4026 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>