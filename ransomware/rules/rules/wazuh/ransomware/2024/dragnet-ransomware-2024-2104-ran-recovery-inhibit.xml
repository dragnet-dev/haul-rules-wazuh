<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2104 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 6d3dce59-ad97-55d1-b107-ea5db885e63a -->
  <rule id="980462" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2104 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>