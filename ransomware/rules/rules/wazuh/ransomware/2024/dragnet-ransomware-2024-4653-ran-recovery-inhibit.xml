<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4653 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 2b03c8be-4a5d-5dc0-8209-7da374781c83 -->
  <rule id="317739" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4653 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>