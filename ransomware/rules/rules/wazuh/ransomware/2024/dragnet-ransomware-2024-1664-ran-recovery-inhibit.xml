<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1664 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f3a563c4-ec9b-5389-8d5a-e1f29e75808f -->
  <rule id="758563" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1664 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>