<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3650 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: dbfc799a-2715-511b-80bb-b42f8e9c847b -->
  <rule id="331679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3650 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
