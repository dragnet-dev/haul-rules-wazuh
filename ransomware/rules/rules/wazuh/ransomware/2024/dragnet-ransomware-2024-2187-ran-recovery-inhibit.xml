<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2187 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4861b0f6-6614-5b4c-9af5-307cdb9c3137 -->
  <rule id="845935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2187 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>