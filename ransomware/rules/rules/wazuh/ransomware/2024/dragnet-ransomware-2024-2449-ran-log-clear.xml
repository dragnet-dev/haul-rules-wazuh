<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2449 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 70d01c1a-50b1-57cd-9d3f-fc10206f96ab -->
  <rule id="112828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2449 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>