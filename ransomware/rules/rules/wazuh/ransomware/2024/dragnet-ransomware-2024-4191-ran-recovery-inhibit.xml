<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4191 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1ca70ff2-62fd-594e-a493-ff5f1157e856 -->
  <rule id="142975" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4191 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>