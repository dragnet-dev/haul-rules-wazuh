<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5022 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 0796e20f-3f47-509d-bfef-0159ecff4f72 -->
  <rule id="475020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5022 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>