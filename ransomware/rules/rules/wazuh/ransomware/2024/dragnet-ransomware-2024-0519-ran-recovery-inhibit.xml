<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0519 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0dcda1f0-6443-5d7f-b52d-548e8364bb3f -->
  <rule id="146111" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0519 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>