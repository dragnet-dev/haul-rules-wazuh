<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4325 — Event Log Clearing (ransomexx) | Status: experimental | Sigma ID: 116aa65d-7388-585a-b78b-3112349c0abc -->
  <rule id="386665" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4325 — Event Log Clearing (ransomexx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>