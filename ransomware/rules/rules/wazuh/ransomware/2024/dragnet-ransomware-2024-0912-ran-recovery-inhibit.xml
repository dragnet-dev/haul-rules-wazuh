<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0912 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: 52bccec6-3ec4-508b-9f7b-07940f127e5f -->
  <rule id="856206" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0912 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>