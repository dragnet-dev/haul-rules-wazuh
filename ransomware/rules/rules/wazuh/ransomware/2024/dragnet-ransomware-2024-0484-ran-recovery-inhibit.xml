<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0484 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2461fa3b-45c8-5179-a34f-57f92d497f40 -->
  <rule id="102663" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0484 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>