<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1276 — Event Log Clearing (stormous) | Status: deprecated | Sigma ID: 55017071-60d5-554b-9546-58fdba0c59f4 -->
  <rule id="201707" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1276 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>