<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1098 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 51fd0d4a-73e9-56d3-b0fd-d4658d8697b2 -->
  <rule id="429453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1098 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>