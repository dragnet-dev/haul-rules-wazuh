<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5546 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: 1bcfa757-f97e-5bcd-a6d5-a9b882fd23af -->
  <rule id="339147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5546 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>