<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0928 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f342d4d2-2378-516b-8b89-dd120321f7bd -->
  <rule id="754854" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0928 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>