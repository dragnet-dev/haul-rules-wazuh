<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3087 — Event Log Clearing (moneymessage) | Status: experimental | Sigma ID: 33a2e8d8-f8da-5ddf-b1d4-98d4bdc20818 -->
  <rule id="380301" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3087 — Event Log Clearing (moneymessage)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>