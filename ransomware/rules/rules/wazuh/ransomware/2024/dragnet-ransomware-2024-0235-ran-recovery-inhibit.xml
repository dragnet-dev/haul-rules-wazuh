<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0235 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 0d05887d-7215-5960-9c46-785a0db0615b -->
  <rule id="505887" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0235 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>