<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2916 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 39fe06c7-7cd5-5e56-ac34-09f6c8f8722c -->
  <rule id="223806" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2916 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>