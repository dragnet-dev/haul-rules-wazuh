<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2484 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 07082c51-c666-563c-9394-b0441a3a1cc4 -->
  <rule id="333245" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2484 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>