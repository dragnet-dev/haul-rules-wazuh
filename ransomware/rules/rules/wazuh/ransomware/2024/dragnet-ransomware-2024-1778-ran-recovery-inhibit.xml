<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1778 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 79b4b897-d594-5600-a94d-597a5f911273 -->
  <rule id="340758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1778 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>