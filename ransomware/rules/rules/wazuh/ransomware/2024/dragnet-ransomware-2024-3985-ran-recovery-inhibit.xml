<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3985 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b239e8f2-37da-5286-a4c6-a20a89ba3571 -->
  <rule id="998388" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3985 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>