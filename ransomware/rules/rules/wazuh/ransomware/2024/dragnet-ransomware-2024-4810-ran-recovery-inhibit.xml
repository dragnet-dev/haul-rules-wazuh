<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4810 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 47649e74-badb-5a85-aa35-cf9e22c17a04 -->
  <rule id="523987" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4810 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>