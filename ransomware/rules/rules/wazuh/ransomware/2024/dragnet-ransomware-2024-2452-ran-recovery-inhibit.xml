<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2452 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 165c4939-aff5-5302-b306-7112667c2048 -->
  <rule id="952493" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2452 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>