<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5595 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 47bb4d6a-5e71-517d-8bce-1511769cf5fb -->
  <rule id="255117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5595 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>