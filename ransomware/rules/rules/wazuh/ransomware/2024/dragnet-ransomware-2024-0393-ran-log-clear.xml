<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0393 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 61d697a6-9ad7-50fc-b3d8-2db2343a19f7 -->
  <rule id="635162" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0393 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>