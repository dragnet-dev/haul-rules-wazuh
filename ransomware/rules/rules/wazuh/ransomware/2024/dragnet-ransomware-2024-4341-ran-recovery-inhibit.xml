<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4341 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 99ae1d9c-1667-593a-9a28-03449a5be565 -->
  <rule id="582909" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4341 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>