<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1308 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: 9e42f316-8616-5d66-adaa-4af1454d0e19 -->
  <rule id="834873" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1308 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>