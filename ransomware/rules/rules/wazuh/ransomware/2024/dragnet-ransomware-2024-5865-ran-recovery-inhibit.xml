<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5865 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 61fc2e8d-0166-5357-9d5b-2971a56abf95 -->
  <rule id="838926" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5865 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>