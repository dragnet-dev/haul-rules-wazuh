<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4427 — Event Log Clearing (raworld) | Status: experimental | Sigma ID: 3afc7dba-76bd-56bc-a43a-9ed3e01b4f2b -->
  <rule id="716125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4427 — Event Log Clearing (raworld)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>