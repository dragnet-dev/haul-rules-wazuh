<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3463 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: dedd4b4c-e695-5463-a7f7-f3e20e9cd97a -->
  <rule id="228555" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3463 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>