<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3592 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: d645791e-1ba1-5e5f-a8f2-cee72540441b -->
  <rule id="564579" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3592 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>