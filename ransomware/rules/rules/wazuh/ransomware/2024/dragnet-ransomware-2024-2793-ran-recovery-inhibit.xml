<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2793 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 36ed0c6f-5122-5130-a35f-40cd787898ca -->
  <rule id="712492" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2793 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>