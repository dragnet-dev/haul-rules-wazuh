<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5876 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1fd77426-85b7-59b1-abf7-402c9d82fa44 -->
  <rule id="697742" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5876 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>