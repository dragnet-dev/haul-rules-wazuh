<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4196 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: a30314f2-5839-57f5-aacb-56eff492dead -->
  <rule id="230314" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4196 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>