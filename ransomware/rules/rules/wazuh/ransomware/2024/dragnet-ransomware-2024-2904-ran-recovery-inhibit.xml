<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2904 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: c32a991f-a28c-58d2-8ee2-81b8ccb69e99 -->
  <rule id="272299" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2904 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>