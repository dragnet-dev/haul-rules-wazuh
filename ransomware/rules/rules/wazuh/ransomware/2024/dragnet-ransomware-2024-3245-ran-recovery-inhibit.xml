<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3245 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b736b964-903a-5b12-b765-190484f3c80d -->
  <rule id="177879" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3245 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>