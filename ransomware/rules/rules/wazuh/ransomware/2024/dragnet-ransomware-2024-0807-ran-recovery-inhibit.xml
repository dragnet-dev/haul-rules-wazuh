<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0807 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 0d80eb67-1ee5-53d8-9736-46c7ea683bf1 -->
  <rule id="935156" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0807 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>