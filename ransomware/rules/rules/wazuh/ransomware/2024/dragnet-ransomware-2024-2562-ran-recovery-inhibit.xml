<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2562 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 4b977fca-1f70-543f-9ebe-07c8ae3339fb -->
  <rule id="415647" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2562 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>