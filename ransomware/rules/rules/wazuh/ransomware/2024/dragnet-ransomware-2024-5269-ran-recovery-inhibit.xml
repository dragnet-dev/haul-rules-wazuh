<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5269 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 2ce7a802-6f0b-5cdf-ad5f-820d1225277f -->
  <rule id="350028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5269 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>