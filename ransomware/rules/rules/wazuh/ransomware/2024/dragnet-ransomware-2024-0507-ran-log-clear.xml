<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0507 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 57a1360a-ee9e-58d4-b190-c6b93578ca5e -->
  <rule id="321360" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0507 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>