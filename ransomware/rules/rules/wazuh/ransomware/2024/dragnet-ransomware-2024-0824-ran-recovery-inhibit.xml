<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0824 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: bb941546-0eea-5698-9184-7e601392a1dd -->
  <rule id="179415" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0824 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>