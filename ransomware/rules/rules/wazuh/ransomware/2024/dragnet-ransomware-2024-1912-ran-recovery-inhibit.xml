<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1912 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 0f8abae4-379b-5513-aca2-bae07ed1d47e -->
  <rule id="598638" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1912 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>