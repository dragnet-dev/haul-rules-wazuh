<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1878 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: e4ccbb56-7499-593d-9fc6-2750059bed62 -->
  <rule id="589595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1878 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>