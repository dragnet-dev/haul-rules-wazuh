<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3501 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: c089c443-3e6c-510b-b788-827a352ce17b -->
  <rule id="234364" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3501 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>