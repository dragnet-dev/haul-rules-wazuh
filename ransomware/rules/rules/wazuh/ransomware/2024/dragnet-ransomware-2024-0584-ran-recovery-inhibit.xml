<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0584 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 089446b9-778b-5c65-aa22-3fb908871a09 -->
  <rule id="631147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0584 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>