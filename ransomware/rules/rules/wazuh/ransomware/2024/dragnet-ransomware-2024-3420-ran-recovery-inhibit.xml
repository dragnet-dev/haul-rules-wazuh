<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3420 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: ec4ecef0-9e4e-52db-a39e-7efc8c816dac -->
  <rule id="786734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3420 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>