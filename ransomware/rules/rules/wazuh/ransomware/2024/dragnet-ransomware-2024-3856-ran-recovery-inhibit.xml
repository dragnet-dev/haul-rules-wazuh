<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3856 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: be1af4d6-4861-573e-9331-1e6778c5fc37 -->
  <rule id="468314" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3856 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>