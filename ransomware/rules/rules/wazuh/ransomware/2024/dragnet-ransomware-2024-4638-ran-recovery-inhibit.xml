<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4638 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3d3bf71e-8466-5d29-9d70-b0f72c515717 -->
  <rule id="771197" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4638 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>