<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1735 — Recovery Inhibition (play) | Status: experimental | Sigma ID: c165a5a1-2793-591e-8b1f-7599187b29e7 -->
  <rule id="246505" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1735 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>