<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5402 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 0e75ac4e-5430-5255-9d7d-405c4f717c4c -->
  <rule id="277724" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5402 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>