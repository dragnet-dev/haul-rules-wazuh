<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0873 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 8ae8b00b-7ca2-50f7-9bb2-4834d706993e -->
  <rule id="956590" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0873 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>