<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5021 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 5a3d32ad-b464-515e-9ad1-7854f832ed29 -->
  <rule id="646132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5021 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>