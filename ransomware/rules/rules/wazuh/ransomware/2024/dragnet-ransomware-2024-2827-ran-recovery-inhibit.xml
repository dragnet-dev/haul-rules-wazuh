<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2827 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 52c0a632-9616-52cb-903a-57e9ce448a49 -->
  <rule id="550506" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2827 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>