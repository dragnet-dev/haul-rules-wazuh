<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5896 — Event Log Clearing (rhysida) | Status: deprecated | Sigma ID: 69da5487-9aeb-50c2-a975-3e5a5b3d4866 -->
  <rule id="988254" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5896 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>