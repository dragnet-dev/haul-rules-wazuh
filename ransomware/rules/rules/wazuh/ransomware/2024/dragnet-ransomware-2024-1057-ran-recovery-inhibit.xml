<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1057 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 041c28bb-2636-5bd7-ba08-8c4c63f5619f -->
  <rule id="269259" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1057 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>