<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2316 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 0aace59f-8b4d-5575-8163-7063406cf039 -->
  <rule id="872659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2316 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>