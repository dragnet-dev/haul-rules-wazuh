<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2492 — Event Log Clearing (apt73) | Status: experimental | Sigma ID: 4ed66bf7-1df2-51e6-9e8a-84739aedf3e8 -->
  <rule id="318667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2492 — Event Log Clearing (apt73)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>