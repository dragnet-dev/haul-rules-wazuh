<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5183 — Recovery Inhibition (play) | Status: experimental | Sigma ID: cb4fc801-f733-59d3-978e-69c9564a01b6 -->
  <rule id="809568" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5183 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>