<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0174 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 207d34d5-75bf-58b0-bd06-eb317422cd9e -->
  <rule id="920557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0174 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>