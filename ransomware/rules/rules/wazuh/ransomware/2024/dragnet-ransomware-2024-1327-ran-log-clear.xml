<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1327 — Event Log Clearing (blackbasta) | Status: experimental | Sigma ID: c1464c6b-c040-5a2e-98e6-4b06d7fbda67 -->
  <rule id="243436" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1327 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>