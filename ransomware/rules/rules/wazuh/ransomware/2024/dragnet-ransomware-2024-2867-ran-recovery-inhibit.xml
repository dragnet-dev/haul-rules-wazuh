<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2867 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 9a6d54e4-ff76-5c05-a488-1cc44eb07cec -->
  <rule id="774954" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2867 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>