<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0201 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: fdd34700-aa2e-53a8-b38c-3628972a9b11 -->
  <rule id="561347" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0201 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>