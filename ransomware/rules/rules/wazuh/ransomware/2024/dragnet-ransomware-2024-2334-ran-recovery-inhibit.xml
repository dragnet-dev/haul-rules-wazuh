<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2334 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2f1c1147-e67d-5f80-86e2-608daef86130 -->
  <rule id="448114" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2334 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>