<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5979 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 5da79b7a-489e-51d2-9462-fa3ede112420 -->
  <rule id="698075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5979 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>