<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5677 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: e493d4a4-b232-5062-9f67-bf6fdacbfc16 -->
  <rule id="619014" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5677 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>