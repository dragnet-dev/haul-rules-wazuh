<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4395 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 4848594d-75f6-54cd-925b-eca8b514c7f1 -->
  <rule id="448594" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4395 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>