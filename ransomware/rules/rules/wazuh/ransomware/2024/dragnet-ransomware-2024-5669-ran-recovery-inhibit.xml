<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5669 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: bbc27ddb-4b07-51b4-9053-9fe6c7634bce -->
  <rule id="406845" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5669 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>