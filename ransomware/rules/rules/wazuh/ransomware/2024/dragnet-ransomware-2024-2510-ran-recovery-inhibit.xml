<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2510 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 122049ae-5783-5dfe-b015-a52e851d1e20 -->
  <rule id="252794" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2510 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>