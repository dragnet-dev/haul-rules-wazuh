<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0157 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 43096bf1-362d-52a5-a981-f84518422e93 -->
  <rule id="332767" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0157 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>