<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3468 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 1151ddbd-8a1a-5ca5-ad7a-e446e828ee92 -->
  <rule id="318043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3468 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>