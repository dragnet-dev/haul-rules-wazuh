<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3810 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: d401d4bc-6997-54f7-bd39-c75501bbd232 -->
  <rule id="444294" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3810 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>