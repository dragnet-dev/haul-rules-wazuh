<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4298 — Recovery Inhibition (play) | Status: experimental | Sigma ID: ea4ccf6e-fdc6-58f2-a1fa-5483987ef2fa -->
  <rule id="704303" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4298 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>