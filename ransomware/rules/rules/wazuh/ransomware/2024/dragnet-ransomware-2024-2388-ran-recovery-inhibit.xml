<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2388 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 32a793f3-d355-5566-96e1-65c390cda9f3 -->
  <rule id="364703" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2388 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>