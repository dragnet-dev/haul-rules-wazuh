<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1113 — Event Log Clearing (meow) | Status: experimental | Sigma ID: 57b9caa5-e6ba-5432-bafa-b8cb1a2214a6 -->
  <rule id="665386" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1113 — Event Log Clearing (meow)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>