<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1714 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 6b6cddf2-e04c-523e-a747-2737a72824f4 -->
  <rule id="910589" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1714 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>