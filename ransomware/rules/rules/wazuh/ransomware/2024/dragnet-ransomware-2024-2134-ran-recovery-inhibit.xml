<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2134 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: bc9acb61-c576-54a0-8b11-db8c077e159f -->
  <rule id="640107" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2134 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>