<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3904 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: bef9bfbd-921a-5ecc-b4a8-726e1028d63f -->
  <rule id="723295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3904 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>