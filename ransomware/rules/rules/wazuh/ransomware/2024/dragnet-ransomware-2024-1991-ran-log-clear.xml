<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1991 — Event Log Clearing (qilin) | Status: experimental | Sigma ID: 326f97e3-d2b1-5c7c-9466-c85d3f1b8a04 -->
  <rule id="371166" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1991 — Event Log Clearing (qilin)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>