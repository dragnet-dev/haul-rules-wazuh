<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3557 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 18ce4181-0db3-5863-ac46-0524aa5ede58 -->
  <rule id="414418" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3557 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>