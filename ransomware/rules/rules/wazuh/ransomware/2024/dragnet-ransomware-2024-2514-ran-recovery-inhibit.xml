<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2514 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: bc6e2dce-6be0-5eec-9524-afcb079a73d3 -->
  <rule id="430445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2514 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>