<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1673 — Event Log Clearing (play) | Status: experimental | Sigma ID: 7f39fe4a-678f-5ca3-b11f-bbe9abb3fa60 -->
  <rule id="661438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1673 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>