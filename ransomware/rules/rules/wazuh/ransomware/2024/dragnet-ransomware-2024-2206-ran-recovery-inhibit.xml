<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2206 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 4a556590-e222-531c-b937-a95b4d0018a7 -->
  <rule id="355659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2206 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>