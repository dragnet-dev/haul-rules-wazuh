<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3031 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: 5501f1b7-5ba3-5c9d-8a89-5bc86db9c62b -->
  <rule id="684987" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3031 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>