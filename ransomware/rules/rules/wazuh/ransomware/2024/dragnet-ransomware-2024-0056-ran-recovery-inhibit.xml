<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0056 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 03b40355-5e3f-5bd3-bd5d-ac7911db3233 -->
  <rule id="640355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0056 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>