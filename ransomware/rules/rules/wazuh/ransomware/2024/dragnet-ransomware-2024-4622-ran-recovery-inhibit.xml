<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4622 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: fd2d0027-936b-5d23-b867-fdc8ca9e7da8 -->
  <rule id="552500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4622 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>