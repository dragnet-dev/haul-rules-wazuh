<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2368 — Event Log Clearing (ransomhouse) | Status: experimental | Sigma ID: 6ec82c9f-6d7d-5a73-93f0-8bc48b192a23 -->
  <rule id="236524" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2368 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>