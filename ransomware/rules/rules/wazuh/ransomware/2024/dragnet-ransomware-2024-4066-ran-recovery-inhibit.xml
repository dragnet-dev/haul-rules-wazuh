<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4066 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 205f63b5-b822-502f-91dc-31c669dd4785 -->
  <rule id="873019" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4066 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>