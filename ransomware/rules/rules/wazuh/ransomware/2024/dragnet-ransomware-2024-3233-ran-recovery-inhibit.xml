<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3233 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: ecca57e1-11cc-5807-8e73-a7d2f268a085 -->
  <rule id="761857" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3233 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>