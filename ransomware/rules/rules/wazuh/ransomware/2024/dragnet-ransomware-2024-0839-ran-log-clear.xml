<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0839 — Event Log Clearing (arcusmedia) | Status: experimental | Sigma ID: 9cd23c93-ff5f-591e-8368-f743559b3c73 -->
  <rule id="514780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0839 — Event Log Clearing (arcusmedia)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>