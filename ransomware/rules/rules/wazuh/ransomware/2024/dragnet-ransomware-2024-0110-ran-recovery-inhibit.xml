<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0110 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: dd98212b-f30d-5e8a-aef0-21fe006ff271 -->
  <rule id="519821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0110 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>