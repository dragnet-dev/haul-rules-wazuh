<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3824 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: fb3479d2-8e90-5acd-92a4-71066e126683 -->
  <rule id="813479" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3824 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>