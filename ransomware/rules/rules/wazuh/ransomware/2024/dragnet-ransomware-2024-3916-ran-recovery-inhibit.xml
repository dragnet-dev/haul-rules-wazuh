<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3916 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 43ad7cb7-e0b8-5089-84c2-81a0aeca3335 -->
  <rule id="989084" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3916 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>