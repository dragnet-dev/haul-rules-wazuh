<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3664 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 200e77d6-c387-54cd-81a8-c824cf5851e3 -->
  <rule id="743645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3664 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>