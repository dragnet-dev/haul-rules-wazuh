<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3004 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: fd091008-6307-55e0-ab52-f98d32f6883b -->
  <rule id="830910" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3004 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>