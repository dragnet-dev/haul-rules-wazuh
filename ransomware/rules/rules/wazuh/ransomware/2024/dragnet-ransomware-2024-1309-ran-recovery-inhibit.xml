<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1309 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: ba9f127f-99f1-5096-95c3-57be2c68c73e -->
  <rule id="391912" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1309 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>