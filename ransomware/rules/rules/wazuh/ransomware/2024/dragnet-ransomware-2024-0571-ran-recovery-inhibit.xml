<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0571 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 510ea358-9eed-5f34-8c7a-88ff5596ca8c -->
  <rule id="507943" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0571 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>