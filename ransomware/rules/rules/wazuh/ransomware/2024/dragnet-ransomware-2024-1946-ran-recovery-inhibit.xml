<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1946 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: a9b5c5da-9889-5fca-9062-ca7ef0051f96 -->
  <rule id="208925" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1946 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>