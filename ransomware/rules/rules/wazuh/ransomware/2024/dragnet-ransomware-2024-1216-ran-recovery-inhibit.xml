<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1216 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 3167e10e-6fec-57b5-b5cc-9a095e0077ff -->
  <rule id="668610" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1216 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>