<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5256 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 420bad7f-29b4-5f92-9a9c-626ceed869ec -->
  <rule id="923309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5256 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>