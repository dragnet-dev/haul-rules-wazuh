<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4405 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 3dbc059f-75d1-5f02-894f-91259e7aed87 -->
  <rule id="780405" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4405 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>