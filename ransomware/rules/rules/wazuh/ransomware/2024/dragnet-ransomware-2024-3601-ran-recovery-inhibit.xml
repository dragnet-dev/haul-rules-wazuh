<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3601 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7e3e40d5-3975-5971-b07d-1b5e3d361ff0 -->
  <rule id="322240" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3601 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>