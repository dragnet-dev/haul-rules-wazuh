<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5276 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 1fe2af7f-c584-5221-a10d-8fae7fa5609e -->
  <rule id="506287" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5276 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>