<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5221 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: a262bdd9-d2c6-5346-b255-08274ef28d7c -->
  <rule id="927261" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5221 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>