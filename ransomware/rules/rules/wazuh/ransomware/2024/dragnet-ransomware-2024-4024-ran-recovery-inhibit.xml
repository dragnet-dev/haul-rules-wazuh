<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4024 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: aa76d6d0-5ab4-5a2f-b620-31fafba1085d -->
  <rule id="132296" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4024 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>