<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5208 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 700c1828-9a78-52e8-b754-5d6227e4fbff -->
  <rule id="321218" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5208 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>