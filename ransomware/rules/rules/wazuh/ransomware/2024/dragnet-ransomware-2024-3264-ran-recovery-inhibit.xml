<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3264 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d3e427ff-c90e-5433-9204-76ceff0ddf3e -->
  <rule id="442427" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3264 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>