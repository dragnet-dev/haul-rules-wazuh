<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4998 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 1b154d14-edc5-5bb3-a2d6-c3e5c190d058 -->
  <rule id="844771" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4998 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>