<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4273 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 430ea046-8de0-5e25-ae12-5da2e236a2f8 -->
  <rule id="303140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4273 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>