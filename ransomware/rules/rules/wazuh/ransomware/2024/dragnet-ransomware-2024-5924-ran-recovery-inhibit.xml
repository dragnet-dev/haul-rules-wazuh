<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5924 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: cc2c5ce5-15be-5cef-a8fb-59673890b5f9 -->
  <rule id="829532" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5924 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>