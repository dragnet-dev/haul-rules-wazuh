<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5203 — Recovery Inhibition (dAn0n) | Status: experimental | Sigma ID: e94a1a46-fadb-5261-ad82-39b4072e14b7 -->
  <rule id="326266" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5203 — Recovery Inhibition (dAn0n)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>