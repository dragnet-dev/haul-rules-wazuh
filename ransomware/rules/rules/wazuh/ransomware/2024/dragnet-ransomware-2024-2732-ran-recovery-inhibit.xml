<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2732 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 1a151e63-e72e-5cbe-94ae-223eb3e89e18 -->
  <rule id="684306" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2732 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>