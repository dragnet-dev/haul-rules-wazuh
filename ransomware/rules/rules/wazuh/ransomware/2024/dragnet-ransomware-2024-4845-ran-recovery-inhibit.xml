<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4845 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: 6473b369-a669-562f-bcb4-44f4deaf9132 -->
  <rule id="235793" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4845 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>