<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0089 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 4276b26d-d6e0-5971-ab46-04509c717274 -->
  <rule id="642726" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0089 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>