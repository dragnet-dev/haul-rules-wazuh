<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5797 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: e3d0b4db-8032-56b6-876e-be6e4639f20b -->
  <rule id="181714" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5797 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>