<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4550 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 42c5850b-9106-5ef9-9783-0724cd6e7440 -->
  <rule id="645850" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4550 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>