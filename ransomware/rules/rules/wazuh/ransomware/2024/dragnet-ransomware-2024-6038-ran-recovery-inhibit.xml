<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6038 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f31d8d2e-dba2-5edc-83b2-3f7c61b13911 -->
  <rule id="421581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6038 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>