<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1826 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 39ed75ed-420e-5aaf-933c-3c7cff6b5d53 -->
  <rule id="222175" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1826 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>