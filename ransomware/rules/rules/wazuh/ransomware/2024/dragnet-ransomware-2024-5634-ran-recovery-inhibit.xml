<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5634 — Recovery Inhibition (apos) | Status: experimental | Sigma ID: ceca9dd6-6846-5438-8579-93b04b7db90a -->
  <rule id="470237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5634 — Recovery Inhibition (apos)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>