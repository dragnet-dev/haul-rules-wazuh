<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1379 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 93511920-0ef1-5dfb-be67-13dbe4660939 -->
  <rule id="451192" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1379 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>