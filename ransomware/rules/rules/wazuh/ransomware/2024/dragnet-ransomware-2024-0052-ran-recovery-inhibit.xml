<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0052 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e2376aba-9b48-511e-9a22-ef83ae857e54 -->
  <rule id="578026" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0052 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>