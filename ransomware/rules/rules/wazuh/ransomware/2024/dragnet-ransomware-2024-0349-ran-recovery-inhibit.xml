<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0349 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 36c1db4c-5f5f-5744-a3f7-9189a6649dd2 -->
  <rule id="705755" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0349 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>