<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0586 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 10b77c4f-9580-541c-ad5c-a73c164b4d45 -->
  <rule id="148444" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0586 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>