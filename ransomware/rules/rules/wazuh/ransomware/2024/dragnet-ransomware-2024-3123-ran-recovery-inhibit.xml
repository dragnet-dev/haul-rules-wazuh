<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3123 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: b9d5fd9a-6a5d-5a41-91d6-424fcad64be0 -->
  <rule id="509053" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3123 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>