<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3101 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 853456ee-017b-5232-aa5c-af4e70ba8a81 -->
  <rule id="255310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3101 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>