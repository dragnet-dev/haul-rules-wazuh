<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3193 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 6d8f877e-ea02-5b29-86d6-ba8f7a2080f0 -->
  <rule id="958387" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3193 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>