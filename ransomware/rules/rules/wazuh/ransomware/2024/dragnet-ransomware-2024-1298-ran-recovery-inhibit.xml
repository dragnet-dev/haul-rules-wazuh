<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1298 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: b17d5c00-7db6-5b93-a928-a537216d5721 -->
  <rule id="261692" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1298 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>