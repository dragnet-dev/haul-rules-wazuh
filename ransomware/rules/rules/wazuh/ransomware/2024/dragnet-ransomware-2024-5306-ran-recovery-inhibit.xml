<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5306 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: d19ef17e-9eb5-535e-945c-c99ab59c9700 -->
  <rule id="779031" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5306 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>