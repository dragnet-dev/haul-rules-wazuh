<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4791 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 5ee3d1e8-80b1-5803-8478-22ba93e88d25 -->
  <rule id="729411" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4791 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>