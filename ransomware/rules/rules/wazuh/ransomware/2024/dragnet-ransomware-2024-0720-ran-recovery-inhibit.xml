<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0720 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 7923abf6-9be2-56d3-ade1-24b0d574fbc8 -->
  <rule id="328459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0720 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>