<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0020 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8ebf2f22-4ea1-5e1c-ab25-46b3e070f502 -->
  <rule id="546927" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0020 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>