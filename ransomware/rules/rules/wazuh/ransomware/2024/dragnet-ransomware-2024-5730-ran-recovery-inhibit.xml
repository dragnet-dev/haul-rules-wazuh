<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5730 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 0115c408-aa96-5971-8fba-a672007d30af -->
  <rule id="152408" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5730 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>