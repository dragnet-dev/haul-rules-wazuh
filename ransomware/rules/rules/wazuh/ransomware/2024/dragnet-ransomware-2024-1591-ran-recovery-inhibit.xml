<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1591 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a63105ab-0180-58c6-9296-e2517d719085 -->
  <rule id="263105" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1591 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>