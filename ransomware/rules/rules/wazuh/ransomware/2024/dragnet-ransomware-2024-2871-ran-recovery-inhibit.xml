<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2871 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: b3af0584-c140-52d1-bab5-91c9a36ca934 -->
  <rule id="310305" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2871 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>