<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2443 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 5f2272e4-e7f0-541c-94bc-959ec630ce1b -->
  <rule id="936366" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2443 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>