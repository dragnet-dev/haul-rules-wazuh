<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4075 — Recovery Inhibition (madliberator) | Status: experimental | Sigma ID: 375a2768-b24d-5d5a-80ac-746d261ebdc6 -->
  <rule id="710276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4075 — Recovery Inhibition (madliberator)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>