<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4704 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 7175b020-348b-5fa2-bb3b-301dda9d24a4 -->
  <rule id="348110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4704 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>