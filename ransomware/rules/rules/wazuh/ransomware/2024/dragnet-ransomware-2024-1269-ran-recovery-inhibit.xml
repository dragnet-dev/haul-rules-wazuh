<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1269 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 2473ba5e-8bfd-54c7-9d69-3930a9748ed9 -->
  <rule id="132745" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1269 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>