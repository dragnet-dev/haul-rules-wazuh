<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1493 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: fd9f0b4a-9258-52a8-9faf-997ef6bdacd9 -->
  <rule id="302251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1493 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
