<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2905 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: acbe4faa-859b-5671-b56d-3f9c4ec34e4d -->
  <rule id="875599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2905 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>