<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2302 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: 955c0cf7-e6f5-5ed7-be11-e392844cfd4f -->
  <rule id="746732" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2302 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>