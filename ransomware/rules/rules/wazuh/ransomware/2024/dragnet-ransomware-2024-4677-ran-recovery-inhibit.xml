<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4677 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 1cd3e9c2-db79-534e-ab78-9049caa01100 -->
  <rule id="211676" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4677 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>