<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1421 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 4527dad7-b86b-57ba-8716-4a5f9af0c5c8 -->
  <rule id="359130" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1421 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>