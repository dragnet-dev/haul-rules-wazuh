<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3010 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: d14cd8e8-3611-5806-b6fe-3ca576bf1e33 -->
  <rule id="765898" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3010 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>