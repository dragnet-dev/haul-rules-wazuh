<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1429 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: f39ebbab-f7fd-5179-bd9c-6c4fd314fcd4 -->
  <rule id="107515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1429 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>