<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2074 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 40b1df9e-f379-568a-878b-7b03483fc418 -->
  <rule id="867039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2074 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>