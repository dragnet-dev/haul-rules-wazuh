<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4122 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 186af866-8085-5a24-8214-8f6608424659 -->
  <rule id="379186" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4122 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>