<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5120 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 956eefbe-c3af-5069-8fbd-819e6a74c25a -->
  <rule id="419599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5120 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>