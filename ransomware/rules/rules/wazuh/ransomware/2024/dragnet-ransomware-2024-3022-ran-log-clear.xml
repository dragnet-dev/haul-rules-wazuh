<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3022 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: a5f44f7b-9bc2-5a45-b1eb-9a6e07977335 -->
  <rule id="112719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3022 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>