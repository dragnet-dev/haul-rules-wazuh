<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3338 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: aa39141c-0d05-5f2a-9814-6c144fe139fe -->
  <rule id="903914" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3338 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
