<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0367 — Event Log Clearing (SilentRansomGroup) | Status: deprecated | Sigma ID: 9051af21-2b7f-5ee9-9b66-775e46416ed8 -->
  <rule id="617231" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0367 — Event Log Clearing (SilentRansomGroup)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>