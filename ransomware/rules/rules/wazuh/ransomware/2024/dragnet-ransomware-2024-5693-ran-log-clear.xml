<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5693 — Event Log Clearing (blacklock) | Status: experimental | Sigma ID: fbb7a882-d441-5201-96e1-cfac510ef875 -->
  <rule id="244428" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5693 — Event Log Clearing (blacklock)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>