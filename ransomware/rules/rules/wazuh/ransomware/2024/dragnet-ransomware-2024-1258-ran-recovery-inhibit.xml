<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1258 — Recovery Inhibition (babuk2) | Status: experimental | Sigma ID: 02373cb9-2951-5898-8d80-bd4bc7c69e0f -->
  <rule id="776919" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1258 — Recovery Inhibition (babuk2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>