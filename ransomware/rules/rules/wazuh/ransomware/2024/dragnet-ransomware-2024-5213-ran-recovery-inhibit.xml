<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5213 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 80360966-885f-503e-8c4d-a20dbe47a7fd -->
  <rule id="936096" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5213 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>