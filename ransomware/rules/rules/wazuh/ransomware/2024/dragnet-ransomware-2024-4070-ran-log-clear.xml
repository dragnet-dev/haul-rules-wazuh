<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4070 — Event Log Clearing (insane) | Status: experimental | Sigma ID: 051e9247-69e9-56b1-90fa-6f8bb180fdba -->
  <rule id="309247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4070 — Event Log Clearing (insane)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>