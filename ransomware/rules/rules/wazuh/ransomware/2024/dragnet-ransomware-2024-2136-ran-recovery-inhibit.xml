<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2136 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: d9a538ad-54d5-5d3d-afdd-158c8bae6017 -->
  <rule id="534538" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2136 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>