<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0268 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 820feecf-e401-5a5a-89e5-f5e7c8b5b177 -->
  <rule id="762798" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0268 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>