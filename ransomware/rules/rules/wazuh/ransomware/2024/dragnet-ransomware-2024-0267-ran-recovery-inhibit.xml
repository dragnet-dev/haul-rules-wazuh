<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0267 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: eeef440d-dc6d-5212-8e39-be2846aae475 -->
  <rule id="816744" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0267 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>