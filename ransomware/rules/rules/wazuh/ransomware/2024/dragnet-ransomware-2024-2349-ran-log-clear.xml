<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2349 — Event Log Clearing (hellogookie) | Status: experimental | Sigma ID: 1260391c-74cb-5e8f-9fdf-deedf9d61eb8 -->
  <rule id="460391" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2349 — Event Log Clearing (hellogookie)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>