<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1770 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: a47e2c3c-2172-50c4-9324-13f84ee2798f -->
  <rule id="982604" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1770 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>