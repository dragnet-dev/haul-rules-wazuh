<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1980 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 10072dd7-a8bc-58d6-9f4c-5e00c749b7db -->
  <rule id="878653" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1980 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>