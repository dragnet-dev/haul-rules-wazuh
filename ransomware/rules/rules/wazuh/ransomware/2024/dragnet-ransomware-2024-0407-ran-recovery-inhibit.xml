<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0407 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: bc0e70d4-e6ed-50c7-8a19-522345984137 -->
  <rule id="409470" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0407 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>