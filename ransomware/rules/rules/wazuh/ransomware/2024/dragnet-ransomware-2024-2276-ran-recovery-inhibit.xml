<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2276 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: aafe39ff-c9e0-5fcf-999b-bbf847695adc -->
  <rule id="877439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2276 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>