<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0397 — Recovery Inhibition (snatch) | Status: experimental | Sigma ID: 2d7c089b-221b-587e-a355-d11bb7cb678f -->
  <rule id="224089" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0397 — Recovery Inhibition (snatch)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>