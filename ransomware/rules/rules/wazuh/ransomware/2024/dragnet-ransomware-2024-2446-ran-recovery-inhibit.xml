<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2446 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: dea4ff3c-a93a-52c8-82ba-dff87cde51de -->
  <rule id="219999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2446 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>