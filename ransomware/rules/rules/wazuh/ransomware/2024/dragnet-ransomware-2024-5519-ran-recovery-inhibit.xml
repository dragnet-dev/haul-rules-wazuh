<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5519 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: 05428a8e-7f26-5d1d-8a64-ba80ac52e7df -->
  <rule id="497422" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5519 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>