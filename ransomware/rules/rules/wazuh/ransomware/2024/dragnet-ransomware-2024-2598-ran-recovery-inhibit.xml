<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2598 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: fd4e9bcc-b724-5708-8b31-122b457ba670 -->
  <rule id="289435" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2598 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>