<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3566 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 638395e0-dc2f-50ec-8fe6-9dc4d379c248 -->
  <rule id="414334" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3566 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>