<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4582 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 10249e41-2bff-5602-be9f-014c2909f562 -->
  <rule id="839984" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4582 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>