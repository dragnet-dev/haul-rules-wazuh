<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5094 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 5f49b7e3-50ad-5cb0-be28-92eac40501ce -->
  <rule id="727957" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5094 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>