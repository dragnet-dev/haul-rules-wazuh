<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0480 — Recovery Inhibition (mallox) | Status: experimental | Sigma ID: 922ddd62-00ca-5c84-8c27-e1906e815601 -->
  <rule id="280061" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0480 — Recovery Inhibition (mallox)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>