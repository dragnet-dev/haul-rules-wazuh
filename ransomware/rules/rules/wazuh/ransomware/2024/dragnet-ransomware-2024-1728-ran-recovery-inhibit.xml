<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1728 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 43e1895d-ce3b-5520-acd6-79461fb6f547 -->
  <rule id="821895" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1728 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>