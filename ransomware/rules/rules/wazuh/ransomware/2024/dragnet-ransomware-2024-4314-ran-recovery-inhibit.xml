<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4314 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 75e16bd6-dec3-56f2-969b-5e2576cc347c -->
  <rule id="242667" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4314 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>