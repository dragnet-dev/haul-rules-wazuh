<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1045 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 360d413a-5b2c-5277-9208-74bec1143b15 -->
  <rule id="473413" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1045 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>