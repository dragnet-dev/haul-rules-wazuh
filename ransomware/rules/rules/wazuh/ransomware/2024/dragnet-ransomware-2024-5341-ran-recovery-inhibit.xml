<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5341 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 8b1c6131-7ecd-530f-813e-1fca66b7de29 -->
  <rule id="526861" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5341 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>