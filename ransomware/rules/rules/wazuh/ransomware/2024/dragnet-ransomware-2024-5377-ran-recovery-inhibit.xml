<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5377 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 02229d34-eadc-5ef4-9647-34514400f75c -->
  <rule id="967734" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5377 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>