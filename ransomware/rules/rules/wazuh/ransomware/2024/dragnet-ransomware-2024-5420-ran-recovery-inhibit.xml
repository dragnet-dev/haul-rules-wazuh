<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5420 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 1c67981c-f70d-5cc9-a2ae-86493e591a2c -->
  <rule id="267981" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5420 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>