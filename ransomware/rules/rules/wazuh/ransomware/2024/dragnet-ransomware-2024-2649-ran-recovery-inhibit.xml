<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2649 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: ea3dd2c0-8e0e-537e-ada1-7f9c7989fee6 -->
  <rule id="700292" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2649 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>