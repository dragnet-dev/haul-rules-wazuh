<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3574 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: fa19b4fa-111a-5653-af69-e60f6d8cf8a6 -->
  <rule id="503154" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3574 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>