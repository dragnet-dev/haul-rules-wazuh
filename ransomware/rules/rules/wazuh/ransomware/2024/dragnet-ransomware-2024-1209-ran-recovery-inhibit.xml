<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1209 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 7a4b0371-1822-594b-861d-23a8c32fea9d -->
  <rule id="259503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1209 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>