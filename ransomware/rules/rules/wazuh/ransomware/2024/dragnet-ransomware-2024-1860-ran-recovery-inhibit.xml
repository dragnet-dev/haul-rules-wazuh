<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1860 — Recovery Inhibition (embargo) | Status: experimental | Sigma ID: f5e9597b-951f-5881-a77f-dba8fe615799 -->
  <rule id="794959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1860 — Recovery Inhibition (embargo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
