<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3778 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: e00ed29f-2e92-5f99-b406-abe37360f92b -->
  <rule id="986372" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3778 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>