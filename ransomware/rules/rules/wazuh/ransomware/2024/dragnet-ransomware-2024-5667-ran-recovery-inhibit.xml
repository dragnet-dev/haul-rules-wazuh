<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5667 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: dd1c45c7-d5ac-59ee-bde5-2653c3c0bcb9 -->
  <rule id="938845" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5667 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>