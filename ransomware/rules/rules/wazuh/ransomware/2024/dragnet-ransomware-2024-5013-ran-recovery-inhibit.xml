<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5013 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 7116848a-cefc-556f-b07b-573eed58cd31 -->
  <rule id="916848" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5013 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>