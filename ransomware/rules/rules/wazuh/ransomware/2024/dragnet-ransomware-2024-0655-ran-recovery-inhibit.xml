<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0655 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d126579b-4d1a-59aa-a118-f93d1efd741c -->
  <rule id="512657" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0655 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>