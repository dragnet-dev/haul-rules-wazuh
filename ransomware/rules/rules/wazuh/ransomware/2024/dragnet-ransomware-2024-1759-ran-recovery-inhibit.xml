<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1759 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 82af2c92-aa14-59bb-ab9f-eff152558623 -->
  <rule id="786764" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1759 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>