<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0374 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 68a157d1-6e80-5bbc-8040-7e66d6ce14e6 -->
  <rule id="298157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0374 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>