<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1875 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 937fd127-1e38-55c3-a8b4-8ba1979a7c51 -->
  <rule id="701251" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1875 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>