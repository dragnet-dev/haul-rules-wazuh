<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1162 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: b1980e04-bb22-55c9-bff6-80d551820143 -->
  <rule id="991694" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1162 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>