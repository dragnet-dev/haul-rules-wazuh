<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4607 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d0ea60d0-866e-565b-89ee-4ad48aaba07f -->
  <rule id="751460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4607 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>