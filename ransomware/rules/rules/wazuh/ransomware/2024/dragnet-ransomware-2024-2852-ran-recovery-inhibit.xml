<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2852 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: cab26368-f8fa-5318-88d7-224f65e4deff -->
  <rule id="643263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2852 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>