<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3311 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: daa798f1-9393-557f-9166-7a13a28f8167 -->
  <rule id="898798" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3311 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>