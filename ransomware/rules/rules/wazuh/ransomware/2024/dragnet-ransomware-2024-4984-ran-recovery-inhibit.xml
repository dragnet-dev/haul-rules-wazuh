<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4984 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: c23f84b9-5dea-5fcf-b576-2701e16d24e6 -->
  <rule id="258384" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4984 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>