<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1737 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d919e474-3f10-544d-aa7b-0761ca44934a -->
  <rule id="527184" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1737 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>