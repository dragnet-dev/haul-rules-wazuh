<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5875 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: 42133ace-a3e8-5a2d-87e7-a0a248a5698d -->
  <rule id="986220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5875 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>