<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0279 — Recovery Inhibition (shinyhunters) | Status: experimental | Sigma ID: 05903cba-2e10-55ac-b260-17fd966e123c -->
  <rule id="711371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0279 — Recovery Inhibition (shinyhunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>