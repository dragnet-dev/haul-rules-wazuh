<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2408 — Event Log Clearing (helldown) | Status: experimental | Sigma ID: e9819e18-747b-5d4a-bb00-95651c2a6b77 -->
  <rule id="697118" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2408 — Event Log Clearing (helldown)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>