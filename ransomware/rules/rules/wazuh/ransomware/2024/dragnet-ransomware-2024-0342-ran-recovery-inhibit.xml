<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0342 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 02948483-1e5b-556a-96ac-edcf7836752f -->
  <rule id="348483" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0342 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>