<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0172 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 213ec028-5fe9-5b02-b837-59e100316ed3 -->
  <rule id="176402" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0172 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>