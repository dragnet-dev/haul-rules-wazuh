<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5567 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 9cd7488e-3aa7-5301-b27f-ba21191f40c6 -->
  <rule id="809748" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5567 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>