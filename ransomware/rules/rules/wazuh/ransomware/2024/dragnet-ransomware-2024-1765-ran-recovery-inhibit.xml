<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1765 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: a40a2b38-897a-5b12-be72-ff43a078cac9 -->
  <rule id="964043" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1765 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>