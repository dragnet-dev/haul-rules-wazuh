<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2846 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6591a45c-45d2-5647-86ca-05af2ab53276 -->
  <rule id="254664" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2846 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>