<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4786 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 158fbdc5-af60-5b41-83b9-5c3ecd1ad29c -->
  <rule id="619164" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4786 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>