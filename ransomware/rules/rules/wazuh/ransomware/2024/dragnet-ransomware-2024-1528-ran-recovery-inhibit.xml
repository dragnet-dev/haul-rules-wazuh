<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1528 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 3afe7a67-8946-555f-bfed-0c6dd9ca7be0 -->
  <rule id="716442" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1528 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>