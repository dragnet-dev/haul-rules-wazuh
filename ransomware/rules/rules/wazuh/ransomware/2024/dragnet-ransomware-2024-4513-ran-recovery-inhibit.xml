<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4513 — Recovery Inhibition (beast) | Status: experimental | Sigma ID: 1b9a10a4-c9fc-5438-b4b8-df87bbd9909e -->
  <rule id="958570" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4513 — Recovery Inhibition (beast)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>