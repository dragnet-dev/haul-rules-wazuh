<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1156 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: e41a7bdd-1b3d-5e9d-ac1f-26e83ae38723 -->
  <rule id="190683" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1156 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>