<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0752 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 6f7c8622-7242-59f8-872a-d20ef4f5c61d -->
  <rule id="988486" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0752 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>