<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1436 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: a82e284a-e0df-5249-b021-ab814f186a74 -->
  <rule id="932628" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1436 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>