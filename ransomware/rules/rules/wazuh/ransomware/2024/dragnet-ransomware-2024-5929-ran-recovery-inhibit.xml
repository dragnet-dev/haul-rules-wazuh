<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5929 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 254b8224-928d-5e14-be19-1e01e3777ff7 -->
  <rule id="575822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5929 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>