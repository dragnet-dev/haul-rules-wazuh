<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2402 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: a60b50b1-9cda-5b97-a626-d2ab451ffd22 -->
  <rule id="897150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2402 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>