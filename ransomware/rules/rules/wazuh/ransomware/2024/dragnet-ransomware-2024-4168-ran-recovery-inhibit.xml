<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4168 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 94940ef0-5294-5efd-b154-24fed33e916b -->
  <rule id="719054" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4168 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>