<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4048 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 291c033d-3a9e-57f3-b66a-3e9e0ccc4067 -->
  <rule id="268033" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4048 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>