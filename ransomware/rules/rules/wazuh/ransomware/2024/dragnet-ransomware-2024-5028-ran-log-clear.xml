<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5028 — Event Log Clearing (threeam) | Status: experimental | Sigma ID: 6e7a6f2f-962b-53aa-aa36-9bc20a3e5cd1 -->
  <rule id="235631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5028 — Event Log Clearing (threeam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>