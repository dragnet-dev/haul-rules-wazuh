<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4412 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 65da5b93-05f6-5f9d-ab19-c786ead7bcd5 -->
  <rule id="997371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4412 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>