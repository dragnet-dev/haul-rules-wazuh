<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1844 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: f50444ba-3e34-5e6a-87f3-3d36aa10d6a0 -->
  <rule id="750444" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1844 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>