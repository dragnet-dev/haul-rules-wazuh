<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4130 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 050bbc81-81ca-5a95-9a2f-5c7f9ea5a4cb -->
  <rule id="378048" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4130 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>