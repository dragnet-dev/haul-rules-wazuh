<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1220 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: d9c4e02e-b4c5-5b48-8842-ed1a6ec52560 -->
  <rule id="978380" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1220 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>