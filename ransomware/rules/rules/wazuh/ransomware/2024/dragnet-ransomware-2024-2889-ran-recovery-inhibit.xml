<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2889 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 2c9da552-edc2-50ba-9d2f-a7614a385f1d -->
  <rule id="351625" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2889 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>