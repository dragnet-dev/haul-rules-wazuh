<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3128 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 63675beb-08ef-57d9-970b-f47c44fc73e0 -->
  <rule id="218811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3128 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>