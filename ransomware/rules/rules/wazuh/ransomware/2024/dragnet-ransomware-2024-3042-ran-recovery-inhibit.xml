<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3042 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 69c48970-5881-5ce9-8311-931d3627cc92 -->
  <rule id="316489" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3042 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
