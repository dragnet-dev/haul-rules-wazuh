<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4819 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 3cabc36c-f732-550f-8315-c246624ce2a3 -->
  <rule id="785083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4819 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>