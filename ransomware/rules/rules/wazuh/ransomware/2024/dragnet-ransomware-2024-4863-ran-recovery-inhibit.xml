<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4863 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 86a7638f-e999-5067-884a-d328252b7ec6 -->
  <rule id="586763" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4863 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>