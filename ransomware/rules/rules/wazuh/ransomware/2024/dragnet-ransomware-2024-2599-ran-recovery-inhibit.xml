<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2599 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: c24f1d3a-d4d1-5500-8744-36912c51f8fa -->
  <rule id="535869" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2599 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>