<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5400 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 92cc65cb-87ba-5f77-8272-108d7ad1f734 -->
  <rule id="675665" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5400 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>