<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3049 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 5c3d771c-b552-5219-99a8-93e48b79df06 -->
  <rule id="678177" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3049 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>