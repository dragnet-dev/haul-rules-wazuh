<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4753 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: d78d3dbe-d5a0-5678-81e0-2e91b9fa00b9 -->
  <rule id="929821" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4753 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>