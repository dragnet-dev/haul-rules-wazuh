<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4536 — Recovery Inhibition (donutleaks) | Status: experimental | Sigma ID: 0ab19b1c-88d8-5318-9447-150c0dddb85e -->
  <rule id="139151" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4536 — Recovery Inhibition (donutleaks)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>