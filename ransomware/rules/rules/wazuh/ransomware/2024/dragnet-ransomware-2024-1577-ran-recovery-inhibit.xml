<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1577 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0f275f7a-fac7-565f-9f47-81104b94a7c0 -->
  <rule id="744157" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1577 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>