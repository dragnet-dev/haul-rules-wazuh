<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0816 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 4e64b91e-ca4b-5076-b49d-5d3be80a8ae9 -->
  <rule id="458359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0816 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>