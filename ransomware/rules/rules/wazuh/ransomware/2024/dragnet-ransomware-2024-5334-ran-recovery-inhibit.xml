<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5334 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: aa3a38d3-a434-5ae3-a624-dd31e274daf6 -->
  <rule id="125838" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5334 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>