<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4782 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 9aa07e23-3921-53a4-bc89-d0a089fb15f8 -->
  <rule id="458526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4782 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>