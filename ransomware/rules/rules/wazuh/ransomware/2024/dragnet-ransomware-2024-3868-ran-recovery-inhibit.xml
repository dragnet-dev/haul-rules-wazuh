<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3868 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 90a75729-df96-5400-813a-f1837ee51c6e -->
  <rule id="650757" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3868 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>