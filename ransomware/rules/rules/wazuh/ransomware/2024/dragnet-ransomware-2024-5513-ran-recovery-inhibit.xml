<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5513 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b6603b1f-66ce-5401-8512-29a9b34505e5 -->
  <rule id="165659" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5513 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>