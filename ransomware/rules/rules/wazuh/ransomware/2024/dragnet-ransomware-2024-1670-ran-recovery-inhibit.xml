<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1670 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 72b28dfb-7fe2-57aa-8ef7-b50e2642e9ab -->
  <rule id="161261" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1670 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>