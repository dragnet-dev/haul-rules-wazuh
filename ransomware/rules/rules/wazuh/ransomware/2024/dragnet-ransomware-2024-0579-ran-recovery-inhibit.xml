<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0579 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c887b44f-72fd-58e8-949e-02759268217d -->
  <rule id="362034" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0579 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>