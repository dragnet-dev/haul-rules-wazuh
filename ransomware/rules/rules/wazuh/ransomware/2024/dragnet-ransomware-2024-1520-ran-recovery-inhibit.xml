<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1520 — Recovery Inhibition (play) | Status: experimental | Sigma ID: bc8abb20-94fd-5d2e-be9e-0584c895f423 -->
  <rule id="635995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1520 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>