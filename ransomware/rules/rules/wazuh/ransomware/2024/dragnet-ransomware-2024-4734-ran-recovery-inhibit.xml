<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4734 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 9878f30b-09e4-5393-8ddc-8c3c8065660b -->
  <rule id="780633" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4734 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>