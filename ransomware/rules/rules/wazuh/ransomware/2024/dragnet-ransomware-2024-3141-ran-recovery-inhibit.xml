<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3141 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 623f4d85-2d0e-590b-bfa1-edec8e3b170c -->
  <rule id="797357" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3141 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>