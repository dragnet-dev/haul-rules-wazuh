<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3662 — Event Log Clearing (fog) | Status: experimental | Sigma ID: ead1ba0d-b5a9-5518-9228-04586a614f84 -->
  <rule id="718362" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3662 — Event Log Clearing (fog)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>