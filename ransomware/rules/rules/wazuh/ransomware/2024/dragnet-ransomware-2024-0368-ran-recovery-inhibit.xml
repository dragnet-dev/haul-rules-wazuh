<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0368 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 49087e9c-6f16-5bc7-9fe8-8ca64dc32285 -->
  <rule id="754069" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0368 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>