<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3464 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: b7884e59-6ca4-5aac-8c9c-efdd9f9d1f63 -->
  <rule id="186158" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3464 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
