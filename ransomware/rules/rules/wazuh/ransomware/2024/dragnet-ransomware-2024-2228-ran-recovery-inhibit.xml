<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2228 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 887298bd-5be8-59eb-94d4-ecf485d97544 -->
  <rule id="796779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2228 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>