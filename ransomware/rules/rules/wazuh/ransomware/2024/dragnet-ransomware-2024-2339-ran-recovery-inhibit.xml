<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2339 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 772fbdfe-e29c-56f6-859b-0c1881ffd82b -->
  <rule id="566141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2339 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>