<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4543 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 28e7a3cf-04cf-58b2-b3bf-348f9510e608 -->
  <rule id="246780" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4543 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>