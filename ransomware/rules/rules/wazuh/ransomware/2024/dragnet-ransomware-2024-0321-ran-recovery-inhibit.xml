<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0321 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 1d6e4bb0-be38-5067-bb1d-f176f8da7ab0 -->
  <rule id="561211" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0321 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>