<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1295 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: cdaed928-14aa-5570-8729-497cce96b50f -->
  <rule id="424779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1295 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>