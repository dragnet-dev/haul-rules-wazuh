<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1214 — Recovery Inhibition (play) | Status: experimental | Sigma ID: dacfd87c-e3d1-522f-8881-f35a68313da6 -->
  <rule id="962538" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1214 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>