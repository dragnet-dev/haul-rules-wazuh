<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5996 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2225bee8-a4a7-5e23-99a3-a14e3955f998 -->
  <rule id="216654" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5996 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>