<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4699 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: bce16c6e-dd2c-5d36-98a6-42d93ff2d018 -->
  <rule id="435468" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4699 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>