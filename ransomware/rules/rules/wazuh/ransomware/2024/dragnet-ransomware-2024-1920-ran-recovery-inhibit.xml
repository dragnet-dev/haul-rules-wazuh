<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1920 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: e15a2fa8-3f9a-5645-ae45-f38ee6bba389 -->
  <rule id="124047" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1920 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>