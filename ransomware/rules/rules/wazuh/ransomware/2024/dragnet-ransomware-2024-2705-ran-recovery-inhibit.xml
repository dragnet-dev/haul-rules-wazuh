<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2705 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: a84fbf8d-9d1f-58c3-936c-5293d7bd9b07 -->
  <rule id="944095" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2705 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>