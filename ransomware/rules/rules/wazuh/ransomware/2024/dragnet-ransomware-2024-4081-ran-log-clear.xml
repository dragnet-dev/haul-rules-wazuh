<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4081 — Event Log Clearing (madliberator) | Status: experimental | Sigma ID: 347543a0-e41b-5e5c-9f9c-70b6dfc5d05c -->
  <rule id="260698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4081 — Event Log Clearing (madliberator)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>