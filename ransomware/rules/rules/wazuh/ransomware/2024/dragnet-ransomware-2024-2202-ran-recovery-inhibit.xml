<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2202 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 08baea96-8f23-556c-a02a-720a7682890f -->
  <rule id="421389" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2202 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>