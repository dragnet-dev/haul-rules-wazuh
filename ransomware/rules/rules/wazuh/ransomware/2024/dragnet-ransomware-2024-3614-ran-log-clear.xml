<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3614 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 49998c87-2aad-5ff7-83f1-7ce6ed847f29 -->
  <rule id="899808" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3614 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>