<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4831 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2b5dbe9a-99e4-5af4-b40e-26813e1384a4 -->
  <rule id="985278" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4831 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>