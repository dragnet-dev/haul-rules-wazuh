<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4089 — Event Log Clearing (meow) | Status: experimental | Sigma ID: ac6d3fd8-c8a9-5fea-bbf6-1cb7c21ee18f -->
  <rule id="920703" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4089 — Event Log Clearing (meow)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>