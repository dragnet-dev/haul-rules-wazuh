<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1168 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: a6cab7ea-49a4-56a2-a73a-319814407ee1 -->
  <rule id="874197" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1168 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>