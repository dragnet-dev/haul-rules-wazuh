<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0874 — Event Log Clearing (fog) | Status: experimental | Sigma ID: 5de2b8ef-0cb6-5837-bd8a-4d5ef78fc0e4 -->
  <rule id="703638" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0874 — Event Log Clearing (fog)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>