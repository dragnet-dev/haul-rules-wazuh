<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0563 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5069eda5-ad73-564f-81cb-60be568ec222 -->
  <rule id="497901" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0563 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>