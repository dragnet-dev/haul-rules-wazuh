<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4526 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 744e79a1-e610-5a6a-8158-a03b4f70cee5 -->
  <rule id="391879" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4526 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>