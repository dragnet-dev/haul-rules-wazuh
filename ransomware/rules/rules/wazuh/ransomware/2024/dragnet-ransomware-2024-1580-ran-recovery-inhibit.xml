<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1580 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a578e62c-54c9-5a81-abcb-a62f68eaa255 -->
  <rule id="892626" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1580 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>