<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0163 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 5c849952-f4e9-5df9-8447-93cb381aa5f4 -->
  <rule id="384995" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0163 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>