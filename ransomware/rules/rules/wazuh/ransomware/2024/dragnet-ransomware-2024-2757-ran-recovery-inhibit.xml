<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2757 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 493ba32c-6479-5971-aafb-0f649fee3048 -->
  <rule id="463943" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2757 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>