<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4618 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 35ae0419-874e-54b3-aba2-80aadf54119e -->
  <rule id="234041" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4618 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>