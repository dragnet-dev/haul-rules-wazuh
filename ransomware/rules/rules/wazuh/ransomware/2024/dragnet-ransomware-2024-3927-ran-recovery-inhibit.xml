<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3927 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: be7544ac-67f6-542b-bfff-0b3469c3aba5 -->
  <rule id="207544" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3927 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>