<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4065 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: a0668a07-734b-5e25-85c7-63d6a34d62b9 -->
  <rule id="810698" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4065 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>