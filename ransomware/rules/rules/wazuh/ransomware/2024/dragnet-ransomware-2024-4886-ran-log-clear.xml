<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4886 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 24cd0339-f0c9-510b-99cd-5bd30900c5a3 -->
  <rule id="149033" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4886 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>