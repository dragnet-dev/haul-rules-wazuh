<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5577 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 2211d169-2b0c-521f-b2fb-1d3c10a6d4db -->
  <rule id="938916" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5577 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>