<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4479 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: e8b42c8f-328e-51af-b87e-7588bc1b9f95 -->
  <rule id="307084" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4479 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>