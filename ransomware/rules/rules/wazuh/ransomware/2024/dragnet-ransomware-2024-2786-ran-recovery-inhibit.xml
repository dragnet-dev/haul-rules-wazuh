<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2786 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 040b669f-02ae-58b4-952d-005dfc30190d -->
  <rule id="626719" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2786 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>