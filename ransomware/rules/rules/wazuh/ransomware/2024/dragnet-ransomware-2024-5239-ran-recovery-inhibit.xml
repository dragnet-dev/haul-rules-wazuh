<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5239 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 96719754-53a6-5b55-8d32-bb498af1d204 -->
  <rule id="771975" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5239 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>