<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5590 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a713a928-1316-5c8c-981e-bd09525861a2 -->
  <rule id="914189" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5590 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>