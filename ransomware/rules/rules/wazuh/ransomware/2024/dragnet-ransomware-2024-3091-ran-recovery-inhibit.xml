<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3091 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 78dd2b8b-b21a-5ed1-a1bb-eeb0f9a1625e -->
  <rule id="630283" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3091 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>