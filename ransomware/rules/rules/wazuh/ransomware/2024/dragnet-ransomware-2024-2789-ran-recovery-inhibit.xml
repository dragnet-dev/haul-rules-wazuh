<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2789 — Recovery Inhibition (ElDorado) | Status: experimental | Sigma ID: 70616fe2-746b-5246-ab97-7e03ed371c3b -->
  <rule id="329871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2789 — Recovery Inhibition (ElDorado)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>