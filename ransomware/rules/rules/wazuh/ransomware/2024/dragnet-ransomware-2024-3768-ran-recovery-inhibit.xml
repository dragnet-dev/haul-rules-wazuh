<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3768 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: 60f01212-0f32-501f-bbf4-8c986c2d2d7b -->
  <rule id="850121" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3768 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>