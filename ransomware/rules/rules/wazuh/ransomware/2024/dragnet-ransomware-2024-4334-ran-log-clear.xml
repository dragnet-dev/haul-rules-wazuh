<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4334 — Event Log Clearing (dragonransomware) | Status: experimental | Sigma ID: f3414773-2563-58c1-81ab-f467342b0e98 -->
  <rule id="734147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4334 — Event Log Clearing (dragonransomware)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>