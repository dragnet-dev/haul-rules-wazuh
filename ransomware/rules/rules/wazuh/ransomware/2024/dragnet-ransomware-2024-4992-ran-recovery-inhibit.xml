<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4992 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ad501584-45bf-5d1c-b62e-bcbd3a75dad1 -->
  <rule id="935015" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4992 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>