<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1348 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: dff2d0a2-aa44-52c1-9023-f6d523ba7598 -->
  <rule id="433250" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1348 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>