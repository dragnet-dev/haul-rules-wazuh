<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0147 — Shadow Copy Deletion (dAn0n) | Status: experimental | Sigma ID: 1d6b6fac-ce2a-5e2f-bf6c-f1e9dc126633 -->
  <rule id="554106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0147 — Shadow Copy Deletion (dAn0n)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>