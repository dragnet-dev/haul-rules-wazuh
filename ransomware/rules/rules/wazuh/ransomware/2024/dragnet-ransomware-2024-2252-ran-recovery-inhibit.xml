<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2252 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: dacbfa2e-47f6-5bd7-b3aa-e53e916d7fce -->
  <rule id="939066" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2252 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>