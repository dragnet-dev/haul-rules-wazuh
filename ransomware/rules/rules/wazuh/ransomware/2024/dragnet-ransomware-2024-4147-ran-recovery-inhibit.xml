<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4147 — Recovery Inhibition (dAn0n) | Status: experimental | Sigma ID: c7835d32-4106-5a48-84f0-e37ac8295e65 -->
  <rule id="345373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4147 — Recovery Inhibition (dAn0n)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>