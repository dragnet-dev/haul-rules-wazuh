<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6027 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 650cfd53-39f7-5b6a-ba2d-1a27da1cd9b9 -->
  <rule id="965725" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6027 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>