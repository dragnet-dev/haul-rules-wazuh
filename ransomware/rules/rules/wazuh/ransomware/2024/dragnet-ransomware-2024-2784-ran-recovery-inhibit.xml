<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2784 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: d2563da3-2c9b-5341-96e8-0f2c91e50bf2 -->
  <rule id="421021" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2784 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>