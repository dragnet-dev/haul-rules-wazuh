<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0812 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6e4f7e2f-33ac-51e6-a0a6-055ca090ec93 -->
  <rule id="228766" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0812 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>