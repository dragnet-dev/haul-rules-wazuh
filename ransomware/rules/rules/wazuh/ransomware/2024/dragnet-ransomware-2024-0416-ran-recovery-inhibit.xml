<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0416 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 13b0a28d-ae14-532c-bb57-70a67d53a275 -->
  <rule id="905028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0416 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>