<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5985 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 13c8936d-d872-52c3-ac54-60b5f8411c22 -->
  <rule id="508936" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5985 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>