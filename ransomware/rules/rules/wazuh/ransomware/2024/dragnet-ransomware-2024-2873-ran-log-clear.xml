<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2873 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 7cb0c5e4-3b95-5f18-90b4-a7bf4c4a1494 -->
  <rule id="592125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2873 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>