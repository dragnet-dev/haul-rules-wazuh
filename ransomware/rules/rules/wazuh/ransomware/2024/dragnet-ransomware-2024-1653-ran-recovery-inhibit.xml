<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1653 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: c8ea2e92-bc85-54b4-bee9-5391ed9d1d63 -->
  <rule id="880366" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1653 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>