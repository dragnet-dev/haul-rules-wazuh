<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0514 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: f64a9a60-61d8-555a-a9e5-7b6c34df1250 -->
  <rule id="505594" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0514 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>