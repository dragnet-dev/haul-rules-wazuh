<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1353 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 29b778bb-140f-5e8b-b7fa-edd2416e8be2 -->
  <rule id="512459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1353 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>