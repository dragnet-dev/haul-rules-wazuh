<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2109 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 10e72526-f0ac-5991-9223-9461a58c0da8 -->
  <rule id="947252" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2109 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>