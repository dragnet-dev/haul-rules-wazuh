<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3312 — Event Log Clearing (ValenciaLeaks) | Status: experimental | Sigma ID: fb19bafe-fc2c-564e-906b-fc6bef608479 -->
  <rule id="230650" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3312 — Event Log Clearing (ValenciaLeaks)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>