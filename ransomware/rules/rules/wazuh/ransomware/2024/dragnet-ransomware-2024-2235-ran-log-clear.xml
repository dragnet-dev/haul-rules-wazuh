<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2235 — Event Log Clearing (incransom) | Status: experimental | Sigma ID: ab0e5bdc-d4d0-5dd5-a8d7-2c6863963421 -->
  <rule id="879931" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2235 — Event Log Clearing (incransom)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>