<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0596 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4394eff5-961c-5071-ab09-30db8ec26ca3 -->
  <rule id="325103" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0596 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>