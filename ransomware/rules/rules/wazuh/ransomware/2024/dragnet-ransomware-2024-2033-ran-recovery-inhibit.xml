<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2033 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 5ae3aeae-82c1-5a43-9208-e76b10ba8d49 -->
  <rule id="223182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2033 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>