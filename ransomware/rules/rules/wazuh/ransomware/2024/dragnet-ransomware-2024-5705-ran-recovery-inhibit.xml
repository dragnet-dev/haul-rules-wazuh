<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5705 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 0a04343e-aebe-5fbf-837a-2178cfacf1d7 -->
  <rule id="204343" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5705 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>