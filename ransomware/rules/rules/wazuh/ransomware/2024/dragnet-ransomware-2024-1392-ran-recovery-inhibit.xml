<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1392 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 11fabf1c-1fe4-583a-ae68-ffe29cfaaf69 -->
  <rule id="750871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1392 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>