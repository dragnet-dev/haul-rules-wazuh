<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4784 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 6725e77e-3323-507c-b1c7-6a0b99ce5c00 -->
  <rule id="276147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4784 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>