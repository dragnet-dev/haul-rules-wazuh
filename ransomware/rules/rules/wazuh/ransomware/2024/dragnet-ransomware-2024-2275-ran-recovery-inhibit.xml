<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2275 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: d9a64f21-2522-5472-b3de-a1d231fac17a -->
  <rule id="975439" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2275 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>