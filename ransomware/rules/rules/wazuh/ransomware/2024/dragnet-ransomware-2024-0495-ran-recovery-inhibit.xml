<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0495 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 6160f249-5e39-5046-bf73-c4140ede9df9 -->
  <rule id="957524" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0495 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>