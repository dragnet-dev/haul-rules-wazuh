<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4651 — Event Log Clearing (dragonransomware) | Status: experimental | Sigma ID: 55498f6b-cb2a-56d0-9727-bbaf4f3431b8 -->
  <rule id="879836" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4651 — Event Log Clearing (dragonransomware)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>