<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0264 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1189d2de-632b-591b-b588-1f1d29bac48b -->
  <rule id="445965" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0264 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>