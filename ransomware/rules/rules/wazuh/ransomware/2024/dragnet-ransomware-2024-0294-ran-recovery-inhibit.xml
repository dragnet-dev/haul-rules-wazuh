<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0294 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: bfbdb5ed-e04b-533e-8397-8c114550e336 -->
  <rule id="753715" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0294 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>