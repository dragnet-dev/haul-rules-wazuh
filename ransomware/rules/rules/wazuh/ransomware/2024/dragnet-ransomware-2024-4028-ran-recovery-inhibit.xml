<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4028 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 8e315faf-0459-5481-91c2-be9a2389dbc2 -->
  <rule id="577055" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4028 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>