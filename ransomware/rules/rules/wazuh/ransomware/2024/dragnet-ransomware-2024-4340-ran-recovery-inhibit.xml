<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4340 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d4669044-2aa0-50d6-b459-ed3d61b861d5 -->
  <rule id="546690" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4340 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>