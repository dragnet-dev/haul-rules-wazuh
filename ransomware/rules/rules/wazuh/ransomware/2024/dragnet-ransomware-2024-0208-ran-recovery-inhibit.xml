<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0208 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 932fd262-0cdd-5636-9a56-6932179ccacc -->
  <rule id="688452" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0208 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>