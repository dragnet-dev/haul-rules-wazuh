<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2461 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2842d3e5-148f-503a-8b98-ab1ede61b738 -->
  <rule id="177662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2461 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>