<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3179 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 653eaf85-8f9f-53ab-a739-a1faafb276f3 -->
  <rule id="978447" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3179 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>