<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5325 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: c83c114f-9878-5642-9f71-c938cc9fdf3c -->
  <rule id="354011" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5325 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>