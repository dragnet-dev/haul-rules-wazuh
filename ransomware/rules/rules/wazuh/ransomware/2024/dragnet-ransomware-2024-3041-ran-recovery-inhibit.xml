<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3041 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 990cea3a-c3cb-561e-ba3f-b8d235406756 -->
  <rule id="558346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3041 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>