<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0888 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 22b6d0a1-c1e7-5673-9466-6d26c39441c8 -->
  <rule id="410250" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0888 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>