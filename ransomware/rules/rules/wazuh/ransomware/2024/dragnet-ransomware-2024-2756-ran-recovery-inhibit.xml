<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2756 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 6e371d8c-06e4-58d4-a967-3bfcb40bb031 -->
  <rule id="965949" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2756 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>