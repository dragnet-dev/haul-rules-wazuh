<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1766 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 5abecf9f-bdb3-54d4-b66f-4fa2f23dcdd3 -->
  <rule id="647087" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1766 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>