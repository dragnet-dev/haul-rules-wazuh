<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1739 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: f1962134-6231-5068-9437-fbfc6c721f2a -->
  <rule id="719621" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1739 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>