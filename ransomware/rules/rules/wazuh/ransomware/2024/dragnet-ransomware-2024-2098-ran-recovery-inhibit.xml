<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2098 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: dae924f0-6d7e-5942-a40b-e89afcd34961 -->
  <rule id="902924" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2098 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>