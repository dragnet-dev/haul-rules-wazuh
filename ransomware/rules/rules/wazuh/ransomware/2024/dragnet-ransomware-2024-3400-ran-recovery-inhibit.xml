<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3400 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 13f541a8-47a8-5642-afd4-3ca7e7e785a9 -->
  <rule id="976666" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3400 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>