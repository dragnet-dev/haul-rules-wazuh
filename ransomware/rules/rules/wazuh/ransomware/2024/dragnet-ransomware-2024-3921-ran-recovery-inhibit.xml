<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3921 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 3e9d78d4-eccf-56e9-8192-bfac6b94bb61 -->
  <rule id="207778" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3921 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>