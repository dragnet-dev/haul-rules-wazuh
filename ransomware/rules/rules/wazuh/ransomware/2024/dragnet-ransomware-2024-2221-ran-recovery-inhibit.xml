<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2221 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 6c1ceb9f-4807-52dc-a898-23bbf22fbf4a -->
  <rule id="931083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2221 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>