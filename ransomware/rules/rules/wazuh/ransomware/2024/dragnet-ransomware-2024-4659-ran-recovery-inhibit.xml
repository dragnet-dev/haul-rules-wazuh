<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4659 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: ab27c9a1-da50-5b59-9130-621a67b78696 -->
  <rule id="140449" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4659 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
