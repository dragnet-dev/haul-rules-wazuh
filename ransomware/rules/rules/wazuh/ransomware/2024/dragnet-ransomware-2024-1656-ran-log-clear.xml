<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1656 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 99ec7f3f-3529-5c4f-9b4c-f1de80974907 -->
  <rule id="592927" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1656 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>