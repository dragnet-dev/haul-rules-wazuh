<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1701 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 05eef478-0e06-59ad-927f-64194ccdb855 -->
  <rule id="730347" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1701 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>