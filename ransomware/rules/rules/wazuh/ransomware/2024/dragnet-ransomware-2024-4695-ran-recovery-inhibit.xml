<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4695 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: d848664e-f37b-5793-8d83-2e00c6b29065 -->
  <rule id="584866" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4695 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>