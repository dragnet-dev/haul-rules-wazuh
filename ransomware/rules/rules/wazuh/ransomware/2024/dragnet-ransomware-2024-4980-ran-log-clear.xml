<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4980 — Event Log Clearing (safepay) | Status: deprecated | Sigma ID: 3216f63b-2c3a-5fc7-bae7-a8c7f532d940 -->
  <rule id="747163" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4980 — Event Log Clearing (safepay)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>