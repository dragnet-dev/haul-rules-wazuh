<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5385 — Recovery Inhibition (play) | Status: experimental | Sigma ID: eb85212e-97b7-537a-8142-5a5c7f44979c -->
  <rule id="658521" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5385 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>