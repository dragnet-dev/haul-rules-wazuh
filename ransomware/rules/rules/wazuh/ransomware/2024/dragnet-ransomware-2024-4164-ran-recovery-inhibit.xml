<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4164 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: f67878a2-d7c2-51b2-bc78-4200cccde178 -->
  <rule id="767878" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4164 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>