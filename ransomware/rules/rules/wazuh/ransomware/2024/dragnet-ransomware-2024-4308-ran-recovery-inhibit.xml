<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4308 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: d2fb64fc-c5df-5ca0-8277-a0a289a9bb48 -->
  <rule id="804364" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4308 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>