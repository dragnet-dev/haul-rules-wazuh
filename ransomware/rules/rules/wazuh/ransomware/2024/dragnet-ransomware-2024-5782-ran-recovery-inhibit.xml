<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5782 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 59f0182a-ae0b-5281-af53-09be5e868766 -->
  <rule id="690182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5782 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>