<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5800 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 0c489704-9007-5a56-b5f7-7acbc82868ae -->
  <rule id="448970" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5800 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>