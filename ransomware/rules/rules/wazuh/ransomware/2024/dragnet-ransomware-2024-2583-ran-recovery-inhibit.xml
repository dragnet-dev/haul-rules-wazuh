<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2583 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0c045ec3-13d6-512b-9e9b-af2744d6389f -->
  <rule id="483756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2583 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>