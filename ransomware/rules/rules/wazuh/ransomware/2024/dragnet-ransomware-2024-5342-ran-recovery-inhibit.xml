<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5342 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1bc2e3be-62d5-530e-a016-fd8e2a20fee3 -->
  <rule id="673819" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5342 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>