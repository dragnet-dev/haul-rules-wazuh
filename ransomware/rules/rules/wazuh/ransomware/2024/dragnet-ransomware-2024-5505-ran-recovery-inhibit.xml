<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5505 — Recovery Inhibition (akira) | Status: deprecated | Sigma ID: 11250f55-aec1-5d3a-ada3-0346be467fcb -->
  <rule id="100155" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5505 — Recovery Inhibition (akira)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>