<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2802 — Recovery Inhibition (blackout) | Status: experimental | Sigma ID: 82d030b9-9fe5-5b4c-9c58-91bd3fb47ea8 -->
  <rule id="525030" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2802 — Recovery Inhibition (blackout)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>