<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4963 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 0e308225-452c-5d2b-8546-ac6f93402eb7 -->
  <rule id="630822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4963 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>