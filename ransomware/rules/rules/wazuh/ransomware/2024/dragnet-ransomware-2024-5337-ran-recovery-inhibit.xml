<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5337 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 46e38c0b-4d15-598c-8857-42cac7862ad6 -->
  <rule id="400620" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5337 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>