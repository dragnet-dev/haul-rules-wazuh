<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5559 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 02f9153b-8f4b-5ab8-b5f8-dcdc929bbebb -->
  <rule id="566459" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5559 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>