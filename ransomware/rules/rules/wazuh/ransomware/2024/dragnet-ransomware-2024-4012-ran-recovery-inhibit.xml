<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4012 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: d8236a7a-b64a-5a47-933f-9e4475cf3bdf -->
  <rule id="511786" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4012 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>