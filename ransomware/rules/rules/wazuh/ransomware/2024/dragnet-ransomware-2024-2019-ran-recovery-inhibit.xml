<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2019 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b5642693-e089-5d83-b4e0-5e517df36779 -->
  <rule id="356426" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2019 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>