<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2475 — Event Log Clearing (akira) | Status: deprecated | Sigma ID: b4b22d13-d37c-57f4-811c-6d747e6f9e7e -->
  <rule id="336365" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2475 — Event Log Clearing (akira)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>