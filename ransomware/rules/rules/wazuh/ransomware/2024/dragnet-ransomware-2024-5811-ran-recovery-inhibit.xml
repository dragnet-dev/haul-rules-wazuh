<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5811 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b5cf2dc7-bb7b-50f2-b7d8-44a76f04830a -->
  <rule id="343565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5811 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>