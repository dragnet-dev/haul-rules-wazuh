<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5944 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 7667cbe0-8875-5b2c-984c-6996cdbc928f -->
  <rule id="262955" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5944 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>