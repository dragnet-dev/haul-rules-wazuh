<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0167 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 156cac6c-c7a5-5493-969b-d77e190a7a8c -->
  <rule id="222206" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0167 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>