<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2620 — Event Log Clearing (darkvault) | Status: experimental | Sigma ID: 5ebb0b9e-8e48-5ab9-93c8-f6a77b2b78ad -->
  <rule id="380171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2620 — Event Log Clearing (darkvault)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>