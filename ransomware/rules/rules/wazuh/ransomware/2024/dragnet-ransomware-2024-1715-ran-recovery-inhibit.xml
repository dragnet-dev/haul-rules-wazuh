<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1715 — Recovery Inhibition (play) | Status: experimental | Sigma ID: aa400ab4-62de-530b-b180-1a3fee5b83c9 -->
  <rule id="126410" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1715 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>