<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4235 — Recovery Inhibition (termite) | Status: experimental | Sigma ID: 2517cbe0-125a-5244-a5a6-ca26abdbc9ce -->
  <rule id="512894" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4235 — Recovery Inhibition (termite)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>