<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2629 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: de477e96-f887-5d07-ac1b-a106a1dcf67e -->
  <rule id="959646" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2629 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>