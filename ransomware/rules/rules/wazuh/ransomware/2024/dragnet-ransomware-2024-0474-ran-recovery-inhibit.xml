<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0474 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 55475aea-d438-556d-9bdc-5e8cdce56500 -->
  <rule id="801774" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0474 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>