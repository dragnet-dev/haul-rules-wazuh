<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1807 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 445e1a9e-c4f8-56f4-904d-6ba10f12ee72 -->
  <rule id="341466" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1807 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>