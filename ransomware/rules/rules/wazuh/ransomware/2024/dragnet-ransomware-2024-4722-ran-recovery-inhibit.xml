<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4722 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 3fc34a8c-455f-59d6-8709-c1ef7d9fb716 -->
  <rule id="832554" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4722 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>