<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5816 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: d88198d5-0bc6-57d1-8caf-0e98f2b1ef0c -->
  <rule id="588198" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5816 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>