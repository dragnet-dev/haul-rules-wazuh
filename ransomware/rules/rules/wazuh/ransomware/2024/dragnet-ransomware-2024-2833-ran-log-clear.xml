<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2833 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: 77c6df1a-85f4-5f5f-b532-3bc574a7e0b0 -->
  <rule id="586399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2833 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>