<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0475 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: eb140abe-534e-57ef-b12b-939ca528a93e -->
  <rule id="262250" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0475 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>