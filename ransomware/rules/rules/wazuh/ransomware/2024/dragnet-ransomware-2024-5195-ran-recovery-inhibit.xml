<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5195 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 61710d5a-b51f-5155-814b-6977260d3779 -->
  <rule id="973735" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5195 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>