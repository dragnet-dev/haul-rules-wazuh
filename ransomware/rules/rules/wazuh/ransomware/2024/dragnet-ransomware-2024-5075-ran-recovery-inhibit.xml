<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5075 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 8112ddca-5a3c-571d-ad63-ec3f053ef6eb -->
  <rule id="376893" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5075 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>