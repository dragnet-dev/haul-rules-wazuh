<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1004 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: eaf330b4-88bb-5e63-a2d0-8c6ee045ba6a -->
  <rule id="259330" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1004 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>