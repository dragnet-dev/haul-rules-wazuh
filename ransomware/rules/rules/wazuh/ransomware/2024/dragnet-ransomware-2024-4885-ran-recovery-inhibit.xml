<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4885 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 99bd3e63-551e-5724-9500-1c8c92d6d4eb -->
  <rule id="585342" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4885 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>