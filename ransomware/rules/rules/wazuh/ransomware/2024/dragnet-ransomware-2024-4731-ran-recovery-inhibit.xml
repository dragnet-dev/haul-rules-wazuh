<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4731 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 2eb12d88-3e5a-50f7-a230-b9308b3c1c26 -->
  <rule id="395405" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4731 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>