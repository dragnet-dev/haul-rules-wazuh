<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6016 — Recovery Inhibition (safepay) | Status: experimental | Sigma ID: 3ba9e7fe-b19b-5e24-88f6-0e993f5b5198 -->
  <rule id="727987" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6016 — Recovery Inhibition (safepay)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>