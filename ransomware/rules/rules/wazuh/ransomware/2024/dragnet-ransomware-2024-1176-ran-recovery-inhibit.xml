<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1176 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 730b2e43-5d72-5a3f-aebc-04b9d6b4277a -->
  <rule id="170606" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1176 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>