<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3628 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: ca9ed23f-032b-5b5d-a26f-34a541f1319c -->
  <rule id="796612" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3628 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>