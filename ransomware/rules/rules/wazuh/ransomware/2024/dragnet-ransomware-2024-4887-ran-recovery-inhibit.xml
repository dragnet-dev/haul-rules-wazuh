<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4887 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 8fd75a47-31b9-55ba-b48c-8e1a4c1267b6 -->
  <rule id="182810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4887 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>