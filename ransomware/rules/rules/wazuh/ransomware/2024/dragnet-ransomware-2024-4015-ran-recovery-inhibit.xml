<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4015 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 0633cf31-ef7b-5dbb-86b0-f13b49efee7d -->
  <rule id="822553" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4015 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>