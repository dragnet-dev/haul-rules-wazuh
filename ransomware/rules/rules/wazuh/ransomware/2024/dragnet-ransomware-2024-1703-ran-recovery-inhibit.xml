<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1703 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: e3e1cd54-c43b-561f-99bc-a2f2abbe68dc -->
  <rule id="593581" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1703 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>