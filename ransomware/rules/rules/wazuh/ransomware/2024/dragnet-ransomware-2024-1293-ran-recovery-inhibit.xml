<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1293 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 7c011fca-d023-50b5-af5e-1bed3b467244 -->
  <rule id="284191" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1293 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>