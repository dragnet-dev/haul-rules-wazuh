<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1123 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 4c3b986b-174c-5e5e-a697-18bd6caf5ff3 -->
  <rule id="421998" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1123 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>