<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5489 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a8b0b700-8302-5f55-8df5-8631359e75ee -->
  <rule id="182517" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5489 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>