<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1014 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 5b0fc7c6-5939-52e1-afd2-1905378f09a3 -->
  <rule id="632127" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1014 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>