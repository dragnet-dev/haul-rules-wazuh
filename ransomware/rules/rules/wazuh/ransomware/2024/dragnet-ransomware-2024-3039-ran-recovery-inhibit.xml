<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3039 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 4e2d6a34-9a6e-502a-a5a5-1843492fdfa9 -->
  <rule id="304106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3039 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>