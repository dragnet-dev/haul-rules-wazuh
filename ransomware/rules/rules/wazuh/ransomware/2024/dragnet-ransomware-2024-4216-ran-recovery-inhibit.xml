<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4216 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: e4f5ff78-7a13-5a09-a2b4-e448deac8c89 -->
  <rule id="638175" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4216 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>