<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5131 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8e4039ee-1ba2-5166-a940-96b5362f6c6f -->
  <rule id="624039" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5131 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>