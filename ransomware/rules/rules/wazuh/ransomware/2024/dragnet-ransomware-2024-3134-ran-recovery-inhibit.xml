<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3134 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 8e3c5c59-5029-50d1-9acb-f17a8104ed9f -->
  <rule id="144892" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3134 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>