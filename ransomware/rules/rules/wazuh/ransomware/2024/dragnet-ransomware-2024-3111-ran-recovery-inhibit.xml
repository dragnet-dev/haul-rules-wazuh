<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3111 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 7bb254f3-c416-5e74-b50a-e34d5c8f6738 -->
  <rule id="279254" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3111 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>