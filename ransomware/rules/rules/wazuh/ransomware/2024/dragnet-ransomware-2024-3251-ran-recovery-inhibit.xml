<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3251 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4fdd8011-6b6d-54a8-a4db-4676516299f7 -->
  <rule id="344580" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3251 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>