<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3661 — Recovery Inhibition (embargo) | Status: experimental | Sigma ID: 7d4fac7e-420d-55b5-bff4-c180f3601380 -->
  <rule id="740396" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3661 — Recovery Inhibition (embargo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>