<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2597 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 09499834-75e7-5e93-880d-d9cc085cf762 -->
  <rule id="599834" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2597 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>