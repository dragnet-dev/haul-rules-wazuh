<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3412 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 02bfb1bc-0c64-5563-90b6-8745955b2ecd -->
  <rule id="101467" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3412 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>