<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5087 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: d4589047-4bf5-5216-b0d5-fd6318f49149 -->
  <rule id="545890" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5087 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>