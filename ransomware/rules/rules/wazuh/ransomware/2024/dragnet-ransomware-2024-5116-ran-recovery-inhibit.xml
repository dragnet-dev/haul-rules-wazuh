<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5116 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ac17c5d4-0532-54a4-b728-4650b97461f8 -->
  <rule id="154845" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5116 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>