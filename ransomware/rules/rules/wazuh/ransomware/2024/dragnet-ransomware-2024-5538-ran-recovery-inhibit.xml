<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5538 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 709e8a87-d022-5b79-94ea-3cc7e7961295 -->
  <rule id="117418" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5538 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>