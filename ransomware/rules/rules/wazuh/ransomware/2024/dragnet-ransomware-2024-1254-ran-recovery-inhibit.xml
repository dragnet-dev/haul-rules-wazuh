<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1254 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 87e3765f-2592-51a7-9b64-ca3551729ea1 -->
  <rule id="606376" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1254 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>