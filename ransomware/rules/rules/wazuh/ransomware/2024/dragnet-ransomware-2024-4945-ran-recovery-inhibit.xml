<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4945 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 414bc6dc-370a-5627-9fb1-1380b460a7a4 -->
  <rule id="261726" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4945 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>