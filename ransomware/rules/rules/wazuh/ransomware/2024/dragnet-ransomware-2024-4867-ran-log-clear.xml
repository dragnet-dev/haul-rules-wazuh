<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4867 — Event Log Clearing (dAn0n) | Status: experimental | Sigma ID: 075dd14e-4d6c-5b83-b4eb-0495d7ed4ba8 -->
  <rule id="242114" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4867 — Event Log Clearing (dAn0n)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>