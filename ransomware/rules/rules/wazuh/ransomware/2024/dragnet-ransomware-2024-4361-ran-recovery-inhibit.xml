<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4361 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 7a11cee0-8525-5b87-8e49-3078c3b0bfe0 -->
  <rule id="526222" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4361 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>