<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1446 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 22f5b0af-0ea4-5b4d-9a0a-42ec3972454f -->
  <rule id="509770" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1446 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>