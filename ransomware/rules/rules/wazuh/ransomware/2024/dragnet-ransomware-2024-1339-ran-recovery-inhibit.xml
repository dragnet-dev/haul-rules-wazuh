<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1339 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 55f74617-0a67-502b-b5e8-fb82dd9609fb -->
  <rule id="957461" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1339 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>