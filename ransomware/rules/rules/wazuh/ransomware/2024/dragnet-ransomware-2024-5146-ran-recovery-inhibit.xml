<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5146 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 4b232bd1-569e-558b-8618-5b29aadda879 -->
  <rule id="403723" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5146 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>