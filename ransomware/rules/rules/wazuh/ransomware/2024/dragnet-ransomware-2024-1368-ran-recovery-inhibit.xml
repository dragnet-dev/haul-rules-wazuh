<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1368 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: d73e7655-01f4-5a7b-a0fd-a6467018e3b7 -->
  <rule id="498276" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1368 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>