<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2710 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 1f88c410-4f84-5ea2-b99c-67c18cc18141 -->
  <rule id="702041" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2710 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>