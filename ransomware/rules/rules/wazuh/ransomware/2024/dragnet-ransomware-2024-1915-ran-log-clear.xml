<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1915 — Event Log Clearing (BrainCipher) | Status: experimental | Sigma ID: ed67a618-a6a8-574b-838b-68b0726ac5fd -->
  <rule id="302826" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1915 — Event Log Clearing (BrainCipher)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>