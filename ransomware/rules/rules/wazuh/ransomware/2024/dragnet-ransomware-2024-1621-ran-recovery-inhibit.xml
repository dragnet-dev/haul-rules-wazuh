<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1621 — Recovery Inhibition (stormous) | Status: experimental | Sigma ID: d82d2ab3-1f1e-568b-95b1-cfc84b6caf29 -->
  <rule id="940042" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1621 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>