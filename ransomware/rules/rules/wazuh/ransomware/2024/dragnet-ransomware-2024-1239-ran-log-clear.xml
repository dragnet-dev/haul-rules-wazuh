<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1239 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: a0c8ec8d-f19b-59b4-b5e4-5f8908690446 -->
  <rule id="629004" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1239 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>