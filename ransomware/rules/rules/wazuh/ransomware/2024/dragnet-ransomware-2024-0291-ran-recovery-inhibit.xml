<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0291 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 0a50ef67-eeb3-5434-af90-2e74186a36eb -->
  <rule id="990396" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0291 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>