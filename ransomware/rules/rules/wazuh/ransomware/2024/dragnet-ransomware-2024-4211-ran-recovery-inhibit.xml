<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4211 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 069a1f83-1497-5df4-a707-cfc73f1b7c11 -->
  <rule id="982718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4211 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>