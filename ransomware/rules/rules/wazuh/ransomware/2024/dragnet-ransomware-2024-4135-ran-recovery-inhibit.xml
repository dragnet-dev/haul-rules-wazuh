<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4135 — Recovery Inhibition (trigona) | Status: experimental | Sigma ID: 482952f9-86f6-578f-bab5-c651df5b42d6 -->
  <rule id="627247" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4135 — Recovery Inhibition (trigona)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>