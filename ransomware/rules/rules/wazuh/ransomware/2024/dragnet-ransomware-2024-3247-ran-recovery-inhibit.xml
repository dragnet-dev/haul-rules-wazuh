<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3247 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: ffe84608-bcc6-562b-a18b-21599d523f37 -->
  <rule id="594846" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3247 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>