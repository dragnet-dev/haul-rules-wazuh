<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0875 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: fe81ede9-4fca-519c-a398-6da5e44e8556 -->
  <rule id="323373" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0875 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>