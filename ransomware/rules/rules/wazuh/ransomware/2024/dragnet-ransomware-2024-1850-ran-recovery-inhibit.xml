<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1850 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: f2c2dbf7-8a5c-518e-af4d-b184836b7cbf -->
  <rule id="957371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1850 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>