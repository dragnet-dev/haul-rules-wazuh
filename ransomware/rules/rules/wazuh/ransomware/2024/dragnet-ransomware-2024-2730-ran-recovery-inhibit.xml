<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2730 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: df3a30b6-2945-54ab-9478-16cff8dddacc -->
  <rule id="973830" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2730 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>