<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0018 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f79921fd-fdf0-569a-bad4-4092d8380343 -->
  <rule id="779921" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0018 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>