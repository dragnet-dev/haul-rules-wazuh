<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3475 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 9b63689d-002d-58d6-aafa-9d0ad5291faf -->
  <rule id="756368" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3475 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>