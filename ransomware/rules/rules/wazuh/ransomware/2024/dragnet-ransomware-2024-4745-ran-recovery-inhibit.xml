<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4745 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 764f779b-6118-56c9-81cb-1ca3a493ce5b -->
  <rule id="423977" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4745 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>