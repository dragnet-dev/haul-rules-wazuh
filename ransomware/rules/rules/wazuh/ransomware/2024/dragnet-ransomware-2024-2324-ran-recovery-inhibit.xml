<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2324 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: a6a6fcba-7aea-5cf7-a502-db78d9faef35 -->
  <rule id="869148" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2324 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>