<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4034 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 94bb25b0-85bf-57ab-8e1b-e9840bd83244 -->
  <rule id="725125" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4034 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>