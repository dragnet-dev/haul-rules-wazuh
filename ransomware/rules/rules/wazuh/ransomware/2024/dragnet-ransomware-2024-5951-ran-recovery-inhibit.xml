<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5951 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 9405217a-48c8-5e19-9cd8-d48896271bb0 -->
  <rule id="505217" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5951 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>