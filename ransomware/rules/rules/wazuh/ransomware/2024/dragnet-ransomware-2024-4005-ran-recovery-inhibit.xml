<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4005 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: aba9ac87-4643-56d2-9fdd-aa77ed8140a0 -->
  <rule id="832236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4005 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>