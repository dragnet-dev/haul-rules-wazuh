<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1760 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 6286d6a9-ebbe-5163-b319-cb59b7eb1f7d -->
  <rule id="205896" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1760 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>