<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0077 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 7665be92-1c1a-574f-92f7-8b8ca972c048 -->
  <rule id="262430" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0077 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>