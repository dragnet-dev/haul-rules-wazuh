<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1328 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 7cbb7bd1-0663-5edc-98e5-2f74cc081912 -->
  <rule id="709083" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1328 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>