<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5250 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 3ca7e5c3-14b8-563e-9487-c6bf31a5edad -->
  <rule id="753265" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5250 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>