<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3727 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f2d921fc-2585-5c5a-9f4a-3f2e6f07a83b -->
  <rule id="745921" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3727 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>