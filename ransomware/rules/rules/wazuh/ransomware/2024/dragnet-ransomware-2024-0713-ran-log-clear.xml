<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0713 — Event Log Clearing (play) | Status: experimental | Sigma ID: 9d63a3b2-e8e6-5e79-a5ca-48616a52f9c2 -->
  <rule id="822183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0713 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>