<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0820 — Event Log Clearing (meow) | Status: experimental | Sigma ID: 8fca6f84-b810-58e4-8ee8-47aa00f1aaf1 -->
  <rule id="589711" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0820 — Event Log Clearing (meow)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>