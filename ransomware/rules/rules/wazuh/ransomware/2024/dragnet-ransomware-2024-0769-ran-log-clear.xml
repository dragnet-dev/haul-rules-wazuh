<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0769 — Event Log Clearing (arcusmedia) | Status: experimental | Sigma ID: b89a9c3e-4c79-5f0b-8c1b-bef4c1b86058 -->
  <rule id="445596" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0769 — Event Log Clearing (arcusmedia)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>