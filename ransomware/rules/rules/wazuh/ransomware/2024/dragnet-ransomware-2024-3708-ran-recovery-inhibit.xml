<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3708 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 6229117c-97c3-5d2e-b2b1-688edbe2036a -->
  <rule id="929117" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3708 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>