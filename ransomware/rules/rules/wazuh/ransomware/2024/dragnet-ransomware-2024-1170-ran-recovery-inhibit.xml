<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1170 — Recovery Inhibition (embargo) | Status: experimental | Sigma ID: ff9e2c52-5cb2-54fe-8f88-65a288634be4 -->
  <rule id="353324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1170 — Recovery Inhibition (embargo)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>