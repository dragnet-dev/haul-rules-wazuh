<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3864 — Event Log Clearing (bianlian) | Status: experimental | Sigma ID: f7d9d4d1-f67d-53dc-9021-bc4dfb61ce96 -->
  <rule id="541574" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3864 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>