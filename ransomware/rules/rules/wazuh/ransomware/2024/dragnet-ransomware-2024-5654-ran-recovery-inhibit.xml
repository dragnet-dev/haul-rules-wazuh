<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5654 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 8e41db9c-97a9-57ec-92cb-421919c8385f -->
  <rule id="145915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5654 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>