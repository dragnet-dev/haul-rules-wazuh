<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2280 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: fa4319e7-f5f6-504d-b69d-aec6124609c0 -->
  <rule id="804319" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2280 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>