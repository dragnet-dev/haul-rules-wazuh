<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1575 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: a2215d45-8502-5413-8f36-bfc7a0589018 -->
  <rule id="835453" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1575 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>