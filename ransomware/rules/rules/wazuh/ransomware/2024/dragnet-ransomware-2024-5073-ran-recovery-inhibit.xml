<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5073 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 29c8f0b3-3b33-59cb-af8b-bdc845a9747e -->
  <rule id="608491" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5073 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>