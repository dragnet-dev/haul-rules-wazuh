<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3944 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: b88bdae3-3eef-5ff0-8b23-9a1cb268db62 -->
  <rule id="469082" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3944 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>