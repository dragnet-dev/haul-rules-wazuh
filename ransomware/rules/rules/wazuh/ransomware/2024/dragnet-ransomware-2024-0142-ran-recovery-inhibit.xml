<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0142 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a68f111f-9164-523e-84d8-201ff7525c51 -->
  <rule id="910311" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0142 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>