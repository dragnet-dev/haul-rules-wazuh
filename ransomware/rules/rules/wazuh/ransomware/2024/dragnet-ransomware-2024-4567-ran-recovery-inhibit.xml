<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4567 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4a82eb1b-19f7-5157-84e9-364523b31285 -->
  <rule id="215627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4567 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>