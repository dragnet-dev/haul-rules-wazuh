<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1894 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 6e53d54c-f8b6-5619-bce1-8eb22df6f113 -->
  <rule id="968615" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1894 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>