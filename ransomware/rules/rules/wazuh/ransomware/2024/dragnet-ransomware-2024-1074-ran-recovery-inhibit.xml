<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1074 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 42fb0741-f414-51d9-a059-80ffb04fae54 -->
  <rule id="300307" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1074 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>