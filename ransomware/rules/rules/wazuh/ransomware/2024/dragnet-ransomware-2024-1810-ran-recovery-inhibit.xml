<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1810 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 151be746-9944-5f43-8aea-94ebbb44aa73 -->
  <rule id="384674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1810 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>