<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0220 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: ccef094f-60e5-5644-a7f4-7005709b0ebe -->
  <rule id="846309" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0220 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>