<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4694 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5837c32b-5c06-5826-b640-af4ae8021fdb -->
  <rule id="440432" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4694 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>