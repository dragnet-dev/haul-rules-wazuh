<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3389 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: 9695b03a-ff02-5167-8fee-284cf35bff56 -->
  <rule id="751310" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3389 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>