<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2463 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0ebf7182-c99f-5330-b1b3-c33ea0d7993b -->
  <rule id="275718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2463 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>