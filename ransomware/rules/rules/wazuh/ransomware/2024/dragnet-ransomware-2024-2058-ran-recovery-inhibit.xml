<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2058 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 50594a8f-9927-5fbc-b1c7-7410e6f6b4f0 -->
  <rule id="995148" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2058 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>