<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3147 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: 043f5cb5-31a2-5fbd-b925-f704efb5852a -->
  <rule id="101163" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3147 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>