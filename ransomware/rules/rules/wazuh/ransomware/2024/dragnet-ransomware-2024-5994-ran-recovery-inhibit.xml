<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5994 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 29f15e80-c12b-54dd-8db1-57cddd1ed1c1 -->
  <rule id="566548" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5994 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>