<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2242 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: bf45f590-e4e0-54f1-bd45-cd5097879976 -->
  <rule id="463355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2242 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>