<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0781 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 4d18e945-ef40-5ab4-834e-fa3916fcf2a4 -->
  <rule id="435029" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0781 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>