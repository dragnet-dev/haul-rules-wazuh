<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3207 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 165b8310-2378-5f76-930c-e1aa2c3f0fa1 -->
  <rule id="951831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3207 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>