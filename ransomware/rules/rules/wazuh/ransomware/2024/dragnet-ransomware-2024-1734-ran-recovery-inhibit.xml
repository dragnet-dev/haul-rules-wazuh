<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1734 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: e73a834e-286f-5e90-a039-5e91602f7c11 -->
  <rule id="657883" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1734 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>