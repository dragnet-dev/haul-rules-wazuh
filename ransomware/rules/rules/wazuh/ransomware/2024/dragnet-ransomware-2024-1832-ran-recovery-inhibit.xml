<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1832 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: a16e32c3-13d0-545e-b713-3175349cfb8a -->
  <rule id="827032" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1832 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>