<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4343 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 77f7abcf-650a-5ed0-a02b-bb4381f2a214 -->
  <rule id="594283" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4343 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>