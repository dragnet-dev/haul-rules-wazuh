<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1393 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d6bcb8f3-f166-5059-b478-209b29d828e2 -->
  <rule id="300758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1393 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>