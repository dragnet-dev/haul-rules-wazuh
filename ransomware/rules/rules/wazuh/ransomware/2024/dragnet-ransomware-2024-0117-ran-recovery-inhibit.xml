<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0117 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 3568ba82-db2b-5a1e-a22b-23c324a7c4ac -->
  <rule id="235948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0117 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>