<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0032 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: b7ff1306-906d-5eb2-8f2c-3c8987c6e04c -->
  <rule id="420713" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0032 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>