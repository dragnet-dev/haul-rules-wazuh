<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1909 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 5a7e267f-f344-5350-a711-ecce5f606452 -->
  <rule id="652626" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1909 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>