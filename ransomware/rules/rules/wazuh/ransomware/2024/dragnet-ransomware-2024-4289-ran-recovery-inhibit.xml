<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4289 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: b5e95889-52d0-5377-92db-712479626bb1 -->
  <rule id="154958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4289 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>