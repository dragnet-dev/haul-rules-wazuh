<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0473 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 8c397495-c644-5212-9c5f-1f4df5edb1d8 -->
  <rule id="603974" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0473 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>