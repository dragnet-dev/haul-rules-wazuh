<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2768 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 635168ba-5aa9-551b-8d7d-861185e46709 -->
  <rule id="362699" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2768 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>