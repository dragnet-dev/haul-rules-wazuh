<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4430 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 4b4b87d5-3b23-57a9-975f-6c503a1242c2 -->
  <rule id="407587" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4430 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>