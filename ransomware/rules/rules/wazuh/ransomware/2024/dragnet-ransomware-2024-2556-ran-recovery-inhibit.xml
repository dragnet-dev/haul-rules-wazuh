<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2556 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: 6de3451c-2482-568d-bf0d-0a3e435255b0 -->
  <rule id="958345" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2556 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
