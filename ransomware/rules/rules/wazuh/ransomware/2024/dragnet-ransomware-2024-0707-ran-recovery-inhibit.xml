<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0707 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 1e9112dc-9c3e-53d9-8ea6-bb9332eb89c3 -->
  <rule id="545805" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0707 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>