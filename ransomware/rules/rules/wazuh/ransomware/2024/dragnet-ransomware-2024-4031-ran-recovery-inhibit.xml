<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4031 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5098112a-35cf-5a87-9995-fbe40dd85fb7 -->
  <rule id="698112" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4031 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>