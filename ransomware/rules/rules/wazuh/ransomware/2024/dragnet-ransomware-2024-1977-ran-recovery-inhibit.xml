<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1977 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: cb9401b1-6f3b-5a04-9008-d647da081187 -->
  <rule id="339401" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1977 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>