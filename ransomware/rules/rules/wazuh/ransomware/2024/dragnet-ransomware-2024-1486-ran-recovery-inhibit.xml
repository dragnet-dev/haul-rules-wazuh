<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1486 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 61bba281-fe90-5139-a387-0486fd00a1fe -->
  <rule id="828582" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1486 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>