<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0898 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: f5cca6d2-3c20-5436-8fe0-8f73d84d8023 -->
  <rule id="181546" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0898 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>