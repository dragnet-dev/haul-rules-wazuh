<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4809 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4b5e1056-9db8-54be-9de5-f4dbfa9a8883 -->
  <rule id="409410" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4809 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>