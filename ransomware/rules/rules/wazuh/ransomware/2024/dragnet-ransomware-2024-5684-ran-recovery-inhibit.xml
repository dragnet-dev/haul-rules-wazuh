<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5684 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c15af0a0-c6e4-5d30-9851-63015e979eec -->
  <rule id="512150" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5684 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>