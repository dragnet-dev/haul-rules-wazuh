<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3023 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 76f6c170-8715-5f94-897b-5444be50b1bd -->
  <rule id="270681" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3023 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>