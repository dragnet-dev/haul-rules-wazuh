<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3690 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 782e00ec-ec20-5120-a1c0-c5e6351be0fe -->
  <rule id="452600" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3690 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>