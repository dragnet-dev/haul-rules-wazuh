<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3845 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 558d5b92-a94f-5fce-9c3c-5e0b3450536b -->
  <rule id="630651" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3845 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>