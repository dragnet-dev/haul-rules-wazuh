<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1554 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 7361550c-f3a1-5b71-a000-8d666cdff099 -->
  <rule id="261550" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1554 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>