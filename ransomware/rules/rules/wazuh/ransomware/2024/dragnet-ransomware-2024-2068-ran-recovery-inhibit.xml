<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2068 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 6afd9e3d-823b-511d-90ef-35b9e69d718d -->
  <rule id="882398" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2068 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>