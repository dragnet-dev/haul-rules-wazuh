<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5918 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: 50ebfff7-99b5-516c-ae9e-231818ba12ab -->
  <rule id="737215" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5918 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>