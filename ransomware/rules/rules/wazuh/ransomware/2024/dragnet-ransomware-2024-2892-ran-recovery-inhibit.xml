<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2892 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: e37f59bd-c065-5cec-91dc-50ee2075e8c8 -->
  <rule id="600759" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2892 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>