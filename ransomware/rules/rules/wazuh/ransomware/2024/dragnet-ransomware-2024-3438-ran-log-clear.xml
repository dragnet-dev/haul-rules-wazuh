<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3438 — Event Log Clearing (trinity) | Status: experimental | Sigma ID: 78052e06-f838-5ccf-bff0-d6aa09f197eb -->
  <rule id="448846" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3438 — Event Log Clearing (trinity)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>