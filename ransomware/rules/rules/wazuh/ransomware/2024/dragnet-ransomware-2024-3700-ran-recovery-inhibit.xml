<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3700 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: db7ad3b6-1e73-58fc-9e48-b3c04e301be9 -->
  <rule id="326053" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3700 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>