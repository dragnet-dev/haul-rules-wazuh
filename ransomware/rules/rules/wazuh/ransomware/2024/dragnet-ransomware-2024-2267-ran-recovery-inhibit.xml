<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2267 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 818749d1-fea4-53ba-81bb-52bbc78ae452 -->
  <rule id="599997" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2267 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>