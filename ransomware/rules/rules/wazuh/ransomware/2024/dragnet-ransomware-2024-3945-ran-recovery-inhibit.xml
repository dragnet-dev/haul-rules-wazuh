<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3945 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: e337e112-ffbe-55ce-9c53-ecd69f9b7152 -->
  <rule id="594061" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3945 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>