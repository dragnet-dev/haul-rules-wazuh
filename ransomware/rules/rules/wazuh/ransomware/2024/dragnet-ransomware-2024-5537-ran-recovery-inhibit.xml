<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5537 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 69bdeff7-6411-5747-9857-04ac6829d1b1 -->
  <rule id="170607" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5537 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>