<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1837 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 391c4991-da7f-5f8e-bc96-bdbb29b37af1 -->
  <rule id="968499" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1837 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>