<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5663 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 747c1eed-e9f0-5e5b-a3d3-2edc8bf16c60 -->
  <rule id="214270" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5663 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>