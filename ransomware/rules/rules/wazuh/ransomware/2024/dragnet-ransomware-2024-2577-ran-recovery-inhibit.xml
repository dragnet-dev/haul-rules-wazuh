<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2577 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 79d4acdc-308b-52dd-9924-4314cab265d9 -->
  <rule id="670316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2577 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>