<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0445 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 6f9fa13a-a01c-51f4-b32c-413118f3977f -->
  <rule id="267141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0445 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>