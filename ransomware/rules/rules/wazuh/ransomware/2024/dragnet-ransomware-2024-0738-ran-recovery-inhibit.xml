<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0738 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: cae159d1-8d0e-5798-909d-f3f736885c57 -->
  <rule id="646159" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0738 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>