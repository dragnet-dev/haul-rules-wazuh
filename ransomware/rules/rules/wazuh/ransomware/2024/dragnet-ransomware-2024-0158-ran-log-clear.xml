<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0158 — Event Log Clearing (killsec) | Status: experimental | Sigma ID: 5fe7f62d-2dc8-51d0-9323-6ba1b1a238f9 -->
  <rule id="755676" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0158 — Event Log Clearing (killsec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>