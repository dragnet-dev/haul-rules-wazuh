<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3174 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: a39d0e7c-46b5-5d3a-89d9-56567a9903b5 -->
  <rule id="961934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3174 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>