<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2319 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 0bc64a0e-b609-5dd0-ba02-c1e5dd6856a6 -->
  <rule id="418340" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2319 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>