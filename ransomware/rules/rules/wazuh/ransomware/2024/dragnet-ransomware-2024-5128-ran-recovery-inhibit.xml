<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5128 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 4d84bee0-f2b8-5024-8ae9-8d2ab476c370 -->
  <rule id="292894" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5128 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>