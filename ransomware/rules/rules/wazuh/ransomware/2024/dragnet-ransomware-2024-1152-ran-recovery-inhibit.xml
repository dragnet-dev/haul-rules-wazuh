<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1152 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: ba90883c-966e-57c4-b9d2-5252030cbfe0 -->
  <rule id="169088" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1152 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>