<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2920 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 40776443-a2a4-5d4f-9406-6fc36ba3db02 -->
  <rule id="577644" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2920 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>