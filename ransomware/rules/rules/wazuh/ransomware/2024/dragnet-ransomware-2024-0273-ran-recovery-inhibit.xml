<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0273 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 15653d50-858c-54ca-a1e0-ea67f00c00dc -->
  <rule id="804615" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0273 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>