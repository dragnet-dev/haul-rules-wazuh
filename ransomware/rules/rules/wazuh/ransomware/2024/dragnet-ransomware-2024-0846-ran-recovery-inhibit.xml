<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0846 — Recovery Inhibition (nitrogen) | Status: experimental | Sigma ID: 39f335b2-11cb-5bd2-8c17-165464ee9ddc -->
  <rule id="429371" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0846 — Recovery Inhibition (nitrogen)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>