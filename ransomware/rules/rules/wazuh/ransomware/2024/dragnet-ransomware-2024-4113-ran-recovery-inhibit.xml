<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4113 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 5d907184-2e01-5d46-9d96-6669d721ffd5 -->
  <rule id="490718" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4113 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>