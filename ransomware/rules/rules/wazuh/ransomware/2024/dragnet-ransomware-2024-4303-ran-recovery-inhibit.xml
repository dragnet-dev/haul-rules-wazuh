<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4303 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 82487a88-3501-583f-ae87-606eaced6ee9 -->
  <rule id="519802" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4303 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>