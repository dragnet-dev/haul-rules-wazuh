<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0644 — Recovery Inhibition (flocker) | Status: experimental | Sigma ID: 8d0530a0-cc6b-5113-b5ec-3a76cb384fcf -->
  <rule id="610530" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0644 — Recovery Inhibition (flocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>