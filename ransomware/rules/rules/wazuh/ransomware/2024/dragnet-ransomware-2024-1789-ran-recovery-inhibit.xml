<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1789 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: ca655fea-ab39-5306-a106-432bbdcb70e1 -->
  <rule id="642495" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1789 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>