<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0531 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 496ed6ee-9cd9-5385-b6dc-f03e5d4ff344 -->
  <rule id="472136" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0531 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>