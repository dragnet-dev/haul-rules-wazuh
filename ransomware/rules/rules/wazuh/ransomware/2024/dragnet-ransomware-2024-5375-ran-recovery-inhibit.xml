<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5375 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: b8647e97-6e6a-507f-9602-f87172ca7985 -->
  <rule id="198366" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5375 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>