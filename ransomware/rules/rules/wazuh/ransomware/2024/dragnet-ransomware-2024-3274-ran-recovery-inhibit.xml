<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3274 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 7efd28c6-c1d2-536a-9266-1bdc06cccd96 -->
  <rule id="650928" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3274 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>