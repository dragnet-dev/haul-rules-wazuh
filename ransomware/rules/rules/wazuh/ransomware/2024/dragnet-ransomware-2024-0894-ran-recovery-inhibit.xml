<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0894 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: dd63f25f-b8e5-57eb-852b-b239fdb4a551 -->
  <rule id="946232" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0894 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>