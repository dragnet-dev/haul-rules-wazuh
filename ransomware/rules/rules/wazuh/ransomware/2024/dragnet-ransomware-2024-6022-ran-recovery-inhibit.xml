<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-6022 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 15a8f356-b839-5f25-87e9-12392878d193 -->
  <rule id="514335" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-6022 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>