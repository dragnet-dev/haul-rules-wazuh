<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3907 — Event Log Clearing (trisec) | Status: experimental | Sigma ID: 96b5c76f-5ddf-5184-8a74-95e28531c7b9 -->
  <rule id="776127" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3907 — Event Log Clearing (trisec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>