<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2749 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: 6bb21a27-9ae6-5101-aa12-f10899dbd327 -->
  <rule id="157146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2749 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>