<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5845 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 362261e9-9889-50d1-b5c5-6f7705c547aa -->
  <rule id="496190" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5845 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>