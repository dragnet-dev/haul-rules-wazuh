<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4187 — Recovery Inhibition (rhysida) | Status: experimental | Sigma ID: 21d93f22-6728-5c3a-a212-b041fe7f5692 -->
  <rule id="299032" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4187 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>