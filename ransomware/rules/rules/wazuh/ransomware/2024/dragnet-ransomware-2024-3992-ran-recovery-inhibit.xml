<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3992 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: 97878339-07e7-54e2-8deb-e36d9c3a243d -->
  <rule id="887833" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3992 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>