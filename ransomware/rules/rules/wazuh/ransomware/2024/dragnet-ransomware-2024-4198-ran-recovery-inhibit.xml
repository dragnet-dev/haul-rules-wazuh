<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4198 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 3ac49857-80fe-50fe-9b25-33eda0294ffc -->
  <rule id="504985" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4198 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>