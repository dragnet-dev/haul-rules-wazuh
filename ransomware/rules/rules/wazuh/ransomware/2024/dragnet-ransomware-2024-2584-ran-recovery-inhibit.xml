<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2584 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 27712b6a-3cc0-5068-90b7-444fb3d63ca7 -->
  <rule id="934036" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2584 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>