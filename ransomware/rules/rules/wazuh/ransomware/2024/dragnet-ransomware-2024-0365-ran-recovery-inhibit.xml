<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0365 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: c7f355ca-686a-5aa8-bedb-76755a3977c0 -->
  <rule id="347355" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0365 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>