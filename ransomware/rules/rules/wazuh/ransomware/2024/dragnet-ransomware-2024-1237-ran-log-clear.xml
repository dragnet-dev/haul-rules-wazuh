<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1237 — Event Log Clearing (lockbit3) | Status: experimental | Sigma ID: 66e3c8d8-6b3a-5a6c-97aa-8ecd0bc344e6 -->
  <rule id="912608" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1237 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>