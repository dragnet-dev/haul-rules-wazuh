<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1805 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 33239235-8274-524a-a0d3-dfddf01668f5 -->
  <rule id="723923" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1805 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>