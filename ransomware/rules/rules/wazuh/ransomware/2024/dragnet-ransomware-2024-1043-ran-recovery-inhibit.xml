<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1043 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 3c2dc8ab-a3c9-5c51-9127-74b2a44f98c9 -->
  <rule id="743328" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1043 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>