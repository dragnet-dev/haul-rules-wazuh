<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4627 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: 2e84b0a6-51cc-56c5-b96f-fb698712d7e4 -->
  <rule id="392810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4627 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>