<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3525 — Recovery Inhibition (ransomhouse) | Status: experimental | Sigma ID: 7e5c23d4-eefb-564b-aa5b-539a5954ccf5 -->
  <rule id="325223" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3525 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>