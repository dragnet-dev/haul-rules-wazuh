<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4872 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 7de8561a-6610-53f2-87e5-4500c76b16f8 -->
  <rule id="314856" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4872 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>