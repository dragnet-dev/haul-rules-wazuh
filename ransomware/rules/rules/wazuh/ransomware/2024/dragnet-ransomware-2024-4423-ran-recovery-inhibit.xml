<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4423 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: bc12e16b-f6e2-55c7-9ee5-57d2652c31e3 -->
  <rule id="410061" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4423 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>