<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4394 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: fb3fe346-11e3-56cc-82b4-f598e63daf35 -->
  <rule id="235823" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4394 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>