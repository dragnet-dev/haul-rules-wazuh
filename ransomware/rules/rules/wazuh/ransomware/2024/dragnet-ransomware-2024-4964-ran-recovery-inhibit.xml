<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4964 — Recovery Inhibition (interlock) | Status: experimental | Sigma ID: cbcb00e2-dcbc-5e0d-a04b-d5cd7713b3e9 -->
  <rule id="817100" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4964 — Recovery Inhibition (interlock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>