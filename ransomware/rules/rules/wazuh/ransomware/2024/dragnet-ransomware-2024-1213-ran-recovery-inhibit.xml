<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1213 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 00b67d36-160a-5bf4-a479-2583511a12e2 -->
  <rule id="168536" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1213 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>