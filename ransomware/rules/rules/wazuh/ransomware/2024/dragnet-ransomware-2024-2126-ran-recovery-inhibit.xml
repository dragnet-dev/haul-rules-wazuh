<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2126 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7cee1d29-f8ad-5478-8781-81465c34a8fb -->
  <rule id="717149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2126 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>