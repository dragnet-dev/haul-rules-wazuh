<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4492 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: c70899c9-9447-5dee-927e-6c368e1b478a -->
  <rule id="470899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4492 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>