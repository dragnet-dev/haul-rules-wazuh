<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0684 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 7eae582b-9690-5873-8d4d-15ac64018d9f -->
  <rule id="643058" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0684 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>