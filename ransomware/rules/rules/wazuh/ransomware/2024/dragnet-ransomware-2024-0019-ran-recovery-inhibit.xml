<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0019 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d5a6de40-c643-5cab-8a8a-0ab3d25796b6 -->
  <rule id="256958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0019 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>