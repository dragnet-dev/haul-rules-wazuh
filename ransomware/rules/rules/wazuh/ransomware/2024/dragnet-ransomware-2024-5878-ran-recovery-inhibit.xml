<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5878 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 5f72f92d-f279-55fd-8022-2c36ea4c2172 -->
  <rule id="731679" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5878 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>