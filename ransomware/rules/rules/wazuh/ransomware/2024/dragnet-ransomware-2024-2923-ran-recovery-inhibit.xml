<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2923 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: bf14d910-b3cb-5a67-bf7b-49f9f8fec4cd -->
  <rule id="458379" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2923 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>