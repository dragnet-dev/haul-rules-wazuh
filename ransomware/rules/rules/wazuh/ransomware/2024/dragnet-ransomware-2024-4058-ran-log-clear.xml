<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4058 — Event Log Clearing (flocker) | Status: experimental | Sigma ID: ea3c313d-a2e0-5d0e-a1b3-f5e5ec9edab7 -->
  <rule id="250031" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4058 — Event Log Clearing (flocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>