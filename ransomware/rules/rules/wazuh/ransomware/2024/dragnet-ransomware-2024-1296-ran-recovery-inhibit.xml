<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1296 — Recovery Inhibition (qilin) | Status: deprecated | Sigma ID: c5c23053-9625-54ea-a151-570d7a6f2143 -->
  <rule id="312230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1296 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>