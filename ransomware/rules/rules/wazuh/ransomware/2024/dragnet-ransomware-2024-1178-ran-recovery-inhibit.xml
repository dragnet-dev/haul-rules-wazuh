<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1178 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: f656bea1-7e77-5abc-bb43-51be2abc4ce1 -->
  <rule id="508126" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1178 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>