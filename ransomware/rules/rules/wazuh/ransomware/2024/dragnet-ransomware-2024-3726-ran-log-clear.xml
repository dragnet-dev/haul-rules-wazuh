<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3726 — Event Log Clearing (arcusmedia) | Status: experimental | Sigma ID: 56e9a38b-6d81-5eb0-947e-9c4588cb6fd3 -->
  <rule id="657543" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3726 — Event Log Clearing (arcusmedia)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>