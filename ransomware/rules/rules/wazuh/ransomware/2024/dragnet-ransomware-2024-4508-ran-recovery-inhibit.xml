<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4508 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 25e7828b-fdb7-5251-b6f3-f01a076c96b3 -->
  <rule id="647828" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4508 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>