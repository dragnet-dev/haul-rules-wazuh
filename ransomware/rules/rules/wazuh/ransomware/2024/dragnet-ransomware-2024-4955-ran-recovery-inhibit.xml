<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4955 — Recovery Inhibition (hellogookie) | Status: experimental | Sigma ID: cb059e49-39d8-5b11-a139-d66a9f24ce9c -->
  <rule id="648958" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4955 — Recovery Inhibition (hellogookie)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>