<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5004 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 80b490f5-a65a-59ab-bb1f-a2980ff8b7e0 -->
  <rule id="491490" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5004 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>