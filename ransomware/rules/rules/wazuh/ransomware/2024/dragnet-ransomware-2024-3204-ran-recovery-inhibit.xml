<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3204 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 57173dda-2d94-5327-ae8f-5cfc53e179ba -->
  <rule id="336509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3204 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>