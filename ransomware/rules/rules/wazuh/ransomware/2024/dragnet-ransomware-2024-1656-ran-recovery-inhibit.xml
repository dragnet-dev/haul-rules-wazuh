<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1656 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 8845f2dd-da58-5a70-8dd3-5ef371eff871 -->
  <rule id="615352" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1656 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>