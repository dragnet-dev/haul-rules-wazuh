<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4222 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 2bb6560c-5e63-5203-8f9a-524d8aceff85 -->
  <rule id="796560" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4222 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>