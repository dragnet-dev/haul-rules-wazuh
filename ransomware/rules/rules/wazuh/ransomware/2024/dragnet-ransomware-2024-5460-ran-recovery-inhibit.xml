<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5460 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 38695166-71d3-5cf1-8ef7-546ca65b4b4e -->
  <rule id="369516" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5460 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>