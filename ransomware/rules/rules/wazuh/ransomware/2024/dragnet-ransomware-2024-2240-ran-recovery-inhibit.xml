<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2240 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a2b8721c-a518-5fa5-8be6-49d497729221 -->
  <rule id="843872" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2240 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>