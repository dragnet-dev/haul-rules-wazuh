<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0897 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a0a73d10-ebd3-59b7-85f4-de79e8505bb8 -->
  <rule id="877181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0897 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>