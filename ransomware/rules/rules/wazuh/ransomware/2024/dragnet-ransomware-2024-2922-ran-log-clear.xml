<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2922 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: 9e61434b-3b21-54fb-99d7-8e2c70fc8576 -->
  <rule id="786143" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2922 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>