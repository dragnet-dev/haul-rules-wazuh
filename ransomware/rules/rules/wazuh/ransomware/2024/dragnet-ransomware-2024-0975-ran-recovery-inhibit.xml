<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0975 — Recovery Inhibition (play) | Status: experimental | Sigma ID: a4ba55c2-706a-5530-a892-9f16c4a73206 -->
  <rule id="981055" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0975 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>