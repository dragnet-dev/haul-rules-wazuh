<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2100 — Event Log Clearing (mogilevich) | Status: deprecated | Sigma ID: 603df8d1-0aae-57cc-a9db-0d49151a1ae3 -->
  <rule id="745918" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2100 — Event Log Clearing (mogilevich)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>