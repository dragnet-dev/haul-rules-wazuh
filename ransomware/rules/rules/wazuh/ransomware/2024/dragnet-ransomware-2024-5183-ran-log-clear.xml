<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5183 — Event Log Clearing (play) | Status: experimental | Sigma ID: 4b54b9d1-0ba2-5fa5-8b3c-ecb43aaac7d5 -->
  <rule id="408759" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5183 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>