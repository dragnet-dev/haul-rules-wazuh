<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4678 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: c8e58dc3-c5e4-5fe0-8a48-a7c80eaeb523 -->
  <rule id="700141" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4678 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>