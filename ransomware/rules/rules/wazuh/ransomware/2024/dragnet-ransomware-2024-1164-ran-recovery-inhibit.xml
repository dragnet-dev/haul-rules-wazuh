<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1164 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 74077b05-aa6b-59cb-ad7a-73b5d5d24590 -->
  <rule id="385243" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1164 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>