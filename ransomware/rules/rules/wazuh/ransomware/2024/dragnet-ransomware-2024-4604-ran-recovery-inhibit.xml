<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4604 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: d75d9d8a-0377-5208-9cbd-8ca69c1844f9 -->
  <rule id="922237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4604 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>