<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5889 — Event Log Clearing (funksec) | Status: experimental | Sigma ID: 0fa6e28e-d638-5d37-9ffc-b66c6d769dc4 -->
  <rule id="511028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5889 — Event Log Clearing (funksec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>