<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5643 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 92be5a2b-c642-5bf5-977a-c295a8733fdd -->
  <rule id="298810" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5643 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>