<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0323 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 261fec46-91ef-5c92-9366-44b7046798f3 -->
  <rule id="273132" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0323 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>