<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5645 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 9b399464-f13f-5b29-901a-76bbc6cc7a29 -->
  <rule id="753994" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5645 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>