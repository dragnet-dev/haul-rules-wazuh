<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4064 — Recovery Inhibition (play) | Status: experimental | Sigma ID: dfbbd78a-481a-5ffa-bcef-264071a2b58a -->
  <rule id="264137" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4064 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>