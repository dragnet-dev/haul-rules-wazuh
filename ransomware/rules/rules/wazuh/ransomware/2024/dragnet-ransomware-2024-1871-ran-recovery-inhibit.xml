<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1871 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 99f56adc-974e-5115-b5c9-e39114b57ca3 -->
  <rule id="859306" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1871 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>