<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5049 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: ecf0207e-e315-5469-ae34-81aa5a88799c -->
  <rule id="291020" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5049 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>