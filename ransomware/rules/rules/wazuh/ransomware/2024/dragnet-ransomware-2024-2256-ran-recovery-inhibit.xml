<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2256 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 4a280879-3976-5915-9673-2a4b3f82a89f -->
  <rule id="328087" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2256 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>