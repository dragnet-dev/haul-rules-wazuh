<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4956 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 93fc1a2e-8d69-59f5-bc75-be356405b07e -->
  <rule id="349626" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4956 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>