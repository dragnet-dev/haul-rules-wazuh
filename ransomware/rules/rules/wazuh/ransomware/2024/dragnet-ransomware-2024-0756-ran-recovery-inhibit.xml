<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0756 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: f74ef5fe-554a-5ddf-b594-1f00a7ffe1f3 -->
  <rule id="531835" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0756 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>