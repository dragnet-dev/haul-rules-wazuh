<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2198 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 68b65edd-143c-57a7-8189-8f67546b44bb -->
  <rule id="959454" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2198 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>