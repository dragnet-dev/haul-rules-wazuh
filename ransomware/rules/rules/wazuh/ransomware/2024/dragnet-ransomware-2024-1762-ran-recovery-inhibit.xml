<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1762 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0f2e8bc6-eb53-50bf-808d-1914b78de792 -->
  <rule id="963996" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1762 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>