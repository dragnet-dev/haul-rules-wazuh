<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5794 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 570388ca-bd6e-5a69-8b32-03685f9eb8e4 -->
  <rule id="226220" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5794 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>