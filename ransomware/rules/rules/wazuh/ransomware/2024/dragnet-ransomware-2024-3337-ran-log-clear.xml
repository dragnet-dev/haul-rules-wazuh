<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3337 — Event Log Clearing (darkvault) | Status: experimental | Sigma ID: 96f44505-ad20-515c-b9c3-a8b3661d4d1b -->
  <rule id="751445" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3337 — Event Log Clearing (darkvault)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>