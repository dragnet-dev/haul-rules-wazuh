<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3454 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: c8c61de0-d2d6-510e-82e2-c251d87b12df -->
  <rule id="696989" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3454 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>