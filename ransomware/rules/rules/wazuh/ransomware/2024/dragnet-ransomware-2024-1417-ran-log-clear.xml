<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1417 — Event Log Clearing (clop) | Status: experimental | Sigma ID: b4cc3c93-2da7-50c2-b2a3-20ce4bbcfe1e -->
  <rule id="302140" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1417 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>