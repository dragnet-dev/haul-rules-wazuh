<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0826 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 298fea03-ae7c-5170-a70f-161147998ec9 -->
  <rule id="424682" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0826 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>