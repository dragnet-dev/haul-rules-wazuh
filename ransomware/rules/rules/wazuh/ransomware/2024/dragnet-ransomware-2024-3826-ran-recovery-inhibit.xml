<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3826 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 52c11a2b-8789-5148-8b57-7fb5d717ed93 -->
  <rule id="550586" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3826 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>