<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2839 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: 97df952a-fc20-5b39-9ed0-3f46f0cf1743 -->
  <rule id="805595" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2839 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>