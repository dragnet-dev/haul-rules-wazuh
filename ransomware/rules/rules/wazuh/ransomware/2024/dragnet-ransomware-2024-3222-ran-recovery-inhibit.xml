<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3222 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: c7ea324b-cf93-5eae-9dd7-e5404f4801e3 -->
  <rule id="674632" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3222 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>