<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4424 — Recovery Inhibition (raworld) | Status: experimental | Sigma ID: 5b2cf2b2-35c4-59c2-9d1d-3aa81a0e5827 -->
  <rule id="636792" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4424 — Recovery Inhibition (raworld)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>