<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1099 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: ad26038a-b61e-5a82-b792-e620a940210d -->
  <rule id="932603" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1099 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>