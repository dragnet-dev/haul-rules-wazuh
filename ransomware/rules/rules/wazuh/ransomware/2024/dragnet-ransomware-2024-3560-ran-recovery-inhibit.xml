<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3560 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: fc329bb3-ce42-59a0-852d-f01c22315bb4 -->
  <rule id="537275" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3560 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>