<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5281 — Event Log Clearing (slug) | Status: experimental | Sigma ID: 64df4728-10dc-5ba4-b218-357bddf03854 -->
  <rule id="860747" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5281 — Event Log Clearing (slug)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>