<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1694 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 1795e051-fb4c-50f4-a8b5-459e17662a19 -->
  <rule id="273405" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1694 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>