<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2733 — Event Log Clearing (play) | Status: experimental | Sigma ID: d56ef9ce-9c04-5d9e-bb98-6df2b20777ec -->
  <rule id="873759" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2733 — Event Log Clearing (play)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>