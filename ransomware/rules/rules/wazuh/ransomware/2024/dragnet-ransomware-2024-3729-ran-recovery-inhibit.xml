<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3729 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 661f59a0-144a-52dd-a671-ec7fef2cb027 -->
  <rule id="259159" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3729 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>