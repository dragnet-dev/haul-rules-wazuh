<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3390 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 45f2a110-2753-52a9-a80f-d8b9d8c4c15f -->
  <rule id="376421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3390 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>