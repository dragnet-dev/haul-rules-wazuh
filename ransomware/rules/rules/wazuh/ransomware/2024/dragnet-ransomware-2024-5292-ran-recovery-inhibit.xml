<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5292 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 2b0c5e52-8948-5f0e-b76b-b2c7428d91dc -->
  <rule id="302814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5292 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>