<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3014 — Recovery Inhibition (play) | Status: experimental | Sigma ID: fa46ec8a-710a-5889-b626-7cff3686f8b4 -->
  <rule id="212012" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3014 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>