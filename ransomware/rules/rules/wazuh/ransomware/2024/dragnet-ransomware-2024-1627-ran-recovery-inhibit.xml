<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1627 — Recovery Inhibition (metaencryptor) | Status: experimental | Sigma ID: f6b4ca87-675a-5951-85da-35f544abb903 -->
  <rule id="219146" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1627 — Recovery Inhibition (metaencryptor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>