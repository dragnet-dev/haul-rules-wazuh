<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1315 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 2bb6600f-4238-52ef-aa94-c67f96b3ffb2 -->
  <rule id="796600" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1315 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>