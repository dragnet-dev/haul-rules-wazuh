<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2997 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e59bf22e-ac49-5f21-aef9-ef5a3a05fc43 -->
  <rule id="236952" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2997 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>