<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5182 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 89766276-d728-590c-b91a-9e20ae9773d9 -->
  <rule id="976627" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5182 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>