<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2420 — Recovery Inhibition (lockbit5) | Status: experimental | Sigma ID: e6560ee5-832b-5fb6-aae9-b079ebb2c50c -->
  <rule id="644974" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2420 — Recovery Inhibition (lockbit5)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>