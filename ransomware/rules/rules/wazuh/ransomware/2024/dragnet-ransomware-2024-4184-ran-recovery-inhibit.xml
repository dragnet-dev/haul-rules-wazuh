<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4184 — Recovery Inhibition (underground) | Status: experimental | Sigma ID: f8e97d85-4ee5-5f47-9034-d8eb62345e77 -->
  <rule id="568765" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4184 — Recovery Inhibition (underground)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>