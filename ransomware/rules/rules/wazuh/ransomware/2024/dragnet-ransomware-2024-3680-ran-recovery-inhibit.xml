<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3680 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 6b79c652-c39e-58cf-a1c9-be5430021a92 -->
  <rule id="924766" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3680 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>