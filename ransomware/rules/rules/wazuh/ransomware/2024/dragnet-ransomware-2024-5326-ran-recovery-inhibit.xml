<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5326 — Recovery Inhibition (funksec) | Status: experimental | Sigma ID: 938f3c53-5ac4-552d-846a-c85248219b5f -->
  <rule id="703740" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5326 — Recovery Inhibition (funksec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>