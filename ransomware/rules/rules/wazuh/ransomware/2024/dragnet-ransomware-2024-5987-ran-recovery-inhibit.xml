<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5987 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 384e8910-3f04-5217-8146-e40abfe758f5 -->
  <rule id="858891" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5987 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>