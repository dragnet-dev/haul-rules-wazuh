<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4043 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: f81fb14b-b4c7-57d9-b374-411bc79fdd1b -->
  <rule id="549871" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4043 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>