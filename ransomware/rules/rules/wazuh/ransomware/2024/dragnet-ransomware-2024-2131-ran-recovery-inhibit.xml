<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2131 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 960abad9-dd55-5031-8338-1fb7bbec3235 -->
  <rule id="434906" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2131 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>