<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1574 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 3f0ad20e-ffe3-574a-86ae-744279b26e47 -->
  <rule id="814532" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1574 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>