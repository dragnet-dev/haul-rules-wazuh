<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2274 — Recovery Inhibition (ElDorado) | Status: experimental | Sigma ID: 93920926-c7ed-546b-882e-b98602b4561e -->
  <rule id="492092" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2274 — Recovery Inhibition (ElDorado)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>