<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3692 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 0f9767a5-0903-5db1-a0b2-f8af8438b478 -->
  <rule id="856282" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3692 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>