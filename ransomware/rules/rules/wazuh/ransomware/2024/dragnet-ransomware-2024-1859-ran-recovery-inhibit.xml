<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1859 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 7c6da01c-0d3c-535a-a899-541579a5120a -->
  <rule id="591940" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1859 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>