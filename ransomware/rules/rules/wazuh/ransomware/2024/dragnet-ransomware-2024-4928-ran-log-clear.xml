<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4928 — Event Log Clearing (malekteam) | Status: experimental | Sigma ID: d387c833-0cec-5067-8f43-aa402ba7b567 -->
  <rule id="442048" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4928 — Event Log Clearing (malekteam)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>