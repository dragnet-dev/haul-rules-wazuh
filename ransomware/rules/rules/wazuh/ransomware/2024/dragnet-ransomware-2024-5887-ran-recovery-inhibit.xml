<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5887 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: ae9b92a3-165b-590c-a67a-5c17b4494acd -->
  <rule id="199592" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5887 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>