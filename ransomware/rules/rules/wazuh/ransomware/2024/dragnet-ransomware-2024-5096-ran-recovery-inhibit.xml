<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5096 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 00fb7ee6-c2ed-57c1-a18e-901beb4c41f8 -->
  <rule id="245906" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5096 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>