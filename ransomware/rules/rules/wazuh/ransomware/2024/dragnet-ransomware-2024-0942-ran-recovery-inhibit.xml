<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0942 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 64a4e337-967d-5c7e-8492-029ded3da995 -->
  <rule id="855183" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0942 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>