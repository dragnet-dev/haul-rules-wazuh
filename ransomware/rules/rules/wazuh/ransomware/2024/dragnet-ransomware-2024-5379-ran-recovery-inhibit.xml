<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5379 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 88c86b8c-2530-5828-b988-7ab3c2230dce -->
  <rule id="573387" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5379 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>