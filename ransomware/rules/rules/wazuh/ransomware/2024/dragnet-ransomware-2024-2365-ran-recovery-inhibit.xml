<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2365 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: a42a84a3-f124-58cf-adb8-e5a9c8afb3f1 -->
  <rule id="868284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2365 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>