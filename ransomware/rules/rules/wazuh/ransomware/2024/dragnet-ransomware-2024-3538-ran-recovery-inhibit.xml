<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3538 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 3d8ff407-97b8-5d99-af75-015ff65925c9 -->
  <rule id="784634" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3538 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>