<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3589 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: b0dfb459-5ed9-5302-8ffe-f2bab5ddf6f7 -->
  <rule id="141394" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3589 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>