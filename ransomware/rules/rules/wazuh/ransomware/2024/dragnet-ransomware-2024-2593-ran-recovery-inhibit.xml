<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2593 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: f869d169-680c-5833-85cb-d56cba117a59 -->
  <rule id="839171" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2593 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>