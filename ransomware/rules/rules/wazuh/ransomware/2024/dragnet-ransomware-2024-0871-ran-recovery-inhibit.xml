<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0871 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 92ebbd8a-2a36-5052-ad8f-1552441968b1 -->
  <rule id="789661" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0871 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>