<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2521 — Recovery Inhibition (incransom) | Status: experimental | Sigma ID: 6be60a93-0eb8-5a50-b94f-80948e56c172 -->
  <rule id="162570" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2521 — Recovery Inhibition (incransom)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>