<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0183 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: e290705b-0517-58c9-9f70-6b073566fe20 -->
  <rule id="629070" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0183 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>