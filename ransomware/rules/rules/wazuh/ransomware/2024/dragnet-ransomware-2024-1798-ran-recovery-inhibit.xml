<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1798 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 86004c50-0d71-536c-b448-adf22b138c87 -->
  <rule id="576076" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1798 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>