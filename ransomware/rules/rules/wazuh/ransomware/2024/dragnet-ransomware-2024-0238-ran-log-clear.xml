<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0238 — Event Log Clearing (sarcoma) | Status: deprecated | Sigma ID: 8d712360-b259-58cf-90dd-28094965e13c -->
  <rule id="617123" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0238 — Event Log Clearing (sarcoma)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>