<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0757 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 4a3a8262-956a-53b5-a790-022ec1e47a04 -->
  <rule id="389882" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0757 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>