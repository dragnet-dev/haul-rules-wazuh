<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2291 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 65894c28-15f3-507d-b074-9539ab0215a7 -->
  <rule id="254316" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2291 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>