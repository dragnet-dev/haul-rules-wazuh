<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2301 — Recovery Inhibition (handala) | Status: experimental | Sigma ID: 85b26c50-117f-54a7-af37-8a0e12f609c9 -->
  <rule id="494028" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2301 — Recovery Inhibition (handala)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>