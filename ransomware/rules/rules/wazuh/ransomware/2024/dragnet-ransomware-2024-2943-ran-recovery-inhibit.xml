<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2943 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 9cde6000-420c-599f-a9d1-49f24d4aff67 -->
  <rule id="515860" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2943 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>