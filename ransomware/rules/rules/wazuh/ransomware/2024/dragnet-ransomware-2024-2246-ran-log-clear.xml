<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2246 — Event Log Clearing (abyss) | Status: deprecated | Sigma ID: 95eeeaea-3a7d-5f64-87f1-bab290ae3a46 -->
  <rule id="987082" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2246 — Event Log Clearing (abyss)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>