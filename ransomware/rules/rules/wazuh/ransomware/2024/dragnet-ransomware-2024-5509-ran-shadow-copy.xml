<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5509 — Shadow Copy Deletion (dragonransomware) | Status: experimental | Sigma ID: 16561edb-a2be-5fd4-af4d-4df2a83fe4f7 -->
  <rule id="739853" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5509 — Shadow Copy Deletion (dragonransomware)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>