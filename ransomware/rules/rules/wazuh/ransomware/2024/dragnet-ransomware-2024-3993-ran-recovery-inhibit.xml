<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3993 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: f365a04d-35c1-5147-ad68-b098710bb1fa -->
  <rule id="758500" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3993 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>