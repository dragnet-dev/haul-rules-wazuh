<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2801 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: d3093f1c-d559-59b7-bbec-011600b121d8 -->
  <rule id="429503" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2801 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>