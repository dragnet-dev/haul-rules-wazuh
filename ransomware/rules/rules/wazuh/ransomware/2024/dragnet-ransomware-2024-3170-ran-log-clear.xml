<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3170 — Event Log Clearing (ciphbit) | Status: deprecated | Sigma ID: dc622e62-1960-56eb-811c-36a87365dd07 -->
  <rule id="929966" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3170 — Event Log Clearing (ciphbit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>