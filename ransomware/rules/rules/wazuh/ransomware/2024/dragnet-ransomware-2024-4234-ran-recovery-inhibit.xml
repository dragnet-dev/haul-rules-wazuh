<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4234 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: fde27162-7641-557c-8b3e-395e503e39ab -->
  <rule id="562271" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4234 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>