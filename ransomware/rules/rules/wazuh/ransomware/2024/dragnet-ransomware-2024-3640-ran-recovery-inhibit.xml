<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3640 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 46808a79-c189-5d69-8589-b6a391197bc7 -->
  <rule id="389387" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3640 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>