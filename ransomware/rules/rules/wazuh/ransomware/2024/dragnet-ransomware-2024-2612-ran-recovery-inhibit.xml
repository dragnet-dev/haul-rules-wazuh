<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2612 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c3ec74e3-6650-5f36-b0cd-bd9e94563287 -->
  <rule id="572474" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2612 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>