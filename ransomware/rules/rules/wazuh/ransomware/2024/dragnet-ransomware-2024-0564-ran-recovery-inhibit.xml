<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0564 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 064865b6-0dc9-5403-a88b-b2e466433a4b -->
  <rule id="237851" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0564 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>