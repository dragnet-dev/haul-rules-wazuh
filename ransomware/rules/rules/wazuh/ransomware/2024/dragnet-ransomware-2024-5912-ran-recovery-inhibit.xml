<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5912 — Recovery Inhibition (monti) | Status: experimental | Sigma ID: d1753508-2e47-5b23-acd1-a22b5633189a -->
  <rule id="517535" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5912 — Recovery Inhibition (monti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>