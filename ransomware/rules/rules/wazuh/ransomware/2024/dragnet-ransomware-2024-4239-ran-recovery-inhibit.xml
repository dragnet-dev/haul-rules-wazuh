<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4239 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: aadd3e0b-d0ea-5d2c-a428-57a7f5bb2fcb -->
  <rule id="798622" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4239 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>