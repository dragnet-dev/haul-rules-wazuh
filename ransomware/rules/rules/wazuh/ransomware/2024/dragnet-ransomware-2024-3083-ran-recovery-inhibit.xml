<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3083 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 95c408d2-c418-5afb-8453-f53a8d0235e3 -->
  <rule id="732408" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3083 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>