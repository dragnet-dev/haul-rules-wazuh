<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5882 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 739c7096-da2a-5af7-8b04-b7126f9cbc43 -->
  <rule id="383670" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5882 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>