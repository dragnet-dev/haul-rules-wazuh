<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5265 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: dc0fff86-d873-5ecf-b548-57c27d370c9e -->
  <rule id="115295" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5265 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
