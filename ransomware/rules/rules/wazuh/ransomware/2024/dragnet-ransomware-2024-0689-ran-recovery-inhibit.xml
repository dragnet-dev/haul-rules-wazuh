<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0689 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 820ef905-e689-578f-9d6e-81e6d33ed051 -->
  <rule id="401599" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0689 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>