<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3802 — Recovery Inhibition (helldown) | Status: experimental | Sigma ID: 854f92bd-3444-5bc6-93ec-e92d36523fc1 -->
  <rule id="567992" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3802 — Recovery Inhibition (helldown)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>