<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0259 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: bef70287-43de-5341-9bb1-675304f82b4b -->
  <rule id="455702" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0259 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>