<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1090 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: a76b8d2b-b618-5178-8bfc-87b1ac308ed8 -->
  <rule id="156461" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1090 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>