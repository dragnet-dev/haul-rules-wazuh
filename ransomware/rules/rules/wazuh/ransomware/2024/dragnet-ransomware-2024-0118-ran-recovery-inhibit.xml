<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0118 — Recovery Inhibition (darkvault) | Status: experimental | Sigma ID: 453e8318-27d9-5b95-ae38-52fa24a211af -->
  <rule id="162831" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0118 — Recovery Inhibition (darkvault)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>