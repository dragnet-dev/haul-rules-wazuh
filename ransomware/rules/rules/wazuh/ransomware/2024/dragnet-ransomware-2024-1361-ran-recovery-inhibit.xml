<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1361 — Recovery Inhibition (threeam) | Status: experimental | Sigma ID: eae70f65-83cc-5708-872f-4ea79ba57c59 -->
  <rule id="713935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1361 — Recovery Inhibition (threeam)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>