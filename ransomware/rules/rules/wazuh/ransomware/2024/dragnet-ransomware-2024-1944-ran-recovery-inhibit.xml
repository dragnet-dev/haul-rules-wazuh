<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1944 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: a2e20fdf-1edc-5af7-8600-69f1c0ac13d5 -->
  <rule id="933935" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1944 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>