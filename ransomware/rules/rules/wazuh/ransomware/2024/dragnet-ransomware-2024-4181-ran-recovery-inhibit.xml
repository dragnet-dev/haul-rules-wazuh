<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4181 — Recovery Inhibition (trinity) | Status: experimental | Sigma ID: 3f5cafce-1d52-52f4-a9b8-b763ef673126 -->
  <rule id="904207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4181 — Recovery Inhibition (trinity)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>