<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3790 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: fc5df778-78d2-517e-8aed-710be8cba0d1 -->
  <rule id="266237" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3790 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>