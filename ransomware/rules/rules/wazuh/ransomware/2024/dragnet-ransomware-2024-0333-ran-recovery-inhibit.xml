<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0333 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 0984ce03-493e-5393-a298-870e452a2c07 -->
  <rule id="821100" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0333 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>