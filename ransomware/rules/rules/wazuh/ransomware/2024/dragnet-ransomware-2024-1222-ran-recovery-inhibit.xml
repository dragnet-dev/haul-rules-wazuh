<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1222 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: f007565d-68b2-57e1-8591-aa5eb796347a -->
  <rule id="700756" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1222 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>