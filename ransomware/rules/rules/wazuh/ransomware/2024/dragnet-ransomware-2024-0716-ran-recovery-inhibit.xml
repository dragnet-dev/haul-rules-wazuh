<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0716 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: 18939fc0-c335-5f19-a324-d4bd2fab41b9 -->
  <rule id="448636" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0716 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>