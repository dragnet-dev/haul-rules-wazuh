<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4335 — Recovery Inhibition (dragonforce) | Status: deprecated | Sigma ID: bdf75b63-146c-5c62-be7d-5478af92b998 -->
  <rule id="463611" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4335 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>