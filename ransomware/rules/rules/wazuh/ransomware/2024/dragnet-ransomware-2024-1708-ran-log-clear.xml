<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1708 — Event Log Clearing (funksec) | Status: experimental | Sigma ID: 3c82d5f5-9d85-5f8a-9390-ef4257b36263 -->
  <rule id="372095" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1708 — Event Log Clearing (funksec)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>