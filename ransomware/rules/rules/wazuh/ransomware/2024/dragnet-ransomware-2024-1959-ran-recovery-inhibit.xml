<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1959 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 4b761049-eab2-5400-8ce9-15a9f5d431d5 -->
  <rule id="476104" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1959 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>