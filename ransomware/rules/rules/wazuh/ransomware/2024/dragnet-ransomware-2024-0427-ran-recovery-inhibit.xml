<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0427 — Recovery Inhibition (ElDorado) | Status: experimental | Sigma ID: 356aee90-f0a8-5b61-8e79-b70b612562f8 -->
  <rule id="660974" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0427 — Recovery Inhibition (ElDorado)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>