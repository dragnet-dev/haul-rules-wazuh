<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4519 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: a2051269-b105-5f49-a955-1887d53b454b -->
  <rule id="220512" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4519 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>