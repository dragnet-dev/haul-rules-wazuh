<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2399 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 8dae2c22-5478-540e-a5b3-c2568d728f09 -->
  <rule id="503244" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2399 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>