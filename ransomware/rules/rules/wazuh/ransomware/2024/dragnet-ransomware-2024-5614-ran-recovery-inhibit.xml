<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5614 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: bbb289ac-beed-56a0-96c9-aa2a14d07541 -->
  <rule id="403289" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5614 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>