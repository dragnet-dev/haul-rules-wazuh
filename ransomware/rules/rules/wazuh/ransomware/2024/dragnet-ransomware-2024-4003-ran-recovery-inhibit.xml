<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4003 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 536d284b-81ce-55e5-83b3-33fd96799c24 -->
  <rule id="589284" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4003 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>