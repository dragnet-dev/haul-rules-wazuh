<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2735 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: 8e66fe58-110f-5706-9cb4-66199f49392a -->
  <rule id="152350" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2735 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>