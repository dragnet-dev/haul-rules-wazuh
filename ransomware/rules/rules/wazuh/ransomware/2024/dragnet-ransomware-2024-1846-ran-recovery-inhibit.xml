<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1846 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: c2a1144f-793f-5f59-8680-9d91e7f4ebd5 -->
  <rule id="262114" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1846 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>