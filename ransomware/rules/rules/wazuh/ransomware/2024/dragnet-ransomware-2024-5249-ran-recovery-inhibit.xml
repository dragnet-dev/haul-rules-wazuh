<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5249 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 0ff5779f-8017-5880-a3cd-9bc91e469d26 -->
  <rule id="855779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5249 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>