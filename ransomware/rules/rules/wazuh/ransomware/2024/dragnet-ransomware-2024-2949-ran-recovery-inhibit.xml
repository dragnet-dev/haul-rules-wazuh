<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2949 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 2322befe-50e2-5868-9588-f6c4c1df6963 -->
  <rule id="613967" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2949 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>