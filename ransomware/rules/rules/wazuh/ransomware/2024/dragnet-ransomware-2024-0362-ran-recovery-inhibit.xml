<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0362 — Recovery Inhibition (ElDorado) | Status: experimental | Sigma ID: ccff87ae-d1c7-525b-a14c-2dfda3eb6642 -->
  <rule id="847987" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0362 — Recovery Inhibition (ElDorado)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>