<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2544 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4a9ed332-177a-5088-b765-cb3d8fdfa17f -->
  <rule id="219813" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2544 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>