<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4187 — Event Log Clearing (rhysida) | Status: experimental | Sigma ID: e4ac7e78-dd86-5c9c-becb-94c2820c4dd5 -->
  <rule id="625886" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4187 — Event Log Clearing (rhysida)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>