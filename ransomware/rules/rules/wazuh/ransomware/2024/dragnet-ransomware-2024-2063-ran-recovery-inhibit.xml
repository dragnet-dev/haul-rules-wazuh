  <rule id="562666" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2063 — Recovery Inhibition (cicada3301)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
