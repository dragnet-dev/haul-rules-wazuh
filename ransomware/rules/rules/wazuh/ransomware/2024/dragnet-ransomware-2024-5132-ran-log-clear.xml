<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5132 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: b41c67f0-0aa7-59c5-9b2a-e8bd3e97af5f -->
  <rule id="126867" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5132 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>