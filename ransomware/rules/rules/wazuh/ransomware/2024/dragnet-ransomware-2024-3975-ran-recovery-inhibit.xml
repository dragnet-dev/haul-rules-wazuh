<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3975 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 5b6c5fce-ff2f-5ad2-bdca-9ad270b6e2e6 -->
  <rule id="646975" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3975 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>