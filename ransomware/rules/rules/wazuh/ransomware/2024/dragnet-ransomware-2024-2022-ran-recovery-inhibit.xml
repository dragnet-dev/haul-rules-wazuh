<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2022 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 1e053dce-98cf-507e-9cf4-52b17dfe8ac3 -->
  <rule id="593788" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2022 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>