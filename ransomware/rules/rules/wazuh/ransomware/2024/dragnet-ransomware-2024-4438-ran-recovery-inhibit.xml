<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4438 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: a3b133f0-16ab-50d2-b642-910d8e47b902 -->
  <rule id="859133" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4438 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>