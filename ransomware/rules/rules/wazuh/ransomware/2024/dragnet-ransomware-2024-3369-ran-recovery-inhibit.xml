<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3369 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: e5bc9006-e508-51be-8726-4c1b2bfeaddb -->
  <rule id="230890" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3369 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>