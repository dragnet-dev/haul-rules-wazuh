<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5163 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 9c346f2d-0687-5879-968b-7af631b0a460 -->
  <rule id="801551" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5163 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>