<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3250 — Recovery Inhibition (play) | Status: experimental | Sigma ID: 8d991b2f-03ce-5800-856a-794f316aa10b -->
  <rule id="571867" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3250 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>