<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0126 — Recovery Inhibition (cloak) | Status: experimental | Sigma ID: 01a5e17c-53f5-57e7-9e43-6ac6b5211466 -->
  <rule id="606684" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0126 — Recovery Inhibition (cloak)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>