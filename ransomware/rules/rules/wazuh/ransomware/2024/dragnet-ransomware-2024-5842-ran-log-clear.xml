<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5842 — Event Log Clearing (dragonforce) | Status: deprecated | Sigma ID: 771d0fd2-5f23-539e-bc74-46ed79b552c1 -->
  <rule id="275855" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5842 — Event Log Clearing (dragonforce)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>