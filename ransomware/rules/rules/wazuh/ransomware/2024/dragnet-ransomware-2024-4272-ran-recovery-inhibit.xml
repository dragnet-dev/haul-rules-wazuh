<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4272 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 140d79b4-7667-5ff5-982d-6faa8c8a2c7a -->
  <rule id="106075" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4272 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>