<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4605 — Recovery Inhibition (meow) | Status: experimental | Sigma ID: 6493adad-1c87-510e-a794-d5b43723a3b9 -->
  <rule id="862381" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4605 — Recovery Inhibition (meow)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>