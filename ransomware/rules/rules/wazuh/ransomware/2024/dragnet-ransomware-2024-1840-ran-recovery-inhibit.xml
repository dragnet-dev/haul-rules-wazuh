<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1840 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 6d488eb0-353c-5070-81ce-ef34b17c1a78 -->
  <rule id="951822" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1840 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>