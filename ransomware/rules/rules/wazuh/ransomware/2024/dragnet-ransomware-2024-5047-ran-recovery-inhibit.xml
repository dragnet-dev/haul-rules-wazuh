<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5047 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 283e45e3-eafe-5c59-a49a-ef25557bb1e5 -->
  <rule id="167934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5047 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>