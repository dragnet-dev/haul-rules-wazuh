<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1057 — Event Log Clearing (medusa) | Status: experimental | Sigma ID: 0aee7e0a-25b0-5e76-a9c0-e51bc0b9666c -->
  <rule id="978060" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1057 — Event Log Clearing (medusa)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>