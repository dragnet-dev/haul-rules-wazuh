<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5809 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 8706b998-4da6-57c6-a42a-e6c296cfc1ee -->
  <rule id="593079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5809 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>