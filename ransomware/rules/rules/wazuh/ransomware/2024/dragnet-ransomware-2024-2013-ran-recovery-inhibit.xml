<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2013 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: a3293475-74a5-5401-83c9-980f0e39b889 -->
  <rule id="232934" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2013 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>