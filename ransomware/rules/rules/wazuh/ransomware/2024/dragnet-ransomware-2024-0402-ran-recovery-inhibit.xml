<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0402 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 06a158fd-63a5-54b7-a764-0a428db61337 -->
  <rule id="898543" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0402 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>