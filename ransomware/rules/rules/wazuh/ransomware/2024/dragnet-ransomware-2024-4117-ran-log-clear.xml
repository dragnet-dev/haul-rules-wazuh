<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4117 — Event Log Clearing (ransomhub) | Status: experimental | Sigma ID: 8c0a2dec-3499-58ce-81e3-f6d4fe5b378a -->
  <rule id="985645" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4117 — Event Log Clearing (ransomhub)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>