<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0925 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 307b799c-fab4-5ead-ba6c-ee205901d33f -->
  <rule id="523799" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0925 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
