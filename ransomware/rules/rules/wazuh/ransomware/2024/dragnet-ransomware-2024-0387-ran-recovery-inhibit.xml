<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0387 — Recovery Inhibition (spacebears) | Status: experimental | Sigma ID: efb7849a-5244-5b78-b62f-c799730a0aa2 -->
  <rule id="335784" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0387 — Recovery Inhibition (spacebears)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>