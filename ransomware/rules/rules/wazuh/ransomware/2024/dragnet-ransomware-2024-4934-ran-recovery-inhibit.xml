<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4934 — Recovery Inhibition (killsec) | Status: experimental | Sigma ID: 2ee1baa0-df71-5903-b5e8-b6ebee210bea -->
  <rule id="220442" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4934 — Recovery Inhibition (killsec)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>