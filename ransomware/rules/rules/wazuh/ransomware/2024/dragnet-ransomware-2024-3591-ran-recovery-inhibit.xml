<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3591 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 1efc28e6-c326-5c16-8772-b867059ec6b6 -->
  <rule id="191662" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3591 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>