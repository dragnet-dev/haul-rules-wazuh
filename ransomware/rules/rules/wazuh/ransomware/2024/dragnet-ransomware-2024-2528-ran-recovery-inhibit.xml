<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2528 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 757c387b-382b-56c7-87de-ddd9ea907eed -->
  <rule id="412438" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2528 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>