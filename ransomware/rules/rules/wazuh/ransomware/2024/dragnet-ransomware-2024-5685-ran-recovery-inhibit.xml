<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5685 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 4012e713-0fce-57a3-92e6-466f83deeab5 -->
  <rule id="220671" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5685 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>