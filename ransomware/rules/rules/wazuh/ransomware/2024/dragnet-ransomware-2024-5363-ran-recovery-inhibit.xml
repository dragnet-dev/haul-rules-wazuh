<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5363 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: e4b5306c-90ba-5bda-bf11-2cf160f8182f -->
  <rule id="615530" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5363 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>