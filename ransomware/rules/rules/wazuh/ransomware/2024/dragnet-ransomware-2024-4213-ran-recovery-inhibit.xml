<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4213 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 19f1b82c-3330-5b79-8523-0dffe65595b3 -->
  <rule id="706782" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4213 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>