<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3476 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: f6f6b4b9-5688-566b-aa16-9aed8a382c00 -->
  <rule id="518674" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3476 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>