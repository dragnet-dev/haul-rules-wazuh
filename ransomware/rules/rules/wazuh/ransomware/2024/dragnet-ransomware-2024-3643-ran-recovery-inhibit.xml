<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3643 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 51733cdc-92ca-5adb-87f2-f665a9bc548d -->
  <rule id="743853" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3643 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>