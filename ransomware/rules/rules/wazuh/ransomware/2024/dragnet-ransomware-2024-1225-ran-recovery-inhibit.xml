<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1225 — Recovery Inhibition (dAn0n) | Status: experimental | Sigma ID: dc2250c5-c140-5d1d-b1a1-0fca102e7576 -->
  <rule id="502250" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1225 — Recovery Inhibition (dAn0n)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>