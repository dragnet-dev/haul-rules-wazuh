<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1544 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: eb27740d-d179-537b-92e6-c7ef9356a1ef -->
  <rule id="652774" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1544 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>