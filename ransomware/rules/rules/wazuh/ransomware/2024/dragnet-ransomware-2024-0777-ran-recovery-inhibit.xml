<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0777 — Recovery Inhibition (cactus) | Status: experimental | Sigma ID: 9c5b9d05-4145-5092-8e21-6ba05287306a -->
  <rule id="508317" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0777 — Recovery Inhibition (cactus)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>