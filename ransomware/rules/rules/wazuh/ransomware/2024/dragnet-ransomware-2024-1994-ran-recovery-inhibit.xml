<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1994 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 5212359f-0f30-5bbe-9686-cc9815eed120 -->
  <rule id="812359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1994 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>