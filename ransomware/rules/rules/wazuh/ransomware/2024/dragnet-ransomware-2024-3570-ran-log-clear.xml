<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3570 — Event Log Clearing (darkvault) | Status: experimental | Sigma ID: 8fbebd83-2b6d-5255-8b35-4f23e1507b81 -->
  <rule id="520477" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3570 — Event Log Clearing (darkvault)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>