<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4587 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: fe09be54-5464-5e1d-b67c-d11c6fa59fb7 -->
  <rule id="304894" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4587 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>