<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0156 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: 7b88059a-a178-5369-8bbf-c71a45ce8162 -->
  <rule id="438805" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0156 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>