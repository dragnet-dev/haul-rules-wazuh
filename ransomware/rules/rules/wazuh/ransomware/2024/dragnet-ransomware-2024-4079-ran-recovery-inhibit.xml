<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4079 — Recovery Inhibition (madliberator) | Status: experimental | Sigma ID: 8d514bc7-d8d6-5cce-ab4d-9b7363a541f2 -->
  <rule id="564235" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4079 — Recovery Inhibition (madliberator)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>