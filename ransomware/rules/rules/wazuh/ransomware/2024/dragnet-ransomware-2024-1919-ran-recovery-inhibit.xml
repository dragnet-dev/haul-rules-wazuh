<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1919 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 61bc7609-9483-564a-b595-017ee1556c38 -->
  <rule id="780476" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1919 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>