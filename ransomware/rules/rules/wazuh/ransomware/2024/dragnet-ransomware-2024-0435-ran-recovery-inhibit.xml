<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0435 — Recovery Inhibition (rhysida) | Status: deprecated | Sigma ID: 500c899a-d767-577a-bb3e-fec8c78bbaeb -->
  <rule id="912899" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0435 — Recovery Inhibition (rhysida)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>