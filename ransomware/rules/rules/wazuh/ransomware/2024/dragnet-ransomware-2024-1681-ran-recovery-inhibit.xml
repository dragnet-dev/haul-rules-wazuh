<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1681 — Recovery Inhibition (BrainCipher) | Status: experimental | Sigma ID: b4a001b6-ebd8-595a-a838-9a4f9557bc34 -->
  <rule id="134001" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1681 — Recovery Inhibition (BrainCipher)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>