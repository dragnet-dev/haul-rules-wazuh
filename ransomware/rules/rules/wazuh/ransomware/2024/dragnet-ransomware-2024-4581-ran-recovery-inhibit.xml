<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4581 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: d09c4670-c289-5e01-bc43-9a72c9eab067 -->
  <rule id="395646" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4581 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>