<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2855 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 0c2c9aa8-89da-5adf-ae67-fa639a0800cc -->
  <rule id="630314" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2855 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>