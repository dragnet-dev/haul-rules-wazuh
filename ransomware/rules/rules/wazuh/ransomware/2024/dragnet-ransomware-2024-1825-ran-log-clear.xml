<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1825 — Event Log Clearing (lynx) | Status: experimental | Sigma ID: ad6f5534-4db2-50c4-96d1-b13db6734ddb -->
  <rule id="179155" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1825 — Event Log Clearing (lynx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>