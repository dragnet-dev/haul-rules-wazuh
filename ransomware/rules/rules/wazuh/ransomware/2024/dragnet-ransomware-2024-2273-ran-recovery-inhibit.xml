<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2273 — Recovery Inhibition (blacksuit) | Status: experimental | Sigma ID: d984a4d3-c8c6-5315-b1a5-ddad8e1373a0 -->
  <rule id="537544" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2273 — Recovery Inhibition (blacksuit)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>