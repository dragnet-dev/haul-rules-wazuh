<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5525 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 764e9c6f-ba55-5f93-8833-a0c608b7c82d -->
  <rule id="258236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5525 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
