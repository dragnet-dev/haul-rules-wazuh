<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2899 — Recovery Inhibition (blacklock) | Status: experimental | Sigma ID: bf3e28e8-6464-513c-bb9c-0f41aa2f1e86 -->
  <rule id="462228" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2899 — Recovery Inhibition (blacklock)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>