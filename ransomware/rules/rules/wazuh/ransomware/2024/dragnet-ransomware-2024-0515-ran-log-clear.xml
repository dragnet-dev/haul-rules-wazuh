<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0515 — Event Log Clearing (cloak) | Status: deprecated | Sigma ID: 2cb01e94-4f1a-5c53-878c-02e8f36f81a6 -->
  <rule id="344030" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0515 — Event Log Clearing (cloak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>