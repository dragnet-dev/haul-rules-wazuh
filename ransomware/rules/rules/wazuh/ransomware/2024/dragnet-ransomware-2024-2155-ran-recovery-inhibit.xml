<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2155 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: db676211-f859-5fe1-b74b-e66225d1090f -->
  <rule id="496762" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2155 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>