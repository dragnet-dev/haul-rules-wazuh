<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4932 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 472bc7d5-028a-5178-b33a-3ebec51da318 -->
  <rule id="410207" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4932 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>