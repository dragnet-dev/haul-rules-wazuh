<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0319 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: fc225e23-ff5f-59b4-90da-3a500aa05118 -->
  <rule id="535614" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0319 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>