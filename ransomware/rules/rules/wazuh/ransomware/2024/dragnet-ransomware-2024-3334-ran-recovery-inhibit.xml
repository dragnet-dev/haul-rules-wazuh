<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3334 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 0b5910f5-962b-5544-8ee6-20caeb8ab077 -->
  <rule id="154575" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3334 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>