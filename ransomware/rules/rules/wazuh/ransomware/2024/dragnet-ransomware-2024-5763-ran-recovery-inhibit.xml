<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5763 — Recovery Inhibition (dragonransomware) | Status: experimental | Sigma ID: 7712646c-0565-5a11-b4a0-88f2b790c2d3 -->
  <rule id="612646" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5763 — Recovery Inhibition (dragonransomware)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>