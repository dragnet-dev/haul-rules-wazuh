<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-2284 — Event Log Clearing (cloak) | Status: deprecated | Sigma ID: 3d9b8d8f-31d4-5a01-b9a9-d7a9dfcb7e6f -->
  <rule id="786541" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-2284 — Event Log Clearing (cloak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>