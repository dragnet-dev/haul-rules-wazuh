<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0828 — Recovery Inhibition (hunters) | Status: experimental | Sigma ID: 5190e995-5c57-5d85-a3c4-aa41986a996f -->
  <rule id="305499" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0828 — Recovery Inhibition (hunters)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>