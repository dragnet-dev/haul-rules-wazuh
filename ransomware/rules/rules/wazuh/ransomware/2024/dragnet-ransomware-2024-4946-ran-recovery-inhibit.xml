<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4946 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: c50edff4-6a42-585c-b414-5a3f849d12b4 -->
  <rule id="723807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4946 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>