<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0693 — Event Log Clearing (blacksuit) | Status: experimental | Sigma ID: cf02ec90-3b54-52e6-a16f-3dbb3f5c3d8a -->
  <rule id="899948" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0693 — Event Log Clearing (blacksuit)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>