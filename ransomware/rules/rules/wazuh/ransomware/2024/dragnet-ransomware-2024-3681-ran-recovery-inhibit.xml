<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3681 — Recovery Inhibition (medusa) | Status: experimental | Sigma ID: 61499fff-ea89-5d70-b6e1-763635cc825e -->
  <rule id="543999" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3681 — Recovery Inhibition (medusa)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>