<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3108 — Recovery Inhibition (everest) | Status: experimental | Sigma ID: 6ca9f95c-6dd2-5dd0-bd29-cd6bb3d69872 -->
  <rule id="182399" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3108 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>