<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5596 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 9612001c-3192-55d5-ac7c-d92af5ae9194 -->
  <rule id="712001" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5596 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>