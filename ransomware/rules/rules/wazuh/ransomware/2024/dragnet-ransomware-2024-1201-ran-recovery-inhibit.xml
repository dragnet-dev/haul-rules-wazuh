<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1201 — Recovery Inhibition (play) | Status: experimental | Sigma ID: b08bf7c0-7a78-53eb-abf5-2f378668d532 -->
  <rule id="238397" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1201 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>