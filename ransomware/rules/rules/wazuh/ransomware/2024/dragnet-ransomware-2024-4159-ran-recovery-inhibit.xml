<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4159 — Recovery Inhibition (arcusmedia) | Status: experimental | Sigma ID: 5e35ee62-dd4f-5f51-b831-09b318185aa1 -->
  <rule id="715598" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4159 — Recovery Inhibition (arcusmedia)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>