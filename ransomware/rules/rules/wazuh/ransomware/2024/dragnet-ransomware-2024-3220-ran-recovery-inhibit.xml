<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3220 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 6bc6ad76-e569-5ba3-bf74-c9b458a0a870 -->
  <rule id="915149" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3220 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>