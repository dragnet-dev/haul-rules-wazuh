<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4060 — Recovery Inhibition (lynx) | Status: experimental | Sigma ID: 28ddf48c-530d-5bf0-a319-7f0e357f71e9 -->
  <rule id="382394" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4060 — Recovery Inhibition (lynx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>