<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-3435 — Recovery Inhibition (apt73) | Status: experimental | Sigma ID: 1fb6f15a-a73e-599d-a84d-7376cb5f22cf -->
  <rule id="123115" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-3435 — Recovery Inhibition (apt73)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>