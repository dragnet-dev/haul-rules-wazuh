<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1740 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 586bb08e-63b4-5778-ad0d-02e992fa5baa -->
  <rule id="702030" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1740 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>