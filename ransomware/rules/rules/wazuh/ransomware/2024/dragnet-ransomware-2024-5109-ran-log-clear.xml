<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5109 — Event Log Clearing (darkvault) | Status: experimental | Sigma ID: 13474b46-f0fc-5b1c-bf3b-0d7a891b5714 -->
  <rule id="455954" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5109 — Event Log Clearing (darkvault)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>