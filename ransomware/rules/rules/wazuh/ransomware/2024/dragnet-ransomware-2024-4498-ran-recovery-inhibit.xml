<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4498 — Recovery Inhibition (play) | Status: experimental | Sigma ID: f0034a80-edfe-5eee-b7e7-5e981a363b9d -->
  <rule id="700554" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4498 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>