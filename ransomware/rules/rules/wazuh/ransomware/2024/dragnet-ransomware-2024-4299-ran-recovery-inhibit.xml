<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4299 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: 4c9df987-6d90-5f51-8e37-7f4632e52da2 -->
  <rule id="270879" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4299 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>