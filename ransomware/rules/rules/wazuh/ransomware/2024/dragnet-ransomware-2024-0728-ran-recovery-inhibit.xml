<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-0728 — Recovery Inhibition (dragonforce) | Status: experimental | Sigma ID: b61f1b80-53db-500e-812b-02c71598a084 -->
  <rule id="374587" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-0728 — Recovery Inhibition (dragonforce)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>