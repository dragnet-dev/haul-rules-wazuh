<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-4126 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: beaff77d-01a6-5bfa-88b1-f30f5e9c12bb -->
  <rule id="710557" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-4126 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>