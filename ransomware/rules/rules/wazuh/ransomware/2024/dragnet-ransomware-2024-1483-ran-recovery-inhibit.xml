<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1483 — Recovery Inhibition (blackbasta) | Status: experimental | Sigma ID: 161e8b64-4907-576b-aacd-1a98eb4abed9 -->
  <rule id="645396" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1483 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>