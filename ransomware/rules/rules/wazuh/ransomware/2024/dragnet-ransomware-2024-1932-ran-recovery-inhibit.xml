<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1932 — Recovery Inhibition (ransomhub) | Status: experimental | Sigma ID: aa2971a5-2892-5d28-8781-a9a39fe23c17 -->
  <rule id="902971" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1932 — Recovery Inhibition (ransomhub)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>