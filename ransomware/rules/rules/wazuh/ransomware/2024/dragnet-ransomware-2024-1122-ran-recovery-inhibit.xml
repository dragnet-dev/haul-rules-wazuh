<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-1122 — Recovery Inhibition (fog) | Status: experimental | Sigma ID: dc3e34d7-a23b-5324-bdf1-6c9dddfe3d04 -->
  <rule id="926234" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-1122 — Recovery Inhibition (fog)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>