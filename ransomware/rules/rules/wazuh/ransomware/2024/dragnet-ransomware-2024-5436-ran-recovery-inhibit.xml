<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2024-5436 — Recovery Inhibition (play) | Status: experimental | Sigma ID: edd06b74-c15c-5d0d-a5e6-b9df9e1fc349 -->
  <rule id="788107" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2024-5436 — Recovery Inhibition (play)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>