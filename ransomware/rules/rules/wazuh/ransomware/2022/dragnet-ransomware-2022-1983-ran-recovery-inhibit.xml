<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1983 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 875be59e-4446-5a67-98b3-518acca2d747 -->
  <rule id="541905" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1983 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
