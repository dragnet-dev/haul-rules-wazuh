<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2523 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 9073f7de-82db-5642-a393-254782c7f67f -->
  <rule id="651837" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2523 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>