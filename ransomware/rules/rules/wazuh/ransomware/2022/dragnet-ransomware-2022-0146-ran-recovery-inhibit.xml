<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0146 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: 53f886be-a46f-53fc-97a5-b8c61879e8a6 -->
  <rule id="422187" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0146 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>