<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1057 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 3fc94bb4-eea2-5b5c-98b1-9131e2827ab7 -->
  <rule id="833515" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1057 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>