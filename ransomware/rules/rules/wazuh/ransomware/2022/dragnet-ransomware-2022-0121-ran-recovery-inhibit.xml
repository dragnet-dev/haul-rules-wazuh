<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0121 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: ec117226-ce05-586a-8fbe-3c9ce9ae5cfc -->
  <rule id="661172" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0121 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
