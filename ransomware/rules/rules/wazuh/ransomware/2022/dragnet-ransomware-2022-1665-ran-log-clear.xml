<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1665 — Event Log Clearing (bianlian) | Status: deprecated | Sigma ID: a253412b-dbc3-5b56-8b27-1dc07f1c4e43 -->
  <rule id="225341" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1665 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>