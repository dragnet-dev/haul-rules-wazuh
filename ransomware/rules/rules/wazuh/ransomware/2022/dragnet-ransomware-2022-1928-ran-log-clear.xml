<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1928 — Event Log Clearing (ransomexx) | Status: experimental | Sigma ID: afc75a90-8929-5ab8-9d6c-8e21fa9a6c92 -->
  <rule id="100410" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1928 — Event Log Clearing (ransomexx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>