<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1198 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 35ea8ef6-f07f-5fa2-8124-421542a90eb5 -->
  <rule id="671182" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1198 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>