<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2331 — Recovery Inhibition (avoslocker) | Status: deprecated | Sigma ID: 86ec3696-826d-5340-a3d7-901cd436015c -->
  <rule id="525236" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2331 — Recovery Inhibition (avoslocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>