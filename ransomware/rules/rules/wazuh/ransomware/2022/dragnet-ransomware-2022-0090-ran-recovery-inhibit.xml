<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0090 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 4d3c06c6-463b-5c6f-83fa-60c9e18b0b35 -->
  <rule id="438006" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0090 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>