<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1298 — Recovery Inhibition (qilin) | Status: experimental | Sigma ID: 446e06ec-eb97-569b-b1c0-b363ff93bdce -->
  <rule id="740110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1298 — Recovery Inhibition (qilin)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>