<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2578 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 1c53b4fd-2a11-55ab-8f65-03e7bb81e88d -->
  <rule id="205519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2578 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>