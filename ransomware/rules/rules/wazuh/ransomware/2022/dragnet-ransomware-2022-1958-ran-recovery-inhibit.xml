<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1958 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 5dbe0772-97a9-5d75-8a06-9ad82d2eba93 -->
  <rule id="699807" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1958 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
