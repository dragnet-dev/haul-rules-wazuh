<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0101 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: c9494f04-487e-557b-a727-fac38c60e1df -->
  <rule id="371919" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0101 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>