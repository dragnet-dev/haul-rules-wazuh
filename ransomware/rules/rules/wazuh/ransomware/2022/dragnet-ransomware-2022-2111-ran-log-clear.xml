<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2111 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 9c2a5d71-bd0f-50b4-b19f-9f08718f71b5 -->
  <rule id="500413" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2111 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>