<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1676 — Recovery Inhibition (revil) | Status: deprecated | Sigma ID: baf3706b-74d3-5839-aeeb-64300b643c53 -->
  <rule id="391370" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1676 — Recovery Inhibition (revil)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>