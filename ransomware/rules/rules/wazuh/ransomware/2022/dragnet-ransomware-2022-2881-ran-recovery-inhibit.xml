<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2881 — Recovery Inhibition (onyx) | Status: deprecated | Sigma ID: 589469f7-b50e-51b8-9b27-96af3ff907f9 -->
  <rule id="531519" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2881 — Recovery Inhibition (onyx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
