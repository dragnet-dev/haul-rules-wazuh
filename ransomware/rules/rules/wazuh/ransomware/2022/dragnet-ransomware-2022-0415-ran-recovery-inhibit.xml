<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0415 — Recovery Inhibition (blackbyte) | Status: deprecated | Sigma ID: 84f7252c-9b88-58d6-aa7a-97269aba231a -->
  <rule id="559725" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0415 — Recovery Inhibition (blackbyte)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
