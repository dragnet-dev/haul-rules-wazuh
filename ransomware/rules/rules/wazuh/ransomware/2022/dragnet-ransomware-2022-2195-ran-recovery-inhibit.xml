<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2195 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 00b85d63-9da7-5bd5-8c67-78b30dbef6a0 -->
  <rule id="197363" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2195 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>