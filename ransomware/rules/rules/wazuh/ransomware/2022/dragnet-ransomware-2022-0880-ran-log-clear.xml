<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0880 — Event Log Clearing (everest) | Status: deprecated | Sigma ID: 5de2feb7-5a71-5d63-8ebc-91e4baf1eca1 -->
  <rule id="345886" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0880 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>