<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0425 — Recovery Inhibition (bianlian) | Status: experimental | Sigma ID: a5be79ca-c70d-5ab6-8a35-f0d6e5b7e60a -->
  <rule id="107079" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0425 — Recovery Inhibition (bianlian)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>