<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0266 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 60393bd3-c337-585f-8415-0169bd8f4209 -->
  <rule id="260797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0266 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>