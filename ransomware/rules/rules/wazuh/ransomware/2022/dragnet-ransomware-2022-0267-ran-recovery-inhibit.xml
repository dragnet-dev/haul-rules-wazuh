<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0267 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 5d2e319e-f65f-580c-80dd-d77fbdc04737 -->
  <rule id="692631" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0267 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>