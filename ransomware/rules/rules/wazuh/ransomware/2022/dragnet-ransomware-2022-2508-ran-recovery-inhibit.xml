<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2508 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 8eccad37-b76d-50e7-aaa9-9d6701524603 -->
  <rule id="458509" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2508 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
