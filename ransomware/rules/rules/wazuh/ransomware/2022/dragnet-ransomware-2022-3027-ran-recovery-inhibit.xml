<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3027 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 7d20ef5f-54fa-5d29-ba6f-c5941145bc23 -->
  <rule id="605359" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3027 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
