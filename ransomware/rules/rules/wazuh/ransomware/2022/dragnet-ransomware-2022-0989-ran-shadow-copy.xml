<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0989 — Shadow Copy Deletion (kelvinsecurity) | Status: deprecated | Sigma ID: c9578ef3-b0b1-5e25-b4b6-faa25b865f85 -->
  <rule id="373262" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0989 — Shadow Copy Deletion (kelvinsecurity)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>