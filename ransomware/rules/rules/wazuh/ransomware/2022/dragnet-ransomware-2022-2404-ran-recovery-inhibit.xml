<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2404 — Recovery Inhibition (cuba) | Status: deprecated | Sigma ID: 719ece1b-8aa4-5ebc-b7cd-a01dc22e522b -->
  <rule id="348814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2404 — Recovery Inhibition (cuba)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
