<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2509 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 2a8917ec-c767-518f-9ebd-39d93923d8c8 -->
  <rule id="662686" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2509 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>