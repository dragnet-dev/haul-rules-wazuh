<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1163 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 254006a8-5d72-55b1-a2db-2519f8d037a7 -->
  <rule id="564106" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1163 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>