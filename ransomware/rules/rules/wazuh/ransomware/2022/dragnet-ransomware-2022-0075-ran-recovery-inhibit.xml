<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0075 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 974298b7-52b6-5fcd-be27-9fe1e2658327 -->
  <rule id="388779" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0075 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>