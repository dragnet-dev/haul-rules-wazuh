<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2931 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 92a80f77-a5c8-5dee-bf45-326cf2c3a29e -->
  <rule id="672495" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2931 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>