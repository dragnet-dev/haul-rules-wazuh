<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1833 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 36949cbf-313f-5f7d-a1f3-556fc503d233 -->
  <rule id="559147" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1833 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>