<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2132 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 13b7fd8a-e58d-58be-ab2a-ad70fceca050 -->
  <rule id="326858" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2132 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>