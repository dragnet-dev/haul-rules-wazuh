<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1018 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 946a55fa-14f9-5805-811e-f63ceffab6ec -->
  <rule id="714655" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1018 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
