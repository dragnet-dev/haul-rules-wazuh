<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0313 — Recovery Inhibition (lockbit3) | Status: experimental | Sigma ID: 84e5a3de-62ab-5283-b006-2b8e714d76bd -->
  <rule id="473703" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0313 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>