<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1537 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: b9e7e53a-090e-5c3e-bff4-d1aeb4ea5791 -->
  <rule id="470065" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1537 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>