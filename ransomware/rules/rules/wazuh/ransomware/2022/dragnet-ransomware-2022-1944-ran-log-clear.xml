<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1944 — Event Log Clearing (icefire) | Status: deprecated | Sigma ID: e019c6f7-fe04-5920-b6e0-56a19c156573 -->
  <rule id="543166" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1944 — Event Log Clearing (icefire)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>