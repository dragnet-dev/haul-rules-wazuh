<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2054 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: ac5cb291-0d29-5aea-a4e3-78a1e60a46f0 -->
  <rule id="918032" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2054 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>