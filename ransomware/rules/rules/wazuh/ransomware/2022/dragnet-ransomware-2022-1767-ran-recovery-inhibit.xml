<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1767 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: c14e0433-7448-5ed5-8267-e9e817169a02 -->
  <rule id="243804" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1767 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>