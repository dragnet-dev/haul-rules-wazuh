<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2252 — Event Log Clearing (clop) | Status: experimental | Sigma ID: e1b46e7e-da4f-525d-9ef3-6f9b6a8eaf80 -->
  <rule id="127950" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2252 — Event Log Clearing (clop)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>