<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1587 — Event Log Clearing (vicesociety) | Status: deprecated | Sigma ID: c002a5a3-7e88-5aad-b7f1-9e5f61229471 -->
  <rule id="220425" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1587 — Event Log Clearing (vicesociety)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>