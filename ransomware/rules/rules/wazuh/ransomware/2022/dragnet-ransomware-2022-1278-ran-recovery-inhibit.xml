<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1278 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 806145bf-e12e-5c7e-a439-627a22ccc96a -->
  <rule id="398331" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1278 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>