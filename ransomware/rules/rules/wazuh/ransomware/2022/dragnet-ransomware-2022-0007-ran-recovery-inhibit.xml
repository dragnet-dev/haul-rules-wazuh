<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0007 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 4b004582-a519-554a-847b-967803bb2d75 -->
  <rule id="400458" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0007 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>