<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3105 — Event Log Clearing (yanluowang) | Status: deprecated | Sigma ID: 90bba121-cb87-5edf-b6f9-7797b5c5ad5c -->
  <rule id="216421" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3105 — Event Log Clearing (yanluowang)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>