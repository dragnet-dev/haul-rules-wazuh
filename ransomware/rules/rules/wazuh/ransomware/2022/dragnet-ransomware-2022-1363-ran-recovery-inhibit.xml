<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1363 — Recovery Inhibition (icefire) | Status: deprecated | Sigma ID: 99cf8802-750b-5c5b-9718-1407d520ced1 -->
  <rule id="855188" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1363 — Recovery Inhibition (icefire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>