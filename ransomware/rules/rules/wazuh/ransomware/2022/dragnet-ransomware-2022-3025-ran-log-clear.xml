<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3025 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: 1b8f4c22-d608-599e-9a2a-0329b0b21707 -->
  <rule id="941562" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3025 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>