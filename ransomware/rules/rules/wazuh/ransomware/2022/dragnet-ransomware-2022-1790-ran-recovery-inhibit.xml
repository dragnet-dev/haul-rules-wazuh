<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1790 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 68c21f9f-de38-514b-adbd-fb2bc4ab75f3 -->
  <rule id="960351" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1790 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>