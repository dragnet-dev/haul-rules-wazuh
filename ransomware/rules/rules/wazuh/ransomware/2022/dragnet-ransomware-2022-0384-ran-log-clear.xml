<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0384 — Event Log Clearing (karakurt) | Status: deprecated | Sigma ID: 45053a5e-b4f9-5351-afa5-f6f7a7d71b1a -->
  <rule id="108585" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0384 — Event Log Clearing (karakurt)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>