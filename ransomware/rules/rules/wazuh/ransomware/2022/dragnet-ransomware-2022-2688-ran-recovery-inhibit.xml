<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2688 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: d3defab9-8587-509b-a8f1-bbe555b3aadd -->
  <rule id="773370" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2688 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
