<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2494 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 4b81db29-4d95-5566-97e7-bab7657d716a -->
  <rule id="240955" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2494 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>