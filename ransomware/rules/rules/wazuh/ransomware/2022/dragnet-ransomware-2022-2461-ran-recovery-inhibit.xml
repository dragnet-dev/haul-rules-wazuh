<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2461 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: a9ad50a0-0601-5d70-b02d-230a9d2528f9 -->
  <rule id="207750" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2461 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>