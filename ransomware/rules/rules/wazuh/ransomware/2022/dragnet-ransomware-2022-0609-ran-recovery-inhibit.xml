<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0609 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 7dd1dedd-4467-5a53-a4db-12d0e76eb997 -->
  <rule id="753758" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0609 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>