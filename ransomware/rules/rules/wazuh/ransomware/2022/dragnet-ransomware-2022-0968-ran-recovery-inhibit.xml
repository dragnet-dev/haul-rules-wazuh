<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0968 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: c1db65ff-12f9-5030-a648-3e8b2588d224 -->
  <rule id="519565" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0968 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>