<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1204 — Event Log Clearing (avoslocker) | Status: deprecated | Sigma ID: b2cd210e-1ea2-5887-bf1c-8e4a161cb6c1 -->
  <rule id="287721" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1204 — Event Log Clearing (avoslocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>