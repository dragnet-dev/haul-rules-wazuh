<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2827 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 6b0feddd-3e19-55d5-8a57-ebecd0a2aac1 -->
  <rule id="886797" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2827 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>