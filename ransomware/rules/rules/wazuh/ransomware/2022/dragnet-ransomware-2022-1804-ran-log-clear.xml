<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1804 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: d4d9e64e-3e9c-5aec-a49f-6bec9dbc8edd -->
  <rule id="852786" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1804 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>