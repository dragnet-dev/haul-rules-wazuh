<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0442 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: b868c017-80e8-5ba0-8ac3-5d2958573e5e -->
  <rule id="199000" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0442 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>