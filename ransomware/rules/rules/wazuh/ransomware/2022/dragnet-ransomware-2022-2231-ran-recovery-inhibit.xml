<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2231 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: ba23f2da-e6e6-5b62-8d58-e968b25eddba -->
  <rule id="379832" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2231 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>