<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0518 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 5328e672-3c21-59b4-8a97-9230c1d889df -->
  <rule id="526267" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0518 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>