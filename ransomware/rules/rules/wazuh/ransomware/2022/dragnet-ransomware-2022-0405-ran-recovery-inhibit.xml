<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0405 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 10a59074-a054-5535-bf9b-84754a41088b -->
  <rule id="905907" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0405 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>