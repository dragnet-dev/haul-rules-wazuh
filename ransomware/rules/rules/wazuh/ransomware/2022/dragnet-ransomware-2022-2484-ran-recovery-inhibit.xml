<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2484 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 1d536392-6623-5be8-9377-2a2c1654b491 -->
  <rule id="353639" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2484 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>