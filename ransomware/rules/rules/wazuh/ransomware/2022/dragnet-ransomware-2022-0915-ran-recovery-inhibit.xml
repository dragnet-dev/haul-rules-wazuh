<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0915 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: c26fef60-edc8-50da-9df1-e665286160ff -->
  <rule id="625775" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0915 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
