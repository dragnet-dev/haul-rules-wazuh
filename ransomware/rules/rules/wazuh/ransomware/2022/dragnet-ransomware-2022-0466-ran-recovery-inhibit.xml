<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0466 — Recovery Inhibition (avoslocker) | Status: deprecated | Sigma ID: 53bf59b6-2ef9-5c83-b012-1619f26a2e3a -->
  <rule id="575959" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0466 — Recovery Inhibition (avoslocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>