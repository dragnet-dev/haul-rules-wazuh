<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2469 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 943df887-7bdd-52f1-ac86-4e840da47412 -->
  <rule id="716318" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2469 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>