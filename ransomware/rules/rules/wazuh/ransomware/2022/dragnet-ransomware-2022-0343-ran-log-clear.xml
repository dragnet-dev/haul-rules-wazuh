<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0343 — Event Log Clearing (blackbasta) | Status: deprecated | Sigma ID: eb841862-11e9-57f9-b6f7-f84f0dc80b8a -->
  <rule id="658418" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0343 — Event Log Clearing (blackbasta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>