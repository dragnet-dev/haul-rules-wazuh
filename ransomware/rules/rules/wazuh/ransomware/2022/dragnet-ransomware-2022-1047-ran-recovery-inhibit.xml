<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1047 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 349896a2-2cf3-5085-9c2f-81f58d32614c -->
  <rule id="298346" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1047 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>