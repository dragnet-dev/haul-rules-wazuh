<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1940 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: d9bacce2-dddd-587b-a1d2-47314f882ec5 -->
  <rule id="257324" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1940 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>