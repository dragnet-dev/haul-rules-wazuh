<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1012 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: 929fbda9-13eb-554e-84b2-a31862b7b61f -->
  <rule id="309213" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1012 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>