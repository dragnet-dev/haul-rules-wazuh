<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2189 — Recovery Inhibition (ransomhouse) | Status: deprecated | Sigma ID: fb38983c-dee6-56aa-b725-39f119b2ddce -->
  <rule id="813898" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2189 — Recovery Inhibition (ransomhouse)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
