<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2533 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: e7342a5b-77f6-5e2a-ba95-31dfabc7ca18 -->
  <rule id="657482" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2533 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>