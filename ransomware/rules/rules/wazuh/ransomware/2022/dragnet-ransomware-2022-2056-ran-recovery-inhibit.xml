<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2056 — Recovery Inhibition (8base) | Status: experimental | Sigma ID: 6987ecd0-56f4-508a-8f84-dc4555e421c3 -->
  <rule id="988908" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2056 — Recovery Inhibition (8base)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>