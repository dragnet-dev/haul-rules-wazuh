<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1978 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 3d243eaa-6f24-5896-bd80-adf9639d2afa -->
  <rule id="478442" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1978 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>