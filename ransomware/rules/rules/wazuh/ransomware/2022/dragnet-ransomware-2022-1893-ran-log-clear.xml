<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1893 — Event Log Clearing (ransomexx) | Status: experimental | Sigma ID: 1fa864c2-3c65-55b1-b7ef-7903f6de517d -->
  <rule id="109836" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1893 — Event Log Clearing (ransomexx)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>