<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0670 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: 1cd67639-66b1-5ed2-994b-5676502500ab -->
  <rule id="216763" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0670 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>