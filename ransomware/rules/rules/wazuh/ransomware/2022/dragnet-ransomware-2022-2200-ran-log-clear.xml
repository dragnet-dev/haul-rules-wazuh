<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2200 — Event Log Clearing (cheers) | Status: deprecated | Sigma ID: eef26089-4d25-5c96-901e-367a56a504ac -->
  <rule id="323260" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2200 — Event Log Clearing (cheers)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>