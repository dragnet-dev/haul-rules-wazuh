<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0570 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: f9a6cc92-57cc-5663-9c72-1a178bd2a92e -->
  <rule id="339980" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0570 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>