<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2262 — Recovery Inhibition (hive) | Status: deprecated | Sigma ID: de584036-2c83-5ea0-94f0-14831d8f2dc4 -->
  <rule id="525840" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2262 — Recovery Inhibition (hive)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>