<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1215 — Event Log Clearing (blackbyte) | Status: deprecated | Sigma ID: 9192e3f8-10e4-59e8-8209-b4d3579127d8 -->
  <rule id="670863" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1215 — Event Log Clearing (blackbyte)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>