<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0588 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: fc06e416-ddca-5a19-a439-71035f748e56 -->
  <rule id="533104" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0588 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>