<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1927 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 0143bb66-55fe-5491-8660-13ca60fe3640 -->
  <rule id="179566" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1927 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>