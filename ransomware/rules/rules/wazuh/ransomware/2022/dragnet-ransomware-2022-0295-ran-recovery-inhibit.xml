<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0295 — Recovery Inhibition (onyx) | Status: deprecated | Sigma ID: 61c74ddf-cc00-53e9-9403-6c104e9b8ec0 -->
  <rule id="781997" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0295 — Recovery Inhibition (onyx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
