<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2975 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: ab6a7f80-3464-5a97-96f9-2c15273c7669 -->
  <rule id="894687" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2975 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>