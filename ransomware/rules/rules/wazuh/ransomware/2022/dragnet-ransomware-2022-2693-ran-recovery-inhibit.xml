<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2693 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: b59478f8-f55b-5274-a7a6-e20da466da01 -->
  <rule id="359478" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2693 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>