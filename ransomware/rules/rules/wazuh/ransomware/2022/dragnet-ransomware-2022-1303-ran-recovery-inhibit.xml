<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1303 — Recovery Inhibition (dispossessor) | Status: experimental | Sigma ID: 694f2e93-a62f-5713-80e7-f7d8294160a0 -->
  <rule id="979086" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1303 — Recovery Inhibition (dispossessor)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>