<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2996 — Event Log Clearing (cheers) | Status: deprecated | Sigma ID: fb992528-6f63-501a-a56b-9c8723361ae4 -->
  <rule id="819925" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2996 — Event Log Clearing (cheers)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>