<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0567 — Event Log Clearing (monti) | Status: deprecated | Sigma ID: 51b9c1fa-5263-50eb-85e1-1ec6bb9fca6e -->
  <rule id="524761" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0567 — Event Log Clearing (monti)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>