<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2101 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 40eaa4ed-886a-572a-879e-dc3288f97064 -->
  <rule id="875944" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2101 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
