<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1517 — Event Log Clearing (everest) | Status: deprecated | Sigma ID: 68038ef4-91cb-59f2-82cf-eb2ebdc37d33 -->
  <rule id="288622" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1517 — Event Log Clearing (everest)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>