<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2900 — Event Log Clearing (sparta) | Status: deprecated | Sigma ID: bc506e23-ac7f-5424-b062-05b9163032d2 -->
  <rule id="416110" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2900 — Event Log Clearing (sparta)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>