<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2682 — Recovery Inhibition (onyx) | Status: deprecated | Sigma ID: fe2320c7-f318-508f-b374-5ac136695c2c -->
  <rule id="842320" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2682 — Recovery Inhibition (onyx)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
