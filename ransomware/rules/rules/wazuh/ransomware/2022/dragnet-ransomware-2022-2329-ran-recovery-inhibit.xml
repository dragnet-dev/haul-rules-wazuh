<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2329 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 08b50234-1a94-5088-8850-b831931cf843 -->
  <rule id="595023" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2329 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>