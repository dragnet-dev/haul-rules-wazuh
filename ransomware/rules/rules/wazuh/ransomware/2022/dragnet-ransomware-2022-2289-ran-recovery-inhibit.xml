<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2289 — Recovery Inhibition (conti) | Status: deprecated | Sigma ID: 2f4b50ef-2020-5525-8493-da1994d7ed7b -->
  <rule id="552814" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2289 — Recovery Inhibition (conti)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
