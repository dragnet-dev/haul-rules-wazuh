<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2851 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 97eaabb2-1f8c-5806-8cc9-edcc837420ed -->
  <rule id="217067" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2851 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>