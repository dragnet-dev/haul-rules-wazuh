<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0769 — Event Log Clearing (lockbit2) | Status: deprecated | Sigma ID: 3ceea896-9f9a-5d0f-949c-08bce2527a7b -->
  <rule id="795788" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0769 — Event Log Clearing (lockbit2)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>