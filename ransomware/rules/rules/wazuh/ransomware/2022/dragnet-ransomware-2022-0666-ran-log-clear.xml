<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0666 — Event Log Clearing (dispossessor) | Status: experimental | Sigma ID: 74e1a25e-24c1-5879-8175-9fa87e6b5ed7 -->
  <rule id="217062" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0666 — Event Log Clearing (dispossessor)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>