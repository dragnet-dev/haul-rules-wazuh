<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1022 — Event Log Clearing (darkleakmarket) | Status: deprecated | Sigma ID: f22b698e-e66f-54f5-a96e-8a03910c3b3a -->
  <rule id="736369" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1022 — Event Log Clearing (darkleakmarket)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>