<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1718 — Recovery Inhibition (everest) | Status: deprecated | Sigma ID: 54b84987-1096-5778-afe3-0ab86a84362c -->
  <rule id="758498" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1718 — Recovery Inhibition (everest)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>