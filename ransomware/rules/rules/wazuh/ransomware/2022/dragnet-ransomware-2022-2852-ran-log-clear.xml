<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2852 — Event Log Clearing (bianlian) | Status: deprecated | Sigma ID: cc3d81ec-2da4-5e04-b96a-ed2b9a5a229a -->
  <rule id="670181" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2852 — Event Log Clearing (bianlian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>