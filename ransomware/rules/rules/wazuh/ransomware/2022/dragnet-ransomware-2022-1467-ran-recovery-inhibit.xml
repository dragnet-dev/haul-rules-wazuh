<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1467 — Recovery Inhibition (suncrypt) | Status: deprecated | Sigma ID: 219ca40a-6da1-5245-a538-2ba8dfe38e5c -->
  <rule id="326640" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1467 — Recovery Inhibition (suncrypt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>