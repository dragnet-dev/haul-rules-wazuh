<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0312 — Event Log Clearing (ransomhouse) | Status: deprecated | Sigma ID: fb01eaf3-7e5c-5408-8e11-a855c3bb2d3a -->
  <rule id="226090" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0312 — Event Log Clearing (ransomhouse)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>