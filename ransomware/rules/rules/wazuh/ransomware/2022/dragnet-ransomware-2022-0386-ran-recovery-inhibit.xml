<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0386 — Recovery Inhibition (ragnarlocker) | Status: deprecated | Sigma ID: 688a85de-7064-5d7a-8d44-504285ba2207 -->
  <rule id="301885" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0386 — Recovery Inhibition (ragnarlocker)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>