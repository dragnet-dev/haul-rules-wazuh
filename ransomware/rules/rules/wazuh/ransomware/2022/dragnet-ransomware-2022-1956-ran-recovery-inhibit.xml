<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1956 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: b8f63341-a0bf-5b8b-86ab-accc5d5db4af -->
  <rule id="203633" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1956 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>