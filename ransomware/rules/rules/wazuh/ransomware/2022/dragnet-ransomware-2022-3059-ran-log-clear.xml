<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3059 — Event Log Clearing (kelvinsecurity) | Status: deprecated | Sigma ID: 9c0e604f-e23b-5139-ac30-c2fd85b031ea -->
  <rule id="797460" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3059 — Event Log Clearing (kelvinsecurity)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>