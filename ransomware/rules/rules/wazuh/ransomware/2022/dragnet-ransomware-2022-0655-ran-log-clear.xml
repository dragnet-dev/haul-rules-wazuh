<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0655 — Event Log Clearing (lockbit3) | Status: deprecated | Sigma ID: eb7c2c05-2ce6-5a5b-a297-31ae6de9aad5 -->
  <rule id="735884" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0655 — Event Log Clearing (lockbit3)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>