<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0835 — Event Log Clearing (unsafe) | Status: deprecated | Sigma ID: c1fddf73-4fb1-54d0-b40d-c8a941f1c481 -->
  <rule id="894847" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0835 — Event Log Clearing (unsafe)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>