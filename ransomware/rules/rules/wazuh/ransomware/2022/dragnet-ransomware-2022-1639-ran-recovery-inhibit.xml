<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1639 — Recovery Inhibition (icefire) | Status: deprecated | Sigma ID: 6c1915f1-428a-5b86-af2c-0ba2af8c0754 -->
  <rule id="281915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1639 — Recovery Inhibition (icefire)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>