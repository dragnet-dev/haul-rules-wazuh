<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1761 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: a7baf676-f0d2-5ab8-be11-4f6a2ae6337c -->
  <rule id="912636" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1761 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>