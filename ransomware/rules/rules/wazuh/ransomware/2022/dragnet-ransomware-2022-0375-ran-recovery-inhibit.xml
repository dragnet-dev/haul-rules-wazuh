<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0375 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: c688d43d-6559-5ee3-942c-cc35f60e98fe -->
  <rule id="330214" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0375 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
