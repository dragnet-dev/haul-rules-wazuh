<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3003 — Recovery Inhibition (stormous) | Status: deprecated | Sigma ID: 219f1770-06cc-594e-8d54-e1e97d000709 -->
  <rule id="919177" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3003 — Recovery Inhibition (stormous)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>