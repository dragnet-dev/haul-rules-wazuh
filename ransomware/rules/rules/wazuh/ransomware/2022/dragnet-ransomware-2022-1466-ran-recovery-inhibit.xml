<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1466 — Recovery Inhibition (karakurt) | Status: experimental | Sigma ID: aa934b1d-f4a5-5a36-8c48-4894081751db -->
  <rule id="134955" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1466 — Recovery Inhibition (karakurt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>