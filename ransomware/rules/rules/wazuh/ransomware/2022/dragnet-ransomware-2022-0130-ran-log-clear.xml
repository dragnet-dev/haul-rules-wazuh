<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0130 — Event Log Clearing (pandora) | Status: deprecated | Sigma ID: 592e3321-5fc9-5b5e-9b3e-8bc980410b77 -->
  <rule id="586332" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0130 — Event Log Clearing (pandora)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>