<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1442 — Event Log Clearing (ragnarlocker) | Status: experimental | Sigma ID: c365b27b-2ee5-59e7-ab55-69384d0d1a1f -->
  <rule id="278512" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1442 — Event Log Clearing (ragnarlocker)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>