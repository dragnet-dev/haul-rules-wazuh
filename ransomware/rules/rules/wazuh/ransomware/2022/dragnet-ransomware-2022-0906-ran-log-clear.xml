<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0906 — Event Log Clearing (dataleak) | Status: deprecated | Sigma ID: bf73d151-a47a-58b2-8bb7-42807d87dab0 -->
  <rule id="467811" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0906 — Event Log Clearing (dataleak)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>