<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0676 — Recovery Inhibition (lockbit3) | Status: deprecated | Sigma ID: 3a121fea-07f7-571e-8e5a-0044c24399a7 -->
  <rule id="579230" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0676 — Recovery Inhibition (lockbit3)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>