<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1168 — Event Log Clearing (stormous) | Status: deprecated | Sigma ID: 95cd7fa4-9496-5a41-ad7d-cb2214ff2c89 -->
  <rule id="424127" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1168 — Event Log Clearing (stormous)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>