<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0462 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: a19f4ec3-a325-5879-9907-b7f7051e7887 -->
  <rule id="911118" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0462 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>