<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2332 — Recovery Inhibition (suncrypt) | Status: deprecated | Sigma ID: 35688768-85a7-572c-80df-a7a4eff3f50f -->
  <rule id="968876" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2332 — Recovery Inhibition (suncrypt)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>