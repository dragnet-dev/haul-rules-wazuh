<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1891 — Event Log Clearing (freecivilian) | Status: deprecated | Sigma ID: 33e7a90b-4e89-5564-9a46-604671c7fc06 -->
  <rule id="684290" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1891 — Event Log Clearing (freecivilian)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>