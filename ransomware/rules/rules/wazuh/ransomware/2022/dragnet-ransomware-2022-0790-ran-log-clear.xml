<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0790 — Event Log Clearing (hive) | Status: deprecated | Sigma ID: 45ea2a96-b9b5-5a74-9619-4c8fd3e14d61 -->
  <rule id="180682" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0790 — Event Log Clearing (hive)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>