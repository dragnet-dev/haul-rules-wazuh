<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-2471 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: c77a630d-9c4d-5581-96ea-48246807cf04 -->
  <rule id="344263" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-2471 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>