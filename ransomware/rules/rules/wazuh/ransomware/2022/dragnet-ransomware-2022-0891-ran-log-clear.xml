<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0891 — Event Log Clearing (pandora) | Status: deprecated | Sigma ID: dac5db1f-8652-56cb-8c53-34fccd67e3bf -->
  <rule id="961499" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0891 — Event Log Clearing (pandora)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>