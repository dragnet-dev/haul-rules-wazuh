<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0971 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 1e6260c5-303d-5559-ba5b-8ce58b587861 -->
  <rule id="500172" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0971 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>