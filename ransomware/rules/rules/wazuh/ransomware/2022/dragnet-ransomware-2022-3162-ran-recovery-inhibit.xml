<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3162 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 15c05263-74f7-5b45-8ac0-30d05f8cf212 -->
  <rule id="820526" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3162 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>