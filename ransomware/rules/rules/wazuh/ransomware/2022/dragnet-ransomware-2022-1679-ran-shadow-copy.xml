<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1679 — Shadow Copy Deletion (kelvinsecurity) | Status: deprecated | Sigma ID: 88a2e898-85f4-5f6d-8439-22b1208c87f4 -->
  <rule id="569268" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1679 — Shadow Copy Deletion (kelvinsecurity)</description>
    <field name="process.args" type="pcre2">Get-WmiObject Win32_ShadowCopy</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2">^delete$|^shadows$</field>
    <field name="process.name" type="pcre2">\\vssadmin\.exe$</field>
    <field name="process.args" type="pcre2">^shadowcopy$|^delete$</field>
    <field name="process.name" type="pcre2">\\wmic\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>