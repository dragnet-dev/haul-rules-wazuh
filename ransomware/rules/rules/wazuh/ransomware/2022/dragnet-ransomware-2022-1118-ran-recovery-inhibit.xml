<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1118 — Recovery Inhibition (clop) | Status: experimental | Sigma ID: 220a3de1-8cd0-5b45-be3d-3718f2f98e31 -->
  <rule id="137790" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1118 — Recovery Inhibition (clop)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>