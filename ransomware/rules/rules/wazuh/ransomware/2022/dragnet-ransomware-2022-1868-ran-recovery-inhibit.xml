<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1868 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: 0712df1d-f6fe-5821-9801-4d610db3609a -->
  <rule id="124951" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1868 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>