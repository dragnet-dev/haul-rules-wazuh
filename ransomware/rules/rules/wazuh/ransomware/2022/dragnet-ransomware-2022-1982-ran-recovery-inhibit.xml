<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1982 — Recovery Inhibition (alphv) | Status: experimental | Sigma ID: bc5809de-edbd-5faa-84dd-c0dc5f7d485e -->
  <rule id="185809" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1982 — Recovery Inhibition (alphv)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>