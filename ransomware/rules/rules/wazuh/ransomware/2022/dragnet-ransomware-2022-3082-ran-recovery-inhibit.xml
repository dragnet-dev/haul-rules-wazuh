<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3082 — Recovery Inhibition (lockbit2) | Status: deprecated | Sigma ID: 83850040-777b-5453-9e84-0a1265e7feb4 -->
  <rule id="385004" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3082 — Recovery Inhibition (lockbit2)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>