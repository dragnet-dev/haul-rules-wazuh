<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-0646 — Event Log Clearing (cuba) | Status: deprecated | Sigma ID: 4d8e10e2-6d39-50a6-94e9-3a912bcfaf25 -->
  <rule id="446210" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-0646 — Event Log Clearing (cuba)</description>
    <field name="process.args" type="pcre2">Clear-EventLog</field>
    <field name="process.name" type="pcre2">\\powershell\.exe$|\\pwsh\.exe$</field>
    <field name="process.args" type="pcre2"> cl | clear-log </field>
    <field name="process.name" type="pcre2">\\wevtutil\.exe$</field>
    <mitre>
      <id>T1070.001</id>
    </mitre>
  </rule>
</group>