<?xml version="1.0" encoding="UTF-8"?>
<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-1932 — Recovery Inhibition (blackbasta) | Status: deprecated | Sigma ID: ed8605f1-9037-52cf-83ce-f7bd7f2cdf3e -->
  <rule id="678605" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-1932 — Recovery Inhibition (blackbasta)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>