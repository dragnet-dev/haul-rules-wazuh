<group name="dragnet,supply_chain">
  <!-- Dragnet [Ransomware]: dragnet-ransomware-2022-3127 — Recovery Inhibition (kelvinsecurity) | Status: deprecated | Sigma ID: 4c2acbd2-374a-5c01-95a4-d28175236da6 -->
  <rule id="523915" level="10">
    <description>Dragnet [Ransomware]: dragnet-ransomware-2022-3127 — Recovery Inhibition (kelvinsecurity)</description>
    <field name="process.args" type="pcre2">recoveryenabled no|bootstatuspolicy ignoreallfailures</field>
    <field name="process.name" type="pcre2">\\bcdedit\.exe$</field>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>
</group>